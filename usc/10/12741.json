{"tag":"section","attrib":{"id":"idabadf0f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12741"},"text":null,"children":[{"tag":"num","attrib":{"value":"12741"},"text":"§ 12741.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement for service in an active status performed in the Selected Reserve of the Ready Reserve after eligibility for regular retirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabadf0f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12741/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Elect to Receive Reserve Retired Pay","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabadf0f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12741/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding the requirement in paragraph (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12731/a"},"text":"section 12731(a) of this title","children":[],"tail":" that a person may not receive retired pay under this chapter when the person is entitled, under any other provision of law, to retired pay or retainer pay, a person may elect to receive retired pay under this chapter, instead of receiving retired or retainer pay under chapter 65, 741, 841, or 941 of this title, if the person—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabadf0f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12741/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfies the requirements specified in paragraphs (1) and (2) of such section for entitlement to retired pay under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabadf0f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12741/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served in an active status in the Selected Reserve of the Ready Reserve after becoming eligible for retirement under chapter 65, 741, 841, or 941 of this title (without regard to whether the person actually retired or received retired or retainer pay under one of those chapters); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabadf0f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12741/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completed not less than two years of satisfactory service (as determined by the Secretary concerned) in such active status (excluding any period of active service).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabadf0fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12741/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary concerned may reduce the minimum two-year service requirement specified in paragraph (1)(C) in the case of a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabadf0fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12741/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completed at least one year of service in a position of adjutant general required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s314"},"text":"section 314 of title 32","children":[],"tail":" or in a position of assistant adjutant general subordinate to such a position of adjutant general; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabadf0fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12741/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failed to complete the minimum years of service solely because the appointment of the person to such position was terminated or vacated as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s324/b"},"text":"section 324(b) of title 32","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabadf0fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12741/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions To Effectuate Election","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As of the effective date of an election made by a person under subsection (a), the Secretary concerned shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabadf0fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12741/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminate the eligibility of the person to retire under chapter 65, 741, 841, or 941 of this title, if the person is not already retired under one of those chapters, and terminate entitlement of the person to retired or retainer pay under one of those chapters, if the person was already receiving retired or retainer pay under one of those chapters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabadf0ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12741/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a reserve commissioned officer, transfer the officer to the Retired Reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabadf100-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12741/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time and Form of Election","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An election under subsection (a) shall be made within such time and in such form as the Secretary concerned requires.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabadf101-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12741/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date of Election","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An election made by a person under subsection (a) shall be effective—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabadf102-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12741/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in paragraph (2)(B), as of the date on which the person attains the eligibility age applicable to the person under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12731/f"},"text":"section 12731(f) of this title","children":[],"tail":", if the Secretary concerned receives the election in accordance with this section within 180 days after that date; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabadf103-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12741/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on the first day of the first month that begins after the date on which the Secretary concerned receives the election in accordance with this section, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabadf104-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12741/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the receipt of the election is more than 180 days after the date on which the person attains the eligibility age applicable to the person under such section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabadf105-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12741/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person retires from service in an active status within that 180-day period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabadf106-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 653(a)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–164; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/a/31"},"text":"Pub. L. 107–107, div. A, title X, § 1048(a)(31)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1225"},"text":"115 Stat. 1225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tX/s1071/a/41"},"text":"Pub. L. 109–364, div. A, title X, § 1071(a)(41)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2400"},"text":"120 Stat. 2400","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tVI/s643/a"},"text":"Pub. L. 111–84, div. A, title VI, § 643(a)","children":[],"tail":"–(c), (e)(1), "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2366"},"text":"123 Stat. 2366","children":[],"tail":", 2367; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s809/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 809(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1840"},"text":"132 Stat. 1840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabadf107-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabadf108-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabadf109-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “chapter 65, 741, 841, or 941” for “chapter 65, 367, 571, or 867” in introductory provisions and in subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “chapter 65, 741, 841, or 941” for “chapter 65, 367, 571, or 867”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s643/e/1"},"text":"Pub. L. 111–84, § 643(e)(1)","children":[],"tail":", substituted “Retirement for service in an active status performed in the Selected Reserve of the Ready Reserve after eligibility for regular retirement” for “Retirement from active reserve service performed after regular retirement” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s643/a"},"text":"Pub. L. 111–84, § 643(a)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"Election of Reserve Retired Pay","children":[],"tail":".—A person who, after becoming entitled to retired or retainer pay under chapter 65, 367, 571, or 867 of this title, serves in an active status in a reserve component is entitled to retired pay under this chapter if—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the person would, but for paragraphs (3) and (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12731/a"},"text":"section 12731(a) of this title","children":[],"tail":", otherwise be entitled to retired pay under this chapter;"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the person elects under this section to receive retired pay under this chapter; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) the person’s service in an active status after having become entitled to retired or retainer pay under that chapter is determined by the Secretary concerned to have been satisfactory.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s643/b"},"text":"Pub. L. 111–84, § 643(b)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “terminate the person’s entitlement to retired or retainer pay under the applicable chapter of this title referred to in subsection (a); and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s643/c/1"},"text":"Pub. L. 111–84, § 643(c)(1)","children":[],"tail":", substituted “attains the eligibility age applicable to the person under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12731/f"},"text":"section 12731(f) of this title","children":[],"tail":"” for “attains 60 years of age”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s643/c/2"},"text":"Pub. L. 111–84, § 643(c)(2)","children":[],"tail":", substituted “attains the eligibility age applicable to the person under such section” for “attains 60 years of age”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" substituted “subsection (a)” for “subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" substituted “receive” for “received”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabadf10a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idabadf10b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabadf10c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 653(b)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–165, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/398/s1/dA"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12741"},"text":"Section 12741 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall take effect 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":"] and shall apply with respect to retired pay payable for months beginning on or after that effective date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
