{"tag":"section","attrib":{"id":"ida9825dda-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2483"},"text":null,"children":[{"tag":"num","attrib":{"value":"2483"},"text":"§ 2483.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissary stores: use of appropriated funds to cover operating expenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9825ddb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2483/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation of Agency and System","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this title, the operation of the Defense Commissary Agency and the defense commissary system shall be funded using such amounts as are appropriated for such purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9825ddc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2483/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operating Expenses of Commissary Stores","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Appropriated funds shall be used to cover the expenses of operating commissary stores and central product processing facilities of the defense commissary system. For purposes of this subsection, operating expenses include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9825ddd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2483/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Salaries and wages of employees of the United States, host nations, and contractors supporting commissary store operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9825dde-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2483/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Utilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9825ddf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2483/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Communications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9825de0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2483/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operating supplies and services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9825de1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2483/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Second destination transportation costs within or outside the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9825de2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2483/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any cost associated with above-store-level management or other indirect support of a commissary store or a central product processing facility, including equipment maintenance and information technology costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9825de3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2483/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advertising of commissary sales on materials available within commissary stores and at other on-base locations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9825de4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2483/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supplemental Funds for Commissary Operations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts appropriated to cover the expenses of operating the Defense Commissary Agency and the defense commissary system may be supplemented with additional funds from manufacturers’ coupon redemption fees, handling fees for tobacco products, and other amounts received as reimbursement for other support activities provided by commissary activities. Such appropriated amounts may also be supplemented with additional funds derived from improved management practices implemented pursuant to sections 2481(c)(3) and 2487(c) of this title and the variable pricing program implemented pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2484/i"},"text":"section 2484(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9825de5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXIV/s1401/i/1"},"text":"Pub. L. 98–525, title XIV, § 1401(i)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2619"},"text":"98 Stat. 2619","children":[],"tail":", § 2484; amended "},{"tag":"ref","attrib":{"href":"