{"tag":"section","attrib":{"id":"ida959c7f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2253"},"text":null,"children":[{"tag":"num","attrib":{"value":"2253"},"text":"§ 2253.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motor vehicles","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida959c7f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2253/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense and the Secretary of each military department may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida959c7f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2253/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for insurance of official motor vehicles in a foreign country when the laws of such country require such insurance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c7f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2253/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase right-hand drive passenger sedans at a cost of not more than $30,000 each.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida959c7f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2253/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hire of Passenger Vehicles","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts appropriated to the Department of Defense for operation and maintenance of the active forces may be used for the hire of passenger motor vehicles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida959c7f7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/370/s1/e/1"},"text":"Pub. L. 100–370, § 1(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-07-19"},"text":"July 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/845"},"text":"102 Stat. 845","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVIII/s805"},"text":"Pub. L. 105–85, div. A, title VIII, § 805","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1834"},"text":"111 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVIII/s814/a"},"text":"Pub. L. 112–81, div. A, title VIII, § 814(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1491"},"text":"125 Stat. 1491","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida959c7f8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida959c7f9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (a)(1) of this section and sections 2241(b) and 2242(1), (4) of this title are based on ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/212/tVII/s705"},"text":"Pub. L. 98–212, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-08"},"text":"Dec. 8, 1