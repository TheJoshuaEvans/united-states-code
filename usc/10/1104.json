{"tag":"section","attrib":{"id":"ida8916ee4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104"},"text":null,"children":[{"tag":"num","attrib":{"value":"1104"},"text":"§ 1104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sharing of health-care resources with the Department of Veterans Affairs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8916ee5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sharing of Health-Care Resources","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Health-care resources of the Department of Defense shall be shared with health-care resources of the Department of Veterans Affairs in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8111"},"text":"section 8111 of title 38","children":[],"tail":" or under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1535"},"text":"section 1535 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8916ee6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement From CHAMPUS Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Pursuant to an agreement entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8111"},"text":"section 8111 of title 38","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1535"},"text":"section 1535 of title 31","children":[],"tail":", the Secretary of a military department may reimburse the Secretary of Veterans Affairs from funds available for that military department for the payment of medical care provided under section 1079 or 1086 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8916ee7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Charges","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may prescribe by regulation a premium, deductible, copayment, or other charge for health care provided to covered beneficiaries under this chapter pursuant to an agreement entered into by the Secretary of a military department under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8111"},"text":"section 8111 of title 38","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1535"},"text":"section 1535 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8916ee8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of Services During War or National Emergency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Members of the armed forces on active duty during and immediately following a period of war, or during and immediately following a national emergency involving the use of the armed forces in armed conflict, may be provided health-care services by the Department of Veterans Affairs in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8111A"},"text":"section 8111A of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8916ee9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVII/s722/a"},"text":"Pub. L. 101–189, div. A, title VII, § 722(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1477"},"text":"103 Stat. 1477","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1052/14"},"text":"Pub. L. 102–484, div. A, title X, § 1052(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2499"},"text":"106 Stat. 2499","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/35/tII/s201/c/1"},"text":"Pub. L. 103–35, title II, § 201(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-05-31"},"text":"May 31, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/98"},"text":"107 Stat. 98","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tVII/s721/b"},"text":"Pub. L. 107–314, div. A, title VII, § 721(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2595"},"text":"116 Stat. 2595","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8916eea-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8916eeb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8916eec-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[