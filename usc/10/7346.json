urce (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3966(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3966(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3966(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1001.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1036.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1948-06-29/ch708"},"text":"June 29, 1948, ch. 708","children":[],"tail":", §§ 201, 301(a), "},{"tag":"html:a","attrib":{"href":"/us/stat/62/1084"},"text":"62 Stat. 1084","children":[],"tail":", 1087."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3966(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a), (b), (c) and (d), the word “maintain” is substituted for the word “establish”, since the lists have been established and are published annually.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Effective upon ","children":[{"tag":"date","attrib":{"date":"1948-06-29"},"text":"June 29, 1948","children":[],"tail":"” are omitted as executed. 10:1001 (last 12 words of 1st sentence, and last sentence) is omitted as no longer required, since, upon enactment of this title laws referring to the limited or unlimited retired list will be expressly repealed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b)(1) is substituted for the words “all commissioned officers and former commissioned officers of the Army of the United States * * * other than those of the Regular Army * * * heretofore or hereafter granted retirement pay under sections 456, 456a, and 1036a of this title, or any law hereafter enacted to provide retirement pay for commissioned officers other than those of the Regular Army”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “who is advanced to a commissioned grade” are substituted for the words “heretofore or hereafter retired under any provision of law who, by reason of service in temporary commissioned grades in the Army of the United States * * * or in any of the respective components thereof, are entitled to be retired with commissioned rank or grade”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsections (c) and (d) are inserted, since sections 3964 and 3965 of this title refer to service on the retired list as a warrant officer or enlisted member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaae597c7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaae597c8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":