{"tag":"section","attrib":{"id":"idaae597bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7346"},"text":null,"children":[{"tag":"num","attrib":{"value":"7346"},"text":"§ 7346.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retired lists","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaae597bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7346/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army shall maintain a retired list containing the name of each retired commissioned officer of the Regular Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaae597be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7346/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall maintain a retired list containing the name of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaae597bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7346/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each person entitled to retired pay under any law providing retired pay for commissioned officers of the Army, other than of the Regular Army; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaae597c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7346/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each retired warrant officer or enlisted member of the Army who is advanced to a commissioned grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaae597c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7346/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall maintain a retired list containing the name of each retired warrant officer of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaae597c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7346/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall maintain a retired list containing the name of each retired enlisted member of the Regular Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaae597c3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/231"},"text":"70A Stat. 231","children":[],"tail":", § 3966; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/101"},"text":"Pub. L. 85–861, § 1(101)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1489"},"text":"72 Stat. 1489","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tV/s512/d/1"},"text":"Pub. L. 100–180, div. A, title V, § 512(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1090"},"text":"101 Stat. 1090","children":[],"tail":"; renumbered § 7346, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/b/13"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(b)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href"