{"tag":"section","attrib":{"id":"ida92ee726-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2128"},"text":null,"children":[{"tag":"num","attrib":{"value":"2128"},"text":"§ 2128.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accession bonus for members of the program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida92ee727-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2128/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may offer a person who enters into an agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2122/a/2"},"text":"section 2122(a)(2) of this title","children":[],"tail":" an accession bonus of not more than $100,000 as part of the agreement."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92ee728-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2128/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relation to Other Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An accession bonus paid a person under this section is in addition to any other amounts payable to the person under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92ee729-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2128/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who receives an accession bonus under this section, but fails to comply with the agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2122/a/2"},"text":"section 2122(a)(2) of this title","children":[],"tail":" or to commence or complete the active duty obligation imposed by "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2123"},"text":"section 2123 of this title","children":[],"tail":", shall be subject to the repayment provisions of section 303a(e) or 373 of title 37."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida92ee72a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVI/s623/a"},"text":"Pub. L. 110–181, div. A, title VI, § 623(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/152"},"text":"122 Stat. 152","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVI/s618/a/1/F"},"text":"Pub. L. 115–91, div. A, title VI, § 618(a)(1)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1426"},"text":"131 Stat. 1426","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVI/s612"},"text":"Pub. L. 118–159, div. A, title VI, § 612","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1933"},"text":"138 Stat. 1933","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida92ee72b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida92ee72c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida92ee72d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 2128 to 2130 were renumbered sections 16201 to 16203 of this title, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida92ee72e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “$100,000” for “$20,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" inserted “or 373” before “of title 37”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida92ee72f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida92ee730-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVI/s623/c"},"text":"Pub. L. 110–181, div. A, title VI, § 623(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/152"},"text":"122 Stat. 152","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/181/dA/tVI/s623/c"},"text":"“The amendment made by subsection (a) [enacting this section] shall apply with respect to agreements entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2122/a/2"},"text":"section 2122(a)(2) of title 10","children":[],"tail":", United States Code, on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
