{"tag":"section","attrib":{"id":"ida82fc69c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s931a"},"text":null,"children":[{"tag":"num","attrib":{"value":"931a"},"text":"§ 931a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 131a. Subornation of perjury","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida82fc69d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s931a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter who induces and procures another person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82fc69e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s931a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take an oath; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc69f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s931a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to falsely testify, depose, or state upon such oath;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall, if the conditions specified in subsection (b) are satisfied, be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82fc6a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s931a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The conditions referred to in subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82fc6a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s931a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The oath is administered with respect to a matter for which such oath is required or authorized by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc6a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s931a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The oath is administered by a person having authority to do so.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc6a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s931a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon the oath, the other person willfully makes or subscribes a statement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc6a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s931a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The statement is material.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc6a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s931a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The statement is false.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc6a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s931a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the statement is made or subscribed, the person subject to this chapter and the other person do not believe that the statement is true.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida82fc6a7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLX/s5444"},"text":"Pub. L. 114–328, div. E, title LX, § 5444","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2956"},"text":"130 Stat. 2956","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida82fc6a8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida82fc6a9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida82fc6aa-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on ","children":[{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. No. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
