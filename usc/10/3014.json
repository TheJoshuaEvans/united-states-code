}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa030036-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3014 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7014"},"text":"section 7014 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 3014, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/158"},"text":"70A Stat. 158","children":[],"tail":", § 3013; "},{"tag":"date","attrib":{"date":"1958-08-06"},"text":"Aug. 6, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/599/s8/a"},"text":"Pub. L. 85–599, § 8(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/519"},"text":"72 Stat. 519","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/58"},"text":"Pub. L. 85–861, § 1(58)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1462"},"text":"72 Stat. 1462","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1964-08-14"},"text":"Aug. 14, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/88/426/tIII/s305/3"},"text":"Pub. L. 88–426, title III, § 305(3)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/422"},"text":"78 Stat. 422","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1967-12-01"},"text":"Dec. 1, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/90/168/s2/12"},"text":"Pub. L. 90–168, § 2(12)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/523"},"text":"81 Stat. 523","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/91/611/tII/s211/a"},"text":"Pub. L. 91–611, title II, § 211(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1829"},"text":"84 Stat. 1829","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1979-11-09"},"text":"Nov. 9, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/107/tVIII/s820/b"},"text":"Pub. L. 96–107, title VIII, § 820(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/819"},"text":"93 Stat. 819","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/98/94/tXII/s1212/c/1"},"text":"Pub. L. 98–94, title XII, § 1212(c)(1)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/687"},"text":"97 Stat. 687","children":[],"tail":"; renumbered § 3014, "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s501/a/2"},"text":"Pub. L. 99–433, title V, § 501(a)(2)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1034"},"text":"100 Stat. 1034","children":[],"tail":", related to Under Secretary and Assistant Secretaries of the Army, appointment, and duties, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/433/s501/a/5"},"text":"Pub. L. 99–433, § 501(a)(5)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 3014 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3015"},"text":"section 3015 of this title","children":[],"tail":" and subsequently repealed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa030037-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “section 4021(a) or 4022” for “section 4002(a) or 4003”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1806/b/5"},"text":"Pub. L. 116–283, § 1806(b)(5)","children":[],"tail":", transferred par. (9) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2302"},"text":"section 2302 of this title","children":[],"tail":" to this section, realigned margin, struck out par. (9) designation at beginning, and substituted “In this part, the term” for “The term” and “section 4002(a) or 4003” for “section 2371(a) or 2371b”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa030038-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa030039-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as an Effective Date of 2021 Amendment note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa03003a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Exemptions for Nontraditional Defense Contractors","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVIII/s1826"},"text":"Pub. L. 119–60, div. A, title XVIII, § 1826","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1249"},"text":"139 Stat. 1249","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tXVIII/s1826"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemption","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of contracts, subcontracts, or agreements of the Department of Defense, products and services provided by nontraditional defense contractors (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3014"},"text":"section 3014 of title 10","children":[],"tail":", United States Code) shall be exempt from the following requirements:"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 252.242–7006 of the Department of Defense Supplement to the Federal Acquisition Regulation, or successor regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 252.234–7002 of the Department of Defense Supplement to the Federal Acquisition Regulation, or successor regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 252.215–7002 of the Department of Defense Supplement to the Federal Acquisition Regulation, or successor regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 252.242–7004 of the Department of Defense Supplement to the Federal Acquisition Regulation, or successor regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 252.245–7003 of the Department of Defense Supplement to the Federal Acquisition Regulation, or successor regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 252.244–7001 of the Department of Defense Supplement to the Federal Acquisition Regulation, or successor regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 252.242–7005 of the Department of Defense Supplement to the Federal Acquisition Regulation, or successor regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 215.407 of the Department of Defense Supplement to the Federal Acquisition Regulation, or successor regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"“(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3702"},"text":"Section 3702 of title 10","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"“(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part 31 of the Federal Acquisition Regulation, or successor regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver and Reporting.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirement under subsection (a) may be waived or modified with respect to a product or service with a written determination approved by the head of the relevant contracting activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delegation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority to approve a written determination under paragraph (1) may only be delegated to a senior contracting official for the relevant contracting activity or a more senior official.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Partial application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"One or more of the requirements described in paragraphs (1) through (10) of subsection (a) may be applied to a contract, subcontract, or other agreement with a nontraditional defense contractor upon a written determination approved by the head of the relevant contracting activity that includes a justification explaining why application of such requirements is in the best interest of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after the date on which a waiver is issued under this section, the Secretary of Defense shall provide to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] a notice of the waiver, including with a discussion of efforts made to adapt the acquisition approach for the product or service with respect to which the such waiver was granted so that such waiver would not be necessary.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
