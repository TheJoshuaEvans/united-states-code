{"tag":"section","attrib":{"id":"ida82d5507-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s918"},"text":null,"children":[{"tag":"num","attrib":{"value":"918"},"text":"§ 918.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 118. Murder","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter who, without justification or excuse, unlawfully kills a human being, when such person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82d5508-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s918/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a premeditated design to kill;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d5509-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s918/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intends to kill or inflict great bodily harm;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d550a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s918/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is engaged in an act which is inherently dangerous to another and evinces a wanton disregard of human life; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d550b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s918/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is engaged in the perpetration or attempted perpetration of burglary, rape, rape of a child, sexual assault, sexual assault of a child, aggravated sexual contact, sexual abuse of a child, robbery, or aggravated arson;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is guilty of murder, and shall suffer such punishment as a court-martial may direct, except that if found guilty under clause (1) or (4), such person shall suffer death or imprisonment for life as a court-martial may direct, unless such person is otherwise sentenced in accordance with a plea agreement entered into between the parties under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s853a"},"text":"section 853a of this title","children":[],"tail":" (article 53a)."}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida82d550c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/72"},"text":"70A Stat. 72","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1066/b"},"text":"Pub. L. 102–484, div. A, title X, § 1066(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2506"},"text":"106 Stat. 2506","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s552/d"},"text":"Pub. L. 109–163, div. A, title V, § 552(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3263"},"text":"119 Stat. 3263","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s541/d/2"},"text":"Pub. L. 112–81, div. A, title V, § 541(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1410"},"text":"125 Stat. 1410","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tV/s531/d/2/B"},"text":"