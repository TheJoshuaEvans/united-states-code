{"tag":"section","attrib":{"id":"idaa8af475-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4705"},"text":null,"children":[{"tag":"num","attrib":{"value":"4705"},"text":"§ 4705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of contract cancellation or termination relating to remote or isolated installations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa8af476-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided by subsection (c), not later than 30 days before the date on which the Secretary of Defense or any other official of an element of the Department of Defense cancels or terminates a contract, the Secretary shall submit to Congress a notice of such cancellation or termination if such cancellation or termination involves a reduction in employment of not fewer than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa8af477-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4705/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 remote or isolated installation contractor employees; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8af478-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4705/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 employees of contractors, including remote or isolated installation contractor employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa8af479-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A notice described in subsection (a) shall include an assessment of the effect of such cancellation or termination on members of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa8af47a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4705/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa8af47b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4705/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may waive the requirements of subsection (a) with respect to the cancellation or termination of a contract if the Secretary determines that such waiver is in the interest of national security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8af47c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4705/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary waives the requirements of subsection (a) with respect to the cancellation or termination of a contract, the Secretary shall submit the notice required by such subsection with respect to such cancellation or termination not later than one week after such cancellation or termination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa8af47d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4705/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa8af47e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4705/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “remote or isolated installation” means a military installation (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2801"},"text":"section 2801 of this title","children":[],"tail":") that is a remote military installation, as determined by the Secretary pursuant to the policy required by section 565 of the National Defense Authorization Act for Fiscal Year 2022 ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1781b"},"text":"10 U.S.C. 1781b","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8af47f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4705/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “remote or isolated installation contractor employee” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa8af480-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4705/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an employee of a contractor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa8af481-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4705/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as such an employee, provides goods or services to a remote or isolated installation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa8af482-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4705/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resides in the same geographic area as such remote or isolated installation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa8af483-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVIII/s808"},"text":"Pub. L. 118–159, div. A, title VIII, § 808","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1977"},"text":"138 Stat. 1977","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa8af484-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa8af485-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaa8af486-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 565 of the National Defense Authorization Act for Fiscal Year 2022, referred to in subsec. (d)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s565"},"text":"section 565 of Pub. L. 117–81","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1781b"},"text":"section 1781b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
