{"tag":"section","attrib":{"id":"idaa222074-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405"},"text":null,"children":[{"tag":"num","attrib":{"value":"3405"},"text":"§ 3405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task order contracts: advisory and assistance services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa222075-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advisory and Assistance Services Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “advisory and assistance services” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/g"},"text":"section 1105(g) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa222076-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Award","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa222077-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the requirements of this section, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3406"},"text":"section 3406 of this title","children":[],"tail":", and other applicable law, the head of an agency may enter into a task order contract (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3401"},"text":"section 3401 of this title","children":[],"tail":") for procurement of advisory and assistance services."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa222078-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of an agency may enter into a task order contract for procurement of advisory and assistance services only under the authority of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa222079-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Contract Period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The period of a task order contract entered into under this section, including all periods of extensions of the contract under options, modifications, or otherwise, may not exceed five years unless a longer period is specifically authorized in a law that is applicable to such contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa22207a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content of Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The notice required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1708"},"text":"section 1708 of title 41","children":[],"tail":" and section 8(e) of the Small Business Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/e"},"text":"15 U.S.C. 637(e)","children":[],"tail":") shall reasonably and fairly describe the general scope, magnitude, and duration of the proposed task order contract in a manner that would reasonably enable a potential offeror to decide whether to request the solicitation and consider submitting an offer."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa22207b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Content of Solicitation and Contract.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa22207c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Solicitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The solicitation for the proposed task order contract shall include the information (regarding services) described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3403/b"},"text":"section 3403(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa22207d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A task order contract entered into under this section shall contain the same information that is required by paragraph (1) to be included in the solicitation of offers for that contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa22207e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multiple Awards.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa22207f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to make multiple awards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an agency may, on the basis of one solicitation, award separate task order contracts under this section for the same or similar services to two or more sources if the solicitation states that the head of the agency has the option to do so.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa222080-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content of solicitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, in the case of a task order contract for advisory and assistance services to be entered into under this section, the contract period is to exceed three years and the contract amount is estimated to exceed $10,000,000 (including all options), the solicitation shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa222081-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for a multiple award authorized under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa222082-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a statement that the head of the agency may also elect to award only one task order contract if the head of the agency determines in writing that only one of the offerers is capable of providing the services required at the level of quality required.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa222083-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (2) does not apply in the case of a solicitation for which the head of the agency concerned determines in writing that, because the services required under the task order contract are unique or highly specialized, it is not practicable to award more than one contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa222084-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract Modifications.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa222085-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Increase in scope, period, or maximum value of contract only by modification of contract","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A task order may not increase the scope, period, or maximum value of the task order contract under which the order is issued. The scope, period, or maximum value of the contract may be increased only by modification of the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa222086-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of competitive procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless use of procedures other than competitive procedures is authorized by an exception in subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3204"},"text":"section 3204 of this title","children":[],"tail":" and approved in accordance with subsection (e) of such section, competitive procedures shall be used for making such a modification."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa222087-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notice regarding the modification shall be provided in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1708"},"text":"section 1708 of title 41","children":[],"tail":" and section 8(e) of the Small Business Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/e"},"text":"15 U.S.C. 637(e)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa222088-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract Extensions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa222089-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When contract may be extended","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding the limitation on the contract period set forth in subsection (c) or in a solicitation or contract pursuant to subsection (f), a task order contract entered into by the head of an agency under this section may be extended on a sole-source basis for a period not exceeding six months if the head of such agency determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa22208a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the award of a follow-on contract has been delayed by circumstances that were not reasonably foreseeable at the time the initial contract was entered into; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa22208b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extension is necessary in order to ensure continuity of the receipt of services pending the award of, and commencement of performance under, the follow-on contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa22208c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limit of one extension","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A task order contract may be extended under the authority of paragraph (1) only once and only in accordance with the limitations and requirements of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa22208d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3405/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability to Certain Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not apply to a contract for the acquisition of property or services that includes acquisition of advisory and assistance services if the head of an agency entering into such contract determines that, under the contract, advisory and assistance services are necessarily incident to, and not a significant component of, the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa22208e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355/tI/s1004/a/1"},"text":"Pub. L. 103–355, title I, § 1004(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3251"},"text":"108 Stat. 3251","children":[],"tail":", § 2304b; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/b/13"},"text":"Pub. L. 111–350, § 5(b)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3843"},"text":"124 Stat. 3843","children":[],"tail":"; renumbered § 3405 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1820/d"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1820(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4192"},"text":"134 Stat. 4192","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/b/8/C"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(b)(8)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2133"},"text":"135 Stat. 2133","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa22208f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa222090-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa222091-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1820/d/1"},"text":"Pub. L. 116–283, § 1820(d)(1)","children":[],"tail":", (2), renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2304b"},"text":"section 2304b of this title","