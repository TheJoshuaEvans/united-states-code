","children":[],"tail":" which provided that no person would suffer any reduction in grade, rating, or pay, is omitted as executed. It pertained to personnel who, when the Hospital Corps was reorganized under the "},{"tag":"ref","attrib":{"href":"/us/act/1947-08-04/ch459"},"text":"Act of August 4, 1947, ch. 459","children":[],"tail":", §§ 301, 302, "},{"tag":"ref","attrib":{"href":"/us/stat/61/738"},"text":"61 Stat. 738","children":[],"tail":", were in grades and ratings prescribed by prior laws."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab1559b9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab1559ba-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8214, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/501"},"text":"70A Stat. 501","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/159"},"text":"Pub. L. 85–861, § 1(159)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1514"},"text":"72 Stat. 1514","children":[],"tail":", prescribed authorized strength of Regular Air Force in enlisted members on active duty, exclusive of officer candidates and aviation cadets, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tII/s202"},"text":"Pub. L. 96–513, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],