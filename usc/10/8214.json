{"tag":"section","attrib":{"id":"idab12e9b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8214"},"text":null,"children":[{"tag":"num","attrib":{"value":"8214"},"text":"§ 8214.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enlisted members: authority for transfer between Marine Corps and Hospital Corps of the Navy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary of the Navy, enlisted members of the Marine Corps are eligible for transfer to the Hospital Corps of the Navy, and enlisted members of the Hospital Corps are eligible for transfer to the Marine Corps.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab12e9b5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/375"},"text":"70A Stat. 375","children":[],"tail":", § 6014; renumbered § 8214, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/7"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1834"},"text":"132 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab12e9b6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab12e9b7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab12e9b8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail