{"tag":"section","attrib":{"id":"idab8ef680-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217"},"text":null,"children":[{"tag":"num","attrib":{"value":"10217"},"text":"§ 10217.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-dual status technicians","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab8ef681-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section and any other provision of law, a non-dual status technician is a civilian employee of the Department of Defense serving in a military technician position who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8ef682-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was hired as a technician before ","children":[{"tag":"date","attrib":{"date":"1997-11-18"},"text":"November 18, 1997","children":[],"tail":", under any of the authorities specified in subsection (b) and as of that date is not a member of the Selected Reserve or after such date has ceased to be a member of the Selected Reserve;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef683-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is employed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s709"},"text":"section 709 of title 32","children":[],"tail":" in a position designated under subsection (c) of that section and when hired was not required to maintain membership in the Selected Reserve; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef684-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is hired as a temporary employee pursuant to the exception for temporary employment provided by subsection (d) and subject to the terms and conditions of such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8ef685-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employment Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authorities referred to in subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8ef686-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s10216"},"text":"Section 10216 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef687-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s709"},"text":"Section 709 of title 32","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef688-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The requirements referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8401"},"text":"section 8401 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef689-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 8016 of the Department of Defense Appropriations Act, 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/61"},"text":"Public Law 104–61","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/109/654"},"text":"109 Stat. 654","children":[],"tail":"), and any comparable provision of law enacted on an annual basis in the Department of Defense Appropriations Acts for fiscal years 1984 through 1995."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef68a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any memorandum of agreement between the Department of Defense and the Office of Personnel Management providing for the hiring of military technicians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8ef68b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Permanent Limitations on Number","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8ef68c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total number of non-dual status technicians employed by the Army Reserve may not exceed 595 and by the Air Force Reserve may not exceed 90. If at any time the number of non-dual status technicians employed by the Army Reserve and Air Force Reserve exceeds the number specified in the limitation in the preceding sentence, the Secretary of Defense shall require that the Secretary of the Army or the Secretary of the Air Force, or both, take immediate steps to reduce the number of such technicians in order to comply with such limitation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef68d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total number of non-dual status technicians employed by the National Guard may not exceed 1,950. If at any time the number of non-dual status technicians employed by the National Guard exceeds the number specified in the limitation in the preceding sentence, the Secretary of Defense shall require that the Secretary of the Army or the Secretary of the Air Force, or both, take immediate steps to reduce the number of such technicians in order to comply with such limitation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef68e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual employed as a non-dual status technician as described in subsection (a)(3) shall not be considered a non-dual status technician for purposes of paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8ef68f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for Temporary Employment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8ef690-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s10218"},"text":"section 10218 of this title","children":[],"tail":", the Secretary of the Army or the Secretary of the Air Force may employ, for a period not to exceed two years, a person to fill a vacancy created by the mobilization of a military technician (dual status) occupying a position under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10216"},"text":"section 10216 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef691-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The duration of the temporary employment of a person in a military technician position under this subsection may not exceed the shorter of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab8ef692-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The period of mobilization of the military technician (dual status) whose vacancy is being filled by the temporary employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8ef693-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef694-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No person may be hired under the authority of this subsection after ","children":[{"tag":"date","attrib":{"date":"2013-01-06"},"text":"January 6, 2013","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8ef695-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conversion of Positions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8ef696-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No individual may be newly hired or employed, or rehired or reemployed, as a non-dual status technician for purposes of this section after ","children":[{"tag":"date","attrib":{"date":"2017-09-30"},"text":"September 30, 2017","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef697-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" By not later than ","children":[{"tag":"date","attrib":{"date":"2017-10-01"},"text":"October 1, 2017","children":[],"tail":", the Secretary of Defense shall convert all non-dual status technicians to positions filled by individuals who are employed under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3101"},"text":"section 3101 of title 5","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1601"},"text":"section 1601 of this title","children":[],"tail":" and are not military technicians."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef698-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a position converted under paragraph (2) for which there is an incumbent employee on ","children":[{"tag":"date","attrib":{"date":"2017-10-01"},"text":"October 1, 2017","children":[],"tail":", the Secretary shall fill that position, as converted, with the incumbent employee without regard to any requirement concerning competition or competitive hiring procedures."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef699-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10217/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any individual newly hired or employed, or rehired or employed, to a position required to be filled by reason of paragraph (1) shall be an individual employed in such position under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3101"},"text":"section 3101 of title 5","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1601"},"text":"section 1601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab8ef69a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tV/s523/a/1"},"text":"Pub. L. 105–85, div. A, title V, § 523(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1736"},"text":"111 Stat. 1736","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s523"},"text":"Pub. L. 106–65, div. A, title V, § 523","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/598"},"text":"113 Stat. 598","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title IV, § 414(c)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–94; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tIV/s414/d"},"text":"Pub. L. 107–314, div. A, title IV, § 414(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2527"},"text":"116 Stat. 2527","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tIV/s415"},"text":"Pub. L. 108–136, div. A, title IV, § 415","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1453"},"text":"117 Stat. 1453","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tV/s513"},"text":"Pub. L. 111–383, div. A, title V, § 513","children":[],"tail":", title X, § 1075(b)(53), "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4210"},"text":"124 Stat. 4210","children":[],"tail":", 4372; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/e/7"},"text":"Pub. L. 112–239, div. A, title X, § 1076(e)(7)","children":[],"tail":", (f)(45), "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1951"},"text":"126 Stat. 1951","children":[],"tail":", 1955; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tX/s1053/b/1"},"text":"Pub. L. 114–92, div. A, title X, § 1053(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/981"},"text":"129 Stat. 981","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tX/s1084/b"},"text":"Pub. L. 114–328, div. A, title X, § 1084(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2421"},"text":"130 Stat. 2421","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXVII/s1731/a/62"},"text":"Pub. L. 116–92, div. A, title XVII, § 1731(a)(62)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1816"},"text":"133 Stat. 1816","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab8ef69b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab8ef69c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idab8ef69d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 8016 of the Department of Defense Appropriations Act, 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/61"},"text":"Public Law 104–61","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/109/654"},"text":"109 Stat. 654","children":[],"tail":"), referred to in subsec. (b)(4), was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10101"},"text":"section 10101 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tV/s522/e"},"text":"Pub. L. 105–85, div. A, title V, § 522(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1735"},"text":"111 Stat. 1735","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab8ef69e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (e)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “shall be an individual” for “shall an individual”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" amended subsec. (e) generally. Prior to amendment, subsec. (e) related to phased-in termination of non-dual status positions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1076/f/45"},"text":"Pub. L. 112–239, § 1076(f)(45)","children":[],"tail":", substituted “considered” for “consider”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1076/e/7"},"text":"Pub. L. 112–239, § 1076(e)(7)","children":[],"tail":", substituted “after "},{"tag":"date","attrib":{"date":"2013-01-06"},"text":"January 6, 2013","children":[],"tail":"” for “after the end of the 2-year period beginning on the date of the enactment of this subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s513/a/1"},"text":"Pub. L. 111–383, § 513(a)(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1075/b/53"},"text":"Pub. L. 111–383, § 1075(b)(53)","children":[],"tail":", substituted “The” for “Effective "},{"tag":"date","attrib":{"date":"2007-10-01"},"text":"October 1, 2007","children":[],"tail":", the” and struck out “after the preceding sentence takes effect” after “If at any time”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s513/b"},"text":"Pub. L. 111–383, § 513(b)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s513/a/2"},"text":"Pub. L. 111–383, § 513(a)(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" substituted “may not exceed 595 and by the Air Force Reserve may not exceed 90” for “and Air Force Reserve may not exceed 175”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" substituted “The total number” for “Effective "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"October 1, 2002","children":[],"tail":", the total number” in first sentence and struck out “after the preceding sentence takes effect” after “If at any time” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"October 1, 2002","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2001-10-01"},"text":"October 1, 2001","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s523/b"},"text":"Pub. L. 106–65, § 523(b)","children":[],"tail":", struck out “military” after “status” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s523/a/1/A"},"text":"Pub. L. 106–65, § 523(a)(1)(A)","children":[],"tail":", struck out “military” after “non-dual status” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s523/a/1/B"},"text":"Pub. L. 106–65, § 523(a)(1)(B)","children":[],"tail":", added pars. (1) and (2) and struck out former pars. (1) and (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) was hired as a military technician before the date of the enactment of the National Defense Authorization Act for Fiscal Year 1998 under any of the authorities specified in subsection (c); and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) as of the date of the enactment of that Act is not a member of the Selected Reserve or after such date ceased to be a member of the Selected Reserve.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s523/a/2"},"text":"Pub. L. 106–65, § 523(a)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab8ef69f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab8ef6a0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s525"},"text":"Pub. L. 106–65, div. A, title V, § 525","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/600"},"text":"113 Stat. 600","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/65/dA/tV/s525"},"text":"“The amendments made by sections 523 and 524 [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s709"},"text":"section 709 of Title 32","children":[],"tail":", National Guard] shall take effect 180 days after the date of the receipt by Congress of the plan required by section 523(d) of the National Defense Authorization Act for Fiscal Year 1998 ("},{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Public Law 105–85","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/111/1737"},"text":"111 Stat. 1737","children":[],"tail":") [set out below] [plan received by Congress from Under Secretary of Defense, Personnel and Readiness on "},{"tag":"date","attrib":{"date":"1999-09-21"},"text":"Sept. 21, 1999","children":[],"tail":", see Cong. Rec., vol. 145, pt. 15, p. 21975, Ex. Comm. 4276] or a report by the Secretary of Defense providing an alternative proposal to the plan required by that section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab8ef6a1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan for Full Utilization of Military Technicians (Dual Status)","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tV/s523/d"},"text":"Pub. L. 105–85, div. A, title V, § 523(d)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1737"},"text":"111 Stat. 1737","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/85/dA/tV/s523/d"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan for Full Utilization of Military Technicians (Dual Status)","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":"], the Secretary of Defense shall submit to Congress a plan for ensuring that, on and after "},{"tag":"date","attrib":{"date":"2007-09-30"},"text":"September 30, 2007","children":[],"tail":", all military technician positions are held only by military technicians (dual status)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The plan shall provide for achieving, by ","children":[{"tag":"date","attrib":{"date":"2002-09-30"},"text":"September 30, 2002","children":[],"tail":", a 50 percent reduction, by conversion of positions or otherwise, in the number of non-dual status military technicians that are holding military technicians positions, as compared with the number of non-dual status technicians that held military technician positions as of "},{"tag":"date","attrib":{"date":"1997-09-30"},"text":"September 30, 1997","children":[],"tail":", as specified in the report under subsection (c) ["},{"tag":"ref","attrib":{"href":"/us/stat/111/1737"},"text":"111 Stat. 1737","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Among the alternative actions to be considered in developing the plan, the Secretary shall consider the feasibility and cost of each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Eliminating or consolidating technician functions and positions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contracting with private sector sources for the performance of functions performed by military technicians.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Converting non-dual status military technician positions to military technician (dual status) positions or to positions in the competitive service or, in the case of positions of the Army National Guard of the United States or the Air National Guard of the United States, to positions of State employment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Use of incentives to facilitate attainment of the objectives specified for the plan in paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall submit with the plan any recommendations for legislation that the Secretary considers necessary to carry out the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions for Categories of Military Technicians","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section [enacting this section]:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘non-dual status military technician’ has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s10217"},"text":"section 10217 of title 10","children":[],"tail":", United States Code, as added by subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘military technician (dual status)’ has the meaning given the term in section 10216(a) of such title.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
