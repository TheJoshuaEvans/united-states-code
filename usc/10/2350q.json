{"tag":"section","attrib":{"id":"ida9719549-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350q"},"text":null,"children":[{"tag":"num","attrib":{"value":"2350q"},"text":"§ 2350q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Execution of projects under the North Atlantic Treaty Organization Security Investment Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida971954a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Execute Projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the United States is designated as the Host Nation for purposes of executing a project under the North Atlantic Treaty Organization Security Investment Program (in this section referred to as the “Program”), the Secretary of Defense may accept such designation and carry out such project consistent with the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida971954b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project Funding","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may fund authorized expenditures of projects accepted under subsection (a) with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida971954c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350q/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contributions under subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida971954d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350q/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriations of the Department of Defense for the Program when directed by the North Atlantic Treaty Organization to apply amounts of such appropriations as part of the share of contributions of the United States for the Program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida971954e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350q/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any combination of amounts described in paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida971954f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350q/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Accept Contributions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9719550-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350q/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may accept contributions from the North Atlantic Treaty Organization and member nations of the North Atlantic Treaty Organization for the purpose of carrying out a project under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9719551-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350q/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contributions accepted under paragraph (1) shall be placed in an account established for the purpose of carrying out the project for which the funds were provided and shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9719552-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350q/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9719553-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350q/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If contributions are made under paragraph (1) as reimbursement for a project or portion of a project previously completed by the Department of Defense, such contributions shall be credited to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9719554-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350q/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriations used for the project or portion thereof, if such appropriations have not yet expired; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9719555-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350q/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriations for the Program, if the appropriations described in clause (i) have expired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9719556-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350q/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funding credited under subparagraph (A) shall merge with and remain available for the same purposes and duration as the appropriations to which credited.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9719557-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350q/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obligation Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The construction agent of the Department of Defense designated by the Secretary of Defense to execute a project under subsection (a) may recognize the North Atlantic Treaty Organization project authorization amounts as budgetary resources to incur obligations against for the purposes of executing the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9719558-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350q/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Insufficient Contributions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9719559-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350q/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the event that the North Atlantic Treaty Organization does not agree to contribute funding for all costs necessary for the Department of Defense to carry out a project under subsection (a), including necessary personnel costs of the construction agent designated by the Department of Defense, contract claims, and any conjunctive funding requirements that exceed the project authorization or standards of the North Atlantic Treaty Organization, the Secretary of Defense, upon determination that completion of the project is in the national interest of the United States, may fund such costs, and undertake such conjunctively funded requirements not otherwise authorized by law, using any unobligated funds available among funds appropriated for the Program for military construction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida971955a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350q/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use of funds under paragraph (1) from appropriations for the Program may be in addition to or in place of any other funding sources otherwise available for the purposes for which those funds are used.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida971955b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350q/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Expenditures Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “authorized expenditures” means project expenses for which the North Atlantic Treaty Organization has agreed to contribute funding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida971955c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dB/tXXV/s2503/a"},"text":"Pub. L. 116–283, div. B, title XXV, § 2503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4309"},"text":"134 Stat. 4309","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tX/s1081/a/29"},"text":"Pub. L. 117–81, div. A, title X, § 1081(a)(29)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1921"},"text":"135 Stat. 1921","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida971955d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida971955e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida971955f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" renumbered a second "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2350m"},"text":"section 2350m of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9719560-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9719561-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dB/s2003"},"text":"Pub. L. 116–283, div. B, § 2003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4295"},"text":"134 Stat. 4295","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dB/s2003"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Titles XXI through XXVII and title XXIX [see Tables for classification] shall take effect on the later of—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2020-10-01"},"text":"October 1, 2020","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
