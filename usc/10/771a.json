{"tag":"section","attrib":{"id":"ida8073022-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s771a"},"text":null,"children":[{"tag":"num","attrib":{"value":"771a"},"text":"§ 771a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition on discharge","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8073023-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s771a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsections (b) and (c), when an enlisted member of an armed force is discharged, the exterior articles of uniform in his possession that were issued to him, other than those that he may wear from the place of discharge to his home under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s772/d"},"text":"section 772(d) of this title","children":[],"tail":", shall be retained for military use."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8073024-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s771a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When an enlisted member of an armed force is discharged for bad conduct, undesirability, unsuitability, inaptitude, or otherwise than honorably—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8073025-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s771a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the exterior articles of uniform in his possession shall be retained for military use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8073026-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s771a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under such regulations as the Secretary concerned prescribes, a suit of civilian clothing and an overcoat when necessary, both to cost not more than $30, may be issued to him; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8073027-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s771a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if he would be otherwise without funds to meet his immediate needs, he may be paid an amount, fixed by the Secretary concerned, of not more than $25.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8073028-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s771a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When an enlisted member of the Army National Guard or the Air National Guard who has been called into Federal service is released from that service, the exterior articles of uniform in his possession shall be accounted for as property issued to the Army National Guard or the Air National Guard, as the case may be, of the State or territory, Puerto Rico, or the District of Columbia of whose Army National Guard or Air National Guard he is a member, as prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s708"},"text":"section 708 of title 32","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8073029-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/235/s8/1/A"},"text":"Pub. L. 90–235, § 8(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/763"},"text":"81 Stat. 763","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXII/s1234/a/1"},"text":"Pub. L. 100–456, div. A, title XII, § 1234(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2059"},"text":"102 Stat. 2059","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida807302a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida807302b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida807302c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" struck out “the Canal Zone,” after “Puerto Rico,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
