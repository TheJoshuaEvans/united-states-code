{"tag":"section","attrib":{"id":"idaa1fb026-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3377"},"text":null,"children":[{"tag":"num","attrib":{"value":"3377"},"text":"§ 3377.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability to Coast Guard and National Aeronautics and Space Administration; definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa1fb027-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3377/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This chapter does not apply to the Coast Guard or the National Aeronautics and Space Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa1fb028-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3377/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa1fb029-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3377/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “undefinitized contractual action” means a new procurement action entered into by the head of an agency for which the contractual terms, specifications, or price are not agreed upon before performance is begun under the action. Such term does not include contractual actions with respect to the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa1fb02a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3377/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Purchases in an amount not in excess of the amount of the simplified acquisition threshold.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa1fb02b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3377/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Special access programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa1fb02c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3377/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congressionally mandated long-lead procurement contracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa1fb02d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3377/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “qualifying proposal” means a proposal that contains sufficient information to enable the Department of Defense to conduct a meaningful audit of the information contained in the proposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa1fb02e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1819/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1819(a)","children":[],"tail":", (g), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4189"},"text":"134 Stat. 4189","children":[],"tail":", 4191.