{"tag":"section","attrib":{"id":"idaab11ac0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4983"},"text":null,"children":[{"tag":"num","attrib":{"value":"4983"},"text":"§ 4983.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaab11ac1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4983/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreements Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may enter into one or more agreements, each with an appropriate Federal or private entity, under which such entity may, under this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab11ac2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4983/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" process applications for loan guarantees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab11ac3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4983/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer repayment of loans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab11ac4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4983/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide any other services to the Secretary to administer this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab11ac5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4983/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The costs of such agreements shall be considered, for purposes of the special account established under section 4982(c), to be costs of administrative expenses of the Department of Defense that are attributable to the loan guarantee program under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaab11ac6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1033(a)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–259, § 2541b; renumbered § 4983 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1873/b"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1873(b)","children":[],"tail":", (c)(2), (e)(2), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4290"},"text":"134 Stat. 4290","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaab11ac7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaab11ac8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaab11ac9-3a6f-11f1-a5