{"tag":"section","attrib":{"id":"ida974061a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2387"},"text":null,"children":[{"tag":"num","attrib":{"value":"2387"},"text":"§ 2387.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract working dogs: requirement to transfer animals to 341st Training Squadron after service life","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida974061b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2387/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each contract entered into by the Secretary of Defense for the provision of a contract working dog shall require, and shall contain a contract term, that the dog be transferred to the 341st Training Squadron and assigned for veterinary screening and care in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2583"},"text":"section 2583 of this title","children":[],"tail":" after the service life of the dog has terminated as described in subsection (b) for reclassification as a military animal and placement for adoption in accordance with such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida974061c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2387/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service Life","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The service life of a contract working dog has terminated and the dog is available for transfer to the 341st Training Squadron pursuant to a contract under subsection (a) only if the contracting officer concerned has determined that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida974061d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2387/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the final contractual obligation of the dog preceding such transfer is with the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida974061e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2387/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dog cannot be used by another department or agency of the Federal Government due to age, injury, or performance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida974061f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2387/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract Working Dog","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “contract working dog” means a dog—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9740620-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2387/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that performs a service for the Department of Defense pursuant to a contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9740621-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2387/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is trained and kenneled by an entity that provides such a dog pursuant to such a contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9740622-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tIII/s342/a/1"},"text":"Pub. L. 114–328, div. A, title III, § 342(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2082"},"text":"130 Stat. 2082","children":[],"tail":", § 2410r; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIII/s372/f"},"text":"Pub. L. 116–92, div. A, title III, § 372(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1331"},"text":"133 Stat. 1331","children":[],"tail":"; renumbered § 2387, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1882/b"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1882(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4293"},"text":"134 Stat. 4293","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9740623-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9740624-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida9740625-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2387, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/45"},"text":"Pub. L. 85–861, § 1(45)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1458"},"text":"72 Stat. 1458","children":[],"tail":", related to limitation on procurement of table and kitchen equipment for officers’ quarters, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s833/b/4/A"},"text":"Pub. L. 114–328, div. A, title VIII, § 833(b)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2285"},"text":"130 Stat. 2285","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9740626-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2410r"},"text":"section 2410r of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" inserted “, and shall contain a contract term,” after “shall require” and “and assigned for veterinary screening and care in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2583"},"text":"section 2583 of this title","children":[],"tail":"” after “341st Training Squadron” and substituted “such section” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2583"},"text":"section 2583 of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9740627-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9740628-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
