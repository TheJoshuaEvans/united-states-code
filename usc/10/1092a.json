{"tag":"section","attrib":{"id":"ida88cb2f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1092a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1092a"},"text":"§ 1092a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons entering the armed forces: baseline health data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida88cb2f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1092a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall carry out a program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida88cb2f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1092a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to collect baseline health data from each person entering the armed forces, at the time of entry into the armed forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida88cb2f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1092a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for computerized compilation and maintenance of the baseline health data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida88cb2f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1092a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program under this section shall be designed to achieve the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida88cb2f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1092a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To facilitate understanding of how subsequent exposures related to service in the armed forces affect health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida88cb2fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1092a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To facilitate development of early intervention and prevention programs to protect health and readiness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida88cb2fb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVII/s733/a/1"},"text":"Pub. L. 108–375, div. A, title VII, § 733(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1997"},"text":"118 Stat. 1997","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida88cb2fc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida88cb2fd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida88cb2fe-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Time for Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVII/s733/a/3"},"text":"Pub. L. 108–375, div. A, title VII, § 733(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1998"},"text":"118 Stat. 1998","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/375/dA/tVII/s733/a/3"},"text":"“The Secretary of Defense shall implement the program required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1092a"},"text":"section 1092a of title 10","children":[],"tail":", United States Code (as added by paragraph (1)), not later than two years after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
