{"tag":"section","attrib":{"id":"idaabd0154-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6116"},"text":null,"children":[{"tag":"num","attrib":{"value":"6116"},"text":"§ 6116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stockpile management program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaabd0155-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy, acting through the Administrator and in consultation with the Secretary of Defense, shall carry out a program, in support of the stockpile stewardship program, to provide for the effective management, modernization, and replacement, as required, of the weapons in the nuclear weapons stockpile. The program shall have the following objectives:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabd0156-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6116/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To enhance the performance and reliability of the nuclear weapons stockpile of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabd0157-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6116/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To further reduce the likelihood of the resumption of underground nuclear weapons testing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabd0158-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6116/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To maintain the safety and security of the nuclear weapons stockpile.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabd0159-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6116/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To optimize the future size of the nuclear weapons stockpile.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabd015a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6116/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To reduce the risk of an accidental detonation of an element of the stockpile.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabd015b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6116/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To reduce the risk of an element of the stockpile being used by a person or entity hostile to the United States, its vital interests, or its allies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabd015c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the stockpile management program under subsection (a), the Secretary of Energy shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabd015d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6116/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any changes made to the stockpile shall be consistent with the objectives identified in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabd015e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6116/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any changes made to the stockpile consistent with the objectives identified in subsection (a) are carried out in a cost effective manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabd015f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6116/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any such changes made to the stockpile shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaabd0160-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6116/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be well understood and certifiable without the need to resume underground nuclear weapons testing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabd0161-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6116/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the design, certification, and production expertise resident in the nuclear security enterprise to fulfill current mission requirements of the existing stockpile; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabd0162-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6116/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop future generations of design, certification, and production expertise in the nuclear security enterprise to support the fulfillment of mission requirements of the future stockpile.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabd0163-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6116/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Budget","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In accordance with the requirements under section 6120, for each budget submitted by the President to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", the amounts requested for the program under this section shall be clearly identified in the budget justification materials submitted to Congress in support of that budget."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaabd0164-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1352"},"text":"139 Stat. 1352","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaabd0165-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaabd0166-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaabd0167-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6116, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/382"},"text":"70A Stat. 382","children":[],"tail":", provided that in computing length of service, no officer of the Navy or Marine Corps could be credited with service as a midshipman at the Naval Academy or as a cadet at the Military Academy, if he was appointed as a midshipman or cadet after "},{"tag":"date","attrib":{"date":"1913-03-04"},"text":"Mar. 4, 1913","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s971"},"text":"section 971 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/90/235/s6/a/2"},"text":"Pub. L. 90–235, § 6(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/761"},"text":"81 Stat. 761","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2524"},"text":"section 2524 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
