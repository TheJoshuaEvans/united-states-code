{"tag":"section","attrib":{"id":"idab3dca40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8679a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8679a"},"text":"§ 8679a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting with shipyards controlled by a foreign adversary country: prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense may not enter into any contract or other agreement with a shipyard determined by the Secretary of Defense to be under the ownership, control, or influence of a covered nation, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4872/f"},"text":"section 4872(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab3dca41-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tX/s1025"},"text":"Pub. L. 118–159, div. A, title X, § 1025","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2055"},"text":"138 Stat. 2055","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVII/s1701/a/36"},"text":"Pub. L. 119–60, div. A, title XVII, § 1701(a)(36)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1209"},"text":"139 Stat. 1209","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab3dca42-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab3dca43-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","child