tml:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1956 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"651(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"651(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"651(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50 App.:454(d)(3) (1st sentence, and less applicability to members of National Security Training Corps).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50 App.:454(d)(3) (2d sentence, and less applicability to members of National Security Training Corps).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50 App.:454(d)(3) (3d and last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1948-06-24/ch625/s4/d/3"},"text":"June 24, 1948, ch. 625, § 4(d)(3)","children":[],"tail":" (less 4th sentence, and less applicability to members of National Security Training Corps); added "},{"tag":"html:a","attrib":{"href":"/us/act/1951-06-19/ch144/s1/g"},"text":"June 19, 1951, ch. 144, § 1(g)","children":[],"tail":" (last par., less 4th sentence, and less applicability to members of National Security Training Corps), "},{"tag":"html:a","attrib":{"href":"/us/stat/65/79"},"text":"65 Stat. 79","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608/s813"},"text":"July 9, 1952, ch. 608, § 813","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/66/509"},"text":"66 Stat. 509","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “male” is inserted, since the source statute (Universal Military Training and Service Act (50 U.S.C. App. 451 et seq.)) applies only to male persons. The words “subsequent to the date of enactment of this paragraph [","children":[{"tag":"date","attrib":{"date":"1951-06-19"},"text":"June 19, 1951","children":[],"tail":"]” are omitted as executed. The words “becomes a member” are substituted for the words “is inducted, enlisted, or appointed * * * in”. The words “in the armed forces” are substituted for the words “on active training and service in the Armed Forces * * * and in a reserve component”. The last sentence is substituted for the words “or in training in the National Security Training Corps”. The words “under any provision of law” and “including the reserve components thereof” are omitted as surplusage."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “who is not a Reserve” are inserted, since the eight year obligation for Reserves is covered by subsection (a). The words “active duty” are substituted for the words “active training and service”. The last eight words are substituted for the words “and shall serve therein for the remainder of the period which he is required to serve under this paragraph”. The words “physically and mentally” and 50 App.:454(d)(3) (last 15 words of 2d sentence) are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In [former] subsection (c), the words “who is released from active duty” are inserted for clarity. The words “shall become a member” are substituted for the words “it shall be the duty of such person to enlist, enroll, or accept appointment in, or accept assignment to”. The words “there is a vacancy” are substituted for the words “enlistment, enrollment, or appointment in, or assignment to”. 50 App.:454(d)(3) (last sentence) is omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida7f68de5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida7f68de6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1958 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"651(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50 App.:454(d)(3) (2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1955-08-09/ch665/s3/a"},"text":"Aug. 9, 1955, ch. 665, § 3(a)","children":[],"tail":" (last sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/69/603"},"text":"69 Stat. 603","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “male” is inserted, since the source statute applies only to male persons. The words “subsequent to the date of enactment of the Reserve Forces Act of 1955” are omitted as executed. The words “becomes a member” are substituted for the words “is inducted, enlisted, or appointed . . . in”. The last sentence is substituted for the words “on active training and service . . . and in a reserve component”. The requirement of transfer to and service in a reserve component, after active training and service is covered by subsection (b) of this section. The words “under any provision of law” and “including the reserve components thereof” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7f68de7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7f68de8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s509/a/1"},"text":"Pub. L. 118–31, § 509(a)(1)","children":[],"tail":", inserted before period at end “or in the case of an unrestricted officer designated within a cyberspace occupational specialty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s509/a/2"},"text":"Pub. L. 118–31, § 509(a)(2)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" inserted comma after “3806(d)(1))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" struck out “of his armed force” after “reserve component”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" inserted “shall serve” before “in the armed forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3806/d/1"},"text":"50 U.S.C. 3806(d)(1)","children":[],"tail":")” for “(50 U.S.C. App. 456(d)(1)) shall serve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94"},"text":"Pub. L. 98–94","children":[],"tail":" amended subsec. (a) generally, substituting a reference to service in the armed forces for a total initial period of not less than six years nor more than eight years under prescribed regulations for the prior reference to service in the armed forces for a total of six years."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":", substituted “Secretary of Transportation” for “Secretary of the Treasury”, and “section 6(d)(1) of the Military Selective Service Act (50 U.S.C. App. 456(d)(1))” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t50/s456/d/1"},"text":"section 456(d)(1) of title 50","children":[],"tail":", appendix”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/107"},"text":"Pub. L. 96–107","children":[],"tail":" struck out “before his twenty-sixth birthday” after “force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/79"},"text":"Pub. L. 95–79","children":[],"tail":" struck out “male” after “Each” and “after "},{"tag":"date","attrib":{"date":"1955-08-09"},"text":"August 9, 1955","children":[],"tail":",” after “who”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/718"},"text":"Pub. L. 89–718","children":[],"tail":" struck out reference to persons who enlisted under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1013"},"text":"section 1013 of title 50","children":[],"tail":" in the description of persons not required to serve in the armed forces for a total of six years."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/12"},"text":"Pub. L. 85–861, § 1(12)","children":[],"tail":", restricted section to male persons who became members of the armed forces after "},{"tag":"date","attrib":{"date":"1955-08-09"},"text":"Aug. 9, 1955","children":[],"tail":", excluded persons enlisted under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1013"},"text":"section 1013 of Title 50","children":[],"tail":" or deferred under the next to last sentence of "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s456/d/1"},"text":"section 456(d)(1) of Title 50","children":[],"tail":", Appendix, reduced from eight to six years the required period of service, required any part of such service that is not active duty or is active duty for training to be performed in a reserve component, and struck out provisions which permitted members of the armed forces to count service in the National Security Training Corps as if it were service in the armed forces for the purposes of this subsection."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s36B/3"},"text":"Pub. L. 85–861, § 36B(3)","children":[],"tail":", repealed subsec. (c) which required members released from active duty to become members of an organized unit of a reserve component of an officers’ training program."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7f68de9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7f68dea-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7f68deb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/tX/s1022/b/2"},"text":"Pub. L. 98–94, title X, § 1022(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/671"},"text":"97 Stat. 671","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/94/tX/s1022/b/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall apply only with respect to persons who enter the Armed Forces 60 or more days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7f68dec-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/b/3"},"text":"section 701(b)(3) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"i