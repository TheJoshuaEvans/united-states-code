{"tag":"section","attrib":{"id":"ida9c50ce9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2708"},"text":null,"children":[{"tag":"num","attrib":{"value":"2708"},"text":"§ 2708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts for handling hazardous waste from defense facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9c50cea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9c50ceb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2708/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each contract or subcontract to which this section applies shall provide that, upon receipt of hazardous wastes properly characterized pursuant to applicable laws and regulations, the contractor or subcontractor will reimburse the Federal Government for all liabilities incurred by, penalties assessed against, costs incurred by, and damages suffered by, the Government that are caused by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9c50cec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2708/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contractor’s or subcontractor’s breach of any term or provision of the contract or subcontract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9c50ced-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2708/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any negligent or willful act or omission of the contractor or subcontractor, or the employees of the contractor or subcontractor, in the performance of the contract or subcontract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c50cee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2708/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 30 days after such a contract or subcontract is awarded, the contractor or subcontractor shall demonstrate that the contractor or subcontractor will reimburse the Federal Government as provided in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c50cef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9c50cf0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2708/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), this section applies to each contract entered into by the Secretary of Defense or the Secretary of a military department, and any subcontract under any such contract, with an owner or operator of a hazardous waste treatment or disposal facility during fiscal years 1992 through 1996 for the offsite treatment or disposal of hazardous wastes from a facility under the jurisdiction of the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c50cf1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2708/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section does not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9c50cf2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2708/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any contract or subcontract to perform remedial action or corrective action under the Defense Environmental Restoration Program, other programs or activities of the Department of Defense, or authorized State hazardous waste programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9c50cf3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2708/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any contract or subcontract under which the generation of the hazardous waste to be disposed of is incidental to the performance of the contract; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9c50cf4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2708/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any contract or subcontract to dispose of ammunition or solid rocket motors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c50cf5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2708/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception to Reimbursement Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (a), in the case of any contract to which this section applies, if the Secretary of Defense or the Secretary of the military department concerned determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9c50cf6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2708/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is only one responsible offeror or there is no responsible offeror willing to provide the reimbursement required by subsection (a) for such contract; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c50cf7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2708/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failure to award the contract would place the facility concerned in violation of any requirement of the Solid Waste Disposal Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6901"},"text":"42 U.S.C. 6901","children":[],"tail":" et seq.),"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then the contract may be awarded without including the reimbursement provision required by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c50cf8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2708/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9c50cf9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2708/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “hazardous waste” has the meaning given that term by section 1004(5) of the Solid Waste Disposal Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6903/5"},"text":"42 U.S.C. 6903(5)","children":[],"tail":"), except that such term also includes polychlorinated biphenyls."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c50cfa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2708/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “remedial action” has the meaning given that term by section 101(24) of the Comprehensive Environmental Response, Compensation, and Liability Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601/24"},"text":"42 U.S.C. 9601(24)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c50cfb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2708/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “corrective action” has the meaning given that term under section 3004(u) of the Solid Waste Disposal Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6924/u"},"text":"42 U.S.C. 6924(u)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c50cfc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2708/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “polychlorinated biphenyls” has the meaning given that term under section 6(e) of the Toxic Substances Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2605/e"},"text":"15 U.S.C. 2605(e)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c50cfd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2708/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on Liability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall affect the liability of the Federal Government under any Federal or State law or under common law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9c50cfe-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tIII/s331/a/1"},"text":"Pub. L. 102–190, div. A, title III, § 331(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1339"},"text":"105 Stat. 1339","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tIII/s321"},"text":"Pub. L. 102–484, div. A, title III, § 321","children":[],"tail":", title X, § 1052(36), "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2365"},"text":"106 Stat. 2365","children":[],"tail":", 2501; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tX/s1004"},"text":"Pub. L. 103–160, div. A, title X, § 1004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1748"},"text":"107 Stat. 1748","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9c50cff-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9c50d00-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida9c50d01-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Solid Waste Disposal Act, referred to in subsec. (c)(2), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272"},"text":"Pub. L. 89–272","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-20"},"text":"Oct. 20, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/997"},"text":"79 Stat. 997","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/94/580/s2"},"text":"Pub. L. 94–580, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2795"},"text":"90 Stat. 2795","children":[],"tail":", which is classified generally to chapter 82 (§ 6901 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6901"},"text":"section 6901 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9c50d02-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":" substituted “fiscal years 1992 through 1996” for “fiscal years 1992 and 1993”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s1052/36/A"},"text":"Pub. L. 102–484, § 1052(36)(A)","children":[],"tail":", substituted “each contract” for “all contracts” and “any subcontract under any such contract” for “all subcontracts under such contracts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s321"},"text":"Pub. L. 102–484, § 321","children":[],"tail":", substituted “fiscal years 1992 and 1993” for “fiscal year 1992”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s1052/36/B"},"text":"Pub. L. 102–484, § 1052(36)(B)","children":[],"tail":", substituted “In” for “For purposes of” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9c50d03-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9c50d04-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tIII/s331/b"},"text":"Pub. L. 102–190, div. A, title III, § 331(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1340"},"text":"105 Stat. 1340","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/190/dA/tIII/s331/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2708"},"text":"Section 2708 of title 10","children":[],"tail":", United States Code, shall apply with respect to contracts entered into after the expiration of the 60-day period beginning on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
