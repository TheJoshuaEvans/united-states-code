{"tag":"section","attrib":{"id":"idaa7f0e12-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4507"},"text":null,"children":[{"tag":"num","attrib":{"value":"4507"},"text":"§ 4507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement of services: contracts for professional and technical services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa7f0e13-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe regulations to ensure, to the maximum extent practicable, that professional and technical services are acquired on the basis of the task to be performed rather than on the basis of the number of hours of services provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa7f0e14-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content of Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to contracts to acquire services on the basis of the number of hours of services provided, the regulations described in subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa7f0e15-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4507/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include standards and approval procedures to minimize the use of such contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa7f0e16-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4507/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish criteria to ensure that proposals for contracts for technical and professional services are evaluated on a basis which does not encourage contractors to propose uncompensated overtime;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa7f0e17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4507/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure appropriate emphasis on technical and quality factors in the source selection process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa7f0e18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4507/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require identification of any hours in excess of 40-hour weeks included in a proposal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa7f0e19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4507/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that offerors are notified that proposals which include unrealistically low labor rates or which do not otherwise demonstrate cost realism will be considered in a risk assessment and evaluated appropriately; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa7f0e1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4507/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide guidance to contracting officers to ensure that any use of uncompensated overtime will not degrade the level of technical expertise required to perform the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa7f0e1b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tVIII/s834/a/1"},"text":"Pub. L. 101–510, div. A, title VIII, § 834(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1613"},"text":"104 Stat. 1613","children":[],"tail":", § 2331; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/25/tVII/s701/a"},"text":"Pub. L. 102–25, title VII, § 701(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-04-06"},"text":"Apr. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/113"},"text":"105 Stat. 113","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/tI/s1004/c"},"text":"Pub. L. 103–355, title I, § 1004(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3253"},"text":"108 Stat. 3253","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tVIII/s801/g/1"},"text":"Pub. L. 107–107, div. A, title VIII, § 801(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1177"},"text":"115 Stat. 1177","children":[],"tail":"; renumbered § 4507, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1856/g"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1856(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4275"},"text":"134 Stat. 4275","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa7f0e1c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa7f0e1d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa7f0e1e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4507, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/253"},"text":"70A Stat. 253","children":[],"tail":", which related to sale of ordnance and ordnance stores to designers, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tVIII/s822/b/3"},"text":"Pub. L. 103–160, div. A, title VIII, § 822(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1706"},"text":"107 Stat. 1706","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa7f0e1f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2331"},"text":"section 2331 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" substituted “Procurement of services: contracts” for “Contracts” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355"},"text":"Pub. L. 103–355","children":[],"tail":" struck out text and heading of subsec. (c). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The Secretary of Defense may waive the limitation in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2304/j/4"},"text":"section 2304(j)(4) of this title","children":[],"tail":" on the total value of task orders for specific contracting activities to the extent the Secretary considers the use of master agreements necessary in order to further the policy set forth in subsection (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) During any fiscal year, such a waiver may not increase the total value of task orders under master agreements of a contracting activity by more than 20 percent of the value of all contracts for advisory and assistance services awarded by that contracting activity during fiscal year 1989.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) Such a waiver shall not become effective until 60 days after the Secretary of Defense has published notice thereof in the Federal Register.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L. 102–25","children":[],"tail":" struck out “on a case-by-case basis” after “value of task orders”, substituted “considers the use of master agreements necessary” for “considers necessary the use of master agreements”, and struck out “of this section” before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa7f0e20-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa7f0e21-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa7f0e22-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date and applicability of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355"},"text":"Pub. L. 103–355","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/s10001"},"text":"section 10001 of Pub. L. 103–355","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8752"},"text":"section 8752 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa7f0e23-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tVIII/s834/b"},"text":"Pub. L. 101–510, div. A, title VIII, § 834(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1614"},"text":"104 Stat. 1614","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/510/dA/tVIII/s834/b"},"text":"“Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":"], the Secretary of Defense shall publish for public comment new regulations to carry out the requirements in this section [enacting this section]. The Secretary shall promulgate final regulations to carry out such requirements not later than 270 days after the date of the enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa7f0e24-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Provisions Not Affected by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355"},"text":"Pub. L. 103–355","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Repeal of subsec. (c) of this section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355"},"text":"Pub. L. 103–355","children":[],"tail":" not to be construed as modifying or superseding, or as intended to impair or restrict, authorities or responsibilities under former "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s759"},"text":"40 U.S.C. 759","children":[],"tail":" or chapter 11 of Title 40, Public Buildings, Property, and Works, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/s1004/d"},"text":"section 1004(d) of Pub. L. 103–355","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3401"},"text":"section 3401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
