{"tag":"section","attrib":{"id":"ida82ae586-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s911"},"text":null,"children":[{"tag":"num","attrib":{"value":"911"},"text":"§ 911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 111. Leaving scene of vehicle accident","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida82ae587-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s911/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Driver","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82ae588-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s911/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is the driver of a vehicle that is involved in an accident that results in personal injury or property damage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82ae589-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s911/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who wrongfully leaves the scene of the accident—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida82ae58a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s911/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without providing assistance to an injured person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82ae58b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s911/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without providing personal identification to others involved in the accident or to appropriate authorities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82ae58c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s911/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Senior Passenger","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82ae58d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s911/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a passenger in a vehicle that is involved in an accident that results in personal injury or property damage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82ae58e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s911/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is the superior commissioned or noncommissioned officer of the driver of the vehicle or is the commander of the vehicle; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82ae58f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s911/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who wrongfully and unlawfully orders, causes, or permits the driver to leave the scene of the accident—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida82ae590-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s911/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without providing assistance to an injured person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82ae591-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s911/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without providing personal identification to others involved in the accident or to appropriate authorities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida82ae592-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLX/s5423"},"text":"Pub. L. 114–328, div. E, title LX, § 5423","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2947"},"text":"130 Stat. 2947","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida82ae593-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida82ae594-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida82ae595-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attr