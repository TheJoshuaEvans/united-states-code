{"tag":"section","attrib":{"id":"idab42ab70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8704"},"text":null,"children":[{"tag":"num","attrib":{"value":"8704"},"text":"§ 8704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of receipts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Amounts received under this chapter shall be credited to appropriations for maintaining naval salvage facilities. However, any amount received under this chapter in any fiscal year in excess of naval salvage costs incurred by the Navy during that fiscal year shall be deposited into the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab42ab71-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tX/s1015"},"text":"Pub. L. 104–106, div. A, title X, § 1015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/425"},"text":"110 Stat. 425","children":[],"tail":", § 7364; renumbered § 8704, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/3"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab42ab72-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab42ab73-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note"