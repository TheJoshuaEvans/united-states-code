{"tag":"section","attrib":{"id":"ida9fbfb2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920"},"text":null,"children":[{"tag":"num","attrib":{"value":"2920"},"text":"§ 2920.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy resilience and energy security measures on military installations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9fbfb2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Energy Resilience Measures","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9fbfb2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall, by the end of fiscal year 2030, provide that 100 percent of the energy load required to maintain the critical missions of each installation have a minimum level of availability of 99.9 percent per fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall issue standards establishing levels of availability relative to specific critical missions, with such standards providing a range of not less than 99.9 percent availability per fiscal year and not more than 99.9999 percent availability per fiscal year, depending on the criticality of the mission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb31-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may establish interim goals to take effect prior to fiscal year 2025 to ensure the requirements under this subsection are met.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb32-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of each military department and the head of each Defense Agency shall ensure that their organizations meet the requirements of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb33-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish internal processes to support coordination with external regulatory and planning entities involved in grid reliability, transmission infrastructure, and long-term energy planning, in order to assess and mitigate risks to defense-critical installations, advance the energy security objectives of the Department, and comply with statutory mandates under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb34-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Coordination under paragraph (5)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9fbfb35-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include identification of mission-critical loads and infrastructure dependencies and load profiles at or near military installations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fbfb36-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include consultation with relevant Federal and non-Federal entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9fbfb37-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Planning","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9fbfb38-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall require the Secretary of each military department and the head of each Defense Agency to plan for the provision of energy resilience and energy security for installations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Planning under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9fbfb3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the use of multiple and diverse sources of energy, with an emphasis favoring energy resources originating on the installation such as modular generation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fbfb3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote installing microgrids to ensure the energy security and energy resilience of critical missions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fbfb3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" favor the use of full-time, installed energy sources rather than emergency generation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9fbfb3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development of Information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The planning required by subsection (b) shall identify each of the following for each installation:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9fbfb3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The critical missions of the installation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The energy requirements of those critical missions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The duration that those energy requirements are likely to be needed in the event of a disruption or emergency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb41-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The current source of energy provided to those critical missions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb42-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The duration that the currently provided energy would likely be available in the event of a disruption or emergency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb43-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any currently available sources of energy that would provide uninterrupted energy to critical missions in the event of a disruption or emergency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb44-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Alternative sources of energy that could be developed to provide uninterrupted energy to critical missions in the event of a disruption or emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9fbfb45-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Testing and Measuring","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9fbfb46-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9fbfb47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall require the Secretary of each military department and head of each Defense Agency to conduct monitoring, measuring, and testing to provide the data necessary to comply with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fbfb48-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any data provided under subparagraph (A) shall be made available to the Assistant Secretary of Defense for Sustainment upon request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb49-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9fbfb4a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall require that black start exercises be conducted to assess the energy resilience and energy security of installations for periods established to evaluate the ability of the installation to perform critical missions without access to off-installation energy resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fbfb4b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A black start exercise conducted under subparagraph (A) may exclude, if technically feasible, housing areas, commissaries, exchanges, and morale, welfare, and recreation facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fbfb4c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9fbfb4d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide uniform policy for the military departments and the Defense Agencies with respect to conducting black start exercises; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9fbfb4e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a schedule of black start exercises for the military departments and the Defense Agencies, with each military department and Defense Agency scheduled to conduct such an exercise on a number of installations each year sufficient to allow that military department or Defense Agency to meet the goals of this section, but in any event not fewer than five installations each year for each military department through fiscal year 2032.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fbfb4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9fbfb50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/d/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in clause (ii), the Secretary of each military department shall, notwithstanding any other provision of law, conduct black start exercises in accordance with the schedule provided for in subparagraph (C)(ii), with any such exercise not to last longer than five days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9fbfb51-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/d/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of a military department may conduct more black start exercises than those identified in the schedule provided for in subparagraph (C)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9fbfb52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For contracts for energy and utility services, the Secretary of Defense shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9fbfb53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify methods and processes to measure, manage, and verify compliance with subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb54-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that such contracts include requirements appropriate to ensure energy resilience and energy security, including requirements for metering to measure, manage, and verify energy consumption, availability, and reliability consistent with this section and the energy resilience metrics and standards under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2911/b"},"text":"section 2911(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9fbfb55-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not apply to fuels used in aircraft, vessels, or motor vehicles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9fbfb56-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If by the end of fiscal year 2027, the Secretary determines that the Department will be unable to meet the requirements under subsection (a), not later than 90 days after the end of such fiscal year, the Secretary shall submit to the Committees on Armed Services of the Senate and House of Representatives a report detailing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9fbfb57-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projected shortfall;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasons for the projected shortfall;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any statutory, technological, or monetary impediments to achieving such requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any impact to readiness or ability to meet the national defense posture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb5b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other relevant information as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9fbfb5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9fbfb5d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “availability” means the availability of required energy at a stated instant of time or over a stated period of time for a specific purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb5e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “black start exercise” means an exercise in which delivery of energy provided from off an installation is terminated before backup generation assets on the installation are turned on. Such an exercise shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9fbfb5f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the ability of the backup systems to start independently, transfer the load, and carry the load until energy from off the installation is restored;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fbfb60-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" align organizations with critical missions to coordinate in meeting critical mission requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fbfb61-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" validate mission operation plans, such as continuity of operations plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fbfb62-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/h/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify infrastructure interdependencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fbfb63-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/h/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" verify backup electric power system performance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb64-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “critical mission”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9fbfb65-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means those aspects of the missions of an installation, including mission essential operations, that are critical to successful performance of the strategic national defense mission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fbfb66-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include operational headquarters facilities, airfields and supporting infrastructure, harbor facilities supporting naval vessels, munitions production and storage facilities, missile fields, radars, satellite control facilities, cyber operations facilities, space launch facilities, operational communications facilities, and biological defense facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fbfb67-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/h/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include military housing (including privatized military housing), morale, welfare, and recreation facilities, exchanges, commissaries, or privately owned facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “energy” means electricity, natural gas, steam, chilled water, and heated water.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb69-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2920/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “installation” has the meaning given the term “military installation” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2801/c/4"},"text":"section 2801(c)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9fbfb6a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIII/s316/a"},"text":"Pub. L. 116–283, div. A, title III, § 316(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3516"},"text":"134 Stat. 3516","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tIII"},"text":"Pub. L. 118–159, div. A, title III","children":[],"tail":", §§ 313, 314(a), "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1851"},"text":"138 Stat. 1851","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dB/tXXVIII/s2847"},"text":"Pub. L. 119–60, div. B, title XXVIII, § 2847","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1319"},"text":"139 Stat. 1319","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9fbfb6b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9fbfb6c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9fbfb6d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" added pars. (5) and (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsec. (d)(2)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s313"},"text":"Pub. L. 118–159, § 313","children":[],"tail":", substituted “2032” for “2027”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s314/a"},"text":"Pub. L. 118–159, § 314(a)","children":[],"tail":", substituted “2027” for “2029” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9fbfb6e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9fbfb6f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pilot Program on Procurement of Utility Services for Installations of the Department of Defense Through Areawide Contracts","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dB/tXXVIII/s2888"},"text":"Pub. L. 119–60, div. B, title XXVIII, § 2888","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1332"},"text":"139 Stat. 1332","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dB/tXXVIII/s2888"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pilot Program Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the date of the enactment of this Act [Dec 18, 2025], the Secretary of Defense shall establish a pilot program (in this section referred to as the ‘pilot program’) for the purposes of procuring utility services through an areawide contract with a public utility provider for any utility services that support energy resilience and mission readiness of a military installation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act, the Secretary of each military department shall enter into at least one areawide contract with a public utility provider pursuant to the pilot program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public-private Partnerships","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall carry out the pilot program by entering into one or more public-private partnerships through an areawide contract entered into under the pilot program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Competition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the pilot program, the Secretary shall, in accordance with part 6.302 of the Federal Acquisition Regulation, develop—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a justification and approval template to be used by all acquisition commands of the military departments when entering into an areawide contract pursuant to the pilot program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a process for granting waivers with respect to the requirements of the Defense Federal Acquisition Regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority of the Secretary of Defense to carry out the pilot program shall terminate on the date that is one year after the date on which the Secretary commences the pilot program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date on which the pilot program is terminated pursuant to subsection (e), the Secretary of Defense shall submit to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] a report that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the pilot program, including any efficiencies, benefits, and cost-savings associated with utilizing areawide contracts under the pilot program to procure utility services from a public utility provider; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposed solutions, including recommended legislative text and modifications to the Federal Acquisition Regulation or policy guidance of the Department of Defense, to overcome any remaining legal and policy hurdles that the Secretary identifies as inhibiting adherence to and implementation of section 2811(b) of the Military Construction Authorization Act for Fiscal Year 2024 (division B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Public Law 118–31","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2920"},"text":"10 U.S.C. 2920","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms ‘areawide contract’, ‘energy resilience’, and ‘utility service’ have the meanings given such terms in section 2811(b)(3) of such Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘military installation’ has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2801"},"text":"section 2801 of title 10","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9fbfb70-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Department of Defense Infrastructure Resilience and Readiness","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dB/tXXVIII/s2811/b"},"text":"Pub. L. 118–31, div. B, title XXVIII, § 2811(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/748"},"text":"137 Stat. 748","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dB/tXXVIII/s2811/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense and the Secretary of the military department concerned may utilize existing areawide contracts to procure utility services from a utility service supplier—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support installation energy resilience and mission readiness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the protection of critical infrastructure of the Department of Defense located at a military installation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to achieve energy resilience at military installations through implementation of utility system infrastructure projects, to include facilities sustainment, restoration, and modernization of such infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority under this subsection shall terminate on ","children":[{"tag":"date","attrib":{"date":"2032-09-30"},"text":"September 30, 2032","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Areawide contract","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘areawide contract’ means a contract entered into between the General Services Administration and a utility service supplier under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s501"},"text":"section 501 of title 40","children":[],"tail":", United States Code, to procure the utility service needs of Federal agencies within the franchise territory of the supplier."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Energy resilience","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘energy resilience’ has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/e"},"text":"section 101(e) of title 10","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Franchise territory","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘franchise territory’ means a geographical area that a utility service supplier has a right to serve based upon a franchise granted by an independent regulatory body, a certificate of public convenience and necessity, or other legal means.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Utility service","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘utility service’—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a utility or service described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2872a/b"},"text":"section 2872a(b) of title 10","children":[],"tail":", United States Code;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the services supplied by a utility service supplier described in an areawide contract such as connection, change, disconnection, continue service, line extension, alteration or relocation, metering, and special facilities, including primary generation, backup generation, microgrid controls, charging capabilities, and any supporting infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes ancillary services, including total maintenance and repair, major restoration and repair, studies, and any other services, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Utility service supplier","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘utility service supplier’ means an entity that supplies a utility service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Utility system","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘utility system’ has the meaning given the term in subsections (i)(1)(A) and (i)(2)(A) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2688"},"text":"section 2688 of title 10","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
