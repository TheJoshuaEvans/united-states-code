{"tag":"section","attrib":{"id":"ida817d19e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s830a"},"text":null,"children":[{"tag":"num","attrib":{"value":"830a"},"text":"§ 830a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 30a. Proceedings conducted before referral","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida817d19f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s830a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida817d1a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s830a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President shall prescribe regulations for matters relating to proceedings conducted before referral of charges and specifications to court-martial for trial, including the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida817d1a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s830a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pre-referral investigative subpoenas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida817d1a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s830a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pre-referral warrants or orders for electronic communications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida817d1a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s830a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pre-referral matters referred by an appellate court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida817d1a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s830a/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pre-referral matters under subsection (c) or (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s806b"},"text":"section 806b of this title","children":[],"tail":" (article 6b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida817d1a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s830a/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Pre-referral matters relating to the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida817d1a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s830a/a/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pre-trial confinement of an accused.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida817d1a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s830a/a/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The mental capacity or mental responsibility of an accused.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida817d1a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s830a/a/1/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A request for an individual military counsel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida817d1a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s830a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In addition to the matters specified in paragraph (1), the regulations prescribed under that paragraph shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida817d1aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s830a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth the matters that a military judge may rule upon in such proceedings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida817d1ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s830a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include procedures for the review of such rulings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida817d1ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s830a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include appropriate limitations to ensure that proceedings under this section extend only to matters that would be subject to consideration by a military judge in a general or special court-martial; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida817d1ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s830a/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such limitations on the relief that may be ordered under this section as the President considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida817d1ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s830a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If any matter in a proceeding under this section becomes a subject at issue with respect to charges that have been referred to a general or special court-martial, the matter shall be transferred to the military judge detailed to the court-martial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida817d1af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s830a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Detail of Military Judge","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall prescribe regulations providing for the manner in which military judges are detailed to proceedings under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida817d1b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s830a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discretion to Designate Magistrate to Preside","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In accordance with regulations prescribed by the Secretary concerned, a military judge detailed to a proceeding under subsection (a)(1), other than a proceeding described in subparagraph (B) of that subsection, may designate a military magistrate to preside over the proceeding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida817d1b1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLVI/s5202"},"text":"Pub. L. 114–328, div. E, title LVI, § 5202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2904"},"text":"130 Stat. 2904","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tV/s531/b"},"text":"Pub. L. 115–91, div. A, title V, § 531(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1384"},"text":"131 Stat. 1384","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tV/s531/a"},"text":"Pub. L. 116–92, div. A, title V, § 531(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1359"},"text":"133 Stat. 1359","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida817d1b2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida817d1b3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida817d1b4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s531/b/1"},"text":"Pub. L. 116–92, § 531(b)(1)","children":[],"tail":", substituted “Proceedings conducted before referral” for “Certain proceedings conducted before referral” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s531/a"},"text":"Pub. L. 116–92, § 531(a)","children":[],"tail":", added pars. (1) and (2) and struck out former pars. (1) and (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Proceedings may be conducted to review, or otherwise act on, the following matters before referral of charges and specifications to court-martial for trial in accordance with regulations prescribed by the President:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) Pre-referral investigative subpoenas.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) Pre-referral warrants or orders for electronic communications.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) Pre-referral matters referred by an appellate court.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) Pre-referral matters under subsection (c) or (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s806b"},"text":"section 806b of this title","children":[],"tail":" (article 6b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The regulations prescribed under paragraph (1) shall—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) include procedures for the review of such rulings that may be ordered under this section as the President considers appropriate; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) provide such limitations on the relief that may be ordered under this section as the President considers appropriate.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s531/b/1"},"text":"Pub. L. 115–91, § 531(b)(1)","children":[],"tail":", inserted “, or otherwise act on,” after “to review” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s531/b/2"},"text":"Pub. L. 115–91, § 531(b)(2)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida817d1b5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida817d1b6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" effective immediately after this section takes effect as provided for in "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"10 U.S.C. 801","children":[],"tail":" note), see "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/s531/p"},"text":"section 531(p) of Pub. L. 115–91","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida817d1b7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on ","children":[{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
