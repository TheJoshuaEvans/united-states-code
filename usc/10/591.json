{"tag":"section","attrib":{"id":"ida7e3549c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s591"},"text":null,"children":[{"tag":"num","attrib":{"value":"591"},"text":"§ 591.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reference to chapters 1205 and 1207","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Provisions of law relating to appointments of reserve officers other than warrant officers are set forth in chapter 1205 of this title (beginning with section 12201). Provisions of law relating to appointments and promotion of reserve warrant officers are set forth in chapter 1207 (beginning with section 12241).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida7e3549d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1662/d/3"},"text":"Pub. L. 103–337, div. A, title XVI, § 1662(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2991"},"text":"108 Stat. 2991","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7e3549e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7e3549f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida7e354a0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 591 to 594, 595, and 596 were renumbered sections 12201 to 12204, 12208, and 12205 of this title, respectively.","chil