{"tag":"section","attrib":{"id":"idaafd6623-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7725"},"text":null,"children":[{"tag":"num","attrib":{"value":"7725"},"text":"§ 7725.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Superintendents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaafd6624-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7725/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment and Qualifications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual serving as the superintendent of one of the Cemeteries should have, as determined by the Secretary of the Army—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaafd6625-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7725/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experience in the administration, management, and operation of cemeteries under the jurisdiction of the National Cemeteries System administered by the Department of Veterans Affairs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaafd6626-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7725/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experience in the administration, management, and operation of large civilian cemeteries equivalent to the experience described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafd6627-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7725/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":nu