{"tag":"section","attrib":{"id":"ida84067c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974"},"text":null,"children":[{"tag":"num","attrib":{"value":"974"},"text":"§ 974.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military musical units and musicians: performance policies; restriction on performance in competition with local civilian musicians","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida84067c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Military Musicians Performing in an Official Capacity","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84067c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A military musical unit, and a member of the armed forces who is a member of such a unit performing in an official capacity, may not engage in the performance of music in competition with local civilian musicians.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84067c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of paragraph (1), the following shall, except as provided in paragraph (3), be included among the performances that are considered to be a performance of music in competition with local civilian musicians:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida84067c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A performance that is more than incidental to an event that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida84067c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not supported, in whole or in part, by United States Government funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida84067c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not free to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida84067ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A performance of background, dinner, dance, or other social music at an event that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida84067cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not supported, in whole or in part, by United States Government funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida84067cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is held at a location not on a military installation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84067cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of paragraph (1), the following shall not be considered to be a performance of music in competition with local civilian musicians:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida84067ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A performance (including background, dinner, dance, or other social music) at an official United States Government event that is supported, in whole or in part, by United States Government funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida84067cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A performance at a concert, parade, or other event, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida84067d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a patriotic event or a celebration of a national holiday; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida84067d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is free to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida84067d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A performance that is incidental to an event that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida84067d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not supported, in whole or in part, by United States Government funds; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida84067d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not free to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida84067d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A performance (including background, dinner, dance, or other social music) at—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida84067d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an event that is sponsored by a military welfare society, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2566"},"text":"section 2566 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida84067d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an event that is a traditional military event intended to foster the morale and welfare of members of the armed forces and their families; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida84067d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an event that is specifically for the benefit or recognition of members of the armed forces, their family members, veterans, civilian employees of the Department of Defense, or former civilian employees of the Department of Defense, to the extent provided in regulations prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida84067d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A performance (including background, dinner, dance, or other social music)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida84067da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to uphold the standing and prestige of the United States with dignitaries and distinguished or prominent persons or groups of the United States or another nation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida84067db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/a/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in support of fostering and sustaining a cooperative relationship with another nation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84067dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition of Military Musicians Accepting Additional Remuneration for Official Performances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A military musical unit, and a member of the armed forces who is a member of such a unit performing in an official capacity, may not receive remuneration for an official performance, other than applicable military pay and allowances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84067dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recordings","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84067de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When authorized under regulations prescribed by the Secretary of Defense for purposes of this section, a military musical unit may produce recordings for distribution to the public, at a cost not to exceed expenses of production and distribution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84067df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts received in payment for a recording distributed to the public under this subsection shall be credited to the appropriation or account providing the funds for the production of the recording. Any amount so credited shall be merged with amounts in the appropriation or account to which credited, and shall be available for the same purposes, and subject to the same conditions and limitations, as amounts in such appropriation or account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84067e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Private Donations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84067e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may accept contributions of money, personal property, or services on the condition that such money, property, or services be used for the benefit of a military musical unit under the jurisdiction of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84067e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any contribution of money under paragraph (1) shall be credited to the appropriation or account providing the funds for such military musical unit. Any amount so credited shall be merged with amounts in the appropriation or account to which credited, and shall be available for the same purposes, and subject to the same conditions and limitations, as amounts in such appropriation or account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84067e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performances at Foreign Locations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) does not apply to a performance outside the United States, its commonwealths, or its possessions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84067e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s974/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Military Musical Unit Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “military musical unit” means a band, ensemble, chorus, or similar musical unit of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida84067e5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tV/s590/a/1"},"text":"Pub. L. 110–181, div. A, title V, § 590(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/136"},"text":"122 Stat. 136","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tV/s591/a"},"text":"Pub. L. 111–84, div. A, title V, § 591(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2335"},"text":"123 Stat. 2335","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tIII/s351"},"text":"Pub. L. 113–66, div. A, title III, § 351","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/741"},"text":"127 Stat. 741","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1051/a/4"},"text":"Pub. L. 115–91, div. A, title X, § 1051(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1560"},"text":"131 Stat. 1560","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida84067e6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida84067e7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida84067e8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 974, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/235/s6/a/6/A"},"text":"Pub. L. 90–235, § 6(a)(6)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/762"},"text":"81 Stat. 762","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tIII/s327/e"},"text":"Pub. L. 101–510, div. A, title III, § 327(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1532"},"text":"104 Stat. 1532","children":[],"tail":", related to civilian employment by enlisted members, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tV/s569/a"},"text":"Pub. L. 105–261, div. A, title V, § 569(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2032"},"text":"112 Stat. 2032","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida84067e9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" struck out par. (3) which read as follows: “Not later than January 30 of each year, the Secretary concerned shall submit to Congress a report on any contributions of money, personal property, and services accepted under paragraph (1) during the fiscal year preceding the fiscal year during which the report is submitted.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" added subsec. (d) and redesignated former subsecs. (d) and (e) as (e) and (f), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" amended section generally. Prior to amendment, section related to uniform performance policies for military bands and other musical units."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
