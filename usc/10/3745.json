{"tag":"section","attrib":{"id":"idaa32c2e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745"},"text":null,"children":[{"tag":"num","attrib":{"value":"3745"},"text":"§ 3745.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa32c2e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Acquisition Regulation shall contain provisions on the allowability of contractor costs. Such provisions shall define in detail and in specific terms those costs which are unallowable, in whole or in part, under covered contracts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa32c2e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specific Items","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations shall, at a minimum, clarify the cost principles applicable to contractor costs of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa32c2e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Air shows.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c2ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Membership in civic, community, and professional organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c2eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recruitment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c2ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Employee morale and welfare.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c2ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Actions to influence (directly or indirectly) executive branch action on regulatory and contract matters (other than costs incurred in regard to contract proposals pursuant to solicited or unsolicited bids).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c2ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Community relations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c2ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Dining facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c2f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Professional and consulting services, including legal services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c2f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c2f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Selling and marketing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c2f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Travel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c2f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Public relations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c2f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hotel and meal expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c2f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Expense of corporate aircraft.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c2f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/b/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Company-furnished automobiles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c2f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/b/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advertising.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c2f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/b/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conventions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa32c2fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Requirements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa32c2fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When questioned costs may be resolved","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Acquisition Regulation shall require that a contracting officer not resolve any questioned costs until he has obtained—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa32c2fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate documentation with respect to such costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa32c2fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the opinion of the contract auditor on the allowability of such costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c2fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presence of contract auditor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Acquisition Regulation shall provide that, to the maximum extent practicable, the contract auditor be present at any negotiation or meeting with the contractor regarding a determination of the allowability of indirect costs of the contractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c2ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3745/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Settlement to reflect amount of individual questioned costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Acquisition Regulation shall require that all categories of costs designated in the report of the contract auditor as questioned with respect to a proposal for settlement be resolved in such a manner that the amount of the individual questioned costs that are paid will be reflected in the settlement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa32c300-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1832/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1832(a)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4218"},"text":"134 Stat. 4218","children":[],"tail":", 4221.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa32c301-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa32c302-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa32c303-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2324"},"text":"section 2324 of this title","children":[],"tail":", which was transferred to this section and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1832/e"},"text":"Pub. L. 116–283, § 1832(e)","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tIX/s911/a/1"},"text":"Pub. L. 99–145, title IX, § 911(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 19