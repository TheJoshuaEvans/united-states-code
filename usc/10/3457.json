(A) subsequently struck out “the heading of the final section of” this chapter, which was executed by incorporating the text of former section 2380b at the end of this section. The text of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2380b"},"text":"section 2380b of this title","children":[],"tail":" was based on "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s877/a"},"text":"Pub. L. 114–328, div. A, title VIII, § 877(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2311"},"text":"130 Stat. 2311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s836/d/7"},"text":"Pub. L. 115–232, div. A, title VIII, § 836(d)(7)","children":[],"tail":", (8)(G), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1868"},"text":"132 Stat. 1868","children":[],"tail":", 1869; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXVII/s1731/a/47"},"text":"Pub. L. 116–92, div. A, title XVII, § 1731(a)(47)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1815"},"text":"133 Stat. 1815","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa26db42-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3491 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7191"},"text":"section 7191 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 3492 and 3493 were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/235/s1/a/2"},"text":"Pub. L. 90–235, § 1(a)(2)","childr