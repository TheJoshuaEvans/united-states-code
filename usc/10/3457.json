{"tag":"section","attrib":{"id":"idaa26db3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3457"},"text":null,"children":[{"tag":"num","attrib":{"value":"3457"},"text":"§ 3457.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain products and services as commercial products and commercial services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa26db3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3457/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Goods and Services Provided by Nontraditional Defense Contractors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3451/1"},"text":"section 3451(1) of this title","children":[],"tail":", products and services provided by nontraditional defense contractors (as that term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3014"},"text":"section 3014 of this title","children":[],"tail":") may be treated by the head of an agency as commercial products and commercial services, respectively, for purposes of this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa26db3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3457/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Services Provided by Certain Nontraditional Contractors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3451/1"},"text":"section 3451(1) of this title","children":[],"tail":", services provided by a business unit that is a nontraditional defense contractor (as that term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3014"},"text":"section 3014 of this title","children":[],"tail":") shall be treated as commercial services for purposes of this chapter, to the extent that such services use the same pool of employees as used for commercial customers and are priced using methodology similar to methodology used for commercial pricing."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa26db3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3457/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commingled Items Purchased by Contractors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3451/1"},"text":"section 3451(1) of this title","children":[],"tail":", items valued at less than $10,000 that are purchased by a contractor for use in the performance of multiple contracts with the Department of Defense and other parties and are not identifiable to any particular contract shall be treated as a commercial product for purposes of this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa26db3e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVIII/s857/a"},"text":"Pub. L. 114–92, div. A, title VIII, § 857(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/921"},"text":"129 Stat. 921","children":[],"tail":", § 2380A; renumbered § 2380a and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s878/a"},"text":"Pub. L. 114–328, div. A, title VIII, § 878(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":