116/283/s1821/b/7/A"},"text":"Pub. L. 116–283, § 1821(b)(7)(A)","children":[],"tail":", (B), transferred "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2380b"},"text":"section 2380b of this title","children":[],"tail":" to this section and struck out section designation and catchline, designated text as subsec. (c) and inserted heading, and substituted “Notwithstanding section 3451(1)” for “Notwithstanding section 2376(1)”. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s836/d/8/F"},"text":"Pub. L. 115–232, § 836(d)(8)(F)","children":[],"tail":", substituted “products and services as commercial products and commercial services” for “items as commercial items” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s836/d/6/A"},"text":"Pub. L. 115–232, § 836(d)(6)(A)","children":[],"tail":", substituted “products and” for “items and” and “commercial products and commercial services, respectively,” for “commercial items”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s836/d/6/B"},"text":"Pub. L. 115–232, § 836(d)(6)(B)","children":[],"tail":", substituted “commercial services” for “commercial items”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s878/b/1"},"text":"Pub. L. 114–328, § 878(b)(1)","children":[],"tail":", which directed amendment of “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2380A"},"text":"Section 2380A of title 10","children":[],"tail":"” by striking out the section catchline and inserting “§ 2380a. Treatment of certain items as commercial items”, was executed by redesignating this section as section 2380a and substituting “Treatment of certain items as commercial items” for “Treatment of goods and services provided by nontraditional defense contractors as commercial items” in section catchline, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s878/a"},"text":"Pub. L. 114–328, § 878(a)","children":[],"tail":", designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa26db44-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa26db45-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa26db46-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"t