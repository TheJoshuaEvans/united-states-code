{"tag":"section","attrib":{"id":"ida92ee7ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2149"},"text":null,"children":[{"tag":"num","attrib":{"value":"2149"},"text":"§ 2149.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications for educational assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To receive educational assistance benefits under this chapter, a person entitled to such assistance under section 2142 or 2147 of this title shall submit an application for such assistance to the Secretary concerned in such form and manner as the Secretary concerned may prescribe.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida92ee7bb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/342/tIX/s901/a"},"text":"Pub. L. 96–342, title IX, § 901(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1114"},"text":"94 Stat. 1114","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
