{"tag":"section","attrib":{"id":"ida960f343-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2275c"},"text":"§ 2275c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Space Force satellite ground systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida960f344-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary of the Air Force for Space Acquisitions and Integration, acting as the service acquisition executive for the Air Force for space systems and programs, may not authorize a launch associated with a Space Force satellite acquisition program unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida960f345-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the associated ground systems and modifications are completed and ready for operation at the time of the launch; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f346-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable satellite capabilities may be used on completion of the launch.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida960f347-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida960f348-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Air Force may waive the requirement under subsection (a) if the Secretary determines that such waiver is necessary for reasons of national security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f349-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 10 days after making a waiver under paragraph (1), the Secretary shall notify the congressional defense committees of such waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida960f34a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1603/a"},"text":"Pub. L. 118–159, div. A, title XVI, § 1603(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2160"},"text":"138 Stat. 2160","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida960f34b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida960f34c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida960f34d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions requiring reports on integration of acquisition and capability delivery schedules for segments of major satellite acquisition programs and funding for such programs were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2275"},"text":"section 2275 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1603/b"},"text":"Pub. L. 118–159, div. A, title XVI, § 1603(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2160"},"text":"138 Stat. 2160","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
