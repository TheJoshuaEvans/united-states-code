{"tag":"section","attrib":{"id":"idab403c5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8702"},"text":null,"children":[{"tag":"num","attrib":{"value":"8702"},"text":"§ 8702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition and transfer of vessels and equipment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab403c5d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy may acquire or transfer for operation by private salvage companies such vessels and equipment as the Secretary considers necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403c5e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement on Use","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before any salvage vessel or salvage gear is transferred by the Secretary to a private party, the private party must agree in writing with the Secretary that the vessel or gear will be used to support organized offshore salvage facilities for a period of as many years as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403c5f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reference to Authority To Advance Funds for Immediate Salvage Operations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For authority for the Secretary of the Navy to advance to private salvage companies such funds as the Secretary considers necessary to provide for the immediate financing of salvage operations, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3808/b"},"text":"section 3808(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab403c60-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tX/s1015"},"text":"Pub. L. 104–106, div. A, title X, § 1015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/424"},"text":"110 Stat. 424","children":[],"tail":", § 7362; renumbered § 8702, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/3"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1834/i/5"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1834(i)(5)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/n/2"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(n)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2145"},"text":"135 Stat. 2145","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1876/c"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1876(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01