{"tag":"section","attrib":{"id":"ida8073075-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s777"},"text":null,"children":[{"tag":"num","attrib":{"value":"777"},"text":"§ 777.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wearing of insignia of higher grade before promotion (frocking): authority; restrictions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8073076-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s777/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer in a grade below the grade of major general or, in the case of the Navy, rear admiral, who has been selected for promotion to the next higher grade may be authorized, under regulations and policies of the Department of Defense and subject to subsection (b), to wear the insignia for that next higher grade. An officer who is so authorized to wear the insignia of the next higher grade is said to be “frocked” to that grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8073077-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s777/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restrictions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An officer may not be authorized to wear the insignia for a grade as described in subsection (a) unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8073078-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s777/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Senate has given its advice and consent to the appointment of the officer to that grade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8073079-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s777/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer is serving in, or has received orders to serve in, a position for which that grade is authorized; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida807307a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s777/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an officer selected for promotion to a grade above colonel or, in the case of an officer of the Navy, a grade above captain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida807307b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s777/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authority for that officer to wear the insignia of that grade has been approved by the Secretary of Defense (or a civilian officer within the Office of the Secretary of Defense whose appointment was made with the advice and consent of the Senate and to whom the Secretary delegates such approval authority); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida807307c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s777/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense has submitted to Congress a written notification of the intent to authorize the officer to wear the insignia for that grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida807307d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s777/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Benefits Not To Be Construed as Accruing","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida807307e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s777/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Authority provided to an officer as described in subsection (a) to wear the insignia of the next higher grade may not be construed as conferring authority for that officer to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida807307f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s777/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be paid the rate of pay provided for an officer in that grade having the same number of years of service as that officer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8073080-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s777/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assume any legal authority associated with that grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8073081-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s777/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The period for which an officer wears the insignia of the next higher grade under such authority may not be taken into account for any of the following purposes:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8073082-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s777/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Seniority in that grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8073083-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s777/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Time of service in that grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8073084-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s777/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Number of Officers Frocked to Specified Grades","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8073085-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s777/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total number of colonels, Navy captains, brigadier generals, and rear admirals (lower half) on the active-duty list who are authorized as described in subsection (a) to wear the insignia for the next higher grade may not exceed 85.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8073086-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s777/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of officers of an armed force on the active-duty list, or for the Space Force, the Space Force officer list, who are authorized as described in subsection (a) to wear the insignia for a grade to which a limitation on total number applies under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s523/a"},"text":"section 523(a) of this title","children":[],"tail":" for a fiscal year may not exceed 1 percent, or, for the grades of colonel and Navy captain, 2 percent, of the total number provided for the officers in that grade in that armed force in the administration of the limitation under that section for that fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8073087-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s503/a/1"},"text":"Pub. L. 104–106, div. A, title V, § 503(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/294"},"text":"110 Stat. 294","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tV/s505"},"text":"Pub. L. 105–85, div. A, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1726"},"text":"111 Stat. 1726","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s502"},"text":"Pub. L. 106–65, div. A, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/590"},"text":"113 Stat. 590","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tV/s509/a"},"text":"Pub. L. 108–136, div. A, title V, § 509(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1458"},"text":"117 Stat. 1458","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s503"},"text":"Pub. L. 108–375, div. A, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1875"},"text":"118 Stat. 1875","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV"},"text":"Pub. L. 109–163, div. A, title V","children":[],"tail":", §§ 503(c), 504, "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3226"},"text":"119 Stat. 3226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tV/s505/b"},"text":"Pub. L. 111–383, div. A, title V, § 505(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4210"},"text":"124 Stat. 4210","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1722/e"},"text":"Pub. L. 118–31, div. A, title XVII, § 1722(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/671"},"text":"137 Stat. 671","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8073088-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8073089-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida807308a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" inserted “, or for the Space Force, the Space Force officer list,” after “active-duty list”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" struck out “and a period of 30 days has elapsed after the date of the notification” after “grade”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s503/c"},"text":"Pub. L. 109–163, § 503(c)","children":[],"tail":", inserted “in a grade below the grade of major general or, in the case of the Navy, rear admiral,” after “An officer” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s504/1"},"text":"Pub. L. 109–163, § 504(1)","children":[],"tail":", substituted “colonels, Navy captains, brigadier generals, and rear admirals (lower half)” for “brigadier generals and Navy rear admirals (lower half)” and “the next higher grade may not exceed 85” for “the grade of major general or rear admiral, as the case may be, may not exceed 30”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s504/2"},"text":"Pub. L. 109–163, § 504(2)","children":[],"tail":", (3), redesignated par. (3) as (2) and struck out former par. (2) which read as follows: “The total number of colonels and Navy captains on the active-duty list who are authorized as described in subsection (a) to wear the insignia for the grade of brigadier general or rear admiral (lower half), as the case may be, may not exceed 55.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" added par. (1) and redesignated former pars. (1) and (2) as (2) and (3), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “55.” for “the following:” and struck out subpars. (A) to (C) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) During fiscal years 1996 and 1997, 75.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) During fiscal year 1998, 55.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) After fiscal year 1998, 35.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" inserted “, or, for the grades of colonel and Navy captain, 2 percent,” after “1 percent”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida807308b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida807308c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tV/s509/b"},"text":"Pub. L. 108–136, div. A, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1459"},"text":"117 Stat. 1459","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/136/dA/tV/s509/b"},"text":"“Paragraph (3) of subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s777"},"text":"section 777 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall not apply with respect to the wearing by an officer of insignia for a grade that was authorized under that section before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida807308d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Temporary Variation of Limitations on Numbers of Frocked Officers","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s503/b"},"text":"Pub. L. 104–106, div. A, title V, § 503(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/294"},"text":"110 Stat. 294","children":[],"tail":", provided that in the administration of former subsec. (d)(2) of this section, the percent limitation applied under that section for fiscal year 1996 would be 2 percent, rather than 1 percent."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
