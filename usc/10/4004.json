{"tag":"section","attrib":{"id":"idaa4d011c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4004"},"text":null,"children":[{"tag":"num","attrib":{"value":"4004"},"text":"§ 4004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract authority for development and demonstration of initial or additional prototype units","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa4d011d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A contract initially awarded from the competitive selection of a proposal resulting from a general solicitation referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3012/2"},"text":"section 3012(2) of this title","children":[],"tail":" may contain a contract line item or contract option for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa4d011e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4004/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and demonstration or initial production of technology developed under the contract; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa4d011f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4004/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the delivery of initial or additional items if the item or a prototype thereof is created as the result of work performed under the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa4d0120-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa4d0121-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4004/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimal amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contract line item or contract option described in subsection (a)(2) shall require the delivery of the minimal amount of initial or additional items to allow for the timely competitive solicitation and award of a follow-on development or production contract for those items.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa4d0122-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4004/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contract line item or contract option described in subsection (a) shall be for a term of not more than 2 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa4d0123-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4004/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dollar value of work","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The dollar value of the work to be performed pursuant to a contract line item or contract option described in subsection (a) may not exceed $100,000,000, in fiscal year 2017 constant dollars.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa4d0124-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4004/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority provided in subsection (a) applies only to the Secretary of Defense, the Secretary of the Army, the Secretary of the Navy, and the Secretary of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa4d0125-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4004/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall establish procedures to collect and analyze information on the use and benefits of the authority under this section and related impacts on performance, affordability, and capability delivery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa4d0126-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVIII/s861/a/1"},"text":"Pub. L. 115–91, div. A, title VIII, § 861(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1493"},"text":"131 Stat. 1493","children":[],"tail":", § 2302e; renumbered § 4004 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/