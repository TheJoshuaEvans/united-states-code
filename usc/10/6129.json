{"tag":"section","attrib":{"id":"idaabf7264-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6129"},"text":null,"children":[{"tag":"num","attrib":{"value":"6129"},"text":"§ 6129.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of completion of milestones with respect to plutonium pit aging","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaabf7265-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6129/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall complete the milestones on plutonium pit aging identified in the report entitled “Research Program Plan for Plutonium and Pit Aging”, published by the Administration in September 2021.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabf7266-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6129/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabf7267-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6129/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acting through the Defense Programs Advisory Committee, conduct biennial reviews during the period beginning not later than one year after the date of the enactment of this Act and ending ","children":[{"tag":"date","attrib":{"date":"2030-12-31"},"text":"December 31, 2030","children":[],"tail":", regarding the progress achieved toward completing the milestones described in subsection (a); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabf7268-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6129/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to enter into an arrangement with the private scientific advisory group known as JASON to conduct, not later than 2030, an assessment of plutonium pit aging.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabf7269-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6129/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the period beginning not later than one year after the date of the enactment of this Act and ending ","children":[{"tag":"date","attrib":{"date":"2030-12-31"},"text":"December 31, 2030","children":[],"tail":", the Administrator shall provide to the congressional defense committees biennial briefings on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabf726a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6129/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress achieved toward completing the milestones described in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabf726b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6129/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the assessments described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabf726c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6129/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification of Completion of Milestones","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2031-10-01"},"text":"October 1, 2031","children":[],"tail":", the Administrator shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabf726d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6129/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify to the congressional defense committees whether the milestones described in subsection (a) have been achieved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabf726e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6129/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the milestones have not been achieved, submit to such committees a report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaabf726f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6129/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing the reasons such milestones have not been achieved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabf7270-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6129/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" including, if the Administrator determines the Administration will not be able to meet one of such milestones, an explanation for that determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabf7271-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6129/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifying new dates for the completion of the milestones the Administrator anticipates the Administration will meet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaabf7272-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1365"},"text":"139 Stat. 1365","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaabf7273-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaabf7274-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaabf7275-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this Act, referred to in subsecs. (b)(1) and (c), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaabf7276-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3124"},"text":"section 3124 of Pub. L. 117–263","children":[],"tail":", which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2538a"},"text":"section 2538a of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/11"},"text":"Pub. L. 119–60, § 3111(b)(11)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
