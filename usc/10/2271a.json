{"tag":"section","attrib":{"id":"ida95c38c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2271a"},"text":"§ 2271a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Space Contractor Responsibility Watch List","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida95c38c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Assistant Secretary of the Air Force for Space Acquisition and Integration, acting as the service acquisition executive for the Air Force for space systems and programs, shall maintain a list of contractors with a history of poor performance on space procurement contracts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida95c38c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Basis for Inclusion on Watch List","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida95c38c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary shall place a contractor, which may consist of the entire contracting entity or a specific division of the contracting entity, on the watch list based on a determination made under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida95c38c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida95c38c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In considering whether to place a contractor on the watch list, the Assistant Secretary shall determine whether there is evidence of any of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida95c38c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Poor performance on one or more space procurement contracts, or award fee scores below 50 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida95c38c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Inadequate management, operational or financial controls, or resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida95c38c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Inadequate security controls or resources, including unremediated vulnerabilities arising from foreign ownership, control, or influence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida95c38ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other failure of controls or performance of a nature so serious or compelling as to warrant placement of the contractor on the watch list.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida95c38cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Assistant Secretary determines, based on evidence described in any of clauses (i) through (iv) of subparagraph (A), that the ability of a contractor to responsibly perform is meaningfully impaired, the Assistant Secretary shall place the contractor on the watch list.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida95e82bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Assistant Secretary shall establish written policies for the consideration of contractors for placement on the watch list, including policies that require that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida95e82bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contractors proposed for placement on the watch list shall be provided with notice and an opportunity to respond;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida95e82be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis for a final determination placing a contractor on the watch list shall be documented in writing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida95e82bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the request of a contractor, the contractor shall be removed from the watch list if the Assistant Secretary determines that there is evidence that the issue resulting in placement on the list has been satisfactorily remediated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida95e82c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Listing","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida95e82c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary may not solicit an offer from, award a contract to, consent to a subcontract with, execute a grant, cooperative agreement, or other transaction with, or exercise an option on any space procurement contract with, an entity included on the watch list unless the Assistant Secretary makes a written determination that there is a compelling reason to do so.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida95e82c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 10 days after the Assistant Secretary makes a determination under paragraph (1), the Assistant Secretary shall notify the congressional defense committees and the Interagency Committee on Debarment and Suspension constituted under sections 4 and 5 of Executive Order 12549 (51 Fed. Reg. 6370; relating to debarment and suspension) of the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida95e82c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Delegation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary may delegate the authority to make a determination under subsection (b)(2)(B) or subsection (c)(1) only if the following criteria are met:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida95e82c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The delegation is to the suspension and debarment official of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida95e82c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The delegation is made on a case-by-case basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida95e82c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than seven days after the date on which such determination is made, the Assistant Secretary notifies the congressional defense committees of the delegation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida95e82c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed as preventing the suspension or debarment of a contractor, but inclusion on the watch list shall not be construed as a punitive measure or de facto suspension or debarment of a contractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida95e82c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida95e82c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “contract” includes a grant, cooperative agreement, or other transaction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida95e82ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “contractor” means any individual or entity that enters into a contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida95e82cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2271a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “watch list” means the watch list maintained under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida95e82cc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1601/a"},"text":"Pub. L. 118–159, div. A, title XVI, § 1601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2157"},"text":"138 Stat. 2157","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida95e82cd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida95e82ce-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida95e82cf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tXVI/s1612"},"text":"Pub. L. 115–91, div. A, title XVI, § 1612","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1729"},"text":"131 Stat. 1729","children":[],"tail":", which was set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2271"},"text":"section 2271 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1601/b"},"text":"Pub. L. 118–159, div. A, title XVI, § 1601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2158"},"text":"138 Stat. 2158","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
