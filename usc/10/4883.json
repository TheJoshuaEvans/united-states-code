{"tag":"section","attrib":{"id":"idaaa9eee6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4883"},"text":null,"children":[{"tag":"num","attrib":{"value":"4883"},"text":"§ 4883.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industrial mobilization: plants; lists","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaa9eee7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4883/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"List of Plants Equipped to Manufacture Arms or Ammunition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may maintain a list of all privately owned plants in the United States, and the territories, Commonwealths, and possessions of the United States, that are equipped to manufacture for the armed forces arms or ammunition, or parts thereof, and may obtain complete information of the kinds of those products manufactured or capable of being manufactured by each of those plants, and of the equipment and capacity of each of those plants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaa9eee8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4883/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"List of Plants Convertible Into Ammunition Factories","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may maintain a list of privately owned plants in the United States, and the territories, Commonwealths, and possessions of the United States, that are capable of being readily transformed into factories for the manufacture of ammunition for the armed forces and that have a capacity sufficient to warrant conversion into ammunition plants in time of war or when war is imminent, and may obtain complete information as to the equipment of each of those plants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaa9eee9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4883/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conversion Plans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may prepare comprehensive plans for converting each plant listed pursuant to subsection (b) into a factory for the manufacture of ammunition or parts thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaa9eeea-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tVIII/s822/a/1"},"text":"Pub. L. 103–160, div. A, title VIII, § 822(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1705"},"text":"107 Stat. 1705","children":[],"tail":", § 2539; renumbered § 4883, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1870/e/2/A"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1870(e)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4286"},"text":"134 Stat. 4286","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaa9eeeb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaa9eeec-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaaa9eeed-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 4502(a)–(c) and 9502(a)–(c) of this title, prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s822/a/2"},"text":"Pub. L. 103–160, § 822(a)(2)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaaa9eeee-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2539"},"text":"section 2539 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaaa9eeef-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaaa9eef0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
