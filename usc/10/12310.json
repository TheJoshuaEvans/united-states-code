{"tag":"section","attrib":{"id":"idab9f9949-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310"},"text":null,"children":[{"tag":"num","attrib":{"value":"12310"},"text":"§ 12310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserves: for organizing, administering, etc., reserve components","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab9f994a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab9f994b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may order a member of a reserve component under the Secretary’s jurisdiction to active duty pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12301/d"},"text":"section 12301(d) of this title","children":[],"tail":" to perform Active Guard and Reserve duty organizing, administering, recruiting, instructing, or training the reserve components."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab9f994c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Reserve ordered to active duty under paragraph (1) shall be ordered in the Reserve’s reserve grade. While so serving, the Reserve continues to be eligible for promotion as a Reserve, if otherwise qualified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab9f994d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Reserve on active duty under subsection (a) may perform the following additional duties to the extent that the performance of those duties does not interfere with the performance of the Reserve’s primary Active Guard and Reserve duties described in subsection (a)(1):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab9f994e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supporting operations or missions assigned in whole or in part to the reserve components.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab9f994f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Supporting operations or missions performed or to be performed by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab9f9950-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit composed of elements from more than one component of the same armed force; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab9f9951-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a joint forces unit that includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idab9f9952-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more reserve component units; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab9f9953-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of a reserve component whose reserve component assignment is in a position in an element of the joint forces unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab9f9954-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advising the Secretary of Defense, the Secretaries of the military departments, the Joint Chiefs of Staff, and the commanders of the combatant commands regarding reserve component matters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab9f9955-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Instructing or training in the United States or the Commonwealth of Puerto Rico or possessions of the United States of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab9f9956-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" active-duty members of the armed forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab9f9957-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of foreign military forces (under the same authorities and restrictions applicable to active-duty members providing such instruction or training);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab9f9958-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Defense contractor personnel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab9f9959-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Defense civilian employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab9f995a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operations Relating to Defense Against Weapons of Mass Destruction and Terrorist Attacks","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab9f995b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding subsection (b), a Reserve on active duty as described in subsection (a), or a Reserve who is a member of the National Guard serving on full-time National Guard duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s502/f"},"text":"section 502(f) of title 32","children":[],"tail":" in connection with functions referred to in subsection (a), may, subject to paragraph (3), perform duties in support of emergency preparedness programs to prepare for or to respond to any emergency involving any of the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab9f995c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use or threatened use of a weapon of mass destruction (as defined in section 1403 of the Defense Against Weapons of Mass Destruction Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2302/1"},"text":"50 U.S.C. 2302(1)","children":[],"tail":")) in the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab9f995d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A terrorist attack or threatened terrorist attack in the United States that results, or could result, in catastrophic loss of life or property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab9f995e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The intentional or unintentional release of nuclear, biological, radiological, or toxic or poisonous chemical materials in the United States that results, or could result, in catastrophic loss of life or property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab9f995f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A natural or manmade disaster in the United States that results in, or could result in, catastrophic loss of life or property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab9f9960-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The costs of the pay, allowances, clothing, subsistence, gratuities, travel, and related expenses for a Reserve performing duties under the authority of paragraph (1) shall be paid from the appropriation that is available to pay such costs for other members of the reserve component of that Reserve who are performing duties as described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab9f9961-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Reserve may perform duty described in paragraph (1) only while assigned to a reserve component weapons of mass destruction civil support team.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab9f9962-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reserves on active duty who are performing duties described in paragraph (1) shall be counted against the annual end strength authorizations required by section 115(a)(1)(B) and 115(a)(2) of this title. The justification material for the defense budget request for a fiscal year shall identify the number and component of the Reserves programmed to be performing duties described in paragraph (1) during that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab9f9963-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A reserve component weapons of mass destruction civil support team, and any Reserve assigned to such a team, may not be used to respond to an emergency described in paragraph (1) unless the Secretary of Defense has certified to the Committee on Armed Services of the Senate and the Committee on Armed Services of the House of Representatives that that team, or that Reserve, possesses the requisite skills, training, and equipment to be proficient in all mission requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab9f9964-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Secretary of Defense submits to Congress any request for the enactment of legislation to modify the requirements of paragraphs (1) and (3), the Secretary shall provide with the request—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab9f9965-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" justification for each such requested modification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab9f9966-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary’s plan for sustaining the qualifications of the personnel and teams described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab9f9967-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the term “United States” includes the Commonwealth of Puerto Rico, Guam, and the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab9f9968-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12310/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Reserve on active duty as described in subsection (a) may be provided training consistent with training provided to other members on active duty, as the Secretary concerned sees fit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaba20969-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/30"},"text":"70A Stat. 30","children":[],"tail":", § 678; renumbered § 12310 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI"},"text":"Pub. L. 103–337, div. A, title XVI","children":[],"tail":", §§ 1662(e)(2), 1675(c)(7), "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2992"},"text":"108 Stat. 2992","children":[],"tail":", 3017; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s541"},"text":"Pub. L. 104–201, div. A, title V, § 541","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2521"},"text":"110 Stat. 2521","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tV/s511/b/1"},"text":"Pub. L. 105–261, div. A, title V, § 511(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2006"},"text":"112 Stat. 2006","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV"},"text":"Pub. L. 106–65, div. A, title V","children":[],"tail":", §§ 555(a), (b), 556, title X, § 1067(1), "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/617-619"},"text":"113 Stat. 617–619","children":[],"tail":", 774; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tV/s514/b"},"text":"Pub. L. 107–314, div. A, title V, § 514(b)","children":[],"tail":", title IX, § 933, "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2539"},"text":"116 Stat. 2539","children":[],"tail":", 2626; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV"},"text":"Pub. L. 109–364, div. A, title V","children":[],"tail":", §§ 525(a), 527, "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2193"},"text":"120 Stat. 2193","children":[],"tail":", 2196; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tX/s1073/a/34"},"text":"Pub. L. 111–84, div. A, title X, § 1073(a)(34)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2474"},"text":"123 Stat. 2474","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaba2096a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaba2096b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaba2096c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"678(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"678(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:962 (2d sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:962 (less 1st and 2d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608/s234"},"text":"July 9, 1952, ch. 608, § 234","children":[],"tail":", (less 1st sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/66/490"},"text":"66 Stat. 490","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “to active duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s672/d"},"text":"section 672(d) of this title","children":[],"tail":" in connection with organizing, administering, recruiting, instructing, or training the reserve components” are substituted for the words “into the active military service of the United States under the provisions of this section”. The words “his reserve grade” are substituted for the words “held by them in the Reserve of their Armed Force”. The words “as a Reserve”, in the last sentence of the revised subsection, are substituted for the words “in the Reserve of their Armed Force”. The word “Hereafter” is omitted as surplusage."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is substituted for 50:962 (less 1st and 2d sentences).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaba2096d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaba2096e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" substituted “section 1403 of the Defense Against Weapons of Mass Destruction Act of 1996 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2302/1"},"text":"50 U.S.C. 2302(1)","children":[],"tail":")” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12304/i/2"},"text":"section 12304(i)(2) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s525/a"},"text":"Pub. L. 109–364, § 525(a)","children":[],"tail":", amended subsecs. (a) and (b) generally, substituting provisions relating to authority of the Secretary concerned to order a member of a reserve component to active duty and setting forth duties including supporting operations or missions, providing advice regarding reserve component matters, and providing instruction or training of active-duty members of the armed forces or foreign military forces and Department of Defense contractor personnel or civilian employees, for provisions relating to grade when a Reserve is ordered to active duty and setting forth duties including supporting operations or missions and providing advice regarding reserve component matters."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s527/b/1"},"text":"Pub. L. 109–364, § 527(b)(1)","children":[],"tail":", substituted “Operations Relating to Defense Against Weapons of Mass Destruction and Terrorist Attacks” for “Duties Relating to Defense Against Weapons of Mass Destruction” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s527/a/1/A"},"text":"Pub. L. 109–364, § 527(a)(1)(A)","children":[],"tail":", substituted “involving any of the following:” for “involving—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A) to (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s527/a/1/B"},"text":"Pub. L. 109–364, § 527(a)(1)(B)","children":[],"tail":", added subpars. (A) to (D) and struck out former subpars. (A) and (B) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the use of a weapon of mass destruction (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12304/i/2"},"text":"section 12304(i)(2) of this title","children":[],"tail":"); or"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) a terrorist attack or threatened terrorist attack in the United States that results, or could result, in catastrophic loss of life or property.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s527/a/2"},"text":"Pub. L. 109–364, § 527(a)(2)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) read as follows: “A Reserve may perform duties described in paragraph (1) only while assigned to a reserve component rapid assessment element team and performing those duties within the geographical limits of the United States, its territories and possessions, the District of Columbia, and the Commonwealth of Puerto Rico.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s527/b/2"},"text":"Pub. L. 109–364, § 527(b)(2)","children":[],"tail":", substituted “weapons of mass destruction civil support team” for “rapid assessment element team”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s527/b/3/A"},"text":"Pub. L. 109–364, § 527(b)(3)(A)","children":[],"tail":", substituted “paragraphs (1) and (3)” for “paragraph (3)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s527/b/3/B"},"text":"Pub. L. 109–364, § 527(b)(3)(B)","children":[],"tail":", substituted “(3)” for “(3)(B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s527/a/3"},"text":"Pub. L. 109–364, § 527(a)(3)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s514/b"},"text":"Pub. L. 107–314, § 514(b)","children":[],"tail":", substituted “involving—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the use of a weapon of mass destruction (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12304/i/2"},"text":"section 12304(i)(2) of this title","children":[],"tail":"); or"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) a terrorist attack or threatened terrorist attack in the United States that results, or could result, in catastrophic loss of life or property.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"for “involving the use of a weapon of mass destruction (as defined in section 1403 of the Defense Against Weapons of Mass Destruction Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2302/1"},"text":"50 U.S.C. 2302(1)","children":[],"tail":")).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s933"},"text":"Pub. L. 107–314, § 933","children":[],"tail":", substituted “only while assigned” for “only—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) while assigned to the Department of Defense Consequence Management Program Integration Office; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) while assigned”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s555/b/1"},"text":"Pub. L. 106–65, § 555(b)(1)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s555/a/2"},"text":"Pub. L. 106–65, § 555(a)(2)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s555/b/2"},"text":"Pub. L. 106–65, § 555(b)(2)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s555/b/2"},"text":"Pub. L. 106–65, § 555(b)(2)","children":[],"tail":", substituted “Notwithstanding subsection (b), a Reserve” for “A Reserve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s556/a"},"text":"Pub. L. 106–65, § 556(a)","children":[],"tail":", struck out first sentence which read as follows: “The number of Reserves on active duty who are performing duties described in paragraph (1) at the same time may not exceed 228.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s1067/1"},"text":"Pub. L. 106–65, § 1067(1)","children":[],"tail":", substituted “and the Committee on Armed Services” for “and the Committee on National Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s556/b"},"text":"Pub. L. 106–65, § 556(b)","children":[],"tail":", struck out “or to increase the number of personnel authorized by paragraph (4)” after “requirements of paragraph (3)” in introductory provisions and “or for the requested additional personnel and explain the need for the increase in the context of existing or projected similar capabilities at the local, State, and Federal levels” after “modification” in subpar. (A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s555/a/1"},"text":"Pub. L. 106–65, § 555(a)(1)","children":[],"tail":", (b)(3), redesignated subsec. (b) as (d) and inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":"Pub. L. 105–261","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “To assure that a Reserve on duty under subsection (a) receives periodic refresher training in the categories for which he is qualified, the Secretary concerned may detail him to duty with any armed force, or otherwise as the Secretary sees fit.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1662/e/2"},"text":"Pub. L. 103–337, § 1662(e)(2)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s678"},"text":"section 678 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1675/c/7"},"text":"Pub. L. 103–337, § 1675(c)(7)","children":[],"tail":", substituted “12301(d)” for “672(d)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaba2096f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaba20970-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691"},"text":"section 1691 of Pub. L. 103–337","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaba20971-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Additional Weapons of Mass Destruction Civil Support Teams","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tXIV/s1403"},"text":"Pub. L. 107–314, div. A, title XIV, § 1403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2676"},"text":"116 Stat. 2676","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXIV/s1435/a"},"text":"Pub. L. 112–239, div. A, title XIV, § 1435(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2051"},"text":"126 Stat. 2051","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/239/dA/tXIV/s1435/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Additional Teams","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish 23 additional teams designated as Weapons of Mass Destruction Civil Support Teams, for a total of 55 such teams; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that of such 55 teams, there is at least one team established in each State and territory.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Further Additional Teams","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense is authorized to have established two additional teams designated as Weapons of Mass Destruction Civil Support Teams, beyond the 55 teams required in subsection (a), if—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense has made the certification provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12310/c/5"},"text":"section 12310(c)(5) of title 10","children":[],"tail":", United States Code, with respect to each of such additional teams before "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of such additional teams does not require an increase in authorized personnel levels above the numbers authorized as of the date of the enactment of the National Defense Authorization Act for Fiscal Year 2013 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":", approved "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation of Establishment of Further Teams","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No Weapons of Mass Destruction Civil Support Team may be established beyond the number authorized by subsections (a) and (b) unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary submits to Congress a request for authority to establish such team, including a detailed justification for its establishment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of such team is specifically authorized by a law enacted after the date of the enactment of the National Defense Authorization Act for Fiscal Year 2013.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of Disestablishment of Teams","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No Weapons of Mass Destruction Civil Support Team established pursuant to this section may be disestablished unless, by not later than 90 days before the date on which such team is disestablished, the Secretary submits to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] notice of the proposed disestablishment of the team and the date on which the disestablishment is proposed to take place.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘Weapons of Mass Destruction Civil Support Team’ means a team of members of the reserve components of the Armed Forces that is established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12310/c"},"text":"section 12310(c) of title 10","children":[],"tail":", United States Code, in support of emergency preparedness programs to prepare for or to respond to any emergency involving the use of a weapon of mass destruction."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘State and territory’ means each of the several States, the District of Columbia, Puerto Rico, Guam, and the Virgin Islands.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
