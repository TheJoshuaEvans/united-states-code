:a","attrib":{"href":"/us/act/1926-07-02/ch721/s5"},"text":"July 2, 1926, ch. 721, § 5","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1928-05-21/ch647"},"text":"May 21, 1928, ch. 647","children":[],"tail":"; added "},{"tag":"html:a","attrib":{"href":"/us/act/1933-06-15/ch87/s2"},"text":"June 15, 1933, ch. 87, § 2","children":[],"tail":" (less last par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/48/153"},"text":"48 Stat. 153","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1938-06-03/ch319"},"text":"June 3, 1938, ch. 319","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1939-07-14/ch269"},"text":"July 14, 1939, ch. 269","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1950-06-28/ch383/s401/b"},"text":"June 28, 1950, ch. 383, § 401(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/271"},"text":"64 Stat. 271","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8033(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5:626(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1947-07-26/ch343/s207/f"},"text":"July 26, 1947, ch. 343, § 207(f)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/61/503"},"text":"61 Stat. 503","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “the following subjects” are inserted for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (c), the words “of officers”, after the word “committee”, are inserted for clarity. The words “and of” are substituted for the words “to which shall be added”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “For the purpose specified herein” are omitted as surplusage. The words “on that duty” are substituted for the words “so serving”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (g), the word “perform” is substituted for the words “be charged with”. All of 5:626(f) except the first proviso of the first sentence is omitted as executed. The words “Territories, Puerto Rico, the Canal Zone, and the District of Columbia” are inserted to conform to other sections of this title which, in describing the National Guard, also include these jurisdictions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab914139-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1958 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"The change is necessary to make subsection (d) coextensive with subsection (c), to which it was a proviso in the source law, the Act of ","children":[{"tag":"date","attrib":{"date":"1916-06-03"},"text":"June 3, 1916","children":[],"tail":", chapter 134, section 5 (1st sentence of 2d par.) (formerly "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s38"},"text":"10 U.S.C. 38","children":[],"tail":" (1st sentence of 2d par.))."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab91413a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab91413b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s916/2"},"text":"Pub. L. 118–31, § 916(2)","children":[],"tail":"–(4), inserted par. (1) designation before “The committee”, redesignated former pars. (1) to (3) as subpars. (A) to (C), respectively, of par. (1), and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s916/1"},"text":"Pub. L. 118–31, § 916(1)","children":[],"tail":", substituted “shall have voting members, who shall be” for “consists of” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s511/1"},"text":"Pub. L. 118–31, § 511(1)","children":[],"tail":", struck out “not on active duty” after “Air National Guard of the United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s511/1"},"text":"Pub. L. 118–31, § 511(1)","children":[],"tail":", struck out “not on active duty” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s511/2"},"text":"Pub. L. 118–31, § 511(2)","children":[],"tail":", inserted “of the reserve components” after “among the members” and struck out “not on active duty” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8021"},"text":"section 8021 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/s521/a/6/C"},"text":"Pub. L. 99–433, § 521(a)(6)(C)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8033"},"text":"section 8033 of this title","children":[],"tail":" as this section, and substituted “Air Force Reserve Forces Policy Committee” for “Reserve components of Air Force; policies and regulations for government of: functions of National Guard Bureau with respect to Air National Guard” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/s521/a/6/A"},"text":"Pub. L. 99–433, § 521(a)(6)(A)","children":[],"tail":", substituted “Policy. The Committee” for “Policy which”, inserted “and the mobilization preparedness”, and substituted “Air Force. The” for “Air Force and the” and “Secretary of the Air Force and the Chief of Staff” for “Chief of Staff, and the Assistant Secretary responsible for reserve affairs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/s521/a/6/B"},"text":"Pub. L. 99–433, § 521(a)(6)(B)","children":[],"tail":", inserted “and” after the semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/168"},"text":"Pub. L. 90–168","children":[],"tail":" amended section generally, and among other changes, redesignated subsec. (e) as (h) and increased from seven to eight the number of subsecs. in the section and in such subsecs. (a)–(h) restated with certain changes the existing authority relating to the Staff Committee on Air Force Reserve Policy within the Office of the Secretary of the Air Force, reduced the membership of the Committee from 21 to 15, reduced the grade requirements so as to permit inclusion of colonels, and provided that the Committee review and comment on all major policies affecting Air Force Reserve matters and that the Committee comments accompany any final submission to the Chief of Staff and Assistant Secretary responsible for Reserve matters."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":" substituted “affecting the organization, distribution, training, appointment, assignment, promotion, or discharge of members of the Air Force Reserve and those of either” for “affecting the Air Force Reserve and either”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab91413c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab91413d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1967 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/168"},"text":"Pub. L. 90–168","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/168/s7"},"text":"section 7 of Pub. L. 90–168","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s138"},"text":"section 138 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab91413e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1956-08-10"},"text":"Aug. 10, 1956","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/