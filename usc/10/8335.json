{"tag":"section","attrib":{"id":"idab1ed028-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8335"},"text":null,"children":[{"tag":"num","attrib":{"value":"8335"},"text":"§ 8335.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restoration to former grade: warrant officers and enlisted members","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each retired warrant officer or enlisted member of the naval service who has been advanced on the retired list to a higher commissioned grade under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8334"},"text":"section 8334 of this title","children":[],"tail":", and who applies to the Secretary of the Navy within three months after his advancement, shall, if the Secretary approves, be restored on the retired list to his former warrant officer or enlisted status, as the case may be."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab1ed029-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tV/s512/b"},"text":"Pub. L. 100–180, div. A, title V, § 512(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1090"},"text":"101 Stat. 1090","children":[],"tail":", § 6335; renumbered § 8335 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 807(b)(15), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":", 1840.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab1ed02a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"i