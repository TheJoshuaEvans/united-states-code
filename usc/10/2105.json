{"tag":"section","attrib":{"id":"ida9254a06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2105"},"text":null,"children":[{"tag":"num","attrib":{"value":"2105"},"text":"§ 2105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced training; failure to complete or to accept commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A member of the program who is selected for advanced training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2104"},"text":"section 2104 of this title","children":[],"tail":", and who does not complete the course of instruction, or who completes the course but declines to accept a commission when offered, may be ordered to active duty by the Secretary of the military department concerned to serve in his enlisted grade or rating for such period of time as the Secretary prescribes but not for more than two years. If the member does not complete the period of active duty prescribed by the Secretary concerned, the member shall be subject to the repayment provisions of section 303a(e) or 373 of title 37."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida9254a07-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/647/tII/s201/1"},"text":"Pub. L. 88–647, title II, § 201(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1066"},"text":"78 Stat. 1066","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s687/c/4"},"text":"Pub. L. 109–163, div. A, title VI, § 687(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3334"},"text":"119 Stat. 3334","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us