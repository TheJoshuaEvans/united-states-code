{"tag":"section","attrib":{"id":"ida959c871-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2262"},"text":null,"children":[{"tag":"num","attrib":{"value":"2262"},"text":"§ 2262.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Defense conferences: collection of fees to cover Department of Defense costs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida959c872-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2262/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Collect Fees","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida959c873-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2262/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may collect fees from any individual or commercial participant in a conference, seminar, exhibition, symposium, or similar meeting conducted by the Department of Defense (in this section referred to collectively as a “conference”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c874-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2262/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may provide for the collection of fees under this section directly or by contract. The fees may be collected in advance of a conference.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida959c875-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2262/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Collected Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts collected under subsection (a) with respect to a conference shall be credited to the appropriation or account from which the costs of the conference are paid and shall be available to pay the costs of the Department of Defense with respect to the conference or to reimburse the Department for costs incurred with respect to the conference.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida959c876-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2262/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Excess Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the event the total amount of fees collected under subsection (a) with respect to a conference exceeds the actual costs of the Department of Defense with respect to the conference, the amount of such excess shall be deposited into the Treasury as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida959c877-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tX/s1051/a"},"text":"Pub. L. 109–364, div. A, title X, § 1051(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2395"},"text":"120 Stat. 2395","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1051/a/11"},"text":"Pub. L. 115–91, div. A, title X, § 1051(a)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1561"},"text":"131 Stat. 1561","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida959c878-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida959c879-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida959c87a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" struck out subsec. (d) which required annual reports on conferences, including information on costs and fees collected."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
