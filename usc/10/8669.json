{"tag":"section","attrib":{"id":"idab390f18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8669"},"text":null,"children":[{"tag":"num","attrib":{"value":"8669"},"text":"§ 8669.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts: applicability of chapter 65 of title 41","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each contract for the construction, alteration, furnishing, or equipping of a naval vessel is subject to chapter 65 of title 41 unless the President determines that this requirement is not in the interest of national defense.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab390f19-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tVIII/s815/a"},"text":"Pub. L. 104–106, div. A, title VIII, § 815(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/396"},"text":"110 Stat. 396","children":[],"tail":", § 7299; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/b/52"},"text":"Pub. L. 111–350, § 5(b)(52)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3846"},"text":"124 Stat. 3846","children":[],"tail":"; renumbered § 8669, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/2"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab390f1a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeadi