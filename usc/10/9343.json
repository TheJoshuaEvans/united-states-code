{"tag":"section","attrib":{"id":"idab6d8c1d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9343"},"text":null,"children":[{"tag":"num","attrib":{"value":"9343"},"text":"§ 9343.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Highest grade held satisfactorily: Reserve enlisted members reduced in grade not as a result of the member’s misconduct","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab6d8c1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9343/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Reserve enlisted member of the Air Force described in subsection (b) who is retired under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9314"},"text":"section 9314 of this title","children":[],"tail":" shall be retired in the highest enlisted grade in which the member served on active duty satisfactorily (or, in the case of a member of the National Guard, in which the member served on full-time National Guard duty satisfactorily), as determined by the Secretary of the Air Force."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab6d8c1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9343/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section applies to a Reserve enlisted member who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab6d8c20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9343/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time of retirement is serving on active duty (or, in the case of a member of the National Guard, on full-time National Guard duty) in a grade lower than the highest enlisted grade held by the member while on active duty (or full-time National Guard duty); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab6d8c21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9343/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was previously administratively reduced in grade not as a result of the member’s own misconduct, as determined by the Secretary of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab6d8c22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9343/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section applies with respect to Reserve enlisted members who are retired under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9314"},"text":"section 9314 of this title","children":[],"tail":" after "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab6d8c23-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s532/c/1"},"text":"Pub. L. 104–201, div. A, title V, § 532(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2519"},"text":"110 Stat. 2519","children":[],"tail":", § 8963; renumbered § 9343 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 806(b)(14), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1833"},"text":"132 Stat. 1833","children":[],"tail":", 1840.)"}],"tail":"\n"},{"tag":"notes","attrib":