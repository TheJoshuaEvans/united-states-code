{"tag":"section","attrib":{"id":"ida769b6b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a"},"text":null,"children":[{"tag":"num","attrib":{"value":"139a"},"text":"§ 139a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of Cost Assessment and Program Evaluation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida769b6b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is a Director of Cost Assessment and Program Evaluation in the Department of Defense, appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida769b6b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Independent Advice to Secretary of Defense","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida769b6b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director of Cost Assessment and Program Evaluation is the principal advisor to the Secretary of Defense and other senior officials of the Department of Defense, and shall provide independent analysis and advice to such officials, on the following matters:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida769b6b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Matters assigned to the Director pursuant to this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3221"},"text":"section 3221 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida769b6b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Matters assigned to the Director by the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s113"},"text":"section 113 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida769b6b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director may communicate views on matters within the responsibility of the Director directly to the Secretary of Defense and the Deputy Secretary of Defense without obtaining the approval or concurrence of any other official within the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida769b6b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deputy Directors","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are two Deputy Directors within the Office of the Director of Cost Assessment and Program Evaluation, as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida769b6ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Deputy Director for Cost Assessment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida769b6bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Deputy Director for Program Evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida769b6bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of Cost Assessment and Program Evaluation shall carry out the requirements of this section in accordance with the objectives established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3102"},"text":"section 3102 of this title","children":[],"tail":" and shall serve as the principal official within the senior management of the Department of Defense for the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida769b6bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cost estimation and cost analysis for acquisition programs of the Department of Defense, and carrying out the duties assigned pursuant to section ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3221"},"text":"section 3221 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida769b6be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Analysis and advice on matters relating to the planning and programming phases of the Planning, Programming, Budgeting and Execution system, and the preparation of materials and guidance for such system, as directed by the Secretary of Defense, working in coordination with the Under Secretary of Defense (Comptroller).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida769b6bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Analysis and advice for resource discussions relating to requirements under consideration in the Joint Requirements Oversight Council pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s181"},"text":"section 181 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida769b6c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Formulation of study guidance for analyses of alternatives for major defense acquisition programs and performance of such analyses, as directed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida769b6c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Review, analysis, and evaluation of programs for executing approved strategies and policies and ensuring that information on programs is presented accurately and completely.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida769b6c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assessments of special access and compartmented intelligence programs, in coordination with the Under Secretary of Defense for Acquisition and Sustainment, the Under Secretary of Defense for Research and Engineering, and the Under Secretary of Defense for Intelligence and Security and in accordance with applicable policies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida769b6c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assessments of alternative plans, programs, and policies with respect to the acquisition programs of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida769b6c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Leading the development of improved analytical skills and competencies within the cost assessment and program evaluation workforce of the Department of Defense and improved tools, data, and methods to promote performance, economy, and efficiency in analyzing national security planning and the allocation of defense resources, including the standardization of analytical methodologies and the establishment and maintenance of a centralized knowledge repository of physical attributes or other data for modeling and simulation purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida769b6c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Performing the duties assigned to the Director in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2222"},"text":"section 2222 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida769b6c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Evaluation Competitive Analysis Cell.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida769b6c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"2024-06-01"},"text":"June 1, 2024","children":[],"tail":", the Secretary of Defense shall establish a team, to be known as the “Program Evaluation Competitive Analysis Cell” (referred to in this subsection as the “Cell”), to critically assess the analytical methodologies, assumptions, and data used in key strategic and operational analyses conducted by the Director of Cost Assessment and Program Evaluation."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida769b6c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida769b6c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate an individual to serve as the head of the Cell; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida769b6ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the Cell has a sufficient number of personnel to carry out the duties described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida769b6cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Cell shall be independent of the Director of Cost Assessment and Program Evaluation. The head of the Cell shall report directly to the Secretary of Defense or the Deputy Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida769b6cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida769b6cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not less frequently than once every two years, the Cell shall conduct an alternative operational or strategic analysis of an analytical question identified by the Chairman of the Joint Chiefs of Staff under subparagraph (B). In conducting such alternative analysis, the Cell shall use assumptions different from the assumptions used by the Director of Cost Assessment and Program Evaluation for the original analysis of such question.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida769b6ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of each alternative analysis required under subparagraph (A), at an appropriate time before the commencement of such analysis—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida769b6cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/e/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Joint Staff shall submit to the Chairman of the Joint Chiefs of Staff a list of not fewer than three operational or strategic questions previously studied by the Director of Cost Assessment and Program Evaluation that could potentially serve as the basis of for such alternative analysis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida769b6d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/e/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from such list, the Chairman shall select one question to serve as the basis for such analysis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida769b6d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion of Risk Estimates in Certain Submissions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case in which the Director of Cost Assessment and Program Evaluation submits to the Secretary of Defense an analytical product that recommends not meeting or changing a requirement established by the Joint Requirements Oversight Council, the Director shall include with such submission—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida769b6d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a risk assessment that assesses any risks of the recommended course of action with respect to the execution of operational plans and the long-term ability of the armed forces to meet the needs of combatant commanders (as determined by the Secretary of Defense); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida769b6d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a risk estimate from the military service in question that assesses the risks described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida769b6d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida769b6d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2024-02-01"},"text":"February 1, 2024","children":[],"tail":", and annually thereafter, the Director of Cost Assessment and Program Evaluation shall submit to the congressional defense committees a report on any strategic and operational analyses conducted under paragraphs (2), (3), (6), (7), or (8) of subsection (d). Each report shall include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida769b6d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of strategic portfolio reviews completed in the fiscal year preceding submission of the report and a description of such reviews planned for the fiscal year that begins after submission of the report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida769b6d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of analyses of alternatives completed in the fiscal year preceding submission of the report and a description of such analyses planned for the fiscal year that begins after submission of the report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida769b6d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of defense program projections completed in the fiscal year preceding submission of the report and a description of such projections planned for the fiscal year that begins after submission of the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida769b6d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each report required by paragraph (1) shall be submitted in classified form, but shall include an unclassified summary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida769b6da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 15 days after the submission of each report required by paragraph (1), the Director of Cost Assessment and Program Evaluation shall provide to the congressional defense committees a briefing on the contents of the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida769b6db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quarterly Briefings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Beginning not later than 30 days after the date of the enactment of this subsection, and on a quarterly basis thereafter, the Director of Cost Assessment and Program Evaluation shall provide to the congressional defense committees a briefing on the activities carried out by the Director during the preceding quarter and any ongoing activities of the Director as of the date of briefing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida769b6dc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/23/tI/s101/a/1"},"text":"Pub. L. 111–23, title I, § 101(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1705"},"text":"123 Stat. 1705","children":[],"tail":", § 139c; renumbered § 139a and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tIX/s901/f"},"text":"Pub. L. 111–383, div. A, title IX, § 901(f)","children":[],"tail":", title X, § 1075(b)(5), "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4322"},"text":"124 Stat. 4322","children":[],"tail":", 4369; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/f/4"},"text":"Pub. L. 112–239, div. A, title X, § 1076(f)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1952"},"text":"126 Stat. 1952","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tIX/s912/c"},"text":"Pub. L. 115–91, div. A, title IX, § 912(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1521"},"text":"131 Stat. 1521","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s902/5"},"text":"Pub. L. 116–92, div. A, title IX, § 902(5)","children":[],"tail":", title XVI, § 1621(e)(1)(A)(iii), "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1543"},"text":"133 Stat. 1543","children":[],"tail":", 1733; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1883/b/2"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1883(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4294"},"text":"134 Stat. 4294","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tIX/s902/a"},"text":"Pub. L. 118–31, div. A, title IX, § 902(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/355"},"text":"137 Stat. 355","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVII/s1701/a/3"},"text":"Pub. L. 118–159, div. A, title XVII, § 1701(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2203"},"text":"138 Stat. 2203","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVII/s1701/a/4"},"text":"Pub. L. 119–60, div. A, title XVII, § 1701(a)(4)","children":[],"tail":", title XVIII, § 1801(a)(2)(C), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1208"},"text":"139 Stat. 1208","children":[],"tail":", 1222.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida769b6dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida769b6de-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida769b6df-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this subsection, referred to in subsec. (h), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida769b6e0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 139a was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s138b"},"text":"section 138b of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 139a was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4351"},"text":"section 4351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida769b6e1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1701/a/4"},"text":"Pub. L. 119–60, § 1701(a)(4)","children":[],"tail":", substituted “section 3221” for “section 2334”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1801/a/2/C"},"text":"Pub. L. 119–60, § 1801(a)(2)(C)","children":[],"tail":", in introductory provisions, inserted “shall carry out the requirements of this section in accordance with the objectives established pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3102"},"text":"section 3102 of this title","children":[],"tail":" and” before “shall serve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1701/a/4"},"text":"Pub. L. 119–60, § 1701(a)(4)","children":[],"tail":", substituted “section 3221” for “section 2334”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “out by the Director” for “out by Director” and “and any” for “an any”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s902/a/1/A"},"text":"Pub. L. 118–31, § 902(a)(1)(A)","children":[],"tail":", substituted “and ensuring” for “, ensuring” and struck out “, and assessing the effect of spending by the Department of Defense on the United States economy” after “accurately and completely”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s902/a/1/B"},"text":"Pub. L. 118–31, § 902(a)(1)(B)","children":[],"tail":", inserted “, including the standardization of analytical methodologies and the establishment and maintenance of a centralized knowledge repository of physical attributes or other data for modeling and simulation purposes” after “defense resources”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s902/a/2"},"text":"Pub. L. 118–31, § 902(a)(2)","children":[],"tail":", added subsecs. (e) to (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsecs. (b)(1)(A), (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", which directed that each reference in the text of title 10 to a section that was redesignated by title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", as such section was in effect before the redesignation, be amended by striking such reference and inserting a reference to the appropriate redesignated section, was not executed with respect to “section 2334”, which was redesignated as multiple sections."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (d)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1621/e/1/A/iii"},"text":"Pub. L. 116–92, § 1621(e)(1)(A)(iii)","children":[],"tail":", substituted “Under Secretary of Defense for Intelligence and Security” for “Under Secretary of Defense for Intelligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s902/5"},"text":"Pub. L. 116–92, § 902(5)","children":[],"tail":", substituted “Under Secretary of Defense for Acquisition and Sustainment, the Under Secretary of Defense for Research and Engineering,” for “Under Secretary of Defense for Acquisition, Technology, and Logistics”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (d)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":", which directed amendment of par. (4) by inserting a period at end, was not executed to reflect the probable intent of Congress and the prior amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1075/b/5"},"text":"Pub. L. 111–383, § 1075(b)(5)","children":[],"tail":". See 2011 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s901/f"},"text":"Pub. L. 111–383, § 901(f)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s139c"},"text":"section 139c of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1075/b/5"},"text":"Pub. L. 111–383, § 1075(b)(5)","children":[],"tail":", which directed amendment of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s139c"},"text":"section 139c of this title","children":[],"tail":" by inserting a period at the end of subsec. (d)(4), was executed to this section, to reflect the probable intent of Congress and the renumbering of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s139c"},"text":"section 139c of this title","children":[],"tail":" as this section by "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/s901/f"},"text":"Pub. L. 111–383, § 901(f)","children":[],"tail":". See above."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida769b6e2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida769b6e3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1883/b/2"},"text":"section 1883(b)(2) of Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida769b6e4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s901/f"},"text":"section 901(f) of Pub. L. 111–383","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2011-01-01"},"text":"Jan. 1, 2011","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/s901/p"},"text":"section 901(p) of Pub. L. 111–383","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s131"},"text":"section 131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida769b6e5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Personnel and Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/23/tI/s101/c"},"text":"Pub. L. 111–23, title I, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1709"},"text":"123 Stat. 1709","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/23/tI/s101/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of functions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The functions of the Office of Program Analysis and Evaluation of the Department of Defense, including the functions of the Cost Analysis Improvement Group, are hereby transferred to the Office of the Director of Cost Assessment and Program Evaluation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of personnel to deputy director for independent cost assessment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The personnel of the Cost Analysis Improvement Group are hereby transferred to the Deputy Director for Cost Assessment in the Office of the Director of Cost Assessment and Program Evaluation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of personnel to deputy director for program analysis and evaluation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The personnel (other than the personnel transferred under paragraph (2)) of the Office of Program Analysis and Evaluation are hereby transferred to the Deputy Director for Program Evaluation in the Office of the Director of Cost Assessment and Program Evaluation.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida769b6e6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pilot Program on Alternative Analysis; Establishment of Analysis Working Group","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tIX/s902/b"},"text":"Pub. L. 118–31, div. A, title IX, § 902(b)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/357"},"text":"137 Stat. 357","children":[],"tail":", 358, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dA/tIX/s902/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pilot Program on Alternative Analysis.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2024-05-01"},"text":"May 1, 2024","children":[],"tail":", the Director of Cost Assessment and Program Evaluation shall establish a pilot program on alternative analysis (referred to in this subsection as the ‘pilot program’)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Structure","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the pilot program, the Director shall establish three analytical groups focused on programmatic analysis in the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Year 1 of the future-years defense program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s221"},"text":"section 221 of title 10","children":[],"tail":", United States Code, beginning with fiscal year 2025."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Years 2 through 5 of the future-years defense program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Years outside the future-years defense program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director shall ensure that at least one strategic portfolio review or an equivalent analytical effort is conducted each year under the pilot program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The pilot program shall terminate on ","children":[{"tag":"date","attrib":{"date":"2028-09-30"},"text":"September 30, 2028","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Analysis Working Group.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2024-05-01"},"text":"May 1, 2024","children":[],"tail":", the Secretary of Defense shall establish within the Department of Defense a working group to be known as the ‘Analysis Working Group’."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall ensure that the Analysis Working Group possesses sufficient full-time equivalent support personnel to carry out the duties of the Group, including expansive coordination activities across the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regular members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Analysis Working Group shall be composed of at least one representative from each of the following components of the Department of Defense:","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of the Director of Cost Assessment and Program Evaluation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Directorate for Joint Force Development (J7) of the Joint Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Directorate for Force Structure, Resources, and Assessment (J8) of the Joint Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"“(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of the Secretary of Defense for Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"“(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Digital and Artificial Intelligence Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Observers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At least one representative from each of the following commands shall serve as observers of the Analysis Working Group:","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Indo-Pacific Command.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States European Command.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Central Command.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Analysis Working Group shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish clear priorities and standards to focus analysts on decision support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve transparency of methodologies, tools, and tradecraft across the analytic community, including testing and validation for new or emerging methodologies, tools, and tradecraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve quality of and expand access to data, including evaluation of new data sets, or application of existing data sets in new or novel ways;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evolve the methodologies, tools, and tradecraft methods and tools used in strategic analysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resolve classified access and infrastructure challenges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster a workforce and organizations that are innovative, creative, and provide high-quality strategic decision support; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"“(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out such other activities as the Secretary of Defense determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in subsection (b) or (c) shall be construed to interfere with the authority of the Chiefs of Staff of the Armed Forces to establish military requirements, performance requirements, and joint performance requirements, or the authority of the Joint Requirements Oversight Council to validate such requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s181"},"text":"section 181 of title 10","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
