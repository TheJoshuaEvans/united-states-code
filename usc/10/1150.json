{"tag":"section","attrib":{"id":"ida8a48172-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1150"},"text":null,"children":[{"tag":"num","attrib":{"value":"1150"},"text":"§ 1150.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affiliation with Guard and Reserve units: waiver of certain limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8a48173-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1150/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preference for Certain Persons","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who is separated from the armed forces during the period beginning on ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"October 1, 1990","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2001-12-31"},"text":"December 31, 2001","children":[],"tail":", and who applies to become a member of a National Guard or Reserve unit within one year after the date of such separation shall be given preference over other equally qualified applicants for existing or projected vacancies within the unit to which the member applies."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8a48174-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1150/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limited Waiver of Strength Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under regulations prescribed by the Secretary of Defense, a person covered by subsection (a) who enters a National Guard or Reserve unit pursuant to an application described in such subsection may be retained in that unit for up to three years without regard to reserve-component strength limitations so long as the individual maintains good standing in that unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8a48175-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1150/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coast Guard","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall apply to the Coast Guard in the same manner and to the same extent as it applies to the Department of Defense. The Secretary of Homeland Security shall prescribe regulations to implement this section for the Coast Guard when it is not operating as a service in the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8a48176-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tV/s502/a/1"},"text":"Pub. L. 101–510, div. A, title V, § 502(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1557"},"text":"104 Stat. 1557","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tV/s514"},"text":"Pub. L. 102–484, div. A, title V, § 514","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2406"},"text":"106 Stat. 2406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tV/s561/j"},"text":"Pub. L. 103–160, div. A, title V, § 561(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1668"},"text":"107 Stat.