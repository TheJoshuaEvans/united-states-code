{"tag":"section","attrib":{"id":"ida8cd1845-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1449"},"text":null,"children":[{"tag":"num","attrib":{"value":"1449"},"text":"§ 1449.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mental incompetency of member","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8cd1846-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1449/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election by Secretary Concerned on Behalf of Mentally Incompetent Member","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a person to whom ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1448"},"text":"section 1448 of this title","children":[],"tail":" applies is determined to be mentally incompetent by medical officers of the armed force concerned or of the Department of Veterans Affairs, or by a court of competent jurisdiction, an election described in subsection (a)(2) or (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1448"},"text":"section 1448 of this title","children":[],"tail":" may be made on behalf of that person by the Secretary concerned."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8cd1847-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1449/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revocation of Election by Member.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8cd1848-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1449/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority upon subsequent determination of mental competence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a person for whom the Secretary has made an election under subsection (a) is later determined to be mentally competent by an authority named in that subsection, that person may, within 180 days after that determination, revoke that election.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8cd1849-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1449/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deductions from retired pay or CRSC not to be refunded","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any deduction made from retired pay or combat-related special compensation by reason of such an election may not be refunded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8cd184a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/425/s1/3"},"text":"Pub. L. 92–425, § 1(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-21"},"text":"Sept. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/708"},"text":"86 Stat. 708","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/397/tII/s207/a"},"text":"Pub. L. 95–397, title II, § 207(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/848"},"text":"92 Stat. 848","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXIV/s1407/a/3"},"text":"Pub. L. 101–189, div. A, title XIV, § 1407(a)(3)","children":[],"tail":", title XVI, § 1621(a)(1), "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1588"},"text":"103 Stat. 1588","children":[],"tail":", 1602; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tVI/s634"},"text":"Pub. L. 104–201, div. A, title VI, § 634","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2560"},"text":"110 Stat. 2560","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVI/s643/c/1"},"text":"Pub. L. 114–328, div. A, title VI, § 643(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2166"},"text":"130 Stat. 2166","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8cd184b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8cd184c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8cd184d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" inserted “or CRSC” after “retired pay” in heading and “or combat-related special compensation” after “from retired pay” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “If a person to whom "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1448"},"text":"section 1448 of this title","children":[],"tail":" applies is determined to be mentally incompetent by medical officers of the armed force concerned or of the Department of Veterans Affairs, or by a court of competent jurisdiction, any election described in subsection (a)(2) or (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1448"},"text":"section 1448 of this title","children":[],"tail":" may be made on behalf of that person by the Secretary concerned. If the person for whom the Secretary has made an election is later determined to be mentally competent by an authority named in the first sentence, he may, within 180 days after that determination revoke that election. Any deductions made from retired pay by reason of such an election will not be refunded.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" substituted “Department of Veterans Affairs” for “Veterans’ Administration” and struck out “or retainer” after “made from retired”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/397"},"text":"Pub. L. 95–397","children":[],"tail":" substituted “subsection (a)(2) or (b)” for “the first sentence of subsection (a), or subsection (b)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8cd184e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8cd184f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/397"},"text":"Pub. L. 95–397","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1978-10-01"},"text":"Oct. 1, 1978","children":[],"tail":", and applicable to annuities payable by virtue of amendment for months beginning on or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/397/s210"},"text":"section 210 of Pub. L. 95–397","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1447"},"text":"section 1447 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
