{"tag":"section","attrib":{"id":"ida88cb37d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1095b"},"text":"§ 1095b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" TRICARE program: contractor payment of certain claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida88cb37e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of Claims","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida88cb37f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may authorize a contractor under the TRICARE program to pay a claim described in paragraph (2) before seeking to recover from a third-party payer the costs incurred by the contractor to provide health care services that are the basis of the claim to a beneficiary under such program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida88cb380-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A claim under this paragraph is a claim—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida88cb381-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is submitted to the contractor by a provider under the TRICARE program for payment for services for health care provided to a covered beneficiary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida88cb382-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is identified by the contractor as a claim for which a third-party payer may be liable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida88cb383-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recovery From Third-Party Payers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The United States shall have the same right to collect charges related to claims described in subsection (a) as charges for claims under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1095"},"text":"section 1095 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida88cb384-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Third-Party Payer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “third-party payer” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1095/h"},"text":"section 1095(h) of this title","children":[],"tail":", except that such term excludes primary medical insurers."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida88cb385-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tVII/s711/a/1"},"text":"Pub. L. 105–261, div. A, title VII, § 711(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2058"},"text":"112 Stat. 2058","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVII/s716/c/2"},"text":"Pub. L. 106–65, div. A, title VII, § 716(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/692"},"text":"113 Stat. 692","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida88cb386-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida88cb387-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida88cb388-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “The United States shall have the same right to collect charges related to claims described in subsection (a) as charges for claims under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1095"},"text":"section 1095 of this title","children":[],"tail":".” for “A contractor for the provision of health care services under the TRICARE program that pays a claim described in subsection (a)(2) shall have the right to collect from the third-party payer the costs incurred by such contractor on behalf of the covered beneficiary. The contractor shall have the same right to collect such costs under this subsection as the right of the United States to collect costs under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1095"},"text":"section 1095 of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
