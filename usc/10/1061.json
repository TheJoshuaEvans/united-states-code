{"tag":"section","attrib":{"id":"ida855eba4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1061"},"text":null,"children":[{"tag":"num","attrib":{"value":"1061"},"text":"§ 1061.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survivors of certain Reserve and Guard members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida855eba5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1061/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Benefits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe regulations to allow dependents of members of the uniformed services described in subsection (b) to use commissary and exchange stores on the same basis as dependents of members of the uniformed services who die while on active duty for a period of more than 30 days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida855eba6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1061/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Dependents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A dependent referred to in subsection (a) is a dependent of a member of a uniformed service who died—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida855eba7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1061/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while on active duty, active duty for training, or inactive-duty training (regardless of the period of such duty); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida855eba8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1061/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while traveling to or from the place at which the member was to perform, or has performed, active duty, active duty for training, or inactive-duty training (regardless of the period of such duty).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida855eba9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/370/s1/c/1"},"text":"Pub. L. 100–370, § 1(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-07-19"},"text":"July 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/841"},"text":"102 Stat. 841","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida855ebaa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida855ebab-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section is based on ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/tIII/s308"},"text":"Pub. L. 99–145, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/618"},"text":"99 Stat. 618","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
