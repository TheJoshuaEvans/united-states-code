{"tag":"section","attrib":{"id":"ida9740637-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2389"},"text":null,"children":[{"tag":"num","attrib":{"value":"2389"},"text":"§ 2389.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ensuring safety regarding insensitive munitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense shall ensure, to the extent practicable, that insensitive munitions under development or procurement are safe throughout development and fielding when subject to unplanned stimuli.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida9740638-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tVIII/s834/a/1"},"text":"Pub. L. 107–107, div. A, title VIII, § 834(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1191"},"text":"115 Stat. 1191","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9740639-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida974063a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida974063b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2389, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/696/s1/1"},"text":"Pub. L. 89–696, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-19"},"text":"Oct. 19, 1966","chi