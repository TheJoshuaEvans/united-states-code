[{"tag":"html:a","attrib":{"href":"/us/act/1950-06-28/ch383/s402/a"},"text":"June 28, 1950, ch. 383, § 402(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/272"},"text":"64 Stat. 272","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 1135; ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-06-28/ch383/s402/a"},"text":"June 28, 1950, ch. 383, § 402(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/272"},"text":"64 Stat. 272","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “While * * * on shore duty” are substituted for the words “under orders to act on shore”, in 10:1259d and 1259e, and 34:541. The words “branch, office, or” and “during the time such detachment is so acting or proceeding to act”, in 10:1259d and 1259e, and 34:541, are omitted as surplusage. The words “their baggage, provisions, and cannon”, in 10:1259e and 34:541, are omitted as surplusage. The words “and shall furnish the naval officer commanding any such detachment, and his necessary aides, with horses, accouterments, and forage”, in 10:1259e and 34:541, are omitted as obsolete.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaf8ab1a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note