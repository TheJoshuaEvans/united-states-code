%","id":"idab5cc389-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1956 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8034(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8034(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1812 (1st sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1812 (less 1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1951-09-19/ch407"},"text":"Sept. 19, 1951, ch. 407","children":[],"tail":", §§ 202, 204, "},{"tag":"html:a","attrib":{"href":"/us/stat/65/328"},"text":"65 Stat. 328","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8034(c)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8034(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1814(a) (1st 10 words).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1814(b) (2d sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1814(c).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:38 (last par.).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1814(a) (less 1st 10 words).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1814(b) (less 2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-06-03/ch134/s5"},"text":"June 3, 1916, ch. 134, § 5","children":[],"tail":" (last par.); added "},{"tag":"html:a","attrib":{"href":"/us/act/1933-06-15/ch87/s2"},"text":"June 15, 1933, ch. 87, § 2","children":[],"tail":" (last par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/48/154"},"text":"48 Stat. 154","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “not for” are substituted for the words “no person shall serve as Chief of Staff for a term of”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “so serving” are substituted for the words “holding office as such”. The words “regular or reserve” are substituted for the word “permanent”, since there are no other “permanent” grades in the Air Force. The words “in the Air Force” are omitted as surplusage. The words “and shall take rank as prescribed by law” are omitted as superseded by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s743"},"text":"section 743 of this title","children":[],"tail":". The words “He shall receive the compensation prescribed by law” are omitted as covered by the Career Compensation Act of 1949, "},{"tag":"ref","attrib":{"href":"/us/stat/63/802"},"text":"63 Stat. 802","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t37/s231"},"text":"37 U.S.C. 231","children":[],"tail":" et seq.)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the provisions of 10:1814 relating to the direction of the Secretary of the Air Force over the Chief of Staff are combined. The words “and subsection (c) of this section” and “state of” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), 10:38 (last par.) is omitted as covered by 10:1814(a). The words “and other provisions of law” are substituted for the words “and by other laws”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab5cc38a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1962 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"The changes correct references to section 202(j) of the National Security Act of 1947, which is now set out as ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s124"},"text":"section 124 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab5cc38b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idab5cc38c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s664/f"},"text":"Section 664(f) of this title","children":[],"tail":", referred to in subsec. (a)(2)(B), was redesignated as "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s664/d"},"text":"section 664(d) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tV/s510/g/1"},"text":"Pub. L. 114–328, div. A, title V, § 510(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2111"},"text":"130 Stat. 2111","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab5cc38d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1847/e/6/B"},"text":"Pub. L. 116–283, § 1847(e)(6)(B)","children":[],"tail":", which directed substitution of “, 3103, and 4274” for “and 2547”, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/r/1/B"},"text":"Pub. L. 117–81, § 1701(r)(1)(B)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1808/d/3"},"text":"Pub. L. 116–283, § 1808(d)(3)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/r/2"},"text":"Pub. L. 117–81, § 1701(r)(2)","children":[],"tail":", substituted “and 3104” for “and 2547”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s806/c"},"text":"Pub. L. 115–232, § 806(c)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8033"},"text":"section 8033 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 9013(f)” for “section 8013(f)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 9040” for “section 8040”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s1652/a/3"},"text":"Pub. L. 114–92, § 1652(a)(3)","children":[],"tail":", inserted “, including pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8040"},"text":"section 8040 of this title","children":[],"tail":"” after “other provisions of law”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s802/d/4/D"},"text":"Pub. L. 114–92, § 802(d)(4)(D)","children":[],"tail":", substituted “sections 171 and 2547” for “section 171”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" substituted “full tour of duty in a joint duty assignment (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s664/f"},"text":"section 664(f) of this title","children":[],"tail":")” for “joint duty assignment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433"},"text":"Pub. L. 99–433","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8034"},"text":"section 8034 of this title","children":[],"tail":" as this section, substituted “Chief of Staff” for “Chief of Staff: appointment; duties” in section catchline, and amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) The Chief of Staff shall be appointed for a period of four years by the President, by and with the advice and consent of the Senate, from the general officers of the Air Force. He serves during the pleasure of the President. In time of war or national emergency declared by the Congress after ","children":[{"tag":"date","attrib":{"date":"1968-12-31"},"text":"December 31, 1968","children":[],"tail":", he may be reappointed for a term of not more than four years."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) The Chief of Staff, while so serving, has the grade of general without vacating his regular or reserve grade.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) Except as otherwise prescribed by law and subject to section 8012(c) and (d) of this title, the Chief of Staff performs his duties under the direction of the Secretary of the Air Force, and is directly responsible to the Secretary for the efficiency of the Air Force, its preparedness for military operations, and plans therefor.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(d) The Chief of Staff shall—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) preside over the Air Staff;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) send the plans and recommendations of the Air Staff to the Secretary, and advise him with regard thereto;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) after approval of the plans or recommendations of the Air Staff by the Secretary, act as the agent of the Secretary in carrying them into effect;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) exercise supervision over such of the members and organizations of the Air Force as the Secretary of the Air Force determines. Such supervision shall be exercised in a manner consistent with the full operational command vested in unified or specified combatant commanders under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s124"},"text":"section 124 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) perform the duties prescribed for him by sections 141 and 171 of this title and other provisions of law; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) perform such other military duties, not otherwise assigned by law, as are assigned to him by the President.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/22"},"text":"Pub. L. 97–22","children":[],"tail":" struck out the comma after “his regular or reserve grade”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" struck out “and is counted as one of the officers authorized to serve in a grade above lieutenant general under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8066"},"text":"section 8066 of this title","children":[],"tail":"” after “without vacating his regular or reserve grade”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/22"},"text":"Pub. L. 90–22","children":[],"tail":" changed the requirement that the Chief of Staff be reappointed only with the advice and consent of the Senate by providing for his reappointment for a term of not more than four years by the President without such advice and consent in a time of war or national emergency as declared by the Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/651"},"text":"Pub. L. 87–651","children":[],"tail":" substituted “under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s124"},"text":"section 124 of this title","children":[],"tail":"” for “pursuant to section 202(j) of the National Security Act of 1947, as amended”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (d)(4) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/599"},"text":"Pub. L. 85–599","children":[],"tail":" redesignated pars. (5) to (7) as (4) to (6), respectively, and in par. (4), as redesignated, required the Chief of Staff to exercise supervision only as the Secretary of the Air Force determines and in a manner consistent with the full operational command vested in unified or specified combatant commanders. Former par. (4), which related to command over the air defense, strategic, tactical, and other major commands, was struck out."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab5cc38e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab5cc38f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" applicable as if included in the enactment of title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" as enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/a/2"},"text":"section 1701(a)(2) of Pub. L. 117–81","children":[],"tail":", set out in a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":" and note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab5cc390-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab5cc391-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/22/s10/b"},"text":"Pub. L. 97–22, § 10(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-07-10"},"text":"July 10, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/137"},"text":"95 Stat. 137","children":[],"tail":", provided that the amendment made by that section is effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab5cc392-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701"},"text":"section 701 of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},