{"tag":"section","attrib":{"id":"ida8d44394-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1454"},"text":null,"children":[{"tag":"num","attrib":{"value":"1454"},"text":"§ 1454.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correction of administrative errors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8d44395-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1454/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may, under regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1455"},"text":"section 1455 of this title","children":[],"tail":", correct or revoke any election under this subchapter when the Secretary considers it necessary to correct an administrative error."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8d44396-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1454/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Finality","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except when procured by fraud, a correction or revocation under this section is final and conclusive on all officers of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8d44397-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/425/s1/3"},"text":"Pub. L. 92–425, § 1(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-21"},"text":"Sept. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/711"},"text":"86 Stat. 711","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXIV/s1407/a/10/A"},"text":"Pub. L. 101–189, div. A, title XIV, § 1407(a)(10)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1589"},"text":"103 Stat. 1589","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tVI/s634"},"text":"Pub. L. 104–201, div. A, title VI, § 634","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2577"},"text":"110 Stat. 2577","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8d44398-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8d44399-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8d4439a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The Secretary concerned may, under regulations prescribed under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1455"},"text":"section 1455 of this title","children":[],"tail":", correct or revoke any election under this subchapter when he considers it necessary to correct an administrative error. Except when procured by fraud, a correction or revocation under this section is final and conclusive on all officers of the United 