{"tag":"section","attrib":{"id":"ida9d81eeb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2808a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2808a"},"text":"§ 2808a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facility construction or repair: transactions other than contracts and grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9d81eec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2808a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2853"},"text":"section 2853 of this title","children":[],"tail":", the Secretary concerned may enter into transactions (other than contracts, cooperative agreements, or grants) to carry out repair and construction projects for facilities, including the planning, design, engineering, prototyping, piloting, and execution of such repair and construction projects."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9d81eed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2808a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may carry out projects under subsection (a) using amounts available to such Secretary for military construction, operation and maintenance, or research, development, test, and evaluation, notwithstanding chapters 221 and 223 and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2851/a"},"text":"section 2851(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9d81eee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2808a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Follow-on Transactions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A transaction entered into under this section for a project may provide for the award of a follow-on production contract or transaction to the participants in the transaction without further competition, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9d81eef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2808a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" competitive procedures were used for the selection of parties for participation in the original transaction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d81ef0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2808a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the participants in the original transaction successfully completed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9d81ef1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2808a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a complete and useable facility; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9d81ef2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2808a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a complete and useable improvement to a facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9d81ef3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2808a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9d81ef4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2808a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 14 days before entering into a transaction for a project under this section, the Secretary concerned shall submit to the congressional defense committees a notification of the intent to use this authority in an electronic medium pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s480"},"text":"section 480 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d81ef5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2808a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each notification under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9d81ef6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2808a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9d81ef7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2808a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the project and its location;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9d81ef8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2808a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated project cost and source of funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9d81ef9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2808a/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient or contractor selected to execute the project, if known at the time of notification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9d81efa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2808a/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rationale for using the authority under this section instead of the process for military construction projects under subchapter I of chapter 169 of title 10, United States Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9d81efb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2808a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of enactment of this section, and biannually thereafter, the Secretary of Defense shall submit to the congressional defense committees a report summarizing the use of the authority under this section during the period covered by the report, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9d81efc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2808a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the military department or Defense Agency carrying out each project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d81efd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2808a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total cost of each project and the source of the funds obligated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d81efe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2808a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the scope, purpose, and location of each project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d81eff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2808a/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any observed differences in project delivery timelines or execution speed as a result of using the authority under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d81f00-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2808a/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of cost savings, efficiencies, or risk reductions realized through the use of such authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d81f01-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2808a/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lessons learned and recommendations to improve the implementation, oversight, or scope of such authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9d81f02-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dB/tXXVIII/s2802/a"},"text":"Pub. L. 119–60, div. B, title XXVIII, § 2802(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1292"},"text":"139 Stat. 1292","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9d81f03-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9d81f04-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida9d81f05-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (e), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9d81f06-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9d81f07-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dB/tXXVIII/s2802/b"},"text":"Pub. L. 119–60, div. B, title XXVIII, § 2802(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1293"},"text":"139 Stat. 1293","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dB/tXXVIII/s2802/b"},"text":"“The amendments made by this section [enacting this section] shall apply with respect to transactions entered into on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
