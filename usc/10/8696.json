{"tag":"section","attrib":{"id":"idab403bb5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696"},"text":null,"children":[{"tag":"num","attrib":{"value":"8696"},"text":"§ 8696.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Navy shipbuilding workforce development special incentive","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab403bb6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab403bb7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy shall include in any solicitation for a covered contract a special incentive for workforce development that funds one or more workforce development activities described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403bb8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of special incentive","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of a special incentive required under subsection (a)(1) shall be equal to not less than one quarter of one percent and not more than one percent of the estimated cost of the covered contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403bb9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403bba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Navy may waive one or more of the requirements of this section if the Secretary determines—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idab403bbb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unreasonable cost or delay would be incurred by complying with such requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab403bbc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing workforce development initiatives are sufficient to meet workforce needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab403bbd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are minimal workforce development issues to be addressed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab403bbe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/a/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is not in the national security interests of the United States to comply with such requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bbf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less than 30 days prior to issuing a waiver under subparagraph (A), the Secretary of the Navy shall submit to the congressional defense committees written notice of the intent of the Secretary to issue such a waiver. Such notice shall specify the basis for such waiver and include a detailed explanation of the reasons for issuing the waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403bc0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matching Contribution Requirement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab403bc1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds for a special incentive for workforce development required under subsection (a)(1) may be expended only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403bc2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on or after the date on which the service acquisition executive of the Navy receives a written commitment from one or more entities described in paragraph (2) of separate and distinct cumulative monetary contributions to be made on or after the date of such commitment for workforce development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bc3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an amount that is equal to the aggregate amount of all monetary contributions from entities that made commitments under subparagraph (A) not to exceed the amount of funding made available for the special incentive under subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403bc4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Entities described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The entities described in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403bc5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The prime contractor that was awarded a covered contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bc6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A qualified subcontractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bc7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State government or other State entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bc8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A county government or other county entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bc9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A local government or other local entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An industry association, organization, or consortium that directly supports workforce development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403bcb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a case in which the aggregate amount of all monetary contributions from entities that made commitments under paragraph (1)(A) is less than the minimum amount specified for the special incentive under subsection (a)(2), funds for the special incentive may be expended in an amount equal to such lesser amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403bcc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Activities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab403bcd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds for a special incentive for workforce development required under subsection (a)(1) may be obligated or expended only to provide for the activities described in paragraph (2) in support of the production and production support workforce of the prime contractor concerned or a qualified subcontractor concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403bce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The activities described in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403bcf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The creation of short- and long-term workforce housing, transportation, and other support services to facilitate attraction, relocation, and retention of workers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bd0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The expansion of local talent pipeline programs for both new and existing workers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bd1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Investments in long-term outreach in middle school and high school programs, specifically career and technical education programs, to promote and develop manufacturing skills.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bd2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The development or modification of facilities for the primary purpose of workforce development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bd3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment of direct costs attributable to workforce development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bd4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Attraction and retention bonus programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bd5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On-the-job training to develop key manufacturing skills.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403bd6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The service acquisition executive of the Navy shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab403bd7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the final approval of the use of funds for a special incentive for workforce development required under subsection (a)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403bd8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 30 days after the date on which such approval is provided, certify to the congressional defense committees compliance with the requirements of subsections (b) and (c), including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403bd9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed explanation of such compliance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bda-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the associated benefits to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idab403bdb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab403bdc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the shipbuilding industrial base of the Navy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403bdd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab403bde-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered contract” means a prime contract for the construction of a naval vessel funded using amounts appropriated or otherwise made available for Shipbuilding and Conversion, Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403bdf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8696/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “qualified subcontractor” means a subcontractor that will deliver the vessel or vessels awarded under a covered contract to the Navy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab403be0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tI/s122/a"},"text":"Pub. L. 117–263, div. A, title I, § 122(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2441"},"text":"136 Stat. 2441","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab403be1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab403be2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idab403be3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 8696 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8697"},"text":"section 8697 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab403be4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idab403be5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tI/s122/c"},"text":"Pub. L. 117–263, div. A, title I, § 122(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2443"},"text":"136 Stat. 2443","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tI/s122/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8696"},"text":"Section 8696 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a solicitation for a covered contract (as defined in subsection (e) of that section) made on or after ","children":[{"tag":"date","attrib":{"date":"2023-06-01"},"text":"June 1, 2023","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a solicitation or award of a covered contract, if otherwise determined appropriate by the Secretary of the Navy.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
