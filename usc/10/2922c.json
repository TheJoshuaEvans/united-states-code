{"tag":"section","attrib":{"id":"ida9fbfbba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2922c"},"text":"§ 2922c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement of gasohol as motor vehicle fuel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9fbfbbb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Federal Fuel Procurements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Consistent with the vehicle management practices prescribed by the heads of affected departments and agencies of the Federal Government and consistent with Executive Order Number 12261, whenever the Secretary of Defense enters into a contract for the procurement of unleaded gasoline that is subject to tax under section 4081 of the Internal Revenue Code of 1986 for motor vehicles of a department or agency of the Federal Government other than the Department of Defense, the Secretary shall buy alcohol-gasoline blends containing at least 10 percent domestically produced alcohol in any case in which the price of such fuel is the same as, or lower than, the price of unleaded gasoline.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9fbfbbc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Solicitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever the Secretary issues a solicitation for bids to procure unleaded gasoline under subsection (a), the Secretary shall expressly include in such solicitation a request for bids on alcohol-gasoline blends containing at least 10 percent domestically produced alcohol.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9fbfbbd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295/s1/29/A"},"text":"Pub. L. 97–295, § 1(29)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1293"},"text":"96 Stat. 1293","children":[],"tail":", § 2398; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVIII/s841/a"},"text":"Pub. L. 102–190, div. A, title VIII, § 841(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1448"},"text":"105 Stat. 1448","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tX/s1061/h"},"text":"Pub. L. 104–106, div. A, title X, § 1061(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/443"},"text":"110 Stat. 443","children":[],"tail":"; renumbered § 2922c, "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dB/tXXVIII/s2851/b/2"},"text":"Pub. L. 109–364, div. B, title XXVIII, § 2851(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2494"},"text":"120 Stat. 2494","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9fbfbbe-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida9fbfbbf-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida9fbfbc0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2398","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:2388 (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Nov. 9, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/107/s815"},"text":"Pub. L. 96–107, § 815","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/93/817"},"text":"93 Stat. 817","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “prescribed” is substituted for “determined” because it is more appropriate. The word “Secretary” is substituted for “Department of Defense” because the responsibility is in the head of the agency. The word “shall” is substituted for “is authorized and directed” for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9fbfbc1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida9fbfbc2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order Number 12661, referred to in subsec. (a), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8871"},"text":"section 8871 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4081 of the Internal Revenue Code of 1986, referred to in subsec. (a), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4081"},"text":"section 4081 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9fbfbc3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2398"},"text":"section 2398 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1061/h/1"},"text":"Pub. L. 104–106, § 1061(h)(1)","children":[],"tail":", (2)(A), redesignated subsec. (b) as (a) and struck out former subsec. (a) which read as follows: “"},{"tag":"inline","attrib":{},"text":"DOD Motor Vehicles","children":[],"tail":".—To the maximum extent feasible and consistent with overall defense needs and vehicle management practices prescribed by the Secretary of Defense, the Secretary shall make contracts, by competitive bid and subject to appropriations, to purchase domestically produced alcohol or alcohol-gasoline blends containing at least 10 percent domestically produced alcohol for use in motor vehicles owned or operated by the Department of Defense.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1061/h/2"},"text":"Pub. L. 104–106, § 1061(h)(2)","children":[],"tail":", redesignated subsec. (c) as (b) and substituted “subsection (a)” for “subsection (b)”. Former subsec. (b) redesignated (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1061/h/2/A"},"text":"Pub. L. 104–106, § 1061(h)(2)(A)","children":[],"tail":", redesignated subsec. (c) as (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9fe44b4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9fe44b5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVIII/s841/b"},"text":"Pub. L. 102–190, div. A, title VIII, § 841(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1448"},"text":"105 Stat. 1448","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/190/dA/tVIII/s841/b"},"text":"“Section 2398(b) [now 2922c(a)] of title 10, United States Code, as added by subsection (a), shall apply with respect to contracts awarded pursuant to solicitations issued after the expiration of the 180-day period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
