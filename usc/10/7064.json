{"tag":"section","attrib":{"id":"idaad9b0ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7064"},"text":null,"children":[{"tag":"num","attrib":{"value":"7064"},"text":"§ 7064.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special branches","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaad9b100-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7064/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The special branches of the Army consist of commissioned officers of the Regular Army appointed therein, other members of the Army assigned thereto by the Secretary of the Army, and the sections prescribed in this chapter. The special branches are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad9b101-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7064/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each corps of the Army Medical Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b102-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7064/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Judge Advocate General’s Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b103-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7064/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chaplains; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b104-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7064/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other special branches as may be established by the Secretary of the Army under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad9b105-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7064/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army may establish special branches for the Army and may assign commissioned officers (other than officers of the Regular Army) and members to such branches.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad9b106-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7064/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Commissioned officers of the Regular Army may be appointed in a special branch, but the Secretary may not assign any officer of the Regular Army to a special branch.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad9b107-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/167"},"text":"70A Stat. 167","children":[],"tail":", § 3064; "},{"tag":"ref","attrib":{"href":"/us/pl/90/329"},"text":"Pub. L. 90–329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-06-04"},"text":"June 4, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/170"},"text":"82 Stat. 170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tII/s231"},"text":"Pub. L. 96–513, title II, § 231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2886"},"text":"94 Stat. 2886","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/22/s5/a"},"text":"Pub. L. 97–22, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-07-10"},"text":"July 10, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/128"},"text":"95 Stat. 128","children":[],"tail":"; renumbered § 7064, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1838"},"text":"132 Stat. 1838","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaad9b108-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaad9b109-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaad9b10a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3064(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1g(b) (less words of 1st sentence after semicolon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-06-28/ch383/s306/b"},"text":"June 28, 1950, ch. 383, § 306(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/269"},"text":"64 Stat. 269","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3064(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1g(b) (words of 1st sentence after semicolon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “The special branches of the Army” are substituted for the words “There shall be in the Army certain branches, which shall be known as special branches, and which shall”. The words “authorized by sections 61–1, 81–1, and 231a of this title” are omitted as surplusage. The words “and the sections prescribed in this chapter” are inserted, since some of the corps of the Army Medical Service consist of members and sections. Clauses (1), (2), and (3) are substituted for 10:1g(b) (last sentence).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “who has been appointed and commissioned in some other special branch, or * * * without specification of branch” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaad9b10b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaad9b10c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3064"},"text":"section 3064 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/22/s5/a/1"},"text":"Pub. L. 97–22, § 5(a)(1)","children":[],"tail":", substituted “may assign commissioned officers (other than officers of the Regular Army) and members to such branches” for “may appoint commissioned officers in, and may assign members to, such branches”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/22/s5/a/2"},"text":"Pub. L. 97–22, § 5(a)(2)","children":[],"tail":", substituted “Commissioned officers of the Regular Army may be appointed in a special branch, but the Secretary” for “The Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s231/1"},"text":"Pub. L. 96–513, § 231(1)","children":[],"tail":", added cl. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s231/2"},"text":"Pub. L. 96–513, § 231(2)","children":[],"tail":", (3), added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/329"},"text":"Pub. L. 90–329","children":[],"tail":" substituted “Army Medical Department” for “Army Medical Service”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaad9b10d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaad9b10e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],