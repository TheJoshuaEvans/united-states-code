{"tag":"section","attrib":{"id":"idaae0dc71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7275"},"text":null,"children":[{"tag":"num","attrib":{"value":"7275"},"text":"§ 7275.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medal of honor; distinguished-service cross; distinguished-service medal: delegation of power to award","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President may delegate his authority to award the medal of honor, distinguished-service cross, and distinguished-service medal, to a commanding general of a separate army or higher unit in the field.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idaae0dc72-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/216"},"text":"70A Stat. 216","children":[],"tail":", § 3745; renumbered § 7275, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/b/11"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(b)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1838"},"text":"132 Stat. 1838","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaae0dc73-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaae0dc74-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaae0dc75-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attr