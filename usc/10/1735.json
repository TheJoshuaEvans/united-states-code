{"tag":"section","attrib":{"id":"ida90b0ada-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1735"},"text":null,"children":[{"tag":"num","attrib":{"value":"1735"},"text":"§ 1735.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education, training, and experience requirements for critical acquisition positions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida90b0adb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1735/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualification Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In establishing the education, training, and experience requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1723"},"text":"section 1723 of this title","children":[],"tail":" for critical acquisition positions, the Secretary of Defense shall, at a minimum, include the requirements set forth in subsections (b) through (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90b0adc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1735/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Managers and Deputy Program Managers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before being assigned to a position as a program manager or deputy program manager of a major defense acquisition program or a significant nonmajor defense acquisition program, a person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90b0add-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1735/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must have completed the program management course at the Defense Systems Management College or a management program at an accredited educational institution determined to be comparable by the Secretary of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90b0ade-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1735/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must have executed a written agreement as required in section 1734(b)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90b0adf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1735/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida90b0ae0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1735/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a program manager of a major defense acquisition program, must have at least eight years of experience in acquisition, at least two years of which were performed in a systems program office or similar organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90b0ae1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1735/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a program manager of a significant nonmajor defense acquisition program, must have at least six years of experience in acquisition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90b0ae2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1735/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a deputy program manager of a major defense acquisition program, must have at least six years of experience in acquisition, at least two years of which were performed in a systems program office or similar organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90b0ae3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1735/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a deputy program manager of a significant nonmajor defense acquisition program, must have at least four years of experience in acquisition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90b0ae4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1735/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Product Support Manager","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before being assigned to a position as product support manager, a person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90b0ae5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1735/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have completed all life-cycle logistics certification and training requirements prescribed by the Secretary of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90b0ae6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1735/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have executed a written agreement as required in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1734/b/2"},"text":"section 1734(b)(2) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90b0ae7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1735/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida90b0ae8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1735/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a product support manager of a major defense acquisition program, shall have at least eight years of experience in life-cycle logistics, at least two years of which were performed in a systems program office or similar organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90b0ae9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1735/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a product support manager of a significant nonmajor defense acquisition program, shall have at least six years of experience in life-cycle logistics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90b0aea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1735/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a product support manager for a covered system (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4324"},"text":"section 4324 of this title","children":[],"tail":"), shall be designated as a key leadership position."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90b0aeb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1735/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Portfolio Acquisition Executives","children":[],"tail":"."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":"—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before being assigned to a position as a portfolio acquisition executive, a person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90b0aec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1735/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must have completed the program management course at the Defense Systems Management College or a management program at an accredited educational institution in the private sector determined to be comparable by the Secretary of Defense, acting through the Under Secretary of Defense for Acquisition and Sustainment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90b0aed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1735/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must have at least 10 years experience in an acquisition position, at least four years of which were performed while assigned to a critical acquisition position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90b0aee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1735/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must have held a position as a program manager or a deputy program manager.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90b0aef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1735/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General and Flag Officers and Civilians in Equivalent Positions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before a general or flag officer, or a civilian serving in a position equivalent in grade to the grade of such an officer, may be assigned to a critical acquisition position, the person must have at least 10 years experience in an acquisition position, at least four years of which were performed while assigned to a critical acquisition position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90b0af0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1735/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Senior Contracting Officials","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before a person may be assigned to a critical acquisition position as a senior contracting official, the person must have at least four years experience in contracting.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida90b0af1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXII/s1202/a"},"text":"Pub. L. 101–510, div. A, title XII, § 1202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1648"},"text":"104 Stat. 1648","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tVIII/s812/d"},"text":"Pub. L. 102–484, div. A, title VIII, § 812(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2451"},"text":"106 Stat. 2451","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tIX/s904/d/1"},"text":"Pub. L. 103–160, div. A, title IX, § 904(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1728"},"text":"107 Stat. 1728","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/b/2"},"text":"Pub. L. 107–107, div. A, title X, § 1048(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1225"},"text":"115 Stat. 1225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s902/20"},"text":"Pub. L. 116–92, div. A, title IX, § 902(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1545"},"text":"133 Stat. 1545","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVIII"},"text":"Pub. L. 119–60, div. A, title XVIII","children":[],"tail":", §§ 1802(b)(1)(A), (D), 1803(a)(2), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1227"},"text":"139 Stat. 1227","children":[],"tail":", 1228.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida90b0af2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida90b0af3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida90b0af4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1803/a/2"},"text":"Pub. L. 119–60, § 1803(a)(2)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1802/b/1/D"},"text":"Pub. L. 119–60, § 1802(b)(1)(D)","children":[],"tail":", which directed the substitution of “Portfolio acquisition executives” for “Program executive officers” in heading, was executed by making the substitution for “Program Executive Officers”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1802/b/1/A"},"text":"Pub. L. 119–60, § 1802(b)(1)(A)","children":[],"tail":", substituted “portfolio acquisition executive” for “program executive officer” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1803/a/2"},"text":"Pub. L. 119–60, § 1803(a)(2)","children":[],"tail":", redesignated subsecs. (c) to (e) as (d) to (f), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “Under Secretary of Defense for Acquisition and Sustainment” for “Under Secretary of Defense for Acquisition, Technology, and Logistics”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" substituted “Under Secretary of Defense for Acquisition, Technology, and Logistics” for “Under Secretary of Defense for Acquisition and Technology”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":" substituted “Under Secretary of Defense for Acquisition and Technology” for “Under Secretary of Defense for Acquisition”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":" struck out “or deputy program manager” after “program manager” in subpars. (A) and (B), struck out “and” at end of subpar. (A), substituted semicolon for period at end of subpar. (B), and added subpars. (C) and (D)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida90b0af5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida90b0af6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Fulfillment Standards for Mandatory Training","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to development of fulfillment standards for purposes of the training requirements of this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s812/c"},"text":"section 812(c) of Pub. L. 102–484","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1723"},"text":"section 1723 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
