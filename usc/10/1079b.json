{"tag":"section","attrib":{"id":"ida8858770-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1079b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1079b"},"text":"§ 1079b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for charging fees for care provided to civilians; retention and use of fees collected","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8858771-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1079b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement To Implement Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall implement procedures under which a military medical treatment facility may charge civilians who are not covered beneficiaries (or their insurers) fees representing the costs, as determined by the Secretary, of trauma and other medical care provided to such civilians.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8858772-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1079b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver of Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Defense Health Agency may issue a waiver for a fee that would otherwise be charged under the procedures implemented under subsection (a) to a civilian provided medical care who is not a covered beneficiary if the provision of such care enhances the knowledge, skills, and abilities of health care providers, as determined by the Director of the Defense Health Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8858773-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1079b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modified Payment Plan for Certain Civilians","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8858774-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1079b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8858775-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1079b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a civilian specified in subsection (a) is covered by a covered payer at the time care under this section is provided, the civilian shall only be responsible to pay the standard copays, coinsurance, deductibles, or nominal fees that are otherwise applicable under the covered payer plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8858776-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1079b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except with respect to the copays, coinsurance, deductibles, and nominal fees specified in subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8858777-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1079b/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense may bill only the covered payer for care provided to a civilian described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8858778-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1079b/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment received by the Secretary from the covered payer of a civilian for care provided under this section that is provided to the civilian shall be considered payment in full for such care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8858779-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1079b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a civilian specified in subsection (a) does not meet the criteria under paragraph (1), is underinsured, or has a remaining balance and is at risk of financial harm, the Director of the Defense Health Agency shall reduce each fee that would otherwise be charged to the civilian under this section according to a sliding fee discount program, as prescribed by the Director of the Defense Health Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida885877a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1079b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a civilian specified in subsection (a) does not meet the criteria under paragraph (1) or (2), the Director of the Defense Health Agency shall implement an additional catastrophic waiver to prevent severe financial harm.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida885877b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1079b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The modified payment plan under this subsection may not be administered by a Federal agency other than the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida885877c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1079b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Fees Collected","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A military medical treatment facility may retain and use the amounts collected under subsection (a) for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida885877d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1079b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trauma consortium activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida885877e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1079b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative, operating, and equipment costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida885877f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1079b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" readiness training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8858780-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1079b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8858781-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1079b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered payer” means a third-party payer or other insurance, medical service, or health plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8858782-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1079b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “third-party payer” and “insurance, medical service, or health plan” have the meaning given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1095/h"},"text":"section 1095(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8858783-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tVII/s732/a/1"},"text":"Pub. L. 107–107, div. A, title VII, § 732(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1169"},"text":"115 Stat. 1169","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVII/s702"},"text":"Pub. L. 116–283, div. A, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3686"},"text":"134 Stat. 3686","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVII/s716/a"},"text":"Pub. L. 117–263, div. A, title VII, § 716(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2661"},"text":"136 Stat. 2661","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8858784-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8858785-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8858786-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s716/a/1"},"text":"Pub. L. 117–263, § 716(a)(1)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, text read as follows: “The Secretary may waive a fee that would otherwise be charged under the procedures implemented under subsection (a) to a civilian who is not a covered beneficiary if—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the civilian is unable to pay for the costs of the trauma or other medical care provided to the civilian (including any such costs remaining after the Secretary receives payment from an insurer for such care, as applicable); and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the provision of such care enhances the knowledge, skills, and abilities of health care providers, as determined by the Secretary.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s716/a/2"},"text":"Pub. L. 117–263, § 716(a)(2)","children":[],"tail":", (b)(1), added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s716/b/2"},"text":"Pub. L. 117–263, § 716(b)(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8858787-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8858788-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVII/s716/c"},"text":"Pub. L. 117–263, div. A, title VII, § 716(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2661"},"text":"136 Stat. 2661","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tVII/s716/c"},"text":"“The amendments made by subsections (a) and (b) [amending this section] shall apply with respect to care provided on or after the date that is 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8858789-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Improved Implementation of Financial Relief for Civilians Treated in Military Medical Treatment Facilities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVII/s717"},"text":"Pub. L. 118–159, div. A, title VII, § 717","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1949"},"text":"138 Stat. 1949","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tVII/s717"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Final Rule Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall issue a final rule (or interim final rule) to implement as soon as possible after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"] "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1079b"},"text":"section 1079b of title 10","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Claims.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the Secretary shall hold in abeyance any claims under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1079b"},"text":"section 1079b of title 10","children":[],"tail":", United States Code, until the final rule (or interim final rule) required under subsection (a) is in effect."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) does not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" claims to third-party payers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative support provided to the Secretary by another Federal agency to assist the Secretary in the administration of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1079b"},"text":"section 1079b of title 10","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida885878a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tVII/s732/b"},"text":"Pub. L. 107–107, div. A, title VII, § 732(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1170"},"text":"115 Stat. 1170","children":[],"tail":", directed the Secretary of Defense to begin to implement the procedures required by subsec. (a) of this section not later than one year after "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
