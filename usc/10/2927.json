{"tag":"section","attrib":{"id":"idaa00b599-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2927"},"text":null,"children":[{"tag":"num","attrib":{"value":"2927"},"text":"§ 2927.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Global bulk fuel management and delivery","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa00b59a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2927/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsible Element","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa00b59b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2927/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Beginning during the period described in paragraph (2) and permanently thereafter, the United States Transportation Command shall be the element responsible for bulk fuel management and delivery of the Department of Defense on a global basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa00b59c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2927/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The period described in this paragraph is the period beginning on ","children":[{"tag":"date","attrib":{"date":"2023-01-01"},"text":"January 1, 2023","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2023-02-01"},"text":"February 1, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa00b59d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2927/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination With Defense Logistics Agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out the responsibilities specified in subsection (a), the Commander of the United States Transportation Command shall coordinate with the Director of the Defense Logistics Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa00b59e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2927/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except to the extent that, prior to ","children":[{"tag":"date","attrib":{"date":"2023-01-01"},"text":"January 1, 2023","children":[],"tail":", a responsibility specified in subsection (a) was a specific function of the Defense Logistics Agency Energy, nothing under this section shall be construed as—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa00b59f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2927/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limiting any other function of the Defense Logistics Agency Energy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa00b5a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2927/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requiring the transfer of any function, personnel, or asset from the Defense Logistics Agency Energy to the United States Transportation Command.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa00b5a1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tIII/s352/a/1"},"text":"Pub. L. 117–81, div. A, title III, § 352(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1654"},"text":"135 Stat. 1654","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
