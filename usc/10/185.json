{"tag":"section","attrib":{"id":"ida781abc9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185"},"text":null,"children":[{"tag":"num","attrib":{"value":"185"},"text":"§ 185.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint Safety Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida781abca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established, within the Office of the Deputy Secretary of Defense, a Joint Safety Council (in this section referred to as the “Council”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida781abcb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership; Appointment; Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida781abcc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Council shall be composed of voting members as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida781abcd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of Safety for each military department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida781abce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee of the Department of Defense who is a career member of the Senior Executive Service and has a demonstrated record of success in the implementation of programs within the Department of Defense (as determined by the Deputy Secretary of Defense), appointed by the Deputy Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida781abcf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member of the armed forces or civilian employee from each military department, appointed by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida781abd0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During periods in which the Coast Guard is not operating as a service in the Department of the Navy, an officer of the Coast Guard, appointed by the Secretary of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida781abd1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such additional members as may be determined by the Deputy Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abd2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida781abd3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member of the Council shall serve at the will of the official who appointed that member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida781abd4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vacancy on the Council shall be filled in the same manner as the original appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abd5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Council may not receive additional pay, allowances, or benefits by reason of their service on the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida781abd6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairperson and Vice Chairperson","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida781abd7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida781abd8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense, or the designee of the Secretary, shall select one of the members of the Council who is a member of the armed forces to serve as the Chairperson of the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida781abd9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Chairperson shall serve for a term of two years and shall be responsible for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida781abda-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving as the Director of Safety for the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida781abdb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving as principal advisor to the Secretary of Defense regarding military safety and related regulations and policy reforms, including issues regarding maintenance, supply chains, personnel management, and training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida781abdc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overseeing all duties and activities of the Council, including the conduct of military safety studies and the issuance of safety guidance to the military departments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida781abdd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" working with, and advising, the Secretaries of the military departments through appointed safety chiefs to implement standardized safety guidance across the military departments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida781abde-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/c/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submitting to the Secretary of Defense and Congress an annual report reviewing the compliance of each military department with the guidance described in clause (iv);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida781abdf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/c/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advising Congress on issues relating to military safety and reforms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida781abe0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/c/1/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overseeing coordination with other Federal agencies, including the Federal Aviation Administration, to inform military aviation safety guidance and reforms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abe1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The individual appointed under subsection (b)(1)(B) shall serve as the Vice Chairperson. The Vice Chairperson shall report to the Chairperson and shall serve as Chairperson in the absence of the Chairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida781abe2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall carry out the following responsibilities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida781abe3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (e), issuing, publishing, and updating regulations related to joint safety, including regulations on the reporting and investigation of mishaps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abe4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to mishap data—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida781abe5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing uniform data collection standards and a repository, that is accessible Department-wide, of data for mishaps in the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida781abe6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing the compliance of each military department in adopting and using the uniform data collection standards established under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida781abe7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing mishap data to assess, identify, and prioritize risk mitigation efforts and safety improvement efforts across the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abe8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to non-mishap data—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida781abe9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing standards and requirements for the collection of aircraft, equipment, simulator, airfield, range, pilot, and operator data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida781abea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing standards and requirements for the collection of ground vehicle equipment and crew data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida781abeb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing requirements for each military department to collect and analyze any waivers issued relating to pilot or operator qualifications or standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reviewing and assessing civil and commercial aviation safety programs and practices to determine the suitability of such programs and practices for implementation in the military departments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing, in consultation with the Administrator of the Federal Aviation Administration, a requirement for each military department to implement an aviation safety management system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing, in consultation with the heads of appropriate Federal departments and agencies, a requirement for each military department to implement a separate safety management program for ground vehicles and ships.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Ensuring each military department has in place, for the safety management system and program described in paragraphs (5) and (6), respectively, of that military department—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida781abf0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/d/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a resolution plan that identifies specific corrective and preventative actions to address the causes of mishaps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida781abf1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/d/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an implementation plan for such system and program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abf2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reviewing the proposal of each military department for the safety management system and program described in paragraphs (5) and (6), respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abf3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reviewing the implementation of such systems by each military department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abf4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ensuring each military department has in place a system to monitor the implementation of recommendations made in safety and legal investigation reports of mishap incidents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abf5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/d/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than one year after the initial identification of corrective and preventative actions by a military department pursuant to a resolution plan under paragraph (7)(A), and periodically thereafter, reviewing and validating each such identified corrective and preventative action to ensure the action is effective.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abf6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/d/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ensuring any related change in methods, tactics, or procedures necessary for the conduct of such identified corrective and preventative actions have been implemented.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida781abf7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Oversight","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The decisions and recommendations of the Council are subject to review and approval by the Deputy Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida781abf8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Staff","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida781abf9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Council may appoint staff in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3101"},"text":"section 3101 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abfa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Council may accept persons on detail from within the Department of Defense and from other Federal departments or agencies on a reimbursable or non-reimbursable basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida781abfb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council may enter into contracts for the acquisition of administrative supplies, equipment, and personnel services for use by the Council, to the extent that funds are available for such purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida781abfc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procurement of Temporary and Intermittent Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chairperson may procure temporary and intermittent services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109/b"},"text":"section 3109(b) of title 5","children":[],"tail":" at rates for individuals which do not exceed the daily equivalent of the annual rate of basic pay prescribed for level V of the Executive Schedule under section 5316 of such title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida781abfd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Data Collection","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida781abfe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations issued by the Secretary of Defense, the Council shall have access to Department of Defense databases necessary to carry out its responsibilities, including causal factors to be used for mishap reduction purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations issued by the Secretary of Defense, the Council may enter into agreements with the Federal Aviation Administration, the National Transportation Safety Board, and any other Federal agency regarding the sharing of safety data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781ac00-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Data collected by the Council pursuant to this subsection may include privileged safety information that is protected from disclosure or discovery to any person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida781ac01-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council shall meet quarterly and at the call of the Chairperson.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida781ac02-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida781ac03-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairperson of the Council shall submit to the congressional defense committees biannual reports on the activities of the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781ac04-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than December 31 of each year, the Deputy Secretary of Defense shall submit to the congressional defense committees an annual report containing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida781ac05-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/k/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the goals and priorities of the Deputy Secretary for the year following the date of the submission of the report with respect to the activities of the Council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida781ac06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/k/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment by the Deputy Secretary of the activities of the Council carried out during the year preceding the date of such submission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida781ac07-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/k/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the year covered by the report—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida781ac08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/k/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" releasable information regarding any mishap that occurred during such year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida781ac09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/k/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of any corrective or preventative action implemented pursuant to a recommendation made in a safety or legal investigation report of such a mishap.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida781ac0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s185/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Biannual Briefings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than March 31 and December 31 of each year, the Chairperson of the Council shall provide to the congressional defense committees a briefing on the contents of the report required to be submitted under subsection (k)(1) that covers the six-month period preceding the date of the briefing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida781ac0b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tIII/s372/a"},"text":"Pub. L. 117–81, div. A, title III, § 372(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1664"},"text":"135 Stat. 1664","children":[],"tail":", § 184; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tIII"},"text":"Pub. L. 117–263, div. A, title III","children":[],"tail":", §§ 381, 383, "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2542"},"text":"136 Stat. 2542","children":[],"tail":", 2544; renumbered § 185 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tIII/s363"},"text":"Pub. L. 118–31, div. A, title III, § 363","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/233"},"text":"137 Stat. 233","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tIII/s331"},"text":"Pub. L. 118–159, div. A, title III, § 331","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1854"},"text":"138 Stat. 1854","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida781ac0c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida781ac0d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida781ac0e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (k)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s331/1/A"},"text":"Pub. L. 118–159, § 331(1)(A)","children":[],"tail":", substituted “Chairperson” for “Chair” and “biannual” for “semi-annual”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s331/1/B/i"},"text":"Pub. L. 118–159, § 331(1)(B)(i)","children":[],"tail":", in introductory provisions, struck out “"},{"tag":"date","attrib":{"date":"2023-03-31"},"text":"March 31, 2023","children":[],"tail":", and not later than” before “December 31” and “thereafter” after “each year” and substituted “an annual report” for “a report”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s331/1/B/ii"},"text":"Pub. L. 118–159, § 331(1)(B)(ii)","children":[],"tail":"–(iv), added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/s331/2"},"text":"Pub. L. 118–159, § 331(2)","children":[],"tail":", added subsec. ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s363/1"},"text":"Pub. L. 118–31, § 363(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s184"},"text":"section 184 of this title","children":[],"tail":" relating to Joint Safety Council as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(7) to (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s363/2"},"text":"Pub. L. 118–31, § 363(2)","children":[],"tail":", added pars. (7), (11), and (12), redesignated former pars. (7) to (9) as (8) to (10), respectively, and substituted “the safety management system and program described in paragraphs (5) and (6), respectively” for “the safety management systems described in paragraphs (9) and (10)” in par. (8) as so redesignated."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(1)(D), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s383"},"text":"Pub. L. 117–263, § 383","children":[],"tail":", added subpar. (D) and redesignated former subpar. (D) as (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s381"},"text":"Pub. L. 117–263, § 381","children":[],"tail":", substituted “Reports” for “Report” in heading, designated existing provisions as par. (1), and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida781ac0f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida781ac10-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Establishment of Major Mishap Incident Designation Classification for Department of Defense Incidents","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tX/s1054"},"text":"Pub. L. 118–159, div. A, title X, § 1054","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2061"},"text":"138 Stat. 2061","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tX/s1054"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall establish a new mishap designation classification for the most serious incidents, to be known as ‘major mishap incidents’, to describe any incident that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results in not less than $500,000,000 in damage or loss; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is of such complexity or sensitivity, or would have such an effect on the national security of the United States, as to warrant designation by the Secretary of Defense as a major mishap incident pursuant to regulations prescribed by the Secretary and that include the consideration of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of members of the Armed Forces who were killed due to the incident;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographic dispersion of the incident;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grade of individuals involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of Armed Forces and Government entities involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of the incident on the local civilian population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of the incident on any foreign government or foreign personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"“(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the anticipated complexity or difficulty of the investigation of the incident;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"“(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of the incident on the capability of any major operational command or component to continue to function effectively; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"“(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other matters as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Investigations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grade of investigating officer","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The convening authority for any investigation of a major mishap incident shall appoint an investigating officer from among officers who hold a rank not lower than Major General in the Army, Air Force, or Marine Corps or Rear Admiral in the Navy to investigate all major mishap incidents—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" including any related administrative, disciplinary, or legal investigations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" excluding any criminal investigations conducted by a military criminal investigative organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timeline for investigations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall amend Department of Defense Instruction 6055.07 to set the goal that a full investigation of each major mishap incident be completed, to the extent practicable, not later than one year after the date on which the investigation is initiated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefing requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any investigation of a major mishap incident that is not completed within the timeline provided under paragraph (2), the Secretary of Defense shall provide to the Committees on Armed Services of the Senate and House of Representatives a briefing every 90 days until the date of the completion of the investigation. Each such briefing shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation for why the investigation has not been completed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projected date of the completion of the investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accountability Actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If an investigation into a major mishap incident includes a recommendation to hold an individual accountable, the separation authority or convening authority, as appropriate, shall submit to the Committees on Armed Services of the Senate and House of Representatives a report on the status of the proceeding for the accountability action every 120 days beginning on the date of the completion of the investigation of the incident and ending on the date on which the proceeding is complete.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefing Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"], the Secretary of Defense shall provide to the Committees on Armed Services for the Senate and House of Representatives a briefing on—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of the implementation of the establishment of a major mishap incident designation, as required under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any updates to statutes or Department of Defense Instructions that are needed to implement this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projected timeline for the implementation of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after the date of the enactment of this Act, the Secretary of Defense shall finalize the implementation of this section, including by updating any Department of Defense guidance and policy as necessary to carry out the requirements of this section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida781ac11-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadlines","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tIII/s372/c"},"text":"Pub. L. 117–81, div. A, title III, § 372(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1666"},"text":"135 Stat. 1666","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dA/tIII/s372/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall ensure the establishment of the Joint Safety Council under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s184"},"text":"section 184 of title 10","children":[],"tail":", United States Code (as added by subsection (a)) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s185"},"text":"10 U.S.C. 185","children":[],"tail":"], by not later than the date that is 120 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment of first members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The initial members of the Joint Safety Council established under such section 184 [now ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s185"},"text":"10 U.S.C. 185","children":[],"tail":"] shall be appointed by not later than the date that is 120 days after the date of the enactment of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Directors of safety","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the date of the enactment of this Act, the Secretary of each military department shall ensure there is appointed as the Director of Safety for the military department concerned an officer of that military department in pay grade O–8 or above.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
