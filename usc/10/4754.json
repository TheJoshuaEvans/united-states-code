{"tag":"section","attrib":{"id":"idaa8d65c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754"},"text":null,"children":[{"tag":"num","attrib":{"value":"4754"},"text":"§ 4754.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of purchase cards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa8d65c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Management of Purchase Cards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe regulations governing the use and control of all purchase cards and convenience checks that are issued to Department of Defense personnel for official use. Those regulations shall be consistent with regulations that apply Government-wide regarding use of purchase cards by Government personnel for official purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa8d65c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Safeguards and Internal Controls","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Regulations under subsection (a) shall include safeguards and internal controls to ensure the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa8d65c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That there is a record in the Department of Defense of each holder of a purchase card issued by the Department of Defense for official use, annotated with the limitations on amounts that are applicable to the use of each such card by that purchase card holder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8d65c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That each purchase card holder and individual issued a convenience check is assigned an approving official other than the card holder with the authority to approve or disapprove transactions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8d65c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" That the holder of a purchase card and each official with authority to authorize expenditures charged to the purchase card are responsible for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa8d65c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reconciling the charges appearing on each statement of account for that purchase card with receipts and other supporting documentation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa8d65c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forwarding that statement after being so reconciled to the designated disbursing office in a timely manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8d65c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That any disputed purchase card charge, and any discrepancy between a receipt and other supporting documentation and the purchase card statement of account, is resolved in the manner prescribed in the applicable Government-wide purchase card contract entered into by the Administrator of General Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8d65ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That payments on purchase card accounts are made promptly within prescribed deadlines to avoid interest penalties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8d65cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That rebates and refunds based on prompt payment on purchase card accounts are properly recorded.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8d65cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That records of each purchase card transaction (including records on associated contracts, reports, accounts, and invoices) are retained in accordance with standard Government policies on the disposition of records.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8d65cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That periodic reviews are performed to determine whether each purchase card holder has a need for the purchase card.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8d65ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That appropriate training is provided to each purchase card holder and each official with responsibility for overseeing the use of purchase cards issued by the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8d65cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That the Department of Defense has specific policies regarding the number of purchase cards issued by various organizations and categories of organizations, the credit limits authorized for various categories of card holders, and categories of employees eligible to be issued purchase cards, and that those policies are designed to minimize the financial risk to the Federal Government of the issuance of the purchase cards and to ensure the integrity of purchase card holders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8d65d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That the Department of Defense uses effective systems, techniques, and technologies to prevent or identify potential fraudulent purchases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8d65d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" That the Department of Defense takes appropriate steps to invalidate the purchase card of each card holder who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa8d65d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an employee of the Department—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa8d65d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/12/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ceases to be employed by the Department, immediately upon termination of the employment of the employee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa8d65d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/12/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfers to another unit of the Department, immediately upon the transfer of the employee unless the Secretary of Defense determines that the units are covered by the same purchase card authority; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa8d65d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a member of the armed forces, is separated or released from active duty or full-time National Guard duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8d65d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That the Department of Defense takes steps to recover the cost of any illegal, improper, or erroneous purchase made with a purchase card or convenience check by an employee or member of the armed forces, including, as necessary, through salary offsets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8d65d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" That the Inspector General of the Department of Defense, the Inspector General of the Army, the Naval Inspector General, and the Inspector General of the Air Force perform periodic audits to identify—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa8d65d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potentially fraudulent, improper, and abusive uses of purchase cards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa8d65d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any patterns of improper card holder transactions, such as purchases of prohibited items; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa8d65da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/14/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" categories of purchases that should be made by means other than purchase cards in order to better aggregate purchases and obtain lower prices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8d65db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/b/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That the Inspector General of the Department of Defense conducts periodic audits or reviews of purchase card or convenience check programs to identify and analyze risks of illegal, improper, or erroneous purchases and payments and that the findings of such audits or reviews, along with recommendations to prevent abuse of purchase cards or convenience checks, are reported to the Director of the Office of Management and Budget and Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa8d65dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties for Violations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations prescribed under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa8d65dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa8d65de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the reimbursement of charges for unauthorized or erroneous purchases, in appropriate cases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa8d65df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for appropriate adverse personnel actions or other punishment to be imposed in cases in which employees of the Department of Defense violate such regulations or are negligent or engage in misuse, abuse, or fraud with respect to a purchase card, including removal in appropriate cases; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8d65e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4754/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that a violation of such regulations by a person subject to chapter 47 of this title (the Uniform Code of Military Justice) is punishable as a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s892"},"text":"section 892 of this title","children":[],"tail":" (article 92 of the Uniform Code of Military Justice)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa8d65e1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tIX/s933/a/1"},"text":"Pub. L. 106–65, div. A, title IX, § 933(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/728"},"text":"113 Stat. 728","children":[],"tail":", § 2784; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tX/s1007/a"},"text":"Pub. L. 107–314, div. A, title X, § 1007(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2633"},"text":"116 Stat. 2633","children":[],"tail":", 2634; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title X, § 1003(a), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4582"},"text":"122 Stat. 4582","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/194/s2/b"},"text":"Pub. L. 112–194, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-10-05"},"text":"Oct. 5, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1447"},"text":"126 Stat. 1447","children":[],"tail":"; renumbered § 4754, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1864/b"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1864(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4279"},"text":"134 Stat. 4279","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa8d65e2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa8d65e3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa8d65e4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 4771 and 4772 were renumbered sections 7771 and 7772 of this title, respectively.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 4774, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/269"},"text":"70A Stat. 269","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1957-08-30"},"text":"Aug. 30, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/241/tIV"},"text":"Pub. L. 85–241, title IV","children":[],"tail":", §404(a), "},{"tag":"ref","attrib":{"href":"/us/stat/71/555"},"text":"71 Stat. 555","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1959-08-10"},"text":"Aug. 10, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/86/149/tIV/s410/a"},"text":"Pub. L. 86–149, title IV, § 410(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/321"},"text":"73 Stat. 321","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1962-07-27"},"text":"July 27, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/554/tV/s504/a"},"text":"Pub. L. 87–554, title V, § 504(a)","children":[],"tail":", (c), "},{"tag":"ref","attrib":{"href":"/us/stat/76/239"},"text":"76 Stat. 239","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1963-11-07"},"text":"Nov. 7, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/88/174/tV/s503"},"text":"Pub. L. 88–174, title V, § 503","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/325"},"text":"77 Stat. 325","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1969-12-05"},"text":"Dec. 5, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/91/142/tV/s510/b"},"text":"Pub. L. 91–142, title V, § 510(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/312"},"text":"83 Stat. 312","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1971-10-27"},"text":"Oct. 27, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/145/tV/s508/a"},"text":"Pub. L. 92–145, title V, § 508(a)","children":[],"tail":", (c), "},{"tag":"ref","attrib":{"href":"/us/stat/85/408"},"text":"85 Stat. 408","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1973-11-29"},"text":"Nov. 29, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/166/tV/s509/c"},"text":"Pub. L. 93–166, title V, § 509(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/677"},"text":"87 Stat. 677","children":[],"tail":", related to limitations on construction, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/214"},"text":"Pub. L. 97–214","children":[],"tail":", §§ 7(1), 12(a), "},{"tag":"date","attrib":{"date":"1982-07-12"},"text":"July 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/173"},"text":"96 Stat. 173","children":[],"tail":", 176, effective "},{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 4775, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/269"},"text":"70A Stat. 269","children":[],"tail":", authorized assignment of quarters belonging to United States at a post or station by post quartermaster to officers, grade lieutenant general down to second lieutenant, 10 to 2 rooms, respectively, and prohibited other assignment where quarters existed, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/92/145/tV/s509/a"},"text":"Pub. L. 92–145, title V, § 509(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-10-27"},"text":"Oct. 27, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/408"},"text":"85 Stat. 408","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 4776 to 4780 were renumbered sections 7776 to 7780 of this title, respectively.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 4781 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7781"},"text":"section 7781 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 4781, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/dN/tVI/s602/a"},"text":"Pub. L. 115–31, div. N, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/828"},"text":"131 Stat. 828","children":[],"tail":", was substantially identical to the prior section 4781, and related to Cyber Center for Education and Innovation-Home of the National Cryptologic Museum, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1081/a/49/A"},"text":"Pub. L. 115–91, div. A, title X, § 1081(a)(49)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1597"},"text":"131 Stat. 1597","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa8d65e5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2784"},"text":"section 2784 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (b)(2) to (15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/194"},"text":"Pub. L. 112–194","children":[],"tail":" added pars. (2), (11) to (13), and (15) and redesignated former pars. (2) to (7) and (8) as (3) to (8) and (14), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" substituted “provide—” for “provide”, added subpar. (A), and substituted “(B) for” for “for”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s1007/b/1/A"},"text":"Pub. L. 107–314, § 1007(b)(1)(A)","children":[],"tail":", substituted “purchase” for “credit” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s1007/a/1"},"text":"Pub. L. 107–314, § 1007(a)(1)","children":[],"tail":", (b)(1)(B), (C), substituted “Purchase” for “Credit” in heading and “purchase” for “credit” in two places in text and struck out “, acting through the Under Secretary of Defense (Comptroller),” after “Secretary of Defense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s1007/b/1/C"},"text":"Pub. L. 107–314, § 1007(b)(1)(C)","children":[],"tail":", substituted “purchase” for “credit” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s1007/a/2"},"text":"Pub. L. 107–314, § 1007(a)(2)","children":[],"tail":", added pars. (7) to (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s1007/a/2"},"text":"Pub. L. 107–314, § 1007(a)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa8d65e6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa8d65e7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa8d65e8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tIX/s933/b/1"},"text":"Pub. L. 106–65, div. A, title IX, § 933(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/730"},"text":"113 Stat. 730","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/65/dA/tIX/s933/b/1"},"text":"“Regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2784"},"text":"section 2784 of title 10","children":[],"tail":", United States Code [now "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4754"},"text":"10 U.S.C. 4754","children":[],"tail":"], as added by subsection (a), shall be prescribed not later than 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa8d65e9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Compliance With Travel Charge Card Deactivation Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tV/s593/a"},"text":"Pub. L. 119–60, div. A, title V, § 593(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/900"},"text":"139 Stat. 900","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tV/s593/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy Compliance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"], the Secretary of Defense shall ensure that Department of Defense policies and procedures are consistent with section 2(h)(1)(H) of the Travel and Transportation Reform Act of 1998 ("},{"tag":"ref","attrib":{"href":"/us/pl/105/264"},"text":"Public Law 105–264","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5701"},"text":"5 U.S.C. 5701","children":[],"tail":" note) and related implementing guidance, regarding the prompt deactivation and closure of government-issued travel charge card accounts upon the separation, retirement, or termination of military or civilian personnel.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa8d65ea-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Crediting of Refunds","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/116/dA/tVIII/s8067"},"text":"Pub. L. 110–116, div. A, title VIII, § 8067","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-13"},"text":"Nov. 13, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1329"},"text":"121 Stat. 1329","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/116/dA/tVIII/s8067"},"text":"“Beginning in the current fiscal year and hereafter, refunds attributable to the use of the Government travel card, refunds attributable to the use of the Government Purchase Card and refunds attributable to official Government travel arranged by Government Contracted Travel Management Centers may be credited to operation and maintenance, and research, development, test and evaluation accounts of the Department of Defense which are current when the refunds are received.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa8d65eb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Government Charge Card Accounts: Limitation on Number; Requirements for Issuance; Disciplinary Action for Misuse; Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/248/tVIII/s8149"},"text":"Pub. L. 107–248, title VIII, § 8149","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-23"},"text":"Oct. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1572"},"text":"116 Stat. 1572","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/87/tVIII/s8144"},"text":"Pub. L. 108–87, title VIII, § 8144","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1108"},"text":"117 Stat. 1108","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/87/tVIII/s8144"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Number of Government Charge Card Accounts during Fiscal Year","children":[],"tail":" 2003.—"}],"tail":null},{"tag":"content","attrib":{},"text":"The total number of accounts for government purchase charge cards and government travel charge cards for Department of Defense personnel during fiscal year 2003 may not exceed 1,500,000 accounts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for Creditworthiness for Issuance of Government Charge Card","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall evaluate the creditworthiness of an individual before issuing the individual a government purchase charge card or government travel charge card.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual may not be issued a government purchase charge card or government travel charge card if the individual is found not credit worthy as a result of the evaluation under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection shall remain in effect for fiscal year 2004.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disciplinary Action for Misuse of Government Charge Card","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish guidelines and procedures for disciplinary actions to be taken against Department personnel for improper, fraudulent, or abusive use of government purchase charge cards and government travel charge cards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The guidelines and procedures under this subsection shall include appropriate disciplinary actions for use of charge cards for purposes, and at establishments, that are inconsistent with the official business of the Department or with applicable standards of conduct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The disciplinary actions under this subsection may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the review of the security clearance of the individual involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the modification or revocation of such security clearance in light of the review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The guidelines and procedures under this subsection shall apply uniformly among the Armed Forces and among the elements of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2003-06-30"},"text":"June 30, 2003","children":[],"tail":", the Secretary shall submit to the congressional defense committees [Committees on Armed Services of the Senate and the House of Representatives and Subcommittees on Defense of the Committees on Appropriations of the Senate and the House of Representatives] a report on the implementation of the requirements and limitations in this section, including the guidelines and procedures established under subsection (c).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
