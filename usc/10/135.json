{"tag":"section","attrib":{"id":"ida762b2f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s135"},"text":null,"children":[{"tag":"num","attrib":{"value":"135"},"text":"§ 135.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary of Defense (Comptroller)","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida762b2f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s135/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida762b2f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s135/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is an Under Secretary of Defense (Comptroller), appointed from civilian life by the President, by and with the advice and consent of the Senate. A person may not be appointed as Under Secretary within seven years after relief from active duty as a commissioned officer of a regular component of an armed force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida762b2f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s135/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense (Comptroller) shall be appointed from among persons who have significant budget, financial management, or audit experience in complex organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida762b2f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s135/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense (Comptroller) is the agency Chief Financial Officer of the Department of Defense for the purposes of chapter 9 of title 31. The Under Secretary of Defense (Comptroller) shall perform the duties assigned to the Under Secretary in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2222"},"text":"section 2222 of this title","children":[],"tail":" and such additional duties and exercise such powers as the Secretary of Defense may prescribe."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida762b2f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s135/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Under Secretary of Defense (Comptroller) shall advise and assist the Secretary of Defense—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida762b2f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s135/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in performing such budgetary and fiscal functions and duties, and in exercising such budgetary and fiscal powers, as are needed to carry out the powers of the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida762b2f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s135/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in supervising and directing the preparation of budget estimates of the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida762b2f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s135/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in establishing and supervising the execution of principles, policies, and procedures to be followed in connection with organizational and administrative matters relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida762b2fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s135/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preparation and execution of budgets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida762b2fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s135/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fiscal, cost, operating, and capital property accounting; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida762b2fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s135/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" progress and statistical reporting;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida762b2fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s135/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in establishing and supervising the execution of policies and procedures relating to the expenditure and collection of funds administered by the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida762b2fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s135/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in establishing uniform terminologies, classifications, and procedures concerning matters covered by paragraphs (1) through (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida762b2ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s135/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In addition to any duties under subsection (c), the Under Secretary of Defense (Comptroller) shall, subject to the authority, direction, and control of the Secretary of Defense, do the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida762b300-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s135/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Provide guidance and instruction on annual performance plans and evaluations to the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida762b301-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s135/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretaries of the military departments for financial management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida762b302-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s135/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other official of an agency, organization, or element of the Department of Defense with responsibility for financial management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida762b303-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s135/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Give directions to the military departments, Defense Agencies, and other organizations and elements of the Department of Defense regarding their financial statements and the audit and audit readiness of such financial statements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida762b304-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s135/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense (Comptroller) takes precedence in the Department of Defense after the Under Secretary of Defense for Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida762b305-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s135/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense (Comptroller) shall ensure that each of the congressional defense committees is informed, in a timely manner, regarding all matters relating to the budgetary, fiscal, and analytic activities of the Department of Defense that are under the supervision of the Under Secretary of Defense (Comptroller).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida762b306-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tI/s107"},"text":"Pub. L. 99–433, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/998"},"text":"100 Stat. 998","children":[],"tail":", § 137; renumbered § 135 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tIX"},"text":"Pub. L. 103–160, div. A, title IX","children":[],"tail":", §§ 901(a)(2), 902(a)(1), (b), "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1726"},"text":"107 Stat. 1726","children":[],"tail":", 1727; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tIX/s903/a/1"},"text":"Pub. L. 103–337, div. A, title IX, § 903(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2823"},"text":"108 Stat. 2823","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1502/a/6"},"text":"Pub. L. 104–106, div. A, title XV, § 1502(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/502"},"text":"110 Stat. 502","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1067/1"},"text":"Pub. L. 106–65, div. A, title X, § 1067(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/774"},"text":"113 Stat. 774","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tX/s1043/b/1"},"text":"Pub. L. 108–136, div. A, title X, § 1043(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1610"},"text":"117 Stat. 1610","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tIX/s901/m/3"},"text":"Pub. L. 111–383, div. A, title IX, § 901(m)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4326"},"text":"124 Stat. 4326","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tIX"},"text":"Pub. L. 115–91, div. A, title IX","children":[],"tail":", §§ 904(1), 905(a), 912(b), "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1512"},"text":"131 Stat. 1512","children":[],"tail":", 1520; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tIX/s901/f/1"},"text":"Pub. L. 117–81, div. A, title IX, § 901(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1868"},"text":"135 Stat. 1868","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida762b307-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida762b308-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida762b309-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 135 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s138b"},"text":"section 138b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida762b30a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" substituted “an armed force” for “the armed forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s905/a/1"},"text":"Pub. L. 115–91, § 905(a)(1)","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s904/1"},"text":"Pub. L. 115–91, § 904(1)","children":[],"tail":", inserted at end “A person may not be appointed as Under Secretary within seven years after relief from active duty as a commissioned officer of a regular component of the armed forces.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s912/b"},"text":"Pub. L. 115–91, § 912(b)","children":[],"tail":", inserted “the duties assigned to the Under Secretary in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2222"},"text":"section 2222 of this title","children":[],"tail":" and” after “shall perform”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s905/a/2"},"text":"Pub. L. 115–91, § 905(a)(2)","children":[],"tail":", added subsec. (d) and redesignated former subsecs. (d) and (e) as (e) and (f), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" substituted “paragraphs” for “clauses”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" struck out “(1)” before “The Under Secretary”, substituted “each of the congressional defense committees” for “each congressional committee specified in paragraph (2)”, and struck out par. (2) which read as follows: “The committees referred to in paragraph (1) are—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the Committee on Armed Services and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the Committee on Armed Services and the Committee on Appropriations of the House of Representatives.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (e)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “Committee on Armed Services” for “Committee on National Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" designated existing provisions as par. (1), substituted “each congressional committee specified in paragraph (2) is” for “the Committees on Armed Services and the Committees on Appropriations of the Senate and House of Representatives are each”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s903/a/2"},"text":"Pub. L. 103–337, § 903(a)(2)","children":[],"tail":", substituted “Under Secretary of Defense (Comptroller)” for “Comptroller” as section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s903/a/1/A"},"text":"Pub. L. 103–337, § 903(a)(1)(A)","children":[],"tail":", substituted “an Under Secretary of Defense (Comptroller)” for “a Comptroller of the Department of Defense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s903/a/1/B"},"text":"Pub. L. 103–337, § 903(a)(1)(B)","children":[],"tail":", substituted “Under Secretary of Defense (Comptroller)” for “Comptroller” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s901/a/2"},"text":"Pub. L. 103–160, § 901(a)(2)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s137"},"text":"section 137 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s902/a/1"},"text":"Pub. L. 103–160, § 902(a)(1)","children":[],"tail":", inserted “The Comptroller is the agency Chief Financial Officer of the Department of Defense for the purposes of chapter 9 of title 31.” after “(b)” and “additional” after “shall perform such”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s901/a/2"},"text":"Pub. L. 103–160, § 901(a)(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s902/b"},"text":"Pub. L. 103–160, § 902(b)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida762b30b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"ida762b30c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tIX/s903/d"},"text":"Pub. L. 103–337, div. A, title IX, § 903(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2823"},"text":"108 Stat. 2823","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/337/dA/tIX/s903/d"},"text":"“Any reference to the Comptroller of the Department of Defense in any provision of law other than title 10, United States Code, or in any rule, regulation, or other paper of the United States shall be treated as referring to the Under Secretary of Defense (Comptroller).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida762b30d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tIX/s905/c"},"text":"Pub. L. 115–91, div. A, title IX, § 905(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1513"},"text":"131 Stat. 1513","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/91/dA/tIX/s905/c"},"text":"“The appointment qualifications imposed by the amendments made by subsection (a)(1) [amending this section] and the appointment qualifications imposed by subsection (b) [set out as a note below] shall apply with respect to appointments as Under Secretary of Defense (Comptroller) and Deputy Chief Financial Officer of the Department of Defense that are made on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida762b30e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2011-01-01"},"text":"Jan. 1, 2011","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/s901/p"},"text":"section 901(p) of Pub. L. 111–383","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s131"},"text":"section 131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida762b30f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Qualification for Appointment as Deputy Chief Financial Officer","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tIX/s905/b"},"text":"Pub. L. 115–91, div. A, title IX, § 905(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1513"},"text":"131 Stat. 1513","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/91/dA/tIX/s905/b"},"text":"“The Deputy Chief Financial Officer of the Department of Defense shall be appointed from among persons who have significant budget, financial management, or audit experience in complex organizations.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
