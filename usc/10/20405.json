{"tag":"section","attrib":{"id":"idabccea59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20405"},"text":null,"children":[{"tag":"num","attrib":{"value":"20405"},"text":"§ 20405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Force shaping authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabccea5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20405/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Air Force may, solely for the purpose of restructuring the Space Force—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabccea5b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20405/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discharge an officer described in subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabccea5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20405/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involuntarily release such an officer from sustained duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabccea5d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20405/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Officers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabccea5e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20405/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The authority under this section may be exercised in the case of an officer of the Space Force serving on sustained duty who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabccea5f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20405/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed not more than six years of service as a commissioned officer in the armed forces; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabccea60-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20405/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed more than six years of service as a commissioned officer in the armed forces, but has not completed the minimum service obligation applicable to that officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabccea61-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20405/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the term “minimum service obligation”, with respect to a member of the Space Force, means the initial period of required active duty service applicable to the member, together with any additional period of required active duty service incurred by that member during the member’s initial period of required active duty service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabccea62-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20405/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Air Force shall prescribe regulations for the exercise of the Secretary’s authority under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabccea63-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1718/a"},"text":"Pub. L. 118–31, div. A, title XVII, § 1718(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/658"},"text":"137 Stat. 658","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
