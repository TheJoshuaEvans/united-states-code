/us/pl/117/263/dA/tVIII/s854/b"},"text":"Pub. L. 117–263, div. A, title VIII, § 854(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2722"},"text":"136 Stat. 2722","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tVIII/s853/b"},"text":"Pub. L. 118–31, div. A, title VIII, § 853(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/344"},"text":"137 Stat. 344","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaaecfff-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaaed000-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaaaed001-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/m/2/C"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(m)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2144"},"text":"135 Stat. 2144","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1872/a/7"},"text":"Pub. L. 116–283, § 1872(a)(7)","children":[],"tail":", which had originally transferred "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2415"},"text":"section 2415 of this title","children":[],"tail":" to this section. After amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1872/a/7"},"text":"section 1872(a)(7) of Pub. L. 116–283","children":[],"tail":" instead transferred section 2415 to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4956"},"text":"section 4956 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":" is a corrected version of "},{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaaaed002-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s853/b/1"},"text":"Pub. L. 118–31, § 853(b)(1)","children":[],"tail":", designated existing provisions as par. (1), redesignated former pars. (1) and (2) as subpars. (A) and (B), respectively, of par. (1), and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s853/b/2"},"text":"Pub. L. 118–31, § 853(b)(2)","children":[],"tail":", redesignated subsecs. (d) to (f) as (c) to (e), respectively, and struck out former subsec. (c). Prior to amendment, text of subsec. (c) read as follows: “In entering into cooperative agreements under subsection (a), the Secretary shall assure that at least one procurement technical assistance program is carried out in each Department of Defense contract administration services district during each fiscal year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s853/b/3"},"text":"Pub. L. 118–31, § 853(b)(3)","children":[],"tail":", added subsec. (f). Former subsec. (f) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1872/a/5"},"text":"Pub. L. 116–283, § 1872(a)(5)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/b/24"},"text":"Pub. L. 117–81, § 1701(b)(24)","children":[],"tail":", (m)(2)(A)(i), renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2413"},"text":"section 2413 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1872/a/5/A"},"text":"Pub. L. 116–283, § 1872(a)(5)(A)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1872/a/5/B"},"text":"Pub. L. 116–283, § 1872(a)(5)(B)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/m/2/A/ii"},"text":"Pub. L. 117–81, § 1701(m)(2)(A)(ii)","children":[],"tail":", inserted heading and, in par. (2), substituted “section 4959(b)” for “section 2419(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1872/a/5/C"},"text":"Pub. L. 116–283, § 1872(a)(5)(C)","children":[],"tail":"–(E), inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s858/a/1"},"text":"Pub. L. 115–232, § 858(a)(1)","children":[],"tail":", substituted “not more than 75 percent” for “not more than 65 percent” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s858/a/2"},"text":"Pub. L. 115–232, § 858(a)(2)","children":[],"tail":", substituted “more than 75 percent, but not more than 85 percent” for “more than 65 percent, but not more than 75 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1612/a/1"},"text":"Pub. L. 113–66, § 1612(a)(1)","children":[],"tail":", substituted “65 percent” for “one-half” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1611/c/1/A"},"text":"Pub. L. 113–66, § 1611(c)(1)(A)","children":[],"tail":", (B), substituted “except that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) in the case”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"for “except that in the case” and “; and” for period at end.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1612/a"},"text":"Pub. L. 113–66, § 1612(a)","children":[],"tail":", substituted “65 percent” for “one-half” and “75 percent” for “three-fourths”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1611/c/1/C"},"text":"Pub. L. 113–66, § 1611(c)(1)(C)","children":[],"tail":", added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1611/c/3"},"text":"Pub. L. 113–66, § 1611(c)(3)","children":[],"tail":", struck out “and in determining the level of funding to provide under an agreement under subsection (b),” after “subsection (a),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1611/c/2"},"text":"Pub. L. 113–66, § 1611(c)(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":"Pub. L. 105–261","children":[],"tail":" substituted “district” for “region”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180"},"text":"Pub. L. 100–180","children":[],"tail":" made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":". See 1986 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/180"},"text":"Pub. L. 100–180","children":[],"tail":", amended subsec. (b) identically, inserting “sponsor programs to” after first reference to “agree to”, “under such programs” after “such assistance”, and “with respect to such program” after “such cost” and substituting “a program sponsored by such an entity that provides services solely in a distressed area” for “an eligible entity that is a distressed entity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" amended section generally, substituting “, in accordance with the provisions of this chapter