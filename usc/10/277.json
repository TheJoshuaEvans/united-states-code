{"tag":"section","attrib":{"id":"ida79708e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s277"},"text":null,"children":[{"tag":"num","attrib":{"value":"277"},"text":"§ 277.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida79708e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s277/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (c), to the extent otherwise required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1535"},"text":"section 1535 of title 31","children":[],"tail":" (popularly known as the “Economy Act”) or other applicable law, the Secretary of Defense shall require a civilian law enforcement agency to which support is provided under this chapter to reimburse the Department of Defense for that support."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida79708e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s277/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida79708e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s277/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (c), the Secretary of Defense shall require a Federal agency to which law enforcement support or support to a national special security event is provided by National Guard personnel performing duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s502/f"},"text":"section 502(f) of title 32","children":[],"tail":" to reimburse the Department of Defense for the costs of that support, notwithstanding any other provision of law. No other provision of this chapter shall apply to such support."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida79708e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s277/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any funds received by the Department of Defense under this subsection as reimbursement for support provided by personnel of the National Guard shall be credited, at the election of the Secretary of Defense, to the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida79708e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s277/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The appropriation, fund, or account used to fund the support.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida79708e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s277/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The appropriation, fund, or account currently available for reimbursement purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida79708e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s277/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An agency to which support is provided under this chapter or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s502/f"},"text":"section 502(f) of title 32","children":[],"tail":" is not required to reimburse the Department of Defense for such support if the Secretary of Defense waives reimbursement. The Secretary may waive the reimbursement requirement under this subsection if such support—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida79708ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s277/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is provided in the normal course of military training or operations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida79708eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s277/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results in a benefit to the element of the Department of Defense or personnel of the National Guard providing the support that is substantially equivalent to that which would otherwise be obtained from military operations or training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida79708ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/86/tIX/s905/a/1"},"text":"Pub. L. 97–86, title IX, § 905(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-01"},"text":"Dec. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1116"},"text":"95 Stat. 1116","children":[],"tail":", § 377; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXI/s1104/a"},"text":"Pub. L. 100–456, div. A, title XI, § 1104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2045"},"text":"102 Stat. 2045","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tX/s1061"},"text":"Pub. L. 110–181, div. A, title X, § 1061","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/319"},"text":"122 Stat. 319","children":[],"tail":"; renumbered § 277, "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1241/a/2"},"text":"Pub. L. 114–328, div. A, title XII, § 1241(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2497"},"text":"130 Stat. 2497","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida79708ed-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida79708ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida79708ef-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 277, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/14"},"text":"70A Stat. 14","children":[],"tail":", prohibited discrimination in administering laws applicable to both Regulars and Reserves, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI"},"text":"Pub. L. 103–337, div. A, title XVI","children":[],"tail":", §§ 1661(a)(2)(A), 1691, "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2979"},"text":"108 Stat. 2979","children":[],"tail":", 3026, effective "},{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10209"},"text":"section 10209 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida79708f0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s377"},"text":"section 377 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1061/1"},"text":"Pub. L. 110–181, § 1061(1)","children":[],"tail":", substituted “Subject to subsection (c), to the extent” for “To the extent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1061/2"},"text":"Pub. L. 110–181, § 1061(2)","children":[],"tail":", added subsecs. (b) and (c) and struck out former subsec. (b) which read as follows: “An agency to which support is provided under this chapter is not required to reimburse the Department of Defense for such support if such support—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) is provided in the normal course of military training or operations; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) results in a benefit to the element of the Department of Defense providing the support that is substantially equivalent to that which would otherwise be obtained from military operations or training.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The Secretary of Defense shall issue regulations providing that reimbursement may be a condition of assistance to a civilian law enforcement official under this chapter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
