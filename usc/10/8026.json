{"tag":"section","attrib":{"id":"idab0702aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8026"},"text":null,"children":[{"tag":"num","attrib":{"value":"8026"},"text":"§ 8026.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with Commandant of the Marine Corps on major decisions directly concerning Marine Corps aviation or amphibious force structure and capability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Navy shall ensure that the views of the Commandant of the Marine Corps are given appropriate consideration before a major decision is made by an element of the Department of the Navy outside the Marine Corps on a matter that directly concerns Marine Corps aviation or amphibious force structure and capability.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab0702ab-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tIX/s935/a"},"text":"Pub. L. 105–261, div. A, title IX, § 935(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2109"},"text":"112 Stat. 2109","children":[],"tail":", § 5026; renumbered § 8026, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/a/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1834"},"text":"132 Stat. 1834","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tX/s1022/a"},"text":"Pub. L. 117–263, div. A, title X, § 1022(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/