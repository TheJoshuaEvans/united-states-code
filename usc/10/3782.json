{"tag":"section","attrib":{"id":"idaa377d33-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3782"},"text":null,"children":[{"tag":"num","attrib":{"value":"3782"},"text":"§ 3782.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical data: challenges to contractor restrictions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa377d34-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3782/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Challenges by Secretary of Defense","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may challenge a use or release restriction asserted with respect to technical data by a contractor or subcontractor at any tier under a contract subject to this subchapter if the Secretary finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa377d35-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3782/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable grounds exist to question the current validity of the asserted restriction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa377d36-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3782/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the continued adherence by the United States to the asserted restriction would make it impracticable to procure the item to which the technical data pertain competitively at a later time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa377d37-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3782/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time Limit for Challenges; Exceptions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa377d38-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3782/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A challenge to a use or release restriction asserted by the contractor in accordance with applicable regulations may not be made under subsection (a) after the end of the six-year period described in paragraph (2) unless the technical data involved—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa377d39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3782/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are publicly available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa377d3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3782/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have been furnished to the United States without restriction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa377d3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3782/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have been otherwise made available without restriction; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa377d3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3782/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are the subject of a fraudulently asserted use or release restriction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa377d3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3782/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The six-year period referred to in paragraph (1) is the six-year period beginning on the later of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa377d3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3782/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which final payment is made on the contract under which the technical data are required to be delivered; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa377d3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3782/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the technical data are delivered under the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa377d40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3782/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Written Notice to Contractor or Subcontractor","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary challenges an asserted use or release restriction under subsection (a), the Secretary shall provide written notice of the challenge to the contractor or subcontractor asserting the restriction. Any such notice shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa377d41-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3782/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state the specific grounds for challenging the asserted restriction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa377d42-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3782/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require a response within 60 days justifying the current validity of the asserted restriction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa377d43-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3782/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state that evidence of a justification described in subsection (d) may be submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa377d44-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3782/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Justification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is a justification of an asserted use or release restriction challenged under subsection (a) that, within the three-year period preceding the challenge to the restriction, the Department of Defense validated a restriction identical to the asserted restriction if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa377d45-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3782/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such validation occurred after a challenge to the validated restriction under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa377d46-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3782/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the validated restriction was asserted by the same contractor or subcontractor (or a licensee of such contractor or subcontractor).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa377d47-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1833/g"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1833(g)","children":[],"tail":", (i), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4231"},"text":"134 Stat. 4231","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa377d48-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa377d49-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa377d4a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2321"},"text":"section 2321 of this title","children":[],"tail":", which was transferred to this section and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/i"},"text":"Pub. L. 116–283, § 1833(i)","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s7/a/5/A/ii"},"text":"Pub. L. 100–26, § 7(a)(5)(A)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/276"},"text":"101 Stat. 276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tXII/s1231/6/A"},"text":"Pub. L. 100–180, div. A, title XII, § 1231(6)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1160"},"text":"101 Stat. 1160","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/35/tII/s201/g/4"},"text":"Pub. L. 103–35, title II, § 201(g)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-05-31"},"text":"May 31, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/100"},"text":"107 Stat. 100","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVIII/s824/c"},"text":"Pub. L. 111–383, div. A, title VIII, § 824(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4269"},"text":"124 Stat. 4269","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVIII/s815/b"},"text":"Pub. L. 112–81, div. A, title VIII, § 815(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1492"},"text":"125 Stat. 1492","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa377d4b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3782, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/218"},"text":"70A Stat. 218","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/616/s2/a"},"text":"Pub. L. 86–616, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/387"},"text":"74 Stat. 387","children":[],"tail":", provided for boards of inquiry, composed of three or more officers, to be convened at such places as Secretary of the Army prescribes, to receive evidence and make findings and recommendations whether an officer, required to show cause under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3781"},"text":"section 3781 of this title","children":[],"tail":", should be retained on active list of Regular Army, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tII/s213"},"text":"Pub. L. 96–513, title II, § 213","children":[],"tail":", title VII, § 701, "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2885"},"text":"94 Stat. 2885","children":[],"tail":", 2955, effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1182"},"text":"section 1182 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa377d4c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/i/1/A"},"text":"Pub. L. 116–283, § 1833(i)(1)(A)","children":[],"tail":", transferred subsec. (d) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2321"},"text":"section 2321 of this title","children":[],"tail":" to this section and struck out subsec. (d) designation and heading “Challenges to Restrictions” at beginning."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/i/1/B"},"text":"Pub. L. 116–283, § 1833(i)(1)(B)","children":[],"tail":", (2), redesignated par. (1) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2321/d"},"text":"section 2321(d) of this title","children":[],"tail":" as subsec. (a) of this section, inserted heading, substituted “this subchapter” for “this section” in introductory provisions, and redesignated subpars. (A) and (B) as pars. (1) and (2), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/i/1/B"},"text":"Pub. L. 116–283, § 1833(i)(1)(B)","children":[],"tail":", (3)(A), (B), redesignated par. (2) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2321/d"},"text":"section 2321(d) of this title","children":[],"tail":" as subsec. (b) of this section, inserted heading, and redesignated subpars. (A) and (B) as pars. (1) and (2), respectively, and realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/i/3/C"},"text":"Pub. L. 116–283, § 1833(i)(3)(C)","children":[],"tail":", substituted “subsection (a)” for “paragraph (1)” and “paragraph (2)” for “subparagraph (B)” in introductory provisions and redesignated cls. (i) to (iv) as subpars. (A) to (D), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/i/3/D"},"text":"Pub. L. 116–283, § 1833(i)(3)(D)","children":[],"tail":", substituted “paragraph (1)” for “subparagraph (A)” in introductory provisions and redesignated cls. (i) and (ii) as subpars. (A) and (B), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/i/1/B"},"text":"Pub. L. 116–283, § 1833(i)(1)(B)","children":[],"tail":", (4)(A)–(C), redesignated par. (3) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2321/d"},"text":"section 2321(d) of this title","children":[],"tail":" as subsec. (c) of this section, inserted heading, substituted “subsection (a)” for “paragraph (1)” in introductory provisions, and redesignated subpars. (A) to (C) as pars. (1) to (3), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/i/4/D"},"text":"Pub. L. 116–283, § 1833(i)(4)(D)","children":[],"tail":", substituted “subsection (d)” for “paragraph (4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/i/1/B"},"text":"Pub. L. 116–283, § 1833(i)(1)(B)","children":[],"tail":", (5)(A)–(C), redesignated par. (4) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2321/d"},"text":"section 2321(d) of this title","children":[],"tail":" as subsec. (d) of this section, inserted heading, substituted “subsection (a)” for “paragraph (1)” in introductory provisions, and redesignated subparagraphs (A) and (B) as pars. (1) and (2), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/i/5/D"},"text":"Pub. L. 116–283, § 1833(i)(5)(D)","children":[],"tail":", substituted “this section” for “this subsection”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa377d4d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa377d4e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as an Effective Date of 2021 Amendment note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
