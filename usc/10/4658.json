":"/us/usc/t10/s4658"},"text":"10 U.S.C. 4658","children":[],"tail":"], whether the person should be debarred from contracting with the Department of Defense.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior authorization acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVIII/s816/b"},"text":"Pub. L. 106–65, div. A, title VIII, § 816(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/712"},"text":"113 Stat. 712","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tVIII/s849/b"},"text":"Pub. L. 103–160, div. A, title VIII, § 849(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1725"},"text":"107 Stat. 1725","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
