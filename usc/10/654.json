{"tag":"section","attrib":{"id":"ida7f68e1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s654"},"text":null,"children":[{"tag":"num","attrib":{"value":"654"},"text":"§ 654.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum service requirement for certain cyberspace occupational specialties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7f68e1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s654/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cyberspace Operations Officer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The minimum service obligation for any member who successfully completes training in the armed forces in direct accession to the cyberspace operations officer occupational specialty of the Marine Corps shall be eight years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f68e1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s654/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service Obligation Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “service obligation” means the period of active duty or, in the case of a member of a reserve component who completed cyberspace operations training in an active duty for training status as a member of a reserve component, the period of service in an active status in the Selected Reserve, required to be served after completion of cyberspace operations training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7f68e1d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tV/s509/b"},"text":"Pub. L. 118–31, div. A, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/243"},"text":"137 Stat. 243","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7f68e1e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7f68e1f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida7f68e20-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 654, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tV/s571/a/1"},"text":"Pub. L. 103–160, div. A, title V, § 571(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1670"},"text":"107 Stat. 1670","children":[],"tail":", related to policy concerning homosexuality in the armed forces, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/111/321/s2/f/1/A"},"text":"Pub. L. 111–321, § 2(f)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3516"},"text":"124 Stat. 3516","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7f8d811-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7f8d812-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Don’t Ask, Don’t Tell Repeal","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/321"},"text":"Pub. L. 111–321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3515"},"text":"124 Stat. 3515","children":[],"tail":", repealed former "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s654"},"text":"section 654 of this title","children":[],"tail":" effective 60 days after the later of the Secretary of Defense receiving a report, which was released "},{"tag":"date","attrib":{"date":"2010-11-30"},"text":"Nov. 30, 2010","children":[],"tail":", and the President transmitting to the congressional defense committees a written certification, which was transmitted "},{"tag":"date","attrib":{"date":"2011-07-22"},"text":"July 22, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
