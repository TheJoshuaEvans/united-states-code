{"tag":"section","attrib":{"id":"idaaecc345-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7434"},"text":null,"children":[{"tag":"num","attrib":{"value":"7434"},"text":"§ 7434.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Command and supervision","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaecc346-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7434/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The supervision and charge of the Academy is in the Department of the Army, under officers of the Army detailed to that duty by the Secretary of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaecc347-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7434/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The immediate government of the Academy is under the Superintendent, who is also the commanding officer of the Academy and of the military post at West Point.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaecc348-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7434/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commandant of Cadets is the immediate commander of the Corps of Cadets, and is in charge of the instruction of the Corps in tactics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaecc349-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7434/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The permanent professors and the director of admissions exercise command only in the academic department of the Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaecc34a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/239"},"text":"70A Stat. 239","children":[],"tail":", § 4334; "},{"tag":"ref","attrib":{"href":"/us/pl/85/600/s1/10"},"text":"Pub. L. 85–600, § 1(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-06"},"text":"Aug. 6, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/523"},"text":"72 Stat. 523","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/551/s2"},"text":"Pub. L. 95–551, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-30"},"text":"Oct. 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2069"},"text":"92 Stat. 2069","children":[],"tail":"; renumbered § 7434, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/c/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaecc34b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaaecc34c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaaecc34d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag