{"tag":"section","attrib":{"id":"idabb9d7f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14903"},"text":null,"children":[{"tag":"num","attrib":{"value":"14903"},"text":"§ 14903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boards of inquiry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabb9d7f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Convening of Boards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the military department concerned shall convene a board of inquiry at such time and place as the Secretary may prescribe to receive evidence and review the case of any officer who has been required to show cause for retention in an active status under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14902"},"text":"section 14902 of this title","children":[],"tail":". Each board of inquiry shall be composed of not less than three officers who have the qualifications prescribed in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s14906"},"text":"section 14906 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb9d7f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Right to Fair Hearing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A board of inquiry shall give a fair and impartial hearing to each officer required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14902"},"text":"section 14902 of this title","children":[],"tail":" to show cause for retention in an active status."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb9d7f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendations to Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a board of inquiry determines that the officer has failed to establish that the officer should be retained in an active status, the board shall recommend to the Secretary concerned that the officer not be retained in an active status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb9d7fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14903/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Action by Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"After review of the recommendation of the board of inquiry, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb9d7fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14903/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remove the officer from an active status; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb9d7fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14903/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine that the case be closed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb9d7fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14903/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Action in Cases Where Cause for Retention Is Established","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb9d7fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14903/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a board of inquiry determines that an officer has established that the officer should be retained in an active status or if the Secretary determines that the case be closed, the officer’s case is closed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb9d7ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14903/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who is required to show cause for retention under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14902/a"},"text":"section 14902(a) of this title","children":[],"tail":" and whose case is closed under paragraph (1) may not again be required to show cause for retention under such subsection during the one-year period beginning on the date of that determination."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb9d800-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14903/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabb9d801-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14903/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subparagraph (B), an officer who is required to show cause for retention under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14902/b"},"text":"section 14902(b) of this title","children":[],"tail":" and whose case is closed under paragraph (1) may again be required to show cause for retention at any time."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabb9d802-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14903/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who has been required to show cause for retention under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14902/b"},"text":"section 14902(b) of this title","children":[],"tail":" and who is thereafter retained in an active status may not again be required to show cause for retention under such section solely because of conduct which was the subject of the previous proceeding, unless the recommendations of the board of inquiry that considered the officer’s case are determined to have been obtained by fraud or collusion."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabb9d803-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2958"},"text":"108 Stat. 2958","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1501/b/32"},"text":"Pub. L. 104–106, div. A, title XV, § 1501(b)(32)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/498"},"text":"110 Stat. 498","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb9d804-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabb9d805-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabb9d806-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" substituted “title” for “chapter”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabb9d807-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idabb9d808-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" effective as if included in the Reserve Officer Personnel Management Act, title XVI of "},{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":", as enacted on "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1501/f/3"},"text":"section 1501(f)(3) of Pub. L. 104–106","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s113"},"text":"section 113 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabb9d809-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691/b/1"},"text":"section 1691(b)(1) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
