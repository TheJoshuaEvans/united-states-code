{"tag":"section","attrib":{"id":"ida88cb30b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094"},"text":null,"children":[{"tag":"num","attrib":{"value":"1094"},"text":"§ 1094.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensure requirement for health-care professionals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida88cb30c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida88cb30d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person under the jurisdiction of the Secretary of a military department may not provide health care independently as a health-care professional under this chapter unless the person has a current license to provide such care. In the case of a physician, the physician may not provide health care as a physician under this chapter unless the current license is an unrestricted license that is not subject to limitation on the scope of practice ordinarily granted to other physicians for a similar specialty by the jurisdiction that granted the license.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida88cb30e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may waive paragraph (1) with respect to any person in unusual circumstances. The Secretary shall prescribe by regulation the circumstances under which such a waiver may be granted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida88cb30f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The commanding officer of each health care facility of the Department of Defense shall ensure that each person who provides health care independently as a health-care professional at the facility meets the requirement of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida88cb310-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida88cb311-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person (other than a person subject to chapter 47 of this title) who provides health care in violation of subsection (a) is subject to a civil money penalty of not more than $5,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida88cb312-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The provisions of subsections (c) and (e) through (h) of section 1128A of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7a"},"text":"42 U.S.C. 1320a–7a","children":[],"tail":") shall apply to the imposition of a civil money penalty under paragraph (1) in the same manner as they apply to the imposition of a civil money penalty under that section, except that for purposes of this subsection—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida88cb313-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reference to the Secretary in that section is deemed a reference to the Secretary of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida88cb314-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reference to a claimant in subsection (e) of that section is deemed a reference to the person described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida88cb315-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida88cb316-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any law regarding the licensure of health care providers, a health-care professional described in paragraph (2), (3), or (4) may practice the health profession or professions of the health-care professional at any location in any State, the District of Columbia, or a Commonwealth, territory, or possession of the United States, regardless of where such health-care professional or the patient are located, so long as the practice is within the scope of the authorized Federal duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida88cb317-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A health-care professional referred to in paragraph (1) as being described in this paragraph is a member of the armed forces, civilian employee of the Department of Defense, personal services contractor under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1091"},"text":"section 1091 of this title","children":[],"tail":", contractor not covered under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1091"},"text":"section 1091 of this title","children":[],"tail":" who is providing an examination or assessment under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10206"},"text":"section 10206 of this title","children":[],"tail":" or medical treatment as part of a mission relating to emergency, humanitarian, or refugee assistance, or other health-care professional credentialed and privileged at a Federal health care institution or location specially designated by the Secretary for this purpose who—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida88cb318-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a current license to practice medicine, osteopathic medicine, dentistry, or another health profession; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida88cb319-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is performing authorized duties for the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida88cb31a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A health-care professional referred to in paragraph (1) as being described in this paragraph is a member of the National Guard who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida88cb31b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a current license to practice medicine, osteopathic medicine, dentistry, or another health profession; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida88cb31c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is performing training or duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s502/f"},"text":"section 502(f) of title 32","children":[],"tail":" in response to an actual or potential disaster."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida88cb31d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To the extent provided in regulations prescribed by the Secretary for the purpose of assuring the availability of high-quality mental health care services to members of the armed forces and dependents entitled to health care under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1076"},"text":"section 1076 of this title","children":[],"tail":", a health care professional referred to in paragraph (1) as being described in this paragraph is a mental health provider providing care through a network under the TRICARE program who—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida88cb31e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a current license to practice as a mental health care professional;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida88cb31f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is providing tele-mental health care services to members of the armed forces or such dependents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida88cb320-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is providing such services under terms and conditions specified by the Secretary (which shall establish the scope of authorized Federal duties for purposes of paragraph (1)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida88cb321-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida88cb322-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “license”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida88cb323-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a grant of permission by an official agency of a State, the District of Columbia, or a Commonwealth, territory, or possession of the United States to provide health care independently as a health-care professional, or the official agency of the government of a partner country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida88cb324-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes, in the case of such care furnished in a foreign country by any person who is not a national of the United States, a grant of permission by an official agency of that foreign country for that person to provide health care independently as a health-care professional.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida88cb325-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “health-care professional” means a physician, dentist, clinical psychologist, marriage and family therapist certified as such by a certification recognized by the Secretary of Defense, or nurse and any other person providing direct patient care as may be designated by the Secretary of Defense in regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida88cb326-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “partner country” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida88cb327-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Australia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida88cb328-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Canada.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida88cb329-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" New Zealand.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida88cb32a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United Kingdom.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida88cb32b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1094/e/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other country designated as a partner country by the Secretary of Defense for the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida88cb32c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/tVI/s653/a/1"},"text":"Pub. L. 99–145, title VI, § 653(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/657"},"text":"99 Stat. 657","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tXIII/s1343/a/5"},"text":"Pub. L. 99–661, div. A, title XIII, § 1343(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3992"},"text":"100 Stat. 3992","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVI/s653/e/1"},"text":"Pub. L. 101–189, div. A, title VI, § 653(e)(1)","children":[],"tail":", title XVI, § 1622(e)(3), "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1463"},"text":"103 Stat. 1463","children":[],"tail":", 1605; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVII/s737"},"text":"Pub. L. 105–85, div. A, title VII, § 737","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1814"},"text":"111 Stat. 1814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tVII/s734/a"},"text":"Pub. L. 105–261, div. A, title VII, § 734(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2072"},"text":"112 Stat. 2072","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVII/s717/b"},"text":"Pub. L. 108–375, div. A, title VII, § 717(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1986"},"text":"118 Stat. 1986","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVII/s713"},"text":"Pub. L. 111–383, div. A, title VII, § 713","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4247"},"text":"124 Stat. 4247","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVII/s713/a"},"text":"Pub. L. 112–81, div. A, title VII, § 713(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1476"},"text":"125 Stat. 1476","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVII/s718"},"text":"Pub. L. 117–263, div. A, title VII, § 718","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2662"},"text":"136 Stat. 2662","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVII"},"text":"Pub. L. 118–159, div. A, title VII","children":[],"tail":", §§ 713, 714(a), "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1947"},"text":"138 Stat. 1947","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVII/s716"},"text":"Pub. L. 119–60, div. A, title VII, § 716","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/923"},"text":"139 Stat. 923","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida88cb32d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida88cb32e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida88cb32f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (e)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s716/1"},"text":"Pub. L. 119–60, § 716(1)","children":[],"tail":", substituted “, or the official agency of the government of a partner country; and” for “; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s716/2"},"text":"Pub. L. 119–60, § 716(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s714/a/1"},"text":"Pub. L. 118–159, § 714(a)(1)","children":[],"tail":", substituted “paragraph (2), (3), or (4)” for “paragraph (2) or (3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s713"},"text":"Pub. L. 118–159, § 713","children":[],"tail":", inserted “an examination or assessment under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10206"},"text":"section 10206 of this title","children":[],"tail":" or” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1091"},"text":"section 1091 of this title","children":[],"tail":" who is providing” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s714/a/2"},"text":"Pub. L. 118–159, § 714(a)(2)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" inserted “contractor not covered under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1091"},"text":"section 1091 of this title","children":[],"tail":" who is providing medical treatment as part of a mission relating to emergency, humanitarian, or refugee assistance,” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1091"},"text":"section 1091 of this title","children":[],"tail":",” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s713/a/1"},"text":"Pub. L. 112–81, § 713(a)(1)","children":[],"tail":", inserted “at any location” before “in any State” and substituted “regardless of where such health-care professional or the patient are located, so long as the practice is within the scope of the authorized Federal duties.” for “regardless of whether the practice occurs in a health care facility of the Department of Defense, a civilian facility affiliated with the Department of Defense, or any other location authorized by the Secretary of Defense.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s713/1"},"text":"Pub. L. 111–383, § 713(1)","children":[],"tail":", inserted “or (3)” after “paragraph (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s713/a/2"},"text":"Pub. L. 112–81, § 713(a)(2)","children":[],"tail":", substituted “member of the armed forces, civilian employee of the Department of Defense, personal services contractor under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1091"},"text":"section 1091 of this title","children":[],"tail":", or other health-care professional credentialed and privileged at a Federal health care institution or location specially designated by the Secretary for this purpose” for “member of the armed forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s713/2"},"text":"Pub. L. 111–383, § 713(2)","children":[],"tail":", inserted “as being described in this paragraph” after “paragraph (1)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s713/3"},"text":"Pub. L. 111–383, § 713(3)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" inserted “marriage and family therapist certified as such by a certification recognized by the Secretary of Defense,” after “psychologist,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":"Pub. L. 105–261","children":[],"tail":" inserted at end “In the case of a physician, the physician may not provide health care as a physician under this chapter unless the current license is an unrestricted license that is not subject to limitation on the scope of practice ordinarily granted to other physicians for a similar specialty by the jurisdiction that granted the license.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s653/e/1"},"text":"Pub. L. 101–189, § 653(e)(1)","children":[],"tail":", substituted “subsections (c) and (e) through (h)” for “subsections (b) and (d) through (g)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s1622/e/3/A"},"text":"Pub. L. 101–189, § 1622(e)(3)(A)","children":[],"tail":", substituted “The term ‘license” for “ ‘License” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s1622/e/3/B"},"text":"Pub. L. 101–189, § 1622(e)(3)(B)","children":[],"tail":", substituted “The term ‘health-care” for “ ‘Health-care”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" realigned margin of par. (2) to conform to margin of par. (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida88cb330-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida88cb331-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tVII/s734/c/1"},"text":"Pub. L. 105–261, div. A, title VII, § 734(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2073"},"text":"112 Stat. 2073","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/261/dA/tVII/s734/c/1"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1999-10-01"},"text":"October 1, 1999","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida88cb332-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/tVI/s653/b"},"text":"Pub. L. 99–145, title VI, § 653(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/658"},"text":"99 Stat. 658","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/145/tVI/s653/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1094"},"text":"Section 1094 of title 10","children":[],"tail":", United States Code, as added by subsection (a), does not apply during the three-year period beginning on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":"] with respect to the provision of health care by any person who on the date of the enactment of this Act is a member of the Armed Forces.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida88cb333-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVII/s714/b"},"text":"Pub. L. 118–159, div. A, title VII, § 714(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1948"},"text":"138 Stat. 1948","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tVII/s714/b"},"text":"“Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"], the Secretary of Defense shall issue an interim final regulation to implement the amendments made by subsection (a) [amending this section].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVII/s713/b"},"text":"Pub. L. 112–81, div. A, title VII, § 713(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1476"},"text":"125 Stat. 1476","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/81/dA/tVII/s713/b"},"text":"“The Secretary of Defense shall prescribe regulations to carry out the amendments made by this section [amending this section].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida88cb334-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Review of Disclosure Requirements Under Processes and Forms Relating to Health Care Provider Credentialing and Privileging of Department of Defense","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVII/s720"},"text":"Pub. L. 119–60, div. A, title VII, § 720","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/927"},"text":"139 Stat. 927","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tVII/s720"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"], the Secretary of Defense shall review all processes and forms relating to health care provider credentialing and privileging of covered applicants to ensure that each individual who provides health care independently as a health-care professional at a health care facility of the Department of Defense meets the requirement of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1094/a"},"text":"section 1094(a) of title 10","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Centralized credential system","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1094/b"},"text":"section 1094(b) of title 10","children":[],"tail":", United States Code, the Secretary shall establish a centralized credential system that allows the commanding officer of a health care facility of the Department to verify the licensure of a health care professional, regardless of the location of the facility or the Armed Force in which the health care professional serves. The Secretary shall ensure that not less than 90 percent of such verifications are completed within seven days of the date on which the commanding officer requests such verification if the request does not relate to a health-care professional with an adverse record."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than one year after the date of the enactment of this Act, the Secretary shall submit to Congress a report containing the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The findings of the review required under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed plan outlining steps the Secretary has taken or will take pursuant to such review, including a timeline for completion of such steps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Applicant Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term ‘covered applicant’ means an applicant for a position as a health-care professional (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1094"},"text":"section 1094 of title 10","children":[],"tail":", United States Code) who—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required to go through a credentialing and privileging process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides care—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a health care facility of the Department of Defense; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through the civilian network of the TRICARE program (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072"},"text":"section 1072 of title 10","children":[],"tail":", United States Code).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
