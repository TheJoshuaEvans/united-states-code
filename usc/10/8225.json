{"tag":"section","attrib":{"id":"idab155a13-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8225"},"text":null,"children":[{"tag":"num","attrib":{"value":"8225"},"text":"§ 8225.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Female members: congressional review period for assignment to duty on submarines or for reconfiguration of submarines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab155a14-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8225/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No change in the Department of the Navy policy limiting service on submarines to males, as in effect on ","children":[{"tag":"date","attrib":{"date":"2000-05-10"},"text":"May 10, 2000","children":[],"tail":", may take effect until—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab155a15-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8225/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense submits to Congress written notice of the proposed change; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab155a16-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8225/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 30 days of continuous session of Congress (excluding any day on which either House of Congress is not in session) expires following the date on which the notice is received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab155a17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8225/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No funds available to the Department of the Navy may be expended to reconfigure any existing submarine, or to design any new submarine, to accommodate female crew members until—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab155a18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8225/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense submits to Congress written notice of the proposed reconfiguration or design; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab155a19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8225/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 30 days of continuous session of Congress (excluding any day on which either House of Congress is not in session) expires following the date on which the notice is received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab155a1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8225/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this section, the continuity of a session of Congress is broken only by an adjournment of the Congress sine die.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab155a1b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 573(a)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–136, § 6035; renumbered § 8225, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/7"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1834"},"text":"132 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab155a1c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab155a1d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab155a1e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8225, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/503"},"text":"70A Stat. 503","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s504/9"},"text":"Pub. L. 96–513, title V, § 504(9)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2916"},"text":"94 Stat. 2916","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXII/s1234/a/1"},"text":"Pub. L. 100–456, div. A, title XII, § 1234(a)(1)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2059"},"text":"102 Stat. 2059","children":[],"tail":", related to authorized strength of Air 