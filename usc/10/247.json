{"tag":"section","attrib":{"id":"ida7924e2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s247"},"text":null,"children":[{"tag":"num","attrib":{"value":"247"},"text":"§ 247.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Militia duty: exemptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7924e2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s247/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following persons are exempt from militia duty:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7924e2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s247/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Vice President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7924e2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s247/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The judicial and executive officers of the United States, the several States, the Commonwealth of Puerto Rico, Guam, and the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7924e2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s247/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the armed forces, except members who are not on active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7924e30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s247/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Customhouse clerks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7924e31-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s247/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Persons employed by the United States in the transmission of mail.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7924e32-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s247/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Workmen employed in armories, arsenals, and naval shipyards of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7924e33-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s247/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pilots on navigable waters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7924e34-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s247/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mariners in the sea service of a citizen of, or a merchant in, the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7924e35-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s247/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who claims exemption because of religious belief is exempt from militia duty in a combatant capacity, if the conscientious holding of that belief is established under such regulations as the President may prescribe. However, such a person is not exempt from militia duty that the President determines to be noncombatant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7924e36-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/15"},"text":"70A Stat. 15","children":[],"tail":", § 312; "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXII/s1234/a/3"},"text":"Pub. L. 100–456, div. A, title XII, § 1234(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2059"},"text":"102 Stat. 2059","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1057/a/7"},"text":"Pub. L. 109–163, div. A, title X, § 1057(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3441"},"text":"119 Stat. 3441","children":[],"tail":"; renumbered § 247, "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1241/a/2"},"text":"Pub. L. 114–328, div. A, title XII, § 1241(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2497"},"text":"130 Stat. 2497","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7924e37-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida7924e38-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida7924e39-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"312(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"312(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"32:3 (less last 67 words).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"32:3 (last 67 words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-06-03/ch134/s59"},"text":"June 3, 1916, ch. 134, § 59","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/39/197"},"text":"39 Stat. 197","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Members of the armed forces” are substituted for the words “persons in the military or naval service”. The words “except members who are not on active duty” are inserted to reflect an opinion of the Judge Advocate General of the Army (JAGA 1952/4374, 9 July 1952). The word “artificers” is omitted as covered by the word “workmen”. The words “naval shipyards” are substituted for the words “navy yards” to reflect modern terminology. The words “on navigable waters” are inserted to preserve the original coverage of the word “pilots”. The words “actually” and “without regard to age” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7924e3a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7924e3b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s312"},"text":"section 312 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “States, the Commonwealth of Puerto Rico, Guam, and the Virgin Islands” for “States and Territories, and Puerto Rico”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" substituted “and Puerto Rico” for “Puerto Rico, and the Canal Zone”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
