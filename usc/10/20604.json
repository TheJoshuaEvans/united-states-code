{"tag":"section","attrib":{"id":"idabcceab2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20604"},"text":null,"children":[{"tag":"num","attrib":{"value":"20604"},"text":"§ 20604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enlisted members: computation of years of service for voluntary retirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabcceab3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20604/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Years of Active Service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purpose of determining whether an enlisted member of the Space Force may be retired under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20603"},"text":"section 20603 of this title","children":[],"tail":", the member’s years of service are computed by adding all active service in the armed forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabcceab4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20604/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reference to Section Excluding Counting of Certain Service Required to Be Made up","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Time required to be made up under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s972/a"},"text":"section 972(a) of this title","children":[],"tail":" may not be counted in computing years of service under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabcceab5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1719A/a"},"text":"Pub. L. 118–31, div. A, title XVII, § 1719A(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/663"},"text":"137 Stat. 663","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
