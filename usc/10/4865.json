{"tag":"section","attrib":{"id":"idaaa2e9d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865"},"text":null,"children":[{"tag":"num","attrib":{"value":"4865"},"text":"§ 4865.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on acquisition of advanced batteries composed of materials from certain foreign sources","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaa2e9d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall procure advanced batteries and cells whose functional cell components and technology, whether as end items or embedded within warfighting and support systems, are not owned, sourced, refined, or produced from a foreign entity of concern.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaa2e9da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section applies to all new acquisition programs on ","children":[{"tag":"date","attrib":{"date":"2028-01-01"},"text":"January 1, 2028","children":[],"tail":", standard batteries on "},{"tag":"date","attrib":{"date":"2029-01-01"},"text":"January 1, 2029","children":[],"tail":", and for existing acquisition programs on "},{"tag":"date","attrib":{"date":"2031-01-30"},"text":"January 30, 2031","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaa2e9db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaa2e9dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sourcing and production compliance.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaa2e9dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply to an advanced battery or cell of an advanced battery if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaaa2e9de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the final assembly of such advanced battery or cell is carried out by an entity other than a foreign entity of concern;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaaa2e9df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" functional cell components comprising more than 95 percent of the costs of the functional cell components of such advanced battery or cell are from sources other than foreign entities of concern; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaaa2e9e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such advanced battery or cell is produced without technology licensed from a foreign entity of concern.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa2e9e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recycled source determination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purposes of subparagraph (A)(ii), any material or component from an entity that has been recycled and reprocessed domestically is considered to originate from that entity regardless of origin.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaa2e9e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Excluded batteries","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply to a battery or cell of a battery that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaa2e9e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquired for use in a cell phone, laptop, personal electronic device, or medical equipment intended for use in an office, administrative, hospital, or non-combat environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa2e9e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercially available off-the-shelf item for use only in the maintenance of equipment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa2e9e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquired for research, development, testing, and evaluation by the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaa2e9e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaa2e9e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may waive the limitations specified in subsection (a) for a specific system or battery for one year if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaaa2e9e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that a satisfactory quality and sufficient quantity such advanced battery or cell that are not subject to such prohibition cannot be acquired as and when needed by the Department of Defense at reasonable costs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaaa2e9e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an advanced battery or cell that is a component of a warfighting or support system, sufficient documentation exists to show that such advanced battery or cell is not a functional enabler of operational capability for such system and such advanced battery or cell poses no risk to the security of or sourcing for such system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa532da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delegation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may delegate the authority under subparagraph (A) only to the Under Secretary of Defense for Acquisition and Sustainment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaa532db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2028-12-01"},"text":"December 1, 2028","children":[],"tail":", and not less frequently than once every three years thereafter until the date that is twelve years after the date of the enactment of this Act, the Secretary of Defense shall provide to the congressional defense committees a briefing on the status of meeting the requirements under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaa532dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaa532dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “new acquisition program” means a defense acquisition program that has not reached the initiation of the engineering and manufacturing development phase, or an equivalent phase of development, including a defense acquisition program that has not undergone a formal Milestone B approval or equivalent decision point, before the date of the enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaa532de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “existing acquisition program” means a defense acquisition program that has reached the initiation of the engineering and manufacturing development phase, or an equivalent phase of development, including a defense acquisition program that has undergone a formal Milestone B approval or equivalent decision point, before the date of the enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaa532df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “functional cell component” means the cathode materials, anode materials, separators, anode foils, and other functional materials of an advanced battery that contribute to the chemical processes necessary for energy storage, including solvents, additives, electrolyte salts, and internal safety devices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaa532e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The “foreign entity of concern” has the meaning given such term under section 40207(a) of the Infrastructure Investment and Jobs Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18741/a"},"text":"42 U.S.C. 18741(a)","children":[],"tail":"), and includes entities specified in section 154 of the National Defense Authorization Act for Fiscal Year 2024 ("},{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Public Law 118–31","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4651"},"text":"10 U.S.C. 4651","children":[],"tail":" note prec.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaa532e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4865/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “standard battery” means a battery that used in more than one weapons system and are not managed by one portfolio acquisition executive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaa532e2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVIII/s842/a"},"text":"Pub. L. 119–60, div. A, title VIII, § 842(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/973"},"text":"139 Stat. 973","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaa532e3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaa532e4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaaa532e5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this Act, referred to in subsec. (d), (e)(1), (2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaaa532e6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaaa532e7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVIII/s842/b"},"text":"Pub. L. 119–60, div. A, title VIII, § 842(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/975"},"text":"139 Stat. 975","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tVIII/s842/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4865"},"text":"Section 4865 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall apply only with respect to contracts or other agreements entered into after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaaa532e8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVIII/s842/c"},"text":"Pub. L. 119–60, div. A, title VIII, § 842(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/975"},"text":"139 Stat. 975","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tVIII/s842/c"},"text":"“Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"], the Secretary of Defense shall revise the Department of Defense Supplement to the Federal Acquisition Regulation to incorporate the requirements of this "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4865"},"text":"section 4865 of title 10","children":[],"tail":", United States Code, as added by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
