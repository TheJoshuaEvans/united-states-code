{"tag":"section","attrib":{"id":"idaab11a5f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4971"},"text":null,"children":[{"tag":"num","attrib":{"value":"4971"},"text":"§ 4971.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of loan guarantee program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaab11a60-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4971/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In order to meet the national security objectives in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4811/a"},"text":"section 4811(a) of this title","children":[],"tail":", the Secretary of Defense shall establish a program under which the Secretary may issue guarantees assuring a lender against losses of principal or interest, or both principal and interest, arising out of the financing of the sale or long-term lease of defense articles, defense services, or design and construction services to a country referred to in subsection (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab11a61-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4971/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Countries","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authority under subsection (a) applies with respect to the following countries:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab11a62-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4971/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member nation of the North Atlantic Treaty Organization (NATO).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab11a63-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4971/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A country designated as of ","children":[{"tag":"date","attrib":{"date":"1995-03-31"},"text":"March 31, 1995","children":[],"tail":", as a major non-NATO ally pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2350a/i/3"},"text":"section 2350a(i)(3) of this title","children":[],"tail":", as in effect on that date."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab11a64-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4971/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A country in Central Europe that, as determined by the Secretary of State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaab11a65-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4971/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has changed its form of national government from a nondemocratic form of government to a democratic form of government since ","children":[{"tag":"date","attrib":{"date":"1989-10-01"},"text":"October 1, 1989","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab11a66-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4971/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the process of changing its form of national government from a nondemocratic form of government to a democratic form of government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab11a67-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4971/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A noncommunist country that was a member nation of the Asia Pacific Economic Cooperation (APEC) as of ","children":[{"tag":"date","attrib":{"date":"1993-10-31"},"text":"October 31, 1993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab11a68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4971/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority Subject to Provisions of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may guarantee a loan under this subchapter only to such extent or in such amounts as may be provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaab11a69-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXIII/s1321/a/1"},"text":"Pub. L. 104–106, div. A, title XIII, § 1321(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/475"},"text":"110 Stat. 475","children":[],"tail":", § 2540; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tX/s1084/d/21"},"text":"Pub. L. 108–375, div. A, title X, § 1084(d)(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2062"},"text":"118 Stat. 2062","children":[],"tail":"; renumbered § 4971 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII"},"text":"Pub. L. 116–283, div. A, title XVIII","children":[],"tail":", §§ 1873(b), (c)(1), 1883(b)(2), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4290"},"text":"134 Stat. 4290","children":[],"tail":", 4294.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaab11a6a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaab11a6b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaab11a6c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1873/b"},"text":"Pub. L. 116–283, § 1873(b)","children":[],"tail":", (c)(1), renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2540"},"text":"section 2540 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1883/b/2"},"text":"Pub. L. 116–283, § 1883(b)(2)","children":[],"tail":", substituted “section 4811(a)” for “section 2501(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" inserted “, as in effect on that date” before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaab11a6d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaab11a6e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaab11a6f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authority To Issue Loan Guarantees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/287/tVIII/s8065"},"text":"Pub. L. 108–287, title VIII, § 8065","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-05"},"text":"Aug. 5, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/985"},"text":"118 Stat. 985","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1873/d"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1873(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4290"},"text":"134 Stat. 4290","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1702/b/3"},"text":"Pub. L. 117–81, div. A, title XVII, § 1702(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2155"},"text":"135 Stat. 2155","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dA/tXVII/s1702/b/3"},"text":"“To the extent authorized by subchapter I of chapter 389 of title 10, United States Code, for the current fiscal year and hereafter the Secretary of Defense may issue loan guarantees in support of United States defense exports not otherwise provided for: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the total contingent liability of the United States for guarantees issued under the authority of this section may not exceed $15,000,000,000: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That the exposure fees charged and collected by the Secretary for each guarantee shall be paid by the country involved and shall not be financed as part of a loan guaranteed by the United States: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That the Secretary shall provide quarterly reports to the Committees on Appropriations, Armed Services, and Foreign Relations of the Senate and the Committees on Appropriations, Armed Services, and International Relations [now Committee on Foreign Affairs] in the House of Representatives on the implementation of this program: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That amounts charged for administrative fees and deposited to the special account provided for under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4974/d"},"text":"section 4974(d) of title 10","children":[],"tail":", shall be available for paying the costs of administrative expenses of the Department of Defense that are attributable to the loan guarantee program under subchapter I of chapter 389 of title 10, United States Code.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1873/d"},"text":"Pub. L. 116–283, § 1873(d)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1702/b/3"},"text":"Pub. L. 117–81, § 1702(b)(3)","children":[],"tail":", made identical amendments to "},{"tag":"ref","attrib":{"href":"/us/pl/108/287/s8065"},"text":"section 8065 of Pub. L. 108–287","children":[],"tail":", set out above, substituting “subchapter I of chapter 389” for “subchapter VI of chapter 148” in two places and “section 4974(d)” for “section 2540c(d)”. The amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" was effective as if included in title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", thus making the amendments effective simultaneously.]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/87/tVIII/s8066"},"text":"Pub. L. 108–87, title VIII, § 8066","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1087"},"text":"117 Stat. 1087","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/248/tVIII/s8067"},"text":"Pub. L. 107–248, title VIII, § 8067","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-23"},"text":"Oct. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1551"},"text":"116 Stat. 1551","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/117/dA/tVIII/s8073"},"text":"Pub. L. 107–117, div. A, title VIII, § 8073","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"Jan. 10, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2264"},"text":"115 Stat. 2264","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/259/tVIII/s8071"},"text":"Pub. L. 106–259, title VIII, § 8071","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-08-09"},"text":"Aug. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/690"},"text":"114 Stat. 690","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/79/tVIII/s8075"},"text":"Pub. L. 106–79, title VIII, § 8075","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-25"},"text":"Oct. 25, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1246"},"text":"113 Stat. 1246","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/262/tVIII/s8075"},"text":"Pub. L. 105–262, title VIII, § 8075","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2314"},"text":"112 Stat. 2314","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/56/tVIII/s8081"},"text":"Pub. L. 105–56, title VIII, § 8081","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-10-08"},"text":"Oct. 8, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1237"},"text":"111 Stat. 1237","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,