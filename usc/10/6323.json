{"tag":"section","attrib":{"id":"idaacdca6b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6323"},"text":null,"children":[{"tag":"num","attrib":{"value":"6323"},"text":"§ 6323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments of emergency preparedness of defense nuclear facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":" The Secretary of Energy shall include, in each award-fee evaluation conducted under section 16.401 of title 48, Code of Federal Regulations, of a management and operating contract for a Department of Energy defense nuclear facility in 2016 or any even-numbered year thereafter, an assessment of the adequacy of the emergency preparedness of that facility, including an assessment of the seniority level of management and operating contractor employees that participate in emergency preparedness exercises at that facility.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idaacdca6c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1441"},"text":"139 Stat. 1441","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaacdca6d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaacdca6e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaacdca6f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6323 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8323"},"text":"section 8323 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2782a"},"text":"section 2782a of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
