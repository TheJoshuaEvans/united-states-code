{"tag":"section","attrib":{"id":"ida8ff2544-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1605"},"text":null,"children":[{"tag":"num","attrib":{"value":"1605"},"text":"§ 1605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits for certain employees assigned outside the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8ff2545-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ff2546-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1605/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may provide to civilian personnel described in subsection (d) allowances and benefits comparable to those provided by the Secretary of State to officers and employees of the Foreign Service under paragraphs (2), (3), (4), (5), (6), (7), (8), and (13) of section 901 and sections 705 and 903 of the Foreign Service Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4081/2"},"text":"22 U.S.C. 4081(2)","children":[],"tail":", (3), (4), (5), (6), (7), (8), and (13), 4025, 4083) and under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5924/4"},"text":"section 5924(4) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ff2547-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1605/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may also provide to any such civilian personnel special retirement accrual benefits in the same manner provided for certain officers and employees of the Central Intelligence Agency in section 303 of the Central Intelligence Agency Retirement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2153"},"text":"50 U.S.C. 2153","children":[],"tail":") and in section 18 of the Central Intelligence Agency Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3518"},"text":"50 U.S.C. 3518","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ff2548-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority of the Secretary of Defense to make payments under subsection (a) is effective for any fiscal year only to the extent that appropriated funds are available for such purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ff2549-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1605/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Regulations prescribed under subsection (a) may not take effect until the Secretary of Defense has submitted such regulations to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ff254a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1605/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services and the Select Committee on Intelligence of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ff254b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1605/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services and the Permanent Select Committee on Intelligence of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ff254c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1605/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a) applies to civilian personnel of the Department of Defense who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ff254d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1605/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are United States nationals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ff254e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1605/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of employees of the Defense Intelligence Agency, are assigned to duty outside the United States and, in the case of other employees, are assigned to Defense Attaché Offices or Defense Intelligence Agency Liaison Offices outside the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ff254f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1605/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are designated by the Secretary of Defense for the purposes of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8ff2550-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/215/tV/s501/a"},"text":"Pub. L. 98–215, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-09"},"text":"Dec. 9, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1478"},"text":"97 Stat. 1478","children":[],"tail":", § 192; renumbered § 1605 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXIII/s1302/a/1"},"text":"Pub. L. 99–145, title XIII, § 1302(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/737"},"text":"99 Stat. 737","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/tV/s507/b"},"text":"Pub. L. 99–335, title V, § 507(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/628"},"text":"100 Stat. 628","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/569/tV/s501"},"text":"Pub. L. 99–569, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3198"},"text":"100 Stat. 3198","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/193/tV/s505/a"},"text":"Pub. L. 101–193, title V, § 505(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1709"},"text":"103 Stat. 1709","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s803/d"},"text":"Pub. L. 102–496, title VIII, § 803(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3253"},"text":"106 Stat. 3253","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tXI/s1182/a/3"},"text":"Pub. L. 103–160, div. A, title XI, § 1182(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1771"},"text":"107 Stat. 1771","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/93/tV/s502/a"},"text":"Pub. L. 104–93, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-01-06"},"text":"Jan. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/972"},"text":"109 Stat. 972","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVI/s1633/c/1"},"text":"Pub. L. 104–201, div. A, title XVI, § 1633(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2751"},"text":"110 Stat. 2751","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1067/1"},"text":"Pub. L. 106–65, div. A, title X, § 1067(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/774"},"text":"113 Stat. 774","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1071/c/11"},"text":"Pub. L. 113–291, div. A, title X, § 1071(c)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3509"},"text":"128 Stat. 3509","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8ff2551-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8ff2552-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8ff2553-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3518"},"text":"50 U.S.C. 3518","children":[],"tail":")” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403r"},"text":"50 U.S.C. 403r","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “Committee on Armed Services” for “Committee on National Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" substituted “assigned outside the United States” for “of the Defense Intelligence Agency” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/93/s502/a/1"},"text":"Pub. L. 104–93, § 502(a)(1)","children":[],"tail":", designated first sentence of existing text as par. (1) and substituted “described in subsection (d)” for “of the Department of Defense who are United States nationals, who are assigned to Defense Attaché Offices and Defense Intelligence Agency Liaison Offices outside the United States, and who are designated by the Secretary of Defense for the purposes of this subsection,”, and designated second sentence of existing text as par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/93/s502/a/2"},"text":"Pub. L. 104–93, § 502(a)(2)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c) which read as follows: “Regulations issued pursuant to subsection (a) shall be submitted to the Committee on Armed Services and the Permanent Select Committee on Intelligence of the House of Representatives and the Committee on Armed Services and the Select Committee on Intelligence of the Senate before such regulations take effect.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/93/s502/a/3"},"text":"Pub. L. 104–93, § 502(a)(3)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":" substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2153"},"text":"50 U.S.C. 2153","children":[],"tail":")” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403"},"text":"50 U.S.C. 403","children":[],"tail":" note)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/496"},"text":"Pub. L. 102–496","children":[],"tail":" substituted “the Central Intelligence Agency Retirement Act” for “the Central Intelligence Agency Retirement Act of 1964 for Certain Employees” and inserted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403r"},"text":"50 U.S.C. 403r","children":[],"tail":")” after “the Central Intelligence Agency Act of 1949”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/193"},"text":"Pub. L. 101–193","children":[],"tail":" struck out “who are subject to chapter 84 of title 5,” after “such civilian personnel” in last sentence and inserted reference to section 18 of the Central Intelligence Agency Act of 1949."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/569"},"text":"Pub. L. 99–569","children":[],"tail":" inserted reference to par. (5) of section 901 of the Foreign Service Act of 1980 ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4081/5"},"text":"22 U.S.C. 4081(5)","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335"},"text":"Pub. L. 99–335","children":[],"tail":" inserted provision authorizing the Secretary to provide to any civilian personnel subject to chapter 84 of title 5 special retirement accrual benefits in the same manner provided for certain officers and employees of the Central Intelligence Agency in section 303 of the Central Intelligence Agency Retirement Act of 1964 for Certain Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/s1302/a/1/A"},"text":"Pub. L. 99–145, § 1302(a)(1)(A)","children":[],"tail":", (B), struck out references to Director of the Defense Intelligence Agency and to military personnel, substituted “sections 705 and 903” for “under sections 903, 705, and 2308”, and substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4081/2"},"text":"22 U.S.C. 4081(2)","children":[],"tail":", (3), (4), (6), (7), (8), and (13), 4025, 4083) and under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5924/4"},"text":"section 5924(4) of title 5","children":[],"tail":".” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4025"},"text":"22 U.S.C. 4025","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4081/2"},"text":"22 U.S.C. 4081(2)","children":[],"tail":", (3), (4), (6), (7), (8), and (13); "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4083"},"text":"22 U.S.C. 4083","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5924/4"},"text":"5 U.S.C. 5924(4)","children":[],"tail":").”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/s1302/a/1/A"},"text":"Pub. L. 99–145, § 1302(a)(1)(A)","children":[],"tail":", struck out reference to Director of the Defense Intelligence Agency."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/s1302/a/1/C"},"text":"Pub. L. 99–145, § 1302(a)(1)(C)","children":[],"tail":", struck out subsec. (c) which read as follows: “Members of the Armed Forces may not receive benefits under both subsection (a) and title 37, United States Code, for the same purpose. The Secretary of Defense shall prescribe such regulations as may be necessary to carry out this subsection.”, and redesignated former subsec. (d) as (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8ff2554-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8ff2555-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1635"},"text":"section 1635 of Pub. L. 104–201","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1593"},"text":"section 1593 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8ff2556-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/496"},"text":"Pub. L. 102–496","children":[],"tail":" effective on first day of fourth month beginning after "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/s805"},"text":"section 805 of Pub. L. 102–496","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2001"},"text":"section 2001 of Title 50","children":[],"tail":", War and National Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8ff2557-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335"},"text":"Pub. L. 99–335","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"Jan. 1, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/s702/a"},"text":"section 702(a) of Pub. L. 99–335","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8401"},"text":"section 8401 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
