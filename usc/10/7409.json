text":"104 Stat. 1533","children":[],"tail":") shall not take effect."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If under paragraph (1) the amendments made by this section take effect on ","children":[{"tag":"date","attrib":{"date":"1992-10-01"},"text":"October 1, 1992","children":[],"tail":", the amendments made by this section shall be considered executed immediately following the amendments made by section 328 of the National Defense Authorization Act for Fiscal Year 1991 ("},{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Public Law 101–510","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/104/1533"},"text":"104 Stat. 1533","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaae8089b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tIII/s328/h"},"text":"Pub. L. 101–510, div. A, title III, § 328(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1534"},"text":"104 Stat. 1534","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/510/dA/tIII/s328/h"},"text":"“The amendments made by this section [amending this section and sections 4308, 4311, and 4313 of this title] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1992-10-01"},"text":"October 1, 1992","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
