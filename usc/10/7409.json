{"tag":"section","attrib":{"id":"idaae8088b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7409"},"text":null,"children":[{"tag":"num","attrib":{"value":"7409"},"text":"§ 7409.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rifle ranges: availability for use by members and civilians","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaae8088c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7409/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ranges Available","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All rifle ranges constructed in whole or in part with funds provided by the United States may be used by members of the armed forces and by persons capable of bearing arms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaae8088d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7409/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Military Ranges","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaae8088e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7409/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a rifle range referred to in subsection (a) that is located on a military installation, the Secretary concerned may establish reasonable fees for the use by civilians of that rifle range to cover the material and supply costs incurred by the armed forces to make that rifle range available to civilians.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaae8088f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7409/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fees collected pursuant to paragraph (1) in connection with the use of a rifle range shall be credited to the appropriation available for the operation and maintenance of that rifle range and shall be available for the operation and maintenance of that rifle range.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaae80890-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7409/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Use of a rifle range referred to in paragraph (1) by civilians may not interfere with the use of the range by members of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaae80891-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7409/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Regulations to carry out this section with respect to a rifle range shall be prescribed, subject to the approval of the Secretary concerned, by the authorities controlling the rifle range.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaae80892-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/236"},"text":"70A Stat. 236","children":[],"tail":", § 4309; "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXIII/s1301/b/3/A"},"text":"Pub. L. 99–145, title XIII, § 1301(b)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/735"},"text":"99 Stat. 735","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tIII/s328/e"},"text":"Pub. L. 101–510, div. A, title III, § 328(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1533"},"text":"104 Stat. 1533","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tIII/s380/b/1"},"text":"Pub. L. 102–484, div. A, title III, § 380(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2390"},"text":"106 Stat. 2390","children":[],"tail":"; renumbered § 7409, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/c/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaae80893-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaae80894-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaae80895-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4309(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4309(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"32:186 (1st sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"32:186 (less 1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-06-03/ch134/s113"},"text":"June 3, 1916, ch. 134, § 113","children":[],"tail":" (1st 2 sentences), "},{"tag":"html:a","attrib":{"href":"/us/stat/39/211"},"text":"39 Stat. 211","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “such a comprehensive * * * as will ultimately result in” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “United States” are substituted for the word “Congress”. The words “members of the armed forces” are substituted for the words “those in any branch of the military or naval service”. The words “of the United States” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaae80896-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaae80897-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4309"},"text":"section 4309 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":" amended section generally. Prior to amendment section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"Ranges Available","children":[],"tail":".—(1) All rifle ranges constructed in whole or in part with funds provided by the United States may be used by members of the armed forces and by able-bodied persons capable of bearing arms."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Military Ranges","children":[],"tail":".—(1) In the case of a rifle range referred to in subsection (a) located on a military installation, the Secretary of the Army shall establish reasonable fees for the use by civilians of that rifle range to cover any costs incurred by the Army to make that rifle range available to civilians."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Use of a rifle range referred to in paragraph (1) by civilians may not interfere with the use of those ranges by members of the armed forces.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—Regulations to carry out this section shall be prescribed by the authorities controlling the rifle range, subject to the approval of the Secretary of the Army.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" substituted “Rifle ranges: available for use by members and civilians” for “Rifle ranges: recommendations to Congress; regulations” in section catchline and amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) The Secretary of the Army shall submit annually to Congress recommendations and estimates for the establishment and maintenance of indoor and outdoor rifle ranges under a plan to provide facilities for rifle practice in all sections of the country.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) All rifle ranges established under subsection (a) and all rifle ranges already constructed, in whole or in part with funds provided by the United States, may be used by members of the armed forces and by all able-bodied persons capable of bearing arms, under regulations prescribed by the authorities controlling those ranges and approved by the Secretary.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" substituted “persons” for “males”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaae80898-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaae80899-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaae8089a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tIII/s380/e"},"text":"Pub. L. 102–484, div. A, title III, § 380(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children"