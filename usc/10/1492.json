{"tag":"section","attrib":{"id":"ida8ddb9ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1492"},"text":null,"children":[{"tag":"num","attrib":{"value":"1492"},"text":"§ 1492.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to provide travel and transportation allowances in connection with transfer ceremonies of certain civilian employees who die overseas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8ddb9eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1492/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A covered official may treat a covered relative of a covered employee under the jurisdiction of that covered official in the same manner the Secretary of a military department treats, under section 481f(d) ","children":[{"tag":"ref","attrib":{"idref":"fn002067"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002067"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 37, next of kin and family members of a member of the armed forces who dies while located or serving overseas."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ddb9ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1492/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ddb9ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1492/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered employee” means a civilian employee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8ddb9ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1492/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the jurisdiction of a covered official; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8ddb9ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1492/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who dies while located or serving overseas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ddb9f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1492/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered official” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8ddb9f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1492/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the military department concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8ddb9f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1492/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of a Defense Agency or Department of Defense Field Activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ddb9f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1492/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered relative” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8ddb9f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1492/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the primary next of kin of the covered employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8ddb9f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1492/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two family members (other than primary next of kin) of the covered employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8ddb9f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1492/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more additional family members of the covered employee, at the discretion of the Secretary a sibling of the covered employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8ddb9f7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXI/s1104/a/1"},"text":"Pub. L. 116–283, div. A, title XI, § 1104(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3889"},"text":"134 Stat. 3889","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8ddb9f