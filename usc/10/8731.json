{"tag":"section","attrib":{"id":"idab476641-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8731"},"text":null,"children":[{"tag":"num","attrib":{"value":"8731"},"text":"§ 8731.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements as to consultation and approval","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab476642-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8731/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Committee on Armed Services of the Senate and the Committee on Armed Services of the House of Representatives must be consulted and the President’s approval must be obtained before any condemnation proceedings may be started under this chapter and before any of the following transactions authorized by this chapter may be effective:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab476643-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8731/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A lease of any part of the naval petroleum reserves.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab476644-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8731/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contract to alienate from the United States the use, control, or possession of any part of the naval petroleum reserves (except that consultation and Presidential approval are not required in connection with the issuance of permits, licenses, easements, grazing and agricultural leases, rights-of-way, and similar contracts pertaining to use of the surface area of the naval petroleum reserves).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab476645-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8731/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contract to sell the petroleum (other than royalty oil and gas) produced from any part of the naval petroleum reserves.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab476646-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8731/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contract for conservation or for compensation for estimated drainage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab476647-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8731/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agreement to exchange land, the right to royalty production, or the right to any money due the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab476648-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8731/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab476649-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8731/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During the period of production authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8722/c"},"text":"section 8722(c) of this title","children":[],"tail":", the Secretary shall submit to the Committee on Armed Services of the Senate and the Committee on Armed Services of the House of Representatives any new plans or substantial amendments to ongoing plans for the exploration, development, and production of the naval petroleum reserves."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab47664a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8731/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All plans or substantial amendments submitted to the Congress pursuant to this section shall contain a report by the Attorney General of the United States with respect to the anticipated effects of such plans or amendments on competition. Such plans or amendments shall not be implemented until sixty days after such plans or amendments have been submitted to such committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab47664b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/460"},"text":"70A Stat. 460","children":[],"tail":", § 7431; "},{"tag":"ref","attrib":{"href":"/us/pl/87/796/s1/7"},"text":"Pub. L. 87–796, § 1(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-11"},"text":"Oct. 11, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/905"},"text":"76 Stat. 905","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/258/tII/s201/12"},"text":"Pub. L. 94–258, title II, § 201(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-05"},"text":"Apr. 5, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/311"},"text":"90 Stat. 311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXIV/s1405/52"},"text":"Pub. L. 98–525, title XIV, § 1405(52)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},