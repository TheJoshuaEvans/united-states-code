{"tag":"section","attrib":{"id":"ida903df3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1701b"},"text":"§ 1701b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced pay authority for certain acquisition and technology positions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida903df3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may carry out a program using the pay authority specified in subsection (d) to fix the rate of basic pay for positions described in subsection (c) in order to assist the Office of the Secretary of Defense and the military departments in attracting and retaining high-quality acquisition and technology experts in positions responsible for managing and developing complex, high-cost, technological acquisition efforts of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida903df3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program may be carried out only with approval as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida903df3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Approval of the Under Secretary of Defense for Acquisition and Sustainment, in the case of positions in the Office of the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida903df3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Approval of the service acquisition executive of the military department concerned, in the case of positions in a military department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida903df40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Positions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The positions described in this subsection are positions that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida903df41-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require expertise of an extremely high level in a scientific, technical, professional, or acquisition management field; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida903df42-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are critical to the successful accomplishment of an important acquisition or technology development mission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida903df43-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rate of Basic Pay","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The pay authority specified in this subsection is authority as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida903df44-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Authority to fix the rate of basic pay for a position at a rate not to exceed 150 percent of the rate of basic pay payable for level I of the Executive Schedule, upon the approval of the Under Secretary of Defense for Acquisition and Sustainment or the service acquisition executive concerned, as applicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida903df45-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Authority to fix the rate of basic pay for a position at a rate in excess of 150 percent of the rate of basic pay payable for level I of the Executive Schedule, upon the approval of the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida903df46-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida903df47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority in subsection (a) may be used only to the extent necessary to competitively recruit or retain individuals exceptionally well qualified for positions described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida903df48-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Number of positions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authority in subsection (a) may not be used at any one time with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida903df49-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701b/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than five positions, in total, in Department of Defense Field Activities and Defense Agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida903df4a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701b/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than five positions in the Office of the Secretary of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida903df4b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701b/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than five positions in each military department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida903df4c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term of positions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority in subsection (a) may be used only for positions having terms less than five years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida903df4d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXI/s1114/a"},"text":"Pub. L. 116–283, div. A, title XI, § 1114(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3894"},"text":"134 Stat. 3894","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVIII/s831/b"},"text":"Pub. L. 117–263, div. A, title VIII, § 831(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2711"},"text":"136 Stat. 2711","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida903df4e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida903df4f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida903df50-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Level I of the Executive Schedule, referred to in subsec. (d), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5312"},"text":"section 5312 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida903df51-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" amended par. (2) generally. Prior to amendment, text read as follows: “The authority in subsection (a) may not be used with respect to more than five positions in the Office of the Secretary of Defense and more than five positions in each military department at any one time.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
