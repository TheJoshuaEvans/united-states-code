{"tag":"section","attrib":{"id":"idaa8af490-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4751"},"text":null,"children":[{"tag":"num","attrib":{"value":"4751"},"text":"§ 4751.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations and decisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa8af491-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4751/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Individual or Class Determinations and Decisions Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Determinations and decisions required to be made under any chapter 137 legacy provision by the head of an agency may be made for an individual purchase or contract or, except to the extent expressly prohibited by another provision of law, for a class of purchases or contracts. Such determinations and decisions are final.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa8af492-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4751/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Written Findings Required","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa8af493-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4751/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each determination or decision under section 3531(a), 3803, or 3841(c)(2)(B) of this title shall be based on a written finding by the person making the determination or decision. The finding shall set out facts and circumstances that support the determination or decision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8af494-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4751/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each finding referred to in paragraph (1) is final. The head of the agency making such finding shall maintain a copy of the finding for not less than 6 years after the date of the determination or decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa8af495-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/132"},"text":"70A Stat. 132","children":[],"tail":", § 2310; "},{"tag":"ref","attrib":{"href":"/us/pl/85/800/s10"},"text":"Pub. L. 85–800, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-28"},"text":"Aug. 28, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/967"},"text":"72 Stat. 967","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/653/s1/f"},"text":"Pub. L. 87–653, § 1(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-10"},"text":"Sept. 10, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/529"},"text":"76 Stat. 529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/607/s1/1"},"text":"Pub. L. 89–607, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-27"},"text":"Sept. 27, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/850"},"text":"80 Stat. 850","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/378/s2"},"text":"Pub. L. 90–378, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-05"},"text":"July 5, 1968","children":[],"tail":", "}