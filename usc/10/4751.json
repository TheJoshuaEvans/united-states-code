ext":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2310(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2310(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:156(a) (1st sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"41:156(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1948-02-19/ch65/s7/a"},"text":"Feb. 19, 1948, ch. 65, § 7(a)","children":[],"tail":" (1st sentence), (c), "},{"tag":"html:a","attrib":{"href":"/us/stat/62/24"},"text":"62 Stat. 24","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “required * * * under” are substituted for the words “provided in”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “person” is substituted for the word “official”. The words “to which it applies” are inserted for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa8af499-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa8af49a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1864/b"},"text":"Pub. L. 116–283, § 1864(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2310"},"text":"section 2310 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1864/c/1"},"text":"Pub. L. 116–283, § 1864(c)(1)","children":[],"tail":", substituted “made under any chapter 137 legacy provision” for “made under this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1864/c/2"},"text":"Pub. L. 116–283, § 1864(c)(2)","children":[],"tail":", substituted “section 3531(a), 3803, or 3841(c)(2)(B)” for “section 2306(g)(1), 2307(d), or 2313(c)(2)(B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355"},"text":"Pub. L. 103–355","children":[],"tail":" amended section generally. Prior to amendment, section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) Determinations and decisions required to be made under this chapter by the head of an agency may be made for an individual purchase or contract or, except for determinations and decisions under section 2304 or 2305 of this title, for a class of purchases or contracts. Such a determination or decision, including a determination or decision under section 2304 or 2305 of this title, is final.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) Each determination or decision under section 2306(c), 2306(g)(1), 2307(c), or 2313(c) of this title shall be based on a written finding by the person making the determination or decision, which finding shall set out facts and circumstances that—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) clearly indicate why the type of contract selected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2306/c"},"text":"section 2306(c) of this title","children":[],"tail":" is likely to be less costly than any other type or that it is impracticable to obtain property or services of the kind or quality required except under such a contract;"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) support the findings required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2306/g/1"},"text":"section 2306(g)(1) of this title","children":[],"tail":";"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) clearly indicate why advance payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2307/c"},"text":"section 2307(c) of this title","children":[],"tail":" would be in the public interest; or"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) clearly indicate why the application of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2313/b"},"text":"section 2313(b) of this title","children":[],"tail":" to a contract or subcontract with a foreign contractor or foreign subcontractor would not be in the public interest."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Such a finding is final and shall be kept available in the agency for at least six years after the date of the determination or decision. A copy of the finding shall be submitted to the General Accounting Office with each contract to which it applies.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" inserted “this” after “2305 of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s2725/1"},"text":"Pub. L. 98–369, § 2725(1)","children":[],"tail":", inserted “, except for determinations and decisions under section 2304 or 2305 of title,” and “, including a determination or decision under section 2304 or 2305 of this title,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s2725/2"},"text":"Pub. L. 98–369, § 2725(2)","children":[],"tail":", amended subsec. (b) generally, striking out requirement that determinations to negotiate contracts be based on written findings by the contracting officers making the determinations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/378"},"text":"Pub. L. 90–378","children":[],"tail":" inserted “section 2306 (g)(1),” after “clauses (11)–(16) of section 2304(a), section 2306(c),”, and “(3) support the findings required by section 2306(g)(1),” after “kind or quality required except under such a contract,”, and redesignated former cls. (3) to (5) as (4) to (6), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/607"},"text":"Pub. L. 89–607","children":[],"tail":" inserted reference to section 2313(c), added cl. (4), and redesignated former cl. (4) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/653"},"text":"Pub. L. 87–653","children":[],"tail":" substituted “section 2306(c)” for “section 2306”, required decisions to negotiate contracts under section 2304(a)(2), (7), (8), (10) to (12) of this title to be based on a written finding by the person making the decision, which findings shall set out facts and circumstances illustrative of conditions described in section 2304(a)(11) to (16), indicate why the type of contract selected under section 2306(c) is likely to be less costly than any other or that its impracticable to obtain the required property or services except under such contract, indicate why advance payments under section 2307(c) would be in the public interest, or establish with respect to section 2304(a), (2), (7), (8), (10) to (12) that formal advertising would not have been feasible and practicable."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/800"},"text":"Pub. L. 85–800","children":[],"tail":" substituted “2307(c)” for “2307(a)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa8af49b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa8af49c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa8d659d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date and applicability of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355"},"text":"Pub. L. 103–355","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/s10001"},"text":"section 10001 of Pub. L. 103–355","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8752"},"text":"section 8752 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa8d659e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dB/tVII/s2751"},"text":"Pub. L. 98–369, div. B, title VII, § 2751","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1203"},"text":"98 Stat. 1203","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dB/tVII/s2751"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b), the amendments made by this title [see Tables for classification] shall apply with respect to any solicitation for bids or proposals issued after ","children":[{"tag":"date","attrib":{"date":"1985-03-31"},"text":"March 31, 1985","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by section 2713 [amending section 759 of former Title 40, Public Buildings, Property, and Works, and enacting provisions set out as a note under section 759 of former Title 40] and subtitle D [enacting sections 3551 to 3556 of Title 31, Money and Finance] shall apply with respect to any protest filed after ","children":[{"tag":"date","attrib":{"date":"1985-01-14"},"text":"January 14, 1985","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa8d659f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1962 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/653"},"text":"Pub. L. 87–653","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/87/653/s1/h"},"text":"section 1(h) of Pub. L. 87–653","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3065"},"text":"section 3065 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
