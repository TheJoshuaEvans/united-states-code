{"tag":"section","attrib":{"id":"ida9cc38a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2738"},"text":null,"children":[{"tag":"num","attrib":{"value":"2738"},"text":"§ 2738.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property loss: reimbursement of members for certain losses of household effects caused by hostile action","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9cc38aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2738/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Reimburse","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may reimburse a member of the armed forces in an amount not more than $100,000 for a loss described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cc38ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2738/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Losses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section applies with respect to a loss of household effects sustained during a move made incident to a change of permanent station when, as determined by the Secretary, the loss was caused by a hostile action incident to war or a warlike action by a military force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cc38ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2738/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may provide reimbursement under this section for a loss described in subsection (b) only to the extent that the loss is not reimbursed under insurance or under the authority of another provision of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cc38ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2738/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Other Authorities and Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsections (b), (d), (e), (f), and (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2733"},"text":"section 2733 of this title","children":[],"tail":" shall apply to a request for a reimbursement under this section as if the request were a claim against the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9cc38ae-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tV/s557/a"},"text":"Pub. L. 103–337, div. A, title V, § 557(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2775"},"text":"108 Stat. 2775","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9cc38af-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9cc38b0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9cc38b1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tV/s557/c"},"text":"Pub. L. 103–337, div. A, title V, § 557(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2776"},"text":"108 Stat. 2776","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/337/dA/tV/s557/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2738"},"text":"Section 2738 of title 10","children":[],"tail":", United States Code, as added by subsection (a), applies with respect to losses incurred after "},{"tag":"date","attrib":{"date":"1990-06-30"},"text":"June 30, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a loss incurred after ","children":[{"tag":"date","attrib":{"date":"1990-06-30"},"text":"June 30, 1990","children":[],"tail":", and before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":"], a request for reimbursement shall be filed with the Secretary of the military department concerned not later than two years after such date of enactment.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
