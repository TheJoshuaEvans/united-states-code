{"tag":"section","attrib":{"id":"ida79004c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240c"},"text":null,"children":[{"tag":"num","attrib":{"value":"240c"},"text":"§ 240c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit: consolidated corrective action plan; centralized reporting system","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Under Secretary of Defense (Comptroller) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida79004c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a bimonthly basis, prepare a consolidated corrective action plan management summary on the status of key corrective actions plans related to critical capabilities for the armed forces and for the components of the Department of Defense that support the armed forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida79004c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and maintain a centralized monitoring and reporting process that captures and maintains up-to-date information, including the standard data elements recommended in the implementation guide for Office of Management and Budget Circular A–123, for key corrective action plans and findings and recommendations Department-wide that pertain to critical capabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida79004ca-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1002/d"},"text":"Pub. L. 115–91, div. A, title X, § 1002(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1540"},"text":"131 Stat. 1540","children":[],"tail":", § 253; renumbered § 240c, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tX/s1002/a/1/A"},"text":"Pub. L. 115–232, div. A, title X, § 1002(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1945"},"text":"132 Stat. 1945","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida79004cb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida79004cc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida79004cd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s253"},"text":"section 253 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
