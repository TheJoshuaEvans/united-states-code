{"tag":"section","attrib":{"id":"ida92549e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2103a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2103a"},"text":"§ 2103a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Students not eligible for advanced training: commitment to military service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida92549e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2103a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member of the program who has completed successfully the first year of a four-year Senior Reserve Officers’ Training Corps course and who is not eligible for advanced training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2104"},"text":"section 2104 of this title","children":[],"tail":" and is not a cadet or midshipman appointed under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2107"},"text":"section 2107 of this title","children":[],"tail":" may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida92549e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2103a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contract with the Secretary of the military department concerned, or the Secretary’s designated representative, to serve for the period required by the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92549e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2103a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree in writing to accept an appointment, if offered, as a commissioned officer in the Army, Navy, Air Force, Marine Corps, or Space Force, as the case may be, and to serve in the armed forces for the period prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92549e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2103a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member of the program may enter into a contract and agreement under this section (and receive a subsistence allowance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s209/c"},"text":"section 209(c) of title 37","children":[],"tail":") only if the person—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida92549e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2103a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a citizen of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92549e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2103a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enlists in an armed force under the jurisdiction of the Secretary of the military department concerned for the period prescribed by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92549e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2103a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" executes a certificate of loyalty in such form as the Secretary of Defense prescribes or take a loyalty oath as prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92549e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2103a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Parental Consent for Minors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the program who is a minor may enter into a contract under subsection (a)(1) only with the consent of the member’s parent or guardian.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida92549e9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tV/s523/b/1"},"text":"Pub. L. 108–136, div. A, title V, § 523(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1464"},"text":"117 Stat. 1464","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s525"},"text":"Pub. L. 108–375, div. A, title V, § 525","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1889"},"text":"118 Stat. 1889","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tX/s1071/a/10"},"text":"Pub. L. 109–364, div. A, title X, § 1071(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2398"},"text":"120 Stat. 2398","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/3/CC"},"text":"Pub. L. 116–283, div. A, title IX, § 924(b)(3)(CC)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3822"},"text":"134 Stat. 3822","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida92549ea-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida92549eb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida92549ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Marine Corps, or Space Force” for “or Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" substituted “Eligibility” for “Eligibilty” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" struck out heading and text of subsec. (d). Text read as follows: “No contract may be entered into under subsection (a)(1) after "},{"tag":"date","attrib":{"date":"2006-12-31"},"text":"December 31, 2006","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida92549ed-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida92549ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tV/s523/c"},"text":"Pub. L. 108–136, div. A, title V, § 523(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1464"},"text":"117 Stat. 1464","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/136/dA/tV/s523/c"},"text":"“The amendments made by subsections (a) and (b) [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s209"},"text":"section 209 of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services] shall take effect on "},{"tag":"date","attrib":{"date":"2004-01-01"},"text":"January 1, 2004","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
