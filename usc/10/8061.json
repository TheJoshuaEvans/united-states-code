{"tag":"section","attrib":{"id":"idab097403-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8061"},"text":null,"children":[{"tag":"num","attrib":{"value":"8061"},"text":"§ 8061.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of the Navy: composition","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Department of the Navy is composed of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab097404-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8061/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of the Secretary of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab097405-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8061/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of the Chief of Naval Operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab097406-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8061/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Headquarters, Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab097407-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8061/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The entire operating forces, including naval aviation, of the Navy and of the Marine Corps, and the reserve components of those operating forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab097408-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8061/5"},"text":null,"children":