{"tag":"section","attrib":{"id":"idaacdcaef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6331"},"text":null,"children":[{"tag":"num","attrib":{"value":"6331"},"text":"§ 6331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Laboratory-directed research and development programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaacdcaf0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6331/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Government-owned, contractor-operated laboratories that are funded out of funds available to the Department of Energy for national security programs are authorized to carry out laboratory-directed research and development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdcaf1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6331/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy shall prescribe regulations for the conduct of laboratory-directed research and development at such laboratories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdcaf2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6331/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of the funds provided by the Department of Energy to a national security laboratory for national security activities, the Secretary shall provide a specific amount, of not less than 5 percent and not more than 7 percent of such funds, to be used by the laboratory for laboratory-directed research and development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdcaf3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6331/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Laboratory-directed Research and Development Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term “laboratory-directed research and development” means research and development work of a creative and innovative nature which, under the regulations prescribed pursuant to subsection (b), is selected by the director of a laboratory for the purpose of maintaining the vitality of the laboratory in defense-related scientific disciplines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaacdcaf4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1448"},"text":"139 Stat. 1448","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaacdcaf5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaacdcaf6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaacdcaf7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6331 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8331"},"text":"section 8331 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2791"},"text":"section 2791 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
