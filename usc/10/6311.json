{"tag":"section","attrib":{"id":"idaacdca0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311"},"text":null,"children":[{"tag":"num","attrib":{"value":"6311"},"text":"§ 6311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on financial balances for atomic energy defense activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaacdca0b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports Required","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacdca0c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Concurrent with the submission of the budget justification materials submitted to Congress in support of the budget of the President for a fiscal year (submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":"), the Secretary of Energy shall submit to the congressional defense committees a report on the financial balances for each atomic energy defense program."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdca0d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In each report required by paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacdca0e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present information on the financial balances for each atomic energy defense program at the budget control levels used in the report accompanying the most current Act appropriating funds for energy and water development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdca0f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present financial balances in connection with funding under recurring DOE national security authorizations (as defined in section 6271) separately from balances in connection with funding under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdca10-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacdca11-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each report required by subsection (a) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacdca12-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be divided into two parts, as specified in paragraphs (2) and (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdca13-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth the information required by those paragraphs in summary form and by fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdca14-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The first part of the report required by subsection (a) shall set forth, for each atomic energy defense program, the following information, as of the end of the most recently completed fiscal year:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacdca15-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The balance of any unobligated funds and an explanation for why those funds are unobligated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdca16-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total funds available to cost.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdca17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total balance of costed funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdca18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total balance of uncosted funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdca19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The threshold for the balance of uncosted funds, stated in dollars.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdca1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of any balance of uncosted funds that is over or under that threshold and, in the case of a balance over that threshold, an explanation for why the balance is over that threshold.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdca1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total balance of encumbered, uncosted funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdca1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total balance of unencumbered, uncosted funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdca1d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of any balance of unencumbered, uncosted funds that is over or under the threshold described in subparagraph (E) and, in the case of a balance over that threshold, an explanation for why the balance is over that threshold.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdca1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The second part of the report required by subsection (a) shall set forth, for each atomic energy defense program, the following information:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacdca1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The balance of any unobligated funds, as of the end of the first quarter of the current fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdca20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total balance of uncosted funds, as of the end of the first quarter of the current fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdca21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Unalloted budget authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdca22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacdca23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “costed”, with respect to funds, means the funds have been obligated to a contract and goods or services have been received from the contractor in exchange for the funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdca24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “encumbered”, with respect to funds, means the funds have been obligated to a contract and are being held for a specific known purpose by the contractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdca25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “uncosted”, with respect to funds, means the funds have been obligated to a contract and goods or services have not been received from the contractor in exchange for the funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdca26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “unencumbered”, with respect to funds, means the funds have been obligated to a contract and are not being held for a specific known purpose by the contractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdca27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “threshold” means a benchmark over which a balance carried over at the end of a fiscal year should be given greater scrutiny by Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdca28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “total funds available to cost” means the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacdca29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" total uncosted obligations from prior fiscal years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdca2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" current fiscal year obligations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdca2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6311/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" current fiscal year deobligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaacdca2c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1438"},"text":"139 Stat. 1438","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaacdca2d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaacdca2e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaacdca2f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2772"},"text":"section 2772 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaacdca30-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) and (2) headings which read as follows: "},{"tag":"inline","attrib":{},"text":"“In general”","children":[],"tail":" and "},{"tag":"inline","attrib":{},"text":"“Presentation of information”","children":[],"tail":", respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) to (3) headings which read as follows: "},{"tag":"inline","attrib":{},"text":"“Format”, “Part 1”","children":[],"tail":", and "},{"tag":"inline","attrib":{},"text":"“Part 2”","children":[],"tail":", respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) to (6) headings which corresponded to the defined term in each par."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
