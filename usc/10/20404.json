{"tag":"section","attrib":{"id":"idabccea45-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20404"},"text":null,"children":[{"tag":"num","attrib":{"value":"20404"},"text":"§ 20404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of officers for early retirement or discharge","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabccea46-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20404/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration for Early Retirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Air Force may convene selection boards under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20211/b"},"text":"section 20211(b) of this title","children":[],"tail":" to consider for early retirement officers on the Space Force officer list as follows:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabccea47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20404/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Officers in the grade of lieutenant colonel who have failed of selection for promotion at least one time and whose names are not on a list of officers recommended for promotion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabccea48-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20404/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Officers in the grade of colonel who have served in that grade for at least two years and whose names are not on a list of officers recommended for promotion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabccea49-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20404/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Officers, other than those described in paragraphs (1) and (2), holding a grade below the grade of colonel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabccea4a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20404/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who are eligible for retirement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20601"},"text":"section 20601 of this title","children":[],"tail":" or who after two additional years or less of active service would be eligible for retirement under that section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabccea4b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20404/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose names are not on a list of officers recommended for promotion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabccea4c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20404/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration for Discharge.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabccea4d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20404/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Air Force may convene selection boards under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20211"},"text":"section 20211 of this title","children":[],"tail":" to consider for discharge officers on the Space Force officer list—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabccea4e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20404/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who have served at least one year of active status in the grade currently held;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabccea4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20404/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose names are not on a list of officers recommended for promotion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabccea50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20404/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who are not eligible to be retired under any provision of law (other than by reason of eligibility pursuant to section 4403 of the National Defense Authorization Act for Fiscal Year 1993) and are not within two years of becoming so eligible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabccea51-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20404/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who is recommended for discharge by a selection board convened pursuant to the authority of paragraph (1) and whose discharge is approved by the Secretary of the Air Force shall be discharged on a date specified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabccea52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20404/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Selection of officers for discharge under paragraph (1) shall be based on the needs of the service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabccea53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20404/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discharges and Retirements Considered to Be Involuntary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The discharge or retirement of an officer pursuant to this section shall be considered to be involuntary for purposes of any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabccea54-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1718/a"},"text":"Pub. L. 118–31, div. A, title XVII, § 1718(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/657"},"text":"137 Stat. 657","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVII/s1701/a/50"},"text":"Pub. L. 118–159, div. A, title XVII, § 1701(a)(50)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2206"},"text":"138 Stat. 2206","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabccea55-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabccea56-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idabccea57-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 4403 of the National Defense Authorization Act for Fiscal Year 1993, referred to in subsec. (b)(1)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s4403"},"text":"section 4403 of Pub. L. 102–484","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1293"},"text":"section 1293 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabccea58-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsecs. (a), (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “Space Force” for “space force” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
