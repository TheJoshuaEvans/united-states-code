{"tag":"section","attrib":{"id":"idab369e2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8625"},"text":null,"children":[{"tag":"num","attrib":{"value":"8625"},"text":"§ 8625.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Navy Reserve flag","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Navy shall prescribe a suitable flag to be known as the Navy Reserve flag. This flag may be flown by a seagoing merchant vessel if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab369e2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8625/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is documented under the laws of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369e2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8625/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel has been designated by the Secretary, under such regulations as he prescribes, as suitable for service as a naval auxiliary in time of war; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369e2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8625/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the master or commanding officer and at least half of the other licensed officers of the vessel are members of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab369e30-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/447"},"t