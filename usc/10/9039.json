{"tag":"section","attrib":{"id":"idab5f34f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9039"},"text":null,"children":[{"tag":"num","attrib":{"value":"9039"},"text":"§ 9039.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief of Chaplains: appointment; duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab5f34f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9039/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chief of Chaplains","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab5f34f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9039/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There is a Chief of Chaplains for the Air Force and the Space Force, appointed by the President, by and with the advice and consent of the Senate, from officers of the Air Force designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9067/h"},"text":"section 9067(h) of this title","children":[],"tail":" as chaplains who—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab5f34f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9039/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are serving on active duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab5f34f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9039/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have served on active duty as a chaplain for at least eight years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5f34f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9039/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer appointed as the Chief of Chaplains shall be appointed for a term of three years. However, the President may terminate or extend the appointment at any time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5f34f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9039/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Chaplains shall perform such duties as may be prescribed by the Secretary of the Air Force and by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab5f34f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9039/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection Board","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under regulations approved by the Secretary of Defense, the Secretary of the Air Force, in selecting an officer for recommendation to the President for appointment as the Chief of Chaplains, shall ensure that the officer selected is recommended by a board of officers that, insofar as practicable, is subject to the procedures applicable to the selection boards convened under chapter 36 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab5f34f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9039/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grade of Chief of Chaplains","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief of Chaplains, while so serving, holds the grade of major general.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab5f34f9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tV/s508/a"},"text":"Pub. L. 112–239, div. A, title V, § 508(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1716"},"text":"126 Stat. 1716","children":[],"tail":", § 8039; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tV/s502/mm"},"text":"Pub. L. 114–328, div. A, title V, § 502(mm)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2106"},"text":"130 Stat. 2106","children":[],"tail":"; renumbered § 9039 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tV/s510/c"},"text":"Pub. L. 115–232, div. A, title V, § 510(c)","children":[],"tail":", title VIII, §§ 806(c), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1751"},"text":"132 Stat. 1751","children":[],"tail":", 1833, 1840; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s923/b/8"},"text":"Pub. L. 116–283, div. A, title IX, § 923(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3809"},"text":"134 Stat. 3809","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab5f34fa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab5f34fb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab5f34fc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “for the Air Force and the Space Force” for “in the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s806/c"},"text":"Pub. L. 115–232, § 806(c)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8039"},"text":"section 8039 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 9067(h)” for “section 8067(h)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s510/c"},"text":"Pub. L. 115–232, § 510(c)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s502/mm/1"},"text":"Pub. L. 114–328, § 502(mm)(1)","children":[],"tail":", redesignated subpars. (B) and (C) as (A) and (B), respectively, and struck out former subpar. (A) which read as follows: “are serving in the grade of colonel or above;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s502/mm/2"},"text":"Pub. L. 114–328, § 502(mm)(2)","children":[],"tail":", struck out subsec. (c). Text read as follows: “An officer appointed as Chief of Chaplains who holds a lower regular grade may be appointed in the regular grade of major general.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab5f34fd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab5f34fe-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by sections 806(c) and 809(a) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab5f34ff-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Service of Incumbents in Certain Positions Without Reappointment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For continued service of Chief of Chaplains for the Air Force and the Space Force under this section after ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", without further appointment, notwithstanding amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/b/8"},"text":"section 923(b)(8) of Pub. L. 116–283","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/f"},"text":"section 923(f) of Pub. L. 116–283","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9020"},"text":"section 9020 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
