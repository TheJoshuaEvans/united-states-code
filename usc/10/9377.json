{"tag":"section","attrib":{"id":"idab6fd69d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9377"},"text":null,"children":[{"tag":"num","attrib":{"value":"9377"},"text":"§ 9377.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civilian special agents of the Office of Special Investigations: authority to execute warrants and make arrests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab6fd69e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9377/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Air Force may authorize any Department of the Air Force civilian employee described in subsection (b) to have the same authority to execute and serve warrants and other processes issued under the authority of the United States and to make arrests without a warrant as may be authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1585a"},"text":"section 1585a of this title","children":[],"tail":" for special agents of the Defense Criminal Investigative Service."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab6fd69f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9377/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agents To Have Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) applies to any employee of the Department of the Air Force who is a special agent of the Air Force Office of Special Investigations (or a successor to that office) whose duties include conducting, supervising, or coordinating investigations of criminal activity in programs and operations of the Department of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab6fd6a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9377/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidelines for Exercise of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority provided under subsection (a) shall be exercised in accordance with guidelines prescribed by the Secretary of the Air Force and approved by the Secretary of Defense and the Attorney General and any other applicable guidelines prescribed by the Secretary of the Air Force, the Secretary of Defense, or the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab6fd6a1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 554(c)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–127, § 9027; renumbered § 9377, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/b/16"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(b)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1833"},"text":"132 Stat. 1833","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab6fd6a2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab6fd6a3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab6fd6a4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9027"},"text":"section 9027 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab6fd6a5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab6fd6a6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
