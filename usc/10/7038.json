{"tag":"section","attrib":{"id":"idaad73fa8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7038"},"text":null,"children":[{"tag":"num","attrib":{"value":"7038"},"text":"§ 7038.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Army Reserve: appointment of Chief","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaad73fa9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7038/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is in the executive part of the Department of the Army an Office of the Army Reserve which is headed by a chief who is the adviser to the Chief of Staff on Army Reserve matters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad73faa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7038/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad73fab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7038/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President, by and with the advice and consent of the Senate, shall appoint the Chief of Army Reserve from general officers of the Army Reserve who have had at least 10 years of commissioned service in the Army Reserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad73fac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7038/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense may not recommend an officer to the President for appointment as Chief of Army Reserve unless the officer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaad73fad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7038/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is recommended by the Secretary of the Army; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad73fae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7038/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined by the Chairman of the Joint Chiefs of Staff, in accordance with criteria and as a result of a process established by the Chairman, to have significant joint duty experience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad73faf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7038/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer on active duty for service as the Chief of Army Reserve shall be counted for purposes of the grade limitations under sections 525 and 526 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad73fb0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7038/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Until ","children":[{"tag":"date","attrib":{"date":"2006-12-31"},"text":"December 31, 2006","children":[],"tail":", the Secretary of Defense may waive subparagraph (B) of paragraph (2) with respect to the appointment of an officer as Chief of Army Reserve if the Secretary of the Army requests the waiver and, in the judgment of the Secretary of Defense—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaad73fb1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7038/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer is qualified for service in the position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad73fb2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7038/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the waiver is necessary for the good of the service.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Any such waiver shall be made on a case-by-case basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad73fb3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7038/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term; Reappointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief of Army Reserve is appointed for a period of four years, but may be removed for cause at any time. An officer serving as Chief of Army Reserve may be reappointed for one additional four-year period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad73fb4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7038/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Budget","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief of Army Reserve is the official within the executive part of the Department of the Army who, subject to the authority, direction, and control of the Secretary of the Army and the Chief of Staff, is responsible for justification and execution of the personnel, operation and maintenance, and construction budgets for the Army Reserve. As such, the Chief of Army Reserve is the director and functional manager of appropriations made for the Army Reserve in those areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad73fb5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7038/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Full Time Support Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief of Army Reserve manages, with respect to the Army Reserve, the personnel program of the Department of Defense known as the Full Time Support Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad73fb6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7038/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief of Army Reserve shall submit to the Secretary of Defense, through the Secretary of the Army, an annual report on the state of the Army Reserve and the ability of the Army Reserve to meet its missions. The report shall be prepared in conjunction with the Chief of Staff of the Army and may be submitted in classified and unclassified versions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad73fb7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/168/s2/16"},"text":"Pub. L. 90–168, § 2(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-01"},"text":"Dec. 1, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/523"},"text":"81 Stat. 523","children":[],"tail":", § 3019; renumbered § 3038 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV"},"text":"Pub. L. 99–433, title V","children":[],"tail":", §§ 501(a)(4), 502(g)(1), "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1034"},"text":"100 Stat. 1034","children":[],"tail":", 1042; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1672/c/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1672(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3015"},"text":"108 Stat. 3015","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXII/s1212/a"},"text":"Pub. L. 104–201, div. A, title XII, § 1212(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2691"},"text":"110 Stat. 2691","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s554/b"},"text":"Pub. L. 106–65, div. A, title V, § 554(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/617"},"text":"113 Stat. 617","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 507(a)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–102; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tV/s501/a"},"text":"Pub. L. 107–314, div. A, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2529"},"text":"116 Stat. 2529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s536/a"},"text":"Pub. L. 108–375, div. A, title V, § 536(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1901"},"text":"118 Stat. 1901","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tV/s502/m"},"text":"Pub. L. 114–328, div. A, title V, § 502(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2103"},"text":"130 Stat. 2103","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1051/a/28"},"text":"Pub. L. 115–91, div. A, title X, § 1051(a)(28)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1562"},"text":"131 Stat. 1562","children":[],"tail":"; renumbered § 7038, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1838"},"text":"132 Stat. 1838","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaad73fb8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaad73fb9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaad73fba-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 7041 to 7046 were renumbered sections 8541 to 8546 of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 7047 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8547"},"text":"section 8547 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 7047 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8548"},"text":"section 8548 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 7048 to 7050 were renumbered sections 8548 to 8550 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaad73fbb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3038"},"text":"section 3038 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" struck out par. (1) designation before “The Chief of Army Reserve” and struck out par. (2) which read as follows: “The Secretary of Defense shall transmit the annual report of the Chief of Army Reserve under paragraph (1) to Congress, together with such comments on the report as the Secretary considers appropriate. The report shall be transmitted at the same time each year that the annual report of the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s113"},"text":"section 113 of this title","children":[],"tail":" is submitted to Congress.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" struck out “; Grade” after “Reappointment” in heading, and in text struck out par. (1) designation before “The Chief of Army Reserve” and struck out par. (2) which read as follows: “The Chief of Army Reserve, while so serving, holds the grade of lieutenant general.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2006-12-31"},"text":"December 31, 2006","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2004-12-31"},"text":"December 31, 2004","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2004-12-31"},"text":"December 31, 2004","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2003-10-01"},"text":"October 1, 2003","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “The President, by and with the advice and consent of the Senate, shall appoint the Chief of Army Reserve from officers of the Army Reserve not on active duty, or on active duty under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10211"},"text":"section 10211 of this title","children":[],"tail":", who—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) have had at least 10 years of commissioned service in the Army Reserve;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) are in grade of brigadier general and above; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) have been recommended by the Secretary of the Army.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “The Chief of Army Reserve holds office for four years but may be removed for cause at any time. He is eligible to succeed himself. If he holds a lower reserve grade, he shall be appointed in the grade of major general for service in the Army Reserve. However, if selected in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12505"},"text":"section 12505 of this title","children":[],"tail":", he may be appointed in the grade of lieutenant general.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" inserted at end “However, if selected in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12505"},"text":"section 12505 of this title","children":[],"tail":", he may be appointed in the grade of lieutenant general.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" added subsecs. (d) to (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" substituted “10211” for “265”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/s501/a/4"},"text":"Pub. L. 99–433, § 501(a)(4)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3019"},"text":"section 3019 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/s502/g/1"},"text":"Pub. L. 99–433, § 502(g)(1)","children":[],"tail":", substituted “service” for “services”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaad73fbc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaad73fbd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaad73fbe-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment; Applicability to Incumbents","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s554/g"},"text":"Pub. L. 106–65, div. A, title V, § 554(g)","children":[],"tail":", (h), "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/617"},"text":"113 Stat. 617","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/65/dA/tV/s554/g"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12505"},"text":"section 12505 of this title","children":[],"tail":" and amending this section and sections 5143, 5144, 8038, and 10506 of this title] shall take effect 60 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"“(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability to Incumbents","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an officer who is a covered position incumbent is appointed under the amendments made by this section to the grade of lieutenant general or vice admiral, the term of service of that officer in that covered position shall not be extended by reason of such appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘covered position incumbent’ means a reserve component officer who on the effective date specified in subsection (g) is serving in a covered position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘covered position’ means a position specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12505"},"text":"section 12505 of title 10","children":[],"tail":", United States Code, as added by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaad73fbf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691"},"text":"section 1691 of Pub. L. 103–337","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tai