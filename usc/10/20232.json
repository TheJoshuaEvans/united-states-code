{"tag":"section","attrib":{"id":"idabca7928-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20232"},"text":null,"children":[{"tag":"num","attrib":{"value":"20232"},"text":"§ 20232.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to allow officers to opt out of selection board consideration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabca7929-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20232/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Air Force may provide that an officer on the Space Force officer list may, upon the officer’s request and with the approval of the Secretary, be excluded from consideration by a selection board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20211"},"text":"section 20211 of this title","children":[],"tail":" to consider officers for promotion to the next higher grade."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabca792a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20232/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may only approve a request under subsection (a) as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabca792b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20232/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Completion of certain assignments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabca792c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20232/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis for the request is to allow an officer to complete a broadening assignment, an advanced education assignment, another assignment of significant value to the Department, or a career progression requirement delayed by such an assignment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabca792d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20232/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines the exclusion from consideration is in the best interest of the Space Force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabca792e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20232/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer has not previously failed of selection for promotion to the grade for which the officer requests the exclusion from consideration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabca792f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20232/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Completion of certain education","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabca7930-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20232/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis for the request is to allow an officer to complete advanced education or professional military education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabca7931-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20232/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that it is in the best interests of the Space Force for the officer to continue to serve in current position and grade; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabca7932-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20232/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer has not previously opted out of a promotion board under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabca7933-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20232/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service in critical skill position","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabca7934-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20232/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer is serving in a critical skill position that cannot be filled by another Space Force officer serving in the same grade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabca7935-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20232/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that it is in the best interests of the Space Force for the officer to continue to serve in their current position and grade; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabca7936-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20232/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer has not previously opted out of a promotion board under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabca7937-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1716/c"},"text":"Pub. L. 118–31, div. A, title XVII, § 1716(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/641"},"text":"137 Stat. 641","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
