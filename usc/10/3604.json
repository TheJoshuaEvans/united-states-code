{"tag":"section","attrib":{"id":"idaa2b96d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604"},"text":null,"children":[{"tag":"num","attrib":{"value":"3604"},"text":"§ 3604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program to accelerate the procurement and fielding of innovative technologies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa2b96da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to availability of appropriations, the Secretary of Defense shall establish a competitive, merit-based program to accelerate the procurement and fielding of innovative technologies by, with respect to such technologies—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa2b96db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing acquisition or life-cycle costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa2b96dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addressing technical risks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa2b96dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the timeliness and thoroughness of test and evaluation outcomes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa2b96de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rapidly implementing such technologies to directly support defense missions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa2b96df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidelines.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa2b96e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall issue guidelines for the operation of the program established under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa2b96e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At a minimum, the guidelines for the operation of the program established under this section required under paragraph (1) shall provide for the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa2b96e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The issuance of one or more solicitations for proposals by the Department of Defense in support of the program, with a priority established for technologies developed by small business concerns (as defined under section 3 of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"15 U.S.C. 632","children":[],"tail":")) or nontraditional defense contractors (as defined under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3014"},"text":"section 3014 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa2b96e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The issuance of not more than two solicitations for proposals by the Department of Defense in support of the program each fiscal year for innovative technologies from entities that, during the one-year period preceding the issuance of the solicitation, have not performed on contracts and subcontracts for the Department under which the aggregate obligations of the Department to such entity for such period exceeds $400,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa2b96e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A process for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa2b96e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the review of proposals received in response to a solicitation issued under subparagraph (A) by the Secretary of Defense and by each Secretary of a military department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa2b96e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the merit-based selection of the most promising cost-effective proposals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa2b96e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procurement of goods or services offered by such a proposal through contracts, cooperative agreements, other transaction authority, or by another appropriate process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa2b96e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The total amount of funding provided for any proposal selected for an award under the program established under this section shall be greater than or equal to $10,000,000 and shall not exceed $50,000,000, unless the Secretary (or designee of the Secretary) approves a greater amount of funding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa2b96e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Data Collection.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa2b96ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan required before implementation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may not provide funding under this section until the date on which the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa2b96eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completes a plan for carrying out the data collection required under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa2b96ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits the plan to the congressional defense committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa2b96ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Data collection required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall collect and analyze data on the program established under this section for the purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa2b96ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and sharing best practices for achieving the objectives of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa2b96ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing information on the implementation of the program and related policy issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa2b96f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reporting to the congressional defense committees as required under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa2b96f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Biannual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than March 1 and September 1 of each year beginning after the date of the enactment of this section, the Secretary of Defense shall submit to the congressional defense committees a report on the program established under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa2b96f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3604/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall notify the congressional defense committees within 30 days after funding has been provided for a proposal selected for an award under the program established under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa2b96f3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVIII/s861/a"},"text":"Pub. L. 118–159, div. A, title VIII, § 861(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1999"},"text":"138 Stat. 1999","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVIII/s813"},"text":"Pub. L. 119–60, div. A, title VIII, § 813","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/952"},"text":"139 Stat. 952","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa2b96f4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa2b96f5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaa2b96f6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (e), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa2b96f7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVIII/s834"},"text":"Pub. L. 117–81, div. A, title VIII, § 834","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1835"},"text":"135 Stat. 1835","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVIII/s845"},"text":"Pub. L. 117–263, div. A, title VIII, § 845","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2720"},"text":"136 Stat. 2720","children":[],"tail":", which was set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4061"},"text":"section 4061 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVIII/s861/b"},"text":"Pub. L. 118–159, div. A, title VIII, § 861(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2000"},"text":"138 Stat. 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa2b96f8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" struck out “Maximum” before “Amount” in heading and inserted “shall be greater than or equal to $10,000,000 and” before “shall not exceed”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
