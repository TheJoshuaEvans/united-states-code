{"tag":"section","attrib":{"id":"idaba20a2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12406"},"text":null,"children":[{"tag":"num","attrib":{"value":"12406"},"text":"§ 12406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Guard in Federal service: call","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Whenever—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba20a2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12406/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States, or any of the Commonwealths or possessions, is invaded or is in danger of invasion by a foreign nation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba20a2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12406/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a rebellion or danger of a rebellion against the authority of the Government of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba20a2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12406/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President is unable with the regular forces to execute the laws of the United States;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the President may call into Federal service members and units of the National Guard of any State in such numbers as he considers necessary to repel the invasion, suppress the rebellion, or execute those laws. Orders for these purposes shall be issued through the governors of the States or, in the case of the District of Columbia, through the commanding general of the National Guard of the District of Columbia.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaba20a2f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1662/f/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1662(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2994"},"text":"108 Stat. 2994","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1057/a/5"},"text":"Pub. L. 109–163, div. A, title X, § 1057(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3440"},"text":"119 Stat. 3440","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaba20a30-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaba20a31-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaba20a32-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 3500 and 8500 of this title, prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1662/f/2"},"text":"Pub. L. 103–337, § 1662(f)(2)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaba45323-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","c