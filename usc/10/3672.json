sfer of par. (2) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2401/c"},"text":"section 2401(c) of this title","children":[],"tail":" to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3673"},"text":"section 3673 of this title","children":[],"tail":", redesignated remainder of subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2401"},"text":"section 2401 of this title","children":[],"tail":" as subsec. (a) of this section, inserted heading, struck out par. (1) designation before “Funds may not”, and redesignated subpars. (A) and (B) of such former par. (1) as pars. (1) and (2), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1825/e"},"text":"Pub. L. 116–283, § 1825(e)","children":[],"tail":", redesignated subsec. (e) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2401"},"text":"section 2401 of this title","children":[],"tail":" as subsec. (b) of this section, inserted heading, and substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3676"},"text":"section 3676 of this title","children":[],"tail":"” for “subsection (g)” in par. (2) and “this chapter” for “this section” in introductory provisions of par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa2e074b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa2e074c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as an Effective Date of 2021 Amendment note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
