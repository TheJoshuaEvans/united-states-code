{"tag":"section","attrib":{"id":"idaafd65ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7722"},"text":null,"children":[{"tag":"num","attrib":{"value":"7722"},"text":"§ 7722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interment and inurnment policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaafd65ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7722/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility Determinations Generally","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaafd65f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7722/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army, with the approval of the Secretary of Defense, shall determine eligibility for interment or inurnment in the Cemeteries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaafd65f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7722/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army, with the approval of the Secretary of Defense, shall establish policy and procedures for reviewing and determining requests for exceptions to interment and inurnment eligibility policy, which shall include a requirement, before granting the request for an exception, for notification of the Committees on Armed Services and the Committees on Veterans Affairs of the Senate and the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafd65f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7722/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Removal of Remains","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under such regulations as the Secretary of the Army may prescribe under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7721/d"},"text":"section 7721(d) of this title","children":[],"tail":", the Secretary of the Army may authorize the removal of the remains of a person described in subsection (c) from one of the Cemeteries for re-interment or re-inurnment if, upon the death of the primary person eligible for interment or inurnment in the Cemeteries, the deceased primary eligible person will not be buried in the same or an adjoining grave."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafd65f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7722/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Persons","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (d), the persons whose remains may be removed pursuant to subsection (b) are the deceased spouse, a minor child, and, in the discretion of the Secretary of the Army, an unmarried adult child of a member eligible for interment or inurnment in the Cemeteries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafd65f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7722/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The remains of a person described in subsection (c) may not be removed from one of the Cemeteries under subsection (b) if the primary person eligible for burial in the Cemeteries is a person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaafd65f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7722/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is missing in action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaafd65f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7722/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose remains have not been recovered or identified;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaafd65f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7722/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose remains were buried at sea, whether by the choice of the person or otherwise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaafd65f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7722/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose remains were donated to science; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaafd65f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7722/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose remains were cremated and whose ashes were scattered without interment of any portion of the ashes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaafd65fa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s591/a/1"},"text":"Pub. L. 112–81, div. A, title V, § 591(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1439"},"text":"125 Stat. 1439","children":[],"tail":", § 4722; renumbered § 7722 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 808(d), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":", 1840.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaafd65fb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaafd65fc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaafd65fd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7722 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8892"},"text":"section 8892 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaafd65fe-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s808/d"},"text":"Pub. L. 115–232, § 808(d)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4722"},"text":"section 4722 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 7721(d)” for “section 4721(d)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaafd65ff-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaafd6600-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
