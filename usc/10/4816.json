{"tag":"section","attrib":{"id":"idaa96db9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4816"},"text":null,"children":[{"tag":"num","attrib":{"value":"4816"},"text":"§ 4816.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National technology and industrial base: periodic defense capability assessments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa96db9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4816/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Periodic Assessment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each fiscal year, the Secretary of Defense shall prepare selected assessments of the capability of the national technology and industrial base to attain the national security objectives set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4811/a"},"text":"section 4811(a) of this title","children":[],"tail":". The Secretary of Defense shall prepare such assessments in consultation with the Secretary of Commerce and the Secretary of Energy."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa96db9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4816/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment Process","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall ensure that technology and industrial capability assessments—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa96db9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4816/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe sectors or capabilities, their underlying infrastructure and processes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa96db9e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4816/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze present and projected financial performance of industries supporting the sectors or capabilities in the assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa96db9f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4816/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the extent to which the requirements associated with defense acquisition programs can be satisfied by the present and projected performance capacities of industries supporting the sectors or capabilities in the assessment, evaluate the reasons for any variance from applicable preceding determinations, and identify the extent to which those industries are comprised of only one potential source in the national technology and industrial base or have multiple potential sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa96dba0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4816/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the extent to which the requirements associated with defense acquisition programs can be satisfied by the present and projected performance capacities of industries that do not actively support Department of Defense acquisition programs and identify the barriers to the participation of those industries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa96dba1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4816/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify technological and industrial capabilities and processes for which there is potential for the national industrial and technology base not to be able to support the achievement of national security objectives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa96dba2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4816/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the effects of the termination of major defense acquisition programs (as the term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4201"},"text":"section 4201 of this title","children":[],"tail":") in the previous fiscal year on the sectors and capabilities in the assessment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa96dba3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4816/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment of Extent of Dependency on Foreign Source Items","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each assessment under subsection (a) shall include a separate discussion and presentation regarding the extent to which the national technology and industrial base is dependent on items for which the source of supply, manufacture, or technology is outside of the United States and Canada and for which there is no immediately available source in the United States or Canada. The discussion and presentation regarding foreign dependency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa96dba4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4816/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify cases that pose an unacceptable risk of foreign dependency, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa96dba5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4816/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present actions being taken or proposed to be taken to remedy the risk posed by the cases identified under paragraph (1), including efforts to develop a domestic source for the item in question.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa96dba6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4816/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment of Extent of Effects of Foreign Boycotts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each assessment under subsection (a) shall include an examination of the extent to which the national technology and industrial base is affected by foreign boycotts. If it is determined that a foreign boycott (other than a boycott addressed in a previous assessment) is subjecting the national technology and industrial base to significant harm, the assessment shall include a separate discussion and presentation regarding that foreign boycott that shall, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa96dba7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4816/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the sectors that are subject to such harm;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa96dba8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4816/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the harm resulting from such boycott; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa96dba9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4816/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify actions necessary to minimize the effects of such boycott on the national technology and industrial base.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa96dbaa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4816/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Integrated Process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall ensure that consideration of the technology and industrial base assessments is integrated into the overall budget, acquisition, and logistics support decision processes of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa96dbab-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dD/tXLII/s4215"},"text":"Pub. L. 102–484, div. D, title XLII, § 4215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2667"},"text":"106 Stat. 2667","children":[],"tail":", § 2505; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/35/tII/s201/g/7"},"text":"Pub. L. 103–35, title II, § 201(g)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-05-31"},"text":"May 31, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/100"},"text":"107 Stat. 100","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tVIII/s829/c/1"},"text":"Pub. L. 104–201, div. A, title VIII, § 829(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2612"},"text":"110 Stat. 2612","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/23/tIII/s303/b"},"text":"Pub. L. 111–23, title III, § 303(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1731"},"text":"123 Stat. 1731","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVIII/s895/c"},"text":"Pub. L. 111–383, div. A, title VIII, § 895(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4314"},"text":"124 Stat. 4314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXVI/s1602"},"text":"Pub. L. 112–239, div. A, title XVI, § 1602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2062"},"text":"126 Stat. 2062","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVIII/s876"},"text":"Pub. L. 114–92, div. A, title VIII, § 876","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/941"},"text":"129 Stat. 941","children":[],"tail":"; renumbered § 4816 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII"},"text":"Pub. L. 116–283, div. A, title XVIII","children":[],"tail":", §§ 1867(b), (d)(4), 1883(b)(2), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4281"},"text":"134 Stat. 4281","children":[],"tail":", 4282, 4294; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVII/s1701/a/41"},"text":"Pub. L. 118–159, div. A, title XVII, § 1701(a)(41)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2206"},"text":"138 Stat. 2206","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVII/s1701/a/30"},"text":"Pub. L. 119–60, div. A, title XVII, § 1701(a)(30)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1209"},"text":"139 Stat. 1209","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa96dbac-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa96dbad-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa96dbae-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" inserted closing parenthesis after “this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":", which directed substitution of “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4201"},"text":"section 4201 of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2430"},"text":"section 2430 of this title","children":[],"tail":") or major automated information systems (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2445a"},"text":"section 2445a of this title","children":[],"tail":")”, was executed by making the substitution for “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2430"},"text":"section 2430 of this title","children":[],"tail":") or major automated information system programs (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2445a"},"text":"section 2445a of this title","children":[],"tail":")” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1867/b"},"text":"Pub. L. 116–283, § 1867(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2505"},"text":"section 2505 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1867/d/4"},"text":"Pub. L. 116–283, § 1867(d)(4)","children":[],"tail":", substituted “section 4811(a)” for “section 2501(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1883/b/2"},"text":"Pub. L. 116–283, § 1883(b)(2)","children":[],"tail":", which directed that each reference in the text of title 10 to a section that was redesignated by title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", as such section was in effect before the redesignation, be amended by striking such reference and inserting a reference to the appropriate redesignated section, was not executed with respect to “section 2430”, which was redesignated as multiple sections."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(3) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" added pars. (3) and (4) and redesignated former pars. (3) and (4) as (5) and (6), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" inserted “or major automated information system programs (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2445a"},"text":"section 2445a of this title","children":[],"tail":")” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2430"},"text":"section 2430 of this title","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/23"},"text":"Pub. L. 111–23","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" reenacted section catchline without change and amended text generally. Prior to amendment, text consisted of subsecs. (a) to (d) providing for National Defense Technology and Industrial Base Council to prepare, at least annually through fiscal year 1997 and biennially thereafter, a comprehensive assessment of capability of the national technology and industrial base to attain national security objectives."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/35"},"text":"Pub. L. 103–35","children":[],"tail":" substituted “capability” for “capabilty” in section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa96dbaf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa96dbb0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa96dbb1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pilot Program on Strengthening the Defense Industrial and Innovation Base","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tXVII/s1711"},"text":"Pub. L. 115–91, div. A, title XVII, § 1711","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1811"},"text":"131 Stat. 1811","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tII/s213/c"},"text":"Pub. L. 116–283, div. A, title II, § 213(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3457"},"text":"134 Stat. 3457","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dA/tII/s213/c"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pilot Program Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall carry out a pilot program to assess the feasibility and advisability of increasing the capability of the defense industrial base and the defense innovation base to support—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development, prototyping, and manufacturing production needs to meet military requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development, prototyping, and manufacturing of emerging defense and commercial technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out the pilot program under the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" [Former] Chapters 137 and 139 and sections 2371, 2371b, and 2373 of title 10, United States Code [now ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4021"},"text":"10 U.S.C. 4021","children":[],"tail":", 4022, 4023]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" [Former] Section 230 of the John S. McCain National Defense Authorization Act for Fiscal Year 2019 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Public Law 115–232","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2358"},"text":"10 U.S.C. 2358","children":[],"tail":" note [now "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4061"},"text":"10 U.S.C. 4061","children":[],"tail":" note prec.])."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other legal authorities as the Secretary considers applicable to carrying out the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities under the pilot program may include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Use of contracts, grants, or other transaction authorities to support development, prototyping, and manufacturing capabilities in small- and medium-sized manufacturers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Purchases of goods or equipment for testing and certification purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Incentives, including purchase commitments and cost sharing with nongovernmental sources, for the private sector to develop capabilities in areas of national security interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Issuing loans or providing loan guarantees to small- and medium-sized companies to support manufacturing and production capabilities in areas of national security interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Giving awards to third party entities to support investments in small- and medium-sized companies working in areas of national security interest, including debt and equity investments that would benefit missions of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other activities as the Secretary determines necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The pilot program shall terminate on ","children":[{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefing Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No later than ","children":[{"tag":"date","attrib":{"date":"2027-01-31"},"text":"January 31, 2027","children":[],"tail":", the Secretary of Defense shall provide a briefing to the Committees on Armed Services in the Senate and the House of Representatives on the results of the pilot program.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
