{"tag":"section","attrib":{"id":"idaba6c46b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12645"},"text":null,"children":[{"tag":"num","attrib":{"value":"12645"},"text":"§ 12645.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioned officers: retention until completion of required service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaba6c46c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12645/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b), a reserve commissioned officer who has not completed the period of service required of him by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s651"},"text":"section 651 of this title","children":[],"tail":" or any other provision of law may not be discharged or transferred from an active status under chapter 843, 1407, 1409, or 1411 of this title or chapter 21 "},{"tag":"ref","attrib":{"idref":"fn002175"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002175"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 14. Unless, under regulations prescribed by the Secretary concerned, he is promoted to a higher reserve grade, he shall be retained in an active status in his reserve grade for the rest of his period of required service and shall be an additional number to the authorized strength of his grade."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba6c46d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12645/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a) does not prevent the discharge or transfer from an active status of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba6c46e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12645/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commissioned warrant officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba6c46f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12645/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer on the active-duty list or a reserve active-status list who is found not qualified for promotion to the grade of first lieutenant, in the case of an officer of the Army, Air Force, or Marine Corps, or lieutenant (junior grade), in the case of an officer of the Navy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba6c470-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12645/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer on the active-duty list or reserve active-status list who has failed of selection for promotion for the second time to the grade of captain, in the case of an officer of the Army, Air Force, or Marine Corps, or to the grade of lieutenant, in the case of an officer of the Navy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba6c471-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12645/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer whose discharge or transfer from an active status is required by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaba6c472-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/