ildren":[],"tail":", (ii), (v), inserted par. (1) designation before “The Secretary”, redesignated former pars. (1) and (2) as subpars. (A) and (B), respectively, of par. (1), and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1719A/b/4/B/iii"},"text":"Pub. L. 118–31, § 1719A(b)(4)(B)(iii)","children":[],"tail":", struck out “, or for commissioned officers of the Space Force other than of the Regular Space Force” after “Regular Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1719A/b/4/B/iv"},"text":"Pub. L. 118–31, § 1719A(b)(4)(B)(iv)","children":[],"tail":", struck out “or the Space Force” after “Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1719A/b/4/C"},"text":"Pub. L. 118–31, § 1719A(b)(4)(C)","children":[],"tail":", substituted “and a separate retired list containing the name of each retired warrant officer of the Space Force” for “or the Space Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1719A/b/4/D"},"text":"Pub. L. 118–31, § 1719A(b)(4)(D)","children":[],"tail":", substituted “and a separate retired list containing the name of each retired enlisted member of the Space Force” for “or the Regular Space Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/c/21/C/i"},"text":"Pub. L. 116–283, § 923(c)(21)(C)(i)","children":[],"tail":", inserted “or the Regular Space Force” after “Regular Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/c/21/C/ii"},"text":"Pub. L. 116–283, § 923(c)(21)(C)(ii)","children":[],"tail":", inserted “, or for commissioned officers of the Space Force other than of the Regular Space Force” after “Regular Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/c/21/C/iii"},"text":"Pub. L. 116–283, § 923(c)(21)(C)(iii)","children":[],"tail":", inserted “or the Space Force” after “Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/c/21/C/iii"},"text":"Pub. L. 116–283, § 923(c)(21)(C)(iii)","children":[],"tail":", inserted “or the Space Force” after “Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/c/21/C/i"},"text":"Pub. L. 116–283, § 923(c)(21)(C)(i)","children":[],"tail":", inserted “or the Regular Space Force” after “Regular Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8966"},"text":"section 8966 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180"},"text":"Pub. L. 100–180","children":[],"tail":" struck out “Regular” before “Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":" struck out provisions in subsecs. (a) and (b) which required annual publication in official Air Force Register of the retired list."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab6d8c5a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries"