{"tag":"section","attrib":{"id":"idab6d8c46-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9346"},"text":null,"children":[{"tag":"num","attrib":{"value":"9346"},"text":"§ 9346.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retired lists","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab6d8c47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9346/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Air Force shall maintain a retired list containing the name of each retired commissioned officer of the Regular Air Force and a separate retired list containing the name of each retired commissioned officer of the Space Force (other than an officer whose name is on the list maintained under subsection (b)(2)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab6d8c48-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9346/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab6d8c49-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9346/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall maintain a retired list containing the name of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab6d8c4a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9346/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each person entitled to retired pay under any law providing retired pay for commissioned officers of the Air Force, other than of the Regular Air Force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab6d8c4b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9346/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each retired warrant officer or enlisted member of the Air Force who is advanced to a commissioned grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab6d8c4c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9346/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall maintain a retired list containing the name of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab6d8c4d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9346/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each person entitled to retired pay who as a member of the Space Force qualified for retirement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20601"},"text":"section 20601 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab6d8c4e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9346/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each retired warrant officer or enlisted member of the Space Force who is advanced to a commissioned grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab6d8c4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9346/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall maintain a retired list containing the name of each retired warrant officer of the Air Force and a separate retired list containing the name of each retired warrant officer of the Space Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab6d8c50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9346/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall maintain a retired list containing the name of each retired enlisted member of the Regular Air Force and a separate retired list containing the name of each retired enlisted member of the Space Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab6d8c51-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/556"},"text":"70A Stat. 556","children":[],"tail":", § 8966; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/199"},"text":"Pub. L. 85–861, § 1(199)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1541"},"text":"72 Stat. 1541","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tV/s512/d/3"},"text":"Pub. L. 100–180, div. A, title V, § 512(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1090"},"text":"101 Stat. 1090","children":[],"tail":"; renumbered § 9346, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/b/14"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(b)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1833"},"text":"132 Stat. 1833","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s923/c/21/C"},"text":"Pub. L. 116–283, div. A, title IX, § 923(c)(21)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3812"},"text":"134 Stat. 3812","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1719A/b/4"},"text":"Pub. L. 118–31, div. A, title XVII, § 1719A(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/664"},"text":"137 Stat. 664","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab6d8c52-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab6d8c53-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab6d8c54-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1956 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8966(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8966(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8966(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1001.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1036.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1948-06-29/ch708"},"text":"June 29, 1948, ch. 708","children":[],"tail":", §§ 201, 301(a), "},{"tag":"html:a","attrib":{"href":"/us/stat/62/1084"},"text":"62 Stat. 1084","children":[],"tail":", 1087."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8966(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a), (b), and (d), the word “maintain” is substituted for the word “establish”, and in subsection (c) the word “maintain” is substituted for the word “established”, since the lists have been established and are published annually.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Effective upon ","children":[{"tag":"date","attrib":{"date":"1948-06-29"},"text":"June 29, 1948","children":[],"tail":"” are omitted as executed. 10:1001 (last 12 words of 1st sentence, and last sentence) is omitted as no longer required, since, upon enactment of this title, laws referring to the limited or unlimited retired list will be expressly repealed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “shall” is substituted for the word “may”, since 10:1036 further requires that such a list be published annually in the Register. The requirement as to publication necessarily implies that the list must be maintained.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b)(1) is substituted for the words “all commissioned officers and former commissioned officers * * * or the Air Force of the United States, as the case may be * * * or the Regular Air Force, heretofore or hereafter granted retirement pay under sections 456, 456a, and 1036a of this title, or any law hereafter enacted to provide retirement pay for commissioned officers * * * or the Regular Air Force”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “who is advanced to a commissioned grade” are substituted for the words “heretofore or hereafter retired under any provision of law who, by reason of service in temporary commissioned grades * * * or the Air Force of the United States, or in any of the respective components thereof, are entitled to be retired with commissioned rank or grade”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsections (c) and (d) are inserted, since sections 8964 and 8965 of this title refer to service on the retired list as a warrant officer or enlisted member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab6d8c55-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab6d8c56-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1958 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},