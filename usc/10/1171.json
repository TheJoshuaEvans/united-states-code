{"tag":"section","attrib":{"id":"ida8a96397-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1171"},"text":null,"children":[{"tag":"num","attrib":{"value":"1171"},"text":"§ 1171.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regular enlisted members: early discharge","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary concerned and approved by the President, any regular enlisted member of an armed force may be discharged within one year before the expiration of the term of his enlistment or extended enlistment. A discharge under this section does not affect any right, privilege, or benefit that a member would have had if he completed his enlistment or extended enlistment, except that the member is not entitled to pay and allowances for the period not served.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida8a96398-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/235/s3/a/1/A"},"text":"Pub. L. 90–235, § 3(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/757"},"text":"81 Stat. 757","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s525"},"text":"Pub. L. 112–81, div. A, title V, § 525","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1401"},"text":"125 Stat. 1401","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8a96399-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8a9639a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8a9639b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" substituted “within one year” for “within three months”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"ida8a9639c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"ida8a9639d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 11498. Delegation of Authority to Secretary of Defense","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 11498, ","children":[{"tag":"date","attrib":{"date":"1969-12-01"},"text":"Dec. 1, 1969","children":[],"tail":", 34 F.R. 19125, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By virtue of the authority vested in me by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":" of the United States Code, and as President of the United States, it is ordered that the Secretary of Defense is hereby designated and empowered to approve regulations issued by the Secretaries concerned under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1171"},"text":"section 1171 of title 10","children":[],"tail":", United States Code, effective "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"January 2, 1968","children":[],"tail":", which relate to the early discharge of regular enlisted members of the armed forces."}],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Richard Nixon.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
