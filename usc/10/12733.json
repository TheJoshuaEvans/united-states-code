{"tag":"section","attrib":{"id":"idabab7f77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12733"},"text":null,"children":[{"tag":"num","attrib":{"value":"12733"},"text":"§ 12733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of retired pay: computation of years of service","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of computing the retired pay of a person under this chapter, the person’s years of service and any fraction of such a year are computed by dividing 360 into the sum of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabab7f78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12733/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The person’s days of active service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabab7f79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12733/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The person’s days of full-time service under sections 316, 502, 503, 504, and 505 of title 32 while performing annual training duty or while attending a prescribed course of instruction at a school designated as a service school by law or by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabab7f7a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12733/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" One day for each point credited to the person under clause (B), (C), (D), or (F) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12732/a/2"},"text":"section 12732(a)(2) of this title","children":[],"tail":", but not more than—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabab7f7b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12733/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 60 days in any one year of service before the year of service that includes ","children":[{"tag":"date","attrib":{"date":"1996-09-23"},"text":"September 23, 1996","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabab7f7c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12733/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 75 days in the year of service that includes ","children":[{"tag":"date","attrib":{"date":"1996-09-23"},"text":"September 23, 1996","children":[],"tail":", and in any subsequent year of service before the year of service that includes "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"October 30, 2000","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabab7f7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12733/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 days in the year of service that includes ","children":[{"tag":"date","attrib":{"date":"2000-10-30"},"text":"October 30, 2000","children":[],"tail":", and in any subsequent year of service before the year of service that includes "},{"tag":"date","attrib":{"date":"2007-10-30"},"text":"October 30, 2007","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabab7f7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12733/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 130 days in the year of service that includes ","children":[{"tag":"date","attrib":{"date":"2007-10-30"},"text":"October 30, 2007","children":[],"tail":", and in any subsequent year of service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabab7f7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12733/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One day for each point credited to the person under subparagraph (E) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12732/a/2"},"text":"section 12732(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabab7f80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12733/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One day for each point credited to the person under subparagraph (F) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12732/a/2"},"text":"section 12732(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabab7f81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12733/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 days for each year before ","children":[{"tag":"date","attrib":{"date":"1949-07-01"},"text":"July 1, 1949","children":[],"tail":", and proportionately for each fraction of a year, of service (other than active service) in a reserve component of an armed force, in the Army or the Air Force without component, or in any other category covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12732/a/1"},"text":"section 12732(a)(1) of this title","children":[],"tail":", except a regular component."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id"