e to determination of retired pay).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1036e(d) (as applicable to determination of retired pay).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"34:440j (less 1st 91 words, and less 1st proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1948-06-29/ch708"},"text":"June 29, 1948, ch. 708","children":[],"tail":", §§ 303 (less 1st 91 words, and less 1st proviso), 306 ((c) and (d), as applicable to determination of retired pay), "},{"tag":"html:a","attrib":{"href":"/us/stat/62/1088-1090"},"text":"62 Stat. 1088–1090","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1949-09-07/ch547/s3"},"text":"Sept. 7, 1949, ch. 547, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/693"},"text":"63 Stat. 693","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"34:440m(c) (as applicable to determination of retired pay).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"34:440m(d) (as applicable to determination of retired pay).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The revised section consolidates provisions of 10:1036b and 1036e, and 34:440j and 440m, relating to the years of service that may be counted in determining retired pay for persons entitled to that pay under this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clause (1) is substituted for 10:1036b(i). In clause (3), the words “and proportionately for each fraction of a year” are inserted to make clear that parts of years must be counted. 10:1036e(d) and 34:440m(d) are omitted as covered by sections 101(22) and 101(24) of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idabab7f86-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1958 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"The change is necessary so that active service and service described in section 1332(a)(2)(A)(ii) that was performed on or before ","children":[{"tag":"date","attrib":{"date":"1949-07-01"},"text":"July 1, 1949","children":[],"tail":", may be counted in computing retired pay, as provided by the source law, section 303(i) of the Army and Air Force Vitalization and Retirement Equalization Act of 1948 ("},{"tag":"ref","attrib":{"href":"/us/stat/62/1088"},"text":"62 Stat. 1088","children":[],"tail":") and in accordance with the opinion of the Judge Advocate General of the Army (JAGA 1956/1908, "},{"tag":"date","attrib":{"date":"1956-02-13"},"text":"Feb. 13, 1956","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabab7f87-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabab7f88-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s516/b"},"text":"Pub. L. 116–283, § 516(b)","children":[],"tail":", substituted “(D), or (F)” for “or (D)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s602/b/5"},"text":"Pub. L. 116–283, § 602(b)(5)","children":[],"tail":", added par. (5) and redesignated former par. (5) as (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Par. (3)(B) to (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" struck out “and” at end of subpar. (B), substituted “before the year of service that includes "},{"tag":"date","attrib":{"date":"2007-10-30"},"text":"October 30, 2007","children":[],"tail":"; and” for period at end of subpar. (C), and added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Par. (3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1048/c/16/A"},"text":"Pub. L. 107–107, § 1048(c)(16)(A)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"October 30, 2000","children":[],"tail":"” for “the date of the enactment of the Floyd D. Spence National Defense Authorization Act for Fiscal Year 2001”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1048/c/16/B"},"text":"Pub. L. 107–107, § 1048(c)(16)(B)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"October 30, 2000","children":[],"tail":",” for “the date of the enactment of the Floyd D. Spence National Defense Authorization Act for Fiscal Year 2001”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Par. (3). ","children":[{"tag":"re