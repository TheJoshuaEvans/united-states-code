{"tag":"section","attrib":{"id":"ida984a8a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2488"},"text":null,"children":[{"tag":"num","attrib":{"value":"2488"},"text":"§ 2488.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Combined exchange and commissary stores","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida984a8a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2488/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may authorize a nonappropriated fund instrumentality to operate a military exchange and a commissary store as a combined exchange and commissary store on a military installation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida984a8a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2488/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida984a8a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2488/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than ten combined exchange and commissary stores may be operated pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida984a8a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2488/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may select a military installation for the operation of a combined exchange and commissary store under this section only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida984a8a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2488/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the installation is to be closed, or has been or is to be realigned, under a base closure law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida984a8a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2488/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a military exchange and a commissary store are operated at the installation by separate entities at the time of, or immediately before, such selection and it is not economically feasible to continue that separate operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida984a8a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2488/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation at Carswell Field","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Combined exchange and commissary stores operated under this section shall include the combined exchange and commissary store that is operated at the Naval Air Station Fort Worth, Joint Reserve Center, Carswell Field, Texas, under the authority provided in section 375 of the National Defense Authorization Act for Fiscal Year 1995 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Public Law 103–337","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/108/2736"},"text":"108 Stat. 2736","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida984a8a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2488/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adjustments and Surcharges","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Adjustments to, and surcharges on, the sales price of a grocery food item sold in a combined exchange and commissary store under this section shall be provided for in accordance with the same laws that govern such adjustments and surcharges for items sold in a commissary store of the Defense Commissary Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida984a8aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2488/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Appropriated Funds","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida984a8ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2488/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a nonappropriated fund instrumentality incurs a loss in operating a combined exchange and commissary store at a military installation under this section as a result of the requirement set forth in subsection (d), the Secretary may authorize a transfer of funds available for the Defense Commissary Agency to the nonappropriated fund instrumentality to offset the loss.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida984a8ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2488/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total amount of appropriated funds transferred during a fiscal year to support the operation of a combined exchange and commissary store at a military installation under this section may not exceed an amount that is equal to 25 percent of the amount of appropriated funds that was provided for the operation of the commissary store of the Defense Commissary Agency on that installation during the last full fiscal year of operation of that commissary store.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida984a8ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2488/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonappropriated Fund Instrumentality Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “nonappropriated fund instrumentality” means the Army and Air Force Exchange Service, Navy Exchange Service Command, Marine Corps exchanges, or any other instrumentality of the United States under the jurisdiction of the armed forces which is conducted for the comfort, pleasure, contentment, or physical or mental improvement of members of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida984a8ae-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tIII/s336/a/1"},"text":"Pub. L. 104–106, div. A, title III, § 336(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/263"},"text":"110 Stat. 263","children":[],"tail":", § 2490a; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1061/d"},"text":"Pub. L. 105–85, div. A, title X, § 1061(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1891"},"text":"111 Stat. 1891","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tX/s1043/c/2"},"text":"Pub. L. 108–136, div. A, title X, § 1043(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1611"},"text":"117 Stat. 1611","children":[],"tail":"; renumbered § 2488, "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVI/s651/b/3"},"text":"Pub. L. 108–375, div. A, title VI, § 651(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1971"},"text":"118 Stat. 1971","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/b/37"},"text":"Pub. L. 111–383, div. A, title X, § 1075(b)(37)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4371"},"text":"124 Stat. 4371","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida984a8af-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida984a8b0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida984a8b1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 375 of the National Defense Authorization Act for Fiscal Year 1995, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s375"},"text":"section 375 of Pub. L. 103–337","children":[],"tail":", div. A, title III, "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2736"},"text":"108 Stat. 2736","children":[],"tail":", as amended, which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida984a8b2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2488 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2495"},"text":"section 2495 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida984a8b3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" substituted “armed forces” for “Armed Forces” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2490a"},"text":"section 2490a of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1043/c/2"},"text":"Pub. L. 108–136, § 1043(c)(2)","children":[],"tail":", substituted “"},{"tag":"inline","attrib":{},"text":"Nonappropriated Fund Instrumentality Defined","children":[],"tail":".—In this section, the term” for “"},{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—In this section:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The term”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"and struck out par. (2) which read as follows: “The term ‘base closure law’ has the meaning given such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2667/h"},"text":"section 2667(h) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" substituted “section 2667(h)” for “section 2667(g)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
