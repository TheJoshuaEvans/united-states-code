{"tag":"section","attrib":{"id":"ida7b873a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s423"},"text":null,"children":[{"tag":"num","attrib":{"value":"423"},"text":"§ 423.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to use proceeds from counterintelligence operations of the military departments or the Defense Intelligence Agency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7b873a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s423/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may authorize, without regard to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":", use of proceeds from counterintelligence operations conducted by components of the military departments or the Defense Intelligence Agency to offset necessary and reasonable expenses, not otherwise prohibited by law, incurred in such operations, and to make exceptional performance awards to personnel involved in such operations, if use of appropriated funds to meet such expenses or to make such awards would not be practicable."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b873a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s423/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As soon as the net proceeds from such counterintelligence operations are no longer necessary for the conduct of those operations, such proceeds shall be deposited into the Treasury as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b873a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s423/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall establish policies and procedures to govern acquisition, use, management, and disposition of proceeds from counterintelligence operations conducted by components of the military departments or the Defense Intelligence Agency, including effective internal systems of accounting and administrative controls.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7b873a8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/569/tIV/s403/a"},"text":"Pub. L. 99–569, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3196"},"text":"100 Stat. 3196","children":[],"tail":", § 140b; renumbered § 423 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s9/a/3"},"text":"Pub. L. 100–26, § 9(a)(3)","children":[],"tail":", (b)(3), "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/287"},"text":"101 Stat. 287","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tIX/s921/a"},"text":"Pub. L. 111–84, div. A, title IX, § 921(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2432"},"text":"123 Stat. 2432","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7b873a9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7b873aa-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7b873ab-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" inserted “or the Defense Intelligence Agency” after “military departments” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/26"},"text":"Pub. L. 100–26","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s140b"},"text":"section 140b of this title","children":[],"tail":" as this section and struck out “United States Code,” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":",” in subsec. (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
