{"tag":"section","attrib":{"id":"idab8c867b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10173"},"text":null,"children":[{"tag":"num","attrib":{"value":"10173"},"text":"§ 10173.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marine Forces Reserve","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab8c867c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10173/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy, with the advice and assistance of the Commandant of the Marine Corps, shall establish in the Marine Corps a command known as the Marine Forces Reserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c867d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10173/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commander","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Marine Forces Reserve is commanded by the Commander, Marine Forces Reserve. The Commander, Marine Forces Reserve, reports directly to the Commandant of the Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c867e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10173/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assignment of Forces","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant of the Marine Corps—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8c867f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10173/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall assign to the Marine Forces Reserve the forces of the Marine Corps Reserve stationed in the continental United States other than forces assigned to the unified combatant command for special operations forces established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s167"},"text":"section 167 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c8680-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10173/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as otherwise directed by the Secretary of Defense in the case of forces assigned to carry out functions of the Secretary of the Navy specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8013"},"text":"section 8013 of this title","children":[],"tail":", shall assign to the combatant commands (through the Marine Corps component commander for each such command) all such forces assigned to the Marine Forces Reserve under paragraph (1) in the manner specified by the Secretary of Defense."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab8c8681-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXII/s1211/a/1"},"text":"Pub. L. 104–201, div. A, title XII, § 1211(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2690"},"text":"110 Stat. 2690","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s809/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 809(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1840"},"text":"132 Stat. 1840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab8c8682-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab8c8683-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab8c8684-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “section 8013” for “section 5013”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab8c8685-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab8c8686-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
