{"tag":"section","attrib":{"id":"idab49b0c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8746"},"text":null,"children":[{"tag":"num","attrib":{"value":"8746"},"text":"§ 8746.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of oaths by clerks and employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab49b0ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8746/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Chief clerks and inspectors attached to any office of inspector of naval material, chief clerks attached to the field service of the Department of the Navy, to naval shipyards and stations, and to Marine Corps posts and stations, and such other clerks and employees attached to those activities as the Secretary of the Navy designates, may administer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab49b0cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8746/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oaths required by law or regulation relating to claims against, or applications to, the United States of officers and of employees of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab49b0cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8746/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oaths of office to officers and employees of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab49b0cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8746/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There may be no compensation for the administration of oaths under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab49b0ce-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/463"},"text":"70A Stat. 463","children":[],"tail":", § 7476; renumbered § 8746, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/6"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab49b0cf-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab49b0d0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab49b0d1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":nu