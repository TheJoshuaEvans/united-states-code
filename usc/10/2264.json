{"tag":"section","attrib":{"id":"ida959c887-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2264"},"text":null,"children":[{"tag":"num","attrib":{"value":"2264"},"text":"§ 2264.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement for assistance provided to nongovernmental entertainment-oriented media producers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida959c888-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2264/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There shall be credited to the applicable appropriations account or fund from which the expenses described in subsection (b) were charged any amounts received by the Department of Defense as reimbursement for such expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida959c889-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2264/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Description of Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The expenses referred to in subsection (a) are any expenses—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida959c88a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2264/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incurred by the Department of Defense as a result of providing assistance to a nongovernmental entertainment-oriented media producer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c88b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2264/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the Department of Defense requires reimbursement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9701"},"text":"section 9701 of title 31","children":[],"tail":" or any other provision of law; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c88c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2264/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the Department of Defense received reimbursement after ","children":[{"tag":"date","attrib":{"date":"2014-12-19"},"text":"December 19, 2014","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida959c88d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tVIII/s859/a"},"text":"Pub. L. 113–291, div. A, title VIII, § 859(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3461"},"text":"128 Stat. 3461","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1081/a/29"},"text":"Pub. L. 115–91, div. A, title X, § 1081(a)(29)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1595"},"text":"131 Stat. 1595","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida959c88e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida959c88f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"ta