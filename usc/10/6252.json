{"tag":"section","attrib":{"id":"idaac90f2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6252"},"text":null,"children":[{"tag":"num","attrib":{"value":"6252"},"text":"§ 6252.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stockpile stewardship recruitment and training program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaac90f2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6252/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conduct of Program","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac90f2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6252/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As part of the stockpile stewardship program established pursuant to section 6111, the Secretary of Energy shall conduct a stockpile stewardship recruitment and training program at the national security laboratories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90f2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6252/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The recruitment and training program shall be conducted in coordination with the Chairman of the Joint Nuclear Weapons Council established by section 179 and the directors of the laboratories referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90f2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6252/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support of Dual-use Programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As part of the recruitment and training program, the directors of the national security laboratories may employ undergraduate students, graduate students, and postdoctoral fellows to carry out research sponsored by such laboratories for military or nonmilitary dual-use programs related to nuclear weapons stockpile stewardship.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90f30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6252/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Retiree Corps","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As part of the training and recruitment program, the Secretary, in coordination with the directors of the national security laboratories, shall establish for the laboratories a retiree corps of retired scientists who have expertise in research and development of nuclear weapons. The directors may employ the retired scientists on a part-time basis to provide appropriate assistance on nuclear weapons issues, to contribute relevant information to be archived, and to help to provide training to other scientists.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac90f31-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2)(B), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1418"},"text":"139 Stat. 1418","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac90f32-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac90f33-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac90f34-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6252 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8302"},"text":"section 8302 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2722"},"text":"section 2722 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaac90f35-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
