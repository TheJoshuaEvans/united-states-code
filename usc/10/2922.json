"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2388(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2388(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:98i (1st sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:98i (2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-08-03/ch939/s416"},"text":"Aug. 3, 1956, ch. 939, § 416","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/70/1018"},"text":"70 Stat. 1018","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2388(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:98i (less 1st and 2d sentences and proviso of last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2388(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:98i (proviso of last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “section applies only” are substituted for the words “authority is limited”. The word “standards” is substituted for the word “criteria”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “A contract under this section” are substituted for the words “Such contracts”. The last 33 words are substituted for 50:98i (28 words before proviso of last sentence).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida9fbfb9a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1982 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"In 10:2388(c), the title 31 citation is substituted on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258/s4/b"},"text":"Pub. L. 97–258, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":", the first section of which enacted title 31."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9fbfb9b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9fbfb9c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" substituted “30 years” for “20 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2388"},"text":"section 2388 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355"},"text":"Pub. L. 103–355","children":[],"tail":" substituted “liquid fuels or natural gas” for “liquid fuels and natural gas”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s825/b"},"text":"Pub. L. 103–160, § 825(b)","children":[],"tail":", substituted “Liquid fuels and natural gas: contracts for storage, handling, or distribution” for “Liquid fuels: contracts for storage, handling, and distribution” as section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s825/a/1"},"text":"Pub. L. 103–160, § 825(a)(1)","children":[],"tail":", added subsecs. (a) and (b) and struck out former subsecs. (a) and (b) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) The Secretary of a military department may contract for the storage, handling, and distribution of liquid fuels for periods of not more than five years, with options to renew for additional periods of not more than five years each, but not for more than a total of 20 years.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) This section applies only to facilities that conform to standards prescribed by the Secretary of Defense for protection, including dispersal, and that are in a program approved by the Secretary of Defense for the protection of petroleum facilities.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s825/a/2"},"text":"Pub. L. 103–160, § 825(a)(2)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" struck out subsec. (d) which read as follows: “The Secretary concerned shall report to the Committees on Armed Services of the Senate and the House of Representatives the terms of the contracts made under this section and the names of the contractors. The reports shall be made at such times and in such form as may be agreed upon by the Secretary and those Committees.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525"},"text":"Pub. L. 98–525","children":[],"tail":" substituted “subsections (a) and (b) of section 3324” for “section 3324(a) and (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295/s1/27"},"text":"Pub. L. 97–295, § 1(27)","children":[],"tail":", substituted “section 3324(a) and (b) of title 31” for “section 3648 of the Revised Statutes ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s529"},"text":"31 U.S.C. 529","children":[],"tail":")”, clarifying the ambiguity created by previous amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/97/214"},"text":"Pub. L. 97–214","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258/s3/b/6"},"text":"Pub. L. 97–258, § 3(b)(6)","children":[],"tail":", directed the substitution of “section 3324(a) and (b) of title 31” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t31/s529"},"text":"section 529 of title 31","children":[],"tail":"”, which could not be executed in view of prior substitution of language by "},{"tag":"ref","attrib":{"href":"/us/pl/97/214"},"text":"Pub. L. 97–214","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/214/s10/a/3"},"text":"Pub. L. 97–214, § 10(a)(3)","children":[],"tail":", substituted “section 3648 of the Revised Statutes ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s529"},"text":"31 U.S.C. 529","children":[],"tail":")” for “section 4774(d) or 9774(d) of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s529"},"text":"section 529 of title 31","children":[],"tail":", or section 259 or 267 of title 40,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9fbfb9d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9fbfb9e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVIII/s881/b"},"text":"Pub. L. 115–91, div. A, title VIII, § 881(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1504"},"text":"131 Stat. 1504","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/91/dA/tVIII/s881/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply with respect to contracts entered into on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":"], and may be applied to a contract entered into before that date if the total contract period under the contract (including options) has not expired as of the date of any extension of such contract period by reason of such amendment.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9fbfb9f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/214"},"text":"Pub. L. 97–214","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", and applicable to military construction projects, and to construction and acquisition of military family housing authorized before, on, or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/214/s12/a"},"text":"section 12(a) of Pub. L. 97–214","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2801"},"text":"section 2801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9fbfba0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation of Inspector General Recommendations Relating to Oversight of Defense Fuel Support Points","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tIII/s320"},"text":"Pub. L. 118–159, div. A, title III, § 320","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1853"},"text":"138 Stat. 1853","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tIII/s320"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“With respect to each recommendation of the Inspector General of the Department of Defense contained in the report published by the Inspector General on ","children":[{"tag":"date","attrib":{"date":"2024-04-11"},"text":"April 11, 2024","children":[],"tail":", and titled ‘Audit of the Defense Logistics Agency Oversight of Defense Fuel Support Points’ (DODIG–2024–075), by not later than "},{"tag":"date","attrib":{"date":"2026-05-01"},"text":"May 1, 2026","children":[],"tail":", the Secretary of Defense shall—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement such recommendation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Committees on Armed Services of the Senate and the House of Representatives a report containing an explanation of why the Secretary has not implemented the recommendation.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9fbfba1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Bulk Fuel Management in United States Indo-Pacific Command Area of Responsibility","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dB/tXXVIII/s2854"},"text":"Pub. L. 116–283, div. B, title XXVIII, § 2854","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4355"},"text":"134 Stat. 4355","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tIII/s352/d"},"text":"Pub. L. 117–81, div. A, title III, § 352(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1655"},"text":"135 Stat. 1655","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dA/tIII/s352/d"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bulk Fuel Management Strategy.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Strategy required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prepare a bulk fuel management strategy for the United States Indo-Pacific Command Area of Responsibility designed to develop the required bulk fuel management infrastructure and programs to optimally support bulk fuel management in the United States Indo-Pacific Command Area of Responsibility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The strategy shall include the following additional elements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of current organizational responsibility of bulk fuel management in the United States Indo-Pacific Command Area of Responsibility from ordering, storage, strategic transportation, and tactical transportation to the last tactical mile.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of legacy bulk fuel management assets that can be used to support the United States Indo-Pacific Command.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of current programs for platforms and weapon systems and research and development aimed at managing fuel constraints through decreasing demand.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The bulk fuel management strategy required by subsection (a) shall be prepared in coordination with subject-matter experts of the United States Indo-Pacific Command, the United States Transportation Command, the Defense Logistics Agency, and the military departments.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9fbfba2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Notice of Purchase of Drop-In Fuel","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tIII/s316/c"},"text":"Pub. L. 113–291, div. A, title III, § 316(c)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3339"},"text":"128 Stat. 3339","children":[],"tail":", 3340, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/291/dA/tIII/s316/c"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of Purchase Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary of Defense intends to purchase a drop-in fuel intended for operational use with a fully burdened cost in excess of 10 percent more than the fully burdened cost of a traditional fuel available for the same purpose, the Secretary shall provide notice of such intended purchase to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] by not later than 30 days before the date on which such purchase is intended to be made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section [this note]:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘drop-in fuel’ means a neat or blended liquid hydrocarbon fuel designed as a direct replacement for a traditional fuel with comparable performance characteristics and compatible with existing infrastructure and equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘traditional fuel’ means a liquid hydrocarbon fuel derived or refined from petroleum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘operational purposes’ means for the purposes of conducting military operations, including training, exercises, large scale demonstrations, and moving and sustaining military forces and military platforms. The term does not include research, development, testing, evaluation, fuel certification, or other demonstrations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘fully burdened cost’ means the commodity price of the fuel plus the total cost of all personnel and assets required to move and, when necessary, protect the fuel from the point at which the fuel is received from the commercial supplier to the point of use.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9fbfba3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purchases of Gasohol as Fuel for Motor Vehicles","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/107/tVIII/s815"},"text":"Pub. L. 96–107, title VIII, § 815","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-09"},"text":"Nov. 9, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/817"},"text":"93 Stat. 817","children":[],"tail":", which had authorized the Secretary of Defense to buy domestically produced alcohol and gasohol for use as fuel in Department of Defense motor vehicles, was repealed and reenacted as section 2398 (now 2922c) of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":", §§ 1(29)(A), 6(b), "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1293"},"text":"96 Stat. 1293","children":[],"tail":", 1315."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
