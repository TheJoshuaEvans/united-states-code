{"tag":"section","attrib":{"id":"ida9fbfb92-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922"},"text":null,"children":[{"tag":"num","attrib":{"value":"2922"},"text":"§ 2922.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liquid fuels and natural gas: contracts for storage, handling, or distribution","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9fbfb93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Contract","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense and the Secretary of a military department may each contract for storage facilities for, or the storage, handling, or distribution of, liquid fuels or natural gas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9fbfb94-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of Contract","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The period of a contract entered into under subsection (a) may not exceed 5 years. However, the contract may provide options for the Secretary to renew the contract for additional periods of not more than 5 years each, but not for more than a total of 30 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9fbfb95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Option To Purchase Facility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contract under this section may contain an option for the purchase by the United States of the facility covered by the contract at the expiration or termination of the contract, without regard to subsections (a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3324"},"text":"section 3324 of title 31","children":[],"tail":", and before approval of title to the underlying land by the Attorney General."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9fbfb96-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/46"},"text":"Pub. L. 85–861, § 1(46)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1457"},"text":"72 Stat. 1457","children":[],"tail":", § 2388; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/214/s10/a/3"},"text":"Pub. L. 97–214, § 10(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-07-12"},"text":"July 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/175"},"text":"96 Stat. 175","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s3/b/6"},"text":"Pub. L. 97–258, § 3(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1063"},"text":"96 Stat. 1063","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s1/27"},"text":"Pub. L. 97–295, § 1(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1291"},"text":"96 Stat. 1291","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXIV/s1405/56/A"},"text":"Pub. L. 98–