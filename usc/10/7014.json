{"tag":"section","attrib":{"id":"idaad28552-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014"},"text":null,"children":[{"tag":"num","attrib":{"value":"7014"},"text":"§ 7014.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of the Secretary of the Army","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaad28553-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is in the Department of the Army an Office of the Secretary of the Army. The function of the Office is to assist the Secretary of the Army in carrying out his responsibilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad28554-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Office of the Secretary of the Army is composed of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad28555-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad28556-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretaries of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad28557-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrative Assistant to the Secretary of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad28558-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The General Counsel of the Department of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad28559-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Inspector General of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad2855a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Legislative Liaison.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad2855b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Army Reserve Forces Policy Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad2855c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other offices and officials as may be established by law or as the Secretary of the Army may establish or designate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad2855d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad2855e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Office of the Secretary of the Army shall have sole responsibility within the Office of the Secretary and the Army Staff for the following functions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaad2855f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Acquisition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad28560-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Auditing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad28561-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Comptroller (including financial management).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad28562-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad28563-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Inspector General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad28564-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Legislative affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad4f565-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Public affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f566-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army shall establish or designate a single office or other entity within the Office of the Secretary of the Army to conduct each function specified in paragraph (1). No office or other entity may be established or designated within the Army Staff to conduct any of the functions specified in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f567-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe the relationship of each office or other entity established or designated under paragraph (2) to the Chief of Staff and to the Army Staff and shall ensure that each such office or entity provides the Chief of Staff such staff support as the Chief of Staff considers necessary to perform his duties and responsibilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f568-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The vesting in the Office of the Secretary of the Army of the responsibility for the conduct of a function specified in paragraph (1) does not preclude other elements of the executive part of the Department of the Army (including the Army Staff) from providing advice or assistance to the Chief of Staff or otherwise participating in that function within the executive part of the Department under the direction of the office assigned responsibility for that function in the Office of the Secretary of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f569-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of the office or other entity established or designated by the Secretary to conduct the auditing function shall have at least five years of professional experience in accounting or auditing. The position shall be considered to be a career reserved position as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132/a/8"},"text":"section 3132(a)(8) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad4f56a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad4f56b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), the Office of the Secretary of the Army shall have sole responsibility within the Office of the Secretary and the Army Staff for the function of research and development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f56c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army may assign to the Army Staff responsibility for those aspects of the function of research and development that relate to military requirements and test and evaluation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f56d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish or designate a single office or other entity within the Office of the Secretary of the Army to conduct the function specified in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f56e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe the relationship of the office or other entity established or designated under paragraph (3) to the Chief of Staff of the Army and to the Army Staff and shall ensure that each such office or entity provides the Chief of Staff such staff support as the Chief of Staff considers necessary to perform his duties and responsibilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad4f56f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army shall ensure that the Office of the Secretary of the Army and the Army Staff do not duplicate specific functions for which the Secretary has assigned responsibility to the other.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad4f570-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad4f571-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total number of members of the armed forces and civilian employees of the Department of the Army assigned or detailed to permanent duty in the Office of the Secretary of the Army and on the Army Staff may not exceed 3,250.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f572-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than 1,900 officers of the Army on the active-duty list may be assigned or detailed to permanent duty in the Office of the Secretary of the Army and on the Army Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f573-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total number of general officers assigned or detailed to permanent duty in the Office of the Secretary of the Army and on the Army Staff may not exceed 67.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f574-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The limitations in paragraphs (1), (2), and (3) do not apply in time of war.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f575-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7014/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each limitation in paragraphs (1) and (2) may be exceeded by a number equal to 15 percent of such limitation in time of national emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad4f576-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s501/a/5"},"text":"Pub. L. 99–433, title V, § 501(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1036"},"text":"100 Stat. 1036","children":[],"tail":", § 3014; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tXIII/s1314/b/7"},"text":"Pub. L. 100–180, div. A, title XIII, § 1314(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1175"},"text":"101 Stat. 1175","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tIII/s325/a"},"text":"Pub. L. 100–456, div. A, title III, § 325(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1955"},"text":"102 Stat. 1955","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVI/s652/a/4"},"text":"Pub. L. 101–189, div. A, title VI, § 652(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1461"},"text":"103 Stat. 1461","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/a/27"},"text":"Pub. L. 107–107, div. A, title X, § 1048(a)(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1225"},"text":"115 Stat. 1225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tV/s504/c/2"},"text":"Pub. L. 107–314, div. A, title V, § 504(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2532"},"text":"116 Stat. 2532","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tIX/s903/c"},"text":"Pub. L. 114–328, div. A, title IX, § 903(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2344"},"text":"130 Stat. 2344","children":[],"tail":"; renumbered § 7014, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1838"},"text":"132 Stat. 1838","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s901/a/3"},"text":"Pub. L. 116–92, div. A, title IX, § 901(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1541"},"text":"133 Stat. 1541","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaad4f577-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaad4f578-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaad4f579-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s901/a/3/A"},"text":"Pub. L. 116–92, § 901(a)(3)(A)","children":[],"tail":", substituted “3,250” for “3,105”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s901/a/3/B"},"text":"Pub. L. 116–92, § 901(a)(3)(B)","children":[],"tail":", substituted “1,900” for “1,865”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3014"},"text":"section 3014 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (f)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s903/c/1"},"text":"Pub. L. 114–328, § 903(c)(1)","children":[],"tail":", substituted “time of war.” for “time of war or during a national emergency declared by the President or Congress. The limitation in paragraph (2) does not apply whenever the President determines that it is in the national interest to increase the number of officers assigned or detailed to permanent duty in the Office of the Secretary of the Army or on the Army Staff.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s903/c/2"},"text":"Pub. L. 114–328, § 903(c)(2)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(6) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" added par. (6) and redesignated former pars. (6) and (7) as (7) and (8), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" substituted “67” for “the number equal to 85 percent of the number of general officers assigned or detailed to such duty on the date of the enactment of this subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (f)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" struck out par. (5) which read as follows: “The limitations in paragraphs (1), (2), and (3) do not apply before "},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"October 1, 1988","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (f)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180"},"text":"Pub. L. 100–180","children":[],"tail":" inserted “the President or” after “declared by”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaad4f57a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":nul