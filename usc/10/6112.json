{"tag":"section","attrib":{"id":"idaabab7d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6112"},"text":null,"children":[{"tag":"num","attrib":{"value":"6112"},"text":"§ 6112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Portfolio management framework for National Nuclear Security Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaabab7d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than one year after the date of the enactment of the National Defense Authorization Act for Fiscal Year 2022 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Public Law 117–81","children":[],"tail":"), the Administrator shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabab7d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6112/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in consultation with the Nuclear Weapons Council established under section 179, develop and implement a portfolio management framework for the nuclear security enterprise that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaabab7d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6112/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defines the Administration’s portfolio of nuclear weapons stockpile and infrastructure maintenance and modernization programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabab7da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6112/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes a portfolio governance structure, including portfolio-level selection criteria, prioritization criteria, and performance metrics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabab7db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6112/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outlines the approach of the Administration to managing that portfolio; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabab7dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6112/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporates the leading practices identified by the Comptroller General of the United States in the report titled “Nuclear Security Enterprise: NNSA Should Use Portfolio Management Leading Practices to Support Modernization Efforts” (GAO-21-398) and dated June 2021; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab7dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6112/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete an integrated, comprehensive assessment of the portfolio management capabilities required to execute the weapons activities portfolio of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabab7de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefing Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2022-06-01"},"text":"June 1, 2022","children":[],"tail":", the Administrator shall provide to the congressional defense committees a briefing on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabab7df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress of the Administrator in developing the framework described in paragraph (1) of subsection (a) and completing the assessment required by paragraph (2) of that subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab7e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plans of the Administrator for implementing the recommendations of the Comptroller General in the report referred to in paragraph (1)(D) of that subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaabab7e1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1345"},"text":"139 Stat. 1345","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaabab7e2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaabab7e3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaabab7e4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the National Defense Authorization Act for Fiscal Year 2022, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaabab7e5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6112, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/381"},"text":"70A Stat. 381","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1962-10-09"},"text":"Oct. 9, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/777/s1"},"text":"Pub. L. 87–777, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/777"},"text":"76 Stat. 777","children":[],"tail":", prohibited employment of officers of the Regular Navy and Regular Marine Corps, other than a retired officer, from being employed by any person furnishing naval supplies or war materials to the United States under pain of loss of payment from the United States during that employment, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/87/649/s14c/36"},"text":"Pub. L. 87–649, § 14c(36)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/501"},"text":"76 Stat. 501","children":[],"tail":", and by "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s75/6"},"text":"Pub. L. 89–718, § 75(6)","children":[],"tail":", (7), "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1124"},"text":"80 Stat. 1124","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s3121"},"text":"section 3121 of Pub. L. 117–81","children":[],"tail":", which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2521"},"text":"section 2521 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/10"},"text":"Pub. L. 119–60, § 3111(b)(10)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
