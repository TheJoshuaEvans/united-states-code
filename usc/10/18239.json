{"tag":"section","attrib":{"id":"idabc5beb9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18239"},"text":null,"children":[{"tag":"num","attrib":{"value":"18239"},"text":"§ 18239.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of certain restrictions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabc5beba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18239/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense and the Secretary of each military department may make expenditures and contributions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s18233"},"text":"section 18233 of this title","children":[],"tail":" without regard to section 3324(a) and (b) of title 31."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc5bebb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18239/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Authority provided by law to place permanent or temporary improvements on land under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s18233"},"text":"section 18233 of this title","children":[],"tail":" may be exercised on land not owned by the United States—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc5bebc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18239/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before title to the land on which the improvement is located (or is to be located) is approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3111"},"text":"section 3111 of title 40","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc5bebd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18239/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" even though the land will be held in other than a fee simple interest in a case in which the Secretary of the military department concerned determines that the interest to be acquired in the land is sufficient for the purposes of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc5bebe-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/214/s3/b/1"},"text":"Pub. L. 97–214, § 3(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-07-12"},"text":"July 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/169"},"text":"96 Stat. 169","children":[],"tail":", § 2239; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s1/23"},"text":"Pub. L. 97–295, § 1(23)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1290"},"text":"96 Stat. 1290","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/321/tVIII/s805/a/2"},"text":"Pub. L. 97–321, title VIII, § 805(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1573"},"text":"96 Stat. 1573","children":[],"tail":"; renumbered § 18239 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1664/b/2"},"text":"Pub. L. 103–337, div. A, title XVI, § 1664(b)(2)","children":[],"tail":", (10), "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3010"},"text":"108 Stat. 3010","children":[],"tail":", 3011; "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/b/42"},"text":"Pub. L. 107–217, § 3(b)(42)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1298"},"text":"116 Stat. 1298","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabc5bebf-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabc5bec0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabc5bec1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s3111"},"text":"section 3111 of title 40","children":[],"tail":"” for “section 355 of the Revised Statutes ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s255"},"text":"40 U.S.C. 255","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1664/b/2"},"text":"Pub. L. 103–337, § 1664(b)(2)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2239"},"text":"section 2239 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1664/b/10"},"text":"Pub. L. 103–337, § 1664(b)(10)","children":[],"tail":", substituted “18233” for “2233”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97