{"tag":"section","attrib":{"id":"idab403b5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8692"},"text":null,"children":[{"tag":"num","attrib":{"value":"8692"},"text":"§ 8692.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ford-class aircraft carriers: cost limitation baselines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab403b5b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8692/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The total amounts obligated or expended from funds authorized to be appropriated or otherwise made available for Shipbuilding and Conversion, Navy, or for any other procurement account, may not exceed the following amounts for the following aircraft carriers:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab403b5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8692/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $13,224,000,000 for the construction of the aircraft carrier designated CVN–78.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403b5d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8692/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $11,398,000,000 for the construction of the aircraft carrier designated CVN–79.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403b5e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8692/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $12,202,000,000 for the construction of the aircraft carrier designated CVN–80.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403b5f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8692/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $12,451,000,000 for the construction of the aircraft carrier designated CVN–81.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403b60-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8692/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion of Battle and Interim Spares From Cost Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Navy shall exclude from the determination of the amounts set forth in subsection (a) the costs of the following items:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab403b61-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8692/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" CVN–78 class battle spares.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403b62-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8692/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interim spares.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403b63-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8692/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increases attributable to economic inflation after ","children":[{"tag":"date","attrib":{"date":"2018-12-01"},"text":"December 1, 2018","children":[],"tail":", not otherwise included in the amounts listed in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403b64-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8692/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Written Notice and Briefing on Change in Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy may adjust an amount listed in subsection (a) not fewer than 15 days after submitting written notice and providing a briefing to the congressional defense committees, each of which shall include the amount and rationale of any change and the resulting amount after such change.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab403b65-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tI/s121/a"},"text":"Pub. L. 116–92, div. A, title I, § 121(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1233"},"text":"133 Stat. 1233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab403b66-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab403b67-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idab403b68-3a6f-11f1-a58a-d8db