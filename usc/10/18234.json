{"tag":"section","attrib":{"id":"idabc5be6d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18234"},"text":null,"children":[{"tag":"num","attrib":{"value":"18234"},"text":"§ 18234.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location and use","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No expenditures or contribution may be made for a facility under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s18233"},"text":"section 18233 of this title","children":[],"tail":", unless the Secretary of Defense determines that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc5be6e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18234/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of units of the reserve components of the armed forces located or to be located in the area within which the facility is to be provided is not and will not be larger than the number that can reasonably be expected to be maintained at authorized strength, considering the number of persons living in the area who are qualified for membership in those reserve units; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc5be6f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18234/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan under which the facility is to be provided makes provision for the greatest practicable use of the facility jointly by units of two or more of those components.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc5be70-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/121"},"text":"70A Stat. 121","children":[],"tail":", § 2234; renumbered § 18234 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1664/b/2"},"text":"Pub. L. 103–337, div. A, title XVI, § 1664(b)(2)","children":[],"tail":", (6), "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3010"},"text":"108 Stat. 3010","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabc5be71-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idabc5be72-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idabc5be73-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2234","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:883(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-09-11/ch945/s4/a"},"text":"Sept. 11, 1950, ch. 945, § 4(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/830"},"text":"64 Stat. 830","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “community” is omitted as covered by the word “area”. The word “program” is omitted as covered by the word “plan”. The words “use * * * jointly by units of two or more of those components” are substituted for the words “joint utilization” to reflect 50:886(d). The words “is not and will not be larger than” are substituted for the words “does not exceed”. The word “considering” is substituted for the words “taking into account”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabc5be74-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabc5be75-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","