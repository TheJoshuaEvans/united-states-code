{"tag":"section","attrib":{"id":"ida769b6e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b"},"text":null,"children":[{"tag":"num","attrib":{"value":"139b"},"text":"§ 139b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretariat for Special Operations; Special Operations Policy and Oversight Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida769b6e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretariat for Special Operations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida769b6e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In order to fulfill the responsibilities of the Assistant Secretary of Defense for Special Operations and Low Intensity Conflict specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s138/b/2/A/i"},"text":"section 138(b)(2)(A)(i) of this title","children":[],"tail":", there shall be within the Office of the Assistant Secretary of Defense for Special Operations and Low Intensity Conflict an office to be known as the “Secretariat for Special Operations”."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida769b6ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of the Secretariat is to assist the Assistant Secretary in exercising authority, direction, and control with respect to the special operations-peculiar administration and support of the special operations command, including the readiness and organization of special operations forces, resources and equipment, and civilian personnel as specified in such section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida769b6eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Secretariat for Special Operations shall be appointed by the Secretary of Defense from among individuals qualified to serve as the Director. An individual serving as Director shall, while so serving, be a member of the Senior Executive Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida769b6ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative chain of command","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of the support of the Secretariat for the Assistant Secretary in the fulfillment of the responsibilities referred to in paragraph (1), the administrative chain of command is as specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s167/f"},"text":"section 167(f) of this title","children":[],"tail":". Unless otherwise directed by the President, no officer below the Secretary of Defense (other than the Assistant Secretary) may intervene to exercise authority, direction, or control over the Secretariat in its support of the Assistant Secretary in the discharge of such responsibilities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida769b6ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Operations Policy and Oversight Council.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida769b6ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In order to fulfill the responsibilities specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s138/b/2/A/i"},"text":"section 138(b)(2)(A)(i) of this title","children":[],"tail":", the Assistant Secretary of Defense for Special Operations and Low Intensity Conflict shall establish and lead a team known as the “Special Operation Policy and Oversight Council” (in this subsection referred to as the “Council”)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida769b6ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of the Council is to integrate the functional activities of the headquarters of the Department of Defense in order to most efficiently and effectively provide for special operations forces and capabilities. In fulfilling this purpose, the Council shall develop and continuously improve policy, joint processes, and procedures that facilitate the development, acquisition, integration, employment, and sustainment of special operations forces and capabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida769b6f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida769b6f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida769b6f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Appropriate senior representatives of each of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida769b6f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense for Research and Engineering.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida769b6f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense for Acquisition and Sustainment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida769b6f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense (Comptroller).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida769b6f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b/b/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense for Personnel and Readiness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida769b6f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b/b/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense for Intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida769b6f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b/b/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The General Counsel of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida769b6f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b/b/3/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The other Assistant Secretaries of Defense under the Under Secretary of Defense for Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida769b6fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b/b/3/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The military departments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida769b6fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b/b/3/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Joint Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida769b6fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b/b/3/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Special Operations Command.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida769b6fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b/b/3/B/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other officers or Agencies, elements, or components of the Department of Defense as the Secretary of Defense considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida769b6fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s139b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council shall operate continuously.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida769b6ff-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tIX/s922/b/1"},"text":"Pub. L. 114–328, div. A, title IX, § 922(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2355"},"text":"130 Stat. 2355","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1081/a/7"},"text":"Pub. L. 115–91, div. A, title X, § 1081(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1594"},"text":"131 Stat. 1594","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXVI/s1621/e/1/A/iv"},"text":"Pub. L. 116–92, div. A, title XVI, § 1621(e)(1)(A)(iv)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1733"},"text":"133 Stat. 1733","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s902/b/1"},"text":"Pub. L. 116–283, div. A, title IX, § 902(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3795"},"text":"134 Stat. 3795","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida769b700-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida769b701-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida769b702-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 139b, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/23/tI/s102/a/1"},"text":"Pub. L. 111–23, title I, § 102(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1710"},"text":"123 Stat. 1710","children":[],"tail":", § 139d; renumbered § 139b and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tIX/s901/e"},"text":"Pub. L. 111–383, div. A, title IX, § 901(e)","children":[],"tail":", (f), (k)(1)(E), title X, § 1075(b)(6), "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4321"},"text":"124 Stat. 4321","children":[],"tail":", 4322, 4325, 4369; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVIII/s835/b"},"text":"Pub. L. 112–81, div. A, title VIII, § 835(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1507"},"text":"125 Stat. 1507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tIX/s904/a"},"text":"Pub. L. 112–239, div. A, title IX, § 904(a)","children":[],"tail":"–(d), (f), (g), title X, § 1076(f)(5), "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1866"},"text":"126 Stat. 1866","children":[],"tail":", 1867, 1952; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tII/s221/a"},"text":"Pub. L. 113–291, div. A, title II, § 221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3330"},"text":"128 Stat. 3330","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVIII/s832"},"text":"Pub. L. 114–92, div. A, title VIII, § 832","children":[],"tail":", title X, § 1078(b), "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/913"},"text":"129 Stat. 913","children":[],"tail":", 998, related to Deputy Assistant Secretary of Defense for Developmental Test and Evaluation; Deputy Assistant Secretary of Defense for Systems Engineering; support of major defense acquisition programs; annual and biennial report requirements; and joint guidance in certain areas, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tIX/s901/e/2"},"text":"Pub. L. 114–328, div. A, title IX, § 901(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2342"},"text":"130 Stat. 2342","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 139b was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s138c"},"text":"section 138c of this title","children":[],"tail":" and was subsequently repealed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 139b was renumbered sections 4371 to 4375 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida769b703-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" amended section generally. Prior to amendment, section related to Special Operations Policy and Oversight Council."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (c)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “Under Secretary of Defense for Intelligence and Security” for “Under Secretary of Defense for Intelligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (c)(2)(K). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" inserted period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida769b704-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida769b705-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Optimization of Irregular Warfare Technical Support Directorate","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tX/s1071"},"text":"Pub. L. 117–81, div. A, title X, § 1071","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1913"},"text":"135 Stat. 1913","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dA/tX/s1071"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":"], the Assistant Secretary of Defense for Special Operations and Low Intensity Conflict shall submit to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] a plan for improving the support provided by the Irregular Warfare Technical Support Directorate to meet military requirements. Such plan shall include the following:"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Specific actions to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure adequate focus on rapid fielding of required capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve metrics and methods for tracking projects that have transitioned into programs of record; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize overlap with other research, development, and acquisition efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other matters as the Assistant Secretary of Defense for Special Operations and Low Intensity Conflict considers relevant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Department of Defense Instruction Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 270 days after the date of the enactment of this Act, the Assistant Secretary of Defense for Special Operations and Low Intensity Conflict, in coordination with the Under Secretary of Defense for Research and Engineering, the Under Secretary of Defense for Acquisition and Sustainment, and the Secretaries of the military departments, shall publish an updated Department of Defense Instruction in order to—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" define the objectives, organization, mission, customer base, and role of the Irregular Warfare Technical Support Directorate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure coordination with external program managers assigned to the military departments and the United States Special Operations Command;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate adequate oversight by the Assistant Secretary of Defense for Special Operations and Low Intensity Conflict, the Under Secretary of Defense for Research and Engineering, and the Under Secretary of Defense for Acquisition and Sustainment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address such other matters as the Assistant Secretary of Defense for Special Operations and Low Intensity Conflict considers relevant.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
