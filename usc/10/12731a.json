{"tag":"section","attrib":{"id":"idaba9362d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12731a"},"text":null,"children":[{"tag":"num","attrib":{"value":"12731a"},"text":"§ 12731a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary special retirement qualification authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaba9362e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12731a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retirement With At Least","children":[],"tail":" 15 "},{"tag":"inline","attrib":{},"text":"Years of Service","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12731"},"text":"section 12731 of this title","children":[],"tail":", the Secretary concerned may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba9362f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12731a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" during the period described in subsection (b), determine to treat a member of the Selected Reserve of a reserve component of the armed force under the jurisdiction of that Secretary as having met the service requirements of subsection (a)(2) of that section and provide the member with the notification required by subsection (d) of that section if the member—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaba93630-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12731a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as of ","children":[{"tag":"date","attrib":{"date":"1991-10-01"},"text":"October 1, 1991","children":[],"tail":", has completed at least 15, and less than 20, years of service computed under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12732"},"text":"section 12732 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaba93631-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12731a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after that date and before the end of the period described in subsection (b), completes 15 years of service computed under that section; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba93632-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12731a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon the request of the member submitted to the Secretary, transfer the member to the Retired Reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba93633-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12731a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The period referred to in subsection (a)(1) is the period beginning on ","children":[{"tag":"date","attrib":{"date":"1992-10-23"},"text":"October 23, 1992","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2001-12-31"},"text":"December 31, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba93634-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12731a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability Subject to Needs of the Service","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba93635-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12731a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may limit the applicability of subsection (a) to any category of personnel defined by the Secretary in order to meet a need of the armed force under the jurisdiction of the Secretary to reduce the number of members in certain grades, the number of members who have completed a certain number of years of service, or the number of members who possess certain military skills or are serving in designated competitive categories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba93636-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12731a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A limitation under paragraph (1) shall be consistent with the purpose set forth in section 4414(a) of the National Defense Authorization Act for Fiscal Year 1993 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Public Law 102–484","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/106/2713"},"text":"106 Stat. 2713","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba93637-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12731a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding the provisions of section 4415(2) of the Defense Conversion, Reinvestment, and Transition Assistance Act of 1992 (division D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Public Law 102–484","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/106/2714"},"text":"106 Stat. 2714","children":[],"tail":"), the Secretary concerned may, consistent with the other provisions of this section, provide the notification required by "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12731/d"},"text":"section 12731(d) of this title","children":[],"tail":" to a member who no longer meets the qualifications for membership in the Selected Reserve solely because the member is unfit because of physical disability. Such notification may not be made if the disability is the result of the member’s intentional misconduct, willful neglect, or willful failure to comply with standards and qualifications for retention established by the Secretary concerned or was incurred during a period of unauthorized absence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba93638-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12731a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not apply to persons referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12731/c"},"text":"section 12731(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba93639-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12731a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority provided in this section shall be subject to regulations prescribed by the Secretary of Defense and by the Secretary of Homeland Security with respect to the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaba9363a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dD/tXLIV/s4417/a"},"text":"Pub. L. 102–484, div. D, title XLIV, § 4417(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2716"},"text":"106 Stat. 2716","children":[],"tail":", § 1331a; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/35/tII/s201/f/2"},"text":"Pub. L. 103–35, title II, § 201(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-05-31"},"text":"May 31, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/99"},"text":"107 Stat. 99","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tV"},"text":"Pub. L. 103–160, div. A, title V","children":[],"tail":", §§ 561(f)(4), 564(c), "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1668"},"text":"107 Stat. 1668","children":[],"tail":", 1670; renumbered § 12731a and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tV/s517"},"text":"Pub. L. 103–337, div. A, title V, § 517","children":[],"tail":", title XVI, § 1662(j)(1), "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2754"},"text":"108 Stat. 2754","children":[],"tail":", 2998, 3000; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1501/b/21"},"text":"Pub. L. 104–106, div. A, title XV, § 1501(b)(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/497"},"text":"110 Stat. 497","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tV/s561/n/2"},"text":"Pub. L. 105–261, div. A, title V, § 561(n)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2026"},"text":"112 Stat. 2026","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 571(n)(2)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–135; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/b/1"},"text":"Pub. L. 107–296, title XVII, § 1704(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaba9363b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaba9363c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaba9363d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 4414(a) of the National Defense Authorization Act for Fiscal Year 1993 and section 4415(2) of the Defense Conversion, Reinvestment, and Transition Assistance Act of 1992, referred to in subsec. (c)(2), (3), are sections 4414(a) and 4415(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":", which are set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12681"},"text":"section 12681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaba9363e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 571(n)(2)(A)], substituted “the end of the period described in subsection (b)” for “"},{"tag":"date","attrib":{"date":"2001-10-01"},"text":"October 1, 2001","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 571(n)(2)(B)], substituted “"},{"tag":"date","attrib":{"date":"2001-12-31"},"text":"December 31, 2001","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2001-10-01"},"text":"October 1, 2001","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1)(B), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":"Pub. L. 105–261","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2001-10-01"},"text":"October 1, 2001","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"October 1, 1999","children":[],"tail":"”."}],"ta