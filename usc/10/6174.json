{"tag":"section","attrib":{"id":"idaac42d52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174"},"text":null,"children":[{"tag":"num","attrib":{"value":"6174"},"text":"§ 6174.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Future-years defense environmental cleanup plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaac42d53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy shall submit to Congress each year, at or about the same time that the President’s budget is submitted to Congress for a fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", a future-years defense environmental cleanup plan that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac42d54-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflects the estimated expenditures and proposed appropriations included in that budget for the Department of Energy for defense environmental cleanup; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d55-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covers a period that includes the fiscal year for which that budget is submitted and not less than the four succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac42d56-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each future-years defense environmental cleanup plan required by subsection (a) shall contain the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac42d57-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed description of the projects and activities relating to defense environmental cleanup to be carried out during the period covered by the plan at the sites specified in subsection (c) and with respect to the activities specified in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement of proposed budget authority, estimated expenditures, and proposed appropriations necessary to support such projects and activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to each site specified in subsection (c), the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac42d5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement of each milestone included in an enforceable agreement governing cleanup and waste remediation for that site for each fiscal year covered by the plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42d5b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each such milestone, a statement with respect to whether each such milestone will be met in each such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42d5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For any milestone that will not be met, an explanation of why the milestone will not be met and the date by which the milestone is expected to be met.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42d5d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For any milestone that has been missed, renegotiated, or postponed, a statement of the current milestone, the original milestone, and any interim milestones.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac42d5e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sites Specified","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The sites specified in this subsection are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac42d5f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Idaho National Laboratory, Idaho.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d60-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Waste Isolation Pilot Plant, Carlsbad, New Mexico.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d61-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Savannah River Site, Aiken, South Carolina.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d62-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Oak Ridge National Laboratory, Oak Ridge, Tennessee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d63-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Hanford Site, Richland, Washington.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d64-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any defense closure site of the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d65-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any site of the National Nuclear Security Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac42d66-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities Specified","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The activities specified in this subsection are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac42d67-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Program support.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Program direction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d69-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Safeguards and security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d6a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Technology development and deployment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d6b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6174/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal contributions to the Uranium Enrichment Decontamination and Decommissioning Fund established under section 1801 of the Atomic Energy Act of 1954 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2297g"},"text":"42 U.S.C. 2297g","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac42d6c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1387"},"text":"139 Stat. 1387","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac42d6d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac42d6e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac42d6f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2582a"},"text":"section 2582a of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
