{"tag":"section","attrib":{"id":"ida8ff24ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1601"},"text":null,"children":[{"tag":"num","attrib":{"value":"1601"},"text":"§ 1601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civilian intelligence personnel: general authority to establish excepted positions, appoint personnel, and fix rates of pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8ff2500-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1601/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ff2501-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1601/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish, as positions in the excepted service, such defense intelligence positions in the Department of Defense as the Secretary determines necessary to carry out the intelligence functions of the Department, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8ff2502-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1601/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Intelligence Senior Level positions designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1607"},"text":"section 1607 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8ff2503-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1601/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" positions in the Defense Intelligence Senior Executive Service;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ff2504-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1601/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint individuals to those positions (after taking into consideration the availability of preference eligibles for appointment to those positions); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ff2505-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1601/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fix the compensation of such individuals for service in those positions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ff2506-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1601/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction With Other Laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority of the Secretary of Defense under subsection (a) applies without regard to the provisions of any other law relating to the appointment, number, classification, or compensation of employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8ff2507-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVI/s1632/a/3"},"text":"Pub. L. 104–201, div. A, title XVI, § 1632(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2746"},"text":"110 Stat. 2746","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XI, § 1141(a)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–318.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8ff2508-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8ff2509-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida8ff250a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1601, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/89/tVII/s701/a/1"},"text":"Pub. L. 97–89, title VII, § 701(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-04"},"text":"Dec. 4, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1159"},"text":"95 Stat. 1159","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/194/tV/s506/c/3"},"text":"Pub. L. 101–194, title V, § 506(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1759"},"text":"103 Stat. 1759","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/280/s6/d/4"},"text":"Pub. L. 101–280, § 6(d)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-04"},"text":"May 4, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/161"},"text":"104 Stat. 161","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIV/s1484"},"text":"Pub. L. 101–510, div. A, title XIV, § 1484","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(5), "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1720"},"text":"104 Stat. 1720","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/359/tV/s501/b/1/B"},"text":"Pub. L. 103–359, title V, § 501(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3428"},"text":"108 Stat. 3428","children":[],"tail":", related to the Defense Intelligence Senior Executive Service, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVI"},"text":"Pub. L. 104–201, div. A, title XVI","children":[],"tail":", §§ 1632(a)(3), 1635, "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2745"},"text":"110 Stat. 2745","children":[],"tail":", 2752, effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1606"},"text":"section 1606 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 1590(a) and 1604(a) of this title prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":", §§ 1632(a)(3), 1633(a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8ff250b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":", in introductory provisions, substituted “in the Department of Defense” for “in the intelligence components of the Department of Defense and the military departments” and “of the Department” for “of those components and departments”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8ff250c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8ff250d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1635"},"text":"section 1635 of Pub. L. 104–201","children":[],"tail":", set out as an Effective Date of 1996 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1593"},"text":"section 1593 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"ida8ff250e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVI/s1631"},"text":"Pub. L. 104–201, div. A, title XVI, § 1631","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2745"},"text":"110 Stat. 2745","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/201/dA/tXVI/s1631"},"text":"“This subtitle [subtitle B (§§ 1631–1635) of title XVI of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":", enacting this section and sections 1602, 1603, 1606 to 1610, and 1612 to 1614 of this title, amending sections 1593, 1596, 1605, 1611, and 1621 of this title and sections 7103 and 7511 of Title 5, Government Organization and Employees, renumbering sections 1599, 1602, 1606, and 1608 of this title as sections 1611, 1621, 1622, and 1623 of this title, respectively, repealing sections 1590, 1601, 1603, and 1604 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s833"},"text":"section 833 of Title 50","children":[],"tail":", War and National Defense, enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1593"},"text":"section 1593 of this title","children":[],"tail":", and repealing provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s402"},"text":"section 402 of Title 50","children":[],"tail":"] may be cited as the ‘Department of Defense Civilian Intelligence Personnel Policy Act of 1996’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8ff250f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Authority","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/89/tVII/s701/b"},"text":"Pub. L. 97–89, title VII, § 701(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-04"},"text":"Dec. 4, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1160"},"text":"95 Stat. 1160","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/89/tVII/s701/b"},"text":"“The authority of the Secretary of Defense under chapter 83 of title 10, United States Code, as added by subsection (a), may be delegated in accordance with section 133(d) [now 113(d)] of title 10, United States Code.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8ff2510-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Provisions Relating to the Defense Civilian Intelligence Personnel System","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tXI/s1114"},"text":"Pub. L. 111–84, div. A, title XI, § 1114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2504"},"text":"123 Stat. 2504","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/84/dA/tXI/s1114"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Suspension of Certain Pay Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Effective with respect to amounts paid during the period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":"] and ending on "},{"tag":"date","attrib":{"date":"2010-12-31"},"text":"December 31, 2010","children":[],"tail":", rates of basic pay for employees and positions within any element of the intelligence community (as defined by the National Security Act of 1947 ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"50 U.S.C. 3001","children":[],"tail":" et seq.])—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be fixed under the Defense Civilian Intelligence Personnel System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall instead be fixed in accordance with the provisions of law that (disregarding DCIPS) would then otherwise apply.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The preceding sentence shall not apply with respect to the National Geospatial-Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Response to GAO Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 3 months after the date of the enactment of this Act, the Secretary of Defense shall submit to the congressional oversight committees a written description of any actions taken or proposed to be taken by such Secretary in response to the review and recommendations of the Government Accountability Office regarding the Defense Civilian Intelligence Personnel System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Independent Organization.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the date of the enactment of this Act, the Secretary of Defense, the Director of the Office of Personnel Management, and the Director of National Intelligence shall jointly designate an independent organization to review the operation of the Defense Civilian Intelligence Personnel System, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its impact on career progression;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its appropriateness or inappropriateness in light of the complexities of the workforce affected;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its sufficiency in terms of providing protections for diversity in promotion and retention of personnel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adequacy of the training, policy guidelines, and other preparations afforded in connection with transitioning to that system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The independent organization shall, after appropriate consultation with employees and employee organizations, submit its findings and recommendations under this section to the Secretary of Defense and the congressional oversight committees, in a written report, not later than ","children":[{"tag":"date","attrib":{"date":"2010-06-01"},"text":"June 1, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proposed Actions Based on Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after receiving the report of the independent organization under subsection (c), the Secretary of Defense, in coordination with the Director of the Office of Personnel Management and the Director of National Intelligence, shall submit to the congressional oversight committees a written report describing any actions that the Secretary has taken or proposes to take in response to such report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hold-harmless Provision","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No employee shall suffer any loss of or decrease in pay as a result of being converted from DCIPS in compliance with subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the terms ‘Defense Civilian Intelligence Personnel System’ and ‘DCIPS’ mean the civilian personnel system established by the Secretary of Defense under regulations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribed pursuant to sections 1601 through 1614 of title 10, United States Code; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taking effect in September 2008 or thereafter; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term ‘congressional oversight committees’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services and the Permanent Select Committee on Intelligence of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services and the Select Committee on Intelligence of the Senate.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
