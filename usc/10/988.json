{"tag":"section","attrib":{"id":"ida84522e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s988"},"text":null,"children":[{"tag":"num","attrib":{"value":"988"},"text":"§ 988.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on ownership or trading of stocks in certain companies by certain officials of the Department of Defense","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida84522e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s988/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), a covered official of the Department of Defense may not own or purchase publicly traded stock of a company if that company is one of the 10 entities awarded the most amount of contract funds by the Department of Defense in a fiscal year during the five preceding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84522ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s988/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not apply to the purchase or ownership of a publicly traded stock of a company otherwise described in subsection (a) as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84522eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s988/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the aggregate market value of the holdings of the covered official, and the spouse and minor children of the covered official, in the stock of that company, both before and after purchase (in the case of a purchase), does not exceed the de minimis threshold established in section 2640.202(a)(2) of title 5, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84522ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s988/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the stock is purchased and owned as part of an Excepted Investment Fund or mutual fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84522ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s988/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84522ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s988/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered official of the Department of Defense” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida84522ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s988/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A civilian appointed to a position in the Department of Defense by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida84522f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s988/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If serving in a key acquisition position (as designated by the Secretary of Defense or the Secretary concerned for purposes of this section), the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida84522f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s988/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the armed forces in a grade above O–6.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida84522f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s988/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A civilian officer or employee in a Senior Executive Service, Senior-Level, or Scientific or Professional position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84522f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s988/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Excepted Investment Fund” means a widely-held investment fund described in section 102(f)(8) of the Ethics in Government Act of 1978 (5 U.S.C. App.).","children":[{"tag":"ref","attrib":{"idref":"fn002044"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002044"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida84522f4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s921/a"},"text":"Pub. L. 116–92, div. A, title IX, § 921(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1560"},"text":"133 Stat. 1560","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida84522f5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida84522f6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida84522f7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 102(f)(8) of the Ethics in Government Act of 1978, referred to in subsec. (c)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/521/s102/f/8"},"text":"section 102(f)(8) of Pub. L. 95–521","children":[],"tail":", which was set out in the Appendix to Title 5, Government Organization and Employees, and was repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s13104/f/8"},"text":"section 13104(f)(8) of Title 5","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(c), (7), "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4284"},"text":"136 Stat. 4284","children":[],"tail":", 4361."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
