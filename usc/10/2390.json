{"tag":"section","attrib":{"id":"ida974063e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2390"},"text":null,"children":[{"tag":"num","attrib":{"value":"2390"},"text":"§ 2390.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on the sale of certain defense articles from the stocks of the Department of Defense","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida974063f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2390/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9740640-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2390/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsections (b) and (c), the sale outside the Department of Defense of any defense article designated or otherwise classified as Prepositioned Material Configured to Unit Sets, as decrement stock, or as Prepositioned War Reserve Stocks for United States Forces is prohibited.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9740641-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2390/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section, the term “decrement stock” means such stock as is needed to bring the armed forces from a peacetime level of readiness to a combat level of readiness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9740642-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2390/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President may authorize the sale outside the Department of Defense of a defense article described in subsection (a) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9740643-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2390/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" he determines that there is an international crisis affecting the national security of the United States and the sale of such article is in the best interests of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9740644-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2390/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" he reports to the Congress not later than 60 days after the transfer of such article a plan for the prompt replenishment of the stocks of such article and the planned budget request to begin implementation of that plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9740645-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2390/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9740646-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2390/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall preclude the sale of stocks which have been designated for replacement, substitution, or elimination or which have been designated for sale to provide funds to procure higher priority stocks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9740647-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2390/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall preclude the transfer or sale of equipment to other members of the North Atlantic Treaty Organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9740648-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/485/tVIII/s815/a"},"text":"Pub. L. 95–485, title VIII, § 815(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-20"},"text":"Oct. 20, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1625"},"text":"92 Stat. 1625","children":[],"tail":", § 975; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s7/k/3"},"text":"Pub. L. 100–26, § 7(k)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/284"},"text":"101 Stat. 284","children":[],"tail":"; renumbered § 2390, "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXVI/s1622/b/1"},"text":"Pub. L. 101–189, div. A, title XVI, § 1622(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1604"},"text":"103 Stat. 1604","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9740649-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida974064a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida974064b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2390, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/79/tVIII/s815/a"},"text":"Pub. L. 95–79, title VIII, § 815(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-07-30"},"text":"July 30, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/337"},"text":"91 Stat. 337","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/470/tI/s104/a"},"text":"Pub. L. 96–470, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-19"},"text":"Oct. 19, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2238"},"text":"94 Stat. 2238","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s511/80"},"text":"Pub. L. 96–513, title V, § 511(80)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2927"},"text":"94 Stat. 2927","children":[],"tail":", directed Secretary of Defense to request each commissioned officer, and each civilian employee above grade GS–12, who was scheduled for retirement and who was or had been at any time within one year prior to such scheduled retirement, assigned to, or employed in, military procurement to submit suggestions for methods to improve procurement policies, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/98/94/tXII/s1259/a"},"text":"Pub. L. 98–94, title XII, § 1259(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/703"},"text":"97 Stat. 703","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida974064c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s975"},"text":"section 975 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/26"},"text":"Pub. L. 100–26","children":[],"tail":" inserted “the term” after “In this section,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
