{"tag":"section","attrib":{"id":"idaba20a24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12405"},"text":null,"children":[{"tag":"num","attrib":{"value":"12405"},"text":"§ 12405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Guard in Federal service: status","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Members of the National Guard called into Federal service are, from the time when they are required to respond to the call, subject to the laws and regulations governing the Army or the Air Force, as the case may be, except those applicable only to members of the Regular Army or Regular Air Force, as the case may be.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idaba20a25-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1662/f/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1662(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2993"},"text":"108 Stat. 2993","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaba20a26-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaba20a27-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaba20a28-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 3499 and 8499 of this title, prior to repeal 