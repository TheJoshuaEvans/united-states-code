{"tag":"section","attrib":{"id":"ida997bb30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2653"},"text":null,"children":[{"tag":"num","attrib":{"value":"2653"},"text":"§ 2653.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evacuation of family pets and contract working dogs during noncombatant evacuations of foreign countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida997bb31-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2653/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Evacuate","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the limitations under subsection (b), in the event of a situation during which the Department of Defense evacuates noncombatants from a foreign country, the Secretary of Defense may enter into agreements with appropriate nonprofit entities under which such entities provide for the evacuation of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida997bb32-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2653/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the family pets of citizens of the United States who are evacuated by the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida997bb33-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2653/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contract working dogs located in such country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida997bb34-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2653/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The limitations under this subsection are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida997bb35-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2653/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Defense is not responsible for providing veterinary care for a family pet or contract working dog by reason of the evacuation of the pet or dog pursuant to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida997bb36-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2653/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not exercise the authority under subsection (a) if the exercise of such authority would result in a reduction in the number of individuals who would otherwise be evacuated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida997bb37-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2653/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The operator of a vehicle used for evacuation may refuse to evacuate a family pet or contract working dog if the operator determines that the evacuation would create a safety risk to other passengers or personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida997bb38-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tIII/s372"},"text":"Pub. L. 119–60, div. A, title III, § 372","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/836"},"text":"139 Stat. 836","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
