title II, § 204","children":[],"tail":", title VII, § 701, "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2880"},"text":"94 Stat. 2880","children":[],"tail":", 2955, effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":". See sections 631 and 632 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa1d3e0d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1816/c/4/A"},"text":"Pub. L. 116–283, § 1816(c)(4)(A)","children":[],"tail":", (C), redesignated subsec. (b)(3) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2305"},"text":"section 2305 of this title","children":[],"tail":" as subsec. (a) of this section and inserted heading. Former second and third sentences of subsec. (a) designated subsecs. (b) and (c), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1816/c/4/B"},"text":"Pub. L. 116–283, § 1816(c)(4)(B)","children":[],"tail":", (D), designated second sentence of subsec. (a) as subsec. (b) of this section, inserted heading, and substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3301/a"},"text":"section 3301(a) of this title","children":[],"tail":"” for “paragraph (1)” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3301/b"},"text":"section 3301(b) of this title","children":[],"tail":"” for “paragraph (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1816/c/4/B"},"text":"Pub. L. 116–283, § 1816(c)(4)(B)","children":[],"tail":", (E), designated third sentence of subsec. (a) as subsec. (c) of this section and inserte