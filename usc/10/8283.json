{"tag":"section","attrib":{"id":"idab17a436-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8283"},"text":null,"children":[{"tag":"num","attrib":{"value":"8283"},"text":"§ 8283.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency medical treatment: reimbursement for expense","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Navy shall prescribe regulations for reimbursing members of the naval service for expenses of emergency or necessary medical service, including hospitalization and medicines, when the member was in a duty status at the time he received the service and the service was not available from a Federal source. For the purpose of this section, a member on leave or liberty is in a duty status.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab17a437-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/387"},"text":"70A Stat. 387","children":[],"tail":", § 6203; renumbered § 8283, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/11"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1835"},"text":"132 Stat. 1835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab17a438-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab17a439-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab17a43a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"ta