{"tag":"section","attrib":{"id":"idab4766cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8743"},"text":null,"children":[{"tag":"num","attrib":{"value":"8743"},"text":"§ 8743.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment of aliens","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Laws prohibiting payment of compensation to a person who is not a citizen of the United States do not apply to a person whose employment by the Department of the Navy is determined by the Secretary of the Navy to be necessary to obtain for the armed forces the benefits of the special technical or scientific knowledge or experience possessed by that person and not readily obtainable from a citizen.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab4766d0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/462"},"text":"70A Stat. 462","children":[],"tail":", § 7473; renumbered § 8743, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/6"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab4766d1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab4766d2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab4766d3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"child