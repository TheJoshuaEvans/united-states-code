{"tag":"section","attrib":{"id":"ida936131a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2182"},"text":null,"children":[{"tag":"num","attrib":{"value":"2182"},"text":"§ 2182.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational assistance: dependents of captives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida936131b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2182/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under regulations prescribed by the President, the Secretary concerned shall pay (by advancement or reimbursement) a dependent of a person who is in a captive status for expenses incurred, while attending an educational or training institution, for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida936131c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2182/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsistence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida936131d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2182/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tuition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida936131e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2182/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida936131f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2182/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supplies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361320-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2182/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" books;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361321-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2182/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361322-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2182/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other educational expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9361323-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2182/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2184"},"text":"section 2184 of this title","children":[],"tail":", payments shall be available under this section for a dependent of a person who is in a captive status for education or training that occurs—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9361324-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2182/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after that person is in a captive status for not less than 90 days; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361325-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2182/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on or before—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9361326-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2182/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the end of any semester or quarter (as appropriate) that begins before the date on which the captive status of that person terminates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9361327-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2182/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the earlier of the end of any course that began before such date or the end of the 16-week period following that date if the educational or training institution is not operated on a semester or quarter system; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9361328-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2182/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a date specified by the Secretary concerned in order to respond to special circumstances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9361329-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2182/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a person in a captive status or a former captive dies and the death is incident to the captivity, payments shall be available under this section for a dependent of that person for education or training that occurs after the date of the death of that person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida936132a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2182/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of this section shall not apply to any dependent who is eligible for assistance under chapter 35 of title 38 or similar assistance under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida936132b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tVIII/s806/d/1"},"text":"Pub. L. 99–399, title VIII, § 806(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/887"},"text":"100 Stat. 887","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida936132c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida936132d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida936132e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to persons whose captive status begins after ","children":[{"tag":"date","attrib":{"date":"1981-01-21"},"text":"Jan. 21, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/399/s806/d/3"},"text":"section 806(d)(3) of Pub. L. 99–399","children":[],"tail":", set out as a note under 2181 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"ida936132f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"ida9361330-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of the President under this section delegated to the Secretary of Defense, see section 3 of Ex. Ord. No. 12598, ","children":[{"tag":"date","attrib":{"date":"1987-06-17"},"text":"June 17, 1987","children":[],"tail":", 52 F.R. 23421, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5569"},"text":"section 5569 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
