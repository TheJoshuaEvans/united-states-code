{"tag":"section","attrib":{"id":"idaa77e18f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377"},"text":null,"children":[{"tag":"num","attrib":{"value":"4377"},"text":"§ 4377.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Breach of critical cost growth threshold: actions if program not terminated","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa77e190-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions if Program Not Terminated","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary elects not to terminate a major defense acquisition program pursuant to subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4376"},"text":"section 4376 of this title","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa77e191-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restructure the program in a manner that addresses the root cause or causes of the critical cost growth, as identified pursuant to subsection (a) of that section, and ensures that the program has an appropriate management structure as set forth in the certification submitted pursuant to subsection (b)(2)(E) of that section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa77e192-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rescind the most recent Milestone approval for the program and withdraw any associated certification under section 4251 or 4252 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa77e193-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require a new Milestone approval for the program before taking any contract action to enter a new contract, exercise an option under an existing contract, or otherwise extend the scope of an existing contract under the program, except to the extent determined necessary by the Milestone Decision Authority, on a non-delegable basis, to ensure that the program can be restructured as intended by the Secretary without unnecessarily wasting resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa77e194-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in the report specified in subsection (b) a description of all funding changes made as a result of the growth in cost of the program, including reductions made in funding for other programs to accommodate such cost growth; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa77e195-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct regular reviews of the program in accordance with the requirements of section 205 of the Weapon Systems Acquisition Reform Act of 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa77e196-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Identification of Report for Description of Funding Changes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of subsection (a)(4), the report specified in this subsection is the first Selected Acquisition Report for the program submitted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4351"},"text":"section 4351 of this title","children":[],"tail":" after the President submits a budget pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", in the calendar year following the year in which the program was restructured."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa77e197-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of Certain Subsection (a) Requirements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa77e198-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions for inapplicability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of paragraphs (2), (3), and (5) of subsection (a) shall not apply to a program or subprogram if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa77e199-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Milestone Decision Authority determines in writing, on the basis of a cost assessment and root cause analysis conducted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4376/a"},"text":"section 4376(a) of this title","children":[],"tail":", that—"}],"tail":null},{"tag":"clause","attrib":{"id":"idaa77e19a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" but for a change in the quantity of items to be purchased under the program or subprogram, the program acquisition unit cost or procurement unit cost for the program or subprogram would not have increased by a percentage equal to or greater than the cost growth thresholds for the program or subprogram set forth in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa77e19b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the change in quantity of items described in clause (i) was not made as a result of an increase in program cost, a delay in the program, or a problem meeting program requirements;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa77e19c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines in writing that the cost to the Department of Defense of complying with such requirements is likely to exceed the benefits to the Department of complying with such requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa77e19d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary submits to Congress, before the end of the 60-day period beginning on the day the Selected Acquisition Report containing the information described in subsections (d) and (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4375"},"text":"section 4375 of this title","children":[],"tail":" is required to be submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4351/f"},"text":"section 4351(f) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"idaa77e19e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the written determination under subparagraph (A) and an explanation of the basis for the determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa77e19f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the written determination under subparagraph (B) and an explanation of the basis for the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa77e1a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost growth thresholds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The cost growth thresholds specified in this paragraph are as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa77e1a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a major defense acquisition program or designated major defense subprogram, a percentage increase in the program acquisition unit cost for the program or subprogram of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa77e1a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 percent over the program acquisition unit cost for the program or subprogram as shown in the current Baseline Estimate for the program or subprogram; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa77e1a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent over the program acquisition unit cost for the program or subprogram as shown in the original Baseline Estimate for the program or subprogram.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa77e1a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a major defense acquisition program or designated major defense subprogram that is a procurement program, a percentage increase in the procurement unit cost for the program or subprogram of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa77e1a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 percent over the procurement unit cost for the program or subprogram as shown in the current Baseline Estimate for the program or subprogram; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa77e1a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4377/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent over the procurement unit cost for the program or subprogram as shown in the original Baseline Estimate for the program or subprogram.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa77e1a7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1850/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1850(a)","children":[],"tail":", (k), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4265"},"text":"134 Stat. 4265","children":[],"tail":", 4270; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(6)(E)(vi), (vii), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2148"},"text":"135 Stat. 2148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa77e1a8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa77e1a9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaa77e1aa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 205 of the Weapon Systems Acquisition Reform Act of 2009, referred to in subsec. (a)(5), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/23/s205"},"text":"section 205 of Pub. L. 111–23","children":[],"tail":", which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4252"},"text":"section 4252 of this title","children":[],"tail":" and enacted provisions set out as notes under this section and former "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2366b"},"text":"section 2366b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa77e1ab-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2433a"},"text":"section 2433a of this title","children":[],"tail":", which was transferred to this section and redesignated as subsec. (a) by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1850/k/1"},"text":"Pub. L. 116–283, § 1850(k)(1)","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/pl/111/23/tII/s206/a/1"},"text":"Pub. L. 111–23, title II, § 206(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1726"},"text":"123 Stat. 1726","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVIII"},"text":"Pub. L. 112–81, div. A, title VIII","children":[],"tail":", §§ 801(e)(4), 831, "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1484"},"text":"125 Stat. 1484","children":[],"tail":", 1503; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tVIII/s813"},"text":"Pub. L. 112–239, div. A, title VIII, § 813","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1829"},"text":"126 Stat. 1829","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa77e1ac-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 4381 to 4387 were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/647/tIII/s301/10"},"text":"Pub. L. 88–647, title III, § 301(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1072"},"text":"78 Stat. 1072","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4381, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/246"},"text":"70A Stat. 246","children":[],"tail":", defined “advanced training” for purposes of chapter 405."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4382, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/246"},"text":"70A Stat. 246","children":[],"tail":", provided for the establishment and composition of the Reserve Officers’ Training Corps."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4383, ","chi