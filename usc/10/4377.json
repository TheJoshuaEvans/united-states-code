nce assessment pursuant to section 103 of this Act [formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2430"},"text":"section 2430 of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4273"},"text":"10 U.S.C. 4273","children":[],"tail":"], shall assess the performance of each major defense acquisition program that has exceeded critical cost growth thresholds established pursuant to [former] "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2433/e"},"text":"section 2433(e) of title 10","children":[],"tail":", United States Code [see "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4375/a"},"text":"10 U.S.C. 4375(a)","children":[],"tail":" to (c)], but has not been terminated in accordance with [former] section 2433a of such title [see "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4376"},"text":"10 U.S.C. 4376","children":[],"tail":", 4377] (as added by section 206(a) of this Act) not less often than semi-annually until one year after the date on which such program receives a new milestone approval, in accordance with [former] section 2433a(c)(1)(C) of such title [see "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4377/a/3"},"text":"10 U.S.C. 4377(a)(3)","children":[],"tail":"] (as so added). The results of reviews performed under this subsection shall be reported to the Under Secretary of Defense for Acquisition, Technology, and Logistics and summarized in the next annual report of such designated official.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVIII/s813/e"},"text":"Pub. L. 111–383, div. A, title VIII, § 813(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4266"},"text":"124 Stat. 4266","children":[],"tail":", provided that the amendment made by section 813(e) to "},{"tag":"ref","attrib":{"href":"/us/pl/111/23/s205/c"},"text":"section 205(c) of Pub. L. 111–23","children":[],"tail":", set out above, is effective as of "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/111/23"},"text":"Pub. L. 111–23","children":[],"tail":", as enacted.]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “major defense acquisition program” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/23/s205/c"},"text":"section 205(c) of Pub. L. 111–23","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/23/s2/2"},"text":"section 2(2) of Pub. L. 111–23","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4321"},"text":"section 4321 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
