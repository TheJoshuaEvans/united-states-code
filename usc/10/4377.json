ail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa77e1ad-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1850/k/2"},"text":"Pub. L. 116–283, § 1850(k)(2)","children":[],"tail":", redesignated pars. (2) and (3) of subsec. (a) as subsecs. (b) and (c), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1850/k/1"},"text":"Pub. L. 116–283, § 1850(k)(1)","children":[],"tail":", transferred subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2433a"},"text":"section 2433a of this title","children":[],"tail":" to this section and redesignated it as subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1850/k/3/A"},"text":"Pub. L. 116–283, § 1850(k)(3)(A)","children":[],"tail":"–(C), struck out par. (1) designation before “If the Secretary”, inserted “of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4376"},"text":"section 4376 of this title","children":[],"tail":"” after “subsection (b)” in introductory provisions, and redesignated subpars. (A) to (E) as pars. (1) to (5), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1850/k/3/D"},"text":"Pub. L. 116–283, § 1850(k)(3)(D)","children":[],"tail":", inserted “of that section” after “subsection (a)” and “subsection (b)(2)(E)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1850/k/3/E"},"text":"Pub. L. 116–283, § 1850(k)(3)(E)","children":[],"tail":", substituted “section 4251 or 4252” for “section 2366a or 2366b”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"