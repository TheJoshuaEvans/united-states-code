"}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1947-04-16/ch38/s205"},"text":"Apr. 16, 1947, ch. 38, § 205","children":[],"tail":" (proviso), "},{"tag":"html:a","attrib":{"href":"/us/stat/61/48"},"text":"61 Stat. 48","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provision of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1899-03-03/s7"},"text":"§ 7 of the Act of March 3, 1899","children":[],"tail":" (supra), relating to relative rank is omitted as executed. The provision that the rank conferred upon staff corps officers shall not change their titles is omitted because these titles were abolished by § 405 of the Officer Personnel Act of 1947 ("},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10a"},"text":"34 U.S.C. 10a","children":[],"tail":") and the corresponding line grades substituted. The cited proviso in the Act of "},{"tag":"date","attrib":{"date":"1910-06-24"},"text":"June 24, 1910","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t34/s253"},"text":"34 U.S.C. 253","children":[],"tail":" (proviso)) is omitted as obsolete because the officers referred to were officers of the Construction Corps which has been abolished."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The first sentence of this section is phrased so as to reflect the accepted meaning of the cited provision. ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s253"},"text":"34 U.S.C. 253","children":[],"tail":", as worded, if interpreted literally, could be held to prohibit, for example, the assignment of members of the Medical Service Corps, Nurse Corps, and Hospital Corps to duty under officers of the Medical Corps, despite the fact that all of these corps were established by law within the Medical Department of the Navy. The provision is not so interpreted. It is understood to restrict only the types of activities that staff corps officers may command, and not to restrict to a single corps the personnel who may be assigned to an activity commanded by a staff corps officer."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab12e92f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab12e930-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s5945"},"text":"section 5945 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/130"},"text":"Pub. L. 90–130","children":[],"tail":" struck out provision that an officer in the Nurse Corps may not exercise command."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab12e931-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab12e932-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
