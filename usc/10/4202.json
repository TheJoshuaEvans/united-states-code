{"tag":"section","attrib":{"id":"idaa64cf16-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4202"},"text":null,"children":[{"tag":"num","attrib":{"value":"4202"},"text":"§ 4202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to increase definitional threshold amounts: major defense acquisition programs; major systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa64cf17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adjustments to Thresholds for Major Defense Acquisition Programs.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa64cf18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4202/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may adjust the amounts (and the base fiscal year) provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4201/a/2"},"text":"section 4201(a)(2) of this title","children":[],"tail":" on the basis of Department of Defense escalation rates."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa64cf19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4202/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matters to be considered","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4201/a/2"},"text":"section 4201(a)(2) of this title","children":[],"tail":", the Secretary shall consider, as applicable, the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa64cf1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4202/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The estimated level of resources required to fulfill the relevant joint military requirement, as determined by the Joint Requirements Oversight Council pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s181"},"text":"section 181 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa64cf1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4202/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cost estimate referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4251/a/6"},"text":"section 4251(a)(6) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa64cf1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4202/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cost estimate referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4252/a/1/C"},"text":"section 4252(a)(1)(C) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa64cf1d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4202/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cost estimate within a baseline description as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4214"},"text":"section 4214 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa64cf1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adjustment Authority for Major Systems.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa64cf1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4202/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may adjust the amounts and the base fiscal year provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3041/c/1"},"text":"section 3041(c)(1) of this title","children":[],"tail":" on the basis of Department of Defense escalation rates."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa64cf20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4202/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rounding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An amount, as adjusted under paragraph (1), that is not evenly divisible by $5,000,000 shall be rounded to the nearest multiple of $5,000,000. In the case of an amount that is evenly divisible by $2,500,000 but not evenly divisible by $5,000,000, the amount shall be rounded to the next higher multiple of $5,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa64cf21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification to Congressional Committees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An adjustment under subsection (a) or (b) shall be effective after the Secretary transmits to the Committee on Armed Services of the Senate and the Committee on Armed Services of the House of Representatives a written notification of the adjustment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa64cf22-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1846/b"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1846(b)","children":[],"tail":", (d), (e), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4248"},"text":"134 Stat. 4248","children":[],"tail":", 4249.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa64cf23-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa64cf24-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa64cf25-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsecs. (b) and (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2430"},"text":"section 2430 of this title","children":[],"tail":", which was transferred to this section, red