{"tag":"section","attrib":{"id":"ida8f7f89a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1581"},"text":null,"children":[{"tag":"num","attrib":{"value":"1581"},"text":"§ 1581.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign National Employees Separation Pay Account","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8f7f89b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1581/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment and Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established on the books of the Treasury an account to be known as the “Foreign National Employees Separation Pay Account, Defense”. The account shall be used for the accumulation of funds to finance obligations of the United States for separation pay for foreign nationals referred to in subsection (e).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f7f89c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1581/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposits Into Account","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall deposit into the account from applicable appropriations all amounts obligated for separation pay for foreign nationals referred to in subsection (e).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f7f89d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1581/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payments From Account","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts in the account shall remain available for expenditure in accordance with the purpose for which obligated until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f7f89e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1581/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deobligated Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any amount in the account that is deobligated shall be available for a period of two years from the date of deobligation for recording, adjusting, and liquidating amounts properly chargeable to the liability of the United States for which the obligation was made. Any such deobligated amount remaining at the end of such two-year period shall be canceled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f7f89f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1581/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employees Covered","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies only with respect to separation pay of foreign nationals employed by the Department of Defense, and foreign nationals employed by a foreign government for the benefit of the Department of Defense, under any of the following agreements that provide for payment of separation pay:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8f7f8a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1581/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f7f8a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1581/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A treaty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f7f8a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1581/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A memorandum of understanding with a foreign nation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8f7f8a3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tX/s1003/a/1"},"text":"Pub. L. 102–190, div. A, title X, § 1003(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1456"},"text":"105 Stat. 1456","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1052/20"},"text":"Pub. L. 102–484, div. A, title X, § 1052(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2500"},"text":"106 Stat. 2500","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tIII/s346"},"text":"Pub. L. 103–337, div. A, title III, § 346","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2724"},"text":"108 Stat. 2724","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/e/2"},"text":"Pub. L. 107–107, div. A, title X, § 1048(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1227"},"text":"115 Stat. 1227","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8f7f8a4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8f7f8a5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida8f7f8a6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1581, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/118"},"text":"70A Stat. 118","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/34"},"text":"Pub. L. 85–861, § 1(34)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1456"},"text":"72 Stat. 1456","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1959-05-29"},"text":"May 29, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/86/36/s3"},"text":"Pub. L. 86–36, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/63"},"text":"73 Stat. 63","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1959-09-23"},"text":"Sept. 23, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/86/377/s2"},"text":"Pub. L. 86–377, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/701"},"text":"73 Stat. 701","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1961-10-04"},"text":"Oct. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/367/tII/s203"},"text":"Pub. L. 87–367, title II, § 203","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/790"},"text":"75 Stat. 790","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1962-10-11"},"text":"Oct. 11, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/793/s1001/b"},"text":"Pub. L. 87–793, § 1001(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/863"},"text":"76 Stat. 863","children":[],"tail":", provided for appointment of a limited number of civilian research and development personnel and prescribed their relationship to civil service provisions, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s1/19/A"},"text":"Pub. L. 97–295, § 1(19)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1290"},"text":"96 Stat. 1290","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8f7f8a7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" struck out par. (2) designation and “on or after "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"December 5, 1991","children":[],"tail":",” after “all amounts obligated” and struck out par. (1) which read as follows: “The Secretary of the Treasury shall deposit into the account all amounts that were obligated by the Secretary of Defense before "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"December 5, 1991","children":[],"tail":", and that remain unexpended for separation pay for foreign nationals referred to in subsection (e).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s346/1"},"text":"Pub. L. 103–337, § 346(1)","children":[],"tail":", substituted “foreign nationals referred to in subsection (e)” for “foreign national employees of the Department of Defense” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s346/2"},"text":"Pub. L. 103–337, § 346(2)","children":[],"tail":", added subsec. (e) and struck out former subsec. (e) which read as follows: “"},{"tag":"inline","attrib":{},"text":"Employees Covered","children":[],"tail":".—This section applies only with respect to separation pay of foreign nationals employed by the Department of Defense under any of the following agreements that provide for payment of separation pay:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) A contract.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) A treaty.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) A memorandum of understanding with a foreign nation.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"December 5, 1991","children":[],"tail":",” for “the date of the enactment of this section”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
