{"tag":"section","attrib":{"id":"ida74abd17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a"},"text":null,"children":[{"tag":"num","attrib":{"value":"118a"},"text":"§ 118a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quadrennial quality of life review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida74abd18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review Required","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida74abd19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall every four years conduct a comprehensive examination of the quality of life of the members of the armed forces (to be known as the “quadrennial quality of life review”). The review shall include examination of the programs, projects, and activities of the Department of Defense, including the morale, welfare, and recreation activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74abd1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The quadrennial quality of life review shall be designed to result in determinations, and to foster policies and actions, that reflect the priority given the quality of life of members of the armed forces as a primary concern of the Department of Defense leadership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida74abd1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conduct of Review","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each quadrennial quality of life review shall be conducted so as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida74abd1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assess quality of life priorities and issues consistent with the most recent National Security Strategy prescribed by the President pursuant to section 108 of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3043"},"text":"50 U.S.C. 3043","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74abd1d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify actions that are needed in order to provide members of the armed forces with the quality of life reasonably necessary to encourage the successful execution of the full range of missions that the members are called on to perform under the national security strategy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74abd1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify other actions that have the potential for improving the quality of life of the members of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida74abd1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall consider addressing the following matters as part of the quadrennial quality of life review:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida74abd20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Infrastructure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74abd21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Military construction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74abd22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Physical conditions at military installations and other Department of Defense facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74abd23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Budget plans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74abd24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adequacy of medical care for members of the armed forces and their dependents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74abd25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adequacy of housing and the basic allowance for housing and basic allowance for subsistence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74abd26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Housing-related utility costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74abd27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Educational opportunities and costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74abd28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Length of deployments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74abd29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rates of pay and pay differentials between the pay of members and the pay of civilians.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74abd2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Retention and recruiting efforts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74abd2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Workplace safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74abd2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/c/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Support services for spouses and children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74abd2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/c/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other elements of Department of Defense programs and Government policies and programs that affect the quality of life of members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74abd2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/c/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Support services for Gold Star families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida74abd2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission to Congressional Committees","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida74abd30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall submit a report on each quadrennial quality of life review to the Committee on Armed Services of the Senate and the Committee on Armed Services of the House of Representatives. The report shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida74abd31-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The assumptions used in the review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida74abd32-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The results of the review, including a comprehensive discussion of how the quality of life of members of the armed forces affects the national security strategy of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74abd33-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s118a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The report shall be submitted in the year following the year in which the review is conducted, but not later than the date on which the President submits the budget for the next fiscal year to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida74abd34-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tV/s581/a/1"},"text":"Pub. L. 107–314, div. A, title V, § 581(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2559"},"text":"116 Stat. 2559","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1071/c/2"},"text":"Pub. L. 113–291, div. A, title X, § 1071(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3508"},"text":"128 Stat. 3508","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tX/s1061/a/1"},"text":"Pub. L. 117–81, div. A, title X, § 1061(a)(1)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1909"},"text":"135 Stat. 1909","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida74abd35-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida74abd36-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida74abd37-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 118a was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s118b"},"text":"section 118b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida74abd38-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1061/a/1"},"text":"Pub. L. 117–81, § 1061(a)(1)","children":[],"tail":", which directed renumbering of the “second section 118a” of this title, relating to quadrennial quality of life review, as "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s118b"},"text":"section 118b of this title","children":[],"tail":" could not be executed because there was no second "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s118a"},"text":"section 118a of this title","children":[],"tail":" after the renumbering of another "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s118a"},"text":"section 118a of this title","children":[],"tail":", relating to National Defense Sustainment and Logistics Review, as section 118b by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s311/b/1/B"},"text":"Pub. L. 117–81, § 311(b)(1)(B)","children":[],"tail":", (C). See 2021 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s118b"},"text":"section 118b of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1061/b"},"text":"Pub. L. 117–81, § 1061(b)","children":[],"tail":", which directed the addition of par. (15) to subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s118b"},"text":"section 118b of this title","children":[],"tail":", as redesignated by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1061/a/1"},"text":"Pub. L. 117–81, § 1061(a)(1)","children":[],"tail":", was executed by adding par. (15) to subsec. (c) of this section to reflect the probable intent of Congress. See above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3043"},"text":"50 U.S.C. 3043","children":[],"tail":")” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s404a"},"text":"50 U.S.C. 404a","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida74abd39-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida74abd3a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2021-12-31"},"text":"Dec. 31, 2021","children":[],"tail":", of provisions in subsec. (d) of this section requiring submittal of report to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1061"},"text":"section 1061 of Pub. L. 114–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s111"},"text":"section 111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida74abd3b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"First Quadrennial Quality of Life Review","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tV/s581/b"},"text":"Pub. L. 107–314, div. A, title V, § 581(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2561"},"text":"116 Stat. 2561","children":[],"tail":", directed that the first quadrennial quality of life review under this section would be conducted during 2003, and that the report on such review was to be submitted not later than the date on which the President submitted the budget for fiscal year 2005 to Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
