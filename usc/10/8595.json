{"tag":"section","attrib":{"id":"idab345421-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595"},"text":null,"children":[{"tag":"num","attrib":{"value":"8595"},"text":"§ 8595.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Naval Community College: establishment and degree granting authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab345422-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment and Function","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is a United States Naval Community College. The primary function of such College shall be to provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab345423-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" programs of academic instruction and professional and technical education for individuals described in subsection (b) in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab345424-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic and technical fields of the liberal arts and sciences which are relevant to the current and future needs of the Navy and Marine Corps, including in designated fields of national and economic importance such as cybersecurity, artificial intelligence, machine learning, data science, and software engineering; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab345425-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" their practical duties;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab345426-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remedial, developmental, or continuing education programs, as prescribed by the Secretary of the Navy, which are necessary to support, maintain, or extend programs under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab345427-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support and advisement services for individuals pursuing such programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab345428-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuous monitoring of the progress of such individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab345429-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Individuals Eligible for Programs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to such other eligibility requirements as the Secretary of the Navy may prescribe, the following individuals are eligible to participate in programs and services under subsection (a):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab34542a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enlisted members of the Navy and Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab34542b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Officers of the Navy and Marine Corps who hold a commission but have not completed a postsecondary degree.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab34542c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Civilian employees of the Department of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab34542d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Other individuals, as determined by the Secretary of the Navy, so long as access to programs and services under subsection (a) by such individuals is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab34542e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in alignment with the mission of the United States Naval Community College; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab34542f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined to support the mission or needs of the Department of the Navy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab345430-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Degree and Credential Granting Authority.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab345431-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under regulations prescribed by the Secretary of the Navy, the head of the United States Naval Community College may, upon the recommendation of the directors and faculty of the College, confer appropriate degrees or academic credentials upon graduates who meet the degree or credential requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab345432-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A degree or credential may not be conferred under this subsection unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab345433-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Education has recommended approval of the degree or credential in accordance with the Federal Policy Governing Granting of Academic Degrees by Federal Agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab345434-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Naval Community College is accredited by the appropriate civilian academic accrediting agency or organization to award the degree or credential, as determined by the Secretary of Education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab345435-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional notification requirements.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab345436-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When seeking to establish degree or credential granting authority under this subsection, the Secretary of Defense shall submit to the Committees on Armed Services of the Senate and House of Representatives—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idab345437-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the self assessment questionnaire required by the Federal Policy Governing Granting of Academic Degrees by Federal Agencies, at the time the assessment is submitted to the Department of Education’s National Advisory Committee on Institutional Quality and Integrity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab345438-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the subsequent recommendations and rationale of the Secretary of Education regarding the establishment of the degree or credential granting authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab345439-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon any modification or redesignation of existing degree or credential granting authority, the Secretary of Defense shall submit to the Committees on Armed Services of the Senate and House of Representatives a report containing the rationale for the proposed modification or redesignation and any subsequent recommendation of the Secretary of Education on the proposed modification or redesignation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab34543a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall submit to the Committees on Armed Services of the Senate and House of Representatives a report containing an explanation of any action by the appropriate academic accrediting agency or organization not to accredit the United States Naval Community College to award any new or existing degree or credential.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab34543b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civilian Faculty Members.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab34543c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy may employ as many civilians as professors, instructors, and lecturers at the United States Naval Community College as the Secretary considers necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab34543d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8595/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The compensation of persons employed under this subsection shall be prescribed by the Secretary of the Navy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab34543e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tV/s557/a"},"text":"Pub. L. 117–81, div. A, title V, § 557(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1739"},"text":"135 Stat. 1739","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
