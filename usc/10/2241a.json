{"tag":"section","attrib":{"id":"ida957566f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2241a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2241a"},"text":"§ 2241a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of funds for publicity or propaganda purposes within the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds available to the Department of Defense may not be obligated or expended for publicity or propaganda purposes within the United States not otherwise specifically authorized by law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida9575670-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tX/s1031/a/1"},"text":"Pub. L. 111–84, div. A, title X, § 1031(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2448"},"text":"123 Stat. 2448","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9575671-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9575672-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9575673-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tX/s1031/b"},"text":"Pub. L. 111–84, div. A, title X, § 1031(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2448"},"text":"123 Stat. 2448","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/84/dA/tX/s1031/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2241a"},"text":"Section 2241a of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall take effect on "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"October 1, 2009","children":[],"tail":", or the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":"], whichever is later.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
