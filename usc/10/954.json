{"tag":"section","attrib":{"id":"ida83df753-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s954"},"text":null,"children":[{"tag":"num","attrib":{"value":"954"},"text":"§ 954.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary extension; probation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary concerned may provide for persons who were subject to his authority at the time of commission of their offenses a system for retention of selected offenders beyond expiration of normal service obligation in order to voluntarily serve a period of probation with a view to honorable restoration to duty.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida83df754-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/377/s1"},"text":"Pub. L. 90–377, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-05"},"text":"July 5, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/288"},"text":"82 Stat. 288","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1073/a/12"},"text":"Pub. L. 105–85, div. A, title X, § 1073(a)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1900"},"text":"111 Stat. 1900","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida83df755-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida83df756-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida83df757-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" substituted “his authority” for “this authority”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
