{"tag":"section","attrib":{"id":"idabc82f93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20201"},"text":null,"children":[{"tag":"num","attrib":{"value":"20201"},"text":"§ 20201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Original appointments: how made","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabc82f94-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s531"},"text":"section 531 of this title","children":[],"tail":" shall apply to original appointments of commissioned officers in the Space Force."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc82f95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grade Upon Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc82f96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20201/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The grade of a person receiving an appointment under this section who at the time of appointment is credited with service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20203"},"text":"section 20203 of this title","children":[],"tail":" shall be determined under regulations prescribed by the Secretary of the Defense based upon the amount of service credited."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20201/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The grade of a person receiving an appointment under this section who at the time of the appointment is a commissioned officer of a reserve component shall be determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20203/e"},"text":"section 20203(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc82f98-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1716/a"},"text":"Pub. L. 118–31, div. A, title XVII, § 1716(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/631"},"text":"137 Stat. 631","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
