{"tag":"section","attrib":{"id":"ida74f9f37-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s123b"},"text":null,"children":[{"tag":"num","attrib":{"value":"123b"},"text":"§ 123b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forces stationed abroad: limitation on number","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida74f9f38-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s123b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"End-Strength Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No funds appropriated to the Department of Defense may be used to support a strength level of members of the armed forces assigned to permanent duty ashore in nations outside the United States at the end of any fiscal year at a level in excess of 203,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida74f9f39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s123b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for Wartime","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) does not apply in the event of a declaration of war or an armed attack on any member nation of the North Atlantic Treaty Organization, Japan, the Republic of Korea, or any other ally of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida74f9f3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s123b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presidential Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President may waive the operation of subsection (a) if the President declares an emergency. The President shall immediately notify Congress of any such waiver.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida74f9f3b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXIII/s1312/a/1"},"text":"Pub. L. 103–337, div. A, title XIII, § 1312(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2894"},"text":"108 Stat. 2894","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida74f9f3c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida74f9f3d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida74f9f3e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tXIII/s1302"},"text":"Pub. L. 102–484, div. A, title XIII, § 1302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2545"},"text":"106 Stat. 2545","children":[],"tail":", which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s113"},"text":"section 113 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1312/c"},"text":"Pub. L. 103–337, § 1312(c)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida74f9f3f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida74f9f40-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXIII/s1312/b"},"text":"Pub. L. 103–337, div. A, title XIII, § 1312(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2894"},"text":"108 Stat. 2894","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/337/dA/tXIII/s1312/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s123b"},"text":"Section 123b of title 10","children":[],"tail":", United States Code, as added by subsection (a), does not apply with respect to a fiscal year before fiscal year 1996.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
