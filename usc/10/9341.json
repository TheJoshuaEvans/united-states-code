{"tag":"section","attrib":{"id":"idab6d8bfa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9341"},"text":null,"children":[{"tag":"num","attrib":{"value":"9341"},"text":"§ 9341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab6d8bfb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9341/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab6d8bfc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9341/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The retired grade of a regular commissioned officer of the Air Force who retires other than for physical disability is determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1370"},"text":"section 1370 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab6d8bfd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9341/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The retired grade of a reserve commissioned officer of the Air Force who retires other than for physical disability is determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1370a"},"text":"section 1370a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab6d8bfe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9341/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Unless entitled to a higher retired grade under some other provision of law, a Regular or Reserve of the Air Force not covered by subsection (a) who retires other than for physical disability retires in the regular or reserve grade that the member holds on the date of the member’s retirement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab6d8bff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9341/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Space Force","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab6d8c00-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9341/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The retired grade of a commissioned officer of the Space Force who retires other than for physical disability is determined under section 1370 or 1370a of this title, as applicable to the officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab6d8c01-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9341/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Unless entitled to a higher retired grade under some other provision of law, a member of the Space Force not covered by paragraph (1) who retires other than for physical disability retires in the grade that the member holds on the date of the member’s retirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab6d8c02-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/554"},"text":"70A Stat. 554","children":[],"tail":", § 8961; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s504/19"},"text":