{"tag":"section","attrib":{"id":"ida8d443cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1461"},"text":null,"children":[{"tag":"num","attrib":{"value":"1461"},"text":"§ 1461.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purpose of Fund; definition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8d443cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1461/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established on the books of the Treasury a fund to be known as the Department of Defense Military Retirement Fund (hereinafter in this chapter referred to as the “Fund”), which shall be administered by the Secretary of the Treasury. The Fund shall be used for the accumulation of funds in order to finance on an actuarially sound basis liabilities of the Department of Defense and the Coast Guard under military retirement and survivor benefit programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8d443cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1461/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this chapter, the term “military retirement and survivor benefit programs” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8d443ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1461/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of this title creating entitlement to, or determining the amount of, retired or retainer pay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d443cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1461/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the programs under the jurisdiction of the Department of Defense providing annuities for survivors of members and former members of the armed forces, including chapter 73 of this title, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/425/s4"},"text":"section 4 of Public Law 92–425","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/96/402/s5"},"text":"section 5 of Public Law 96–402","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d443d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1461/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1408/h"},"text":"section 1408(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8d443d1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/tIX/s925/a/1"},"text":"Pub. L. 98–94, title IX, § 925(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/644"},"text":"97 Stat. 644","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXVI/s1622/e/7"},"text":"Pub. L. 101–189, div. A, title XVI, § 1622(e)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1605"},"text":"103 Stat. 1605","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tVI/s653/b/1"},"text":"Pub. L. 102–484, div. A, title VI, § 653(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"