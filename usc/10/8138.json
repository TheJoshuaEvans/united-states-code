{"tag":"section","attrib":{"id":"idab1078c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8138"},"text":null,"children":[{"tag":"num","attrib":{"value":"8138"},"text":"§ 8138.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regular Marine Corps: judge advocates","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"With the approval of the Secretary of the Navy, any regular officer on the active-duty list of the Marine Corps who is qualified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s827/b"},"text":"section 827(b) of this title","children":[],"tail":" may, upon his application, be designated as a judge advocate."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab1078c6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/179/s5/3"},"text":"Pub. L. 90–179, § 5(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-08"},"text":"Dec. 8, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/548"},"text":"81 Stat. 548","children":[],"tail":", § 5587a; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s503/30"},"text":"Pub. L. 96–513, title V, § 503(30)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2913"},"text":"94 Stat. 2913","children":[],"tail":"; renumbered § 8138, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/4"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1834"},"text":"132 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab1078c7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children"