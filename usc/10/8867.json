{"tag":"section","attrib":{"id":"idab50dce8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8867"},"text":null,"children":[{"tag":"num","attrib":{"value":"8867"},"text":"§ 8867.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of prize property to another district for sale","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab50dce9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8867/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of any prize property ordered to be sold, if the court believes that it will be in the interest of all parties to have the property sold in a judicial district other than the one in which the proceedings are pending, the court may direct the marshal to transfer the property to the district selected by the court for the sale, and to insure it. In such a case the court shall give the marshal proper orders as to the time and manner of conducting the sale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab50dcea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8867/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When so ordered the marshal shall transfer the property and keep it safely. He is responsible for its sale in the same manner as if the property were in his own district and for the deposit of the gross proceeds with the Treas­urer of the United States or public depositary nearest to the place of sale, subject to the order of the court for the district where the adjudication is pending.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab50dceb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8867/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The necessary expenses of insuring, transferring, receiving, keeping, and selling the property are a charge upon it and upon the proceeds. Whenever any such expense is paid in advance by the marshal, any amount not repaid to him from the proceeds shall be allowed to him as in the case of expenses incurred in suits in which the United States is a party.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab50dcec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8867/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary of the Navy believes that it will be in the interest of all parties to have the property sold in a judicial district other than the one in which the proceedings are pending, he may, either by a general regulation or by a special direction in the cause, require the marshal to transfer the property from the district in which the judicial proceedings are pending to any other district for sale. In such a case proceedings shall be had as if the transfer had been made by order of the court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab50dced-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/479"},"text":"70A Stat. 479","children":[],"tail":", § 7667; renumbered § 8867, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/9"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab50dcee-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab50dcef-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab50dcf0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7667","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s1145"},"text":"34 U.S.C. 1145","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 4629.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s1145"},"text":"34 U.S.C. 1145","children":[],"tail":" and this section reflect the "},{"tag":"ref","attrib":{"href":"/us/act/1920-05-29/ch214/s1"},"text":"Act of May 29, 1920, ch. 214, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/654"},"text":"41 Stat. 654","children":[],"tail":", which requires substitution of “Treasurer of the United States or public depositary” for “assistant treasurer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b) the words “He is responsible for its sale” are substituted for the words “It shall be the duty of the marshal to * * * sell the same”, because, as shown in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7666"},"text":"§ 7666 of this title","children":[],"tail":", the marshal does not sell the property himself but supervises the auctioneer who conducts the sale."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab50dcf1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab50dcf2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7667"},"text":"section 7667 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab50dcf3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab50dcf4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
