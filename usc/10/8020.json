{"tag":"section","attrib":{"id":"idab07025b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8020"},"text":null,"children":[{"tag":"num","attrib":{"value":"8020"},"text":"§ 8020.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Naval Inspector General: detail; duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab07025c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8020/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is in the Office of the Secretary of the Navy the Office of the Naval Inspector General. The Naval Inspector General shall be detailed from officers on the active-duty list in the line of the Navy serving in grades above captain.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab07025d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8020/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Naval Inspector General, when directed, shall inquire into and report upon any matter that affects the discipline or military efficiency of the Department of the Navy. He shall make such inspections, investigations, and reports as the Secretary of the Navy or the Chief of Naval Operations directs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab07025e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8020/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Naval Inspector General shall cooperate fully with the Inspector General of the Department of Defense in connection with the performance of any duty or function by the Inspector General of the Department of Defense under chapter 4 of title 5 regarding the Department of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab07025f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8020/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Naval Inspector General shall periodically propose programs of inspections to the Secretary of the Navy and shall recommend additional inspections and investigations as may appear appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab070260-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/283"},"text":"70A Stat. 283","children":[],"tail":", § 5088; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s503/7"},"text":"Pub. L. 96–513, title V, § 503(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2911"},"text":"94 Stat. 2911","children":[],"tail":"; renumbered § 5020 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s511/c/5"},"text":"Pub. L. 99–433, title V, § 511(c)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1047"},"text":"100 Stat. 1047","children":[],"tail":"; renumbered § 8020, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/a/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1834"},"text":"132 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/31"},"text":"Pub. L. 117–286, § 4(b)(31)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4346"},"text":"136 Stat. 4346","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab070261-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab070262-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab070263-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5088(a), (b), (c)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s423f"},"text":"5 U.S.C. 423f","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1948-03-05/ch98/s6"},"text":"Mar. 5, 1948, ch. 98, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/62/68"},"text":"62 Stat. 68","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5088(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s423k"},"text":"5 U.S.C. 423k","children":[],"tail":" (as applicable to the Naval Inspector General)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1948-03-05/ch98/s11"},"text":"Mar. 5, 1948, ch. 98, § 11","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/62/69"},"text":"62 Stat. 69","children":[],"tail":" (as applicable to the Naval Inspector General)."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words “In addition to the divisions herein created” are omitted as surplusage. The word “detailed” is added in order to show that the position of the Inspector General is not an appointive office.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c) the words “from time to time” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (d) is worded to make clear that the Naval Inspector General may be designated, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s211d"},"text":"34 U.S.C. 211d","children":[],"tail":", as an officer who performs unusual or special duty, and, if so designated, is entitled to the grade, pay, and retirement privilege accompanying the special designation. The words “under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s5231"},"text":"section 5231 of this title","children":[],"tail":"” are substituted for the words “grade, rank, pay, and allowances provided under any provision of law heretofore or hereafter enacted which authorizes such grade, rank, pay, and allowances for officers so designated”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab070264-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab070265-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8020 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9020"},"text":"section 9020 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 8021 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9021"},"text":"section 9021 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 8021 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s10305"},"text":"section 10305 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab070266-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 4 of title 5” for “the Inspector General Act of 1978 (5 U.S.C. App. 3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s5020"},"text":"section 5020 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/s511/c/5/A"},"text":"Pub. L. 99–433, § 511(c)(5)(A)","children":[],"tail":", substituted “Office of the Secretary of Navy” for “Office of the Chief of Naval Operations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/s511/c/5/B"},"text":"Pub. L. 99–433, § 511(c)(5)(B)","children":[],"tail":", (C), added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/s511/c/5/B"},"text":"Pub. L. 99–433, § 511(c)(5)(B)","children":[],"tail":", redesignated former subsec. (c) as (d) and substituted “Secretary of the Navy” for “Chief of Naval Operations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s503/7/A"},"text":"Pub. L. 96–513, § 503(7)(A)","children":[],"tail":", substituted “active-duty list” for “active list”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s503/7/B"},"text":"Pub. L. 96–513, § 503(7)(B)","children":[],"tail":", struck out subsec. (d) which authorized the President to designate the Naval Inspector General as an officer who performs special or unusual duty or duty of great importance and responsibility under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s5231"},"text":"section 5231 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab070267-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab070268-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab070269-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701"},"text":"section 701 of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
