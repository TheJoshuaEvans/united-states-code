{"tag":"section","attrib":{"id":"idaa863a27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4656"},"text":null,"children":[{"tag":"num","attrib":{"value":"4656"},"text":"§ 4656.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on persons convicted of defense-contract related felonies and related criminal penalty on defense contractors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa863a28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4656/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa863a29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4656/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An individual who is convicted of fraud or any other felony arising out of a contract with the Department of Defense shall be prohibited from each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa863a2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4656/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Working in a management or supervisory capacity on any defense contract or any first tier subcontract of a defense contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa863a2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4656/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Serving on the board of directors of any defense contractor or any subcontractor awarded a contract directly by a defense contractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa863a2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4656/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Serving as a consultant to any defense contractor or any subcontractor awarded a contract directly by a defense contractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa863a2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4656/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Being involved in any other way, as determined under regulations prescribed by the Secretary of Defense, with a defense contract or first tier subcontract of a defense contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa863a2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4656/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (3), the prohibition in paragraph (1) shall apply for a period, as determined by the Secretary of Defense, of not less than five years after the date of the conviction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa863a2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4656/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The prohibition in paragraph (1) may apply with respect to an individual for a period of less than five years if the Secretary determines that the five-year period should be waived in the interests of national security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa863a30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4656/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The prohibition in paragraph (1) does not apply with respect to the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa863a31-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4656/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contract referred to in subparagraph (A), (B), (C), or (D) of such paragraph that is not greater than the simplified acquisition threshold (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s134"},"text":"section 134 of title 41","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa863a32-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4656/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contract referred to in such subparagraph that is for the acquisition of commercial products or commercial services (as defined in sections 103 and 103a, respectively, of title 41).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa863a33-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4656/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A subcontract referred to in such subparagraph that is under a contract described in subparagraph (A) or (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa863a34-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4656/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A defense contractor or subcontractor shall be subject to a criminal penalty of not more than $500,000 if such contractor or subcontractor is convicted of knowingly—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa863a35-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4656/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employing a person under a prohibition under subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa863a36-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4656/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allowing such a person to serve on the board of directors of such contractor or subcontractor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa863a37-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4656/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Single Point of Contact for Information","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa863a38-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4656/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall ensure that a single point of contact is established to enable a defense contractor or subcontractor to promptly obtain information regarding whether a person that the contractor or subcontractor proposes to use for an activity covered by paragraph (1) of subsection (a) is under a prohibition under that subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa863a39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4656/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The procedure for obtaining such information shall be specified in regulations prescribed by the Secretary of Defense under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa863a3a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/c/tX/s941/a/1"},"text":"Pub. L. 99–500, § 101(c) [title X, § 941(a)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-82"},"text":"100 Stat. 1783–82","children":[],"tail":", 1783–161, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/c/tX/s941/a/1"},"text":"Pub. L. 99–591, § 101(c) [title X, § 941(a)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-82"},"text":"100 Stat. 3341–82","children":[],"tail":", 3341–161, § 2408; "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tIX"},"text":"Pub. L. 99–661, div. A, title IX","children":[],"tail":", formerly title IV, § 941(a)(1), "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3941"},"text":"100 Stat. 3941","children":[],"tail":", renumbered title IX, "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s3/5"},"text":"Pub. L. 100–26, § 3(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/273"},"text":"101 Stat. 273","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tVIII/s831/a"},"text":"Pub. L. 100–456, div. A, title VIII, § 831(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2023"},"text":"102 Stat. 2023","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tVIII/s812"},"text":"Pub. L. 101–510, div. A, title VIII, § 812","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1596"},"text":"104 Stat. 1596","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tVIII/s815/a"},"text":"Pub. L. 102–484, div. A, title VIII, § 815(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2454"},"text":"106 Stat. 2454","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/tIV/s4102/g"},"text":"Pub. L. 103–355, title IV, § 4102(g)","children":[],"tail":", title VIII, § 8105(h), "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3340"},"text":"108 Stat. 3340","children":[],"tail":", 3393; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tX/s1062/e"},"text":"Pub. L. 104–106, div. A, title X, § 1062(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/444"},"text":"110 Stat. 444","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/b/26"},"text":"Pub. L. 111–350, § 5(b)(26)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3844"},"text":"124 Stat. 3844","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s836/e/5"},"text":"Pub. L. 115–232, div. A, title VIII, § 836(e)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1870"},"text":"132 Stat. 1870","children":[],"tail":"; renumbered § 4656, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1862/b"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1862(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4277"},"text":"134 Stat. 4277","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa863a3b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa863a3c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa863a3d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":" is a corrected version of "},{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" added identical sections."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa863a3e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4656 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7656"},"text":"section 7656 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa863a3f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2408"},"text":"section 2408 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “commercial products or commercial services (as defined in sections 103 and 103a, respectively, of title 41)” for “commercial items (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s103"},"text":"section 103 of title 41","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/b/26/A"},"text":"Pub. L. 111–350, § 5(b)(26)(A)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t41/s134"},"text":"section 134 of title 41","children":[],"tail":")” for “section 4(11) of the Office of Federal Procurement Policy Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s403/11"},"text":"41 U.S.C. 403(11)","children":[],"tail":"))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/b/26/B"},"text":"Pub. L. 111–350, § 5(b)(26)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t41/s103"},"text":"section 103 of title 41","children":[],"tail":")” for “section 4(12) of the Office of Federal Procurement Policy Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s403/12"},"text":"41 U.S.C. 403(12)","children":[],"tail":"))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" struck out at end “If the five-year period is waived, the Secretary shall submit to Congress a report stating the reasons for the waiver.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355/s4102/g"},"text":"Pub. L. 103–355, § 4102(g)","children":[],"tail":", added introductory provisions and subpar. (A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355/s8105/h/1"},"text":"Pub. L. 103–355, § 8105(h)(1)","children":[],"tail":", added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355/s8105/h/2"},"text":"Pub. L. 103–355, § 8105(h)(2)","children":[],"tail":", inserted “or (B)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355/s4102/g"},"text":"Pub. L. 103–355, § 4102(g)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s812/a/1"},"text":"Pub. L. 101–510, § 812(a)(1)","children":[],"tail":", inserted before period at end “or any first tier subcontract of a defense contract”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s812/a/2"},"text":"Pub. L. 101–510, § 812(a)(2)","children":[],"tail":", inserted before period at end “or any subcontractor awarded a contract directly by a defense contractor”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s812/a/3"},"text":"Pub. L. 101–510, § 812(a)(3)","children":[],"tail":", inserted before period at end “or any subcontractor awarded a contract directly by a defense contractor”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s812/a/4"},"text":"Pub. L. 101–510, § 812(a)(4)","children":[],"tail":", inserted before period at end “or first tier subcontract of a defense contract”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s812/b"},"text":"Pub. L. 101–510, § 812(b)","children":[],"tail":", inserted “or subcontractor” after “contractor” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “A person who is convicted of fraud or any other felony arising out of a contract with the Department of Defense shall be prohibited from working in a management or supervisory capacity on any defense contract, or serving on the board of directors of any defense contractor, for a period, as determined by the Secretary of Defense, of not less than one year from the date of the conviction.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa863a40-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa863a41-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa863a42-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2020-01-01"},"text":"Jan. 1, 2020","children":[],"tail":", subject to a savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s836/h"},"text":"section 836(h) of Pub. L. 115–232","children":[],"tail":", set out as an Effective Date of 2018 Amendment;