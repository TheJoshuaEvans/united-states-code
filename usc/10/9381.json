{"tag":"section","attrib":{"id":"idab6fd6ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9381"},"text":null,"children":[{"tag":"num","attrib":{"value":"9381"},"text":"§ 9381.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fatality reviews","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab6fd6ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9381/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of Fatalities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Air Force shall conduct a multidisciplinary, impartial review (referred to as a “fatality review”) in the case of each fatality known or suspected to have resulted from domestic violence or child abuse against any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab6fd6af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9381/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Air Force or the Space Force on active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab6fd6b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9381/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A current or former dependent of a member of the Air Force or the Space Force on active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab6fd6b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9381/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A current or former intimate partner who has a child in common or has shared a common domicile with a member of the Air Force or the Space Force on active duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab6fd6b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9381/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matters To Be Included","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report of a fatality review under subsection (a) shall, at a minimum, include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab6fd6b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9381/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An executive summary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab6fd6b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9381/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Data setting forth victim demographics, injuries, autopsy findings, homicide or suicide methods, weapons, police information, assailant demographics, and household and family information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab6fd6b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9381/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Legal disposition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab6fd6b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9381/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" System intervention and failures, if any, within the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab6fd6b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9381/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A discussion of significant findings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab6fd6b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9381/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommendations for systemic changes, if any, within the Department of the Air Force and the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab6fd6b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9381/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" OSD ","children":[{"tag":"inline","attrib":{},"text":"Guidance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe guidance, which shall be uniform for the military departments, for the conduct of reviews by the Secretary under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab6fd6ba-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tV/s576/c/1"},"text":"Pub. L. 108–136, div. A, title V, § 576(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1488"},"text":"117 Stat. 1488","children":[],"tail":", § 9061; renumbered § 9381, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/b/17"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(b)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1833"},"text":"132 Stat. 1833","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s923/c/23"},"text":"Pub. L. 116–283, div. A, title IX, § 923(c)(23)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3813"},"text":"134 Stat. 3813","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab6fd6bb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab6fd6bc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab6fd6bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 9381 to 9383 were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1241/i/2"},"text":"Pub. L. 114–328, div. A, title XII, § 1241(i)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2508"},"text":"130 Stat. 2508","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 9381, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tXI/s1178/b"},"text":"Pub. L. 103–160, div. A, title XI, § 1178(b)","children"