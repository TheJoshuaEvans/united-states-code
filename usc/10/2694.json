{"tag":"section","attrib":{"id":"ida9bb9666-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694"},"text":null,"children":[{"tag":"num","attrib":{"value":"2694"},"text":"§ 2694.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation and cultural activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9bb9667-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may establish and carry out a program to conduct and manage in a coordinated manner the conservation and cultural activities described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9bb9668-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9bb9669-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A conservation or cultural activity eligible for the program that the Secretary establishes under subsection (a) is any activity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9bb966a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has regional or Department of Defense-wide significance and that involves more than one military department or involves a sentinel landscape;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9bb966b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is necessary to meet legal requirements or to support military operations or that would contribute to maintaining or improving military installation resilience;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9bb966c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that can be more effectively managed at the Department of Defense level; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9bb966d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which no executive agency has been designated responsible by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9bb966e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such activities include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9bb966f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The development of ecosystem-wide land management plans or nature-based climate resilience plans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9bb9670-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The conduct of wildlife studies to ensure the safety and sustainability of military operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9bb9671-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The identification and return of Native American human remains and cultural items in the possession or control of the Department of Defense, or discovered on land under the jurisdiction of the Department, to the appropriate Native American tribes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9bb9672-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The control of invasive species that may hinder military activities or degrade military training ranges.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9bb9673-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The establishment of a regional curation system for artifacts found on military installations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9bb9674-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The implementation of ecosystem-wide land management plans—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9bb9675-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694/b/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for a single ecosystem—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ida9bb9676-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694/b/2/F/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that encompasses at least two non-contiguous military installations, if those military installations are not all under the administrative jurisdiction of the same Secretary of a military department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ida9bb9677-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694/b/2/F/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing synergistic benefits unavailable if the installations acted separately; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9bb9678-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694/b/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for one or more ecosystems within a sentinel landscape.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9bb9679-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperative Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may negotiate and enter into cooperative agreements with public and private agencies, organizations, institutions, individuals, or other entities to carry out the program established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9bb967a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on Other Laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed or interpreted as preempting any otherwise applicable Federal, State, or local law or regulation relating to the management of natural and cultural resources on military installations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9bb967b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sentinel Landscape Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “sentinel landscape” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2693/g"},"text":"section 2693(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9bb967c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tIII/s332/a/1"},"text":"Pub. L. 104–201, div. A, title III, § 332(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2484"},"text":"110 Stat. 2484","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1073/a/59"},"text":"Pub. L. 105–85, div. A, title X, § 1073(a)(59)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1903"},"text":"111 Stat. 1903","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dB/tXXVIII/s2814"},"text":"Pub. L. 112–81, div. B, title XXVIII, § 2814","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1688"},"text":"125 Stat. 1688","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tIII/s317/c"},"text":"Pub. L. 117–81, div. A, title III, § 317(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1632"},"text":"135 Stat. 1632","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tIII/s311/c/2"},"text":"Pub. L. 118–31, div. A, title III, § 311(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/215"},"text":"137 Stat. 215","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9bb967d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9bb967e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9bb967f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" substituted “meaning given that term in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2693/g"},"text":"section 2693(g) of this title","children":[],"tail":"” for “meaning given that term in section 317(f) of the National Defense Authorization Act for Fiscal Year 2018 ("},{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Public Law 115–91","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2684a"},"text":"10 U.S.C. 2684a","children":[],"tail":" note)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s317/c/1/A/i"},"text":"Pub. L. 117–81, § 317(c)(1)(A)(i)","children":[],"tail":", inserted “or involves a sentinel landscape” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s317/c/1/A/ii"},"text":"Pub. L. 117–81, § 317(c)(1)(A)(ii)","children":[],"tail":", inserted “or that would contribute to maintaining or improving military installation resilience” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s317/c/1/B/i"},"text":"Pub. L. 117–81, § 317(c)(1)(B)(i)","children":[],"tail":", inserted “or nature-based climate resilience plans” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(F)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s317/c/1/B/ii/I"},"text":"Pub. L. 117–81, § 317(c)(1)(B)(ii)(I)","children":[],"tail":", inserted a dash after “single ecosystem”, designated remaining existing provisions as subcl. (I), redesignated provisions of existing cl. (ii) as subcl. (II) of cl. (i), and realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(F)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s317/c/1/B/ii/II"},"text":"Pub. L. 117–81, § 317(c)(1)(B)(ii)(II)","children":[],"tail":", added cl. (ii). Former cl. (ii) redesignated cl. (i)(II)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s317/c/2"},"text":"Pub. L. 117–81, § 317(c)(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s2814/1"},"text":"Pub. L. 112–81, § 2814(1)","children":[],"tail":", inserted “and sustainability” after “safety”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s2814/2"},"text":"Pub. L. 112–81, § 2814(2)","children":[],"tail":", added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" substituted “executive agency” for “executive ageny”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9bb9680-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9bb9681-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tIII/s332/b"},"text":"Pub. L. 104–201, div. A, title III, § 332(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2485"},"text":"110 Stat. 2485","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/201/dA/tIII/s332/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2694"},"text":"Section 2694 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall take effect on "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"October 1, 1996","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
