{"tag":"section","attrib":{"id":"ida9f25ee9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2903"},"text":null,"children":[{"tag":"num","attrib":{"value":"2903"},"text":"§ 2903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Director","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9f25eea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be an Executive Director of the Council appointed by the Secretary of Defense after consultation with the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9f25eeb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the authority, direction, and control of the Secretary of Defense, the Executive Director is responsible for the management of the Strategic Environmental Research and Development Program in accordance with the policies established by the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9f25eec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Executive Director may enter into contracts using competitive procedures. The Executive Director may enter into other agreements in accordance with applicable law. In either case, the Executive Director shall first obtain the approval of the Council for any contract or agreement in an amount equal to or in excess of $500,000 or such lesser amount as the Council may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9f25eed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2903/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9f25eee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2903/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Executive Director, with the concurrence of the Council, may appoint such professional and clerical staff as may be necessary to carry out the responsibilities and policies of the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9f25eef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2903/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Executive Director, with the concurrence of the Council and without regard to the provisions of chapter 51 of title 5 and subchapter III of chapter 53 of such title, may establish the rates of basic pay for professional, scientific, and technical employees appointed pursuant to paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9f25ef0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXVIII/s1801/a/1"},"text":"Pub. L. 101–510, div. A, title XVIII, § 1801(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1755"},"text":"104 Stat. 1755","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/25/tVII/s701/h/2"},"text":"Pub. L. 102–25, title VII, § 701(h)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-04-06"},"text":"Apr. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/115"},"text":"105 Stat. 115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tII/s265/b"},"text":"Pub. L. 103–160, div. A, title II, § 265(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1611"},"text":"107 Stat. 1611","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tII/s203/d"},"text":"Pub. L. 104–106, div. A, title II, § 203(d)","children":[],"tail":", (e)(1), "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/218"},"text":"110 Stat. 218","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9f25ef1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9f25ef2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9f25ef3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s203/d"},"text":"Pub. L. 104–106, § 203(d)","children":[],"tail":", substituted “contracts using competitive procedures. The Executive Director may enter into” for “contracts or” and “law. In either case,” for “law, except that”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s203/e/1"},"text":"Pub. L. 104–106, § 203(e)(1)","children":[],"tail":", struck out at end “The authority provided in the preceding sentence shall expire on "},{"tag":"date","attrib":{"date":"1995-09-30"},"text":"September 30, 1995","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1995-09-30"},"text":"September 30, 1995","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1992-11-05"},"text":"November 5, 1992","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L. 102–25","children":[],"tail":" substituted “on "},{"tag":"date","attrib":{"date":"1992-11-05"},"text":"November 5, 1992","children":[],"tail":"” for “two years after the date of the enactment of the National Defense Authorization Act for Fiscal Year 1991”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9f25ef4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9f25ef5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tII/s203/e/2"},"text":"Pub. L. 104–106, div. A, title II, § 203(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/218"},"text":"110 Stat. 218","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/106/dA/tII/s203/e/2"},"text":"“The amendment made by paragraph (1) [amending this secti