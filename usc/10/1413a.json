8/s5304"},"text":"section 5304 of Title 38","children":[],"tail":", Veterans’ Benefits, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s212"},"text":"section 212 of Title 42","children":[],"tail":", The Public Health and Welfare], to which the amendment made by subsection (a) relates.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8c37af3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76"},"text":"Pub. L. 113–76","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-01"},"text":"Dec. 1, 2015","children":[],"tail":", immediately after the coming into effect of "},{"tag":"ref","attrib":{"href":"/us/pl/113/67/s403"},"text":"section 403 of Pub. L. 113–67","children":[],"tail":" and the amendments made by that section, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/76/s10001/c"},"text":"section 10001(c) of Pub. L. 113–76","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1401a"},"text":"section 1401a of this title","children":[],"tail":". Amendment did not take effect pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/s631/d/2"},"text":"section 631(d)(2) of Pub. L. 114–92","children":[],"tail":", set out as a Repeal of Reduced Cost-of-living Adjustments for Members Under the Age of 62 note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1401a"},"text":"section 1401a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8c37af4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tVI/s643/b"},"text":"Pub. L. 112–239, div. A, title VI, § 643(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1783"},"text":"126 Stat. 1783","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/239/dA/tVI/s643/b"},"text":"“The amendment made by this section [amending this section] shall take effect as of ","children":[{"tag":"date","attrib":{"date":"2013-01-01"},"text":"January 1, 2013","children":[],"tail":", and shall apply to payments for months beginning on or after that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8c37af5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVI/s641/c"},"text":"Pub. L. 110–181, div. A, title VI, § 641(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/156"},"text":"122 Stat. 156","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/181/dA/tVI/s641/c"},"text":"“The amendments made by this section [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2008-01-01"},"text":"January 1, 2008","children":[],"tail":", and shall apply to payments for months beginning on or after that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8c37af6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tVI/s641/c/6"},"text":"Pub. L. 108–136, div. A, title VI, § 641(c)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1516"},"text":"117 Stat. 1516","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/136/dA/tVI/s641/c/6"},"text":"“The amendments made by this subsection [amending this section and sections 1413, 1463, 1465, and 1466 of this title] shall take effect as of ","children":[{"tag":"date","attrib":{"date":"2003-10-01"},"text":"October 1, 2003","children":[],"tail":". The Secretary of Defense shall provide for such administrative adjustments as necessary to provide for payments made for any period during fiscal year 2004 before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":"] to be treated as having been made in accordance with such amendments and for the provisions of such amendments to be implemented as if enacted as of "},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"September 30, 2003","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tVI/s642/f"},"text":"Pub. L. 108–136, div. A, title VI, § 642(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1517"},"text":"117 Stat. 1517","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/136/dA/tVI/s642/f"},"text":"“The amendments made by subsections (a), (b), and (c) [amending this section] shall apply to payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1413a"},"text":"section 1413a of title 10","children":[],"tail":", United States Code, for months beginning on or after "},{"tag":"date","attrib":{"date":"2004-01-01"},"text":"January 1, 2004","children":[],"tail":". The amendment made by subsection (d) [amending this section] shall take effect on "},{"tag":"date","attrib":{"date":"2004-01-01"},"text":"January 1, 2004","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8c37af7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tVI/s636/a/2"},"text":"Pub. L. 107–314, div. A, title VI, § 636(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2576"},"text":"116 Stat. 2576","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/314/dA/tVI/s636/a/2"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1413a"},"text":"Section 1413a of title 10","children":[],"tail":", United States Code, as added by paragraph (1), shall take effect not later than 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8c37af8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Clarification of Eligibility of Members of the Coast Guard for Combat-Related Special Compensation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/tII/s221"},"text":"Pub. L. 114–120, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/48"},"text":"130 Stat. 48","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXIV/s11404/c"},"text":"Pub. L. 117–263, div. K, title CXIV, § 11404(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4110"},"text":"136 Stat. 4110","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXII/s7201/k/2"},"text":"Pub. L. 119–60, div. G, title LXXII, § 7201(k)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1687"},"text":"139 Stat. 1687","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dG/tLXXII/s7201/k/2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration of Eligibility.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":"], the Secretary of the department in which the Coast Guard is operating shall issue procedures and criteria to use in determining whether the disability of a member of the Coast Guard is a combat-related disability for purposes of the eligibility of such member for combat-related special compensation under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1413a"},"text":"section 1413a of title 10","children":[],"tail":", United States Code. Such procedures and criteria shall include the procedures and criteria prescribed by the Secretary of Defense pursuant to subsection (e)(2) of such section. Such procedures and criteria shall apply in determining whether the disability of a member of the Coast Guard is a combat-related disability for purposes of determining the eligibility of such member for combat-related special compensation under such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disability for which a determination is made","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section, and in the case of a member of the Coast Guard, a disability under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1413a/e/2/B"},"text":"section 1413a(e)(2)(B) of title 10","children":[],"tail":", United States Code, includes a disability incurred during aviation duty, diving duty, rescue swimmer or similar duty, hazardous service duty onboard a small vessel (such as duty as a surfman), or a duty in which chemical or other hazardous material exposure has occurred (such as during marine inspections or pollution response activities)—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the performance of duties for which special or incentive pay was paid pursuant to section 301, 301a, 304, 307, 334, or 351 of title 37, United States Code;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the performance of duties related to a statutory mission of the Coast Guard under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s102"},"text":"section 102 of title 14","children":[],"tail":", United States Code; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while engaged in a training exercise for the performance of a duty described in subparagraphs (A) and (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Procedures and Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The procedures and criteria issued pursuant to subsection (a) shall apply to disabilities described in that subsection that are incurred on or after the effective date provided in section 636(a)(2) of the Bob Stump National Defense Authorization Act for Fiscal Year 2003 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Public Law 107–314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/116/2574"},"text":"116 Stat. 2574","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1413a"},"text":"10 U.S.C. 1413a","children":[],"tail":" note) [See Effective Date note above]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reapplication for Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any member of the Coast Guard who was denied combat-related special compensation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1413a"},"text":"section 1413a of title 10","children":[],"tail":", United States Code, during the period beginning on the effective date specified in subsection (b) and ending on the date of the issuance of the procedures and criteria required by subsection (a) may reapply for combat-related special compensation under such section on the basis of such procedures and criteria in accordance with such procedures as the Secretary of the department in which the Coast Guard is operating shall specify.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
