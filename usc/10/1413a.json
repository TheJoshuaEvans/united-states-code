{"tag":"section","attrib":{"id":"ida8c37ad4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1413a"},"text":"§ 1413a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Combat-related special compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8c37ad5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall pay to each eligible combat-related disabled uniformed services retiree who elects benefits under this section a monthly amount for the combat-related disability of the retiree determined under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8c37ad6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8c37ad7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of monthly amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraphs (2) and (3), the monthly amount to be paid an eligible combat-related disabled uniformed services retiree under subsection (a) for any month is the amount of compensation to which the retiree is entitled under title 38 for that month, determined without regard to any disability of the retiree that is not a combat-related disability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8c37ad8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount paid to an eligible combat-related disabled uniformed services retiree for any month under paragraph (1) may not exceed the amount of the reduction in retired pay that is applicable to the retiree for that month under sections 5304 and 5305 of title 38.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8c37ad9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rules for chapter","children":[],"tail":" 61 "},{"tag":"inline","attrib":{},"text":"disability retirees","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8c37ada-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of an eligible combat-related disabled uniformed services retiree who is retired under chapter 61 of this title, the amount of the payment under paragraph (1) for any month may not, when combined with the amount of retired pay payable to the retiree after any such reduction under sections 5304 and 5305 of title 38, cause the total of such combined payment to exceed the amount of retired pay to which the member would have been entitled under any other provision of law based upon the member’s service in the uniformed services if the member had not been retired under chapter 61 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8c37adb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule for retirees with fewer than 20 years of service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of an eligible combat-related disabled uniformed services retiree who is retired under chapter 61 of this title with fewer than 20 years of creditable service, the amount of the payment under paragraph (1) for any month may not, when combined with the amount of retired pay payable to the retiree after any such reduction under sections 5304 and 5305 of title 38, cause the total of such combined payment to exceed the amount equal to the retired pay percentage (determined for the member under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1409/b"},"text":"section 1409(b) of this title","children":[],"tail":") of the member’s years of creditable service multiplied by the member’s retired pay base under section 1406(b)(1) or 1407 of this title, whichever is applicable to the member."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8c37adc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Retirees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, an eligible combat-related disabled uniformed services retiree referred to in subsection (a) is a member of the uniformed services who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8c37add-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to retired pay (other than by reason of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12731b"},"text":"section 12731b of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8c37ade-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a combat-related disability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8c37adf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe procedures and criteria under which a disabled uniformed services retiree may apply to the Secretary of a military department to be considered to be an eligible combat-related disabled uniformed services retiree. Such procedures shall apply uniformly throughout the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8c37ae0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Combat-Related Disability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “combat-related disability” means a disability that is compensable under the laws administered by the Secretary of Veterans Affairs and that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8c37ae1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is attributable to an injury for which the member was awarded the Purple Heart; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8c37ae2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" was incurred (as determined under criteria prescribed by the Secretary of Defense)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8c37ae3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a direct result of armed conflict;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8c37ae4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while engaged in hazardous service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8c37ae5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the performance of duty under conditions simulating war; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8c37ae6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through an instrumentality of war.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8c37ae7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination With Concurrent Receipt Provision","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1414"},"text":"section 1414 of this title","children":[],"tail":" provides for coordination between benefits under that section and under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8c37ae8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Status of Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Payments under this section are not retired pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8c37ae9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Source of Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Payments under this section for a member of the Army, Navy, Air Force, Marine Corps, or Space Force shall be paid from the Department of Defense Military Retirement Fund. Payments under this section for any other member for any fiscal year shall be paid out of funds appropriated for pay and allowances payable by the Secretary concerned for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8c37aea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8c37aeb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “service-connected” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8c37aec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1413a/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “retired pay” includes retainer pay, emergency officers’ retirement pay, and naval pension.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8c37aed-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tVI/s636/a/1"},"text":"Pub. L. 107–314, div. A, title VI, § 636(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2574"},"text":"116 Stat. 2574","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tVI"},"text":"Pub. L. 108–136, div. A, title VI","children":[],"tail":", §§ 641(c)(1), 642(a)–(e)(1), "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1514"},"text":"117 Stat. 1514","children":[],"tail":", 1516, 1517; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVI/s641/a"},"text":"Pub. L. 110–181, div. A, title VI, § 641(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/156"},"text":"122 Stat. 156","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tVI/s643/a"},"text":"Pub. L. 112–239, div. A, title VI, § 643(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1783"},"text":"126 Stat. 1783","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/76/dC/tX/s10001/b/1"},"text":"Pub. L. 113–76, div. C, title X, § 10001(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/151"},"text":"128 Stat. 151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVI/s631/d/2"},"text":"Pub. L. 114–92, div. A, title VI, § 631(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/845"},"text":"129 Stat. 845","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVI/s634/a"},"text":"Pub. L. 114–328, div. A, title VI, § 634(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2163"},"text":"130 Stat. 2163","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/3/X"},"text":"Pub. L. 116–283, div. A, title IX, § 924(b)(3)(X)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3821"},"text":"134 Stat. 3821","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8c37aee-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8c37aef-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8c37af0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Marine Corps, or Space Force” for “or Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" substituted “the retired pay percentage (determined for the member under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1409/b"},"text":"section 1409(b) of this title","children":[],"tail":")” for “2½ percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s631/d/2"},"text":"Pub. L. 114–92, § 631(d)(2)","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", provided that the amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/113/76/s10001/b/1"},"text":"Pub. L. 113–76, § 10001(b)(1)","children":[],"tail":", which were effective "},{"tag":"date","attrib":{"date":"2015-12-01"},"text":"Dec. 1, 2015","children":[],"tail":", would not take effect. See 2014 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76/s10001/b/1/A"},"text":"Pub. L. 113–76, § 10001(b)(1)(A)","children":[],"tail":", which directed insertion of “, with adjustment under paragraph (2) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1401a/b"},"text":"section 1401a(b) of this title","children":[],"tail":" to which the member would have been entitled (but without the application of paragraph (4) of such section),” after “under any other provision of law”, did not take effect pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/s631/d/2"},"text":"Pub. L. 114–92, § 631(d)(2)","children":[],"tail":". See 2015 Amendment note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76/s10001/b/1/B"},"text":"Pub. L. 113–76, § 10001(b)(1)(B)","children":[],"tail":", which directed substitution of “with adjustment under paragraph (2) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1401a/b"},"text":"section 1401a(b) of this title","children":[],"tail":" to which the member would have been entitled (but without the application of paragraph (4) of such section), whichever is applicable to the member.” for “whichever is applicable to the member.”, did not take effect pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/s631/d/2"},"text":"Pub. L. 114–92, § 631(d)(2)","children":[],"tail":". See 2015 Amendment note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" substituted “may not, when combined with the amount of retired pay payable to the retiree after any such reduction under sections 5304 and 5305 of title 38, cause the total of such combined payment to exceed” for “shall be reduced by the amount (if any) by which the amount of the member’s retired pay under chapter 61 of this title exceeds” in subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s641/b"},"text":"Pub. L. 110–181, § 641(b)","children":[],"tail":", designated existing text as subpar. (A), inserted heading, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s641/a"},"text":"Pub. L. 110–181, § 641(a)","children":[],"tail":", substituted “who—” for “entitled to retired pay who—” in introductory provisions, added pars. (1) and (2), and struck out former pars. (1) and (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) has completed at least 20 years of service in the uniformed services that are creditable for purposes of computing the amount of retired pay to which the member is entitled or is entitled to retired pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12731"},"text":"section 12731 of this title","children":[],"tail":" (other than by reason of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12731b"},"text":"section 12731b of this title","children":[],"tail":"); and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) has a combat-related disability.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s642/e/1"},"text":"Pub. L. 108–136, § 642(e)(1)","children":[],"tail":", substituted “Combat-related special compensation” for “Special compensation for certain combat-related disabled uniformed services retirees” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s642/c"},"text":"Pub. L. 108–136, § 642(c)","children":[],"tail":", substituted “under subsection (a) for any month is the amount of compensation to which the retiree is entitled under title 38 for that month, determined without regard to any disability of the retiree that is not a combat-related disability.” for “for a combat-related disability under subsection (a) is the monthly amount of compensation to which the retiree would be entitled solely for the combat-related disability consistent with chapter 11 of title 38.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s642/b"},"text":"Pub. L. 108–136, § 642(b)","children":[],"tail":", inserted before semicolon at end “or is entitled to retired pay under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12731"},"text":"section 12731 of this title","children":[],"tail":" (other than by reason of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12731b"},"text":"section 12731b of this title","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s642/a/2"},"text":"Pub. L. 108–136, § 642(a)(2)","children":[],"tail":", struck out “qualifying” before “combat-related disability”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s642/a/1"},"text":"Pub. L. 108–136, § 642(a)(1)","children":[],"tail":", amended heading and text of subsec. (e) generally. Prior to amendment, subsec. (e) defined term “qualifying combat-related disability”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s642/d"},"text":"Pub. L. 108–136, § 642(d)","children":[],"tail":", amended heading and text of subsec. (f) generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"Single source of compensation","children":[],"tail":".—An individual who is paid special compensation under this section may not receive special compensation under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1413"},"text":"section 1413 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Election of source","children":[],"tail":".—An individual who is eligible for special compensation under this section and special compensation under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1413"},"text":"section 1413 of this title","children":[],"tail":" shall elect which special compensation to receive."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—The Secretary of Defense shall prescribe in regulations the manner and form of an election under this subsection.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s641/c/1"},"text":"Pub. L. 108–136, § 641(c)(1)","children":[],"tail":", inserted first sentence and inserted “for any other member” before “for any fiscal year”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8c37af1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"t