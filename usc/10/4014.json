{"tag":"section","attrib":{"id":"idaa4d0159-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4014"},"text":null,"children":[{"tag":"num","attrib":{"value":"4014"},"text":"§ 4014.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination and communication of defense research activities and technology domain awareness","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa4d015a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4014/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination of Department of Defense Research, Development, and Technological Data","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall promote, monitor, and evaluate programs for the communication and exchange of research, development, and technological data—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa4d015b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4014/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" among the Defense research facilities, combatant commands, and other organizations that are involved in developing for the Department of Defense the technological requirements for new items for use by combat forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa4d015c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4014/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" among Defense research facilities and other offices, agencies, and bureaus in the Department that are engaged in related technological matters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa4d015d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4014/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" among other research facilities and other departments or agencies of the Federal Government that are engaged in research, development, and technological matters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa4d015e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4014/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" among private commercial, research institution, and university entities engaged in research, development, and technological matters potentially relevant to defense on a voluntary basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa4d015f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4014/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, to achieve full awareness of scientific and technological advancement and innovation wherever it may occur, whether funded by the Department of Defense, another element of the Federal Government, or other entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa4d0160-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4014/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through development and distribution of clear technical communications to the public, military operators, acquisition organizations, and civilian and military decision-makers that convey successes of research and engineering activities supported by the Department and the contributions of such activities to support national needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa4d0161-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4014/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defense Research Facility Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “Defense research facility” has the meaning given that term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4125/b"},"text":"section 4125(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa4d0162-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1841/d"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1841(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4243"},"text":"134 Stat. 4243","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/u/2/E"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(u)(2)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2151"},"text":"135 Stat. 2151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVIII/s1801/a/30"},"text":"Pub. L. 118–31, div. A, title XVIII, § 1801(a)(30)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/685"},"text":"137 Stat. 685","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa4d0163-3a6f-11f1-a58a-d8