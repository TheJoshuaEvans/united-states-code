{"tag":"section","attrib":{"id":"idab68d1ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9271"},"text":null,"children":[{"tag":"num","attrib":{"value":"9271"},"text":"§ 9271.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medal of honor: award","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President may award, and present in the name of Congress, a medal of honor of appropriate design, with ribbons and appurtenances, to a person who, while a member of the Air Force or the Space Force, distinguishes himself conspicuously by gallantry and intrepidity at the risk of his life above and beyond the call of duty—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab68d1cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9271/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while engaged in an action against an enemy of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab68d1cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9271/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while engaged in military operations involving conflict with an opposing foreign force; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab68d1cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9271/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while serving with friendly foreign forces engaged in an armed conflict against an opposing armed force in which the United States is not a belligerent party.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab68d1ce-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/540"},"text":"70A Stat. 540","children":[],"tail":", § 8741; "},{"tag":"ref","attrib":{"href":"/us/pl/88/77/s3/1"},"text":"Pub. L. 88–77, § 3(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-07-25"},"text":"July 25, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/94"},"text":"77 Stat. 94","children":[],"tail":"; renumbered § 9271, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/b/11"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(b)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1833"},"text":"132 Stat. 1833","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s923/c/12/A/i"},"text":"Pub. L. 116–283, div. A, title IX, § 923(c)(12)(A)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3811"},"text":"134 Stat. 3811","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab68d1cf-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab68d1d0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab68d1d1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8741","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1403.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1918-07-09/ch143"},"text":"July 9, 1918, ch. 143","children":[],"tail":", (8th par. under “Ordnance Department”), "},{"tag":"html:a","attrib":{"href":"/us/stat/40/870"},"text":"40 Stat. 870","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “That the provisions of existing law relating to the award of medals of honor to officers, noncommissioned officers, and privates of the Army be, and they hereby are, amended so that”, in the ","children":[{"tag":"ref","attrib":{"href":"/us/act/1918-07-09/ch143"},"text":"Act of July 9, 1918, ch. 143","children":[],"tail":" (8th par. under “Ordnance Department”), "},{"tag":"ref","attrib":{"href":"/us/stat/40/870"},"text":"40 Stat. 870","children":[],"tail":", are not contained in 10:1403. They are also omitted from the revised section as surplusage. The word “member” is substituted for the words “officer or enlisted man”. The word “only” is omitted as surplusage. The word “award” is inserted for clarity, since the President determines the recipient of the medal in addition to presenting it."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab68d1d2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab68d1d3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" inserted “or the Space Force” after “the Air Force” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8741"},"text":"section 8741 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/77"},"text":"Pub. L. 88–77","children":[],"tail":" enlarged the authority to award the medal of honor, which was limited to those cases in which persons distinguished themselves in action involving actual conflict with an enemy, to permit its award for distinguished service while engaged in an action against an enemy of the United States, while engaged in military operations involving conflict with an opposing foreign force, or while serving with friendly foreign forces engaged in an armed conflict against an opposing armed force in which the United States is not a belligerent party."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab68d1d4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab68d1d5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
