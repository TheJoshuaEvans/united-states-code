{"tag":"section","attrib":{"id":"idab9f9921-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12306"},"text":null,"children":[{"tag":"num","attrib":{"value":"12306"},"text":"§ 12306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standby Reserve","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab9f9922-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Units and members in the Standby Reserve may be ordered to active duty only as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12301"},"text":"section 12301 of this title","children":[],"tail":", but subject to the limitations in subsection (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab9f9923-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In time of emergency—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab9f9924-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12306/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no unit in the Standby Reserve organized to serve as a unit or any member thereof may be ordered to active duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12301/a"},"text":"section 12301(a) of this title","children":[],"tail":", unless the Secretary concerned, with the approval of the Secretary of Defense in the case of a Secretary of a military department, determines that there are not enough of the required kinds of units in the Ready Reserve that are readily available; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab9f9925-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12306/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12301/a"},"text":"section 12301(a) of this title","children":[],"tail":", no other member in the Standby Reserve may be ordered to active duty as an individual under such section without his consent, unless the Secretary concerned, with the approval of the Secretary of Defense in the case of a Secretary of a military department, determines that there are not enough qualified members in the Ready Reserve in the required category who are readily available."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab9f9926-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/29"},"text":"70A Stat. 29","children":[],"tail":", § 674; "},{"tag":"ref","attrib":{"href":"/us/pl/87/651/tI/s130"},"text":"Pub. L. 87–651, title I, § 130","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/514"},"text":"76 Stat. 514","children":[],"tail":"; renumbered § 12306 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI"},"text":"Pub. L. 103–337, div. A, title XVI","children":[],"tail":", §§ 1662(e)(2), 1675(c)(4), "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2992"},"text":"108 Stat. 2992","children":[],"tail":", 3017; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s514/d"},"text":"Pub. L. 108–375, div. A, title V, § 514(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1883"},"text":"118 Stat. 1883","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab9f9927-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab9f9928-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab9f9929-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1956 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"674(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"674(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:926(a) (less 1st 28 words).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:926(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608/s206"},"text":"July 9, 1952, ch. 608, § 206","children":[],"tail":" (less 1st 28 words of (a)), "},{"tag":"html:a","attrib":{"href":"/us/stat/66/483"},"text":"66 Stat. 483","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “to serve” are substituted for the words “for the purpose of serving”. The words “there are not enough * * * that are” are substituted for the words “adequate numbers of * * * are not”. The words “(other than for training)” are inserted, since the words “active duty” were defined in the source statute cited above to exclude “active duty for training”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab9f992a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1962 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"The change is made to conform section 674(a) more closely to the source law for that section, section 206(a) of the Armed Forces Reserve Act of 1952 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/66/483"},"text":"66 Stat. 483","children":[],"tail":"). Section 206(a) of that Act defined the Standby Reserve in terms of units and members of the reserve components according to their liability to be ordered to active duty. It did not provide authority to order units and members of the Standby Reserve to active duty. This authority was provided by section 233(a) of the Armed Forces Reserve Act of 1952 ("},{"tag":"ref","attrib":{"href":"/us/stat/66/489"},"text":"66 Stat. 489","children":[],"tail":"), which is restated in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s672/a"},"text":"section 672(a) of title 10","children":[],"tail":". Since the present language of section 674(a) may be interpreted to provide independent authority to order units and members of the Standby Reserve to active duty, it is revised to make clear that this is not the case and that section 672 is the authority for that action."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab9f992b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab9f992c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s514/d/1"},"text":"Pub. L. 108–375, § 514(d)(1)","children":[],"tail":", substituted “active duty only as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12301"},"text":"section 12301 of this title","children":[],"tail":", but subject to the limitations in subsection (b)” for “active duty (other than for training) only as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12301"},"text":"section 12301 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s514/d/2/A"},"text":"Pub. L. 108–375, § 514(d)(2)(A)","children":[],"tail":", substituted “under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12301/a"},"text":"section 12301(a) of this title","children":[],"tail":"” for “(other than for training)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s514/d/2/B"},"text":"Pub. L. 108–375, § 514(d)(2)(B)","children":[],"tail":", substituted “notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12301/a"},"text":"section 12301(a) of this title","children":[],"tail":", no other member in the Standby Reserve may be ordered to active duty as an individual under such section without his consent” for “no other member in the Standby Reserve may be ordered to active duty (other than for training) as an individual without his consent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1662/e/2"},"text":"Pub. L. 103–337, § 1662(e)(2)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s674"},"text":"section 674 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1675/c/4"},"text":"Pub. L. 103–337, § 1675(c)(4)","children":[],"tail":", substituted “12301” for “672”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/651"},"text":"Pub. L. 87–651","children":[],"tail":" substituted “only as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s672"},"text":"section 672 of this title","children":[],"tail":"” for “only in time of war, of national emergency declared by Congress, or when otherwise authorized by law”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab9f992d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab9f992e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691"},"text":"section 1691 of Pub. L. 103–337","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
