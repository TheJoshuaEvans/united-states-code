{"tag":"section","attrib":{"id":"ida8000435-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s705"},"text":null,"children":[{"tag":"num","attrib":{"value":"705"},"text":"§ 705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rest and recuperation absence: qualified members extending duty at designated locations overseas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8000436-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under regulations prescribed by the Secretary concerned, a member of an armed force who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8000437-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s705/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to basic pay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8000438-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s705/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a specialty that is designated by the Secretary concerned for the purposes of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8000439-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s705/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed a tour of duty (as defined in accordance with regulations prescribed by the Secretary concerned) at a location outside the 48 contiguous States and the District of Columbia that is designated by the Secretary concerned for the purposes of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida800043a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s705/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the end of that tour of duty executes an agreement to extend that tour for a period of not less than one year;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may, in lieu of receiving special pay under section 314 or 352 of title 37 for duty performed during such extension of duty, elect to receive one of the benefits specified in subsection (b). Receipt of any such benefit is in addition to any other leave or transportation to which the member may be entitled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida800043b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The benefits authorized by subsection (a) are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida800043c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s705/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of rest and recuperation absence for not more than 30 days; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida800043d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s705/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of rest and recuperation absence for not more than 15 days for members whose qualifying tour of duty is 12 months or less, or for not more than 20 days for members whose qualifying tour of duty is longer than 12 months, and round-trip transportation at Government expense from the location of the extended tour of duty to the nearest port in the 48 contiguous States and return, or to an alternative destination and return at a cost not to exceed the cost of round-trip transportation from the location of the extended tour of duty to such nearest port.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida800043e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s705/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of this section shall not be effective unless the Secretary concerned determines that the application of this section will not adversely affect combat or unit readiness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida800043f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/579/s5/b/1"},"text":"Pub. L. 96–579, § 5(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-23"},"text":"Dec. 23, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3366"},"text":"94 Stat. 3366","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tV/s574/a"},"text":"Pub. L. 107–314, div. A, title V, § 574(a)","children":[],"tail":"–(b)(2)(A), "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2558"},"text":"116 Stat. 2558","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tVI/s621/b"},"text":"Pub. L. 108–136, div. A, title VI, § 621(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1505"},"text":"117 Stat. 1505","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tV/s552"},"text":"Pub. L. 110–181, div. A, title V, § 552","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/117"},"text":"122 Stat. 117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVI/s618/d"},"text":"Pub. L. 115–91, div. A, title VI, § 618(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1426"},"text":"131 Stat. 1426","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8000440-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8000441-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8000442-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" inserted “or 352” after “section 314” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" inserted “for members whose qualifying tour of duty is 12 months or less, or for not more than 20 days for members whose qualifying tour of duty is longer than 12 months,” after “for not more than 15 days”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003–","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s621/b/2"},"text":"Pub. L. 108–136, § 621(b)(2)","children":[],"tail":", struck out “enlisted” before “members” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s621/b/1"},"text":"Pub. L. 108–136, § 621(b)(1)","children":[],"tail":", substituted “a member” for “an enlisted member” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s574/b/2/A"},"text":"Pub. L. 107–314, § 574(b)(2)(A)","children":[],"tail":", substituted “recuperation absence: qualified enlisted members” for “recuperative absence for qualified enlisted members” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" substituted “recuperation” for “recuperative” in pars. (1) and (2) and inserted before period at end of par. (2) “, or to an alternative destination and return at a cost not to exceed the cost of round-trip transportation from the location of the extended tour of duty to such nearest port”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8000443-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8000444-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/579/s5/c/2"},"text":"Pub. L. 96–579, § 5(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-23"},"text":"Dec. 23, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3367"},"text":"94 Stat. 3367","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/579/s5/c/2"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s705"},"text":"Section 705 of title 10","children":[],"tail":", United States Code, as added by subsection (b), shall take effect upon the date of the enactment of this section ["},{"tag":"date","attrib":{"date":"1980-12-23"},"text":"Dec. 23, 1980","children":[],"tail":"] and shall apply only with respect to periods of extended duty overseas beginning on or after such date of enactment.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
