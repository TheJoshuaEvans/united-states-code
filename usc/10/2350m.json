{"tag":"section","attrib":{"id":"ida97194fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350m"},"text":null,"children":[{"tag":"num","attrib":{"value":"2350m"},"text":"§ 2350m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation in European program on multilateral exchange of surface transportation services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida97194fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participation Authorized.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida97194fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350m/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense, with the concurrence of the Secretary of State, may authorize the participation of the Department of Defense in the Surface Exchange of Services program (in this section referred to as the “SEOS program”) of the Movement Coordination Centre Europe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida97194fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350m/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope of participation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Participation of the Department of Defense in the SEOS program under paragraph (1) may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida97194ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350m/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reciprocal exchange or transfer of surface transportation on a reimbursable basis or by replacement-in-kind; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9719500-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350m/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the exchange of surface transportation services of an equal value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9719501-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Written Arrangement or Agreement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9719502-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350m/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Participation of the Department of Defense in the SEOS program shall be in accordance with a written arrangement or agreement entered into by the Secretary of Defense, with the concurrence of the Secretary of State, and the Movement Coordination Centre Europe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9719503-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350m/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall provide to the congressional defense committees notification of any arrangement or agreement entered into under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9719504-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350m/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding arrangements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If Department of Defense facilities, equipment, or funds are used to support the SEOS program, the written arrangement or agreement under paragraph (1) shall specify the details of any equitable cost-sharing or other funding arrangement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9719505-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350m/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other elements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any written arrangement or agreement entered into under paragraph (1) shall require that any accrued credits or liability resulting from an unequal exchange or transfer of surface transportation services shall be liquidated through the SEOS program not less than once every five years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9719506-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350m/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out any arrangement or agreement entered into under subsection (b), the Secretary of Defense may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9719507-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350m/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay the equitable share of the Department of Defense for the operating expenses of the Movement Coordination Centre Europe and the SEOS program from funds available to the Department of Defense for operation and maintenance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9719508-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350m/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assign members of the armed forces or Department of Defense civilian personnel, within billets authorized for the United States European Command, to duty at the Movement Coordination Centre Europe as necessary to fulfill Department of Defense obligations under that arrangement or agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9719509-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350m/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Crediting of Receipts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any amount received by the Department of Defense as part of the SEOS program shall be credited, at the option of the Secretary of Defense, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida971950a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350m/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriation, fund, or account used in incurring the obligation for which such amount is received; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida971950b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350m/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appropriate appropriation, fund, or account currently available for the purposes for which the expenditures were made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida971950c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350m/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida971950d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350m/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the end of each fiscal year in which the authority under this section is in effect, the Secretary of Defense shall submit to the congressional defense committees a report on Department of Defense participation in the SEOS program during such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida971950e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350m/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report required by paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida971950f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350m/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the equitable share of the costs and activities of the SEOS program paid by the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9719510-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350m/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of any amount received by the Department of Defense as part of such program, including the country from which the amount was received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9719511-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350m/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Statutory Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section may be construed to authorize the use of foreign sealift in violation of section 2631.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9719512-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII/s1202/a"},"text":"Pub. L. 116–283, div. A, title XII, § 1202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3908"},"text":"134 Stat. 3908","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9719513-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9719514-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida9719515-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 2350m was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2350q"},"text":"section 2350q of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida9719516-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2350m was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s344"},"text":"section 344 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
