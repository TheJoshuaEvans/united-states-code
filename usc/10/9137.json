{"tag":"section","attrib":{"id":"idab6660b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9137"},"text":null,"children":[{"tag":"num","attrib":{"value":"9137"},"text":"§ 9137.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regular Air Force: aviation cadets; qualifications, grade, limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab6660b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9137/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The grade of aviation cadet is a special enlisted grade in the Regular Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab6660b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9137/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any citizen of the United States may be enlisted as an aviation cadet, if he is otherwise qualified.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab6660b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9137/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any enlisted member of the Regular Air Force who is otherwise qualified may be designated, with his consent, as an aviation cadet by the Secretary of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab6660b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9137/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except in time of war or of emergency declared by Congress, at least 20 percent of the aviation cadets designated in each fiscal year shall be selected from members of the Regular Air Force or the Regular Army who are eligible and qualified. No person may be enlisted or designated as an aviation cadet unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab6660ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9137/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" he agrees in writing that, upon his successful completion of the course of training as an aviation cadet, he will accept a commission as second lieutenant in the Air Force Reserve, and will serve on active duty as such for a period of three years, unless sooner released; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab6660bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9137/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if under 21 years of age, he has the consent of his parent or guardian to his agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab6660bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9137/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" While on active duty, an aviation cadet is entitled to uniforms, clothing, and equipment at the expense of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab6660bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/504"},"text":"70A Stat. 504","children":[],"tail":", § 8257; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s33/a/37"},"text":"Pub. L. 85–861, § 33(a)(37)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1566"},"text":"72 Stat. 1566","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tII/s237"},"text":"Pub. L. 96–513, title II, § 237","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2887"},"text":"94 Stat. 2887","children":[],"tail":"; renumbered § 9137, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/b/2"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1832"},"text":"132 Stat. 1832","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab6660be-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab6660bf-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab6660c0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1956 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8257(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8257(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:297a.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:299 (1st sentence, less last 19 words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1941-06-03/ch165"},"text":"June 3, 1941, ch. 165","children":[],"tail":", §§ 1, 3 (1st and 2d sentences), "},{"tag":"html:a","attrib":{"href":"/us/stat/55/239"},"text":"55 Stat. 239","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8257(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:291f–2 (less 1st 55 words of 1st proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-13/ch199/s3"},"text":"June 13, 1949, ch. 199, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/175"},"text":"63 Stat. 175","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:299 (last 19 words of 1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8257(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:291f–2 (1st 55 words of 1st proviso).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:299 (2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Under such regulations as the Secretary of the Army may prescribe” are omitted, since the Secretary has inherent authority to issue regulations appropriate to exercising his statutory functions.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “who is otherwise qualified” and “with his consent” are substituted for 10: 291f–2 (less 1st 55 words of 1st proviso).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the first sentence is substituted for 10:291f–2 (proviso). The words “after ","children":[{"tag":"date","attrib":{"date":"1940-06-13"},"text":"June 13, 1940","children":[],"tail":"” (the date of enactment of the source statute) are substituted for the word “hereafter”, in 10:291f–2. The words “after "},{"tag":"date","attrib":{"date":"1949-06-13"},"text":"June 13, 1949","children":[],"tail":"”, in 10:291f–2, are omitted as executed. The first 17 words of the last sentence are substituted for 10:299 (1st 20 words of 2d sentence). Clause (2) is substituted for 10:299 (proviso of 2d sentence)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab6660c1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1958 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"The new subsection (e) is necessary to reflect the last 11 words of the second sentence of section 4 of the Army Aviation Cadet Act (formerly ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s304"},"text":"10 U.S.C. 304","children":[],"tail":"), which were omitted from the original military codification act, the Act of "},{"tag":"date","attrib":{"date":"1956-08-10"},"text":"August 10, 1956","children":[],"tail":", chapter 1041, as part of the source law for section 20(b) of that Act ("},{"tag":"ref","attrib":{"href":"/us/stat/70A/627"},"text":"70A Stat. 627","children":[],"tail":"). See Senate Report No. 2484, 84th Congress, 2d Session, page 738. Since the source law did not permit the payment of a money allowance to an aviation cadet in place of the issuance of uniforms, clothing, and equipment, as may be done for enlisted members generally, it is necessary to restate this provision separately. See Opinion of the Deputy General Counsel, Department of Defense, "},{"tag":"date","attrib":{"date":"1957-05-29"},"text":"May 29, 1957","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab6660c2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab6660c3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8257"},"text":"section 8257 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “Any citizen” for “Any male citizen”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “Any enlisted member” for “Any male enlisted member”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab6660c4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab6660c5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab6660c6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":", but the authority to prescribe regulations under the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s