":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab986d8f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “the Secretary of Defense” for “the Secretary concerned”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" substituted “of” for “above” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1632"},"text":"Pub. L. 103–337, § 1632","children":[],"tail":". See 1994 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1662/c/2"},"text":"Pub. L. 103–337, § 1662(c)(2)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s593"},"text":"section 593 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1675/b"},"text":"Pub. L. 103–337, § 1675(b)","children":[],"tail":", substituted “12213, or 12214” for “3352, or 8352”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1632"},"text":"Pub. L. 103–337, § 1632","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":", substituted “reserve officers in commissioned grades of lieutenant colonel and commander or below” for “Reserves in commissioned grades below lieutenant colonel and commander” and “reserve officers in commissioned grades above lieutenant colonel and commander” for “Reserves in commissioned grades above major and lieutenant commander”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" inserted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s624"},"text":"section 624 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1971—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/129"},"text":"Pub. L. 92–129","children":[],"tail":" substituted “below lieutenant colonel and commander” for “below general officer and flag officer”, “in commissioned grades above major and lieutenant commander” for “as general and flag officers”, and “section 3352 or 8352 of this title” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3352"},"text":"section 3352 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":" inserted “, except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3352"},"text":"section 3352 of this title","children":[],"tail":"” after “consent of the Senate”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab986d90-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and R