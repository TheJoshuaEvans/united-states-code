{"tag":"section","attrib":{"id":"idab986d84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12203"},"text":null,"children":[{"tag":"num","attrib":{"value":"12203"},"text":"§ 12203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioned officers: appointment, how made; term","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab986d85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appointments of reserve officers in commissioned grades of lieutenant colonel and commander or below, except commissioned warrant officer, shall be made by the President alone. Appointments of reserve officers in commissioned grades above lieutenant colonel and commander shall be made by the President, by and with the advice and consent of the Senate, except as provided in section 624, 12213, or 12214 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab986d86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the authority, direction, and control of the President, the Secretary of Defense may appoint as a reserve commissioned officer any regular officer transferred from the active-duty list of an armed force to the reserve active-status list of a reserve component under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s647"},"text":"section 647 of this title","children":[],"tail":", notwithstanding the requirements of subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab986d87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12203/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appointments of Reserves in commissioned grades are for an indefinite term and are held during the pleasure of the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab986d88-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/25"},"text":"70A Stat. 25","children":[],"tail":", § 593; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/10/C"},"text":"Pub. L. 85–861, § 1(10)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1440"},"text":"72 Stat. 1440","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/129/tVI/s601"},"text":"Pub. L. 92–129, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-09-28"},"text":"Sept. 28, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/361"},"text":"85 Stat. 361","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s501/7"},"text":"Pub. L. 96–513, title V, § 501(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2907"},"text":"94 Stat. 2907","children":[],"tail":"; renumbered § 12203 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI"},"text":"Pub. L. 103–337, div. A, title XVI","children":[],"tail":", §§ 1632, 1662(c)(2), 1675(b)(1), "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2965"},"text":"108 Stat. 2965","children":[],"tail":", 2990, 3017; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1501/a/6"},"text":"Pub. L. 104–106, div. A, title XV, § 1501(a)(6)","