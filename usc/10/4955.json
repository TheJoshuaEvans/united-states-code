{"tag":"section","attrib":{"id":"idaaaed007-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4955"},"text":null,"children":[{"tag":"num","attrib":{"value":"4955"},"text":"§ 4955.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaaed008-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4955/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c), the value of the assistance furnished by the Secretary to any eligible entity to carry out a procurement technical assistance program under a cooperative agreement under this chapter during any fiscal year may not exceed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaaed009-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4955/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a program operating on a Statewide basis, other than a program referred to in paragraph (3) or (4), $1,500,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaaed00a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4955/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a program operating on less than a Statewide basis, other than a program referred to in paragraph (3) or (4), $750,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaaed00b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4955/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a program operated wholly within one service area of the Bureau of Indian Affairs by an eligible entity referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4951/1/D"},"text":"section 4951(1)(D) of this title","children":[],"tail":", $450,000; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaaed00c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4955/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a program operated wholly within more than one service area of the Bureau of Indian Affairs by an eligible entity referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4951/1/D"},"text":"section 4951(1)(D) of this title","children":[],"tail":", $1,500,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaaed00d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4955/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determinations on Scope of Operations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A determination of whether a procurement technical assistance program is operating on a Statewide basis or on less than a Statewide basis or is operated wholly within one or more service areas of the Bureau of Indian Affairs by an eligible entity referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4951/1/D"},"text":"section 4951(1)(D) of this title","children":[],"tail":" shall be made in accordance with regulations prescribed by the Secretary of Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaaed00e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4955/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The value of the assistance provided in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4959/b"},"text":"section 4959(b) of this title","children":[],"tail":" is not subject to the limitations in subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaaed00f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4955/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Program Income.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaaed010-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4955/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An eligible entity that earned income in a specified fiscal year from activities carried out pursuant to a procurement technical assistance program funded under this chapter may expend an amount of such income, not to exceed 25 percent of the cost of furnishing procurement technical assistance in such specified fiscal year, during the fiscal year following such specified fiscal year, to carry out a procurement technical assistance program funded under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaaed011-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4955/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An eligible entity that does not enter into a cooperative agreement with the Secretary for a fiscal year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaaed012-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4955/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall notify the Secretary of the amount of any income the eligible entity carried over from the previous fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaaed013-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4955/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may retain an amount of such income equal to 10 percent of the value of assistance furnished by the Secretary under this section during the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaaed014-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4955/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In determining the value of assistance furnished by the Secretary under this section for any fiscal year, the Secretary shall account for the amount of any income the eligible entity carried over from the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaaed015-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4955/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding From Other Federal Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may accept and use funds from other Federal agencies and departments for execution and administration of the program authorized by this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaaed016-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXII/s1241/a/1"},"text":"Pub. L. 98–525, title XII, § 1241(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2606"},"text":"98 Stat. 2606","children":[],"tail":", § 2414; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tIX/s919/a"},"text":"Pub. L. 99–145, title IX, § 919(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/692"},"text":"99 Stat. 692","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tVIII/s841/a"},"text":"Pub. L. 100–456, div. A, title VIII, § 841(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2025"},"text":"102 Stat. 2025","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVIII/s819/c"},"text":"Pub. L. 101–189, div. A, title VIII, § 819(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1503"},"text":"103 Stat. 1503","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/25/tVII/s701/f/7"},"text":"Pub. L. 102–25, title VII, § 701(f)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-04-06"},"text":"Apr. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/115"},"text":"105 Stat. 115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tVIII/s813"},"text":"Pub. L. 107–107, div. A, tit