n","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/m/2/D"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(m)(2)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2145"},"text":"135 Stat. 2145","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1872/a/8"},"text":"Pub. L. 116–283, § 1872(a)(8)","children":[],"tail":", which had originally transferred "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2416"},"text":"section 2416 of this title","children":[],"tail":" to this section. After amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1872/a/8"},"text":"section 1872(a)(8) of Pub. L. 116–283","children":[],"tail":" instead transferred section 2416 to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4957"},"text":"section 4957 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaaaed01a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s861/c"},"text":"Pub. L. 119–60, § 861(c)","children":[],"tail":", substituted “$1,500,000” for “$1,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s861/b"},"text":"Pub. L. 119–60, § 861(b)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “$1,500,000” for “$1,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1872/a/6"},"text":"Pub. L. 116–283, § 1872(a)(6)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/b/24"},"text":"Pub. L. 117–81, § 1701(b)(24)","children":[],"tail":", (m)(2)(B)(i), (ii), renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2414"},"text":"section 2414 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1872/a/6/A"},"text":"Pub. L. 116–283, § 1872(a)(6)(A)","children":[],"tail":", substituted “paragraph” for “clause”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a)(3), (4), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1872/a/6/B"},"text":"Pub. L. 116–283, § 1872(a)(6)(B)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/m/2/B/iii"},"text":"Pub. L. 117–81, § 1701(m)(2)(B)(iii)","children":[],"tail":", substituted “section 4951(1)(D)” for “section 2411(1)(D)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1872/a/6/C"},"text":"Pub. L. 116–283, § 1872(a)(6)(C)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/m/2/B/iv"},"text":"Pub. L. 117–81, § 1701(m)(2)(B)(iv)","children":[],"tail":", substituted “section 4959(b)” for “section 2419(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1081/a/24/A"},"text":"Pub. L. 115–232, § 1081(a)(24)(A)","children":[],"tail":", substituted “Funding” for “FUNDING” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s858/b/1"},"text":"Pub. L. 115–232, § 858(b)(1)","children":[],"tail":", substituted “$1,000,000” for “$750,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s858/b/2"},"text":"Pub. L. 115–232, § 858(b)(2)","children":[],"tail":", substituted “$750,000” for “$450,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s858/b/3"},"text":"Pub. L. 115–232, § 858(b)(3)","children":[],"tail":", substituted “$450,000” for “$300,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s858/b/4"},"text":"Pub. L. 115–232, § 858(b)(4)","children":[],"tail":", substituted “$1,000,000” for “$750,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s817/1"},"text":"Pub. L. 115–91, § 817(1)","children":[],"tail":", which directed substitution of “FUNDING” for “LIMITATION” in section catchline, was executed by making the substitution for “Limitation” in section catchline, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s817/2"},"text":"Pub. L. 115–91, § 817(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1611/b/1"},"text":"Pub. L. 113–66, § 1611(b)(1)","children":[],"tail":", substituted “Except as provided in subsection (c), the value” for “The value” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1612/b/1"},"text":"Pub. L. 113–66, § 1612(b)(1)","children":[],"tail":", substituted “$750,000” for “$600,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1612/b/2"},