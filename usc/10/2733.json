 1st sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"31:222h.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"[31:223b is made applicable to the Navy by 31:223d and 223e].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1943-07-03/ch189/s1"},"text":"July 3, 1943, ch. 189, § 1","children":[],"tail":" (less 4th sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/57/372"},"text":"57 Stat. 372","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1945-05-29/ch135/s4"},"text":"May 29, 1945, ch. 135, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/59/225"},"text":"59 Stat. 225","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1946-06-28/ch514/s1"},"text":"June 28, 1946, ch. 514, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/332"},"text":"60 Stat. 332","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1952-07-03/ch570/s2/c"},"text":"July 3, 1952, ch. 570, § 2(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/66/334"},"text":"66 Stat. 334","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1953-03-31/ch13"},"text":"Mar. 31, 1953, ch. 13","children":[],"tail":" (as applicable to "},{"tag":"html:a","attrib":{"href":"/us/act/1952-07-03/ch570/s2/c"},"text":"Act of July 3, 1952, ch. 570, § 2(c)","children":[],"tail":"), "},{"tag":"html:a","attrib":{"href":"/us/stat/67/18"},"text":"67 Stat. 18","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1953-06-30/ch172"},"text":"June 30, 1953, ch. 172","children":[],"tail":" (as applicable to "},{"tag":"html:a","attrib":{"href":"/us/act/1952-07-03/ch570/s2/c"},"text":"Act of July 3, 1952, ch. 570, § 2(c)","children":[],"tail":"), "},{"tag":"html:a","attrib":{"href":"/us/stat/67/131"},"text":"67 Stat. 131","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-08-02/ch753/s424/a"},"text":"Aug. 2, 1946, ch. 753, § 424(a)","children":[],"tail":" (4th clause), "},{"tag":"html:a","attrib":{"href":"/us/stat/60/847"},"text":"60 Stat. 847","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1945-12-28/ch597/s1"},"text":"Dec. 28, 1945, ch. 597, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/59/662"},"text":"59 Stat. 662","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1946-06-28/ch514/s2"},"text":"June 28, 1946, ch. 514, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/333"},"text":"60 Stat. 333","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1945-12-28/ch597/s6"},"text":"Dec. 28, 1945, ch. 597, § 6","children":[],"tail":"; added "},{"tag":"html:a","attrib":{"href":"/us/act/1946-03-20/ch104"},"text":"Mar. 20, 1946, ch. 104","children":[],"tail":" (last par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/60/56"},"text":"60 Stat. 56","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “a civilian officer or employee of that department, or a member of the Army, Navy, Air Force, or Marine Corps, as the case may be” are substituted for the words “military personnel or civilian employees of the Department of the Army or of the Army”. The words “whether under a lease, express or implied” are omitted as surplusage. The words “consider, ascertain, adjust, determine” are omitted as covered by the word “settle”, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2731"},"text":"section 2731 of this title","children":[],"tail":". The words “arising on or after "},{"tag":"date","attrib":{"date":"1941-05-27"},"text":"May 27, 1941","children":[],"tail":"” are omitted as executed, since, under revised subsection (b), a claim must be filed within one year after it accrues, or within one year after the war is terminated, if it accrues in time of war."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “or loss” are inserted before the word “incident”, for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “it accrues” are substituted for the words “the accident or incident out of which such claim arises shall have occurred”, in 31:223b. The words “the claim accrues” are substituted for the words “That if such accident or incident occurs”. The words “not later than” are substituted for the words “within” to make it clear that a claim may be presented during a war. The words “the war is terminated” are substituted for the words “after peace is established”, since the other time covered is “time of war”. 31:223b (last 49 words of proviso of 2d sentence) is omitted as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2672"},"text":"section 2672 of title 28","children":[],"tail":"” are substituted for the words “claims cognizable under part 2 of this title”, to reflect the express amendment of 31:223b and 223c by the fourth clause of section 424(a) of the Federal Tort Claims Act, "},{"tag":"ref","attrib":{"href":"/us/stat/60/847"},"text":"60 Stat. 847","children":[],"tail":". Section 424(a) of the Federal Tort Claims Act referred to “claims cognizable under part 2 of this title”. Part 2 of that act consisted of sections 403 and 404 which were repealed by "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s39"},"text":"section 39 of the Act of June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/1008"},"text":"62 Stat. 1008","children":[],"tail":", and replaced by sections 2672 and 2673 of title 28. The words “or possessions thereof” are omitted, since possessions of foreign countries are not specifically covered by the section to which the words refer."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “claim * * * that would otherwise be covered by this section” are substituted for the words “such claims”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “and final settlement” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida9c9c706-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida9c9c707-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1958 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2733","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:223b.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-03-29/ch103"},"text":"Mar. 29, 1956, ch. 103","children":[],"tail":", §§ 1–3, "},{"tag":"html:a","attrib":{"href":"/us/stat/70/60"},"text":"70 Stat. 60","children":[],"tail":", 61."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9c9c708-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9c9c709-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Marine Corps, Space Force,” for “Marine Corps,” in par. (2) and in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316"},"text":"Pub. L. 104–316","children":[],"tail":" substituted “Secretary of the Treasury” for “Comptroller General”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/564/s1/1"},"text":"Pub. L. 98–564, § 1(1)","children":[],"tail":", substituted “Chief Counsel” for “chief legal officer” and “$100,000” for “$25,000” in provisions preceding par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/564/s1/2"},"text":"Pub. L. 98–564, § 1(2)","children":[],"tail":", amended subsec. (d) generally, substituting “$100,000” for “$25,000” and provisions requiring Secretary to report excess to the Comptroller General for provisions requiring reporting to Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/564/s1/3"},"text":"Pub. L. 98–564, § 1(3)","children":[],"tail":", substituted provisions permitting officers and employees of Secretary concerned to settle claims not otherwise payable under this section in amounts not to exceed $25,000 and providing for an appeal to Secretary concerned or his designee for provisions which provided for delegation of claims settlement authority by Secretary for cases not to exceed $5,000 and for appeal therefrom."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “National Oceanic and Atmospheric Administration” for “Environmental Science Services Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/336/s1/1"},"text":"Pub. L. 93–336, § 1(1)","children":[],"tail":", substituted “$25,000” for “$15,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/336/s1/2"},"text":"Pub. L. 93–336, § 1(2)","children":[],"tail":", substituted “$25,000” for “$15,000” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/336/s1/3"},"text":"Pub. L. 93–336, § 1(3)","children":[],"tail":", substituted “$5,000” for “$2,500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/312/s2/a"},"text":"Pub. L. 91–312, § 2(a)","children":[],"tail":", substituted “$15,000” for “$5,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/312/s2/b"},"text":"Pub. L. 91–312, § 2(b)","children":[],"tail":", substituted “$15,000” for “$5,000” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/525/s1"},"text":"Pub. L. 90–525, § 1","children":[],"tail":", substituted “Secretary concerned” for “Secretary of a military department”, and authorized the Chief Legal Officer of the Coast Guard to settle claims, settlement of claims for damage or loss to personal property in possession of the Coast Guard, and settlements when the torts are caused by civilian officers or employees and members of the Coast Guard when acting within scope of employment or otherwise incident to noncombat activities of the Coast Guard."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/522/s1/1"},"text":"Pub. L. 90–522, § 1(1)","children":[],"tail":", authorized application of local law in determining effect of claimant’s contributory negligence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/525/s5"},"text":"Pub. L. 90–525, § 5","children":[],"tail":", struck out “of the military department” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/525/s3"},"text":"Pub. L. 90–525, § 3","children":[],"tail":", increased limitation on amount of settlement from $1,000 to $2,500, struck out “military” before “department concerned”, and provided for appeals to Secretary concerned, or his designee, from determinations delegating authority to settle claims to an officer of an armed force. See "},{"tag":"ref","attrib":{"href":"/us/pl/90/522/s1/2"},"text":"Pub. L. 90–522, § 1(2)","children":[],"tail":", hereunder, for identical provision for appeals to Secretary concerned."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/522/s1/2"},"text":"Pub. L. 90–522, § 1(2)","children":[],"tail":", provided for appeals to Secretary concerned, or his designee, from determinations delegating authority to settle claims to an officer of an armed force."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/525/s4"},"text":"Pub. L. 90–525, § 4","children":[],"tail":", added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/718"},"text":"Pub. L. 89–718","children":[],"tail":" substituted “Environmental Science Services Administration” for “Coast and Geodetic Survey”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/729/s1/1/A"},"text":"Pub. L. 85–729, § 1(1)(A)","children":[],"tail":", substituted “the Judge Advocate General of an armed force under his jurisdiction, if designated by him, may settle, and pay in an amount not more than $5,000” for “any officer designated by him may settle, and pay in an amount not more than $1,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/54/A"},"text":"Pub. L. 85–861, § 1(54)(A)","children":[],"tail":", (B), in cl. (1), substituted “two years” for “one year” in three places and included claims accruing in time of armed conflict, and inserted sentence providing for the determination of dates of the beginning and ending of an armed conflict."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/54/C"},"text":"Pub. L. 85–861, § 1(54)(C)","children":[],"tail":", substituted provisions prohibiting payment for reimbursement for medical, hospital, or burial services furnished at the expense of the United States for provisions which prohibited allowance of claims for personal injury or death for more than the cost of reasonable medical, hospital, and burial expenses actually incurred, and not otherwise furnished or paid by the United States."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/729/s1/1/B"},"text":"Pub. L. 85–729, § 1(1)(B)","children":[],"tail":", substituted provisions authorizing partial payments on claims over $5,000 for provisions which authorized the Secretary of the military department concerned to report a claim for more than $1,000 to Congress for its consideration."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/729/s1/1/B"},"text":"Pub. L. 85–729, § 1(1)(B)","children":[],"tail":", substituted “Except as provided in subsection (d), no claim may be paid under this section” for “No claim may be paid under subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/729/s1/1/C"},"text":"Pub. L. 85–729, § 1(1)(C)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9c9c70a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9c9c70b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/b/3"},"text":"section 701(b)(3) of Pub. L. 96–513","children":[],"tail":", set out as a Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"repeals","id":"ida9c9c70c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeals","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The directory language of, but not the amendment made by, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/718/s8/a"},"text":"Pub. L. 89–718, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1117"},"text":"80 Stat. 1117","children":[],"tail":", cited as a credit to this section, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s6/b"},"text":"Pub. L. 97–295, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1314"},"text":"96 Stat. 1314","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"ida9c9c70d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9c9c70e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Claims for Injury or Death Accrued Before ","children":[{"tag":"date","attrib":{"date":"1956-03-30"},"text":"March 30, 1956","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s17"},"text":"Pub. L. 85–861, § 17","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1558"},"text":"72 Stat. 1558","children":[],"tail":", disallowed claims for personal injury or death under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2733"},"text":"section 2733 of this title","children":[],"tail":", for more than the cost of reasonable medical, hospital, and burial expenses actually incurred if the claim accrued before "},{"tag":"date","attrib":{"date":"1956-03-30"},"text":"March 30, 1956","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"ida9c9c70f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"ida9c9c710-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of Public Health Service, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s802"},"text":"section 802 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
