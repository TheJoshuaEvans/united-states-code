{"tag":"section","attrib":{"id":"ida74d2e7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119"},"text":null,"children":[{"tag":"num","attrib":{"value":"119"},"text":"§ 119.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special access programs: congressional oversight","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida74d2e7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida74d2e80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than March 1 of each year, the Secretary of Defense shall submit to the defense committees a report on special access programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74d2e81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each such report shall set forth—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida74d2e82-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount requested for special access programs of the Department of Defense in the President’s budget for the next fiscal year submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida74d2e83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each program in that budget that is a special access program—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida74d2e84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a brief description of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida74d2e85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a brief discussion of the major milestones established for the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida74d2e86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual cost of the program for each fiscal year during which the program has been conducted before the fiscal year during which that budget is submitted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida74d2e87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated total cost of the program and the estimated cost of the program for (I) the current fiscal year, (II) the fiscal year for which the budget is submitted, and (III) each of the four succeeding fiscal years during which the program is expected to be conducted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74d2e88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a report under paragraph (1) submitted in a year during which the President’s budget for the next fiscal year, because of multiyear budgeting for the Department of Defense, does not include a full budget request for the Department of Defense, the report required by paragraph (1) shall set forth—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida74d2e89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount already appropriated for the next fiscal year for special access programs of the Department of Defense and any additional amount requested in that budget for such programs for such fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida74d2e8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each program of the Department of Defense that is a special access program, the information specified in paragraph (2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida74d2e8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida74d2e8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than February 1 of each year, the Secretary of Defense shall submit to the defense committees a report that, with respect to each new special access program, provides—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida74d2e8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice of the designation of the program as a special access program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida74d2e8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" justification for such designation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74d2e8f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A report under paragraph (1) with respect to a program shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida74d2e90-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current estimate of the total program cost for the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida74d2e91-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of existing programs or technologies that are similar to the technology, or that have a mission similar to the mission, of the program that is the subject of the notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74d2e92-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the term “new special access program” means a special access program that has not previously been covered in a notice and justification under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida74d2e93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida74d2e94-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever a change in the classification of a special access program of the Department of Defense is planned to be made or whenever classified information concerning a special access program of the Department of Defense is to be declassified and made public, the Secretary of Defense shall submit to the defense committees a report containing a description of the proposed change, the reasons for the proposed change, and notice of any public announcement planned to be made with respect to the proposed change.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74d2e95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (3), any report referred to in paragraph (1) shall be submitted not less than 14 days before the date on which the proposed change or public announcement is to occur.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74d2e96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary determines that because of exceptional circumstances the requirement of paragraph (2) cannot be met with respect to a proposed change or public announcement concerning a special access program of the Department of Defense, the Secretary may submit the report required by paragraph (1) regarding the proposed change or public announcement at any time before the proposed change or public announcement is made and shall include in the report an explanation of the exceptional circumstances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida74d2e97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever there is a modification or termination of the policy and criteria used for designating a program of the Department of Defense as a special access program, the Secretary of Defense shall promptly notify the defense committees of such modification or termination. Any such notification shall contain the reasons for the modification or termination and, in the case of a modification, the provisions of the policy as modified.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida74d2e98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida74d2e99-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may waive any requirement under subsection (a), (b), or (c) that certain information be included in a report under that subsection if the Secretary determines that inclusion of that information in the report would adversely affect the national security. Any such waiver shall be made on a case-by-case basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74d2e9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary exercises the authority provided under paragraph (1), the Secretary shall provide the information described in that subsection with respect to the special access program concerned, and the justification for the waiver, jointly to the chairman and ranking minority member of each of the defense committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida74d2e9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A special access program may not be initiated until—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida74d2e9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defense committees are notified of the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74d2e9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 30 days elapses after such notification is received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida74d2e9e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section, the term “defense committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida74d2e9f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services and the Committee on Appropriations, and the Defense Subcommittee of the Committee on Appropriations, of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74d2ea0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s119/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services and the Committee on Appropriations, and the Subcommittee on Defense of the Committee on Appropriations, of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida74d2ea1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tXI/s1132/a/1"},"text":"Pub. L. 100–180, div. A, title XI, § 1132(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1151"},"text":"101 Stat. 1151","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIV"},"text":"Pub. L. 101–510, div. A, title XIV","children":[],"tail":", §§ 1461, 1482(a), "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1698"},"text":"104 Stat. 1698","children":[],"tail":", 1709; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tX/s1055"},"text":"Pub. L. 104–106, div. A, title X, § 1055","children":[],"tail":", title XV, § 1502(a)(4), "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/442"},"text":"110 Stat. 442","children":[],"tail":", 502; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1067/1"},"text":"Pub. L. 106–65, div. A, title X, § 1067(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/774"},"text":"113 Stat. 774","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/a/2"},"text":"Pub. L. 107–107, div. A, title X, § 1048(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1222"},"text":"115 Stat. 1222","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida74d2ea2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida74d2ea3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida74d2ea4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" substituted “Subcommittee on Defense” for “National Security Subcommittee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “Committee on Armed Services” for “Committee on National Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1055"},"text":"Pub. L. 104–106, § 1055","children":[],"tail":", substituted “March 1” for “February 1”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1502/a/4"},"text":"Pub. L. 104–106, § 1502(a)(4)","children":[],"tail":", added pars. (1) and (2) and struck out former pars. (1) and (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the Committees on Armed Services and Appropriations of the Senate and House of Representatives; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the Defense Subcommittees of the Committees on Appropriations of the Senate and House of Representatives.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1461/a"},"text":"Pub. L. 101–510, § 1461(a)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “Whenever a change is made in the status of a program of the Department of Defense as a special access program, the Secretary of Defense shall submit to the defense committees a report describing the change. Any such report shall be submitted not later than 30 days after the date on which the change takes effect.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1482/a/2"},"text":"Pub. L. 101–510, § 1482(a)(2)","children":[],"tail":", added subsec. (f). Former subsec. (f) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1461/b"},"text":"Pub. L. 101–510, § 1461(b)","children":[],"tail":", inserted “and Appropriations” after “Armed Services” in par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1482/a/1"},"text":"Pub. L. 101–510, § 1482(a)(1)","children":[],"tail":", redesignated subsec. (f) as (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida74d2ea5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida74d2ea6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIV/s1482/d"},"text":"Pub. L. 101–510, div. A, title XIV, § 1482(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1710"},"text":"104 Stat. 1710","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/510/dA/tXIV/s1482/d"},"text":"“The amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2214"},"text":"section 2214 of this title","children":[],"tail":" and amending this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1584"},"text":"section 1584 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"1991-10-01"},"text":"October 1, 1991","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida74d2ea7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2021-12-31"},"text":"Dec. 31, 2021","children":[],"tail":", of provisions in subsecs. (a) and (b) of this section requiring submittal of annual report to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1061"},"text":"section 1061 of Pub. L. 114–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s111"},"text":"section 111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida74d2ea8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Initial Reports on Special Access Programs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tXI/s1132/b"},"text":"Pub. L. 100–180, div. A, title XI, § 1132(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1152"},"text":"101 Stat. 1152","children":[],"tail":", required that the first report under subsec. (a) of this section set forth the amount that had been requested in the President’s budget for each of the five previous fiscal years for special access programs of the Department of Defense and the amount appropriated for each such year for such programs, and required that the first report under subsec. (b) of this section cover existing special access programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
