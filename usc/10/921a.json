{"tag":"section","attrib":{"id":"ida82d55bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s921a"},"text":null,"children":[{"tag":"num","attrib":{"value":"921a"},"text":"§ 921a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 121a. Fraudulent use of credit cards, debit cards, and other access devices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida82d55bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s921a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter who, knowingly and with intent to defraud, uses—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82d55bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s921a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a stolen credit card, debit card, or other access device;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d55be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s921a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a revoked, cancelled, or otherwise invalid credit card, debit card, or other access device; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d55bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s921a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a credit card, debit card, or other access device without the authorization of a person whose authorization is required for such use;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to obtain money, property, services, or anything else of value shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82d55c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s921a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access Device Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section (article), the term “access device” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1029"},"text":"section 1029 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida82d55c1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLX/s5432"},"text":"Pub. L. 114–328, div. E, title LX, § 5432","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2951"},"text":"130 Stat. 2951","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida82d55c2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida82d55c3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida82d55c4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 