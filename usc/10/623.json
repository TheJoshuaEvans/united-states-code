{"tag":"section","attrib":{"id":"ida7ecf152-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s623"},"text":null,"children":[{"tag":"num","attrib":{"value":"623"},"text":"§ 623.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of promotion zones","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7ecf153-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s623/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Before convening a selection board under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s611/a"},"text":"section 611(a) of this title","children":[],"tail":" to consider officers for promotion to any grade above first lieutenant or lieutenant (junior grade), the Secretary of the military department concerned shall establish a promotion zone for officers serving in each grade and competitive category to be considered by the board."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7ecf154-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s623/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary concerned shall determine the number of officers in the promotion zone for officers serving in any grade and competitive category from among officers who are eligible for promotion in that grade and competitive category. Such determination shall be made on the basis of an estimate of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7ecf155-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s623/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of officers needed in that competitive category in the next higher grade in each of the next five years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7ecf156-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s623/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of officers to be serving in that competitive category in the next higher grade in each of the next five years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7ecf157-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s623/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a promotion zone for officers to be promoted to a grade to which ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s523"},"text":"section 523 of this title","children":[],"tail":" is applicable, the number of officers authorized for such grade under such section to be on active duty on the last day of each of the next five fiscal years; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7ecf158-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s623/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of officers that should be placed in that promotion zone in each of the next five years to provide to officers in those years relatively similar opportunity for promotion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7ecf159-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tI/s105"},"text":"Pub. L. 96–513, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2856"},"text":"94 Stat. 2856","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7ecf15a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7ecf15b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida7ecf15c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":", but the authority to prescribe regulations under this section effective on "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701"},"text":"section 701 of Pub. L. 96–513","children":[],"tail":", set out as an Effective Date of 1980 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
