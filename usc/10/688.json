{"tag":"section","attrib":{"id":"ida7fb4933-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s688"},"text":null,"children":[{"tag":"num","attrib":{"value":"688"},"text":"§ 688.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retired members: authority to order to active duty; duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7fb4934-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s688/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under regulations prescribed by the Secretary of Defense, a member described in subsection (b) may be ordered to active duty by the Secretary of the military department concerned at any time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7fb4935-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s688/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (d), subsection (a) applies to the following members of the armed forces:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7fb4936-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s688/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A retired member of the Regular Army, Regular Navy, Regular Air Force, or Regular Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7fb4937-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s688/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Retired Reserve who was retired under section 1293, 7311, 7314, 8323, 9311, or 9314 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7fb4938-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s688/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Fleet Reserve or Fleet Marine Corps Reserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7fb4939-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s688/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A retired member of the Space Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7fb493a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s688/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties of Member Ordered to Active Duty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may, to the extent consistent with other provisions of law, assign a member ordered to active duty under this section to such duties as the Secretary considers necessary in the interests of national defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7fb493b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s688/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion of Officers Retired on Selective Early Retirement Basis","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following officers may not be ordered to active duty under this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7fb493c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s688/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who retired under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s638"},"text":"section 638 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7fb493d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s688/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An officer who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7fb493e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s688/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after having been notified that the officer was to be considered for early retirement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s638"},"text":"section 638 of this title","children":[],"tail":" by a board convened under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s611/b"},"text":"section 611(b) of this title","children":[],"tail":" and before being considered by that board, requested retirement under section 7311, 8323, or 9311 of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7fb493f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s688/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was retired pursuant to that request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7fb4940-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s688/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation of Period of Recall Service","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7fb4941-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s688/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member ordered to active duty under subsection (a) may not serve on active duty pursuant to orders under that subsection for more than 12 months within the 24 months following the first day of the active duty to which ordered under that subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7fb4942-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s688/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) does not apply to the following officers:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7fb4943-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s688/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A chaplain who is assigned to duty as a chaplain for the period of active duty to which ordered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7fb4944-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s688/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A health care professional (as characterized by the Secretary concerned) who is assigned to duty as a health care professional for the period of active duty to which ordered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7fb4945-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s688/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer assigned to duty with the American Battle Monuments Commission for the period of active duty to which ordered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7fb4946-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s688/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who is assigned to duty as a defense attaché or service attaché for the period of active duty to which ordered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7fb4947-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s688/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver for Periods of War or National Emergency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsections (d) and (e) do not apply in time of war or of national emergency declared by Congress or the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7fb4948-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s521/a"},"text":"Pub. L. 104–201, div. A, title V, § 521(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","