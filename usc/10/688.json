30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1669"},"text":"107 Stat. 1669","children":[],"tail":", provided that certain retired members of the armed forces could be ordered to active duty, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s521/a"},"text":"Pub. L. 104–201, div. A, title V, § 521(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2515"},"text":"110 Stat. 2515","children":[],"tail":", 2517, effective "},{"tag":"date","attrib":{"date":"1997-09-30"},"text":"Sept. 30, 1997","children":[],"tail":". See sections 688 to 690 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7fd923c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1719A/b/1/A"},"text":"Pub. L. 118–31, § 1719A(b)(1)(A)","children":[],"tail":", substituted “or Regular Marine Corps” for “Regular Marine Corps, or Regular Space Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1719A/b/1/B"},"text":"Pub. L. 118–31, § 1719A(b)(1)(B)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Regular Marine Corps, or Regular Space Force” for “or Regular Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “section 1293, 7311, 7314, 8323, 9311, or 9314” for “section 1293, 3911, 3914, 6323, 8911, or 8914”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “section 7311, 8323, or 9311” for “section 3911, 6323, or 8911”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (e)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7fd923d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7fd923e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7fd923f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s509/c"},"text":"Pub. L. 107–107, div. A, title V, § 509(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1091"},"text":"115 Stat. 1091","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/107/dA/tV/s509/c"},"text":"“The amendments made by subsections (a) and (b) [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s690"},"text":"section 690 of this title","children":[],"tail":"] shall apply with respect to officers serving on active duty as a defense attaché or service attaché on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida7fd9240-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s521/b"},"text":"Pub. L. 104–201, div. A, title V, § 521(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2517"},"text":"110 Stat. 2517","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/201/dA/tV/s521/b"},"text":"“The amendments made by this section [enacting this section and sections 689 and 690 of this title, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s6151"},"text":"section 6151 of this title","children":[],"tail":", and repealing former "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s688"},"text":"section 688 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"1997-09-30"},"text":"September 30, 1997","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
