{"tag":"section","attrib":{"id":"idaa0c9d5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3155"},"text":null,"children":[{"tag":"num","attrib":{"value":"3155"},"text":"§ 3155.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training for personnel outside acquisition workforce","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa0c9d5b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3155/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The joint policy for requirements definition, contingency program management, and contingency contracting required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3151"},"text":"section 3151 of this title","children":[],"tail":" shall provide for training of military personnel outside the acquisition workforce (including operational field commanders and officers performing key staff functions for operational field commanders) who are expected to have acquisition responsibility, including oversight duties associated with contracts or contractors, during combat operations, post-conflict operations, and contingency operations."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa0c9d5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3155/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope of Training","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Training under subsection (a) shall be sufficient to ensure that the military personnel referred to in that subsection—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa0c9d5d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3155/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" understand the scope and scale of contractor support they will experience in contingency operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa0c9d5e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3155/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" are prepared for their roles and responsibilities with regard to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa0c9d5f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3155/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements definition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa0c9d60-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3155/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" program management (including contractor oversight); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa0c9d61-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3155/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contingency contracting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa0c9d62-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1810/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1810(a)","children":[],"tail":", (b)(5), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4162"},"text":"134 Stat. 4162","children":[],"tail":", 4163.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa0c9d63-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa0c9d64-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa0c9d65-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (e)(1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2333"},"text":"section 2333 of this title","children":[],"tail":", which was transferred to this section and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1810/b/5"},"text":"Pub. L. 116–283, § 1810(b)(5)","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVIII/s849/a"},"text":"Pub. L. 110–181, div. A, title VIII, § 849(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/245"},"text":"122 Stat. 245","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa0c9d66-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1810/b/5/A"},"text":"Pub. L. 116–283, § 1810(b)(5)(A)","children":[],"tail":", (B), redesignated subsec. (e)(1) and (2) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2333"},"text":"section 2333 of this title","children":[],"tail":" as subsec. (a) of this section, in heading, substituted “Required Training” for “Training for Personnel Outside Acquisition Workforce”, and, in text, struck out par. (1) designation at beginning and substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3151"},"text":"section 3151 of this title","children":[],"tail":"” for “subsection (a)”. Par. (2) subsequently redesignated subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1810/b/5/C"},"text":"Pub. L. 116–283, § 1810(b)(5)(C)","children":[],"tail":", redesignated subsec. (a)(2) as (b), inserted heading, and substituted “Training under subsection (a)” for “Training under paragraph (1)” and “referred to in that subsection—” and pars. (1) and (2) for “referred to in that paragraph understand the scope and scale of contractor support they will experience in contingency operations and are prepared for their roles and responsibilities with regard to requirements definition, program management (including contractor oversight), and contingency contracting.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa0c9d67-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa0c9d68-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"te