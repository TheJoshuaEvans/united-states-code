{"tag":"section","attrib":{"id":"ida82d54f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s917a"},"text":null,"children":[{"tag":"num","attrib":{"value":"917a"},"text":"§ 917a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 117a. Wrongful broadcast or distribution of intimate visual images","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida82d54f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s917a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82d54f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s917a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who knowingly and wrongfully broadcasts or distributes an intimate visual image of another person or a visual image of sexually explicit conduct involving a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida82d54f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s917a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is at least 18 years of age at the time the intimate visual image or visual image of sexually explicit conduct was created;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82d54f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s917a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is identifiable from the intimate visual image or visual image of sexually explicit conduct itself, or from information displayed in connection with the intimate visual image or visual image of sexually explicit conduct; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82d54f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s917a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not explicitly consent to the broadcast or distribution of the intimate visual image or visual image of sexually explicit conduct;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d54f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s917a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who knows or reasonably should have known that the intimate visual image or visual image of sexually explicit conduct was made under circumstances in which the person depicted in the intimate visual image or visual image of sexually explicit conduct retained a reasonable expectation of privacy regarding any broadcast or distribution of the intimate visual image or visual image of sexually explicit conduct;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d54f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s917a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who knows or reasonably should have known that the broadcast or distribution of the intimate visual image or visual image of sexually explicit conduct is likely—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida82d54f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s917a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to cause harm, harassment, intimidation, emotional distress, or financial loss for the person depicted in the intimate visual image or visual image of sexually explicit conduct; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82d54f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s917a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to harm substantially the depicted person with respect to that person’s health, safety, business, calling, career, financial condition, reputation, or personal relationships; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d54fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s917a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose conduct, under the circumstances, had a reasonably direct and palpable connection to a military mission or military environment,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is guilty of wrongful distribution of intimate visual images or visual images of sexually explicit conduct and shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82d54fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s917a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82d54fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s917a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Broadcast","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “broadcast” means to electronically transmit a visual image with the intent that it be viewed by a person or persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d54fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s917a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribute","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “distribute” means to deliver to the actual or constructive possession of another person, including transmission by mail or electronic means.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d54fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s917a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intimate visual image","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “intimate visual image” means a visual image that depicts a private area of a person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d54ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s917a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Private area","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “private area” means the naked or underwear-clad genitalia, anus, buttocks, or female areola or nipple.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d5500-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s917a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reasonable expectation of privacy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “reasonable expectation of privacy” means circumstances in which a reasonable person would believe that a private area of the person, or sexually explicit conduct involving the person, would not be visible to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d5501-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s917a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sexually explicit conduct","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “sexually explicit conduct” means actual or simulated genital-genital contact, oral-genital contact, anal-genital contact, or oral-anal contact, whether between persons of the same or opposite sex, bestiality, masturbation, or sadistic or masochistic abuse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d5502-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s917a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Visual image","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “visual image” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida82d5503-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s917a/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any developed or undeveloped photograph, picture, film, or video.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82d5504-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s917a/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any digital or computer image, picture, film, or video made by any means, including those transmitted by any means, including streaming media, even if not stored in a permanent format.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82d5505-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s917a/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any digital or electronic data capable of conversion into a visual image.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida82d5506-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tV/s533/a"},"text":"Pub. L. 115–91, div. A, title V, § 533(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1389"},"text":"131 Stat. 1389","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
