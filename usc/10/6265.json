{"tag":"section","attrib":{"id":"idaac90fb0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6265"},"text":null,"children":[{"tag":"num","attrib":{"value":"6265"},"text":"§ 6265.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of probabilistic risk assessment to ensure nuclear safety of facilities of the Administration and the Office of Environmental Management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaac90fb1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6265/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nuclear Safety at NNSA and DOE Facilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator and the Secretary of Energy shall ensure that the methods for assessing, certifying, and overseeing nuclear safety at the facilities specified in subsection (c) use national and international standards and nuclear industry best practices, including probabilistic or quantitative risk assessment if sufficient data exist.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90fb2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6265/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adequate Protection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The use of probabilistic or quantitative risk assessment under subsection (a) shall be to support, rather than replace, the requirement under section 182 of the Atomic Energy Act of 1954 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2232"},"text":"42 U.S.C. 2232","children":[],"tail":") that the utilization or production of special nuclear material will be in accordance with the common defense and security and will provide adequate protection to the health and safety of the public."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90fb3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6265/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Facilities Specified","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall apply—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac90fb4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6265/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Administrator with respect to the national security laboratories and the nuclear weapons production facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90fb5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6265/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Secretary of Energy with respect to defense nuclear facilities of the Office of Environmental Management of the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac90fb6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1424"},"text":"139 Stat. 1424","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac90fb7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac90fb8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac90fb9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2735"},"text":"section 2735 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
