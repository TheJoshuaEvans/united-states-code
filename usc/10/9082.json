{"tag":"section","attrib":{"id":"idab63eef0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082"},"text":null,"children":[{"tag":"num","attrib":{"value":"9082"},"text":"§ 9082.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief of Space Operations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab63eef1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab63eef2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is a Chief of Space Operations, appointed by the President, by and with the advice and consent of the Senate, from the general officers of the Space Force. The Chief serves at the pleasure of the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63eef3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief shall be appointed for a term of four years. In time of war or during a national emergency declared by Congress, the Chief may be reappointed for a term of not more than four years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63eef4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President may appoint an officer as Chief of Space Operations only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab63eef5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer has had significant experience in joint duty assignments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab63eef6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such experience includes at least one full tour of duty in a joint duty assignment (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s664/d"},"text":"section 664(d) of this title","children":[],"tail":") as a general officer of the Space Force."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63eef7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may waive paragraph (3) in the case of an officer if the President determines such action is necessary in the national interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab63eef8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grade","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief, while so serving, has the grade of general without vacating the permanent grade of the officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab63eef9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to the Secretary of the Air Force","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise prescribed by law and subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9013/f"},"text":"section 9013(f) of this title","children":[],"tail":", the Chief performs the duties of such position under the authority, direction, and control of the Secretary of the Air Force and is directly responsible to the Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab63eefa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the authority, direction, and control of the Secretary of the Air Force, the Chief shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab63eefb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preside over the Office of the Chief of Space Operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63eefc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmit the plans and recommendations of the Office of the Chief of Space Operations to the Secretary and advise the Secretary with regard to such plans and recommendations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63eefd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after approval of the plans or recommendations of the Office of the Chief of Space Operations by the Secretary, act as the agent of the Secretary in carrying them into effect;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63eefe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise supervision, consistent with the authority assigned to commanders of unified or specified combatant commands under chapter 6 of this title, over such of the members and organizations of the Space Force as the Secretary determines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63eeff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform duties prescribed for the Chief of Space Operations by sections 171 and 3104 of this title and other provisions of law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63ef00-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other military duties, not otherwise assigned by law, as are assigned to the Chief by the President, the Secretary of Defense, or the Secretary of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab63ef01-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Joint Chiefs of Staff","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab63ef02-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Space Operations shall be a member of the Joint Chiefs of Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63ef03-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent that such action does not impair the independence of the Chief in the performance of the duties of the Chief as a member of the Joint Chiefs of Staff pursuant to paragraph (1), the Chief shall inform the Secretary of the Air Force regarding military advice rendered by members of the Joint Chiefs of Staff on matters affecting the Department of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63ef04-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the authority, direction, and control of the Secretary of Defense, the Chief shall keep the Secretary of the Air Force fully informed of significant military operations affecting the duties and responsibilities of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab63ef05-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vacancy in Position of Chief of Space Operations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"When there is a vacancy in the position of Chief of Space Operations or during the absence or disability of the Chief of Space Operations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab63ef06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Vice Chief of Space Operations shall perform the duties of the Chief of Space Operations until a successor is appointed or the absence or disability ceases; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63ef07-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if there is a vacancy in the position of the Vice Chief of Space Operations or the Vice Chief of Space Operations is absent or disabled, unless the President directs otherwise, the most senior officer of the Space Force in the Space Staff who is not absent or disabled and who is not restricted in performance of duty shall perform the duties of the Chief of Space Operations until the earliest of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab63ef08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appointment of a successor to the Chief of Space Operations or the Vice Chief of Space Operations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab63ef09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9082/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cessation of the absence or disability of the Chief of Space Operations or Vice Chief of Space Operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab63ef0a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s953/a"},"text":"Pub. L. 116–92, div. A, title IX, § 953(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1563"},"text":"133 Stat. 1563","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s922/c"},"text":"Pub. L. 116–283, div. A, title IX, § 922(c)","children":[],"tail":", title XVIII, § 1883(b)(2), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3806"},"text":"134 Stat. 3806","children":[],"tail":", 4294; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1741/b/7"},"text":"Pub. L. 118–31, div. A, title XVII, § 1741(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/681"},"text":"137 Stat. 681","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV"},"text":"Pub. L. 118–159, div. A, title V","children":[],"tail":", §§ 509C(b), 521(j), "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1873"},"text":"138 Stat. 1873","children":[],"tail":", 1882.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab63ef0b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab63ef0c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab63ef0d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(1), (3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s521/j/1"},"text":"Pub. L. 118–159, § 521(j)(1)","children":[],"tail":", struck out “, flag, or equivalent” after “general”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s521/j/2"},"text":"Pub. L. 118–159, § 521(j)(2)","children":[],"tail":", substituted “grade of general” for “grade in the Space Force equivalent to the grade of general in the Army, Air Force, and Marine Corps, or admiral in the Navy”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s509C/b"},"text":"Pub. L. 118–159, § 509C(b)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1741/b/7/A"},"text":"Pub. L. 118–31, § 1741(b)(7)(A)","children":[],"tail":", substituted “sections 171 and 3104 of this title and other provisions of law” for “sections 171, 1808(a), and 1847(e)(4)(B), (5) of this title and other provision of law”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1741/b/7/B"},"text":"Pub. L. 118–31, § 1741(b)(7)(B)","children":[],"tail":", substituted “The Chief” for “Commencing one year after the date of the enactment of the United States Space Force Act, the Chief”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s922/c/1/A"},"text":"Pub. L. 116–283, § 922(c)(1)(A)","children":[],"tail":", substituted “general, flag, or equivalent officers of the Space Force” for “general officers of the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s922/c/1/B"},"text":"Pub. L. 116–283, § 922(c)(1)(B)","children":[],"tail":", added pars. (3) and (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s922/c/2"},"text":"Pub. L. 116–283, § 922(c)(2)","children":[],"tail":", substituted “grade in the Space Force equivalent to the grade of general in the Army, Air Force, and Marine Corps, or admiral in the Navy” for “grade of general”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s922/c/3"},"text":"Pub. L. 116–283, § 922(c)(3)","children":[],"tail":", added par. (5). Former par. (5) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1883/b/2"},"text":"Pub. L. 116–283, § 1883(b)(2)","children":[],"tail":", substituted “, 1808(a), and 1847(e)(4)(B), (5)” for “and 2547”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s922/c/3"},"text":"Pub. L. 116–283, § 922(c)(3)","children":[],"tail":", redesignated par. (5) as (6)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab63ef0e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab63ef0f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1883/b/2"},"text":"section 1883(b)(2) of Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab63ef10-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Designation of Force Design Architect for Department of Defense Space Systems","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVI/s1602/b/4"},"text":"Pub. L. 117–81, div. A, title XVI, § 1602(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2077"},"text":"135 Stat. 2077","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dA/tXVI/s1602/b/4"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":"], the Secretary of Defense shall—"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate the Chief of Space Operations the force design architect for space systems of the Armed Forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the congressional defense committees [Committee on Armed Services and Committee on Appropriations of the Senate and House of Representatives] a certification of such designation.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab63ef11-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Service","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s953/b"},"text":"Pub. L. 116–92, div. A, title IX, § 953(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1564"},"text":"133 Stat. 1564","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dA/tIX/s953/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incumbent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The individual serving as Commander of the Air Force Space Command as of the day before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"] may serve as the Chief of Space Operations under subsection (a) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9082"},"text":"section 9082 of title 10","children":[],"tail":", United States Code (as added by subsection (a) of this section), after that date without further appointment as otherwise provided for by subsection (a) of such section 9082."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"U.S. space command","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"During the one-year period beginning on the date of the enactment of this Act, the Secretary of Defense may authorize an officer serving as the Chief of Space Operations to serve concurrently as the Commander of the United States Space Command, without further appointment.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
