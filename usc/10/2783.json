{"tag":"section","attrib":{"id":"ida9d0f38d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2783"},"text":null,"children":[{"tag":"num","attrib":{"value":"2783"},"text":"§ 2783.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonappropriated fund instrumentalities: financial management and use of nonappropriated funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9d0f38e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2783/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulation of Management and Use of Nonappropriated Funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall prescribe regulations governing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9d0f38f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2783/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purposes for which nonappropriated funds of a nonappropriated fund instrumentality of the United States within the Department of Defense may be expended; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d0f390-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2783/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial management of such funds to prevent waste, loss, or unauthorized use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9d0f391-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2783/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties for Violations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9d0f392-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2783/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A civilian employee of the Department of Defense who is paid from nonappropriated funds and who commits a substantial violation of the regulations prescribed under subsection (a) shall be subject to the same penalties as are provided by law for misuse of appropriations by a civilian employee of the Department of Defense paid from appropriated funds. The Secretary of Defense shall prescribe regulations to carry out this paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d0f393-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2783/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide in regulations that a violation of the regulations prescribed under subsection (a) by a person subject to chapter 47 of this title (the Uniform Code of Military Justice) is punishable as a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s892"},"text":"section 892 of this title","children":[],"tail":" (article 92 of the Uniform Code of Military Justice)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9d0f394-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2783/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of Violations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9d0f395-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2783/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A civilian employee of the Department of Defense (whether paid from nonappropriated funds or from appropriated funds), and a member of the armed forces, whose duties include the obligation of nonappropriated funds, shall notify the Secretary of Defense of information which the person reasonably believes evidences—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9d0f396-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2783/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a violation by another person of any law, rule, or regulation regarding the management of such funds; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9d0f397-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2783/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other mismanagement or gross waste of such funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d0f398-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2783/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall designate civilian employees of the Department of Defense or members of the armed forces to receive a notification described in paragraph (1) and ensure the prompt investigation of the validity of information provided in the notification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d0f399-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2783/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe regulations to protect the confidentiality of a person making a notification under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9d0f39a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tIII/s362/a"},"text":"Pub. L. 102–484, div. A, title III, § 362(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2379"},"text":"106 Stat. 2379","children":[],"tail":", § 2490a; renumbered § 2783 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tXI/s1182/a/8/A"},"text":"Pub. L. 103–160, div. A, title XI, § 1182(a)(8)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1771"},"text":"107 Stat. 1771","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9d0f39b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9d0f39c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9d0f39d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2490a"},"text":"section 2490a of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s1182/a/8/A/i"},"text":"Pub. L. 103–160, § 1182(a)(8)(A)(i)","children":[],"tail":", substituted “chapter 47 of this title” for “chapter 47 of title 10, United States Code”, “Justice) is” for “Justice), is”, and “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s892"},"text":"section 892 of this title","children":[],"tail":"” for “section 892 of such title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s1182/a/8/A/ii"},"text":"Pub. L. 103–160, § 1182(a)(8)(A)(ii)","children":[],"tail":", substituted “armed forces” for “Armed Forces”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9d0f39e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9d0f39f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Standardization of Certain Programs and Activities of Military Exchanges","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tIII/s361"},"text":"Pub. L. 102–484, div. A, title III, § 361","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2379"},"text":"106 Stat. 2379","children":[],"tail":", directed the Secretary of Defense to standardize among the military departments the accounting, financial reporting formats, and automatic data processing and telecommunications data transfer of information by no later than "},{"tag":"date","attrib":{"date":"1994-03-31"},"text":"Mar. 31, 1994","children":[],"tail":", and report to Congress, no later than "},{"tag":"date","attrib":{"date":"1993-03-31"},"text":"Mar. 31, 1993","children":[],"tail":", on other programs and activities that could be standardized or consolidated."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
