{"tag":"section","attrib":{"id":"idab155ab9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8261"},"text":null,"children":[{"tag":"num","attrib":{"value":"8261"},"text":"§ 8261.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presentation of United States flag upon retirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab155aba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8261/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presentation of Flag","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon the release of a member of the Navy or Marine Corps from active duty for retirement or transfer to the Fleet Reserve or the Fleet Marine Corps Reserve, the Secretary of the Navy shall present a United States flag to the member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab155abb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8261/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multiple Presentations Not Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member is not eligible for a presentation of a flag under subsection (a) if the member has previously been presented a flag under this section or any other provision of law providing for the presentation of a United States flag incident to release from active service for retirement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab155abc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8261/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Cost to Recipient","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The presentation of a flag under this section shall be at no cost to the recipient.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab155abd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tVI/s644/b/1"},"text":"Pub. L. 105–261, div. A, title VI, § 644(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2048"},"text":"112 Stat. 2048","children":[],"tail":", § 6141; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s652/e"},"text":"Pub. L. 106–65, div. A, title VI, § 652(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/666"},"text":"113 Stat. 666","children":[],"tail":"; renumbered § 8261, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/10"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1835"},"text":"132 Stat. 1835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab155abe-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab155abf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab155ac0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag"