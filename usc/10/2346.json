{"tag":"section","attrib":{"id":"ida96a6999-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2346"},"text":null,"children":[{"tag":"num","attrib":{"value":"2346"},"text":"§ 2346.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crediting of receipts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any receipt of the United States as a result of an agreement entered into under this subchapter shall be credited, at the option of the Secretary of Defense, to (1) the appropriation, fund, or account used in incurring the obligation, or (2) an appropriate appropriation, fund, or account currently available for the purposes for which the expenditures were made.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida96a699a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/323/s2/a"},"text":"Pub. L. 96–323, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-04"},"text":"Aug. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1018"},"text":"94 Stat. 1018","children":[],"tail":", § 2326; renumbered § 2346, "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXIII/s1304/a/1"},"text":"Pub. L. 99–145, title XIII, § 1304(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/741"},"text":"99 Stat. 741","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tIX/s931/e/1"},"text":"Pub. L. 101–189, div. A, title IX, § 931(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1535"},"text":"103 Stat. 1535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXIII/s1317/f"},"text":"Pub. L. 103–337, div. A, title XIII, § 1317(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2900"},"text":"108 Stat. 2900","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida96a699b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida96a699c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida96a699d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" substituted “shall be credited, at the option of the Secretary of Defense, to (1) the appropriation, fund, or account used in incurring the obligation, or (2) an appropriate appropriation, fund, or account currently available for the purposes for which the expenditures were made” for “shall be credited to applicable appropriations, accounts, and funds of the Department of Defense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" substituted “this subchapter” for “this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2326"},"text":"section 2326 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","to