{"tag":"section","attrib":{"id":"ida887f82f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1086a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1086a"},"text":"§ 1086a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain former spouses: extension of period of eligibility for health benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida887f830-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1086a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Conversion Health Policies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall inform each person who has been a dependent for a period of one year or more under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072/2/H"},"text":"section 1072(2)(H) of this title","children":[],"tail":" of the availability of a conversion health policy for purchase by the person. A conversion health policy offered under this subsection shall provide coverage for not less than a 24-month period."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida887f831-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1086a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Purchase","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida887f832-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1086a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (2), if a person who is a dependent for a one-year period under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072/2/H"},"text":"section 1072(2)(H) of this title","children":[],"tail":" purchases a conversion health policy within that period (or within a reasonable time after that period as prescribed by the Secretary of Defense), the person shall continue to be eligible for medical and dental care in the manner described in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1076"},"text":"section 1076 of this title","children":[],"tail":" and health benefits under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1086"},"text":"section 1086 of this title","children":[],"tail":" until the end of the 24-month period beginning on the later of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida887f833-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1086a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date the person is no longer a dependent under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072/2/H"},"text":"section 1072(2)(H) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida887f834-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1086a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the purchase of the policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida887f835-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1086a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The extended period of eligibility provided under paragraph (1) shall apply only with regard to a condition of the person that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida887f836-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1086a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exists on the date on which coverage under the conversion health policy begins; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida887f837-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1086a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which care is not provided under the policy solely on the grounds that the condition is a preexisting condition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida887f838-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1086a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Unavailability of Policies","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida887f839-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1086a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Secretary of Defense is unable, within a reasonable time, to enter into a contract with a private insurer to offer conversion health policies under subsection (a) at a rate not to exceed the payment required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8905a/d/1/A"},"text":"section 8905a(d)(1)(A) of title 5","children":[],"tail":" for comparable coverage, the Secretary shall provide the coverage required under such a policy through the Civilian Health and Medical Program of the Uniformed Services. Subject to paragraph (2), a person receiving coverage under this subsection shall be required to pay into the Military Health Care Account or other appropriate account an amount equal to the sum of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida887f83a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1086a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual and Government contributions which would be required in the case of a person enrolled in a health benefits plan contracted for under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1079"},"text":"section 1079 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida887f83b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1086a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount necessary for administrative expenses, but not to exceed two percent of the amount under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida887f83c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1086a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount paid by a person who purchases a conversion health policy from the Secretary of Defense under paragraph (1) may not exceed the payment required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8905a/d/1/A"},"text":"section 8905a(d)(1)(A) of title 5","children":[],"tail":" for comparable coverage."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida887f83d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1086a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to reduce premiums required under paragraph (1), the Secretary of Defense may offer a program of coverage that, with respect to mental health services, offers reduced coverage and increased cost-sharing by the purchaser.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida887f83e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1086a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conversion Health Policy Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “conversion health policy” means a health insurance policy with a private insurer, developed through negotiations between the Secretary of Defense and the private insurer, that is available for purchase by or for the use of a person who is a dependent for a one-year period under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072/2/H"},"text":"section 1072(2)(H) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida887f83f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVII/s731/b/1"},"text":"Pub. L. 101–189, div. A, title VII, § 731(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1482"},"text":"103 Stat. 1482","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dD/tXLIV/s4407/b"},"text":"Pub. L. 102–484, div. D, title XLIV, § 4407(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2707"},"text":"106 Stat. 2707","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/35/tII/s202/a/16"},"text":"Pub. L. 103–35, title II, § 202(a)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-05-31"},"text":"May 31, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/102"},"text":"107 Stat. 102","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida887f840-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida887f841-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida887f842-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/35"},"text":"Pub. L. 103–35","children":[],"tail":" made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/s4407/b/2"},"text":"Pub. L. 102–484, § 4407(b)(2)","children":[],"tail":". See 1992 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s4407/b/1"},"text":"Pub. L. 102–484, § 4407(b)(1)","children":[],"tail":", inserted at end “A conversion health policy offered under this subsection shall provide coverage for not less than a 24-month period.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s4407/b/2"},"text":"Pub. L. 102–484, § 4407(b)(2)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/35"},"text":"Pub. L. 103–35","children":[],"tail":", substituted “24-month period” for “one-year period” the second place appearing in the introductory provisions of par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s4407/b/3"},"text":"Pub. L. 102–484, § 4407(b)(3)","children":[],"tail":", (4), added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida887f843-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida887f844-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/35"},"text":"Pub. L. 103–35","children":[],"tail":" applicable as if included in the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/35/s202/b"},"text":"section 202(b) of Pub. L. 103–35","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s155"},"text":"section 155 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida887f845-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to a person referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072/2/H"},"text":"10 U.S.C. 1072(2)(H)","children":[],"tail":" whose decree of divorce, dissolution, or annulment becomes final on or after "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", and to a person so referred to whose decree became final during the period from "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":" to "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", as if section had become effective on "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/s731/d"},"text":"section 731(d) of Pub. L. 101–189","children":[],"tail":", set out as an Effective Date of 1989 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072"},"text":"section 1072 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida887f846-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application of Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":" to Existing Contracts"}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dD/tXLIV/s4407/c"},"text":"Pub. L. 102–484, div. D, title XLIV, § 4407(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2708"},"text":"106 Stat. 2708","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/484/dD/tXLIV/s4407/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In the case of conversion health policies provided under section 1145(b) or 1086a(a) of title 10, United States Code, and in effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":"], the Secretary of Defense shall—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrange with the private insurer providing these policies to extend the term of the policies (and coverage of preexisting conditions) as provided by the amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1145"},"text":"section 1145 of this title","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make other arrangements to implement the amendments made by this section with respect to these policies.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida887f847-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Applicability of Other Conversion Health Policies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dD/tXLIV/s4408/c"},"text":"Pub. L. 102–484, div. D, title XLIV, § 4408(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2712"},"text":"106 Stat. 2712","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/484/dD/tXLIV/s4408/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No person may purchase a conversion health policy under section 1145(b) or 1086a of title 10, United States Code, on or after ","children":[{"tag":"date","attrib":{"date":"1994-10-01"},"text":"October 1, 1994","children":[],"tail":". A person covered by such a conversion health policy on that date may cancel that policy and enroll in a health benefits plan under section 1078a of such title."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No person may be covered concurrently by a conversion health policy under section 1145(b) or 1086a of such title and a health benefits plan under section 1078a of such title.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
