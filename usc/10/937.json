{"tag":"section","attrib":{"id":"ida832101f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s937"},"text":null,"children":[{"tag":"num","attrib":{"value":"937"},"text":"§ 937.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 137. Articles to be explained","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8321020-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s937/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enlisted Members","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8321021-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s937/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The sections (articles) of this chapter specified in paragraph (3) shall be carefully explained to each enlisted member at the time of (or within fourteen days after)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8321022-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s937/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the member’s initial entrance on active duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8321023-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s937/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the member’s initial entrance into a duty status with a reserve component; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8321024-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s937/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the member’s initial entrance on active duty or into a space force active status.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8321025-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s937/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such sections (articles) shall be explained again—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8321026-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s937/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the member has completed six months of active duty or, in the case of a member of a reserve component, after the member has completed basic or recruit training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8321027-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s937/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after a member of the Space Force has completed six months of sustained duty or in the case of a member not on sustained duty, after the member has completed basic or recruit training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8321028-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s937/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time when the member reenlists.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8321029-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s937/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection applies with respect to sections 802, 803, 807–815, 825, 827, 831, 837, 838, 855, 877–934, and 937–939 of this title (articles 2, 3, 7–15, 25, 27, 31, 37, 38, 55, 77–134, and 137–139).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida832102a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s937/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida832102b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s937/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The sections (articles) of this chapter specified in paragraph (2) shall be carefully explained to each officer at the time of (or within six months after)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida832102c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s937/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the initial entrance of the officer on active duty as an officer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida832102d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s937/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the initial commissioning of the officer in a reserve component or the Space Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida832102e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s937/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection applies with respect to the sections (articles) specified in subsection (a)(3) and such other sections (articles) as the Secretary concerned may prescribe by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida832102f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s937/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training for Certain Officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under regulations prescribed by the Secretary concerned, officers with the authority to convene courts-martial or to impose non-judicial punishment shall receive periodic training regarding the purposes and administration of this chapter. Under regulations prescribed by the Secretary of Defense, officers assigned to duty in a joint command or a combatant command, who have such authority, shall receive additional specialized training regarding the purposes and administration of this chapter with respect to joint commands and the combatant commands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8321030-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s937/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability and Maintenance of Text","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The text of this chapter and the text of the regulations prescribed by the President under this chapter shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8321031-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s937/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made available to a member on active duty, to a member of a reserve component, or to a member of the Space Force, upon request by the member, for the member’s personal examination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8321032-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s937/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintained by the Secretary of Defense in electronic formats that are updated periodically and made available on the Internet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8321033-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/78"},"text":"70A Stat. 78","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tVIII/s804/d"},"text":"Pub. L. 99–661, div. A, title VIII, § 804(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3907"},"text":"100 Stat. 3907","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXI/s1152"},"text":"Pub. L. 104–106, div. A, title XI, § 1152","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/468"},"text":"110 Stat. 468","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLXI/s5503"},"text":"Pub. L. 114–328, div. E, title LXI, § 5503","children":[],"tail"