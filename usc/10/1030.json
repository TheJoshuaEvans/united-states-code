{"tag":"section","attrib":{"id":"ida849de1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030"},"text":null,"children":[{"tag":"num","attrib":{"value":"1030"},"text":"§ 1030.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bonus to encourage Department of Defense personnel to refer persons for appointment as officers to serve in health professions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida849de1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Pay Bonus.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida849de1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may authorize the appropriate Secretary to pay a bonus under this section to an individual referred to in paragraph (2) who refers to a military recruiter a person who has not previously served in an armed force and, after such referral, takes an oath of enlistment that leads to appointment as a commissioned officer, or accepts an appointment as a commissioned officer, in an armed force in a health profession designated by the appropriate Secretary for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida849de1d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Individuals eligible for bonus","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (c), the following individuals are eligible for a referral bonus under this section:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida849de1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the armed forces in a regular component of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida849de1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the armed forces in a reserve component of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida849de20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the armed forces in a retired status, including a member under 60 years of age who, but for age, would be eligible for retired or retainer pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida849de21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A civilian employee of a military department or the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida849de22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Referral","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, a referral for which a bonus may be paid under subsection (a) occurs—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida849de23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the individual concerned contacts a military recruiter on behalf of a person interested in taking an oath of enlistment that leads to appointment as a commissioned officer, or accepting an appointment as a commissioned officer, as applicable, in an armed force in a health profession; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida849de24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when a person interested in taking an oath of enlistment that leads to appointment as a commissioned officer, or accepting an appointment as a commissioned officer, as applicable, in an armed force in a health profession contacts a military recruiter and informs the recruiter of the role of the individual concerned in initially recruiting the person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida849de25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain Referrals Ineligible.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida849de26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Referral of immediate family","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the armed forces or civilian employee of a military department or the Department of Defense may not be paid a bonus under subsection (a) for the referral of an immediate family member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida849de27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members in recruiting roles","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the armed forces or civilian employee of a military department or the Department of Defense serving in a recruiting or retention assignment, or assigned to other duties regarding which eligibility for a bonus under subsection (a) could (as determined by the appropriate Secretary) be perceived as creating a conflict of interest, may not be paid a bonus under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida849de28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Junior reserve officers’ training corps instructors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the armed forces detailed under subsection (c)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2031"},"text":"section 2031 of this title","children":[],"tail":" to serve as an administrator or instructor in the Junior Reserve Officers’ Training Corps program or a retired member of the armed forces employed as an administrator or instructor in the program under subsection (d) of such section may not be paid a bonus under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida849de29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of Bonus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of the bonus payable for a referral under subsection (a) may not exceed $2,000. The amount shall be payable as provided in subsection (e).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida849de2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A bonus payable for a referral of a person under subsection (a) shall be paid as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida849de2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than $1,000 shall be paid upon the execution by the person of an agreement to serve as an officer in a health profession in an armed force for not less than three years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida849de2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than $1,000 shall be paid upon the completion by the person of the initial period of military training as an officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida849de2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relation to Prohibition on Bounties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The referral bonus authorized by this section is not a bounty for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s514/a"},"text":"section 514(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida849de2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination With Receipt of Retired Pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A bonus paid under this section to a member of the armed forces in a retired status is in addition to any compensation to which the member is entitled under this title, title 37 or 38, or any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida849de2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate Secretary Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate Secretary” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida849de30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Army, with respect to matters concerning the Army;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida849de31-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Navy, with respect to matters concerning the Navy, the Marine Corps, and the Coast Guard when it is operating as a service in the Navy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida849de32-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Air Force, with respect to matters concerning the Air Force and the Space Force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida849de33-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense, with respect to personnel of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida849de34-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1030/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A bonus may not be paid under subsection (a) with respect to any referral that occurs after ","children":[{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida849de35-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVI/s671/b/1"},"text":"Pub. L. 110–181, div. A, title VI, § 671(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/182"},"text":"122 Stat. 182","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VI, § 615(a), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4485"},"text":"122 Stat. 4485","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tVI/s616/1"},"text":"Pub. L. 111–84, div. A, title VI, § 616(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2354"},"text":"123 Stat. 2354","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVI/s616/1"},"text":"Pub. L. 111–383, div. A, title VI, § 616(1)","children":[],"tail":", title X, § 1075(b)(15), "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4238"},"text":"124 Stat. 4238","children":[],"tail":", 4369; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/23"},"text":"Pub. L. 116–283, div. A, title IX, § 924(b)(23)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3824"},"text":"134 Stat. 3824","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida849de36-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida849de37-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida849de38-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (h)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" inserted “and the Space Force” after “concerning the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1075/b/15"},"text":"Pub. L. 111–383, § 1075(b)(15)","children":[],"tail":", substituted “three years.” for “3 years,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s616/1"},"text":"Pub. L. 111–383, § 616(1)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2010-12-31"},"text":"December 31, 2010","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2010-12-31"},"text":"December 31, 2010","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2008-12-31"},"text":"December 31, 2008","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
