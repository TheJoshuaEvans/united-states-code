{"tag":"section","attrib":{"id":"idaabab7a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6107"},"text":null,"children":[{"tag":"num","attrib":{"value":"6107"},"text":"§ 6107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Center for Security Technology, Analysis, Response, and Testing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaabab7a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator for Nuclear Security shall establish within the nuclear security enterprise a Center for Security Technology, Analysis, Response, and Testing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabab7a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The center established under subsection (a) shall carry out the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabab7a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6107/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide to the Administrator, the Chief of Defense Nuclear Security, and the management and operating contractors of the nuclear security enterprise a wide range of objective expertise on security technologies, systems, analysis, testing, and response forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab7aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6107/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assist the Administrator in developing standards, requirements, analysis methods, and testing criteria with respect to security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab7ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6107/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Collect, analyze, and distribute lessons learned with respect to security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab7ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6107/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Support inspections and oversight activities with respect to security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab7ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6107/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promote professional development and training for security professionals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab7ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6107/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide for advance and bulk procurement for security-related acquisitions that affect multiple facilities of the nuclear security enterprise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab7af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6107/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advocate for continual improvement and security excellence throughout the nuclear security enterprise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab7b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6107/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other duties as the Administrator may assign.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaabab7b1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1343"},"text":"139 Stat. 1343","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaabab7b2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaabab7b3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaabab7b4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2515"},"text":"section 2515 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/2"},"text":"Pub. L. 119–60, § 3111(b)(2)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
