{"tag":"section","attrib":{"id":"ida8bebfc8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407"},"text":null,"children":[{"tag":"num","attrib":{"value":"1407"},"text":"§ 1407.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retired pay base for members who first became members after ","children":[{"tag":"date","attrib":{"date":"1980-09-07"},"text":"September 7, 1980","children":[],"tail":": high-36 month average"}],"tail":null},{"tag":"subsection","attrib":{"id":"ida8bebfc9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Retired Pay Base in Computing Retired Pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The retired pay or retainer pay of any person entitled to that pay who first became a member of a uniformed service after ","children":[{"tag":"date","attrib":{"date":"1980-09-07"},"text":"September 7, 1980","children":[],"tail":", is computed using the retired pay base or retainer pay base determined under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8bebfca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"High-Three Average","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (f), the retired pay base or retainer pay base of a person under this section is the person’s high-three average determined under subsection (c) or (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8bebfcb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Computation of High-Three Average for Members Entitled to Retired or Retainer Pay for Regular Service.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8bebfcc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General rule","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The high-three average of a member entitled to retired or retainer pay under any provision of law other than section 1204 or 1205 or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12731"},"text":"section 12731 of this title","children":[],"tail":" is the amount equal to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8bebfcd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of monthly basic pay to which the member was entitled for the 36 months (whether or not consecutive) out of all the months of active service of the member for which the monthly basic pay to which the member was entitled was the highest, divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8bebfce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 36.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8bebfcf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule for short-term disability retirees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a member who is entitled to retired pay under section 1201 or 1202 of this title and who has completed less than 36 months of active service, the member’s high-three average (notwithstanding paragraph (1)) is the amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8bebfd0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of basic pay to which the member was entitled during the period of the member’s active service, divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8bebfd1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of months (including any fraction thereof) of the member’s active service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8bebfd2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Rule for Reserve Component Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a member of a reserve component who is entitled to retired pay under section 1201 or 1202 of this title, the member’s high-three average (notwithstanding paragraphs (1) and (2)) is computed in the same manner as prescribed in paragraphs (2) and (3) of subsection (d) for a member entitled to retired pay under section 1204 or 1205 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8bebfd3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Computation of High-Three Average for Members and Former Members Entitled to Retired Pay for Nonregular Service.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8bebfd4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retired pay under chapter 1223","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The high-three average of a member or former member entitled to retired pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12731"},"text":"section 12731 of this title","children":[],"tail":" is the amount equal to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8bebfd5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of monthly basic pay to which the member or former member was entitled during the member or former member’s high-36 months (or to which the member or former member would have been entitled if the member or former member had served on active duty during the entire period of the member or former member’s high-36 months), divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8bebfd6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 36.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8bebfd7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonregular service disability retired pay","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The high-three average of a member entitled to retired pay under section 1204 or 1205 of this title is the amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8bebfd8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of monthly basic pay to which the member was entitled during the member’s high-36 months (or to which the member would have been entitled if the member had served on active duty during the entire period of the member’s high-36 months), divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8bebfd9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 36.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8bebfda-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule for short-term disability retirees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a member who is entitled to retired pay under section 1204 or 1205 of this title and who was a member for less than 36 months before being retired under that section, the member’s high-three average (notwithstanding paragraph (2)) is the amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8bebfdb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of basic pay to which the member was entitled during the entire period the member was a member of a uniformed service before being so retired (or to which the member would have been entitled if the member had served on active duty during the entire period the member was a member of a uniformed service before being so retired), divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8bebfdc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of months (including any fraction thereof) which the member was a member before being so retired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8bebfdd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"High-36 months","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The high-36 months of a member or former member whose retired pay is covered by paragraph (1) or (2) are the 36 months (whether or not consecutive) out of all the months before the member or former member became entitled to retired pay or, in the case of a member or former member entitled to retired pay by reason of an election under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12741/a"},"text":"section 12741(a) of this title","children":[],"tail":", before the member or former member completes the service required under such section 12741(a), for which the monthly basic pay to which the member or former member was entitled (or would have been entitled if serving on active duty during those months) was the highest. In the case of a former member, only months during which the former member was a member of a uniformed service may be used for purposes of the preceding sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8bebfde-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation for Enlisted Members Retiring With Less Than","children":[],"tail":" 30 "},{"tag":"inline","attrib":{},"text":"Years’ Service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a member who is retired under section 7314 or 9314 of this title or who is transferred to the Fleet Reserve or Fleet Marine Corps Reserve under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8330"},"text":"section 8330 of this title","children":[],"tail":", the member’s high-36 average shall be computed using only rates of basic pay applicable to months of active duty of the member as an enlisted member."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8bebfdf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for Enlisted Members Reduced in Grade and Officers Who Do Not Serve Satisfactorily in Highest Grade Held","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8bebfe0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Computation based on pre-high-three rules","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a member or former member described in paragraph (2), the retired pay base or retainer pay base is determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1406"},"text":"section 1406 of this title","children":[],"tail":" in the same manner as if the member or former member first became a member of a uniformed service before "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"September 8, 1980","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8bebfe1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Affected members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member or former member referred to in paragraph (1) is a member or former member who by reason of conduct occurring after ","children":[{"tag":"date","attrib":{"date":"2000-10-30"},"text":"October 30, 2000","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8bebfe2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a member retired in an enlisted grade or transferred to the Fleet Reserve or Fleet Marine Corps Reserve, was at any time reduced in grade as the result of a court-martial sentence, nonjudicial punishment, or an administrative action, unless the member was subsequently promoted to a higher enlisted grade or appointed to a commissioned or warrant grade; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8bebfe3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an officer, is retired in a grade lower than the highest grade in which served pursuant to section 1370 or 1370a of this title that the officer served on active duty satisfactorily in that grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8bebfe4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule for enlisted members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a member who retires within three years after having been reduced in grade as described in paragraph (2)(A), who retires in an enlisted grade that is lower than the grade from which reduced, and who would be subject to paragraph (1) but for a subsequent promotion to a higher enlisted grade or a subsequent appointment to a warrant or commissioned grade, the rates of basic pay used in the computation of the member’s high-36 average for the period of the member’s service in a grade higher than the grade in which retired shall be the rates of pay that would apply if the member had been serving for that period in the grade in which retired.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8bebfe5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule for officers who served in grade o–9 or o–10 and retired in grade o–8","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an officer who served in the temporary grade of O–9 or O–10 and received a conditional or final retirement in the permanent grade of O–8 pursuant to section 1370 or 1370a of this title, the retired pay base or retainer pay shall be the lower of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8bebfe6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined under subsection (c) or (d), as applicable; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8bebfe7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1407/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1406"},"text":"section 1406 of this title","children":[],"tail":", as if the officer first became a member of a uniformed service before "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"September 8, 1980","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","a