{"tag":"section","attrib":{"id":"ida83baccd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950h"},"text":null,"children":[{"tag":"num","attrib":{"value":"950h"},"text":"§ 950h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appellate counsel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida83bacce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall, by regulation, establish procedures for the appointment of appellate counsel for the United States and for the accused in military commissions under this chapter. Appellate counsel shall meet the qualifications of counsel for appearing before military commissions under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida83baccf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Representation of United States","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Appellate counsel appointed under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida83bacd0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall represent the United States in any appeal or review proceeding under this chapter before the United States Court of Military Commission Review; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83bacd1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, when requested to do so by the Attorney General in a case arising under this chapter, represent the United States before the United States Court of Appeals for the District of Columbia Circuit or the Supreme Court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida83bacd2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Representation of Accused","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The accused shall be represented by appellate counsel appointed under subsection (a) before the United States Court of Military Commission Review, the United States Court of Appeals for the District of Columbia Circuit, and the Supreme Court, and by civilian counsel if retained by the accused. Any such civilian counsel shall meet the qualifications under paragraph (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s949c/b"},"text":"section 949c(b) of this title","children":[],"tail":" for civilian counsel appearing before military commissions under this chapter and shall be subject to the requirements of paragraph (7) of that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida83bacd3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tXVIII/s1802"},"text":"Pub. L. 111–84, div. A, title XVIII, § 1802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2604"},"text":"123 Stat. 2604","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida83bacd4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida83bacd5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida83bacd6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 950h, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/366/s3/a/1"},"text":"Pub. L. 109–366, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2622"},"text":"120 Stat. 2622","children":[],"tail":", related to appellate counsel, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
