{"tag":"section","attrib":{"id":"ida893df85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1109"},"text":null,"children":[{"tag":"num","attrib":{"value":"1109"},"text":"§ 1109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organ and tissue donor program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida893df86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities of the Secretary of Defense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall ensure that the advanced systems developed for recording armed forces members’ personal data and information (such as the SMARTCARD, MEDITAG, and Personal Information Carrier) include the capability to record organ and tissue donation elections.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida893df87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities of the Secretaries of the Military Departments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretaries of the military departments shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida893df88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1109/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" appropriate information about organ and tissue donation is provided—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida893df89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1109/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to each officer candidate during initial training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida893df8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1109/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to each recruit—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida893df8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1109/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after completion by the recruit of basic training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida893df8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1109/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before arrival of the recruit at the first duty assignment of the recruit;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida893df8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1109/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the armed forces are given recurring, specific opportunities to elect to be organ or tissue donors during service in the armed forces and upon retirement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida893df8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1109/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the armed forces electing to be organ or tissue donors are encouraged to advise their next of kin concerning the donation decision and any subsequent change of that decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida893df8f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1109/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities of the Surgeons General of the Military Departments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Surgeons General of the military departments shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida893df90-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1109/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate training is provided to enlisted and officer medical personnel to facilitate the effective operation of organ and tissue donation activities under garrison conditions and, to the extent possible, under operational conditions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida893df91-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1109/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical logistical activities can, to the extent possible without jeopardizing operational requirements, support an effective organ and tissue donation program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida893df92-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tVII/s741/b/1"},"text":"Pub. L. 105–261, div. A, title VII, § 741(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2073"},"text":"112 Stat. 2073","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1087(a)(8)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–290.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida893df93-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida893df94-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida893df95-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" struck out “(1)” before “The Secretaries” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida893df96-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida893df97-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tVII/s741/a"},"text":"Pub. L. 105–261, div. A, title VII, § 741(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2073"},"text":"112 Stat. 2073","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/261/dA/tVII/s741/a"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress makes the following findings:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Organ and tissue transplantation is one of the most remarkable medical success stories in the history of medicine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each year, the number of people waiting for organ or tissue transplantation increases. It is estimated that there are approximately 39,000 patients, ranging in age from babies to those in retirement, awaiting transplants of kidneys, hearts, livers, and other solid organs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Defense has made significant progress in increasing the awareness of the importance of organ and tissue donations among members of the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The inclusion of organ and tissue donor elections in the Defense Enrollment Eligibility Reporting System (DEERS) central database represents a major step in ensuring that organ and tissue donor elections are a matter of record and are accessible in a timely manner.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida893df98-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tVII/s741/c"},"text":"Pub. L. 105–261, div. A, title VII, § 741(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2074"},"text":"112 Stat. 2074","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1067/3"},"text":"Pub. L. 106–65, div. A, title X, § 1067(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/774"},"text":"113 Stat. 774","children":[],"tail":", directed the Secretary of Defense to submit to committees of Congress a report on the implementation of this section not later than "},{"tag":"date","attrib":{"date":"1999-09-01"},"text":"Sept. 1, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
