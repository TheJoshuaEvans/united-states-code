{"tag":"section","attrib":{"id":"idab17a446-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8286"},"text":null,"children":[{"tag":"num","attrib":{"value":"8286"},"text":"§ 8286.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Navy Band; officer in charge","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab17a447-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8286/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is a Navy band known as the United States Navy Band.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab17a448-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8286/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab17a449-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8286/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer of the Navy designated for limited duty under section 8139 or 8146 of this title who is serving in a grade above lieutenant may be detailed by the Secretary of the Navy as Officer in Charge of the United States Navy Band.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab17a44a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8286/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" While serving as Officer in Charge of the United States Navy Band, an officer shall hold the grade of captain if appointed to that grade by the President, by and with the advice and consent of the Senate. Such an appointment may be made notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8146/d"},"text":"section 8146(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab17a44b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/388"},"text":"70A Stat. 388","children":[],"tail":", § 6221; "},{"tag":"ref","attrib":{"href":"/us/pl/87/649/s14c/44"},"text":"Pub. L. 87–649, § 14c(44)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/501"},"text":"76 Stat. 501","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s513/16"},"text":"Pub. L. 96–513, title V, § 513(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2932"},"text":"94 Stat. 2932","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s510/a"},"text":"Pub. L. 107–107, div. A, title V, § 510(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1091"},"text":"115 Stat. 1091","children":[],"tail":"; renumbered § 8286 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 807(b)(12), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1835"},"text":"132 Stat. 1835","children":[],"tail":", 1840.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab17a44c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab17a44d-3a6f-11f1-a58a-d8db54b14a