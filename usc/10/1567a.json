{"tag":"section","attrib":{"id":"ida8f33e6a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1567a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1567a"},"text":"§ 1567a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory notification of issuance of military protective order to civilian law enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8f33e6b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1567a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial Notification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the event a military protective order is issued against a member of the armed forces, the commander of the unit to which the member is assigned shall, not later than seven days after the date of the issuance of the order, notify the appropriate civilian authorities of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8f33e6c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1567a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuance of the protective order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f33e6d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1567a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individuals involved in the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f33e6e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1567a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification in Event of Transfer","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the event that a member of the armed forces against whom a military protective order is issued is transferred to another unit—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8f33e6f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1567a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than the date of the transfer, the commander of the unit from which the member is transferred shall notify the commander of the unit to which the member is transferred of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8f33e70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1567a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuance of the protective order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8f33e71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1567a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individuals involved in the order; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f33e72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1567a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than seven days after receiving the notice under paragraph (1), the commander of the unit to which the member is transferred shall provide notice of the order to the appropriate civilian authorities in accordance with subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f33e73-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1567a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of Changes or Termination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The commander of the unit to which the member is assigned also shall notify the appropriate civilian authorities of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8f33e74-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1567a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any change made in a protective order covered by subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f33e75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1567a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the termination of the protective order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8f33e76-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title V, § 562(a), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4470"},"text":"122 Stat. 4470","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tX/s1073/a/17"},"text":"Pub. L. 111–84, div. A, title X, § 1073(a)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2473"},"text":"123 Stat. 2473","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tV/s543/a"},"text":"Pub. L. 116–92, div. A, title V, § 543(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1376"},"text":"133 Stat. 1376","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8f33e77-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8f33e78-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8f33e79-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s543/a/1"},"text":"Pub. L. 116–92, § 543(a)(1)","children":[],"tail":", substituted “, the commander of the unit to which the member is assigned shall, not later than seven days after the date of the issuance of the order, notify” for “and any individual involved in the order does not reside on a military installation at any time during the duration of the military protective order, the commander of the military installation shall notify” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s543/a/3"},"text":"Pub. L. 116–92, § 543(a)(3)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s543/a/2"},"text":"Pub. L. 116–92, § 543(a)(2)","children":[],"tail":", (4), redesignated subsec. (b) as (c) and substituted “commander of the unit to which the member is assigned” for “commander of the military installation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" made technical amendment to section catchline."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
