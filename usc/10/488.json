{"tag":"section","attrib":{"id":"ida7c45a7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s488"},"text":null,"children":[{"tag":"num","attrib":{"value":"488"},"text":"§ 488.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management and review of electromagnetic spectrum","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7c45a7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s488/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Organization","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7c45a80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s488/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the effective organization and management of the electromagnetic spectrum used by the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c45a81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s488/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish an enduring review and evaluation process that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7c45a82-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s488/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considers all requirements relating to such spectrum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7c45a83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s488/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures that all users of such spectrum, regardless of the classification of such uses, are involved in the decision-making process of the Department concerning the potential sharing, reassigning, or reallocating of such spectrum, or the relocation of the uses by the Department of such spectrum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7c45a84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s488/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7c45a85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s488/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" From time to time as the Secretary and the Chairman of the Joint Chiefs of Staff determine useful for the effective oversight of the access by the Department to electromagnetic spectrum, but not less frequently than every two years, the Secretary and the Chairman shall jointly submit to the congressional defense committees a report on national policy plans regarding implications for such access in bands identified for study for potential reallocation, or under consideration for potential reallocation, by the Policy and Plans Steering Group established by the National Telecommunications and Information Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c45a86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s488/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each report under paragraph (1) shall address, with respect to the electromagnetic spectrum used by the Department that is covered by the report, the implications to the missions of the Department resulting from sharing, reassigning, or reallocating the spectrum, or relocating the uses by the Department of such spectrum, if the Secretary and the Chairman jointly determine that such sharing, reassigning, reallocating, or relocation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7c45a87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s488/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would potentially create a loss of essential military capability to the missions of the Department, as determined under feasibility assessments to ensure comparable capability; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7c45a88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s488/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would not likely be possible within the 10-year period beginning on the date of the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7c45a89-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tX/s1054/a"},"text":"Pub. L. 108–136, div. A, title X, § 1054(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1615"},"text":"117 Stat. 1615","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tX/s1072/a"},"text":"Pub. L. 113–66, div. A, title X, § 1072(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/868"},"text":"127 Stat. 868","children":[],"tail":", 869; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1071/f/7"},"text":"Pub. L. 113–291, div. A, title X, § 1071(f)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3510"},"text":"128 Stat. 3510","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tX/s1065/a/1"},"text":"Pub. L. 114–328, div. A, title X, § 1065(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2409"},"text":"130 Stat. 2409","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7c45a8a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7c45a8b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7c45a8c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" amended section generally. Prior to amendment, section required Secretary of Defense, in consultation with Director of National Intelligence and Secretary of Commerce, to prepare strategic plan for the management of the electromagnetic spectrum."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" inserted a comma after “Every three years” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1072/b/1"},"text":"Pub. L. 113–66, § 1072(b)(1)","children":[],"tail":", struck out “: biennial strategic plan” after “spectrum” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1072/a/1"},"text":"Pub. L. 113–66, § 1072(a)(1)","children":[],"tail":", substituted “three years” for “other year, and in time for submission to Congress under subsection (b),”, inserted “, in consultation with the Director of National Intelligence and the Secretary of Commerce,” after “Secretary of Defense”, substituted “the national security of the United States. Each such strategic plan shall include each of the following:” for “the mission of the Department of Defense.”, and added pars. (1) to (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1072/a/2"},"text":"Pub. L. 113–66, § 1072(a)(2)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1072/a/3"},"text":"Pub. L. 113–66, § 1072(a)(3)","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1072/a/2"},"text":"Pub. L. 113–66, § 1072(a)(2)","children":[],"tail":", redesignated subsec. (b) as (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7c45a8d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7c45a8e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Issuance of Instruction or Directive","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tX/s1065/b"},"text":"Pub. L. 114–328, div. A, title X, § 1065(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2410"},"text":"130 Stat. 2410","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/328/dA/tX/s1065/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Secretary of Defense shall—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":"], issue a Department of Defense Instruction or a Department of Defense Directive to carry out "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s488/a"},"text":"section 488(a) of title 10","children":[],"tail":", United States Code, as amended by subsection (a); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon the date of the issuance of the instruction or directive issued under paragraph (1), submit to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] such instruction or directive.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
