{"tag":"section","attrib":{"id":"ida82ae538-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s906a"},"text":null,"children":[{"tag":"num","attrib":{"value":"906a"},"text":"§ 906a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 106a. Wearing unauthorized insignia, decoration, badge, ribbon, device, or lapel button","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82ae539-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s906a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is not authorized to wear an insignia, decoration, badge, ribbon, device, or lapel button; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82ae53a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s906a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who wrongfully wears such insignia, decoration, badge, ribbon, device, or lapel button upon the person’s uniform or civilian clothing;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as a court-martial may direct.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida82ae53b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLX/s5418"},"text":"Pub. L. 114–328, div. E, title LX, § 5418","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2945"},"text":"130 Stat. 2945","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida82ae53c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","att