{"tag":"section","attrib":{"id":"ida8289ad2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s882"},"text":null,"children":[{"tag":"num","attrib":{"value":"882"},"text":"§ 882.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 82. Soliciting commission of offenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8289ad3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s882/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Soliciting Commission of Offenses Generally","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person subject to this chapter who solicits or advises another to commit an offense under this chapter (other than an offense specified in subsection (b)) shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8289ad4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s882/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Soliciting Desertion, Mutiny, Sedition, or Misbehavior Before the Enemy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter who solicits or advises another to violate ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s885"},"text":"section 885 of this title","children":[],"tail":" (article 85), "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s894"},"text":"section 894 of this title","children":[],"tail":" (article 94), or "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s899"},"text":"section 899 of this title","children":[],"tail":" (article 99)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8289ad5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s882/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the offense solicited or advised is attempted or is committed, shall be punished with the punishment provided for the commission of the offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8289ad6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s882/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the offense solicited or advised is not attempted or committed, shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8289ad7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/66"},"text":"70A Stat. 66","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLX/s5403"},"text":"Pub. L. 114–328, div. E, title LX, § 5403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2939"},"text":"130 Stat. 2939","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1081/c/1/M"},"text":"Pub. L. 115–91, div. A, title X, § 1081(c)(1)(M)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1598"},"text":"131 Stat. 1598","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8289ad8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8289ad9-3a6f-11