{"tag":"section","attrib":{"id":"idab68d183-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9251"},"text":null,"children":[{"tag":"num","attrib":{"value":"9251"},"text":"§ 9251.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presentation of United States flag upon retirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab68d184-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9251/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presentation of Flag","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon the release of a member of the Air Force or the Space Force from active duty for retirement, the Secretary of the Air Force shall present a United States flag to the member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab68d185-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9251/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multiple Presentations Not Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member is not eligible for a presentation of a flag under subsection (a) if the member has previously been presented a flag under this section or any other provision of law providing for the presentation of a United States flag incident to release from active service for retirement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab68d186-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9251/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Cost to Recipient","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The presentation of a flag under this section shall be at no cost to the recipient.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab68d187-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tVI/s644/c/1"},"text":"Pub. L. 105–261, div. A, title VI, § 644(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2049"},"text":"112 Stat. 2049","children":[],"tail":", § 8681; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s652/e"},"text":"Pub. L. 106–65, div. A, title VI, § 652(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/666"},"text":"113 Stat. 666","children":[],"tail":"; renumbered § 9251, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/b/9"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(b)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1833"},"text":"132 Stat. 1833","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s923/c/9"},"text":"Pub. L. 116–283, div. A, title IX, § 923(c)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3811"},"text":"134 Stat. 3811","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab68d188-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab68d189-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"childre