{"tag":"section","attrib":{"id":"ida9fbfb22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2919"},"text":null,"children":[{"tag":"num","attrib":{"value":"2919"},"text":"§ 2919.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Defense participation in programs for management of energy demand or reduction of energy usage during peak periods","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9fbfb23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2919/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participation in Demand Response or Load Management Programs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense, the Secretaries of the military departments, the heads of the Defense Agencies, and the heads of other instrumentalities of the Department of Defense are authorized to participate in demand response programs for the management of energy demand or the reduction of energy usage during peak periods conducted by any of the following parties:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9fbfb24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2919/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An electric utility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2919/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An independent system operator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2919/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2919/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A third party entity (such as a demand response aggregator or curtailment service provider) implementing demand response programs on behalf of an electric utility, independent system operator, or State agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9fbfb28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2919/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Certain Financial Incentives","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Financial incentives received from an entity specified in subsection (a) shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9fbfb29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2919/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received as a cost reduction in the utility bill for a facility; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2919/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposited into the fund established under subsection (c) for use, to the extent provided for in an appropriations Act, by the military department, Defense Agency, or instrumentality receiving such financial incentive for energy management initiatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9fbfb2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2919/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Energy Savings Financial Incentives Fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established in the Treasury a fund to be known as the “Energy Savings Financial Incentives Fund”. The Fund shall consist of any amount deposited in the Fund pursuant to subsection (b)(2) and amounts appropriated or otherwise made available to the Fund by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9fbfb2c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dB/tXXVIII/s2843/a"},"text":"Pub. L. 111–84, div. B, title XXVIII, § 2843(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2681"},"text":"123 Stat. 2681","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
