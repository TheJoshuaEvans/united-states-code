{"tag":"section","attrib":{"id":"ida93ace78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200e"},"text":null,"children":[{"tag":"num","attrib":{"value":"2200e"},"text":"§ 2200e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93ace79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “cyber” includes the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida93ace7a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Offensive cyber operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida93ace7b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Defensive cyber operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida93ace7c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Defense information network operations and defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida93ace7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other information technology that the Secretary of Defense considers to be related to the cyber activities of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93ace7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “institution of higher education” has the meaning given the term in section 101 of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"20 U.S.C. 1001","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93ace7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Center of Academic Excellence in Cyber Education” means an institution of higher education that is designated by the Director of the National Security Agency as a Center of Academic Excellence in Cyber Education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida93ace80-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title IX, § 922(a)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–236; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tXVI/s1649/c"},"text":"Pub. L. 115–91, div. A, title XVI, § 1649(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1752"},"text":"131 Stat. 1752","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida93ace81-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida93ace82-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida93ace83-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" amended section generally. Prior to amendment, section defined “information assurance”, “institution of higher education”, and “Center of Academic Excellence in Information Assurance Education”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
