{"tag":"section","attrib":{"id":"ida82fc60a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s924b"},"text":null,"children":[{"tag":"num","attrib":{"value":"924b"},"text":"§ 924b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 124b. Graft","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida82fc60b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s924b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Asking, Accepting, or Receiving Thing of Value","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82fc60c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s924b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who occupies an official position or who has official duties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc60d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s924b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who wrongfully asks, accepts, or receives a thing of value as compensation for or in recognition of services rendered or to be rendered by the person with respect to an official matter in which the United States is interested;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82fc60e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s924b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Promising, Offering, or Giving Thing of Value","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person subject to this chapter who wrongfully promises, offers, or gives a thing of value to another person, who occupies an official position or who has official duties, as compensation for or in recognition of services rendered or to be rendered by the other person with respect to an official matter in which the United States is interested, shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida82fc60f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLX/s5438"},"text":"Pub. L. 114–328, div. E, title LX, § 5438","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2953"},"text":"130 Stat. 2953","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida82fc610-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida82fc611-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida82fc612-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on ","children":[{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. No. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
