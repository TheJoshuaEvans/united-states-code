{"tag":"section","attrib":{"id":"ida7fd924f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s689"},"text":null,"children":[{"tag":"num","attrib":{"value":"689"},"text":"§ 689.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retired members: grade in which ordered to active duty and upon release from active duty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7fd9250-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s689/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Rule for Grade in Which Ordered to Active Duty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsections (b) and (c), a retired member ordered to active duty under section 688 or 688a of this title shall be ordered to active duty in the member’s retired grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7fd9251-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s689/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members Retired in O–","children":[],"tail":"9 "},{"tag":"inline","attrib":{},"text":"and O–","children":[],"tail":"10 "},{"tag":"inline","attrib":{},"text":"Grades","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A retired member ordered to active duty under section 688 or 688a of this title whose retired grade is above the grade of major general or rear admiral shall be ordered to active duty in the highest permanent grade held by such member while serving on active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7fd9252-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s689/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members Who Previously Served in Grade Higher Than Retired Grade","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7fd9253-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s689/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A retired member ordered to active duty under section 688 or 688a of this title who has previously served on active duty satisfactorily, as determined by the Secretary of the military department concerned, in a grade higher than that member’s retired grade may be ordered to active duty in the highest grade in which the member had so served satisfactorily, except that such a member may not be so ordered to active duty in a grade above major general or rear admiral.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7fd9254-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s689/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A retired member ordered to active duty in a grade that is higher than the member’s retired grade pursuant to subsection (a) shall be treated for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s690"},"text":"section 690 of this title","children":[],"tail":" as if the member was promoted to that higher grade while on that tour of active duty."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7fd9255-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s689/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If, upon being released from that tour of active duty, such a retired member has served on active duty satisfactorily, as determined by the Secretary concerned, for not less than a total of 36 months in a grade that is a higher grade than the member’s retired grade, the member is entitled to placement on the retired list in that grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7fd9256-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s689/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grade Upon Release From Active Duty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member ordered to active duty under section 688 or 688a of this title who, while on active duty, is promoted to a grade that is higher than that member’s retired grade is entitled, upon that member’s release from that tour of active duty, to placement on the retired list in the highest grade in which the member served on active duty satisfactorily, as determined by the Secretary of the military department concerned, for not less than six months.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7fd9257-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s521/a"},"text":"Pub. L. 104–201, div. A, title V, § 521(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2516"},"text":"110 Stat. 2516","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tV/s503/b/1"},"text":"Pub. L. 107–314, div. A, title V, § 503(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2531"},"text":"116 Stat. 2531","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7fd9258-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7fd9259-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida7fd925a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 689 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12320"},"text":"section 12320 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in section 688(b) and (d) of this title prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s521/a"},"text":"Pub. L. 104–201, § 521(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7fd925b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsecs. (a), (b), (c)(1), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" inserted “or 688a” after “section 688”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7fd925c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida7fd925d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1997-09-30"},"text":"Sept. 30, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s521/b"},"text":"section 521(b) of Pub. L. 104–201","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s688"},"text":"section 688 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7fd925e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tV/s503/b/2"},"text":"Pub. L. 107–314, div. A, title V, § 503(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2531"},"text":"116 Stat. 2531","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/314/dA/tV/s503/b/2"},"text":"“The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s689/d"},"text":"section 689(d) of title 10","children":[],"tail":", United States Code, shall apply with respect to an officer ordered to active duty under section 501 of the National Defense Authorization Act for Fiscal Year 2000 ("},{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Public Law 106–65","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/113/589"},"text":"113 Stat. 589","children":[],"tail":") before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":"] in the same manner as such provisions apply to an officer ordered to active duty under section 688 of such title.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
