{"tag":"section","attrib":{"id":"idaae808b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7415"},"text":null,"children":[{"tag":"num","attrib":{"value":"7415"},"text":"§ 7415.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" The Judge Advocate General’s School: master of laws in military law","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary of the Army, the Commandant of the Judge Advocate General’s School of the Army may, upon recommendation by the faculty of such school, confer the degree of master of laws (LL.M.) in military law upon graduates of the school who have fulfilled the requirements for that degree.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idaae808b1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tV/s504/a"},"text":"Pub. L. 100–180, div. A, title V, § 504(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1086"},"text":"101 Stat. 1086","children":[],"tail":", § 4315; renumbered § 7415, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/c/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaae808b2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaae808b3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],