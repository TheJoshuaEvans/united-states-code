{"tag":"section","attrib":{"id":"idab476663-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8733"},"text":null,"children":[{"tag":"num","attrib":{"value":"8733"},"text":"§ 8733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of royalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab476664-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8733/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any oil, gas, gasoline or other substance accruing to the United States as royalty from any lease under this chapter shall be delivered to the United States, or shall be paid for in money, as the Secretary elects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab476665-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8733/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All money accruing to the United States from lands in the naval petroleum reserves shall be covered into the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab476666-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/461"},"text":"70A Stat. 461","children":[],"tail":", § 7433; "},{"tag":"ref","attrib":{"href":"/us/pl/87/796/s1/9"},"text":"Pub. L. 87–796, § 1(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-11"},"text":"Oct. 11, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/905"},"text":"76 Stat. 905","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/258/tII/s201/14"},"text":"Pub. L. 94–258, title II, § 201(14)","children":[],"tail":", (15), "},{"tag":"date","attrib":{"date":"1976-04-05"},"text":"Apr. 5, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/313"},"text":"90 Stat. 313","children":[],"tail":"; renumbered § 8733, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/5"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab476667-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab476668-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab476669-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7433","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s524"},"text":"34 U.S.C. 524","children":[],"tail":" (10th par.)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1920-06-04/ch228"},"text":"June 4, 1920, ch. 228","children":[],"tail":" (10th par. of amended 3d and 4th provisos), "},{"tag":"html:a","attrib":{"href":"/us/stat/41/813"},"text":"41 Stat. 813","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1938-06-30/ch851/s1"},"text":"June 30, 1938, ch. 851, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/52/1254"},"text":"52 Stat. 1254","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1944-06-17/ch262"},"text":"June 17, 1944, ch. 262","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/58/281"},"text":"58 Stat. 281","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words “or all” are omitted as surplusage. The words “under this chapter” are substituted for the words “of lands within the naval petroleum reserves or other naval fuel reserves under the authority of this section” for brevity. The words “be delivered to the United States, or shall be paid for in money” are substituted for the words “be paid for in money or be paid in kind” for clarity. Neither gas, oil, gasoline, nor hydrocarbon can be “paid”, but any one of them may be delivered.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b) the words “except as otherwise provided in this section” are omitted as surplusage. There is no exception within the chapter to the rule stated in subsection (b). The word “paid” is substituted for the words “which may accrue” for clarity. The words “under this chapter” are substituted for the words “under the provisions of this section or of sections * * * on account of the petroleum products extracted therefrom” for brevity. The two terms are coextensive. The sections of 30 U.S.C. that are cited in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s524"},"text":"34 U.S.C. 524","children":[],"tail":" (10th par.) comprise the entire "},{"tag":"ref","attrib":{"href":"/us/act/1920-02-25/ch85"},"text":"Act of Feb. 25, 1920, ch. 85","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/437"},"text":"41 Stat. 437","children":[],"tail":", as amended. The application of that Act to the Navy is covered in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7427"},"text":"§ 7427 of this title","children":[],"tail":". The words “as miscellaneous receipts” are omitted as surplusage."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab47666a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab47666b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7433"},"text":"section 7433 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/258/s201/14"},"text":"Pub. L. 94–258, § 201(14)","children":[],"tail":", struck out “of the Navy” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/258/s201/15"},"text":"Pub. L. 94–258, § 201(15)","children":[],"tail":", struck out “and oil shale” after “petroleum”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/796"},"text":"Pub. L. 87–796","children":[],"tail":" substituted “or other substance” for “or other hydrocarbon substance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/796"},"text":"Pub. L. 87–796","children":[],"tail":" substituted “All money accruing to the United States from lands in the naval petroleum and oil shale reserves” for “Money paid to the United States for petroleum products under this chapter”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab47666c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab47666d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
