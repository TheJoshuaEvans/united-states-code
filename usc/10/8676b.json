{"tag":"section","attrib":{"id":"idab3b7fff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8676b"},"text":null,"children":[{"tag":"num","attrib":{"value":"8676b"},"text":"§ 8676b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessels stricken from Naval Vessel Register: transfer by gift or otherwise for use as artificial reefs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab3b8000-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8676b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Make Transfer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy may transfer, by gift or otherwise, any vessel stricken from the Naval Vessel Register to any State, Commonwealth, or possession of the United States, or any municipal corporation or political subdivision thereof, for use as provided in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab3b8001-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8676b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel To Be Used as Artificial Reef","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agreement for the transfer of a vessel under subsection (a) shall require that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab3b8002-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8676b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient use, site, construct, monitor, and manage the vessel only as an artificial reef in accordance with the requirements of the National Fishing Enhancement Act of 1984 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2101"},"text":"33 U.S.C. 2101","children":[],"tail":" et seq.), except that the recipient may use the artificial reef to enhance diving opportunities if that use does not have an adverse effect on fishery resources (as that term is defined in section 3(14) of the Magnuson-Stevens Fishery Conservation and Management Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1802/14"},"text":"16 U.S.C. 1802(14)","children":[],"tail":")); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab3b8003-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8676b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient obtain, and bear all responsibility for complying with, applicable Federal, State, interstate, and local permits for using, siting, constructing, monitoring, and managing the vessel as an artificial reef.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab3b8004-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8676b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preparation of Vessel for Use as Artificial Reef","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that the preparation of a vessel transferred under subsection (a) for use as an artificial reef is conducted in accordance with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab3b8005-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8676b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the environmental best management practices developed pursuant to section 3504(b) of the Bob Stump National Defense Authorization Act for Fiscal Year 2003 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Public Law 107–314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1220"},"text":"16 U.S.C. 1220","children":[],"tail":" note); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab3b8006-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8676b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any applicable environmental laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab3b8007-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8676b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost Sharing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may share with the recipient of a vessel transferred under subsection (a) any costs associated with transferring the vessel under that subsection, including costs of the preparation of the vessel under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab3b8008-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8676b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Limitation on Number of Vessels Transferable to Particular Recipient","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State, Commonwealth, or possession of the United States, or any municipal corporation or political subdivision thereof, may be the recipient of more than one vessel transferred under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab3b8009-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8676b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Terms and Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may require such additional terms and conditions in connection with a transfer authorized by subsection (a) as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab3b800a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8676b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to establish a preference for the use as artificial reefs of vessels stricken from the Naval Vessel Register in lieu of other authorized uses of such vessels, including the domestic scrapping of such vessels, or other disposals of such vessels, under this chapter or other applicable authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab3b800b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tX/s1013/a"},"text":"Pub. L. 108–136, div. A, title X, § 1013(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1590"},"text":"117 Stat. 1590","children":[],"tail":", § 7306b; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tX/s1071/a/36"},"text":"Pub. L. 109–364, div. A, title X, § 1071(a)(36)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2400"},"text":"120 Stat. 2400","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tX/s1073/a/31"},"text":"Pub. L. 111–84, div. A, title X, § 1073(a)(31)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2474"},"text":"123 Stat. 2474","children":[],"tail":"; renumbered § 8676b, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/2"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab3b800c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab3b800d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idab3b800e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Fishing Enhancement Act of 1984, referred to in subsec. (b)(1), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/623"},"text":"Pub. L. 98–623","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3394"},"text":"98 Stat. 3394","children":[],"tail":", which enacted chapter 35 (§ 2101 et seq.) of Title 33, Navigation and Navigable Waters, and "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1220d"},"text":"section 1220d of Title 16","children":[],"tail":", Conservation, and amended sections 1220 to 1220c of Title 16. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2101"},"text":"section 2101 of Title 33","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab3b800f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7306b"},"text":"section 7306b of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" substituted “1802(14)))” for “1802(14))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" substituted “3(14)” for “2(14)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab3b8010-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab3b8011-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
