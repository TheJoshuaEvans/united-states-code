{"tag":"section","attrib":{"id":"idab0e2e18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8090"},"text":null,"children":[{"tag":"num","attrib":{"value":"8090"},"text":"§ 8090.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff corps of the Navy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab0e2e19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8090/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The staff corps of the Navy are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab0e2e1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8090/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Medical Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0e2e1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8090/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Dental Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0e2e1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8090/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Judge Advocate General’s Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0e2e1d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8090/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chaplain Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0e2e1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8090/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Supply Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0e2e1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8090/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Civil Engineer Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0e2e20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8090/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Nurse Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0e2e21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8090/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Medical Service Corps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0e2e22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8090/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other staff corps as may be established by the Secretary of the Navy under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0e2e23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8090/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab0e2e24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8090/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy may establish staff corps of the Navy in addition to the staff corps specified in subsection (a). The Secretary may designate commissioned officers in, and may assign members to, any such staff corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0e2e25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8090/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy may provide for the appointment of the chief of any staff corps established under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab0e2e26-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tIII/s351"},"text":"Pub. L. 96–513, title III, § 351","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2902"},"text":"94 Stat. 2902","children":[],"tail":", § 5155; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/22/s6/a"},"text":"Pub. L. 97–22, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-07-10"},"text":"July 10, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/129"},"text":"95 Stat. 129","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/86/tIV/s405/b/1"},"text":"Pub. L. 97–86, title IV, § 405(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-01"},"text":"Dec. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1105"},"text":"95 Stat. 1105","children":[],"tail":"; renumbered § 5150, "},{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s514/a/2"},"text":"Pub. L. 99–433, title V, § 514(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986