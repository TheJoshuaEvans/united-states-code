{"tag":"section","attrib":{"id":"ida7a3174f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s341"},"text":null,"children":[{"tag":"num","attrib":{"value":"341"},"text":"§ 341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Defense State Partnership Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7a31750-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s341/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a31751-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s341/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense, with the concurrence of the Secretary of State, is authorized to establish a program of activities described in paragraph (2), to support the security cooperation objectives of the United States, between members of the National Guard of a State or territory and any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a31752-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s341/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The military forces of a foreign country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a31753-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s341/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The security forces of a foreign country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a31754-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s341/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Governmental organizations of a foreign country whose primary functions include disaster response or emergency response.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a31755-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s341/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State partnership","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each program established under this subsection shall be known as a “State Partnership”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a31756-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s341/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a31757-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s341/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An activity with forces referred to in subsection (a)(1)(B) or organizations described in subsection (a)(1)(C) under a program established under subsection (a) may be carried out only if the Secretary of Defense, with the concurrence of the Secretary of State, determines and notifies the appropriate congressional committees not less than 15 days before initiating such activity that the activity is in the national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a31758-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s341/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on activities with units that have committed gross violations of human rights","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The conduct of any assistance activities under a program established under subsection (a) shall be subject to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s362"},"text":"section 362 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a31759-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s341/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination of Activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief of the National Guard Bureau shall designate a director for each State and territory to be responsible for the coordination of activities under a program established under subsection (a) for such State or territory and reporting on activities under the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a3175a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s341/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall be carried out in accordance with such regulations as the Secretary of Defense shall prescribe for purposes of this section. Such regulations shall include accounting procedures to ensure that expenditures of funds to carry out this section are accounted for and appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a3175b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s341/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Authorized Funds for Program.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a3175c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s341/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds authorized to be appropriated to the Department of Defense, including funds authorized to be appropriated for the Army National Guard and Air National Guard, are authorized to be available—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a3175d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s341/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for payment of costs incurred by the National Guard of a State or territory to conduct activities under a program established under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a3175e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s341/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for payment of incremental expenses of a foreign country to conduct activities under a program established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a3175f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s341/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a31760-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s341/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Active duty requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds shall not be available under paragraph (1) for the participation of a member of the National Guard of a State or territory in activities in a foreign country unless the member is on active duty in the Armed Forces at the time of such participation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a31761-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s341/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incremental expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The total amount of payments for incremental expenses of foreign countries as authorized under paragraph (1)(B) for activities under programs established under subsection (a) in any fiscal year may not exceed $10,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a31762-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s341/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to supersede any authority under title 10 as in effect on ","children":[{"tag":"date","attrib":{"date":"2013-12-26"},"text":"December 26, 2013","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7a31763-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1246/a"},"text":"Pub. L. 114–328, div. A, title XII, § 1246(a)","children":[],"tail":"–(c), (d)(1), (2)(B), "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2520"},"text":"130 Stat. 2520","children":[],"tail":", 2521; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXII/s1210"},"text":"Pub. L. 115–232, div. A, title XII, § 1210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2023"},"text":"132 Stat. 2023","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXVII/s1731/a/16"},"text":"Pub. L. 116–92, div. A, title XVII, § 1731(a)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1813"},"text":"133 Stat. 1813","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7a31764-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7a31765-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida7a31766-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Text of section, as added by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":", is based on text of subsecs. (a) to (g) of "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1205"},"text":"section 1205 of Pub. L. 113–66","children":[],"tail":", div. A, title XII, "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/897"},"text":"127 Stat. 897","children":[],"tail":", as amended, which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s107"},"text":"section 107 of Title 32","children":[],"tail":", National Guard, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1246/e"},"text":"Pub. L. 114–328, div. A, title XII, § 1246(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2521"},"text":"130 Stat. 2521","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7a31767-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (e)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" inserted period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" inserted “assistance” after “any”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1246/b"},"text":"Pub. L. 114–328, § 1246(b)","children":[],"tail":", substituted “Limitations” for “Limitation” in subsec. heading, designated existing provisions as par. (1) and inserted par. heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1246/c/1"},"text":"Pub. L. 114–328, § 1246(c)(1)","children":[],"tail":", added subsec. (d) and struck out former subsec. (d) which required the Secretary of Defense to prescribe regulations to carry out this section and to notify Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1246/d/2/B"},"text":"Pub. L. 114–328, § 1246(d)(2)(B)","children":[],"tail":", redesignated subsec. (g) as (f) and struck out former subsec. (f) which required annual reports for fiscal years 2016, 2017, and 2018."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1246/d/1/A"},"text":"Pub. L. 114–328, § 1246(d)(1)(A)","children":[],"tail":", substituted “Annual Reports” for “Reports and Notifications” in subsec. heading, added par. (1) and struck out former par. (1) which related to a review and report of programs under the State Partnership Program as in effect on "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", redesignated par. (2)(B) as par. (2), substituted “Matters to be included” for “Annual report” in par. (2) heading, and struck out former par. (2)(A) which required reports on activities under programs established under subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1246/d/1/B/i"},"text":"Pub. L. 114–328, § 1246(d)(1)(B)(i)","children":[],"tail":", redesignated cls. (i) to (vi) of former par. (2)(B) as subpars. (A) to (F), respectively, of par. (2) and realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1246/d/1/B/ii"},"text":"Pub. L. 114–328, § 1246(d)(1)(B)(ii)","children":[],"tail":", substituted “subparagraph (E)” for “clause (v)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1246/d/2/B/ii"},"text":"Pub. L. 114–328, § 1246(d)(2)(B)(ii)","children":[],"tail":", redesignated subsec. (g) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1246/c/2"},"text":"Pub. L. 114–328, § 1246(c)(2)","children":[],"tail":", substituted “under title 10 as in effect on "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"December 26, 2013","children":[],"tail":".” for “under title 10, United States Code, as in effect on the date of the enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7a31768-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7a31769-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1246/d/2"},"text":"Pub. L. 114–328, div. A, title XII, § 1246(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2521"},"text":"130 Stat. 2521","children":[],"tail":", provided that the amendment made by section 1246(d)(2)(B) is effective as of "},{"tag":"date","attrib":{"date":"2020-01-01"},"text":"Jan. 1, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7a3176a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"State Partnership Program Selection Analysis","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXII/s1206"},"text":"Pub. L. 119–60, div. A, title XII, § 1206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1082"},"text":"139 Stat. 1082","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tXII/s1206"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Secretary of Defense shall make such changes to Department of Defense Instruction 5111.20 (relating to the State Partnership Program), or a successor instruction, as may be necessary to ensure that, in performing selection analysis for the State Partnership Program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s341"},"text":"section 341 of title 10","children":[],"tail":", United States Code, the Chief of the National Guard Bureau considers—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of current partnerships assigned to the National Guard of a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capacity of the National Guard of a State in relation to the number of assigned countries.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
