{"tag":"section","attrib":{"id":"idaab11a4e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4961"},"text":null,"children":[{"tag":"num","attrib":{"value":"4961"},"text":"§ 4961.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative and other costs","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary may use, out of the amount appropriated for a fiscal year for operation and maintenance for the procurement technical assistance program authorized by this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab11a4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4961/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount not exceeding four percent of such amount to defray the expenses of administering the provisions of this chapter during such fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab11a50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4961/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an amount determined appropriate by the Secretary to assist eligible entities in payment of costs of eligible entities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaab11a51-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4961/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for meetings, including meetings of an association recognized under section 4954(f),","children":[{"tag":"ref","attrib":{"idref":"fn002130"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002130"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" to discuss best practices for the improvement of the operations of procurement technical assistance centers; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab11a52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4961/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for membership dues for any association of such centers created by eligible entities, training fees and associated travel for training to carry out the purposes of this chapter, and voluntary participation on any committees or board of such an association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaab11a53-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tVIII/s814/a/1/B"},"text":"Pub. L. 101–510, div. A, title VIII, § 814(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1596"},"text":"104 Stat. 1596","children":[],"tail":", § 2417; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s859/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 859(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1892"},"text":"132 Stat. 1892","children":[],"tail":"; renumbered § 4961 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tX/s1081/a/41"},"text":"Pub. L. 116–283, div. A, title X, § 1081(a)(41)","children":[],"tail":", title XVIII, § 1872(a)(11), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3873"},"text":"134 Stat. 3873","children":[],"tail":", 4289; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/