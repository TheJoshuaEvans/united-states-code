{"tag":"section","attrib":{"id":"idaacb5904-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6275"},"text":null,"children":[{"tag":"num","attrib":{"value":"6275"},"text":"§ 6275.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limits on construction projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaacb5905-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6275/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction Cost Ceiling","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), construction on a construction project which is in support of national security programs of the Department of Energy and was authorized by a DOE national security authorization may not be started, and additional obligations in connection with the project above the total estimated cost may not be incurred, whenever the current estimated cost of the construction project exceeds by more than 25 percent the higher of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacb5906-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6275/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount authorized for the project; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacb5907-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6275/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the total estimated cost for the project as shown in the most recent budget justification data submitted to Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacb5908-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6275/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception Where Notice-and-wait Given","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An action described in subsection (a) may be taken if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacb5909-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6275/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Energy has submitted to the congressional defense committees a report on the actions and the circumstances making such action necessary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacb590a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6275/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 30 days has elapsed after the date on which the report is received by the committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacb590b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6275/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Computation of Days","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the computation of the 30-day period under subsection (b), there shall be excluded any day on which either House of Congress is not in session because of an adjournment of more than three days to a day certain.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacb590c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6275/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for Minor Projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) does not apply to a construction project with a current estimated cost of less than the minor construction threshold.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaacb590d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1427"},"text":"139 Stat. 1427","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaacb590e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaacb590f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaacb5910-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2744"},"text":"section 2744 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
