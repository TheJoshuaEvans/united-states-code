{"tag":"section","attrib":{"id":"idabb9d872-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15108"},"text":null,"children":[{"tag":"num","attrib":{"value":"15108"},"text":"§ 15108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation on the Reserve Active-Status List","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Sections 14701 through 14703 of this title shall apply in continuation or retention on a reserve active-status list of officers designated for purposes of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idabbc4873-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tV/s514/a"},"text":"Pub. L. 118–31, div. A, title V, § 514(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/248"},"text":"137 Stat. 248","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
