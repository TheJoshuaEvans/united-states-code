{"tag":"section","attrib":{"id":"ida9fbfb71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2921"},"text":null,"children":[{"tag":"num","attrib":{"value":"2921"},"text":"§ 2921.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy efficiency targets for data centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9fbfb72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2921/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Data Centers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9fbfb73-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2921/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For each covered data center, the Secretary of Defense shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9fbfb74-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2921/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a power usage effectiveness target for the data center, based on location, resiliency, industry standards, and best practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fbfb75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2921/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a water usage effectiveness target for the data center, based on location, resiliency, industry standards, and best practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fbfb76-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2921/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop other energy efficiency or water usage targets for the data center based on industry standards and best practices, as applicable to meet energy efficiency and resiliency goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fbfb77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2921/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify potential renewable or clean energy resources, or related technologies such as advanced battery storage capacity, to enhance resiliency at the data center, including potential renewable or clean energy purchase targets based on the location of the data center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fbfb78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2921/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any statutory, regulatory, or policy barriers to meeting any target under any of subparagraphs (A) through (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2921/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall ensure that targets developed under paragraph (1) are consistent with guidance issued by the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb7a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2921/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection, the term “covered data center” means a data center of the Department of Defense that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9fbfb7b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2921/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is one of the 50 data centers of the Department with the highest annual power usage rates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fbfb7c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2921/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been established before the date of the enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9fbfb7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2921/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"New Data Centers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9fbfb7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2921/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2), in the case of any Department of Defense data center established on or after the date of the enactment of this section, the Secretary of Defense shall establish energy, water usage, and resiliency-related standards that the data center shall be required to meet based on location, resiliency, industry and Federal standards, and best practices. Such standards shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9fbfb7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2921/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" power usage effectiveness standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fbfb80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2921/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water usage effectiveness standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fbfb81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2921/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other energy or resiliency standards the Secretary determines are appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfb82-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2921/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may waive the requirement for a Department data center established on or after the date of the enactment of this section to meet the standards established under paragraph (1) if the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9fbfb83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2921/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that such waiver is in the national security interest of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fbfb84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2921/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits to the Committee on Armed Services of the House of Representatives notice of such waiver and the reasons for such waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9fbfb85-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tIII/s312/a/1"},"text":"Pub. L. 117–81, div. A, title III, § 312(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1627"},"text":"135 Stat. 1627","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9fbfb86-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9fbfb87-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida9fbfb88-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsecs. (a)(3)(B) and (b), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
