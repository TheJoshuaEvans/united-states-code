{"tag":"section","attrib":{"id":"idab4c219c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8765"},"text":null,"children":[{"tag":"num","attrib":{"value":"8765"},"text":"§ 8765.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obsolete material and articles of historical interest: loan or gift","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab4c219d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8765/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Make Loans and Gifts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Navy may lend or give, without expense to the United States, items described in subsection (b) that are not needed by the Department of the Navy to any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab4c219e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8765/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State, Commonwealth, or possession of the United States, or political subdivision or municipal corporation thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4c219f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8765/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4c21a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8765/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A library.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4c21a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8765/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A historical society.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4c21a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8765/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An educational institution whose graduates or students fought in a foreign war.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4c21a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8765/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A servicemen’s monument association.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4c21a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8765/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State museum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4c21a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8765/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A museum or memorial operated and maintained for educational purposes only, whose charter denies it the right to operate for profit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4c21a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8765/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A post of the Veterans of Foreign Wars of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4c21a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8765/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A post of the American Legion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4c21a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8765/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other recognized war veterans’ association.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4c21a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8765/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A post of the Sons of Veterans Reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab4c21aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8765/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Items Eligible for Disposal","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies to the following types of property held by the Department of the Navy:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab4c21ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8765/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Captured, condemned, or obsolete ordnance material.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4c21ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8765/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Captured, condemned, or obsolete combat or shipboard material.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab4c21ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8765/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A loan or gift made under this section shall be subject to regulations prescribed by the Secretary and to regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s121"},"text":"section 121 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab4c21ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8765/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maintenance of the Records of the Government","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Records of the Government as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3301"},"text":"section 3301 of title 44","children":[],"tail":" may not be disposed of under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab4c21af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8765/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternative Authorities To Make Gifts or Loans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If any disposition is authorized by this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2572"},"text":"section 2572 of this title","children":[],"tail":", the Secretary may make the gift or loan under either section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab4c21b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8765/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Transfer a Portion of a Vessel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may lend, give, or otherwise transfer any portion of the hull or superstructure of a vessel stricken from the Naval Vessel Register and designated for scrapping to a qualified organization specified in subsection (a). The terms and conditions of an agreement for the transfer of a portion of a vessel under this section shall include a requirement that the transferee will maintain the material conveyed in a condition that will not diminish the historical value of the material or bring discredit upon the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab4c21b1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/466"},"text":"70A Stat. 466","children":[],"tail":", § 7545; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s513/39"},"text":"Pub. L. 96–513, title V, § 513(39)","children":[],"tail":", (40), "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2934"},"text":"94 Stat. 2934","children":[],"tail":", 2935; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tX/s1061/i"},"text":"Pub. L. 104–106, div. A, title X, § 1061(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/443"},"text":"110 Stat. 443","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1043/a"},"text":"Pub. L. 107–107, div. A, title X, § 1043(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1218"},"text":"115 Stat. 1218","children":[],"tail":", 1219; "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/b/34"},"text":"Pub. L. 107–217, § 3(b)(34)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1298"},"text":"116 Stat. 1298","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tX/s1062/e/2"},"text":"Pub. L. 107–314, div. A, title X, § 1062(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2651"},"text":"116 Stat. 2651","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1057/a/3"},"text":"Pub. L. 109–163, div. A, title X, § 1057(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3440"},"text":"119 Stat. 3440","children":[],"tail":"; renumbered § 8765, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/8"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":