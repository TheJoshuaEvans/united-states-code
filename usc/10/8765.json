":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7545","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s546g"},"text":"34 U.S.C. 546g","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-08-07/ch804/s2"},"text":"Aug. 7, 1946, ch. 804, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/897"},"text":"60 Stat. 897","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1951-10-31/ch654/s2/23"},"text":"Oct. 31, 1951, ch. 654, § 2(23)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/65/707"},"text":"65 Stat. 707","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s546h"},"text":"34 U.S.C. 546h","children":[],"tail":" (last sentence as applicable to "},{"tag":"html:a","attrib":{"href":"/us/usc/t34/s546g"},"text":"34 U.S.C. 546g","children":[],"tail":")."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-08-07/ch804/s3"},"text":"Aug. 7, 1946, ch. 804, § 3","children":[],"tail":" (last sentence as applicable to § 2), "},{"tag":"html:a","attrib":{"href":"/us/stat/60/897"},"text":"60 Stat. 897","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s546k"},"text":"34 U.S.C. 546k","children":[],"tail":" (1st sentence as applicable to "},{"tag":"html:a","attrib":{"href":"/us/usc/t34/s546g"},"text":"34 U.S.C. 546g","children":[],"tail":", and 3d sentence)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-08-07/ch804/s6"},"text":"Aug. 7, 1946, ch. 804, § 6","children":[],"tail":" (1st sentence as applicable to § 2, and 3d sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/60/898"},"text":"60 Stat. 898","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words, “ordnance material” are substituted for the words “ordnance, guns, projectiles”. Posts of the Grand Army of the Republic are omitted from the list of authorized donees because there are no surviving members of that organization. The word “Commonwealth” is inserted to reflect the present status of Puerto Rico. Specific reference to the Canal Zone is omitted as unnecessary, since the Zone is a “possession of the United States” as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":" and is therefore covered by clause (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (d) is added to note the existence of a later act, codified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2572"},"text":"§ 2572 of this title","children":[],"tail":", which provides similar disposal authority, and to give effect to "},{"tag":"ref","attrib":{"href":"/us/act/1948-02-27/ch76/s2"},"text":"§ 2 of the Act of February 27, 1948, ch. 76","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/37"},"text":"62 Stat. 37","children":[],"tail":", which is not now contained in the U.S. Code, and which saves this section despite the apparent implied repeal."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab4c21b5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab4c21b6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7545"},"text":"section 7545 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" struck out “Territory,” after “A State,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s121"},"text":"section 121 of title 40","children":[],"tail":"” for “section 205 of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s486"},"text":"40 U.S.C. 486","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1043/a/1"},"text":"Pub. L. 107–107, § 1043(a)(1)","children":[],"tail":", inserted heading and substituted introductory provisions for provisions which read as follows: “Subject to regulations under section 205 of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s486"},"text":"40 U.S.C. 486","children":[],"tail":"), the Secretary of the Navy, under regulations prescribed by him, may lend or give, without expense to the United States, captured, condemned, or obsolete ordnance material, books, manuscripts, works of art, drawings, plans, and models, other condemned or obsolete material, trophies, and flags, and other material of historic interest not needed by the Department of the Navy, to—”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1) to (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1043/a/2"},"text":"Pub. L. 107–107, § 1043(a)(2)","children":[],"tail":", capitalized the first letter after the paragraph designation in each of pars. (1) to (12), substituted a period for a semicolon at end of pars. (1) to (10) and a period for “; or” at end of par. (11), substituted “a foreign war” for “World War I or World War II” in par. (5) and “servicemen’s monument” for “soldiers’ monument” in par. (6), and inserted “or memorial” after “museum” in par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1043/b/2"},"text":"Pub. L. 107–107, § 1043(b)(2)","children":[],"tail":", added subsecs. (b) and (c). Former subsecs. (b) and (c) redesignated (d) and (e), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1043/b/1"},"text":"Pub. L. 107–107, § 1043(b)(1)","children":[],"tail":", (c)(1), redesignated subsec. (b) as (d) and inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1043/b/1"},"text":"Pub. L. 107–107, § 1043(b)(1)","children":[],"tail":", (c)(2), redesignated subsec. (c) as (e) and inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1043/b/3"},"text":"Pub. L. 107–107, § 1043(b)(3)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" redesignated subsec. (d) as (c) and struck out former subsec. (c) which read as follows: “No loan or gift under this section may be made unless—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) notice of the proposal to make the loan or gift is sent to Congress;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) 30 calendar days of continuous session of Congress have expired after the notice was sent to Congress; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) during that 30-day period Congress does not pass a concurrent resolution stating in substance that it does not favor the proposed loan or gift.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s513/39"},"text":"Pub. L. 96–513, § 513(39)","children":[],"tail":", substituted “section 205 of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s486"},"text":"40 U.S.C. 486","children":[],"tail":"),” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s486"},"text":"section 486 of title 40","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s513/40"},"text":"Pub. L. 96–513, § 513(40)","children":[]