{"tag":"section","attrib":{"id":"idaac69dab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222"},"text":null,"children":[{"tag":"num","attrib":{"value":"6222"},"text":"§ 6222.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on access to national security laboratories by foreign visitors from sensitive countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaac69dac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Background Review Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy and the Administrator may not admit to any facility described in paragraph (3) of subsection (c) other than areas accessible to the general public any individual who is a citizen or agent of a covered foreign nation or a nation on the current sensitive countries list unless the Secretary or Administrator first completes a background review with respect to that individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac69dad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sense of Congress Regarding Background Reviews","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is the sense of Congress that the Secretary of Energy, the Director of the Federal Bureau of Investigation, and the Director of National Intelligence should ensure that background reviews carried out under this section are completed in not more than 15 days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac69dae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Admittance","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac69daf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to an individual who is a citizen or agent of a covered foreign nation, the Secretary and the Administrator may not, except as provided in paragraph (2), admit such individual to any areas not accessible to the general public within a facility described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac69db0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary, acting through the Administrator, may waive the prohibition under paragraph (1) with respect to an individual who is a citizen or agent of a covered foreign nation if, not later than 30 days prior to admitting such individual to a facility described in such paragraph, the Secretary certifies to Congress that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac69db1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the admittance of such individual to the facility is in the national security interests of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69db2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no classified or restricted data will be revealed to such individual in connection with the admittance of such individual to the facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69db3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary or Administrator has consulted with the heads of other relevant departments or agencies of the United States Government to mitigate risks associated with the admittance of such individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69db4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the background review completed to ","children":[{"tag":"ref","attrib":{"idref":"fn002141"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002141"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" subsection (a) with respect to such individual did not uncover any previously unreported affiliation with military or intelligence organizations associated with a covered foreign nation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac69db5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A facility described in this paragraph is a facility, or any portion thereof, that directly supports the mission, functions, and operations of the Administration (as described in this subpart) and is located on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac69db6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national security laboratory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69db7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nuclear weapons production facility; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69db8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a site that directly supports the protection, development, sustainment, or disposal of technologies or materials related to the provision of nuclear propulsion for United States naval vessels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac69db9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The prohibition under paragraph (1) shall take effect on ","children":[{"tag":"date","attrib":{"date":"2025-04-15"},"text":"April 15, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac69dba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed to limit or otherwise affect the authority of the Secretary or the Administrator to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac69dbb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" admit to a facility described in paragraph (3) of subsection (c)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac69dbc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a citizen or lawful permanent resident of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69dbd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual involved in an International Atomic Energy Agency (IAEA) inspection (as defined in the “Agreement between the United States and the IAEA for the Application of Safeguards in the U.S.”); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69dbe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual involved in information exchanges in support of activities of the United States with respect to nonproliferation, counterproliferation, and counterterrorism, in accordance with international treaties or other legally-binding agreements or instruments to which the United States is a party; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac69dbf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" admit any individual to a facility, or any portion thereof, that is not directly associated with or directly funded to perform the mission, functions, and operations of the Administration (as described in this subpart).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac69dc0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac69dc1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “background review”, commonly known as an indices check, means a review of information provided by the Director of National Intelligence and the Director of the Federal Bureau of Investigation regarding personal background, including information relating to any history of criminal activity or to any evidence of espionage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac69dc2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered foreign nation” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac69dc3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the People’s Republic of China;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69dc4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Russian Federation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69dc5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Democratic People’s Republic of Korea; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69dc6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Islamic Republic of Iran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac69dc7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6222/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “sensitive countries list” means the list prescribed by the Secretary of Energy known as the Department of Energy List of Sensitive Countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac69dc8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1401"},"text":"139 Stat. 1401","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac69dc9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac69dca-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac69dcb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6222 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8287"},"text":"section 8287 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2652"},"text":"section 2652 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaac69dcc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) to (4) headings which read as follows: “"},{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":"”, “"},{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":"”, “"},{"tag":"inline","attrib":{},"text":"Facilities described","children":[],"tail":"”, and “"},{"tag":"inline","attrib":{},"text":"Effective date","children":[],"tail":"”, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaac69dcd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaac69dce-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pilot Program on Conduct by Department of Energy of Background Reviews for Access by Certain Individuals to National Security Laboratories","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXI/s3121"},"text":"Pub. L. 115–232, div. C, title XXXI, § 3121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2295"},"text":"132 Stat. 2295","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/c/2/M"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(c)(2)(M)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1461"},"text":"139 Stat. 1461","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dC/tXXXI/s3111/c/2/M"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy shall establish a pilot program to assess the feasibility and advisability of conducting background reviews required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s6222/a"},"text":"section 6222(a) of title 10","children":[],"tail":", United States Code[,] within the Department of Energy."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the pilot program established under subsection (a), the Secretary may admit an individual described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s6222/a"},"text":"section 6222(a) of title 10","children":[],"tail":", United States Code[,] to a facility of a national security laboratory described in that section if, in addition to the conduct of a background review under subsection (a) with respect to that individual—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the admission of that individual to that facility is in the national interest and will further science, technology, and engineering capabilities in support of the mission of the Department of Energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a security plan is developed and implemented to mitigate the risks associated with the admission of that individual to that facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Roles of Secretary and Director of National Intelligence and Director of Federal Bureau of Investigation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Role of secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under the pilot program under subsection (a), the Secretary shall conduct background reviews for all individuals described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s6222/a"},"text":"section 6222(a) of title 10","children":[],"tail":", United States Code[,] seeking admission to facilities of national security laboratories described in that section. Such reviews by the Secretary shall be conducted independent of and in addition to background reviews conducted by the Director of National Intelligence and the Director of the Federal Bureau of Investigation under that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Roles of director of national intelligence and director of federal bureau of investigation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding paragraph (1), during the period during which the pilot program established under subsection (a) is being carried out, the Director of National Intelligence and the Director of the Federal Bureau of Investigation shall retain primary responsibility for the conduct of all background reviews required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s6222/a"},"text":"section 6222(a) of title 10","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The pilot program established under subsection (a) shall terminate on the date that is two years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date on which the pilot program established under subsection (a) terminates under subsection (d), the Secretary of Energy, in consultation with the Director of National Intelligence and the Director of the Federal Bureau of Investigation, shall submit to the appropriate congressional committees a report on the conduct of background reviews under the pilot program that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comparison of the effectiveness of and timelines required for background reviews conducted by the Secretary under the pilot program and background reviews conducted by the Director of National Intelligence and the Director of the Federal Bureau of Investigation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s6222/a"},"text":"section 6222(a) of title 10","children":[],"tail":", United States Code; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such reviews conducted for individuals who are citizens or agents of each country on the sensitive countries list referred to in that section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate congressional committees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘appropriate congressional committees’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services and the Select Committee on Intelligence of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services and the Permanent Select Committee on Intelligence of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National security laboratory","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘national security laboratory’ has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s6101"},"text":"section 6101 of title 10","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
