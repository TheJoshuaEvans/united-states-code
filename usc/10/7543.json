{"tag":"section","attrib":{"id":"idaaf6612c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543"},"text":null,"children":[{"tag":"num","attrib":{"value":"7543"},"text":"§ 7543.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Army industrial facilities: sales of manufactured articles or services outside Department of Defense","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaf6612d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Sell Outside DOD","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2208/h"},"text":"section 2208(h) of this title","children":[],"tail":" shall authorize a working-capital funded Army industrial facility (including a Department of the Army arsenal) that manufactures large caliber cannons, gun mounts, recoil mechanisms, ammunition, munitions, or components thereof to sell manufactured articles or services to a person outside the Department of Defense if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaf6612e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an article, the article is sold to a United States manufacturer, assembler, developer, or other concern—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaf6612f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for use in developing new products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaf66130-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for incorporation into items to be sold to, or to be used in a contract with, an agency of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaf66131-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for incorporation into items to be sold to, or to be used in a contract with, or to be used for purposes of soliciting a contract with, a friendly foreign government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaf66132-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for use in commercial products;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf66133-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an article, the purchaser is determined by the Department of Defense to be qualified to carry out the proposed work involving the article to be purchased;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf66134-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale is to be made on a basis that does not interfere with performance of work by the facility for the Department of Defense or for a contractor of the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf66135-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of services, the services are related to an article authorized to be sold under this section and are to be performed in the United States for the purchaser;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf66136-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Army determines that the articles or services are not available from a commercial source located in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf66137-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchaser of an article or service agrees to hold harmless and indemnify the United States, except in a case of willful misconduct or gross negligence, from any claim for damages or injury to any person or property arising out of the article or service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf66138-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the article to be sold can be manufactured, or the service to be sold can be substantially performed, by the industrial facility with only incidental subcontracting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf66139-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is in the public interest to manufacture such article or perform such service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf6613a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale will not interfere with performance of the military mission of the industrial facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf6613b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations shall also—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaf6613c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that the authority to sell articles or services under the regulations be exercised at the level of the commander of the major subordinate command of the Army with responsibility over the facility concerned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf6613d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize a purchaser of articles or services to use advance incremental funding to pay for the articles or services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf6613e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a sale of commercial articles or commercial services in accordance with subsection (a) by a facility that manufactures large caliber cannons, gun mounts, or recoil mechanisms, or components thereof, authorize such facility—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaf6613f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to charge the buyer, at a minimum, the variable costs that are associated with the commercial articles or commercial services sold;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaf66140-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enter into a firm, fixed-price contract or, if agreed by the buyer, a cost reimbursement contract for the sale; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaf66141-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and maintain (from sources other than appropriated funds) working capital to be available for paying design costs, planning costs, procurement costs, and other costs associated with the commercial articles or commercial services sold.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf66142-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Arms Export Control Act","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to affect the application of the export controls provided for in section 38 of the Arms Export Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2778"},"text":"22 U.S.C. 2778","children":[],"tail":") to items which incorporate or are produced through the use of an article sold under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf66143-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaf66144-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “commercial article” means an article that is usable for a nondefense purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf66145-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “commercial service” means a service that is usable for a nondefense purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf66146-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “advance incremental funding”, with respect to a sale of articles or services, means a series of partial payments for the articles or services that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaf66147-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more partial payments before the commencement of work or the incurring of costs in connection with the production of the articles or the performance of the services, as the case may be; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaf66148-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsequent progress payments that result in full payment being completed as the required work is being completed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf66149-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “variable costs”, with respect to sales of articles or services, means the costs that are expected to fluctuate directly with the volume of sales and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaf6614a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of articles, the volume of production necessary to satisfy the sales orders; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaf6614b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7543/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of services, the extent of the services sold.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaf6614c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tI/s158/a/1"},"text":"Pub. L. 103–160, div. A, title I, § 158(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1581"},"text":"107 Stat. 1581","children":[],"tail":", § 4543; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tI/s141"},"text":"Pub. L. 103–337, div. A, title I, § 141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2688"},"text":"108 Stat. 2688","children":[],"tail":"; renumbered § 7543, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/d"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaf6614d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaf6614e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaaf6614f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7543 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8763"},"text":"section 8763 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaaf66150-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4543"},"text":"section 4543 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" struck out “nondefense-related commercial” after “sell manufactured” in introductory provisions and added pars. (5) to (9)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaaf66151-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaaf66152-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaaf66153-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tI/s158/c"},"text":"Pub. L. 103–160, div. A, title I, § 158(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1582"},"text":"107 Stat. 1582","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/160/dA/tI/s158/c"},"text":"“Regulations under subsection (b) of section 4543 [now 7543] of title 10, United States Code, as added by subsection (a), shall be prescribed not later than 30 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaaf66154-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pilot Program on Sales of Manufactured Articles and Services of Certain Army Industrial Facilities Without Regard to Availability From Domestic Sources","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tI/s111/c"},"text":"Pub. L. 107–314, div. A, title I, § 111(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2473"},"text":"116 Stat. 2473","children":[],"tail":", directed the Inspector General of the Department of Defense to review the experience under the pilot program carried out under "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/s141"},"text":"section 141 of Pub. L. 105–85","children":[],"tail":" (formerly set out below) and, not later than "},{"tag":"date","attrib":{"date":"2003-07-01"},"text":"July 1, 2003","children":[],"tail":", submit to Congress a report on the results of the review."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tI/s141"},"text":"Pub. L. 105–85, div. A, title I, § 141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1652"},"text":"111 Stat. 1652","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tI/s115"},"text":"Pub. L. 106–65, div. A, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/533"},"text":"113 Stat. 533","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tI/s112"},"text":"Pub. L. 107–107, div. A, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1029"},"text":"115 Stat. 1029","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tI/s111/a"},"text":"Pub. L. 107–314, div. A, title I, § 111(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2473"},"text":"116 Stat. 2473","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVIII/s844"},"text":"Pub. L. 108–375, div. A, title VIII, § 844","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2019"},"text":"118 Stat. 2019","children":[],"tail":", provided that during fiscal years 1998 through 2009, the Secretary of the Army was to carry out a pilot program to test the efficacy and appropriateness of selling manufactured articles and services of Army industrial facilities under this section without regard to the availability of the articles and services from United States commercial sources, with a report due to Congress by the Inspector General by "},{"tag":"date","attrib":{"date":"1999-07-01"},"text":"July 1, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
