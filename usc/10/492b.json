{"tag":"section","attrib":{"id":"ida7c6cc02-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492b"},"text":null,"children":[{"tag":"num","attrib":{"value":"492b"},"text":"§ 492b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biannual briefing on nuclear weapons and related activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7c6cc03-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On or about May 1 and November 1 of each year, the officials specified in subsection (b) shall provide to the Committees on Armed Services of the Senate and the House of Representatives a briefing on matters relating to nuclear weapons policies, operations, technology development, and other similar topics as requested by such committees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7c6cc04-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officials Specified","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The officials specified in this subsection are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7c6cc05-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary of Defense for Acquisition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c6cc06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary of Defense for Nuclear Deterrence, Chemical, and Biological Defense Policy and Programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c6cc07-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary of Defense for Space Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c6cc08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Deputy Administrator for Defense Programs of the National Nuclear Security Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c6cc09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director for Strategy, Plans, and Policy of the Joint Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c6cc0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492b/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director for Capability and Resource Integration for the United States Strategic Command.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7c6cc0b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delegation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An official specified in subsection (b) may delegate the authority to provide a briefing under subsection (a) to a member of the Senior Executive Service who reports to the official.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7c6cc0c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirement to provide a briefing under subsection (a) shall terminate on ","children":[{"tag":"date","attrib":{"date":"2028-01-01"},"text":"January 1, 2028","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7c6cc0d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tXVI/s1631"},"text":"Pub. L. 117–263, div. A, title XVI, § 1631","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2934"},"text":"136 Stat. 2934","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1621/d/2"},"text":"Pub. L. 118–159, div. A, title XVI, § 1621(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2171"},"text":"138 Stat. 2171","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7c6cc0e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7c6cc0f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida7c6cc10-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"As enacted by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", “SEC.” preceding section designation and catchline text were editorially conformed to the style used in this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7c6cc11-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “Nuclear Deterrence, Chemical, and Biological Defense Policy and Programs” for “Nuclear, Chemical, and Biological Defense Programs”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
