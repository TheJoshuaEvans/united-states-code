{"tag":"section","attrib":{"id":"ida9208f4a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2010"},"text":null,"children":[{"tag":"num","attrib":{"value":"2010"},"text":"§ 2010.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements with respect to motorcycle safety training","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretaries of the military departments shall ensure that all beginner motorcycle safety training provided to members of the Armed Forces meets the motorcycle safety training requirements for licensing of the State in which the permanent station of the member receiving the training is located.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida9208f4b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tV/s543"},"text":"Pub. L. 119–60, div. A, title V, § 543","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/873"},"text":"139 Stat. 873","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9208f4c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9208f4d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida9208f4e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s543"},"text":"Pub. L. 119–60, § 543","children":[],"tail":", which directed amendment of 