{"tag":"section","attrib":{"id":"ida9898a5b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2556"},"text":null,"children":[{"tag":"num","attrib":{"value":"2556"},"text":"§ 2556.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shelter for homeless; incidental services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9898a5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2556/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9898a5d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2556/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of a military department may make military installations under his jurisdiction available for the furnishing of shelter to persons without adequate shelter. The Secretary may, incidental to the furnishing of such shelter, provide services as described in subsection (b). Shelter and incidental services provided under this section may be provided without reimbursement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9898a5e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2556/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned shall carry out this section in cooperation with appropriate State and local governmental entities and charitable organizations. The Secretary shall, to the maximum extent practicable, use the services and personnel of such entities and organizations in determining to whom and the circumstances under which shelter is furnished under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9898a5f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2556/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Services that may be provided incident to the furnishing of shelter under this section are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9898a60-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2556/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Utilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9898a61-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2556/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Bedding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9898a62-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2556/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9898a63-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2556/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9898a64-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2556/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Renovation of facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9898a65-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2556/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Minor repairs undertaken specifically to make suitable space available for shelter to be provided under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9898a66-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2556/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Property liability insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9898a67-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2556/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Shelter and incidental services may only be provided under this section to the extent that the Secretary concerned determines will not interfere with military preparedness or ongoing military functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9898a68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2556/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may provide bedding for support of shelters for the homeless that are operated by entities other than the Department of Defense. Bedding may be provided under this subsection without reimbursement, but may only be provided to the extent that the Secretary determines that the provision of such bedding will not interfere with military requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9898a69-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2556/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall prescribe regulations for the administration of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9898a6a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/tIII/s305/a/1"},"text":"Pub. L. 98–94, title III, § 305(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/628"},"text":"97 Stat. 628","children":[],"tail":", § 2546; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/167/tVIII/s825"},"text":"Pub. L. 99–167, title VIII, § 825","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-03"},"text":"Dec. 3, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/992"},"text":"99 Stat. 992","children":[],"tail":"; renumbered § 2556, "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1033(b)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–260.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9898a6b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9898a6c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9898a6d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2546"},"text":"section 2546 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/167"},"text":"Pub. L. 99–167","children":[],"tail":" added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9898a6e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9898a6f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/tIII/s305/b"},"text":"Pub. L. 98–94, title III, § 305(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/629"},"text":"97 Stat. 629","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/94/tIII/s305/b"},"text":"“Section 2546 [now 2556] of title 10, United States Code, as added by subsection (a), shall take effect on ","children":[{"tag":"date","attrib":{"date":"1983-10-01"},"text":"October 1, 1983","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9898a70-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Certification Required for Use of Department of Defense Facilities by Other Federal Agencies for Temporary Housing Support","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dB/tXXVIII/s2815"},"text":"Pub. L. 114–328, div. B, title XXVIII, § 2815","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2718"},"text":"130 Stat. 2718","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dB/tXXVIII/s2840"},"text":"Pub. L. 118–31, div. B, title XXVIII, § 2840","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/761"},"text":"137 Stat. 761","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dB/tXXVIII/s2840"},"text":"“The Secretary of Defense shall not sign a memorandum of agreement with another Federal agency to provide the agency with a vacant facility for purposes of temporary housing support unless the Secretary first submits to the Committees on Armed Services of the House of Representatives and Senate a certification that the provision of the facility to the agency for such purpose will not negatively affect military training, operations, readiness, or other military requirements, including National Guard and Reserve readiness. Upon granting such certification, the Secretary of Defense shall notify each Member of Congress representing the area in which such facility is located of such grant of certification.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
