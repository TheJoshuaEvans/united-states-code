{"tag":"section","attrib":{"id":"idabb76707-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14508"},"text":null,"children":[{"tag":"num","attrib":{"value":"14508"},"text":"§ 14508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal from the reserve active-status list for years of service: reserve general and flag officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabb76708-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Thirty Years Service or Five Years in Grade for Brigadier Generals and Rear Admirals (Lower Half)","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless retired, transferred to the Retired Reserve, or discharged at an earlier date, each reserve officer of the Army, Air Force, or Marine Corps in the grade of brigadier general who has not been recommended for promotion to the grade of major general, and each reserve officer of the Navy in the grade of rear admiral (lower half) who has not been recommended for promotion to rear admiral shall, 30 days after completion of 30 years of commissioned service or on the fifth anniversary of the date of the officer’s appointment in the grade of brigadier general or rear admiral (lower half), whichever is later, be separated in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14514"},"text":"section 14514 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb76709-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Thirty-Five Years Service or Five Years in Grade for Major Generals and Rear Admirals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless retired, transferred to the Retired Reserve, or discharged at an earlier date, each reserve officer of the Army, Air Force, or Marine Corps in the grade of major general, and each reserve officer of the Navy in the grade of rear admiral, shall, 30 days after completion of 35 years of commissioned service or on the fifth anniversary of the date of the officer’s appointment in the grade of major general or rear admiral, whichever is later, be separated in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14514"},"text":"section 14514 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb7670a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14508/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Thirty-Eight Years of Service for Lieutenant Generals and Vice Admirals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless retired, transferred to the Retired Reserve, or discharged at an earlier date, each reserve officer of the Army, Air Force, or Marine Corps in the grade of lieutenant general and each reserve officer of the Navy in the grade of vice admiral shall be separated in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14514"},"text":"section 14514 of this title","children":[],"tail":" on the later of the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb7670b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14508/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 30 days after completion of 38 years of commissioned service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb7670c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14508/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The fifth anniversary of the date of the officer’s appointment in the grade of lieutenant general or vice admiral.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb7670d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14508/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Forty Years of Service for Generals and Admirals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless retired, transferred to the Retired Reserve, or discharged at an earlier date, each reserve officer of the Army, Air Force, or Marine Corps in the grade of general and each reserve officer of the Navy in the grade of admiral shall be separated in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14514"},"text":"section 14514 of this title","children":[],"tail":" on the first day of the first month beginning after the date of the fifth anniversary of the officer’s appointment to that grade or 30 days after the date on which the officer completes 40 years of commissioned service, whichever is later."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb7670e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14508/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention of Brigadier Generals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A reserve officer of the Army or Air Force in the grade of brigadier general who would otherwise be removed from an active status under subsection (a) may, in the discretion of the Secretary of the Army or the Secretary of the Air Force, as the case may be, be retained in an active status, but not later than the last day of the month in which the officer becomes 62 years of age. Not more than 10 officers of the Army and not more than 10 officers of the Air Force may be retained under this subsection at any one time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb7670f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14508/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention of Major Generals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A reserve officer of the Army or Air Force in the grade of major general who would otherwise be removed from an active status under subsection (b) may, in the discretion of the Secretary of the Army or the Secretary of the Air Force, as the case may be, be retained in an active status, but not later than the date on which the officer becomes 64 years of age. Not more than 10 officers of the Army and not more than 10 officers of the Air Force may be retained under this subsection at any one time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb76710-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14508/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention of Lieutenant Generals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A reserve officer of the Army or Air Force in the grade of lieutenant general who would otherwise be removed from an active status under subsection (c) may, in the discretion of the Secretary of the Army or the Secretary of the Air Force, as the case may be, be retained in an active status, but not later than the date on which the officer becomes 66 years of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb76711-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14508/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for State Adjutants General and Assistant Adjutants General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not apply to an officer who is the adjutant general or assistant adjutant general of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabb76712-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2951"},"text":"108 Stat. 2951","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1501/b/30"},"text":"Pub. L. 104–106, div. A, title XV, § 1501(b)(30)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/498"},"text":"110 Stat. 498","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tV/s521/b"},"text":"Pub. L. 105–85, div. A, title V, § 521(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1734"},"text":"111 Stat. 1734","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s503/e"},"text":"Pub. L. 109–364, div. A, title V, § 503(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2178"},"text":"120 Stat. 2178","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tV/s513"},"text":"Pub. L. 110–181, div. A, title V, § 513","children":[],"tail":", title XVIII, § 1825(c)(1), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/99"},"text":"122 Stat. 99","children":[],"tail":", 502; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title V, § 515, "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4442"},"text":"122 Stat. 4442","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb76713-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabb76714-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idabb76715-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 3851, 3852, 6389(f)(1), (2), 8851, and 8852 of this title, prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":", §§ 1628(4), 1629(a)(3), (c)(3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabb76716-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s513/b/1"},"text":"Pub. L. 110–181, § 513(b)(1)","children":[],"tail":", inserted “"},{"tag":"inline","attrib":{},"text":"for Brigadier Generals and Rear Admirals (Lower Half)","children":[],"tail":"” after “"},{"tag":"inline","attrib":{},"text":"Grade","children":[],"tail":"” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s513/b/2"},"text":"Pub. L. 110–181, § 513(b)(2)","children":[],"tail":", inserted “"},{"tag":"inline","attrib":{},"text":"for Major Generals and Rear Admirals","children":[],"tail":"” after “"},{"tag":"inline","attrib":{},"text":"Grade","children":[],"tail":"” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s513/a/2"},"text":"Pub. L. 110–181, § 513(a)(2)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1825/c/1"},"text":"Pub. L. 110–181, § 1825(c)(1)","children":[],"tail":", added subsec. (d). Former subsec. (d) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s513/a/1"},"text":"Pub. L. 110–181, § 513(a)(1)","children":[],"tail":", redesignated subsec. (d) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e) and (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s513/a/1"},"text":"Pub. L. 110–181, § 513(a)(1)","children":[],"tail":", redesignated subsecs. (c) and (d) as (e) and (f), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s515/2"},"text":"Pub. L. 110–417, § 515(2)","children":[],"tail":", added subsec. (g). Former subsec. (g) redesignated (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s513/a/1"},"text":"Pub. L. 110–181, § 513(a)(1)","children":[],"tail":", redesignated subsec. (e) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s515/1"},"text":"Pub. L. 110–417, § 515(1)","children":[],"tail":", redesignated subsec. (g) as (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s503/e/1"},"text":"Pub. L. 109–364, § 503(e)(1)","children":[],"tail":", substituted “62” for “60”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s503/e/2"},"text":"Pub. L. 109–364, § 503(e)(2)","children":[],"tail":", substituted “64” for “62”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" substituted “not later than the last day of the month in which the officer becomes 60 years of age” for “not later than the date on which the officer becomes 60 years of age”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" struck out “this” after “from an active status under”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabb76717-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idabb76718-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" effective as if included in the Reserve Officer Personnel Management Act, title XVI of "},{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":", as enacted on "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1501/f/3"},"text":"section 1501(f)(3) of Pub. L. 104–106","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s113"},"text":"section 113 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabb76719-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691/b/1"},"text":"section 1691(b)(1) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
