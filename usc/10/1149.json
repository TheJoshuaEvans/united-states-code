{"tag":"section","attrib":{"id":"ida8a4816a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1149"},"text":null,"children":[{"tag":"num","attrib":{"value":"1149"},"text":"§ 1149.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess leave and permissive temporary duty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary of Defense or the Secretary of Homeland Security with respect to the Coast Guard when it is not operating as a service in the Navy, the Secretary concerned shall grant a member of the armed forces who is to be involuntarily separated such excess leave (for a period not in excess of 30 days), or such permissive temporary duty (for a period not in excess of 10 days), as the member requires in order to facilitate the member’s carrying out necessary relocation activities (such as job search and residence search activities), unless to do so would interfere with military missions.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida8a4816b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tV/s502/a/1"},"text":"Pub. L. 101–510, div. A, title V, § 502(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1557"},"text":"104 Stat. 1557","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tV/s542/a/8"},"text":"Pub. L. 103–337, div. A, title V, § 542(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2768"},"text":"108 Stat. 2768","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/b/1"},"text":"Pub. L. 107–296, title XVII, § 1704(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/f/17"},"text":"Pub. L. 112–239, div. A, title X, § 1076(f)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1952"},"text":"126 Stat. 1952","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8a4816c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8a4816d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8a4816e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" inserted “when it is not operating as a service in the Navy” after “Coast Guard”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" inserted “or the Secretary of Transportation with respect to the Coast Guard” after “Secretary of Defense” and struck out “of the military department” before “concerned”."}],"tail":"\n"}],"tail":"\n"},{"tag":"not