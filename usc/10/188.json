{"tag":"section","attrib":{"id":"ida781ac18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188"},"text":null,"children":[{"tag":"num","attrib":{"value":"188"},"text":"§ 188.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency Council on the Strategic Capability of the National Laboratories","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida781ac19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is an Interagency Council on the Strategic Capability of the National Laboratories (in this section referred to as the “Council”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida781ac1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The membership of the Council is comprised of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida781ac1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781ac1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781ac1d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781ac1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781ac1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator for Nuclear Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781ac20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other officials as the President considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida781ac21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Structure and Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President may determine the chair, structure, staff, and procedures of the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida781ac22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall be responsible for the following matters:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida781ac23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identifying and considering the science, technology, and engineering capabilities of the national laboratories that could be leveraged by each participating agency to support national security missions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781ac24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reviewing and assessing the adequacy of the national security science, technology, and engineering capabilities of the national laboratories for supporting national security missions throughout the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781ac25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Establishing and overseeing means of ensuring that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida781ac26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capabilities identified by the Council under paragraph (1) are sustained to an appropriate level; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida781ac27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each participating agency provides the appropriate level of institutional support to sustain such capabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781ac28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In accordance with acquisition rules regarding federally funded research and development centers, establishing criteria for when each participating agency should seek to use the services of the national laboratories, including the identification of appropriate mission areas and capabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781ac29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Making recommendations to the President and Congress regarding regulatory or statutory changes needed to better support—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida781ac2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strategic capabilities of the national laboratories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida781ac2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of such laboratories by each participating agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781ac2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Other actions the Council considers appropriate with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida781ac2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sustainment of the national laboratories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida781ac2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of the strategic capabilities of such laboratories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida781ac2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Streamlined Process","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the participating agency for which a member of the Council is the head of, each member of the Council shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida781ac30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish processes to streamline the consideration and approval of procuring the services of the national laboratories on appropriate matters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781ac31-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that such processes are used in accordance with the criteria established under subsection (d)(4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida781ac32-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida781ac33-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “participating agency” means a department or agency of the Federal Government that is represented on the Council by a member under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781ac34-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “national laboratories” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida781ac35-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each national security laboratory (as defined in section 3281(1) of the National Nuclear Security Administration Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2471/1"},"text":"50 U.S.C. 2471(1)","children":[],"tail":")); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida781ac36-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s188/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each national laboratory of the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida781ac37-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1040/a"},"text":"Pub. L. 112–239, div. A, title X, § 1040(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1928"},"text":"126 Stat. 1928","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida781ac38-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida781ac39-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida781ac3a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1040/d"},"text":"Pub. L. 112–239, div. A, title X, § 1040(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1931"},"text":"126 Stat. 1931","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/239/dA/tX/s1040/d"},"text":"“Nothing in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s188"},"text":"section 188 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall be construed to limit section 309 of the Homeland Security Act of 2002 ("},{"tag":"ref","attrib":{"href":"/us/usc/t6/s189"},"text":"6 U.S.C. 189","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida781ac3b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1040/c"},"text":"Pub. L. 112–239, div. A, title X, § 1040(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1930"},"text":"126 Stat. 1930","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/239/dA/tX/s1040/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2013-09-30"},"text":"September 30, 2013","children":[],"tail":", the Interagency Council on the Strategic Capability of the National Laboratories established under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s188"},"text":"section 188 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall submit to the appropriate congressional committees a report describing and assessing the following:"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The actions taken to implement the requirements of such section 188 and the charter titled ‘Governance Charter for an Interagency Council on the Strategic Capability of DOE National Laboratories as National Security Assets’ signed by the Secretary of Defense, the Secretary of Energy, the Secretary of Homeland Security, and the Director of National Intelligence in July 2010.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The effectiveness of the Council in accomplishing the purpose and objectives of such section and such Charter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Efforts to strengthen work-for-others programs at the national laboratories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Efforts to make work-for-others opportunities at the national laboratories more cost-effective.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ongoing and planned measures for increasing cost-sharing and institutional support investments at the national laboratories from other agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any regulatory or statutory changes recommended to improve the ability of such other agencies to leverage expertise and capabilities at the national laboratories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"“(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The strategic capabilities and core competencies of laboratories and engineering centers operated by the Department of Defense, including identification of mission areas and functions that should be carried out by such laboratories and engineering centers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"“(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Consistent with the protection of sources and methods, the level of funding and general description of programs that were funded during fiscal year 2012 by—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense and carried out at the national laboratories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Energy and the national laboratories and carried out at the laboratories and engineering centers of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The report required by paragraph (1) shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate congressional committees defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term ‘appropriate congressional committees’ means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives].","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Energy and Commerce of the House of Representatives and the Committee on Energy and Natural Resources of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Homeland Security of the House of Representatives and the Committee on Homeland Security and Governmental Affairs of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Science, Space, and Technology of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Permanent Select Committee on Intelligence of the House of Representatives and the Select Committee on Intelligence of the Senate.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
