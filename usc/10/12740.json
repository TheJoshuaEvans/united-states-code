{"tag":"section","attrib":{"id":"idabadf0ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12740"},"text":null,"children":[{"tag":"num","attrib":{"value":"12740"},"text":"§ 12740.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility: denial upon certain punitive discharges or dismissals","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabadf0ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12740/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is convicted of an offense under the Uniform Code of Military Justice (chapter 47 of this title) and whose sentence includes death; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabadf0ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12740/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is separated pursuant to sentence of a court-martial with a dishonorable discharge, a bad conduct discharge, or (in the case of an officer) a dismissal,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is not eligible for retired pay under this chapter.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabadf0f0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tVI/s632/a/1"},"text":"Pub. L. 104–106, div. A, title VI, § 632(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/365"},"text":"110 Stat. 365","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabadf0f1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabadf0f2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabadf0f3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tVI/s632/b"},"text":"Pub. L. 104–106, div. A, title VI, § 632(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/365"},"text":"110 Stat. 365","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/106/dA/tVI/s632/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12740"},"text":"Section 12740 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to court-martial sentences adjudged after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
