{"tag":"section","attrib":{"id":"idab55be75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932"},"text":null,"children":[{"tag":"num","attrib":{"value":"8932"},"text":"§ 8932.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ocean Policy Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab55be76-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Committee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established an Ocean Policy Committee (hereinafter referred to as the “Committee”). The Committee shall retain broad and inclusive membership.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab55be77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab55be78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue the activities of that Committee as it was in existence on the day before the date of the enactment of the William M. (Mac) Thornberry National Defense Authorization Act for Fiscal Year 2021;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab55be79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage and collaborate, pursuant to existing laws and regulations, with stakeholders, including regional ocean partnerships, to address ocean-related matters that may require interagency or intergovernmental solutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab55be7a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate coordination and integration of Federal activities in ocean and coastal waters to inform ocean policy and identify priority ocean research, technology, and data needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab55be7b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prescribe policies and procedures to implement the National Oceanographic Partnership Program, including developing guidelines for review, selection, identification, and approval of partnership projects, in conjunction with Federal agencies participating in the program, for implementation under the program, based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab55be7c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the project addresses important research objectives or operational goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55be7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the project has, or is designed to have, appropriate participation or support from public, academic, commercial, and private entities within the oceanographic community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55be7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the partners have a long-term commitment to the objectives of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55be7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the resources supporting the project are shared among the partners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55be80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the project has been subjected to adequate scientific and technical merit review according to each participating agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55be81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/b/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the approval of such guidelines by a consensus of the members of the Committee; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab55be82-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for projects under the purview of the Committee, establish or designate one or more systems for ocean-related and ocean-mapping-related documents prepared under the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.), in accordance with subsection (h)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab55be83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subcommittees","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab55be84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Committee shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab55be85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a subcommittee to be known as the “Ocean Science and Technology Subcommittee”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55be86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a subcommittee to be known as the “Ocean Resource Management Subcommittee”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab55be87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In discharging its responsibilities in support of agreed-upon scientific needs, and to assist in the execution of the responsibilities described in subsection (b), the Committee may delegate responsibilities to the Ocean Science and Technology Subcommittee, the Ocean Resource Management Subcommittee, or another subcommittee of the Committee, as the Committee determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab55be88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report and Briefing","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab55be89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than March 1 of each year, the Committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab55be8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make publicly available on an appropriate website a report on the National Oceanographic Partnership Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55be8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the appropriate congressional committees a briefing on the contents of the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab55be8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 30 days after providing a briefing under paragraph (1)(B), the Committee shall make publicly available on an appropriate website the briefing materials covered by the briefing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab55be8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each report and briefing shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab55be8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of activities of the National Oceanographic Partnership Program carried out during the fiscal year preceding the fiscal year during which the report is published.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55be8f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A general outline of the activities planned for the program during the fiscal year during which the report is published.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55be90-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary of projects, partnerships, and collaborations, including the Federal and non-Federal sources of funding, continued from the fiscal year preceding the fiscal year during which the report is published and projects expected to begin during the fiscal year during which the report is published and any subsequent fiscal year, as required under subsection (e)(4)(C).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55be91-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amounts requested in the budget submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":" for the fiscal year following the fiscal year during which the report is published, for the programs, projects, activities and the estimated expenditures under such programs, projects, and activities, to execute the National Oceanographic Partnership Program."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55be92-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary of national ocean research priorities informed by the Ocean Research Advisory Panel, as required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8933/b/4"},"text":"section 8933(b)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55be93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/d/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A list of the members of the Ocean Research Advisory Panel established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8933/a"},"text":"section 8933(a) of this title","children":[],"tail":" and any working groups described in subsection (e)(4)(A) in existence during the fiscal years covered by the report."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab55be94-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Partnership Program Office","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab55be95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy and Administrator of the National Oceanic and Atmospheric Administration shall jointly establish a partnership program office for the National Oceanographic Partnership Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab55be96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy and Administrator of the National Oceanic and Atmospheric Administration shall use competitive procedures to select a non-Government entity to manage the partnership program office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab55be97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee shall monitor the management of the partnership program office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab55be98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The partnership program office shall perform the following duties:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab55be99-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supporting working groups established by the Committee or subcommittee and reporting to the Committee and to any Federal agency that has contributed amounts to the National Oceanographic Partnership Program on the activities of such working groups, including the proposals of such working groups for partnership projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55be9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supporting the process for proposing partnership projects to the Committee and to the agencies referred to in subparagraph (A), including, where appropriate, managing review of such projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55be9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Submitting to the appropriate congressional committees, and making publicly available, an annual report on the status of all partnership projects, including the Federal and non-Federal sources of funding for each project, and activities of the office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55be9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/e/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Performing such additional duties for the administration of the National Oceanographic Partnership Program that the Committee and the agencies referred to in subparagraph (A) consider appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab55be9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract and Grant Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee may authorize one or more of the departments or agencies represented on the Committee to enter into contracts and make grants, using funds appropriated pursuant to an authorization of appropriations for the National Oceanographic Partnership Program, for the purpose of implementing the program and carrying out the responsibilities of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab55be9e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment and Forms of Partnership Projects","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab55be9f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A partnership project under the National Oceanographic Partnership Program may be established by any instrument that the Committee considers appropriate, including a memorandum of understanding, a cooperative research and development agreement, and any similar instrument.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab55bea0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Projects under the program may include demonstration projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab55bea1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements of Document System","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The systems established or designated under subsection (b)(5) may include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab55bea2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A publicly accessible, centralized digital archive of documents described in subsection (b)(5) that are finalized after the date of the enactment of the James M. Inhofe National Defense Authorization Act for Fiscal Year 2023, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab55bea3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental impact statements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55bea4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55bea5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" records of decision; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55bea6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/h/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant documents as determined by the lead agency on a project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab55bea7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Geospatially referenced data, if any, contained in the documents under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab55bea8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A mechanism to retrieve information through geo-information tools that can map and integrate relevant geospatial information, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab55bea9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ocean Report Tools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55beaa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Environmental Studies Program Information System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55beab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/h/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Regional Ocean Partnerships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55beac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/h/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Integrated Ocean Observing System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab55bead-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appropriate safeguards on the public accessibility of data to protect national security equities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab55beae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8932/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","chi