{"tag":"section","attrib":{"id":"ida8e02b3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1511"},"text":null,"children":[{"tag":"num","attrib":{"value":"1511"},"text":"§ 1511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return alive of person declared missing or dead","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8e02b40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pay and Allowances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person (except for a person subsequently determined to have been absent without leave or a deserter) in a missing status or declared dead under subchapter VII of chapter 55 of title 5 or chapter 10 of title 37 or by a board appointed under this chapter who is found alive and returned to the control of the United States shall be paid for the full time of the absence of the person while given that status or declared dead under the law and regulations relating to the pay and allowances of persons returning from a missing status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8e02b41-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on Gratuities Paid as a Result of Status","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall not be interpreted to invalidate or otherwise affect the receipt by any person of a death gratuity or other payment from the United States on behalf of a person referred to in subsection (a) before ","children":[{"tag":"date","attrib":{"date":"1996-02-10"},"text":"February 10, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8e02b42-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s569/b/1"},"text":"Pub. L. 104–106, div. A, title V, § 569(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/349"},"text":"110 Stat. 349","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/c/10"},"text":"Pub. L. 107–107, div. A, title X, § 1048(c)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1226"},"text":"115 Stat. 1226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8e02b43-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8e02b44-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8e02b45-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"February 10, 1996","children":[],"tail":"” for “the date of the enactment of this chapter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
