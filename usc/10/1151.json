{"tag":"section","attrib":{"id":"ida8a4817d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1151"},"text":null,"children":[{"tag":"num","attrib":{"value":"1151"},"text":"§ 1151.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of assistive technology and services provided before separation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8a4817e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1151/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the armed forces who is provided an assistive technology or assistive technology device for a severe or debilitating illness or injury incurred or aggravated by such member while on active duty may, under regulations prescribed by the Secretary of Defense, be authorized to retain such assistive technology or assistive technology device upon the separation of the member from active service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8a4817f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1151/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the terms “assistive technology” and “assistive technology device” have the meaning given those terms in section 3 of the Assistive Technology Act of 1998 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3002"},"text":"29 U.S.C. 3002","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8a48180-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s561/a"},"text":"Pub. L. 109–364, div. A, title V, § 561(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2219"},"text":"120 Stat. 2219","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8a48181-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8a48182-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida8a48183-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1151, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dD/tXLIV/s4441/a/1"},"text":"Pub. L. 102–484, div. D, title XLIV, § 4441(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2725"},"text":"106 Stat. 2725","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/35/tII/s201/f/1"},"text":"Pub. L. 103–35, title II, § 201(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-05-31"},"text":"May 31, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/99"},"text":"107 Stat. 99","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tV/s561/k"},"text":"Pub. L. 103–160, div. A, title V, § 561(k)","children":[],"tail":", title XIII, § 1331(a)–(c)(1), (d)–(g), "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "