{"tag":"section","attrib":{"id":"ida9e1bc58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2832"},"text":null,"children":[{"tag":"num","attrib":{"value":"2832"},"text":"§ 2832.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Homeowners assistance program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense may exercise the authority provided in section 1013 of the Demonstration Cities and Metropolitan Development Act of 1966 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3374"},"text":"42 U.S.C. 3374","children":[],"tail":")."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida9e1bc59-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/214/s2/a"},"text":"Pub. L. 97–214, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-07-12"},"text":"July 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/163"},"text":"96 Stat. 163","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dB/tXXVIII/s2831/a"},"text":"Pub. L. 101–189, div. B, title XXVIII, § 2831(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1660"},"text":"103 Stat. 1660","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1502/a/26"},"text":"Pub. L. 104–106, div. A, title XV, § 1502(a)(26)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/506"},"text":"110 Stat. 506","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/e/11"},"text":"Pub. L. 107–107, div. A, title X, § 1048(e)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1228"},"text":"115 Stat. 1228","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9e1bc5a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9e1bc5b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9e1bc5c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" struck out “(a)” before “The Secretary of Defense” and struck out subsec. (b) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b)(1) Subject to paragraph (2) and notwithstanding subsection (i) of section 1013 of the Act referred to in subsection (a)—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the Secretary of Defense may transfer not more than $31,000,000 from the Department of Defense Base Closure Account, established by section 207 of the Defense Authorization Amendments and Base Closure and Realignment Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/526"},"text":"Public Law 100–526","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/102/2627"},"text":"102 Stat. 2627","children":[],"tail":"), to the fund established pursuant to subsection (d) of such section 1013 for use as part of such fund; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) any funds so transferred shall be available for obligation and expenditure for the same purposes that funds appropriated to such fund are available, except that such funds may not be obligated after ","children":[{"tag":"date","attrib":{"date":"1991-09-30"},"text":"September 30, 1991","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Amounts may be transferred under paragraph (1) only after the date on which the appropriate committees of Congress receive from the Secretary written notice of, and justification for, the transfer.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" substituted “appropriate committees of Congress” for “Committees on Armed Services and the Committees on Appropriations of the Senate and of the House of Representatives”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9e1bc5d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9e1bc5e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dB/tXXVIII/s2831/b"},"text":"Pub. L. 101–189, div. B, title XXVIII, § 2831(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1660"},"text":"103 Stat. 1660","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/189/dB/tXXVIII/s2831/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply only to funds appropriated or transferred to, or otherwise deposited in, the Department of Defense Base Closure Account for, or during, fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1989-09-30"},"text":"September 30, 1989","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9e1bc5f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date and applicability of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/214/s12/a"},"text":"section 12(a) of Pub. L. 97–214","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2801"},"text":"section 2801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
