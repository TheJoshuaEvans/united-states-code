{"tag":"section","attrib":{"id":"ida84ec066-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1044b"},"text":"§ 1044b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military powers of attorney: requirement for recognition by States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida84ec067-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Instruments To Be Given Legal Effect Without Regard to State Law","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A military power of attorney—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84ec068-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is exempt from any requirement of form, substance, formality, or recording that is provided for powers of attorney under the laws of a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec069-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be given the same legal effect as a power of attorney prepared and executed in accordance with the laws of the State concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84ec06a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Military Power of Attorney","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, a military power of attorney is any general or special power of attorney that is notarized in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1044a"},"text":"section 1044a of this title","children":[],"tail":" or other applicable State or Federal law."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84ec06b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statement To Be Included","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84ec06c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed by the Secretary concerned, each military power of attorney shall contain a statement that sets forth the provisions of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec06d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) shall not be construed to make inapplicable the provisions of subsection (a) to a military power of attorney that does not include a statement described in that paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84ec06e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “State” includes the District of Columbia, the Commonwealth of Puerto Rico, and a possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida84ec06f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tV/s574/a"},"text":"Pub. L. 103–160, div. A, title V, § 574(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1674"},"text":"107 Stat. 1674","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
