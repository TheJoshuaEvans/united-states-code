{"tag":"section","attrib":{"id":"ida997bafa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2648"},"text":null,"children":[{"tag":"num","attrib":{"value":"2648"},"text":"§ 2648.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons and supplies: sea, land, and air transportation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Whenever the Secretary of Defense considers that space is available, the following persons and supplies may be transported on vessels, vehicles, or aircraft operated by the Department of Defense:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida997bafb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2648/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida997bafc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2648/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other officers of the United States traveling on official business.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida997bafd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2648/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Secretaries and supplies of the Armed Services Department of the Young Men’s Christian Association.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida997bafe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2648/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Officers and employees of the Commonwealth of Puerto Rico on official business.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida997baff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2648/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The families of members of the armed forces, officers and employees of the Department of Defense or the Coast Guard, and persons described in paragraphs (1), (2), and (4).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"However, a person described in paragraph (4) or (5) may be so transported only if the transportation is without expense to the United States.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida997bb00-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/266"},"text":"70A Stat. 266","children":[],"tail":", § 4744; "},{"tag":"ref","attrib":{"href":"/us/pl/86/624/s4/d"},"text":"Pub. L. 86–624, § 4(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/411"},"text":"74 Stat. 411","children":[],"tail":"; renumbered § 2648 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tX/s1072/a"},"text":"Pub. L. 108–375, div. A, title X, § 1072(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2057"},"text":"118 Stat. 2057","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tIII/s352/d"},"text":"Pub. L. 111–383, div. A, title III, § 352(d)","children":[],"tail":", (e)(1), "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/st