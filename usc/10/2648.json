:{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4744","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1369.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1370.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1371 (less last 29 words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1907-03-02/ch2511"},"text":"Mar. 2, 1907, ch. 2511","children":[],"tail":" (6th proviso, less last 29 words under “Transportation of the Army and Its Supplies”), "},{"tag":"html:a","attrib":{"href":"/us/stat/34/1170"},"text":"34 Stat. 1170","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1921-06-30/ch33"},"text":"June 30, 1921, ch. 33","children":[],"tail":" (8th proviso under “Transportation of the Army and Its Supplies”), "},{"tag":"html:a","attrib":{"href":"/us/stat/42/81"},"text":"42 Stat. 81","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1911-03-03/ch209"},"text":"Mar. 3, 1911, ch. 209","children":[],"tail":" (3d proviso under “Transportation of the Army and Its Supplies”), "},{"tag":"html:a","attrib":{"href":"/us/stat/36/1051"},"text":"36 Stat. 1051","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to the Philippine government, contained in the source statute for 10:1371, is omitted, since the Philippine Republic now has the status of a foreign country and only possessions of the United States are intended to be covered by the source statute. The words “Armed Services Department” are substituted for the words “Army and Navy Department”, in 10:1370, to reflect the present name of that Department of the Young Men’s Christian Association. (See also third sentence of revision note for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4746"},"text":"section 4746 of this title","children":[],"tail":", below.)"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida997bb04-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida997bb05-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" substituted “Persons and supplies: sea, land, and air transportation” for “Persons and supplies: sea transportation” in section catchline and inserted “, vehicles, or aircraft” after “vessels” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s1072/b/1"},"text":"Pub. L. 108–375, § 1072(b)(1)","children":[],"tail":", in introductory provisions, substituted “Secretary of Defense” for “Secretary of the Army” and struck out “Army transport agencies or, within bulk space allocations made to the Department of the Army, on vessels operated by any military transport agency of” before “the Department of Defense”, redesignated pars. (4) to (8) as (1) to (5), respectively, in par. (5), substituted “members of the armed forces, officers and employees of the Department of Defense or the Coast Guard, and persons described in paragraphs (1), (2), and (4)” for “persons described in clauses (1), (2), (4), (5), and (7)”, in concluding provisions, substituted “paragraph (4) or (5)” for “clause (7) or (8)”, and struck out former pars. (1) to (3) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Members of the Navy, Marine Corps, or Coast Guard.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Officers and employees of the Department of the Army, the Department of the Navy, the Department of the Air Force, or the Coast Guard.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) Supplies of the Department of the Navy.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s1072/a"},"text":"Pub. L. 108–375, § 1072(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4744"},"text":"section 4744 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/624"},"text":"Pub. L. 86–624","children":[],"tail":" struck out cl. (6) which authorized transportation of officers and employees of the Territory of Hawaii, redesignated cls. (7) to (9) as (6) to (8), respectively, and substituted “clauses (1), (2), (4), (5), and (7)” for “clauses (1), (2), (4), (5), (6), and (8)” in redesignated cl. (8), and “clause (7) or (8)” for “clause (8) or (9)” in closing sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
