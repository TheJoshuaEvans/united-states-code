{"tag":"section","attrib":{"id":"idaab38b45-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5513"},"text":null,"children":[{"tag":"num","attrib":{"value":"5513"},"text":"§ 5513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unfunded priorities of the Missile Defense Agency: annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaab38b46-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 10 days after the date on which the budget of the President for a fiscal year is submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", the Director of the Missile Defense Agency shall submit to the Secretary of Defense and the Chairman of the Joint Chiefs of Staff, and to the congressional defense committees, a report on the unfunded priorities of the Missile Defense Agency."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab38b47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab38b48-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5513/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subsection (a) shall specify, for each unfunded priority covered by such report, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaab38b49-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5513/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary description of such priority, including the objectives to be achieved if such priority is funded (whether in whole or in part).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab38b4a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5513/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The additional amount of funds recommended in connection with the objectives under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab38b4b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5513/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Account information with respect to such priority, including the following (as applicable):","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaab38b4c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5513/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Line Item Number (LIN) for applicable procurement accounts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaab38b4d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5513/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Program Element (PE) number for applicable research, development, test, and evaluation accounts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaab38b4e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5513/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sub-activity group (SAG) for applicable operation and maintenance accounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab38b4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5513/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prioritization of priorities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each report under subsection (a) shall present the unfunded priorities covered by such report in order of urgency of priority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab38b50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5513/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unfunded Priority Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “unfunded priority”, in the case of a fiscal year, means a program, activity, or mission requirement of the Missile Defense Agency that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab38b51-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5513/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not funded in the budget of the President for the fiscal year as submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", United States Code;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab38b52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5513/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary to fulfill a requirement associated with an operational or contingency plan of a combatant command or other validated requirement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab38b53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5513/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would have been recommended for funding through the budget referred to in paragraph (1) by the Director of the Missile Defense Agency in connection with the budget if additional resources had been available for the budget to fund the program, activity, or mission requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaab38b54-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1649/a"},"text":"Pub. L. 118–159, div. A, title XVI, § 1649(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2190"},"text":"138 Stat. 2190","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVII/s1701/a/33"},"text":"Pub. L. 119–60, div. A, title XVII, § 1701(a)(33)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1209"},"text":"139 Stat. 1209","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaab38b55-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaab38b56-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaab38b57-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s222b"},"text":"section 222b of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1649/b/1"},"text":"Pub. L. 118–159, div. A, title XVI, § 1649(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2199"},"text":"138 Stat. 2199","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaab38b58-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “Missile Defense Agency” for “missile defense agency” in section catchline."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
