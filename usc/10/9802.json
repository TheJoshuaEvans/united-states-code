{"tag":"section","attrib":{"id":"idab855a96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9802"},"text":null,"children":[{"tag":"num","attrib":{"value":"9802"},"text":"§ 9802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Admiralty claims against the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab855a97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9802/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Air Force may settle or compromise an admiralty claim against the United States for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab855a98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9802/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" damage caused by a vessel of, or in the service of, the Department of the Air Force or by other property under the jurisdiction of the Department of the Air Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab855a99-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9802/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation for towage and salvage service, including contract salvage, rendered to a vessel of, or in the service of, the Department of the Air Force or to other property under the jurisdiction of the Department of the Air Force; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab855a9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9802/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" damage caused by a maritime tort committed by any agent or employee of the Department of the Air Force or by property under the jurisdiction of the Department of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab855a9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9802/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a claim under subsection (a) is settled or compromised for $500,000 or less, the Secretary of the Air Force may pay it. If it is settled or compromised for more than $500,000, he shall certify it to Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab855a9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9802/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case where the amount to be paid is not more than $100,000, the Secretary of the Air Force may delegate his authority under subsection (a) to any person in the Department of the Air Force designated by him.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab855a9d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/592"},"text":"70A Stat. 592","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/67"},"text":"Pub. L. 89–67","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-07"},"text":"July 7, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/212"},"text":"79 Stat. 212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/417/s1/6"},"text":"Pub. L. 92–417, § 1(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-08-29"},"text":"Aug. 29, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/655"},"text":"86 Stat. 655","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXVI/s1633"},"text":"Pub. L. 101–189, div. A, title XVI, § 1633","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1608"},"text":"103 Stat. 1608","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab855a9e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab855a9f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab855aa0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9802(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9802(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9802(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1861 (less 35 words before 1st proviso, and less last proviso).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1861 (last proviso).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1866 (as applicable to 10:1861).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1951-10-20/ch524"},"text":"Oct. 20, 1951, ch. 524","children":[],"tail":", §§ 1 (less 35 words before 1st proviso), 6 (as applicable to § 1), "},{"tag":"html:a","attrib":{"href":"/us/stat/65/572"},"text":"65 Stat. 572","children":[],"tail":", 573."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “consider, ascertain, adjust, determine, compromise” are omitted as covered by the word “settle”, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9801"},"text":"section 9801 of this title","children":[],"tail":". 10:1861 (1st proviso) is omitted as unnecessary, since other applicable claims laws are restated in this title. 10:1861 (2d proviso) is omitted as surplusage."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab855aa1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab855aa2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" substituted “$100,000” for “$10,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/417"},"text":"Pub. L. 92–417","children":[],"tail":" substituted “Admiralty claims against the United States” for “Damage by United States vessels, towage and salvage of United States vessels” in section catchline, in text preceding par. (1), struck out requirement that the Secretary of the Air Force discharge his functions under the direction of the Secretary of Defense, in par. (1), inserted “or by other property under the jurisdiction of the Department of the Air Force”, in par. (2), inserted “or to other property under the jurisdiction of the Department of the Air Force”, and added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/67"},"text":"Pub. L. 89–67","children":[],"tail":" substituted “$10,000” for “$1,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
