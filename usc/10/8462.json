{"tag":"section","attrib":{"id":"idab2ab72f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8462"},"text":null,"children":[{"tag":"num","attrib":{"value":"8462"},"text":"§ 8462.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Midshipmen: discharge for unsatisfactory conduct or inaptitude","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab2ab730-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8462/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Superintendent of the Naval Academy shall submit to the Secretary of the Navy in writing a full report of the facts—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab2ab731-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8462/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whenever the Superintendent determines that the conduct of a midshipman is unsatisfactory; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2ab732-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8462/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whenever the Academic Board unanimously determines that midshipman possesses insufficient aptitude to become a commissioned officer in the naval service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2ab733-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8462/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A midshipman upon whom a report is made under subsection (a) shall be given an opportunity to examine the report and submit a written statement thereon. If the Secretary believes, on the basis of the report and statement, that the determination of the Superintendent or of the Academic Board is reasonable and well founded, he may discharge the midshipman from the Naval Academy and from the naval service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab2ab734-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/432"},"text":"70A Stat. 432","children":[],"tail":", § 6962; renumbered § 8462, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/c/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab2ab735-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab2ab736-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab2ab737-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},