{"tag":"section","attrib":{"id":"ida9da90d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815"},"text":null,"children":[{"tag":"num","attrib":{"value":"2815"},"text":"§ 2815.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military installation resilience projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9da90d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Projects Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall carry out military construction projects, including unspecified minor military construction projects not otherwise authorized by law, for military installation resilience, in accordance with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da90da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2802"},"text":"section 2802 of this title","children":[],"tail":" (except as provided in subsection (e)); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da90db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2805"},"text":"section 2805 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da90dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Notification","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da90dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When a decision is made to carry out a project under this section, the Secretary of Defense shall notify the congressional defense committees of that decision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da90de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense shall include in each notification submitted under paragraph (1) the rationale for how the project would—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da90df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance military installation resilience;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da90e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance mission assurance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da90e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support mission critical functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da90e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address known vulnerabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da90e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing of Projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (e)(2), a project may be carried out under this section only after the end of the 14-day period beginning on the date that notification with respect to that project under subsection (b) is received by the congressional defense committees in an electronic medium pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s480"},"text":"section 480 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da90e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Location of Projects","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Projects carried out pursuant to this section may be carried out—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da90e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a military installation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da90e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a facility used by the Department of Defense that is owned and operated by a State, the District of Columbia, the Commonwealth of Puerto Rico, American Samoa, Guam, the Commonwealth of the Northern Mariana Islands, or the Virgin Islands, even if the facility is not under the jurisdiction of the Department of Defense, if the Secretary of Defense determines that the facility is subject to significant use by the armed forces for testing or training; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da90e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" outside of a military installation or facility described in paragraph (2) if the Secretary concerned determines that the project would preserve or enhance the resilience of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da90e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a military installation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da90e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a facility described in paragraph (2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da90ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community infrastructure determined by the Secretary concerned to be necessary to maintain, improve, or rapidly reestablish installation mission assurance and mission-essential functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da90eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternative Funding Source","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da90ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out a project under this section, the Secretary concerned may use amounts available for operation and maintenance for the military department concerned if the Secretary concerned submits a notification to the congressional defense committees of the decision to carry out the project using such amounts and includes in the notification—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da90ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current estimate of the cost of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da90ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the source of funds for the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da90ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that deferral of the project for inclusion in the next Military Construction Authorization Act would be inconsistent with national security or the protection of health, safety, or environmental quality, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da90f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A project carried out under this section using amounts under paragraph (1) may be carried out only after the end of the 7-day period beginning on the date on which a copy of the notification described in paragraph (1) is provided in an electronic medium pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s480"},"text":"section 480 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da90f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The maximum aggregate amount that the Secretary concerned may obligate from amounts available to the military department concerned for operation and maintenance in any fiscal year for projects under the authority of this subsection is $125,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da90f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the end of each fiscal year until ","children":[{"tag":"date","attrib":{"date":"2025-12-31"},"text":"December 31, 2025","children":[],"tail":", the Secretary of Defense shall submit to the congressional defense committees a report on the status of the planned and active projects carried out under this section (including completed projects), and shall include in the report with respect to each such project the following information:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da90f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The title, location, a brief description of the scope of work, the original project cost estimate, and the current working cost estimate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da90f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The information provided under subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da90f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other information as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9da90f6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dB/tXXVIII/s2801/b/1"},"text":"Pub. L. 116–92, div. B, title XXVIII, § 2801(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1880"},"text":"133 Stat. 1880","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIII/s315/a"},"text":"Pub. L. 116–283, div. A, title III, § 315(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3514"},"text":"134 Stat. 3514","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dB/tXXVIII/s2804"},"text":"Pub. L. 118–31, div. B, title XXVIII, § 2804","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/744"},"text":"137 Stat. 744","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dB/tXXVIII/s2874"},"text":"Pub. L. 119–60, div. B, title XXVIII, § 2874","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1329"},"text":"139 Stat. 1329","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9da90f7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9da90f8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida9da90f9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2815, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dB/tXXVIII/s2801/b/1"},"text":"Pub. L. 106–398, § 1 [div. B, title XXVIII, § 2801(b)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–412; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tX/s1062/a/14"},"text":"Pub. L. 107–314, div. A, title X, § 1062(a)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2650"},"text":"116 Stat. 2650","children":[],"tail":", related to annual evaluation of joint use military construction projects, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tX/s1061/23/A"},"text":"Pub. L. 112–81, div. A, title X, § 1061(23)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1584"},"text":"125 Stat. 1584","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9da90fa-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" inserted “, including unspecified minor military construction projects not otherwise authorized by law,” after “military construction projects” and substituted “in accordance with—” and pars. (1) and (2) for “in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2802"},"text":"section 2802 of this title","children":[],"tail":" (except as provided in subsections (d)(3) and (e)).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" substituted “$125,000,000” for “$100,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s315/a/1"},"text":"Pub. L. 116–283, § 315(a)(1)","children":[],"tail":", inserted “(except as provided in subsections (d)(3) and (e))” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s315/a/2"},"text":"Pub. L. 116–283, § 315(a)(2)","children":[],"tail":", substituted “Except as provided in subsection (e)(2), a project” for “A project”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s315/a/3"},"text":"Pub. L. 116–283, § 315(a)(3)","children":[],"tail":", (4), added subsecs. (d) and (e) and redesignated former subsec. (d) as (f)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
