{"tag":"section","attrib":{"id":"idaab5fd23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5552"},"text":null,"children":[{"tag":"num","attrib":{"value":"5552"},"text":"§ 5552.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biannual briefing on missile defense and related activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaab5fd24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5552/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On or about June 1 and December 1 of each year, the officials specified in subsection (b) shall provide to the Committees on Armed Services of the Senate and the House of Representatives a briefing on matters relating to missile defense policies, operations, technology development, and other similar topics as requested by such committees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab5fd25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5552/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officials Specified","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The officials specified in this subsection are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab5fd26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5552/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary of Defense for Acquisition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab5fd27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5552/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary of Defense for Space Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab5fd28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5552/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Missile Defense Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab5fd29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5552/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director for Strategy, Plans, and Policy of the Joint Staff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab5fd2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5552/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delegation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An official specified in subsection (b) may delegate the authority to provide a briefing required by subsection (a) to a member of the Senior Executive Service who reports to the official.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab5fd2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5552/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirement to provide a briefing under subsection (a) shall terminate on ","children":[{"tag":"date","attrib":{"date":"2028-01-01"},"text":"January 1, 2028","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaab5fd2c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1649/a"},"text":"Pub. L. 118–159, div. A, title XVI, § 1649(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2198"},"text":"138 Stat. 2198","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaab5fd2d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaab5fd2e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaab5fd2f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s487"},"text":"section 487 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1649/b/1"},"text":"Pub. L. 118–159, div. A, title XVI, § 1649(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2199"},"text":"138 Stat. 2199","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
