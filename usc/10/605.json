{"tag":"section","attrib":{"id":"ida7e354ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605"},"text":null,"children":[{"tag":"num","attrib":{"value":"605"},"text":"§ 605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion to certain grades for officers with critical skills: colonel, lieutenant colonel, major, captain; captain, commander, lieutenant commander, lieutenant","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7e354ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer in the grade of first lieutenant, captain, major, or lieutenant colonel in the Army, Air Force, Marine Corps, or Space Force, or lieutenant (junior grade), lieutenant, lieutenant commander, or commander in the Navy, who is described in subsection (b) may be temporarily promoted to the grade of captain, major, lieutenant colonel, or colonel in the Army, Air Force, Marine Corps, or Space Force, or lieutenant, lieutenant commander, commander, or captain in the Navy, as applicable, under regulations prescribed by the Secretary of the military department concerned. Appointments under this section shall be made by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e354ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Officers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An officer described in this subsection is any officer in a grade specified in subsection (a) who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7e354f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a skill in which the armed force concerned has a critical shortage of personnel (as determined by the Secretary of the military department concerned); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7e354f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is serving in a position (as determined by the Secretary of the military department concerned) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7e5c4f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designated to be held by a captain, major, lieutenant colonel, or colonel in the Army, Air Force, Marine Corps, or Space Force, or lieutenant, lieutenant commander, commander, or captain in the Navy, as applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7e5c4f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires that an officer serving in such position have the skill possessed by such officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e5c4f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preservation of Position and Status of Officers Appointed","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An appointment under this section does not change the position on the active-duty list or the permanent, probationary, or acting status of the officer so appointed, prejudice the officer in regard to other promotions or appointments, or abridge the rights or benefits of the officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e5c4f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Board Recommendation Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A temporary promotion under this section may be made only upon the recommendation of a board of officers convened by the Secretary of the military department concerned for the purpose of recommending officers for such promotions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e5c4f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance and Effective Date of Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each appointment under this section, unless expressly declined, is, without formal acceptance, regarded as accepted on the date such appointment is made, and a member so appointed is entitled to the pay and allowances of the grade of the temporary promotion under this section from the date the appointment is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e5c4f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless sooner terminated, an appointment under this section terminates—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7e5c4f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the date the officer who received the appointment is promoted to the permanent grade of captain, major, lieutenant colonel, or colonel in the Army, Air Force, Marine Corps, or Space Force, or lieutenant, lieutenant commander, commander, or captain in the Navy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7e5c4f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the date the officer is detached from a position described in subsection (b)(2), unless the officer is on a promotion list to the permanent grade of captain, major, lieutenant colonel, or colonel in the Army, Air Force, Marine Corps, or Space Force, or lieutenant, lieutenant commander, commander, or captain in the Navy, in which case the appointment terminates on the date the officer is promoted to that grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e5c4fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Number of Eligible Positions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An appointment under this section may only be made for service in a position designated by the Secretary of the military department concerned for the purposes of this section. The number of positions so designated may not exceed the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7e5c4fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of the Army—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7e5c4fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as captain, 120;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7e5c4fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as major, 350;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7e5c4fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as lieutenant colonel, 200; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7e5c4ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as colonel, 100.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7e5c500-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of the Air Force—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7e5c501-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as captain 95;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7e5c502-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as major, 305;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7e5c503-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as lieutenant colonel, 165; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7e5c504-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as colonel, 75.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7e5c505-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of the Space Force—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7e5c506-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as captain, 5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7e5c507-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as major, 20;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7e5c508-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as lieutenant colonel, 10; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7e5c509-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as colonel, 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7e5c50a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of the Marine Corps—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7e5c50b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as captain, 50;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7e5c50c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as major, 175;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7e5c50d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as lieutenant colonel, 100; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7e5c50e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as colonel, 50.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7e5c50f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of the Navy—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7e5c510-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as lieutenant, 100;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7e5c511-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as lieutenant commander, 425;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7e5c512-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as commander, 175; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7e5c513-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s605/g/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as captain, 80.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7e5c514-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tV/s503/a/1"},"text":"Pub. L. 115–232, div. A, title V, § 503(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1740"},"text":"132 Stat. 1740","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tV/s505"},"text":"Pub. L. 118–31, div. A, title V, § 505","children":[],"tail":", title XVII, § 1716(d), "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/241"},"text":"137 Stat. 241","children":[],"tail":", 653.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7e5c515-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7e5c516-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7e5c517-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1716/d/1"},"text":"Pub. L. 118–31, § 1716(d)(1)","children":[],"tail":", substituted “Marine Corps, or Space Force,” for “or Marine Corps,” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1716/d/2"},"text":"Pub. L. 118–31, § 1716(d)(2)","children":[],"tail":", added pars. (2) and (3), redesignated former par. (3) as (4), and struck out former par. (2) which read as follows: “In the case of the Air Force—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) as captain, 100;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) as major, 325;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) as lieutenant colonel, 175; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) as colonel, 80.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Former par. (4) redesignated (5).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s505"},"text":"Pub. L. 118–31, § 505","children":[],"tail":", substituted “425” for “325”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1716/d/2"},"text":"Pub. L. 118–31, § 1716(d)(2)","children":[],"tail":", redesignated par. (4) as (5)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
