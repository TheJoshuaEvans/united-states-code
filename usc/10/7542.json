{"tag":"section","attrib":{"id":"idaaf66103-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542"},"text":null,"children":[{"tag":"num","attrib":{"value":"7542"},"text":"§ 7542.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical data packages for large-caliber cannon: prohibition on transfers to foreign countries; exception","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaf66104-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Rule","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds appropriated to the Department of Defense may not be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaf66105-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to transfer to a foreign country a technical data package for a defense item being manufactured or developed in an arsenal; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf66106-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist a foreign country in producing such a defense item.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf66107-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Army may use funds appropriated to the Department of Defense to transfer a technical data package, or to provide assistance, described in subsection (a) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaf66108-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer or provision of assistance is to a friendly foreign country (as determined by the Secretary of Defense in consultation with the Secretary of State);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf66109-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary of the Army determines that such action—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaf6610a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would have a clear benefit to the preservation of the production base for the production of cannon at the arsenal concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaf6610b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would not transfer technology (including production techniques) considered unique to the arsenal concerned, except as provided in subsection (e); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf6610c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense enters into an agreement with the country concerned described in subsection (c) or (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf6610d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coproduction Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agreement under this subsection shall be in the form of a Government-to-Government Memorandum of Understanding and shall include provisions that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaf6610e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe the content of the technical data package or assistance to be transferred to the foreign country participating in the agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf6610f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that production by the participating foreign country of the defense item to which the technical data package or assistance relates be shared with the arsenal concerned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf66110-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subject to such exceptions as may be approved under subsection (f), prohibit transfer by the participating foreign country to a third party or country of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaf66111-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any defense article, technical data package, technology, or assistance provided by the United States under the agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaf66112-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any defense article produced by the participating foreign country under the agreement; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf66113-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the Secretary of Defense to monitor compliance with the agreement and the participating foreign country to report periodically to the Secretary of Defense concerning the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf66114-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperative Project Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agreement under this subsection is a cooperative project agreement under section 27 of the Arms Export Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2767"},"text":"22 U.S.C. 2767","children":[],"tail":") which includes provisions that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaf66115-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for development phases describe the technical data to be transferred and for the production phase prescribe the content of the technical data package or assistance to be transferred to the foreign country participating in the agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf66116-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that at least the United States production of the defense item to which the technical data package or assistance relates be carried out by the arsenal concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf66117-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the Secretary of Defense to monitor compliance with the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf66118-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Licensing Fees and Royalties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The limitation in subsection (b)(2)(B) shall not apply if the technology (or production technique) transferred is subject to nonexclusive license and payment of any negotiated licensing fee or royalty that reflects the cost of development, implementation, and prove-out of the technology or production technique. Any negotiated license fee or royalty shall be placed in the operating fund of the arsenal concerned for the purpose of capital investment and technology development at that arsenal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf66119-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfers to Third Parties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A transfer described in subsection (c)(3) may be made if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaf6611a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defense article, technical data package, or technology to be transferred is a product of a cooperative research and development program or a cooperative project in which the United States and the participating foreign country were partners; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf6611b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the President—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaf6611c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with all requirements of section 3(d) of the Arms Export Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2753/d"},"text":"22 U.S.C. 2753(d)","children":[],"tail":") with respect to such transfer; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaf6611d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certifies to Congress, before the transfer, that the transfer would provide a clear benefit to the production base of the United States for large-caliber cannon.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf6611e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice and Reports to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaf6611f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army shall submit to Congress a notice of each agreement entered into under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf66120-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall submit to Congress a semi-annual report on the operation of this section and of agreements entered into under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf66121-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7542/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Arsenal Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “arsenal” means a Government-owned, Government-operated defense plant that manufactures large-caliber cannon.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaf66122-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/c/tIX/s9036/b/1"},"text":"Pub. L. 99–500, § 101(c) [title IX, § 9036(b)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-82"},"text":"100 Stat. 1783–82","children":[],"tail":", 1783–107, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/c/tIX/s9036/b/1"},"text":"Pub. L. 99–591, § 101(c) [title IX, § 9036(b)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-82"},"text":"100 Stat. 3341–82","children":[],"tail":", 3341–107, § 4542; "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tXII/s1203/a/1"},"text":"Pub. L. 99–661, div. A, title XII, § 1203(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3968"},"text":"100 Stat. 3968","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVIII/s806"},"text":"Pub. L. 101–189, div. A, title VIII, § 806","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1489"},"text":"103 Stat. 1489","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tX"},"text":"Pub. L. 102–190, div. A, title X","children":[],"tail":", §§ 1061(a)(24), 1086, "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1473"},"text":"105 Stat. 1473","children":[],"tail":", 1483; renumbered § 7542, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/d"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaf66123-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaf66124-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaaf66125-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":" is a corrected version of "},{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" added identical sections."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaaf66126-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7542 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8762"},"text":"section 8762 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaaf66127-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4542"},"text":"section 4542 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/s1086/a"},"text":"Pub. L. 102–190, § 1086(a)","children":[],"tail":", substituted “friendly foreign country” for “member nation of the North Atlantic Treaty Organization or a country designated as a major non-NATO ally”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":", §§ 1061(a)(24)(A), 1086(b)(1), amended par. (3) identically, substituting “subsection (f)” for “subsection (d)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":", §§ 1061(a)(24)(B), 1086(b)(2), amended subsec. identically, substituting “subsection (c)(3)” for “subsection (b)(3)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s806/a/1"},"text":"Pub. L. 101–189, § 806(a)(1)","children":[],"tail":", substituted “a member nation of the North Atlantic Treaty Organization or a country designated as a major non-NATO ally” for “a friendly foreign country”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s806/a/2"},"text":"Pub. L. 101–189, § 806(a)(2)","children":[],"tail":", inserted “, except as provided in subsection (e)” after “arsenal concerned”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s806/a/3"},"text":"Pub. L. 101–189, § 806(a)(3)","children":[],"tail":", inserted “or (d)” after “subsection (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s806/b/2"},"text":"Pub. L. 101–189, § 806(b)(2)","children":[],"tail":", added subsecs. (d) and (e). Former subsecs. (d) and (e) redesignated (f) and (g), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s806/b/1"},"text":"Pub. L. 101–189, § 806(b)(1)","children":[],"tail":", redesignated subsec. (d) as (f). Former subsec. (f) redesignated (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s806/c"},"text":"Pub. L. 101–189, § 806(c)","children":[],"tail":", inserted “or a cooperative project” after “cooperative research and development program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/