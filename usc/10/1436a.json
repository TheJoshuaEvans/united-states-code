{"tag":"section","attrib":{"id":"ida8c85cdd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1436a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1436a"},"text":"§ 1436a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage paid up at 30 years and age 70","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"2008-10-01"},"text":"October 1, 2008","children":[],"tail":", a reduction under this subchapter in the retired or retainer pay of a person electing an annuity under this subchapter may not be made for any month after the later of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8c85cde-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1436a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the month that is the 360th month for which that person’s retired or retainer pay is reduced pursuant to such an election; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8c85cdf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1436a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the month during which that person attains 70 years of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8c85ce0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s655/a"},"text":"Pub. L. 106–65, div. A, title VI, § 655(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/667"},"text":"113 Stat. 667","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
