{"tag":"section","attrib":{"id":"idab68d1ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9274"},"text":null,"children":[{"tag":"num","attrib":{"value":"9274"},"text":"§ 9274.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medal of honor; Air Force cross; distinguished-service medal: limitations on award","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab68d1ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9274/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No more than one Air Force Cross or distinguished-service medal may be awarded to a person. However, for each succeeding act that would otherwise justify the award of such a medal or cross, the President may award a suitable bar or other device to be worn as he directs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab68d1ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9274/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (c), no medal of honor, Air Force cross, distinguished-service medal, or device in place thereof, may be awarded to a person unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab68d1ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9274/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the award is made within five years after the date of the act justifying the award;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab68d1f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9274/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement setting forth the distinguished service and recommending official recognition of it was made within three years after the distinguished service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab68d1f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9274/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it appears from records of the Department of the Air Force that the person is entitled to the award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab68d1f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9274/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Secretary of the Air Force determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab68d1f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9274/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement setting forth the distinguished service and recommending official recognition of it was made and supported by sufficient evidence within three years after the distinguished service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab68d1f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9274/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no award was made, because the statement was lost or through inadvertence the recommendation was not acted on;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"a medal of honor, Air Force cross, distinguished-service medal, or device in place thereof, as the case may be, may be awarded to the person concerned within two years after the date of that determination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab68d1f5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/540"},"text":"70A Stat. 540","children":[],"tail":", § 8744; "},{"tag":"ref","attrib":{"href":"/us/pl/86/582/s1/3"},"text":"Pub. L. 86–582, § 1(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-05"},"text":"July 5, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/320"},"text":"74 Stat. 320","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/593/s1/2"},"text":"Pub. L. 86–593, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-06"},"text":"July 6, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/331"},"text":"74 Stat. 331","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tV"},"text":"Pub. L. 113–66, div. A, title V","children":[],"tail":", §§ 561(c), 562(b), "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/766"},"text":"127 Stat. 766","children":[],"tail":"; renumbered § 9274, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/b/11"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(b)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1833"},"text":"132 Stat. 1833","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tV/s582/b/3"},"text":"Pub. L. 116–92, div. A, title V, § 582(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1412"},"text":"133 Stat. 1412","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab68d1f6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab68d1f7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab68d1f8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":nu