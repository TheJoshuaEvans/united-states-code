ords between 1st and 2d semicolons of 15th par. under “Ordnance Department”), "},{"tag":"html:a","attrib":{"href":"/us/stat/40/871"},"text":"40 Stat. 871","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “may be awarded to a person” are substituted for the words “shall be issued to any one person” to conform to the other subsections of the revised section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “thereof” is substituted for the words “of either of said medal or of said cross”. The words “Except as otherwise prescribed in this section”, “at the time of”, “specific”, “official”, and “has so distinguished himself as” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), 10:1409 (words after 3d semicolon) is omitted as executed. The words “hereinbefore authorized” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab68d1f9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab68d1fa-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s582/b/3/A"},"text":"Pub. L. 116–92, § 582(b)(3)(A)","children":[],"tail":", substituted “subsection (c)” for “subsection (d)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s582/b/3/B"},"text":"Pub. L. 116–92, § 582(b)(3)(B)","children":[],"tail":", (C), redesignated subsec. (d) as (c) and struck out former subsec. (c) which read as follows: “No medal of honor, Air Force cross, distinguished-service medal, or device in place thereof, may be awarded or presented to a person whose service after he distinguished himself has not been honorable.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8744"},"text":"section 8744 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s561/c"},"text":"Pub. L. 113–66, § 561(c)","children":[],"tail":", substituted “Air Force Cross” for “medal of honor, Air Force cross,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s562/b/1/A"},"text":"Pub. L. 113–66, § 562(b)(1)(A)","children":[],"tail":", substituted “five years” for “three years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s562/b/1/B"},"text":"Pub. L. 113–66, § 562(b)(1)(B)","children":[],"tail":", substituted “three years” for “two years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s562/b/2"},"text":"Pub. L. 113–66, § 562(b)(2)","children":[],"tail":", substituted “three years” for “two years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/593"},"text":"Pub. L. 86–593","children":[],"tail":" substituted “Air Force cross” for “distinguished-service cross” in section catchline and wherever appearing in subsecs. (a) to (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/582/s1/3/A"},"text":"Pub. L. 86–582, § 1(3)(A)","children":[],"tail":", substituted “Except as provided in subsection (d), no” for “No”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/582/s1/3/B"},"text":"Pub. L. 86–582, § 1(3)(B)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab68d1fb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab68d1fc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab68d1fd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Persons Awarded Distinguished-Service Cross or Soldier’s Medal Before ","children":[{"tag":"date","attrib":{"date":"1960-07-06"},"text":"July 6, 1960","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/593/s2"},"text":"Pub. L. 86–593, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-06"},"text":"July 6, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/332"},"text":"74 Stat. 332","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s809/b/12"},"text":"Pub. L. 115–232, div. A, title VIII, § 809(b)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1841"},"text":"132 Stat. 1841","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/232/dA/tVIII/s809/b/12"},"text":"“For the purposes of sections 9274(a) and 9280(b) of title 10, United States Code, a person who was awarded a distinguished-service cross or Soldier’s Medal before the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1960-07-06"},"text":"July 6, 1960","children":[],"tail":"] shall be treated as if he had not been awarded an Air Force cross or Airman’s Medal, as the case may be.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
