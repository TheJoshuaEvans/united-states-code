{"tag":"section","attrib":{"id":"ida77354df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s166b"},"text":null,"children":[{"tag":"num","attrib":{"value":"166b"},"text":"§ 166b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Combatant commands: funding for combating terrorism readiness initiatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida77354e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s166b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Combating Terrorism Readiness Initiatives Fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"From funds made available in any fiscal year for the budget account in the Department of Defense known as the “Combating Terrorism Readiness Initiatives Fund”, the Chairman of the Joint Chiefs of Staff may provide funds to the commander of a combatant command, upon the request of the commander, or, with respect to a geographic area or areas not within the area of responsibility of a commander of a combatant command, to an officer designated by the Chairman of the Joint Chiefs of Staff for such purpose. The Chairman may provide such funds for initiating any activity named in subsection (b) and for maintaining and sustaining the activity for the fiscal year in which initiated and one additional fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida77354e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s166b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities for which funds may be provided under subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida77354e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s166b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procurement and maintenance of physical security equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida77354e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s166b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improvement of physical security sites.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida77354e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s166b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under extraordinary circumstances—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida77354e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s166b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical security management planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida77354e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s166b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procurement and support of security forces and security technicians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida77354e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s166b/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security reviews and investigations and vulnerability assessments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida77354e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s166b/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activity relating to physical security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida77354e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s166b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Priority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chairman of the Joint Chiefs of Staff, in considering requests for funds in the Combating Terrorism Readiness Initiatives Fund, should give priority consideration to emergency or emergent unforeseen high-priority requirements for combating terrorism.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida77354ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s166b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any amount provided by the Chairman of the Joint Chiefs of Staff for a fiscal year out of the Combating Terrorism Readiness Initiatives Fund for an activity referred to in subsection (b) shall be in addition to amounts otherwise available for that activity for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida77354eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s166b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds may not be provided under this section for any activity that has been denied authorization by Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida77354ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXV/s1512/a"},"text":"Pub. L. 107–107, div. A, title XV, § 1512(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1272"},"text":"115 Stat. 1272","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
