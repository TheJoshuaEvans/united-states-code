{"tag":"section","attrib":{"id":"ida83bace7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950j"},"text":null,"children":[{"tag":"num","attrib":{"value":"950j"},"text":"§ 950j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finality of proceedings, findings, and sentences","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The appellate review of records of trial provided by this chapter, and the proceedings, findings, and sentences of military commissions as approved, reviewed, or affirmed as required by this chapter, are final and conclusive. Orders publishing the proceedings of military commissions under this chapter are binding upon all departments, courts, agencies, and officers of the United States, subject only to action by the Secretary or the convening authority as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s950i/c"},"text":"section 950i(c) of this title","children":[],"tail":" and the authority of the President."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida83bace8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tXVIII/s1802"},"text":"Pub. L. 111–84, div. A, title XVIII, § 1802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2605"},"text":"123 Stat. 2605","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida83bace9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida83bacea-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvision