{"tag":"section","attrib":{"id":"idab1559fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8221"},"text":null,"children":[{"tag":"num","attrib":{"value":"8221"},"text":"§ 8221.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chaplains: divine services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab1559fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8221/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer in the Chaplain Corps may conduct public worship according to the manner and forms of the church of which he is a member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1559fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8221/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The commanders of vessels and naval activities to which chaplains are attached shall cause divine service to be performed on Sunday, whenever the weather and other circumstances allow it to be done; and it is earnestly recommended to all officers, seamen, and others in the naval service diligently to attend at every performance of the worship of Almighty God.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1559ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8221/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All persons in the Navy and in the Marine Corps are enjoined to behave themselves in a reverent and becoming manner during divine service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab155a00-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956,