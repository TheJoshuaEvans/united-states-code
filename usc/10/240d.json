{"tag":"section","attrib":{"id":"ida79004ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240d"},"text":null,"children":[{"tag":"num","attrib":{"value":"240d"},"text":"§ 240d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits: audit of financial statements of Department of Defense components by independent external auditors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida79004cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Audits Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of satisfying the requirement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3521/e"},"text":"section 3521(e) of title 31","children":[],"tail":" for audits of financial statements of Department of Defense components identified by the Director of the Office of Management and Budget under section 3515(c) of such title, the Inspector General of the Department of Defense shall obtain each year audits of the financial statements of each such component by an independent external auditor."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida79004d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection of Auditors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The selection of independent external auditors for purposes of subsection (a) shall be based, among other appropriate criteria, on their qualifications, independence, and capacity to conduct audits described in subsection (a) in accordance with applicable generally accepted government auditing standards. The Inspector General shall participate in the selection of the independent external auditors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida79004d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monitoring Audits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Inspector General shall monitor the conduct of all audits by independent external auditors under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida79004d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports on Audits.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida79004d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Inspector General shall require the independent external auditors conducting audits under subsection (a) to submit a report on their audits each year to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida79004d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240d/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary of Defense (Comptroller) as the Chief Financial Officer of the Department of Defense for the purposes of chapter 9 of title 31;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida79004d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240d/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Controller of the Office of Federal Financial Management in the Office of Management and Budget;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida79004d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240d/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of each component audited; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida79004d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240d/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate committees of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida79004d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate committees of congress defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida79004d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240d/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services, the Committee on Homeland Security and Governmental Affairs, and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida79004da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240d/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services, the Committee on Oversight and Government Reform, and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida79004db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Existing Law","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida79004dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be construed to alter the requirement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3521/e"},"text":"section 3521(e) of title 31","children":[],"tail":" that the financial statements of the Department of Defense as a whole be audited by the Inspector General or by an independent external auditor, as determined by the Inspector General; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida79004dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be construed to limit or alter the authorities of the Comptroller General of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3521/g"},"text":"section 3521(g) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7924dce-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1002/e/1"},"text":"Pub. L. 115–91, div. A, title X, § 1002(e)(1)","children":[],"tail":"–(3), "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1541"},"text":"131 Stat. 1541","children":[],"tail":", § 254; renumbered § 240d, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tX/s1002/a/1/A"},"text":"Pub. L. 115–232, div. A, title X, § 1002(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1945"},"text":"132 Stat. 1945","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tIX/s901/d"},"text":"Pub. L. 118–31, div. A, title IX, § 901(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/354"},"text":"137 Stat. 354","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7924dcf-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7924dd0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida7924dd1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Text of section, as added by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":", is based on text of "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/s1005"},"text":"section 1005 of Pub. L. 114–92","children":[],"tail":", div. A, title X, "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/961"},"text":"129 Stat. 961","children":[],"tail":", which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2222"},"text":"section 2222 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1002/e/4"},"text":"Pub. L. 115–91, div. A, title X, § 1002(e)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1541"},"text":"131 Stat. 1541","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7924dd2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" struck out “and the Chief Management Officer of the Department of Defense” after “chapter 9 of title 31”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s254"},"text":"section 254 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1002/e/2/B"},"text":"Pub. L. 115–91, § 1002(e)(2)(B)","children":[],"tail":", struck out “, United States Code,” after “title 31”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1002/e/3/A/i"},"text":"Pub. L. 115–91, § 1002(e)(3)(A)(i)","children":[],"tail":", inserted “and the Chief Management Officer of the Department of Defense” before semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1002/e/2/A"},"text":"Pub. L. 115–91, § 1002(e)(2)(A)","children":[],"tail":", struck out “, United States Code” after “title 31”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1002/e/3/A/ii"},"text":"Pub. L. 115–91, § 1002(e)(3)(A)(ii)","children":[],"tail":"–(iv), added subpar. (C) and redesignated former subpar. (C) as (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1002/e/3/B"},"text":"Pub. L. 115–91, § 1002(e)(3)(B)","children":[],"tail":", redesignated par. (2) as (1) and struck out former par. (1) which read as follows: “shall be implemented in a manner that is consistent with the requirements of section 1008 of the National Defense Authorization Act for Fiscal Year 2002 ("},{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Public Law 107–107","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s113"},"text":"10 U.S.C. 113","children":[],"tail":" note);”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1002/e/3/B/ii"},"text":"Pub. L. 115–91, § 1002(e)(3)(B)(ii)","children":[],"tail":", redesignated par. (3) as (2). Former par. (2) redesignated (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1002/e/2/B"},"text":"Pub. L. 115–91, § 1002(e)(2)(B)","children":[],"tail":", struck out “, United States Code,” after “title 31”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1002/e/3/B/ii"},"text":"Pub. L. 115–91, § 1002(e)(3)(B)(ii)","children":[],"tail":", redesignated par. (3) as (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1002/e/2/A"},"text":"Pub. L. 115–91, § 1002(e)(2)(A)","children":[],"tail":", struck out “, United States Code” after “title 31”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7924dd3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"ida7924dd4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7924dd5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Audit Requirement for Department of Defense Components","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tX/s1004"},"text":"Pub. L. 118–31, div. A, title X, § 1004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/379"},"text":"137 Stat. 379","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tX/s1004"},"text":"Pub. L. 118–159, div. A, title X, § 1004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2047"},"text":"138 Stat. 2047","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tX/s1005"},"text":"Pub. L. 119–60, div. A, title X, § 1005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1029"},"text":"139 Stat. 1029","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tX/s1005"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"During each of fiscal years 2024 through 2035, each component of the Department of Defense shall be subject to an independent audit. Any such component that fails to be subject to such an audit during any fiscal year shall have 1.5 percent of unobligated amounts available for the component be cancelled and returned to the general fund of the Treasury for deficit reduction, except as provided in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following accounts are excluded from any reductions:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Military personnel, reserve personnel, and National Guard personnel accounts of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Defense Health Program account of the Department of Defense.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7924dd6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transparency of Accounting Firms Used To Support Department of Defense Audit","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tX/s1006"},"text":"Pub. L. 115–232, div. A, title X, § 1006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1947"},"text":"132 Stat. 1947","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tX/s1011"},"text":"Pub. L. 116–92, div. A, title X, § 1011","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1577"},"text":"133 Stat. 1577","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dA/tX/s1011"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For all contract actions (including awards, renewals, and amendments) occurring more than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":"], the Secretary of Defense shall require any accounting firm providing financial statement auditing or audit remediation services to the Department of Defense in support of the audit required under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3521"},"text":"section 3521 of title 31","children":[],"tail":", United States Code, to provide the Department with a statement setting forth the details of any disciplinary proceedings with respect to the accounting firm or its associated persons before any entity with the authority to enforce compliance with rules or laws applying to audit services offered by accounting firms."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Statement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A statement setting forth the details of a disciplinary proceeding submitted pursuant to subsection (a), and the information contained in such a statement, shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treated as confidential to the extent required by the court or agency in which the proceeding has occurred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treated in a manner consistent with any protections or privileges established by any other provision of Federal law.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
