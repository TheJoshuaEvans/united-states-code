{"tag":"section","attrib":{"id":"ida7f68da5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649f"},"text":null,"children":[{"tag":"num","attrib":{"value":"649f"},"text":"§ 649f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure of selection for promotion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7f68da6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in this section, sections 627 through 632 of this title shall apply to promotions of officers in competitive categories of officers designated for purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f68da7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of Failure of Selection for Promotion to Officers Above Promotion Zone","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The reference in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s627"},"text":"section 627 of this title","children":[],"tail":" to an officer above the promotion zone shall not apply in the promotion of officers described in subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f68da8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Selection Board Matters","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The reference in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s628/a/1"},"text":"section 628(a)(1) of this title","children":[],"tail":" to a person above the promotion zone shall not apply in the promotion of officers described in subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f68da9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Failure of Selection","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the administration of this subchapter pursuant to subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7f68daa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649f/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer described in subsection (a) shall not be deemed to have failed twice of selection for promotion for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s629/e/2"},"text":"section 629(e)(2) of this title","children":[],"tail":" until the officer has failed selection of promotion to the next higher grade the maximum number of times specified for opportunities for promotion to such grade within the competitive category concerned pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s649d"},"text":"section 649d of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f68dab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649f/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reference in section 631(a) or 632(a) of this title to an officer who has failed of selection for promotion to the next higher grade for the second time shall be deemed to refer instead to an officer described in subsection (a) who has failed of selection for promotion to the next higher grade for the maximum number of times specified for opportunities for promotion to such grade within the competitive category concerned pursuant to such section 649d.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7f68dac-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tV/s507/a/1"},"text":"Pub. L. 115–232, div. A, title V, § 507(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1746"},"text":"132 Stat. 1746","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
