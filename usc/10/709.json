{"tag":"section","attrib":{"id":"ida802749a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s709"},"text":null,"children":[{"tag":"num","attrib":{"value":"709"},"text":"§ 709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency leave of absence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida802749b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Emergency Leave of Absence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may grant a member of the armed forces emergency leave of absence for a qualifying emergency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida802749c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An emergency leave of absence under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida802749d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s709/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be granted only once for any member;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida802749e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s709/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be granted only to prevent the member from entering unearned leave status or excess leave status; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida802749f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s709/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not extend for a period of more than 14 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida80274a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s709/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifying Emergency","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “qualifying emergency”, with respect to a member of the armed forces, means a circumstance that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida80274a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s709/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is due to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida80274a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s709/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a medical condition of a member of the immediate family of the member; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida80274a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s709/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other hardship that the Secretary concerned determines appropriate for purposes of this section; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida80274a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s709/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is verified to the Secretary’s satisfaction based upon information or opinion from a source in addition to the member that the Secretary considers to be objective and reliable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida80274a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s709/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Military Department Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Regulations prescribed under this section by the Secretaries of the military department shall be as uniform as practicable and shall be subject to approval by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida80274a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s709/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida80274a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s709/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “unearned leave status” means leave approved to be used by a member of the armed forces that exceeds the amount of leave credit that has been accrued as a result of the member’s active service and that has not been previously used by the member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida80274a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s709/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “excess leave status” means leave approved to be used by a member of the armed forces that is unearned leave for which a member is unable to accrue leave credit during the member’s current term of service before the member’s separation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida80274a9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tV/s572/a"},"text":"Pub. L. 107–314, div. A, title V, § 572(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2557"},"text":"116 Stat. 2557","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
