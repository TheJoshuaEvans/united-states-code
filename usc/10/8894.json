{"tag":"section","attrib":{"id":"idab534dba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8894"},"text":null,"children":[{"tag":"num","attrib":{"value":"8894"},"text":"§ 8894.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stay of proceedings for taking evidence before suit is filed","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab534dbb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8894/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If in time of war, with respect to any claim against the United States on which a suit described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8891"},"text":"section 8891 of this title","children":[],"tail":" would lie, the Secretary of the Navy certifies to the court, or to a judge of the court, in which proceedings are pending for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab534dbc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8894/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the granting of a dedimus potestatem to take depositions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab534dbd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8894/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a direction to take depositions in perpetuam rei memoriam; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab534dbe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8894/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taking of depositions or production of evidence pursuant to such dedimus potestatem or direction, or pursuant to any other proceedings for the purpose;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that the proceedings would tend to endanger the security of the United States or any of its naval or military operations in the war, or would tend to interfere with those operations, then the proceedings may not be started or, if they have been started, they shall, when the certificate is filed, be stayed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab534dbf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8894/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The time during which a claimant may file suit of the type described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8891"},"text":"section 8891 of this title","children":[],"tail":" is computed by excluding the time during which a stay under this section or any extension of such a stay is in effect."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab534dc0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/484"},"text":"70A Stat. 484","children":[],"tail":", § 7724; renumbered § 8894 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 807(d)(10), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":", 1840.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab534dc1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","