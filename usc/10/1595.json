{"tag":"section","attrib":{"id":"ida8fa699b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1595"},"text":null,"children":[{"tag":"num","attrib":{"value":"1595"},"text":"§ 1595.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civilian faculty members at certain Department of Defense schools: employment and compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8fa699c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1595/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may employ as many civilians as professors, instructors, and lecturers at the organizations specified in subsection (c) as the Secretary considers necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa699d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1595/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation of Faculty Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The compensation of persons employed under this section shall be as prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa699e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1595/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Organizations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies with respect to the following organizations of the Department of Defense:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fa699f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1595/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Defense University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa69a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1595/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Foreign Language Center of the Defense Language Institute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa69a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1595/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The English Language Center of the Defense Language Institute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa69a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1595/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Western Hemisphere Institute for Security Cooperation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa69a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1595/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Joint Special Operations University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa69a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1595/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Defense Security Cooperation University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa69a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1595/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Defense Institute for Security Governance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa69a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1595/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Defense Institute of International Legal Studies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa69a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1595/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Element of the Inter-American Defense College.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa69a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1595/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application to Faculty Members at","children":[],"tail":" NDU.—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of the National Defense University, this section applies with respect to persons selected by the Secretary for employment as professors, instructors, and lecturers at the National Defense University after ","children":[{"tag":"date","attrib":{"date":"1990-02-27"},"text":"February 27, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib