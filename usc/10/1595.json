","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2737"},"text":"110 Stat. 2737","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tIX"},"text":"Pub. L. 105–85, div. A, title IX","children":[],"tail":", §§ 921(c), 922(b), "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1863"},"text":"111 Stat. 1863","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tXI/s1115"},"text":"Pub. L. 108–136, div. A, title XI, § 1115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1636"},"text":"117 Stat. 1636","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tIX/s904/b/1"},"text":"Pub. L. 109–364, div. A, title IX, § 904(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2353"},"text":"120 Stat. 2353","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tV/s555"},"text":"Pub. L. 115–232, div. A, title V, § 555","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1773"},"text":"132 Stat. 1773","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXI/s1107"},"text":"Pub. L. 116–283, div. A, title XI, § 1107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3891"},"text":"134 Stat. 3891","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXI/s1104"},"text":"Pub. L. 117–81, div. A, title XI, § 1104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1950"},"text":"135 Stat. 1950","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXI/s1107"},"text":"Pub. L. 118–159, div. A, title XI, § 1107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2088"},"text":"138 Stat. 2088","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8fa69aa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8fa69ab-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8fa69ac-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1107/b/1"},"text":"Pub. L. 118–159, § 1107(b)(1)","children":[],"tail":", substituted “organizations” for “institutions”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1107/b/2"},"text":"Pub. L. 118–159, § 1107(b)(2)","children":[],"tail":", substituted “Organizations” for “Institutions” in heading and “organizations” for “institutions” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1107/a"},"text":"Pub. L. 118–159, § 1107(a)","children":[],"tail":", added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (c)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" added pars. (6) and (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c)(3) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s904/b/1/A"},"text":"Pub. L. 109–364, § 904(b)(1)(A)","children":[],"tail":", redesignated pars. (4) and (6) as (3) and (4), respectively, and struck out former pars. (3) and (5) which related to the George C. Marshall European Center for Security Studies and the Asia-Pacific Center for Security Studies, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s904/b/1/B"},"text":"Pub. L. 109–364, § 904(b)(1)(B)","children":[],"tail":", struck out heading and text of subsec. (e). Text read as follows: “In addition to the persons specified in subsection (a), this section also applies with respect to the Director and the Deputy Director of the following:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The George C. Marshall European Center for Security Studies.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The Asia-Pacific Center for Security Studies.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) The Center for Hemispheric Defense Studies.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s921/c"},"text":"Pub. L. 105–85, § 921(c)","children":[],"tail":", struck out “(1)” before “In the case of” and struck out par. (2) which read as follows: “For purposes of this section, the National Defense University includes the National War College, the Armed Forces Staff College, the Institute for National Strategic Study, and the Industrial College of the Armed Forces.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s922/b"},"text":"Pub. L. 105–85, § 922(b)","children":[],"tail":", added subsec. (e) and struck out former subsecs. (e) and (f) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(e) ","children":[{"tag":"inline","attrib":{},"text":"Application to Director and Deputy Director at George C. Marshall Center","children":[],"tail":".—In the case of the George C. Marshall European Center for Security Studies, this section also applies with respect to the Director and the Deputy Director."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(f) ","children":[{"tag":"inline","attrib":{},"text":"Application to Director and Deputy Director at Asia-Pacific Center for Security Studies","children":[],"tail":".—In the case of the Asia-Pacific Center for Security Studies, this section also applies with respect to the Director and the Deputy Director.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1607/a"},"text":"Pub. L. 104–201, § 1607(a)","children":[],"tail":", added pars. (4) and (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1607/b"},"text":"Pub. L. 104–201, § 1607(b)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":" substituted “Civilian faculty members at certain Department of Defense schools: employment and compensation” for “National Defense University: Foreign Language Center of the Defense Language Institute: civilian faculty members” as section catchline and amended text generally, substituting subsecs. (a) to (e) for former subsecs. (a) to (d) relating to similar subject matter but not including coverage of the George C. Marshall European Center for Security Studies."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s923/a/2/A"},"text":"Pub. L. 102–484, § 923(a)(2)(A)","children":[],"tail":", substituted “University; Foreign Language Center of the Defense Language Institute” for “University:” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s923/a/1/A"},"text":"Pub. L. 102–484, § 923(a)(1)(A)","children":[],"tail":", inserted “and the Foreign Language Center of the Defense Language Institute” after “National Defense University”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s923/a/1/B"},"text":"Pub. L. 102–484, § 923(a)(1)(B)","children":[],"tail":", substituted “In the case of the National Defense University, this section” for “This section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L. 102–25","children":[],"tail":" substituted “after "},{"tag":"date","attrib":{"date":"1990-02-27"},"text":"February 27, 1990","children":[],"tail":"” for “after the end of the 90-day period beginning on the date of the enactment of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" inserted “the Institute for National Strategic Study,” after “Staff College,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8fa69ad-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8fa69ae-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effect of 1992 Amendments on Current Employees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tIX/s923/b"},"text":"Pub. L. 102–484, div. A, title IX, § 923(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2474"},"text":"106 Stat. 2474","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/484/dA/tIX/s923/b"},"text":"“In the case of a person who, on the day before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":"], is employed as a professor, instructor, or lecturer at the Foreign Language Center of the Defense Language Institute, the Secretary of Defense shall afford the person an opportunity to elect to be paid under the compensation plan authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1595/b"},"text":"section 1595(b) of title 10","children":[],"tail":", United States Code, or to continue to be paid under the General Schedule (with no reduction in pay) under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
