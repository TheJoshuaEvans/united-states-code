{"tag":"section","attrib":{"id":"ida879a067-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074o"},"text":null,"children":[{"tag":"num","attrib":{"value":"1074o"},"text":"§ 1074o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of hyperbaric oxygen therapy for certain members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida879a068-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074o/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may furnish hyperbaric oxygen therapy available at a military medical treatment facility to a covered member if such therapy is prescribed by a physician to treat post-traumatic stress disorder or traumatic brain injury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida879a069-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074o/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Member Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered member” means a member of the armed forces who is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida879a06a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074o/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving on active duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida879a06b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074o/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diagnosed with post-traumatic stress disorder or traumatic brain injury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida879a06c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVII/s703/a/1"},"text":"Pub. L. 115–91, div. A, title VII, § 703(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1435"},"text":"131 Stat. 1435","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida879a06d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida879a06e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida879a06f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVII/s703/b"},"text":"Pub. L. 115–91, div. A, title VII, § 703(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1435"},"text":"131 Stat. 1435","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/91/dA/tVII/s703/b"},"text":"“The amendments made by subsection (a) [enacting this section] shall take effect 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2017-1