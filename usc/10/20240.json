{"tag":"section","attrib":{"id":"idabca7990-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20240"},"text":null,"children":[{"tag":"num","attrib":{"value":"20240"},"text":"§ 20240.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of promotions; oath of office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabca7991-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20240/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who is appointed to a higher grade under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20239"},"text":"section 20239 of this title","children":[],"tail":" is considered to have accepted the appointment on the date on which the appointment is made unless the officer expressly declines the appointment."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabca7992-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20240/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Oath","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who has served continuously since taking the oath of office prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3331"},"text":"section 3331 of title 5","children":[],"tail":" is not required to take a new oath upon appointment to a higher grade under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s20239"},"text":"section 20239 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabca7993-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1716/c"},"text":"Pub. L. 118–31, div. A, title XVII, § 1716(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/647"},"text":"137 Stat. 647","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
