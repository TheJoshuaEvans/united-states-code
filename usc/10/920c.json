{"tag":"section","attrib":{"id":"ida82d559e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920c"},"text":null,"children":[{"tag":"num","attrib":{"value":"920c"},"text":"§ 920c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 120c. Other sexual misconduct","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida82d559f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Indecent Viewing, Visual Recording, or Broadcasting","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter who, without legal justification or lawful authorization—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82d55a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and wrongfully views the private area of another person, without that other person’s consent and under circumstances in which that other person has a reasonable expectation of privacy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d55a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly photographs, videotapes, films, or records by any means the private area of another person, without that other person’s consent and under circumstances in which that other person has a reasonable expectation of privacy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d55a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly broadcasts or distributes any such recording that the person knew or reasonably should have known was made under the circumstances proscribed in paragraphs (1) and (2);","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is guilty of an offense under this section and shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82d55a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Forcible Pandering","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person subject to this chapter who compels another person to engage in an act of prostitution with any person is guilty of forcible pandering and shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82d55a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Indecent Exposure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person subject to this chapter who intentionally exposes, in an indecent manner, the genitalia, anus, buttocks, or female areola or nipple is guilty of indecent exposure and shall by punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82d55a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82d55a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Act of prostitution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “act of prostitution” means a sexual act or sexual contact (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s920/g"},"text":"section 920(g) of this title","children":[],"tail":" (article 120(g))) on account of which anything of value is given to, or received by, any person."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d55a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Private area","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “private area” means the naked or underwear-clad genitalia, anus, buttocks, or female areola or nipple.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d55a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920c/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reasonable expectation of privacy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “under circumstances in which that other person has a reasonable expectation of privacy” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida82d55a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920c/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" circumstances in which a reasonable person would believe that he or she could disrobe in privacy, without being concerned that an image of a private area of the person was being captured; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82d55aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920c/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" circumstances in which a reasonable person would believe that a private area of the person would not be visible to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d55ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920c/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Broadcast","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “broadcast” means to electronically transmit a visual image with the intent that it be viewed by a person or persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d55ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920c/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribute","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “distribute” means delivering to the actual or constructive possession of another, including transmission by electronic means.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d55ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920c/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Indecent manner","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “indecent manner” means conduct that amounts to a form of immorality relating to sexual impurity which is grossly vulgar, obscene, and repugnant to common propriety, and tends to excite sexual desire or deprave morals with respect to sexual relations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida82d55ae-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s541/c"},"text":"Pub. L. 112–81, div. A, title V, § 541(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1409"},"text":"125 Stat. 1409","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida82d55af-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida82d55b0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida82d55b1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", and applicable with respect to offenses committed on or after such effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/s541/f"},"text":"section 541(f) of Pub. L. 112–81","children":[],"tail":", set out as an Effective Date of 2011 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s843"},"text":"section 843 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
