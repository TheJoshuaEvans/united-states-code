g":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3324"},"text":"128 Stat. 3324","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tX/s1079/a"},"text":"Pub. L. 114–92, div. A, title X, § 1079(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/999"},"text":"129 Stat. 999","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tX/s1081/c/6"},"text":"Pub. L. 114–328, div. A, title X, § 1081(c)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2420"},"text":"130 Stat. 2420","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tII/s213"},"text":"Pub. L. 115–91, div. A, title II, § 213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1324"},"text":"131 Stat. 1324","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tX/s1081/a/21"},"text":"Pub. L. 115–232, div. A, title X, § 1081(a)(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1984"},"text":"132 Stat. 1984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tII/s215"},"text":"Pub. L. 116–92, div. A, title II, § 215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1257"},"text":"133 Stat. 1257","children":[],"tail":"; renumbered § 4025 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII"},"text":"Pub. L. 116–283, div. A, title XVIII","children":[],"tail":", §§ 1841(b)(1), 1842(b), 1883(b)(2), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4244"},"text":"134 Stat. 4244","children":[],"tail":", 4294; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVIII/s822"},"text":"Pub. L. 117–81, div. A, title VIII, § 822","children":[],"tail":", title XVII, § 1701(q)(1), (u)(2)(B), (3)(B), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1825"},"text":"135 Stat. 1825","children":[],"tail":", 2148, 2151, 2152; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVIII/s844"},"text":"Pub. L. 117–263, div. A, title VIII, § 844","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2719"},"text":"136 Stat. 2719","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tII/s211"},"text":"Pub. L. 119–60, div. A, title II, § 211","children":[],"tail":", title XVIII, § 1802(b)(1)(A), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/772"},"text":"139 Stat. 772","children":[],"tail":", 1227.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa51bc1a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa51bc1b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa51bc1c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4025 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7375"},"text":"section 7375 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa51bc1d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s211/a"},"text":"Pub. L. 119–60, § 211(a)","children":[],"tail":", inserted “the Director of the Defense Innovation Unit,” after “the Under Secretary of Defense for Acquisition and Sustainment,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s211/b/1"},"text":"Pub. L. 119–60, § 211(b)(1)","children":[],"tail":", substituted “$20,000,000” for “$10,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s211/b/2"},"text":"Pub. L. 119–60, § 211(b)(2)","children":[],"tail":", substituted “$2,000,000” for “$1,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s211/b/3"},"text":"Pub. L. 119–60, § 211(b)(3)","children":[],"tail":", substituted “$20,000” for “$10,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s211/c"},"text":"Pub. L. 119–60, § 211(c)","children":[],"tail":", substituted “$20,000,000” for “$10,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1802/b/1/A"},"text":"Pub. L. 119–60, § 1802(b)(1)(A)","children":[],"tail":", substituted “portfolio acquisition executive” for “program executive officer” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s844/1"},"text":"Pub. L. 117–263, § 844(1)","children":[],"tail":", substituted “development that—” for “development that”, inserted par. (1) designation before “have the potential”, substituted “Defense; or” for “Defense.”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s844/2"},"text":"Pub. L. 117–263, § 844(2)","children":[],"tail":", struck out “of research results, technology developments, and prototypes” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s844/3"},"text":"Pub. L. 117–263, § 844(3)","children":[],"tail":", struck out “to acquire, support, or stimulate basic, advanced and applied research, technology development, or prototype projects” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s844/4"},"text":"Pub. L. 117–263, § 844(4)","children":[],"tail":", substituted “chapter 221” for “section 2304”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2)(B) to (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s844/5"},"text":"Pub. L. 117–263, § 844(5)","children":[],"tail":", added subpars. (B) and (C) and redesignated former subpars. (B) and (C) as (D) and (E), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1842/b"},"text":"Pub. L. 116–283, § 1842(b)","children":[],"tail":", which directed the renumbering of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2374a"},"text":"section 2374a of this title","children":[],"tail":" as section 4065 instead of this section, was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/q/1"},"text":"Pub. L. 117–81, § 1701(q)(1)","children":[],"tail":", (u)(3)(B), effective as if included therein, so that such renumbering was no longer directed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1841/b/1"},"text":"Pub. L. 116–283, § 1841(b)(1)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/u/2/B"},"text":"Pub. L. 117–81, § 1701(u)(2)(B)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2374a"},"text":"section 2374a of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s822/1"},"text":"Pub. L. 117–81, § 822(1)","children":[],"tail":", inserted “, including procurement contracts and other agreements,” after “other types of prizes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s822/2"},"text":"Pub. L. 117–81, § 822(2)","children":[],"tail":", inserted “and for the selection of recipients of procurement contracts and other agreements” after “cash prizes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s822/3"},"text":"Pub. L. 117–81, § 822(3)","children":[],"tail":", inserted “without the approval of the Under Secretary of Defense for Research and Engineering” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1883/b/2"},"text":"Pub. L. 116–283, § 1883(b)(2)","children":[],"tail":", which directed that each reference in the text of title 10 to a section that was redesignated by title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", as such section was in effect before the redesignation, be amended by striking such reference and inserting a reference to the appropriate redesignated section, was not executed with respect to “section 2304”, which was redesignated as multiple sections."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s822/4"},"text":"Pub. L. 117–81, § 822(4)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “Under Secretary of Defense for Research and Engineering, the Under Secretary of Defense for Acquisition and Sustainment,” for “Assistant Secretary of Defense for Research and Engineering”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “Federal Government,” for “Federal Government,,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s213/1"},"text":"Pub. L. 115–91, § 213(1)","children":[],"tail":", substituted “and other types of prizes that the Secretary determines are appropriate to recognize” for “in recognition of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s213/2/A"},"text":"Pub. L. 115–91, § 213(2)(A)","children":[],"tail":", substituted “prize with a fair market value of” for “cash prize of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s213/2/B"},"text":"Pub. L. 115–91, § 213(2)(B)","children":[],"tail":", substituted “Under Secretary of Defense for Research and Engineering” for “Under Secretary of Defense for Acquisition, Technology, and Logistics”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s213/2/C"},"text":"Pub. L. 115–91, § 213(2)(C)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s213/3"},"text":"Pub. L. 115–91, § 213(3)","children":[],"tail":", inserted “or nonmonetary items” after “accept funds”, substituted “, from State and local governments, and from the private sector” for “and from State and local governments”, and inserted at end “The Secretary may not give any special consideration to any private sector entity in return for a donation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s213/4"},"text":"Pub. L. 115–91, § 213(4)","children":[],"tail":", amended subsec. (f) generally. Prior to amendment, text read as follows: “The authority to award prizes under subsection (a) shall terminate at the end of "},{"tag":"date","attrib":{"date":"2018-09-30"},"text":"September 30, 2018","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1081/c/6"},"text":"Pub. L. 114–328, § 1081(c)(6)","children":[],"tail":", made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/s1079/a"},"text":"Pub. L. 114–92, § 1079(a)","children":[],"tail":". See 2015 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s1079/a"},"text":"Pub. L. 114–92, § 1079(a)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1081/c/6"},"text":"Pub. L. 114–328, § 1081(c)(6)","children":[],"tail":", redesignated subsec. (g) as (f) and struck out former subsec. (f) which related to biennial reports."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s211/a"},"text":"Pub. L. 113–291, § 211(a)","children":[],"tail":", substituted “No prize competition may result in the award of a cash prize of more than $10,000,000.” for “The total amount made available for award of cash prizes in a fiscal year may not exceed $10,000,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s211/b/2"},"text":"Pub. L. 113–291, § 211(b)(2)","children":[],"tail":", added subsec. (e). Former subsec. (e) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s211/c/3"},"text":"Pub. L. 113–291, § 211(c)(3)","children":[],"tail":", substituted “"},{"tag":"inline","attrib":{},"text":"Biennial","children":[],"tail":"” for “"},{"tag":"inline","attrib":{},"text":"Annual","children":[],"tail":"” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s211/b/1"},"text":"Pub. L. 113–291, § 211(b)(1)","children":[],"tail":", redesignated subsec. (e) as (f). Former subsec. (f) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s211/c/1"},"text":"Pub. L. 113–291, § 211(c)(1)","children":[],"tail":", substituted “every other year” for “each year” and “two fiscal years” for “fiscal year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s211/c/2"},"text":"Pub. L. 113–291, § 211(c)(2)","children":[],"tail":", substituted “a period of two fiscal years” for “a fiscal year” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s211/b/1"},"text":"Pub. L. 113–291, § 211(b)(1)","children":[],"tail":", redesignated subsec. (f) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2018-09-30"},"text":"September 30, 2018","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2013-09-30"},"text":"September 30, 2013","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" substituted “Assistant Secretary of Defense for Research and Engineering” for “Director of Defense Research and Engineering”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" substituted “2013” for “2010”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s212/a/1"},"text":"Pub. L. 109–364, § 212(a)(1)","children":[],"tail":", substituted “Director of Defense Research and Engineering and the service acquisition executive for each military department” for “Director of the Defense Advanced Research Projects Agency” and “programs” for “a program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s212/a/2/A"},"text":"Pub. L. 109–364, § 212(a)(2)(A)","children":[],"tail":", substituted “Each program” for “The program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s212/a/2/B"},"text":"Pub. L. 109–364, § 212(a)(2)(B)","children":[],"tail":", substituted “A program” for “The program” and “an official referred to in that subsection” for “the Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s212/c"},"text":"Pub. L. 109–364, § 212(c)","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, subsec. (e) required an annual report, which included the results of consultations between the Director and officials of the military departments, a description of goals, cash prizes, methods used for submissions, a description of resources, and a description of transition plans."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “Promptly after the end of each fiscal year during which one or more prizes are awarded under the program under subsection (a), the Secretary shall submit to the Committees on Armed Services of the Senate and the House of Representatives a report on the administration of the program for that fiscal year. The report shall include the following:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The military applications of the research, technology, or prototypes for which prizes were awarded.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The total amount of the prizes awarded.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) The methods used for solicitation and evaluation of submissions, together with an assessment of the effectiveness of those methods.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s212/b"},"text":"Pub. L. 109–364, § 212(b)","children":[],"tail":", substituted “2010” for “2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" inserted “during which one or more prizes are awarded under the program under subsection (a)” after “each fiscal year” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2007-09-30"},"text":"September 30, 2007","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"September 30, 2003","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa51bc1e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa51bc1f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by section 1701(q)(1), (u)(2)(B), (3)(B) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" applicable as if included in the enactment of title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" as enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/a/2"},"text":"section 1701(a)(2) of Pub. L. 117–81","children":[],"tail":", set out in a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":" and note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa51bc20-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tX/s1081/c"},"text":"Pub. L. 114–328, div. A, title X, § 1081(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2419"},"text":"130 Stat. 2419","children":[],"tail":", provided that the amendment made by section 1081(c)(6) is effective as of "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa51bc21-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2011-01-01"},"text":"Jan. 1, 2011","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/s901/p"},"text":"section 901(p) of Pub. L. 111–383","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s131"},"text":"section 131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa51bc22-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prize Competition for Technology That Detects and Watermarks Use of Generative Artificial Intelligence","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXV/s1543"},"text":"Pub. L. 118–31, div. A, title XV, § 1543","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/573"},"text":"137 Stat. 573","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dA/tXV/s1543"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 270 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":"], under the authority of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4025"},"text":"section 4025 of title 10","children":[],"tail":", United States Code, the Secretary of Defense shall establish a prize competition designed to evaluate technology (including applications, tools, and models) for generative artificial intelligence detection and generative artificial intelligence watermarking, for the purposes of—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating the research, development, testing, evaluation, and competition of such technologies to support the Secretaries of the military departments and the commanders of combatant commands in warfighting requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transitioning such technologies, including technologies developed pursuant to pilot programs, prototype projects, or other research and development programs, from the prototyping phase to production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The participants in the prize competition under subsection (a) may include federally funded research and development centers, entities within the private sector, entities within the defense industrial base, institutions of higher education, Federal departments and agencies, and such other categories of participants as the Secretary of Defense considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The prize competition under subsection (a) shall be known as the ‘Generative AI Detection and Watermark Competition’.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Under Secretary of Defense for Research and Engineering shall administer the prize competition under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Framework","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 120 days after the date of the enactment of this Act, the Secretary of Defense shall provide to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] a briefing on the framework to be used in carrying out the prize competition under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Briefings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than October 1 of each year until the date of termination under subsection (g), the Secretary of Defense shall provide to the congressional defense committees a briefing on the results of the prize competition under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority to carry out the prize competition under subsection (a) shall terminate on ","children":[{"tag":"date","attrib":{"date":"2025-12-31"},"text":"December 31, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"“(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘generative artificial intelligence detection’ means, with respect to digital content, the positive identification of the use of generative artificial intelligence in the generation of such content.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘generative artificial intelligence watermarking’ means, with respect to digital content, embedding within such content data conveying attribution of the generation of such content to generative artificial intelligence.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa51bc23-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prize Competition To Identify Root Cause of Physiological Episodes on Navy, Marine Corps, and Air Force Training and Operational Aircraft","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1089"},"text":"Pub. L. 115–91, div. A, title X, § 1089","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1605"},"text":"131 Stat. 1605","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1842/c/1"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1842(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4244"},"text":"134 Stat. 4244","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/u/3/C"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(u)(3)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2152"},"text":"135 Stat. 2152","children":[],"tail":", which provided for the establishment of a prize competition designed to accelerate identification of the root cause of, or to find solutions to, physiological episodes experienced in Navy, Marine Corps, and Air Force training and operational aircraft, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVIII/s811/b/6/C"},"text":"Pub. L. 119–60, div. A, title VIII, § 811(b)(6)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/948"},"text":"139 Stat. 948","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
