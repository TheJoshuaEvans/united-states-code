{"tag":"section","attrib":{"id":"ida7bae53a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s429a"},"text":null,"children":[{"tag":"num","attrib":{"value":"429a"},"text":"§ 429a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditure of funds for Department of Defense intelligence and counterintelligence activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7bae53b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s429a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsections (b) and (c), the Secretary of Defense may expend amounts made available for the Military Intelligence Program for intelligence and counterintelligence activities for any purpose the Secretary determines to be proper with regard to intelligence and counterintelligence objects of a confidential, extraordinary, or emergency nature. Such a determination is final and conclusive upon the accounting officers of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bae53c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s429a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may not expend more than five percent of the amounts described in subsection (a) for any fiscal year for objects described in that subsection unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bae53d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s429a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary notifies the congressional defense committees and the congressional intelligence committees of the intent to expend the amounts and purpose of the expenditure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bae53e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s429a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 30 days have elapsed from the date on which the Secretary provides the notice described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bae53f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s429a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For each expenditure of funds under this section, the Secretary shall certify that such expenditure was made for an object of a confidential, extraordinary, or emergency nature.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bae540-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s429a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than December 31 of each year, the Secretary of Defense shall submit to the congressional defense committees and the congressional intelligence committees a report on expenditures made under this section during the fiscal year preceding the year in which the report is submitted. Each such report shall include, for each expenditure under this section during the fiscal year covered by the report, a description, the purpose, the program element, and the certification required under section (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bae541-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s429a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Delegations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may not delegate the authority under this section with respect to any expenditure in excess of $200,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bae542-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s429a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication of Section ","children":[],"tail":"127.—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority provided by subsection (a) shall be the exclusive authority available to the Secretary of Defense to expend amounts made available for the Military Intelligence Program for intelligence and counterintelligence objects of a confidential, extraordinary, or emergency nature.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bae543-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s429a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Intelligence Committees Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “congressional intelligence committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bae544-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s429a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Select Committee on Intelligence of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bae545-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s429a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Permanent Select Committee on Intelligence of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7bae546-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1614/a"},"text":"Pub. L. 118–159, div. A, title XVI, § 1614(a)","children":[],"tail":"–(e)(1), "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2168"},"text":"138 Stat. 2168","children":[],"tail":", 2169.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7bae547-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7bae548-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida7bae549-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1057"},"text":"section 1057 of Pub. L. 116–92","children":[],"tail":", which was transferred to this subchapter, inserted after "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s429"},"text":"section 429 of this title","children":[],"tail":", redesignated as this section, and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1614/a"},"text":"Pub. L. 118–159, div. A, title XVI, § 1614(a)","children":[],"tail":"–(e)(1), "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2168"},"text":"138 Stat. 2168","children":[],"tail":", 2169, was based on "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tX/s1057"},"text":"Pub. L. 116–92, div. A, title X, § 1057","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1593"},"text":"133 Stat. 1593","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7bae54a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1614/a"},"text":"Pub. L. 118–159, § 1614(a)","children":[],"tail":", transferred "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1057"},"text":"section 1057 of Pub. L. 116–92","children":[],"tail":" to this subchapter, inserted it after "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s429"},"text":"section 429 of this title","children":[],"tail":", redesignated it as this section, and conformed “SEC.” preceding section designation and catchline text to the style used in this title. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1614/b"},"text":"Pub. L. 118–159, § 1614(b)","children":[],"tail":", struck out “for any of fiscal years 2020 through 2025” after “Military Intelligence Program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1614/c"},"text":"Pub. L. 118–159, § 1614(c)","children":[],"tail":", substituted “Not later than December 31 of each year” for “Not later than December 31 of each of 2020 through 2025”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1614/d"},"text":"Pub. L. 118–159, § 1614(d)","children":[],"tail":", substituted “$200,000” for “$100,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1614/e/1"},"text":"Pub. L. 118–159, § 1614(e)(1)","children":[],"tail":", added subsec. (f) and redesignated former subsec. (f) as (g)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
