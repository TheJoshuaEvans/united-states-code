{"tag":"section","attrib":{"id":"idaa5b5960-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128"},"text":null,"children":[{"tag":"num","attrib":{"value":"4128"},"text":"§ 4128.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Laboratory Quality Enhancement Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa5b5961-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Required","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa5b5962-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense, acting through the Under Secretary of Defense for Research and Engineering, shall carry out a program under which the Secretary shall establish the panels described in subsection (b) and direct such panels—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa5b5963-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to review and make recommendations to the Secretary with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa5b5964-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing policies and practices affecting the science and technology reinvention laboratories to improve the mission effectiveness of such laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa5b5965-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new initiatives proposed by the science and technology reinvention laboratories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa5b5966-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new interpretations of existing provisions of law that would enhance the ability of a director of a science and technology reinvention laboratory to manage the laboratory and discharge the mission of the laboratory;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa5b5967-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support implementation of current and future initiatives affecting the science and technology reinvention laboratories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa5b5968-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct assessments or data analysis on the effectiveness of the authorities granted to the science and technology reinvention laboratories and such other issues as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b5969-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program carried out pursuant to paragraph (1) shall be known as the “Laboratory Quality Enhancement Program”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa5b596a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Panels","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The panels described in this subsection are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa5b596b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A panel on personnel, workforce development, and talent management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b596c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A panel on facilities, equipment, and infrastructure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b596d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A panel on research strategy, technology transfer, and industry and university partnerships.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b596e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A panel on governance and oversight processes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa5b596f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition of Panels","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa5b5970-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each panel described in paragraphs (1) through (3) of subsection (b) may be composed of subject matter and technical management experts from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa5b5971-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" laboratories and research centers of the Army, Navy, and Air Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa5b5972-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate Defense Agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa5b5973-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the Under Secretary of Defense for Research and Engineering; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa5b5974-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other entities as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b5975-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The panel described in subsection (b)(4) shall be composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa5b5976-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one member from each of the science and technology reinvention laboratories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa5b5977-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other members as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa5b5978-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Governance of Panels","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa5b5979-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chairperson of each panel established pursuant to subsection (a) shall be selected by the members of the respective panel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b597a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each panel, in coordination with the Under Secretary of Defense for Research and Engineering, shall transmit to the Science and Technology Executive Committee of the Department of Defense such information or findings on topics requiring decision or approval as the panel considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa5b597b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interpretation of Provisions of Law","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa5b597c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense for Research and Engineering, acting under the guidance of the Secretary, shall issue regulations regarding the meaning, scope, implementation, and applicability of any provision of a statute relating to a science and technology reinvention laboratory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b597d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In interpreting or defining under paragraph (1), the Under Secretary shall, to the degree practicable, emphasize providing the maximum operational flexibility to the directors of the science and technology reinvention laboratories to discharge the missions of their laboratories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b597e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In interpreting or defining under paragraph (1), the Under Secretary shall, to the extent practicable, consult and coordinate with the secretaries of the military departments and such other agencies or entities as the Under Secretary considers relevant on any proposed revision to regulations under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b597f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In interpreting or defining under paragraph (1), the Under Secretary shall seek recommendations from the panel described in subsection (b)(4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa5b5980-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4128/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Science and Technology Reinvention Laboratory Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “science and technology reinvention laboratory” means a Department of Defense laboratory designated as a Department of Defense science and technology reinvention laboratory under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4121"},"text":"section 4121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa5b5981-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tII/s217/a"},"text":"Pub. L. 118–159, div. A, title II, § 217(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1825"},"text":"138 Stat. 1825","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa5b5982-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa5b5983-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa5b5984-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 4128 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4129"},"text":"section 4129 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa5b5985-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tII/s211"},"text":"Pub. L. 114–328, div. A, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2046"},"text":"130 Stat. 2046","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tII/s218/a"},"text":"Pub. L. 115–91, div. A, title II, § 218(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1329"},"text":"131 Stat. 1329","children":[],"tail":", 1330; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tII/s215/d/6"},"text":"Pub. L. 117–81, div. A, title II, § 215(d)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1594"},"text":"135 Stat. 1594","children":[],"tail":", which was set out in a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4121"},"text":"section 4121 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tII/s217/b"},"text":"Pub. L. 118–159, div. A, title II, § 217(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1827"},"text":"138 Stat. 1827","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
