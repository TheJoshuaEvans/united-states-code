{"tag":"section","attrib":{"id":"ida84ec051-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1044a"},"text":"§ 1044a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to act as notary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida84ec052-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The persons named in subsection (b) have the general powers of a notary public and of a consul of the United States in the performance of all notarial acts to be executed by any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84ec053-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of any of the uniformed services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec054-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other persons eligible for legal assistance under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1044"},"text":"section 1044 of this title","children":[],"tail":" or regulations of the Department of Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec055-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Persons serving with, employed by, or accompanying the armed forces outside the United States and outside the Commonwealth of Puerto Rico, Guam, and the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec056-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other persons subject to the Uniform Code of Military Justice (chapter 47 of this title) outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84ec057-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Persons with the powers described in subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84ec058-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All judge advocates, including reserve judge advocates when not in a duty status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec059-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All civilian attorneys serving as legal assistance attorneys.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec05a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All adjutants, assistant adjutants, and personnel adjutants, including reserve members when not in a duty status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec05b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All other members of the uniformed services, including reserve members when not in a duty status, who are designated by regulations of the uniformed services or by statute to have those powers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec05c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the performance of notarial acts at locations outside the United States, all employees of a military department or the Coast Guard who are designated by regulations of the Secretary concerned or by statute to have those powers for exercise outside the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec05d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All civilian paralegals serving at military legal assistance offices, supervised by a military legal assistance counsel (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1044d/g"},"text":"section 1044d(g) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84ec05e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No fee may be paid to or received by any person for the performance of a notarial act authorized in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84ec05f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The signature of any such person acting as notary, together with the title of that person’s offices, is prima facie evidence that the signature is genuine, that the person holds the designated title, and that the person is authorized to perform a notarial act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida84ec060-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tV/s551/a/1"},"text":"Pub. L. 101–510, div. A, title V, § 551(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1566"},"text":"104 Stat. 1566","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s573"},"text":"Pub. L. 104–201, div. A, title V, § 573","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2534"},"text":"110 Stat. 2534","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXI/s1103"},"text":"Pub. L. 107–107, div. A, title XI, § 1103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1236"},"text":"115 Stat. 1236","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tV/s523/b"},"text":"Pub. L. 114–328, div. A, title V, § 523(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2116"},"text":"130 Stat. 2116","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/259/tII/s205/b/1"},"text":"Pub. L. 116–259, title II, § 205(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-23"},"text":"Dec. 23, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1167"},"text":"134 Stat. 1167","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida84ec061-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida84ec062-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida84ec063-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/259/s205/b/1/A"},"text":"Pub. L. 116–259, § 205(b)(1)(A)","children":[],"tail":", substituted “uniformed services” for “armed forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/259/s205/b/1/B"},"text":"Pub. L. 116–259, § 205(b)(1)(B)","children":[],"tail":", substituted “uniformed services” for “armed forces” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1103/a"},"text":"Pub. L. 107–107, § 1103(a)","children":[],"tail":", substituted “legal assistance attorneys” for “legal assistance officers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1103/b"},"text":"Pub. L. 107–107, § 1103(b)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s573/1"},"text":"Pub. L. 104–201, § 573(1)","children":[],"tail":", substituted “, including reserve judge advocates when not in a duty status” for “on active duty or performing inactive-duty training”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s573/2"},"text":"Pub. L. 104–201, § 573(2)","children":[],"tail":", substituted “adjutants, including reserve members when not in a duty status” for “adjutants on active duty or performing inactive-duty training”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s573/3"},"text":"Pub. L. 104–201, § 573(3)","children":[],"tail":", substituted “members of the armed forces, including reserve members when not in a duty status,” for “persons on active duty or performing inactive-duty training”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida84ec064-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"ida84ec065-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
