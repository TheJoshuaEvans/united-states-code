{"tag":"section","attrib":{"id":"ida7f68d86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649b"},"text":null,"children":[{"tag":"num","attrib":{"value":"649b"},"text":"§ 649b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection for promotion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7f68d87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in this section, the selection for promotion of officers in any competitive category of officers designated for purposes of this subchapter shall be governed by the provisions of subchapter I of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f68d88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Recommendation for Promotion of Officers Below Promotion Zone","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s616/b"},"text":"Section 616(b) of this title","children":[],"tail":" shall not apply to the selection for promotion of officers described in subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f68d89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendation for Officers To Be Excluded From Future Consideration for Promotion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In making recommendations pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s616"},"text":"section 616 of this title","children":[],"tail":" for purposes of the administration of this subchapter, a selection board convened under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s611/a"},"text":"section 611(a) of this title","children":[],"tail":" may recommend that an officer considered by the board be excluded from future consideration for promotion under this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7f68d8a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tV/s507/a/1"},"text":"Pub. L. 115–232, div. A, title V, § 507(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1744"},"text":"132 Stat. 1744","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
