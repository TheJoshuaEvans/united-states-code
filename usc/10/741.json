trib":{"href":"/us/stat/63/498"},"text":"63 Stat. 498","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"34:241a (1st and 2d sentences, less applicability to rank within grade).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"741(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:517 (1st and 2d sentences, as applicable to rank within grade).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"34:241a (1st and 2d sentences, as applicable to rank within grade).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"34:626–1(j).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"34:651 (less applicability to establishment of commissioned grades, and as applicable to rank within grade).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"741(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:517 (less 1st and 2d sentences).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"34:241a (less 1st and 2d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “Regular”, pertaining to major generals and brigadier generals, in 10:517 and 34:241a, is omitted, since the last sentence of 10:517 and 34:241a establish the rank of nonregular officers of the Army and the Air Force, with respect to officers of the Regular Army and the Regular Air Force. The effect of establishing their rank with respect to regular officers, when read in connection with the provisions prescribing the rank of officers of the regular components with officers of the other services, under 10:517 (less last sentence), 34:241a (less last sentence), and 34:241, is therefore to establish the rank of nonregular officers with respect to officers of the other listed services. This allows a consolidation of 10:517 (less last sentence, as applicable to rank), 34:241, and 34:241a (less last sentence, as applicable to rank), together with 34:651, into a table of rank among officers of the Army, Navy, Air Force, and Marine Corps. The words “lineal rank only being considered”, in 34:241, are covered by setting forth the grades in tabular form. The words “whether on the active or retired list”, in 34:241, are omitted, since retired officers of the Navy continue to be officers of the Navy. The words “Lieutenant (junior grade)” are substituted for the word “masters”, in R.S. 1466, to reflect the change made in the name of that grade by the ","children":[{"tag":"ref","attrib":{"href":"/us/act/1883-03-03/ch97"},"text":"Act of March 3, 1883, ch. 97","children":[],"tail":" (2d par.), "},{"tag":"ref","attrib":{"href":"/us/stat/22/472"},"text":"22 Stat. 472","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b), the words “entitled to pay” and “entitled to the pay”, respectively, are inserted, since rear admiral is one grade with two ranks depending on the amount of pay to which the incumbent is entitled.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “in such grades”, in 10:517 and 34:241a, are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “A commissioned officer of the Army or the Air Force” are substituted for the words “All officers of the Army of the United States, including all components thereof”, since rank among officers of the Regular Army and Regular Air Force is determined under sections 3573, 3574, 8573, and 8574 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida804bed1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida804bed2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" substituted “Marine Corps, and Space Force” for “and Marine Corps” in table."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s924/b/1/G"},"text":"Pub. L. 116–283, § 924(b)(1)(G)","children":[],"tail":", substituted “Marine Corps, and Space Force” for “and Marine Corps” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s924/b/3/M"},"text":"Pub. L. 116–283, § 924(b)(3)(M)","children":[],"tail":", substituted “Marine Corps, or Space Force” for “or Marine Corps” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s924/b/1/G"},"text":"Pub. L. 116–283, § 924(b)(1)(G)","children":[],"tail":", substituted “Marine Corps, and Space Force” for “and Marine Corps” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1626/1"},"text":"Pub. L. 103–337, § 1626(1)","children":[],"tail":". See 1994 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1626/3"},"text":"Pub. L. 103–337, § 1626(3)","children":[],"tail":", inserted at end “The authority to change the date of rank of a reserve officer who is placed on the active-duty list to a later date does not apply in the case of an officer who (A) has served continuously in the Selected Reserve of the Ready Reserve since the officer’s last promotion, or (B) is placed on the active-duty list while on a promotion list as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s14317/b"},"text":"section 14317(b) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1626/2"},"text":"Pub. L. 103–337, § 1626(2)","children":[],"tail":", inserted “or reserve active-status list” after “he is placed on the active-duty list”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1626/1"},"text":"Pub. L. 103–337, § 1626(1)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":", inserted “or who is transferred from an inactive status to an active status and placed on the active-duty list or the reserve active-status list may, effective on the date on which he is placed on the active-duty list” after “warrant officer, W–5,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" substituted “chief warrant officer, W–5,” for “warrant officer (W–4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" substituted “Rear admiral (lower half)” for “Commodore” in table."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" struck out “(Navy) and Rear admiral (upper half) (Coast Guard)” after “Rear admiral” and “(Navy) and Rear admiral (lower half) (Coast Guard)” after “Commodore” in table."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" substituted “the” for “the the” after “uniformly among”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/22/s4/h/4"},"text":"Pub. L. 97–22, § 4(h)(4)","children":[],"tail":", substituted “armed forces” for “Army, Navy, Air Force, and Marine Corps” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/86"},"text":"Pub. L. 97–86","children":[],"tail":" substituted “Commodore” for “Commodore admiral” in right column of table opposite Brigadier general."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/22/s4/h/1"},"text":"Pub. L. 97–22, § 4(h)(1)","children":[],"tail":", inserted reference to the Coast Guard in column heading and inserted references to Rear admiral (upper half) (Coast Guard) and Rear admiral (lower half) (Coast Guard)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/22/s4/h/2"},"text":"Pub. L. 97–22, § 4(h)(2)","children":[],"tail":", inserted “of the Army, Navy, Air Force, and Marine Corps” after “Rank among officers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/22/s4/h/3/A"},"text":"Pub. L. 97–22, § 4(h)(3)(A)","children":[],"tail":", inserted “of the Army, Navy, Air Force, or Marine Corps” after “officer” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/22/s4/h/3/B"},"text":"Pub. L. 97–22, § 4(h)(3)(B)","children":[],"tail":", inserted “of the Army, Navy, Air Force, or Marine Corps” after “(other than a warrant officer)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" completely revised section to restructure and redefine various ranks of commissioned officers of the Army, Air Force, Marine Corps, and Navy and relationships of officers in those ranks among themselves."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida804bed3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida804bed4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s506/c"},"text":"Pub. L. 107–107, div. A, title V, § 506(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1090"},"text":"115 Stat. 1090","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/107/dA/tV/s506/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s741/d"},"text":"section 741(d) of title 10","children":[],"tail":", United States Code, as added by subsection (a), and paragraph (2) of section 14308(c) of such title, as added by subsection (b), shall apply with respect to any report of a selection board recommending officers for promotion to the next higher grade that is submitted to the Secretary of the military department concerned on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the military department concerned may apply the applicable paragraph referred to in paragraph (1) in the case of an appointment of an officer to a higher grade resulting from a report of a selection board submitted to the Secretary before the date of the enactment of this Act if the Secretary determines that such appointment would have been made on an earlier date that is on or after ","children":[{"tag":"date","attrib":{"date":"2001-10-01"},"text":"October 1, 2001","children":[],"tail":", and was delayed under the circumstances specified in paragraph (4) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s741/d"},"text":"section 741(d) of title 10","children":[],"tail":", United States Code, as added by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida804bed5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" effective as if included in the Reserve Officer Personnel Management Act, title XVI of "},{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":", as enacted on "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994",