{"tag":"section","attrib":{"id":"ida804beb8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s741"},"text":null,"children":[{"tag":"num","attrib":{"value":"741"},"text":"§ 741.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rank: commissioned officers of the armed forces","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida804beb9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s741/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Among the grades listed below, the grades of general and admiral are equivalent and are senior to other grades and the grades of second lieutenant and ensign are equivalent and are junior to other grades. Intermediate grades rank in the order listed as follows:","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida804beba-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Army, Air Force, Marine Corps, and Space Force","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Navy and Coast Guard","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"General","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Admiral.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Lieutenant general","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Vice admiral.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Major general","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Rear admiral.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Brigadier general","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Rear admiral (lower half).","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Colonel","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Captain.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Lieutenant colonel","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Commander.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Major","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Lieutenant commander.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Captain","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Lieutenant.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"First lieutenant","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Lieutenant (junior grade).","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Second lieutenant","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Ensign.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida804bebb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s741/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rank among officers of the same grade or of equivalent grades is determined by comparing dates of rank. An officer whose date of rank is earlier than the date of rank of another officer of the same or equivalent grade is senior to that officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida804bebc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s741/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rank among officers of the Army, Navy, Air Force, Marine Corps, and Space Force of the same grade or of equivalent grades who have the same date of rank is determined by regulations prescribed by the Secretary of Defense which shall apply uniformly among the Army, Navy, Air Force, Marine Corps, and Space Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida804bebd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s741/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida804bebe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s741/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The date of rank of an officer of the Army, Navy, Air Force, Marine Corps, or Space Force who holds a grade as the result of an original appointment shall be determined by the Secretary of the military department concerned at the time of such appointment. The date of rank of an officer of the Army, Navy, Air Force, Marine Corps, or Space Force who holds a grade as the result of an original appointment and who at the time of such appointment was awarded service credit for prior commissioned service or constructive credit for advanced education or training, or special experience shall be determined so as to reflect such prior commissioned service or constructive service. Determinations by the Secretary concerned under this paragraph shall be made under regulations prescribed by the Secretary of Defense which shall apply uniformly among the Army, Navy, Air Force, Marine Corps, and Space Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida804bebf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s741/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided by law, the date of rank of an officer who holds a grade as the result of a promotion is the date of his appointment to that grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida804bec0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s741/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed by the Secretary of Defense, which shall apply uniformly among the Army, Navy, Air Force, Marine Corps, and Space Force, the date of rank of a reserve commissioned officer (other than a warrant officer) of the Army, Navy, Air Force, Marine Corps, or Space Force who is to be placed on the active-duty list and who has not been on continuous active duty since his original appointment as a reserve commissioned officer in a grade above chief warrant officer, W–5, or who is transferred from an inactive status to an active status and placed on the active-duty list or the reserve active-status list may, effective on the date on which he is placed on the active-duty list or reserve active-status list, be changed by the Secretary concerned to a later date to reflect such officer’s qualifications and experience. The authority to change the date of rank of a reserve officer who is placed on the active-duty list to a later date does not apply in the case of an officer who (A) has served continuously in the Selected Reserve of the Ready Reserve since the officer’s last promotion, or (B) is placed on the active-duty list while on a promotion list as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14317/b"},"text":"section 14317(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida804bec1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s741/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida804bec2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s741/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary concerned may adjust the date of rank of an officer appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s624/a"},"text":"section 624(a) of this title","children":[],"tail":" to a higher grade that is not a general officer or flag officer grade if the appointment of that officer to that grade is delayed from the date on which (as determined by the Secretary) it would otherwise have been made by reason of unusual circumstances (as determined by the Secretary) that cause an unintended delay in—"}],"tail":null},{"tag":"clause","attrib":{"id":"ida804bec3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s741/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the processing or approval of the report of the selection board recommending the appointment of that officer to that grade; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida804bec4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s741/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the processing or approval of the promotion list established on the basis of that report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida804bec5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s741/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The adjusted date of rank applicable to the grade of an officer under subparagraph (A) shall be consistent—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida804bec6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s741/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the officer’s position on the promotion list for that grade and competitive category when additional officers in that grade and competitive category were needed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida804bec7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s741/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with compliance with the applicable authorized strengths for officers in that grade and competitive category.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida804bec8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s741/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The adjusted date of rank applicable to the grade of an officer under subparagraph (A) shall be the effective date for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida804bec9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s741/d/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer’s pay and allowances for that grade; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida804beca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s741/d/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer’s position on the active-duty list.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida804becb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s741/d/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When under subparagraph (A) the Secretary concerned adjusts the date of rank of an officer in a grade to which the officer was appointed by and with the advice and consent of the Senate and the adjustment is to a date before the date of the advice and consent of the Senate to that appointment, the Secretary shall promptly transmit to the Committee on Armed Services of the Senate a notification of that adjustment. Any such notification shall include the name of the officer and a discussion of the reasons for the adjustment of date of rank.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida804becc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s741/d/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any adjustment in date of rank under this paragraph shall be made under regulations prescribed by the Secretary of Defense, which shall apply uniformly among the Army, Navy, Air Force, Marine Corps, and Space Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida804becd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/33"},"text":"70A Stat. 33","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tI/s107"},"text":"Pub. L. 96–513, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2869"},"text":"94 Stat. 2869","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/22/s4/h"},"text":"Pub. L. 97–22, § 4(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-07-10"},"text":"July 10, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/127"},"text":"95 Stat. 127","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/86/tIV/s405/b/8"},"text":"Pub. L. 97–86, title IV, § 405(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-01"},"text":"Dec. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1106"},"text":"95 Stat. 1106","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s1/11"},"text":"Pub. L. 97–295, § 1(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1289"},"text":"96 Stat. 1289","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s25/c"},"text":"Pub. L