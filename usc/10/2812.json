{"tag":"section","attrib":{"id":"ida9da9070-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2812"},"text":null,"children":[{"tag":"num","attrib":{"value":"2812"},"text":"§ 2812.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease-purchase of facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9da9071-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2812/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da9072-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2812/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may enter into an agreement with a private contractor for the lease of a facility of the kind specified in paragraph (2) if the facility is provided at the expense of the contractor on a military installation under the jurisdiction of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9073-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2812/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The facilities that may be leased pursuant to paragraph (1) are as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da9074-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2812/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Administrative office facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da9075-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2812/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Troop housing facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da9076-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2812/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Energy production facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da9077-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2812/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Utilities, including potable and waste water treatment facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da9078-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2812/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hospital and medical facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da9079-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2812/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transient quarters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da907a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2812/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Depot or storage facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da907b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2812/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Child care centers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da907c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2812/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Classroom and laboratories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da907d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2812/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Leases entered into under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da907e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2812/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not exceed a term of 32 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da907f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2812/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide that, at the end of the term of the lease, title to the leased facility shall vest in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9080-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2812/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include such other terms and conditions as the Secretary concerned determines are necessary or desirable to protect the interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da9081-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2812/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da9082-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2812/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may enter into a lease under this section only after the end of the 14-day period beginning on the date on which the Secretary submits, in an electronic medium pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s480"},"text":"section 480 of this title","children":[],"tail":", to the appropriate committees of Congress a justification of the need for the facility covered by the proposed lease, including an economic analysis (based upon accepted life-cycle costing procedures) that demonstrates the cost effectiveness of the proposed lease compared with a military construction project for the same facility."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9083-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2812/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each Secretary concerned may, under this section, enter into—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da9084-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2812/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than three leases in fiscal year 1990; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da9085-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2812/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than five leases in each of the fiscal years 1991 and 1992.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da9086-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2812/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each lease entered into under this section shall include a provision that the obligation of the United States to make payments under the lease in any fiscal year is subject to the availability of appropriations for that purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9da9087-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dB/tXXVIII/s2809/a"},"text":"Pub. L. 101–189, div. B, title XXVIII, § 2809(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1649"},"text":"103 Stat. 1649","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dB/tXXVIII/s2864"},"text":"Pub. L. 101–510, div. B, title XXVIII, § 2864","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1806"},"text":"104 Stat. 1806","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tX/s1031/a/39"},"text":"Pub. L. 108–136, div. A, title X, § 1031(a)(39)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1601"},"text":"117 Stat. 1601","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dB/tXXVIII/s2801/a/9"},"text":"Pub. L. 115–91, div. B, title XXVIII, § 2801(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1841"},"text":"131 Stat. 1841","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9da9088-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9da9089-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9da908a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" added par. (1) and struck out former par. (1) which set out justification, economic analysis, and wait requirements for entering into a lease."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" inserted before period at end “or, if over sooner, a period of 14 days has expired following the date on which a copy of the justification and economic analysis are provided in an electronic medium pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s480"},"text":"section 480 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(2)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" added subpar. (I)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
