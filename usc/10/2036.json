{"tag":"section","attrib":{"id":"ida925498c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036"},"text":null,"children":[{"tag":"num","attrib":{"value":"2036"},"text":"§ 2036.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to support science, technology, engineering, and mathematics education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida925498d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, in consultation with the Secretary of Education, may carry out a program to make grants to eligible entities to assist such entities in providing education in covered subjects to students in the Junior Reserve Officers’ Training Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida925498e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out a program under subsection (a), the Secretary may coordinate with the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida925498f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9254990-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the National Aeronautics and Space Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9254991-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The heads of such other Federal, State, and local government entities the Secretary of Defense determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9254992-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities funded with grants under this section may include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9254993-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training and other support for instructors to teach courses in covered subjects to students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9254994-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The acquisition of materials, hardware, and software necessary for the instruction of covered subjects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9254995-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Activities that improve the quality of educational materials, training opportunities, and curricula available to students and instructors in covered subjects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9254996-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development of travel opportunities, demonstrations, mentoring programs, and informal education in covered subjects for students and instructors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9254997-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Students’ pursuit of certifications in covered subjects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9254998-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preference","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In making any grants under this section, the Secretary shall give preference to eligible entities that are eligible for assistance under part A of title I of the Elementary and Secondary Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311"},"text":"20 U.S.C. 6311","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9254999-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evaluations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out a program under this section, the Secretary shall establish outcome-based metrics and internal and external assessments to evaluate the merits and benefits of the activities funded with grants under this section with respect to the needs of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida925499a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out a program under this section, the Secretary shall, to the extent practicable, make use of the authorities under chapter 111 and sections 2601 and 2605 of this title, and other authorities the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida925499b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida925499c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “eligible entity” means a local education agency that hosts a unit of the Junior Reserve Officers’ Training Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida925499d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered subjects” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida925499e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" science;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida925499f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92549a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92549a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mathematics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92549a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/g/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" computer science;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92549a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/g/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" computational thinking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92549a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/g/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" artificial intelligence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92549a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/g/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" machine learning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92549a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/g/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data science;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92549a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/g/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quantum information sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92549a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/g/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cybersecurity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92549a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/g/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" robotics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92549aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/g/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health sciences; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92549ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2036/g/2/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other subjects determined by the Secretary of Defense to be related to science, technology, engineering, and mathematics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida92549ac-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tV/s513/a/1"},"text":"Pub. L. 116–283, div. A, title V, § 513(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3587"},"text":"134 Stat. 3587","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tV/s511"},"text":"Pub. L. 117–81, div. A, title V, § 511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1682"},"text":"135 Stat. 1682","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida92549ad-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida92549ae-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida92549af-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Elementary and Secondary Education Act of 1965, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-04-11"},"text":"Apr. 11, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/27"},"text":"79 Stat. 27","children":[],"tail":". Part A of title I of the Act is classified generally to part A (§ 6311 et seq.) of subchapter I of chapter 70 of Title 20, Education. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida92549b0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (g)(2)(J) to (N). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" added subpar. (J) and redesignated former subpars. (J) to (M) as (K) to (N), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
