"},{"tag":"html:a","attrib":{"href":"/us/stat/45/1430"},"text":"45 Stat. 1430","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1951-10-31/ch654/s2/21"},"text":"Oct. 31, 1951, ch. 654, § 2(21)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/65/707"},"text":"65 Stat. 707","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “give” is substituted for the words “dispose of without charge”; the words “naval purposes” are substituted for the words “the Navy”; and the word “sell” is substituted for the words “dispose of * * * at prices”. The words “to the Navy” are omitted as surplusage. Since the corporate name of the organization is “Boy Scouts of America”, that name is used to designate the transferee in lieu of words “sea scout department”, and the words “for the sea scouts” are added.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab49b167-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab49b168-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7541"},"text":"section 7541 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s121"},"text":"section 121 of title 40","children":[],"tail":"” for “section 205 of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s486"},"text":"40 U.S.C. 486","children":[],"tail":")” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “section 205 of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s486"},"text":"40 U.S.C. 486","children":[],"tail":")” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s486"},"text":"section 486 of title 40","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/628"},"text":"Pub. L. 93–628","children":[],"tail":" inserted “Naval Sea Cadet Corps and Young Marines of the Marine Corps League” in section catchline, and authorized the Secretary of the Navy to gift obsolete materials and to sell surplus materials to the Naval Sea Cadet Corps and the Young Marines of the Marine Corps League with the requirement that the cost of transportation and delivery of such materials be charged to the recipient."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab49b169-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab49b16a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},