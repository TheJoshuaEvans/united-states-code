{"tag":"section","attrib":{"id":"ida8000407-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s703"},"text":null,"children":[{"tag":"num","attrib":{"value":"703"},"text":"§ 703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reenlistment leave","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8000408-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Leave for not more than 90 days may be authorized, in the discretion of the Secretary concerned, or his designated representative, to a member of an armed force who reenlists. Leave authorized under this section shall be deducted from leave accrued during active service before reenlistment or charged against leave that may accrue during future active service, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8000409-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under regulations prescribed by the Secretary of Defense, and notwithstanding subsection (a), a member who is on active duty in an area described in section 310(a)(2) or paragraph (1) or (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s351/a"},"text":"section 351(a) of title 37","children":[],"tail":" and who, by reenlistment, extension of enlistment, or other voluntary action, extends his required tour of duty in that area for at least six months may be—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida800040a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s703/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized not more than thirty days of leave, exclusive of travel time, at an authorized place selected by the member; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida800040b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s703/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transported at the expense of the United States to and from that place.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Leave under this subsection may not be charged or credited to leave that accrued or that may accrue under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s701"},"text":"section 701 of this title","children":[],"tail":". The provisions of this subsection shall be effective only in the case of members who extend their required tours of duty on or before "},{"tag":"date","attrib":{"date":"1973-06-30"},"text":"June 30, 1973","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida800040c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649/s3/1"},"text":"Pub. L. 87–649, § 3(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/493"},"text":"76 Stat. 493","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/735"},"text":"Pub. L. 89–735","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1163"},"text":"80 Stat. 1163","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/330"},"text":"Pub. L. 90–330","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-06-05"},"text":"June 5, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/170"},"text":"82 Stat. 170","children":[],