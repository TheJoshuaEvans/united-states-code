 833(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1843"},"text":"111 Stat. 1843","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVIII/s802/b/2"},"text":"Pub. L. 109–163, div. A, title VIII, § 802(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3368"},"text":"119 Stat. 3368","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VIII, § 811(c)(4), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4523"},"text":"122 Stat. 4523","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa759850-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1850/g/1"},"text":"Pub. L. 116–283, § 1850(g)(1)","children":[],"tail":", transferred subsec. (d) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2433"},"text":"section 2433 of this title","children":[],"tail":" to this section, struck out subsec. designation, and redesignated pars. (1) to (3) as subsecs. (a) to (c), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1850/g/2"},"text":"Pub. L. 116–283, § 1850(g)(2)","children":[],"tail":", inserted heading and substituted “under this chapter” for “under this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1850/g/3"},"text":"Pub. L. 116–283, § 1850(g)(3)","children":[],"tail":", inserted heading and substituted “under this chapter” for “under this section” and “subsection (a)” for “paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1850/g/4/B"},"text":"Pub. L. 116–283, § 1850(g)(4)(B)","children":[],"tail":", which directed amendment of subsec. (c) by designating second sentence as par. (2) and fourth sentence as par. (3), was executed by designating second and third sentences as par. (2) and fourth sentence as par. (3) to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1850/g/4/A"},"text":"Pub. L. 116–283, § 1850(g)(4)(A)","children":[],"tail":", inserted subsec. heading, designated first sentence as par. (1) and inserted par. heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1850/g/4/C"},"text":"Pub. L. 116–283, § 1850(g)(4)(C)","children":[],"tail":", inserted heading and substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4372"},"text":"section 4372 of this title","children":[],"tail":"” for “subsection (b)” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4373"},"text":"section 4373 of this title","children":[],"tail":"” for “subsection (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1850/g/4/D"},"text":"Pub. L. 116–283, § 1850(g)(4)(D)","children":[],"tail":", inserted heading."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa759851-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa759852-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as an Effective Date of 2021 Amendment note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
