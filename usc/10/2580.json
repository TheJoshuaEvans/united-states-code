{"tag":"section","attrib":{"id":"ida98e4529-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2580"},"text":null,"children":[{"tag":"num","attrib":{"value":"2580"},"text":"§ 2580.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donation of excess chapel property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida98e452a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2580/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Donate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of a military department may donate personal property specified in subsection (b) to an organization described in section 501(c)(3) of the Internal Revenue Code of 1986 that is a religious organization in order to assist the organization in restoring or replacing property of the organization that has been damaged or destroyed as a result of an act of arson or terrorism, as determined pursuant to procedures prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida98e452b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2580/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Property Covered","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida98e452c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2580/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The property authorized to be donated under subsection (a) is furniture and other personal property that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida98e452d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2580/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in, or was formerly in, a chapel under the jurisdiction of the Secretary of a military department and closed or being closed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida98e452e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2580/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined by the Secretary to be excess to the requirements of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida98e452f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2580/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No real property may be donated under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida98e4530-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2580/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Donees Not To Be Charged","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No charge may be imposed by the Secretary of a military department on a donee of property under this section in connection with the donation. However, the donee shall agree to defray any expense for shipping or other transportation of property donated under this section from the location of the property when donated to any other location.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida98e4531-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1063/a"},"text":"Pub. L. 105–85, div. A, title X, § 1063(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1892"},"text":"111 Stat. 1892","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida98e4532-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida98e4533-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida98e4534-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 501(c)(3) of the Internal Revenue Code of 1986, referred to in subsec. (a), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
