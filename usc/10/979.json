{"tag":"section","attrib":{"id":"ida840683f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s979"},"text":null,"children":[{"tag":"num","attrib":{"value":"979"},"text":"§ 979.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on loan and grant assistance to persons convicted of certain crimes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds appropriated to the Department of Defense may not be used to provide a loan, a guarantee of a loan, or a grant to any person who has been convicted by a court of general jurisdiction of any crime which involves the use of (or assisting others in the use of) force, trespass, or the seizure of property under the control of an institution of higher education to prevent officials or students of the institution from engaging in their duties or pursuing their studies.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida8406840-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXIV/s1401/c/1"},"text":"Pub. L. 98–525, title XIV, § 1401(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2615"},"text":"98 Stat. 2615","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8406841-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8406842-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida8406843-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","c