{"tag":"section","attrib":{"id":"ida919630d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1800"},"text":null,"children":[{"tag":"num","attrib":{"value":"1800"},"text":"§ 1800.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida919630e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1800/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “military child development center” means a facility on a military installation (or on property under the jurisdiction of the commander of a military installation) at which child care services are provided for members of the armed forces or any other facility at which such child care services are provided that is operated by the Secretary of a military department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida919630f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1800/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “family home day care” means home-based child care services that are provided for members of the armed forces by an individual who (A) is certified by the Secretary of the military department concerned as qualified to provide those services, and (B) provides those services on a regular basis for compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9196310-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1800/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “child care employee” means a civilian employee of the Department of Defense who is employed to work in a military child development center (regardless of whether the employee is paid from appropriated funds or nonappropriated funds).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9196311-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1800/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “child care fee receipts” means those nonappropriated funds that are derived from fees paid by members of the armed forces for child care services provided at military child development centers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9196312-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s568/a/1"},"text":"Pub. L. 104–106, div. A, title V, § 568(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/335"},"text":"110 Stat. 335","children":[],"tail":", § 1798; renumbered § 1800, "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s584/a/1/A"},"text":"Pub. L. 106–65, div. A, title V, § 584(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/634"},"text":"113 Stat. 634","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9196313-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9196314-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9196315-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1798"},"text":"section 1798 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
