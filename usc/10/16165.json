{"tag":"section","attrib":{"id":"idabc10325-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16165"},"text":null,"children":[{"tag":"num","attrib":{"value":"16165"},"text":"§ 16165.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabc10326-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16165/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), educational assistance may not be provided under this chapter, or if being provided under this chapter, shall be terminated—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc10327-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16165/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the member is receiving financial assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2107"},"text":"section 2107 of this title","children":[],"tail":" as a member of the Senior Reserve Officers’ Training Corps program; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc10328-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16165/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the member separates from the Ready Reserve as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s16164/a/1"},"text":"section 16164(a)(1) of this title","children":[],"tail":", or upon completion of the period provided for in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16164/a/2"},"text":"section 16164(a)(2) of this title","children":[],"tail":", as applicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc10329-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16165/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under regulations prescribed by the Secretary of Defense, educational assistance may be provided under this chapter to a member of the Selected Reserve of the Ready Reserve who incurs a break in service in the Selected Reserve if the member continues to serve in the Ready Reserve during and after such break in service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc1032a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s527/a"},"text":"Pub. L. 108–375, div. A, title V, § 527(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1893"},"text":"118 Stat. 1893","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s540/b"},"text":"Pub. L. 109–163, div. A, title V, § 540(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3251"},"text":"119 Stat. 3251","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tV/s530/a/2"},"text":"Pub. L. 110–181, div. A, title V, § 530(a)(2)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/110"},"text":"122 Stat. 110","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabc1032b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabc1032c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabc1032d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s530/a/2"},"text":"Pub. L. 110–181, § 530(a)(2)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “when the member separates from the Ready Reserve, as provided for under section 16164(a)(1) or section 16164(a)(2), as applicable, of this title.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s530/b"},"text":"Pub. L. 110–181, § 530(b)","children":[],"tail":", struck out “of not more than 90 days” after “in the Selected Reserve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, substituted “Except as provided in subsection (b), educational assistance” for “Educational assistance”, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabc1032e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note"