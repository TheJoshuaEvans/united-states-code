{"tag":"section","attrib":{"id":"ida9c9c711-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2733a"},"text":"§ 2733a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical malpractice claims by members of the uniformed services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9c9c712-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Consistent with this section and under such regulations as the Secretary of Defense shall prescribe under subsection (h), the Secretary may allow, settle, and pay a claim against the United States for personal injury or death incident to the service of a member of the uniformed services that was caused by the medical malpractice of a Department of Defense health care provider.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c9c713-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for Claims","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A claim may be allowed, settled, and paid under subsection (a) only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9c9c714-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claim is filed by the member of the uniformed services who is the subject of the medical malpractice claimed, or by an authorized representative on behalf of such member who is deceased or otherwise unable to file the claim due to incapacitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c9c715-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claim is for personal injury or death caused by the negligent or wrongful act or omission of a Department of Defense health care provider in the performance of medical, dental, or related health care functions while such provider was acting within the scope of employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c9c716-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the act or omission constituting medical malpractice occurred in a covered military medical treatment facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c9c717-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claim is presented to the Department in writing within two years after the claim accrues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c9c718-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claim is not allowed to be settled and paid under any other provision of law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c9c719-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claim is substantiated as prescribed in regulations prescribed by the Secretary of Defense under subsection (h).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c9c71a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9c9c71b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Defense is liable for only the portion of compensable injury, loss, or damages attributable to the medical malpractice of a Department of Defense health care provider.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c9c71c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Defense shall not be liable for the attorney fees of a claimant under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c9c71d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of Claims","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9c9c71e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary of Defense determines, pursuant to regulations prescribed by the Secretary under subsection (h), that a claim under this section in excess of $100,000 is meritorious, and the claim is otherwise payable under this section, the Secretary may pay the claimant $100,000 and report any meritorious amount in excess of $100,000 to the Secretary of the Treasury for payment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1304"},"text":"section 1304 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c9c71f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (1), no claim may be paid under this section unless the amount tendered is accepted by the claimant in full satisfaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c9c720-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting Medical Malpractice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after a determination of medical malpractice or the payment of all or part of a claim under this section, the Secretary of Defense shall submit to the Director of the Defense Health Agency a report documenting such determination or payment to be used by the Director for all necessary and appropriate purposes, including medical quality assurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c9c721-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Justification of Denial","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a claim under this section is denied, the Secretary of Defense shall provide the claimant with detailed reasoning justifying the denial of the claim, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9c9c722-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" copies of any written reports prepared by any expert upon which the denial is based, and information regarding the qualifications of each such expert who provided an expert medical opinion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c9c723-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all records and documents relied upon in preparing such written reports, other than medical quality assurance records (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1102"},"text":"section 1102 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c9c724-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expert Medical Opinions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In using an expert medical opinion to evaluate a claim under this section, the Secretary of Defense shall use the opinion of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9c9c725-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who is board-certified in the medical specialty with respect to that claim; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c9c726-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the claim involves medical, dental, or related health care functions for which board certification does not apply, an individual who is a highly qualified expert regarding the relevant medical, dental, or related health care function.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c9c727-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9c9c728-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall prescribe regulations to implement this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c9c729-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Regulations prescribed by the Secretary under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9c9c72a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Policies and procedures to ensure the timely, efficient, and effective processing and administration of claims under this section, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9c9c72b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/h/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the filing, receipt, investigation, and evaluation of a claim;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9c9c72c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/h/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the negotiation, settlement, and payment of a claim;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9c9c72d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/h/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other matters relating to the processing and administration of a claim, including an administrative appeals process, as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9c9c72e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Uniform standards consistent with generally accepted standards used in a majority of States in adjudicating claims under chapter 171 of title 28 (commonly known as the “Federal Tort Claims Act”) to be applied to the evaluation, settlement, and payment of claims under this section without regard to the place of occurrence of the medical malpractice giving rise to the claim or the military department or service of the member of the uniformed services, and without regard to foreign law in the case of claims arising in foreign countries, including uniform standards to be applied to determinations with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9cc382f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/h/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether an act or omission by a Department of Defense health care provider in the context of performing medical, dental, or related health care functions was negligent or wrongful, considering the specific facts and circumstances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9cc3830-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/h/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the personal injury or death of the member was caused by a negligent or wrongful act or omission of a Department of Defense health care provider in the context of performing medical, dental, or related health care functions, considering the specific facts and circumstances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9cc3831-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/h/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements relating to proof of duty, breach of duty, and causation resulting in compensable injury or loss, subject to such exclusions as may be established by the Secretary of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9cc3832-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/h/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" calculation of damages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9cc3833-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other matters as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cc3834-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In order to implement expeditiously the provisions of this section, the Secretary may prescribe the regulations under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9cc3835-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by prescribing an interim final rule; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9cc3836-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than one year after prescribing such interim final rule and considering public comments with respect to such interim final rule, by prescribing a final rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cc3837-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Attorney Fees","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9cc3838-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No attorney shall charge, demand, receive, or collect for services rendered, fees in excess of 20 percent of any claim paid pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cc3839-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any attorney who charges, demands, receives, or collects for services rendered in connection with a claim under this section any amount in excess of the amount allowed under paragraph (1), if recovery be had, shall be fined not more than $2,000, imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cc383a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less frequently than annually until 2028, the Secretary of Defense shall submit to the Committees on Armed Services of the Senate and the House of Representatives a report on claims processed under this section that includes, with respect to the period covered by the report, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9cc383b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of claims processed under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cc383c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average timeline for resolving such claims.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cc383d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The resolution of each such claim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cc383e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of claims that were denied based on the claim not meeting one or more requirement specified in subsection (b) (other than for not being substantiated pursuant to paragraph (6)), disaggregated by each such requirement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cc383f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/j/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other information that the Secretary determines may enhance the effectiveness of the claims process under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cc3840-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9cc3841-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered military medical treatment facility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “covered military medical treatment facility” means a facility described in subsection (b), (c), or (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1073d"},"text":"section 1073d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cc3842-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Department of defense health care provider","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Department of Defense health care provider” means a member of the uniformed services, civilian employee of the Department of Defense, or personal services contractor of the Department (under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1091"},"text":"section 1091 of this title","children":[],"tail":") authorized by the Department to provide health care services and acting within the scope of employment of such individual."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cc3843-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2733a/k/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Member of the uniformed services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “member of the uniformed services” includes a member of a reserve component of the armed forces if the claim by the member under this section is in connection with personal injury or death that occurred while the member was in Federal status.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9cc3844-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVII/s731/a/1"},"text":"Pub. L. 116–92, div. A, title VII, § 731(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1457"},"text":"133 Stat. 1457","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tVII/s713"},"text":"Pub. L. 118–31, div. A, title VII, § 713","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/302"},"text":"137 Stat. 302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVII"},"text":"Pub. L. 118–159, div. A, title VII","children":[],"tail":", §§ 731, 732, "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1955"},"text":"138 Stat. 1955","children":[],"tail":", 1956.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9cc3845-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9cc3846-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9cc3847-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsecs. (a), (b)(6), (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s731/1"},"text":"Pub. L. 118–159, § 731(1)","children":[],"tail":", substituted “subsection (h)” for “subsection (g)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s731/2"},"text":"Pub. L. 118–159, § 731(2)","children":[],"tail":", inserted “, and information regarding the qualifications of each such expert who provided an expert medical opinion” before the semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g) to (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s731/3"},"text":"Pub. L. 118–159, § 731(3)","children":[],"tail":", (4), added subsec. (g) and redesignated former subsecs. (g) and (h) as (h) and (i), respectively. Former subsec. (i) redesignated (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":", §§ 731(3), 732, redesignated subsec. (i) as (j) and amended it generally. Prior to amendment, subsec. related to annual reports."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s731/3"},"text":"Pub. L. 118–159, § 731(3)","children":[],"tail":", redesignated subsec. (j) as (k)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s713/1"},"text":"Pub. L. 118–31, § 713(1)","children":[],"tail":", substituted “subsection (g)” for “subsection (f)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s713/2"},"text":"Pub. L. 118–31, § 713(2)","children":[],"tail":", substituted “subsection (g)” for “subsection (f)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s713/3"},"text":"Pub. L. 118–31, § 713(3)","children":[],"tail":", substituted “subsection (g)” for “subsection (f)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f) to (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s713/4"},"text":"Pub. L. 118–31, § 713(4)","children":[],"tail":", (5), added subsec. (f) and redesignated former subsecs. (f) to (i) as (g) to (j), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9cc3848-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9cc3849-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVII/s731/d"},"text":"Pub. L. 116–92, div. A, title VII, § 731(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1460"},"text":"133 Stat. 1460","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dA/tVII/s731/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2735"},"text":"section 2735 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1304"},"text":"section 1304 of Title 31","children":[],"tail":", Money and Finance] shall apply to any claim filed under section 2733a of such title, as added by subsection (a)(1), on or after "},{"tag":"date","attrib":{"date":"2020-01-01"},"text":"January 1, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any claim filed in calendar year 2020 shall be deemed to be filed within the time period specified in section 2733a(b)(4) of such title, as so added, if it is filed within three years after it accrues.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
