{"tag":"section","attrib":{"id":"idab09739a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8042"},"text":null,"children":[{"tag":"num","attrib":{"value":"8042"},"text":"§ 8042.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Headquarters, Marine Corps: general duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab09739b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8042/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Headquarters, Marine Corps, shall furnish professional assistance to the Secretary, the Under Secretary, and the Assistant Secretaries of the Navy and to the Commandant of the Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab09739c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8042/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under the authority, direction, and control of the Secretary of the Navy, the Headquarters, Marine Corps, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab09739d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8042/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsections (c) and (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8014"},"text":"section 8014 of this title","children":[],"tail":", prepare for such employment of the Marine Corps, and for such recruiting, organizing, supplying, equipping (including research and development), training, servicing, mobilizing, demobilizing, administering, and maintaining of the Marine Corps, as will assist in the execution of any power, duty, or function of the Secretary or the Commandant;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab09739e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8042/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigate and report upon the efficiency of the Marine Corps and its preparation to support military operations by combatant commanders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab09739f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8042/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare detailed instructions for the execution of approved plans and supervise the execution of those plans and instructions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0973a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8042/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as directed by the Secretary or the Commandant, coordinate the action of organizations of the Marine Corps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0973a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8042/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other duties, not otherwise assigned by law, as may be prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab0973a2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s513/b"},"text":"Pub. L. 99–433, title V, § 513(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":