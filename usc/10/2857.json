{"tag":"section","attrib":{"id":"ida9e677da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2857"},"text":null,"children":[{"tag":"num","attrib":{"value":"2857"},"text":"§ 2857.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Window fall prevention devices in military family housing units","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9e677db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2857/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requiring Use of Devices on Certain Windows.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9e677dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2857/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall ensure that if a window in any military family housing unit is described in subsection (c), including a window designed for emergency escape or rescue, the window is equipped with fall prevention devices described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e677dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2857/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective date","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall apply with respect to the following military family housing units:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9e677de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2857/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A unit for which the contract for the construction of the unit is first entered into after ","children":[{"tag":"date","attrib":{"date":"2019-10-01"},"text":"October 1, 2019","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e677df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2857/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other unit which is subject to a whole-house renovation project for which the contract is entered into on or after ","children":[{"tag":"date","attrib":{"date":"2019-10-01"},"text":"October 1, 2019","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e677e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2857/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fall prevention device described","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A fall prevention device is a window screen or guard that complies with applicable standards in ASTM standard F2090–13 (or any successor standard).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e677e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2857/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retrofitting or Replacing Existing Windows.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9e677e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2857/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program to retrofit existing windows","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall carry out a program under which, in military family housing units which are not subject to the requirements of subsection (a), windows which are described in subsection (c), including windows designed for emergency escape or rescue, are retrofitted to be equipped with fall prevention devices described in paragraph (3) of subsection (a) or are replaced with windows which are equipped with fall prevention devices described in such paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e677e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2857/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may carry out the program under this subsection by making grants to private entities to retrofit or replace existing windows, in accordance with such criteria as the Secretary may establish by regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e677e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2857/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of operations funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may carry out the program under this subsection during a fiscal year with amounts made available to the Secretary for family housing operations for such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e677e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2857/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Windows Described","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A window is described in this subsection if the bottom sill of the window is within 42 inches of the floor, as measured in the interior of the unit, and is more than 72 inches above the ground, as measured on the exterior grade of the building.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e677e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2857/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Record of Incidents; Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall keep a record of each incident (as defined in Department of Defense Instruction 6055.7 series) in which a minor child is injured or killed as the result of an unintentional window fall in a military family housing unit. Not later than 90 days after the end of each calendar year (beginning with 2017), the Secretary of Defense shall submit a report to the Committees on Armed Services of the House of Representatives and Senate on all such window falls occurring in the previous year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e677e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2857/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability to All Military Family Housing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section applies to military family housing under the jurisdiction of the Department of Defense and military family housing acquired or constructed under subchapter IV of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9e677e8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dB/tXXVIII/s2817/a/1"},"text":"Pub. L. 115–91, div. B, title XXVIII, § 2817(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1851"},"text":"131 Stat. 1851","children":[],"tail":", § 2879; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tX/s1081/a/28"},"text":"Pub. L. 115–232, div. A, title X, § 1081(a)(28)","children":[],"tail":", div. B, title XXVIII, § 2823(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1985"},"text":"132 Stat. 1985","children":[],"tail":", 2269; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXVII/s1731/a/57"},"text":"Pub. L. 116–92, div. A, title XVII, § 1731(a)(57)","children":[],"tail":", div. B, title XXX, § 3034, "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1815"},"text":"133 Stat. 1815","children":[],"tail":", 1936; renumbered § 2857 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dB/tXXVIII/s2812/a"},"text":"Pub. L. 117–81, div. B, title XXVIII, § 2812(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2191"},"text":"135 Stat. 2191","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9e677e9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9e677ea-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida9e677eb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2857 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2915"},"text":"section 2915 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9e677ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s2812/a"},"text":"Pub. L. 117–81, § 2812(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2879"},"text":"section 2879 of this title","children":[],"tail":" as this section and transferred it to appear after "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2856"},"text":"section 2856 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s2812/b/1"},"text":"Pub. L. 117–81, § 2812(b)(1)","children":[],"tail":", struck out “acquired or constructed under this chapter” after “housing unit”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s2812/b/2"},"text":"Pub. L. 117–81, § 2812(b)(2)","children":[],"tail":", struck out “acquired or constructed under this chapter” after “housing units”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s2812/b/3"},"text":"Pub. L. 117–81, § 2812(b)(3)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3034/a/1"},"text":"Pub. L. 116–92, § 3034(a)(1)","children":[],"tail":", substituted “described in paragraph (3)” for “that protect against unintentional window falls by young children and that are in compliance with applicable International Building Code (IBC) standards”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3034/a/2/A"},"text":"Pub. L. 116–92, § 3034(a)(2)(A)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2019-10-01"},"text":"October 1, 2019","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2017-12-11"},"text":"December 11, 2017","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1731/a/57"},"text":"Pub. L. 116–92, § 1731(a)(57)","children":[],"tail":", struck out comma before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3034/a/2/B"},"text":"Pub. L. 116–92, § 3034(a)(2)(B)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2019-10-01"},"text":"October 1, 2019","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2018-09-01"},"text":"September 1, 2018","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3034/a/3"},"text":"Pub. L. 116–92, § 3034(a)(3)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3034/c"},"text":"Pub. L. 116–92, § 3034(c)","children":[],"tail":", substituted “paragraph (3)” for “paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3034/b"},"text":"Pub. L. 116–92, § 3034(b)","children":[],"tail":", substituted “42 inches” for “24 inches”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s2823/a/1"},"text":"Pub. L. 115–232, § 2823(a)(1)","children":[],"tail":", substituted “subsection (c)” for “subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1081/a/28"},"text":"Pub. L. 115–232, § 1081(a)(28)","children":[],"tail":", substituted “after "},{"tag":"date","attrib":{"date":"2017-12-11"},"text":"December 11, 2017","children":[],"tail":",” for “on or after the date of the enactment of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s2823/a/2"},"text":"Pub. L. 115–232, § 2823(a)(2)","children":[],"tail":", (3), added subsec. (b) and redesignated former subsecs. (b) and (c) as (c) and (d), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9e677ed-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9e677ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dB/tXXVIII/s2823/b"},"text":"Pub. L. 115–232, div. B, title XXVIII, § 2823(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2269"},"text":"132 Stat. 2269","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/232/dB/tXXVIII/s2823/b"},"text":"“The amendments made by this section [amending this section] shall apply with respect to fiscal year 2019 and each succeeding fiscal year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
