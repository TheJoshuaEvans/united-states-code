{"tag":"section","attrib":{"id":"ida960f39e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2277"},"text":null,"children":[{"tag":"num","attrib":{"value":"2277"},"text":"§ 2277.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of National Security Space Launch program contract pricing terms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida960f39f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2277/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to any contract awarded by the Secretary of the Air Force for the launch of a national security payload under the National Security Space Launch program, not later than 30 days after entering into such a contract, the Secretary shall submit to the congressional defense committees a description of the pricing terms of the contract. For those contracts that include the launch of assets of the National Reconnaissance Office, the Secretary shall also submit the pricing terms to the congressional intelligence committees (as defined by section 3 of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"50 U.S.C. 3003","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida960f3a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2277/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Competitively Sensitive Trade Secret Data","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The congressional defense committees and the congressional intelligence committees shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida960f3a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2277/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treat a description of pricing terms submitted under subsection (a) as competitively sensitive trade secret data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f3a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2277/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the description solely for committee purposes, subject to appropriate restrictions to maintain the confidentiality of the description.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida960f3a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2277/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1905"},"text":"section 1905 of title 18","children":[],"tail":", a disclosure of contract pricing terms under subsection (a) shall be construed as a disclosure authorized by law."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida960f3a4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVI/s1601/a/1"},"text":"Pub. L. 117–81, div. A, title XVI, § 1601(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2073"},"text":"135 Stat. 2073","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida960f3a5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida960f3a6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida960f3a7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2277, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tIX/s913/c/1"},"text":"Pub. L. 112–239, div. A, title IX, § 913(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1875"},"text":"126 Stat. 1875","children":[],"tail":", related to report on foreign counter-space programs, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1051/a/13/A"},"text":"Pub. L. 115–91, div. A, title X, § 1051(a)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1561"},"text":"131 Stat. 1561","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2277, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/127"},"text":"70A Stat. 127","children":[],"tail":", related to availability of appropriations, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tVIII/s821/a/1"},"text":"Pub. L. 103–160, div. A, title VIII, § 821(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1704"},"text":"107 Stat. 1704","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
