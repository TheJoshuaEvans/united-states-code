{"tag":"section","attrib":{"id":"idab369df4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8619"},"text":null,"children":[{"tag":"num","attrib":{"value":"8619"},"text":"§ 8619.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leases of waterfront property from States or municipalities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In leasing waterfront property from a State or municipality, the Secretary of the Navy may provide in the lease, where it is required by state law or municipal charter, that, as part or all of the consideration, any improvements placed upon the property by the United States become the property of the lessor when the lease, including any renewal, ends.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab369df5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/446"},"text":"70A Stat. 446","children":[],"tail":", § 7219; renumbered § 8619, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab369df6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab369df7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab369df8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],