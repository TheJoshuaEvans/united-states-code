{"tag":"section","attrib":{"id":"ida984a8db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2491b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2491b"},"text":"§ 2491b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of appropriated funds for operation of Armed Forces Recreation Center, Europe: limitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida984a8dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2491b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), funds appropriated to the Department of Defense may not be used to operate the Armed Forces Recreation Center, Europe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida984a8dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2491b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) does not apply to the use of funds for the payment of utilities, the maintenance, repair, or renovation of real property, and the transportation of products made in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida984a8de-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tIII/s372/a"},"text":"Pub. L. 103–337, div. A, title III, § 372(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2735"},"text