{"tag":"section","attrib":{"id":"idabbe9261-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16135"},"text":null,"children":[{"tag":"num","attrib":{"value":"16135"},"text":"§ 16135.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to participate satisfactorily; penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabbe9262-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16135/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the option of the Secretary concerned, a member of the Selected Reserve of an armed force who does not participate satisfactorily in required training as a member of the Selected Reserve during a term of enlistment or other period of obligated service that created entitlement of the member to educational assistance under this chapter, and during which the member has received such assistance, may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabbe9263-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16135/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be ordered to active duty for a period of two years or the period of obligated service the person has remaining under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s16132"},"text":"section 16132 of this title","children":[],"tail":", whichever is less; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbe9264-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16135/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be subject to the repayment provisions under section 303a(e) or 373 of title 37.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabbe9265-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16135/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any repayment under section 303a(e) or 373 of title 37 shall not affect the period of obligation of a member to serve as a Reserve in the Selected Reserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabbe9266-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/79/tIV/s402/a"},"text":"Pub. L. 95–79, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-07-30"},"text":"July 30, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/330"},"text":"91 Stat. 330","children":[],"tail":", § 2135; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/485/tIV/s402/b"},"text":"Pub. L. 95–485, title IV, § 402(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-20"},"text":"Oct. 20, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1613"},"text":"92 Stat. 1613","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/342/tIX/s906/b"},"text":"Pub. L. 96–342, title IX, § 906(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1117"},"text":"94 Stat. 1117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tVII/s705/a/1"},"text":"Pub. L. 98–525, title VII, § 705(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"