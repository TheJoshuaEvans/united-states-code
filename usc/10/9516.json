{"tag":"section","attrib":{"id":"idab7e2e3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9516"},"text":null,"children":[{"tag":"num","attrib":{"value":"9516"},"text":"§ 9516.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Airlift service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab7e2e3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9516/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interstate Transportation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab7e2e3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9516/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (d) of this section, the transportation of passengers or property by CRAF-eligible aircraft in interstate air transportation obtained by the Secretary of Defense or the Secretary of a military department through a contract for airlift service in the United States may be provided only by an air carrier that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab7e2e3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9516/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has aircraft in the civil reserve air fleet or offers to place the aircraft in that fleet; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab7e2e3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9516/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holds a certificate issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41102"},"text":"section 41102 of title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7e2e40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9516/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation shall act as expeditiously as possible on an application for a certificate under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41102"},"text":"section 41102 of title 49","children":[],"tail":" to provide airlift service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7e2e41-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9516/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation Between the United States and Foreign Locations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (d), the transportation of passengers or property by CRAF-eligible aircraft between a place in the United States and a place outside the United States obtained by the Secretary of Defense or the Secretary of a military department through a contract for airlift service shall be provided by an air carrier referred to in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7e2e42-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9516/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation Between Foreign Locations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The transportation of passengers or property by CRAF-eligible aircraft between two places outside the United States obtained by the Secretary of Defense or the Secretary of a military department through a contract for airlift service shall be provided by an air carrier referred to in subsection (a) whenever transportation by such an air carrier is reasonably available.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7e2e43-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9516/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (e), when the Secretary of Defense decides that no air carrier holding a certificate under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41102"},"text":"section 41102 of title 49","children":[],"tail":" is capable of providing, and willing to provide, the airlift service, the Secretary of Defense may make a contract to provide the service with an air carrier not having a certificate."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7e2e44-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9516/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after the end of each fiscal year, the Secretary shall submit to the Committees on Armed Services of the Senate and the House of Representatives a report that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab7e2e45-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9516/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies each contract for airlift services awarded in the preceding fiscal year to a provider that does not meet the requirements set forth in subparagraphs (A) and (B) of subsection (a)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7e2e46-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9516/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each such contract—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab7e2e47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9516/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifies the dollar value of the award; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab7e2e48-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9516/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides a detailed explanation of the reasons for the award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7e2e49-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9516/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"CRAF-eligible Aircraft Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, “CRAF-eligible aircraft” means aircraft of a type the Secretary of Defense has determined to be eligible to participate in the civil reserve air fleet.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab7e2e4a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1042/a"},"text":"Pub. L. 113–291, div. A, title X, § 1042(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3492"},"text":"128 Stat. 3492","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tX/s1083/b"},"text":"Pub. L. 117–81, div. A, title X, § 1083(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1922"},"text":"135 Stat. 1922","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab7e2e4b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab7e2e4c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab7e2e4d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1083/b/1"},"text":"Pub. L. 117–81, § 1083(b)(1)","children":[],"tail":", substituted “Subject to subsection (e), when the Secretary” for “When the Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1083/b/2"},"text":"Pub. L. 117–81, § 1083(b)(2)","children":[],"tail":", (3), added subsec. (e) and redesignated former subsec. (e) as (f)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
