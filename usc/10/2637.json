{"tag":"section","attrib":{"id":"ida995712d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2637"},"text":null,"children":[{"tag":"num","attrib":{"value":"2637"},"text":"§ 2637.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation in certain areas outside the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense may authorize the commander of a unified combatant command to use Government owned or leased vehicles to provide transportation in an area outside the United States for members of the uniformed services and Federal civilian employees under the jurisdiction of that commander, and for the dependents of such members and employees, if the commander determines that public or private transportation in such area is unsafe or not available. Such transportation shall be provided in accordance with regulations prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida995712e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tIII/s326/a/1"},"text":"Pub. L. 101–510, div. A, title III, § 326(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1531"},"text":"104 Stat. 1531","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida995712f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9957130-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida9957131-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2637, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tVI/s614/a"},"text":"Pub. L. 98–525, title VI, § 614(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2540"},"text":"98 Stat. 2540","children":[],"tail":", related to use of passenger motor vehicles of United States for transportation between residences and places of work of senior defense officials, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/550/s2/a/1"},"text":"Pub. L. 99–550, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3070"},"text":"100 Stat. 3070","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
