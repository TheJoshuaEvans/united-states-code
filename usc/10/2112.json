{"tag":"section","attrib":{"id":"ida92a04db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2112"},"text":null,"children":[{"tag":"num","attrib":{"value":"2112"},"text":"§ 2112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida92a04dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida92a04dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2112/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established a Uniformed Services University of the Health Sciences (in this chapter referred to as the “University”) with authority to grant appropriate certificates, certifications, undergraduate degrees, and advanced degrees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92a04de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2112/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The University shall be so organized as to graduate not fewer than 100 medical students annually.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92a04df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2112/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The headquarters of the University shall be at a site or sites selected by the Secretary of Defense within 25 miles of the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92a04e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (a), the numbers of persons to be graduated from the University shall be prescribed by the Secretary of Defense. In so prescribing the number of persons to be graduated from the University, the Secretary of Defense shall institute actions necessary to ensure the maximum number of first-year enrollments in the University consistent with the academic capacity of the University and the needs of the uniformed services for medical personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92a04e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2112/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The development of the University may be by such phases as the Secretary of Defense may prescribe subject to the requirements of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida92a04e2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/426/s2/a"},"text":"Pub. L. 92–426, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-21"},"text":"Sept. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/713"},"text":"86 Stat. 713","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/107/tVIII/s803/a"},"text":"Pub. L. 96–107, title VIII, § 803(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-09"},"text":"Nov. 9, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/811"},"text":"93 Stat. 811","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s511/63"},"text":"Pub. L. 96–513, title V, § 511(63)","children":[],"tail":", (64), "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2925"},"text":"94 Stat. 2925","children":[],"tail":", 2926; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tX/s1072/b/1"},"text":"Pub. L. 104–106, div. A, title X, § 1072(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/446"},"text":"110 Stat. 446","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/e/8"},"text":"Pub. L. 107–107, div. A, title X, § 1048(e)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1228"},"text":"115 Stat. 1228","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVII/s724/a"},"text":"Pub. L. 114–328, div. A, title VII, § 724(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2230"},"text":"130 Stat. 2230","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida92a04e3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida92a04e4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida92a04e5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “There is hereby authorized to be established within 25 miles of the District of Columbia a Uniformed Services University of the Health Sciences (hereinafter in this chapter referred to as the ‘University’), at a site or sites to be selected by the Secretary of Defense, with authority to grant appropriate advanced degrees. It shall be so organized as to graduate not less than 100 medical students annually.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" struck out “, with the first class graduating not later than "},{"tag":"date","attrib":{"date":"1982-09-21"},"text":"September 21, 1982","children":[],"tail":"” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" struck out “, upon recommendation of the Board of Regents,” before “institute actions necessary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" inserted “in this chapter” after “hereinafter”, and substituted “"},{"tag":"date","attrib":{"date":"1982-09-21"},"text":"September 21, 1982","children":[],"tail":"” for “10 years after the date of the enactment of this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/107"},"text":"Pub. L. 96–107","children":[],"tail":" inserted provisions respecting the maximum number of first-year enrollments in the University."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida92a04e6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida92a04e7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/b/3"},"text":"section 701(b)(3) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"ida92a04e8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/426/s1"},"text":"Pub. L. 92–426, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-21"},"text":"Sept. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/713"},"text":"86 Stat. 713","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/92/426/s1"},"text":"“That this Act [enacting this chapter and chapter 105 of this title] may be cited as the ‘Uniformed Services Health Professions Revitalization Act of 1972’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"ida92a04e9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authority of Board of Regents of Uniformed Services University of the Health Sciences to Secretary of Defense, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/511/s8091"},"text":"section 8091 of Pub. L. 101–511","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2113"},"text":"section 2113 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida92a04ea-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Temporary Exemption for Uniformed Services University of the Health Sciences From Certain Paperwork Reduction Act Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVII/s716/a"},"text":"Pub. L. 116–283, div. A, title VII, § 716(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3694"},"text":"134 Stat. 3694","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dA/tVII/s716/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Temporary Exemption From Certain Paperwork Reduction Act Requirements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the two-year period beginning on the date that is 30 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"], the requirements described in paragraph (2) shall not apply with respect to the voluntary collection of information during the conduct of research and program evaluations—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducted or sponsored by the Uniformed Services University of the Health Sciences; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funded through the Defense Health Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements described in this paragraph are the requirements under the following provisions of law:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3506/c"},"text":"Section 3506(c) of title 44","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 3507 and 3508 of such title.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida92a04eb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continuation of Uniformed Services University of the Health Sciences","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tX/s1071"},"text":"Pub. L. 104–106, div. A, title X, § 1071","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/445"},"text":"110 Stat. 445","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tIX/s907/b/2"},"text":"Pub. L. 104–201, div. A, title IX, § 907(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2620"},"text":"110 Stat. 2620","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/201/dA/tIX/s907/b/2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress reaffirms—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prohibition set forth in subsection (a) of section 922 of the National Defense Authorization Act for Fiscal Year 1995 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Public Law 103–337","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/108/2829"},"text":"108 Stat. 2829","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2112"},"text":"10 U.S.C. 2112","children":[],"tail":" note) regarding closure of the Uniformed Services University of the Health Sciences; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expression of the sense of Congress set forth in subsection (b) of such section regarding the budgetary commitment to continuation of the University.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"status":"repealed"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“[(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tIX/s907/b/2"},"text":"Pub. L. 104–201, div. A, title IX, § 907(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2620"},"text":"110 Stat. 2620","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Budgetary Commitment to Continuation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is the sense of Congress that the Secretary of Defense should budget for the operation of the Uniformed Services University of the Health Sciences during fiscal year 1997 at a level at least equal to the level of operations conducted at the University during fiscal year 1995.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tIX/s922"},"text":"Pub. L. 103–337, div. A, title IX, § 922","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2829"},"text":"108 Stat. 2829","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tIX/s907/b/1"},"text":"Pub. L. 104–201, div. A, title IX, § 907(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2620"},"text":"110 Stat. 2620","children":[],"tail":", provided that:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[(a) Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tIX/s907/b/1"},"text":"Pub. L. 104–201, div. A, title IX, § 907(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2620"},"text":"110 Stat. 2620","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2112a"},"text":"section 2112a of this title","children":[],"tail":".]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Budgetary Commitment to Continuation","children":[],"tail":".—It is the sense of Congress that the Secretary of Defense should budget for the ongoing operation of the Uniformed Services University of the Health Sciences as an institution of professional education that is vital to the education and training each year of significant numbers of personnel of the uniformed services for careers as uniformed services health care providers."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) ","children":[{"tag":"inline","attrib":{},"text":"GAO Evaluation","children":[],"tail":".—Not later than "},{"tag":"date","attrib":{"date":"1995-06-01"},"text":"June 1, 1995","children":[],"tail":", the Comptroller General of the United States shall submit to Congress a detailed report on the Uniformed Services University of the Health Sciences. The report shall include the following:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) A comparison of the cost of obtaining physicians for the Armed Forces from the University with the cost of obtaining physicians from other sources.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) An assessment of the retention rate needs of the Armed Forces for physicians in relation to the respective retention rates of physicians obtained from the University and physicians obtained from other sources and the factors that contribute to retention rates among military physicians obtained from all sources.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) A review of the quality of the medical education provided at the University with the quality of medical education provided by other sources of military physicians.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) A review of the overall issue of the special needs of military medicine and how those special needs are being met by physicians obtained from University and physicians obtained from other sources.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) An assessment of the extent to which the University has responded to the 1990 report of the Inspector General of the Department of Defense, including recommendations as to resolution of any continuing issues relating to management and internal fiscal controls of the University, including issues relating to the Henry M. Jackson Foundation for the Advancement of Military Medicine identified in the 1990 report.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) Such other recommendations as the Comptroller General considers appropriate.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida92a04ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"F. Edward Hébert School of Medicine","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/tXII/s1265"},"text":"Pub. L. 98–94, title XII, § 1265","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/704"},"text":"97 Stat. 704","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/94/tXII/s1265"},"text":"“The School of Medicine of the Uniformed Services University of the Health Sciences shall after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":"] be known and designated as the ‘F. Edward Hébert School of Medicine’. Any reference to such school of medicine in any law, regulation, map, document, or other record of the United States shall after such date be deemed to be a reference to such school of medicine as the F. Edward Hébert School of Medicine.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
