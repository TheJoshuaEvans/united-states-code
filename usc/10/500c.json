{"tag":"section","attrib":{"id":"ida7cb866f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500c"},"text":null,"children":[{"tag":"num","attrib":{"value":"500c"},"text":"§ 500c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual assessment of budget with respect to electromagnetic spectrum operations capabilities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"At the same time as the President submits to Congress the budget of the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":" for each of fiscal years 2025 through 2029, the Secretary of Defense shall submit to the congressional defense committees an assessment by the Electromagnetic Spectrum Operations Executive Committee as to whether sufficient funds are requested in such budget for anticipated activities in such fiscal year for each of the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7cb8670-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The development of an electromagnetic battle management capability for joint electromagnetic spectrum operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb8671-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The establishment and operation of associated joint electromagnetic spectrum operations cells.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb8672-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The development of a capability for modeling and simulating multi-domain joint electromagnetic spectrum operations to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7cb8673-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the ability of the joint force to conduct such operations in support of the operational plans of the combatant commands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb8674-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform improvements to such operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7cb8675-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVI/s1682/a"},"text":"Pub. L. 118–31, div. A, title XVI, § 1682(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/615"},"text":"137 Stat. 615","children":[],"tail":", § 503; renumbered § 500c and amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1653"},"text":"Pub. L. 118–159, div. A, title XVI, § 1653","children":[],"tail":", title XVII, § 1701(a)(10), "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2201"},"text":"138 Stat. 2201","children":[],"tail":", 2203.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7cb8676-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7cb8677-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7cb8678-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1701/a/10"},"text":"Pub. L. 118–159, § 1701(a)(10)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s503"},"text":"section 503 of this title","children":[],"tail":", relating to the annual assessment of the budget with respect to electromagnetic spectrum operations capabilities, as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1653"},"text":"Pub. L. 118–159, § 1653","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
