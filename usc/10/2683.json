{"tag":"section","attrib":{"id":"ida9a883c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2683"},"text":null,"children":[{"tag":"num","attrib":{"value":"2683"},"text":"§ 2683.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relinquishment of legislative jurisdiction; minimum drinking age on military installations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9a883c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2683/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, the Secretary concerned may, whenever he considers it desirable, relinquish to a State, or to a Commonwealth, territory, or possession of the United States, all or part of the legislative jurisdiction of the United States over lands or interests under his control in that State, Commonwealth, territory, or possession. Relinquishment of legislative jurisdiction under this section may be accomplished (1) by filing with the Governor (or, if none exists, with the chief executive officer) of the State, Commonwealth, territory, or possession concerned a notice of relinquishment to take effect upon acceptance thereof, or (2) as the laws of the State, Commonwealth, territory, or possession may otherwise provide.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9a883c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2683/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority granted by subsection (a) is in addition to and not instead of that granted by any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9a883ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2683/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9a883cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2683/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraphs (2) and (3), the Secretary concerned shall establish and enforce as the minimum drinking age on a military installation located in a State the age established by the law of that State as the State minimum drinking age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a883cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2683/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9a883cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2683/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a military installation located—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9a883ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2683/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in more than one State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9a883cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2683/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in one State but within 50 miles of another State or Mexico or Canada,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary concerned may establish and enforce as the minimum drinking age on that military installation the lowest applicable age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9a883d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2683/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In subparagraph (A), the term “lowest applicable age” means the lowest minimum drinking age established by the law—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9a883d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2683/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of a State in which a military installation is located; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9a883d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2683/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of a State or jurisdiction of Mexico or Canada that is within 50 miles of such military installation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a883d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2683/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9a883d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2683/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The commanding officer of a military installation may waive the requirement of paragraph (1) if such commanding officer determines that the exemption is justified by special circumstances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9a883d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2683/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall define by regulations what constitute special circumstances for the purposes of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a883d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2683/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9a883d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2683/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” includes the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9a883d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2683/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “minimum drinking age” means the minimum age or ages established for persons who may purchase, possess, or consume alcoholic beverages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9a883d9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/511/tVI/s613/1"},"text":"Pub. L. 91–511, title VI, § 613(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1226"},"text":"84 Stat. 1226","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/92/545/tVIII/s707"},"text":"Pub. L. 92–545, title VIII, § 707","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-25"},"text":"Oct. 25, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1154"},"text":"86 Stat. 1154","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/283/s3"},"text":"Pub. L. 93–283, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-14"},"text":"May 14, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/141"},"text":"88 Stat. 141","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXII/s1224/a"},"text":"Pub. L. 99–145, title XII, § 1224(a)","children":[],"tail":", (b)(1), (c)(1), "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/728"},"text":"99 Stat. 728","children":[],"tail":", 729; "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tXIII/s1343/a/18"},"text":"Pub. L. 99–661, div. A, title XIII, § 1343(a)(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3993"},"text":"100 Stat. 3993","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/526/tI/s106/b/2"},"text":"Pub. L. 100–526, title I, § 106(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-24"},"text":"Oct. 24, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2625"},"text":"102 Stat. 2625","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9a883da-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9a883db-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9a883dc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/526/s106/b/2/A"},"text":"Pub. L. 100–526, § 106(b)(2)(A)","children":[],"tail":", substituted “the term ‘lowest applicable age’ ” for “ ‘lowest age’ ”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/526/s106/b/2/B/i"},"text":"Pub. L. 100–526, § 106(b)(2)(B)(i)","children":[],"tail":", substituted “The term ‘State’ ” for “ ‘State’ ”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/526/s106/b/2/B/ii"},"text":"Pub. L. 100–526, § 106(b)(2)(B)(ii)","children":[],"tail":", substituted “The term ‘minimum’ ” for “ ‘Minimum’ ”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" struck out “this” before “subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/s1224/c/1"},"text":"Pub. L. 99–145, § 1224(c)(1)","children":[],"tail":", inserted “; minimum drinking age on military installations” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/s1224/b/1"},"text":"Pub. L. 99–145, § 1224(b)(1)","children":[],"tail":", substituted “subsection (a)” for “section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/s1224/a"},"text":"Pub. L. 99–145, § 1224(a)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/283"},"text":"Pub. L. 93–283","children":[],"tail":" substituted “Secretary concerned” for “Secretary of a military department”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/545"},"text":"Pub. L. 92–545","children":[],"tail":" provided for relinquishment of all or part of legislative jurisdiction of the United States over lands or interests to Commonwealths, territories, or possessions of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9a883dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9a883de-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXII/s1224/d"},"text":"Pub. L. 99–145, title XII, § 1224(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/729"},"text":"99 Stat. 729","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/145/tXII/s1224/d"},"text":"“The amendments made by this section [amending this section and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s113"},"text":"section 113 of this title","children":[],"tail":"] shall take effect 90 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
