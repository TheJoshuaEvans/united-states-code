{"tag":"section","attrib":{"id":"idaaef3500-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7446"},"text":null,"children":[{"tag":"num","attrib":{"value":"7446"},"text":"§ 7446.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cadets: requirements for admission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaef3501-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7446/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be eligible for admission to the Academy a candidate must be at least 17 years of age and must not have passed his twenty-third birthday on July 1 of the year in which he enters the Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaef3502-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7446/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be admitted to the Academy, an appointee must show, by an examination held under regulations prescribed by the Secretary of the Army, that he is qualified in the subjects prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaef3503-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7446/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A candidate designated as a principal or an alternate for appointment as a cadet shall appear for physical examination at a time and place designated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaef3504-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7446/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be admitted to the Academy, an appointee must take and subscribe to the following oath—","children":[{"tag":"p","attrib":{"role":"listItem"},"text":"“I, ____________, do solemnly swear that I will support the Constitution of the United States, and bear true allegiance to the National Government; that I will maintain and defend the sovereignty of the United States, paramount to any and all allegiance, sovereignty, or fealty I may owe to any State or country whatsoever; and that I will at all times obey the legal orders of my superior officers, and the Uniform Code of Military Justice.”","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"If a candidate for admission refuses to take this oath, his appointment is terminated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaef3505-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/242"},"text":"70A Stat. 242","children":[],"tail":", § 4346; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s555/b"},"text":"Pub. L. 104–201, div. A, title V, § 555(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2527"},"text":"110 Stat. 2527","children":[],"tail":"; renumbered § 7446, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/c/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaef3506-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaaef3507-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaaef3508-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4346(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4346(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4346(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1092b (less provisos).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1096.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1095.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-06-30/ch421/s2"},"text":"June 30, 1950, ch. 421, § 2","children":[],"tail":" (less provisos), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/304"},"text":"64 Stat. 304","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4346(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1099.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 1319; restated ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1901-03-02/ch804"},"text":"Mar. 2, 1901, ch. 804","children":[],"tail":" (1st proviso under “Permanent Establishment”), "},{"tag":"html:a","attrib":{"href":"/us/stat/31/911"},"text":"31 Stat. 911","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1912-08-09/ch275"},"text":"Aug. 9, 1912, ch. 275","children":[],"tail":" (2d proviso under “Permanent Establishment”), "},{"tag":"html:a","attrib":{"href":"/us/stat/37/252"},"text":"37 Stat. 252","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":"R.S. 1320.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Effective ","children":[{"tag":"date","attrib":{"date":"1951-01-01"},"text":"January 1, 1951","children":[],"tail":"” are omitted as executed. The word “Calendar” is omitted as surplusage. The words “must not have passed his twenty-second birthday” are substituted for the words “not more than twenty-two years of age”, to make it clear that a person whose twenty-second birthday falls on July 1 of the year of admission is eligible (see opinion of the Judge Advocate General of the Army (JAGA 1952/7083, 2 Sept. 1952))."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “To be” are substituted for the words “before they shall be”. The words “must show * * * that he is qualified” are substituted for the words “shall be required to be well versed”. The words “from time to time” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “shall” is substituted for the word “may”, since the nominee is required to appear for the examination. The word “appear” is substituted for the words “present himself”. The words “at a place” are substituted for the words “at West Point, New York, or other prescribed places”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the word “county” is omitted as surplusage. The words “Uniform Code of Military Justice” are substituted for the words “rules and articles governing the armies of the United States”, since the Articles of War have been superseded by the Uniform Code of Military Justice. The words “his appointment is terminated” are substituted for the words “shall be dismissed from the service”, since a cadet who has not taken the oath is not yet a member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaef3509-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaaef350a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4346"},"text":"section 4346 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" substituted “twenty-third birthday” for “twenty-second birthday”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaaef350b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaaef350c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaaef350d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Consideration of Standardized Test Scores in Military Service Academy Application Process","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tV/s563"},"text":"Pub. L. 118–31, div. A, title V, § 563","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/274"},"text":"137 Stat. 274","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dA/tV/s563"},"text":"“The Secretary of Defense shall ensure that the United States Military Academy, the United States Naval Academy, and the United States Air Force Academy require the submission and consideration of standardized test scores as part of the application process.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaaef350e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Temporary Authority To Waive Maximum Age Limitation on Admission to the Military Service Academies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s553"},"text":"Pub. L. 112–81, div. A, title V, § 553","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1413"},"text":"125 Stat. 1413","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tX/s1072/b"},"text":"Pub. L. 114–92, div. A, title X, § 1072(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/995"},"text":"129 Stat. 995","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/92/dA/tX/s1072/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver for Certain Enlisted Members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the military department concerned may waive the maximum age limitation specified in section 4346(a), 6958(a)(1), or 9346(a) [now 7446(a), 8458(a)(1), or 9446(a)] of title 10, United States Code, for the admission of an enlisted member of the Armed Forces to the United States Military Academy, the United States Naval Academy, or the United States Air Force Academy if the member—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfies the eligibility requirements for admission to that academy (other than the maximum age limitation); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was or is prevented from being admitted to a military service academy before the member reached the maximum age specified in such sections as a result of service on active duty in a theater of operations for Operation Iraqi Freedom, Operation Enduring Freedom, or Operation New Dawn.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Age for Receipt of Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A waiver may not be granted under this section if the candidate would pass the candidate’s twenty-sixth birthday by July 1 of the year in which the candidate would enter the military service academy pursuant to the waiver.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Number Admitted Using Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not more than five candidates may be admitted to each of the military service academies for an academic year pursuant to a waiver granted under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Record Keeping Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of each military department shall maintain records on the number of graduates of the military service academy under the jurisdiction of the Secretary who are admitted pursuant to a waiver granted under this section and who remain in the Armed Forces beyond the active duty service obligation assumed upon graduation. The Secretary shall compare their retention rate to the retention rate of graduates of that academy generally.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration of Waiver Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority to grant a waiver under this section expires on ","children":[{"tag":"date","attrib":{"date":"2016-09-30"},"text":"September 30, 2016","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaaef350f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authority To Waive Maximum Age Limitation on Admission to Service Academies for Certain Enlisted Members Who Served During Persian Gulf War","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tV/s514"},"text":"Pub. L. 102–190, div. A, title V, § 514","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1361"},"text":"105 Stat. 1361","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/190/dA/tV/s514"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the military department concerned may waive the maximum age limitation in section 4346(a), 6958(a)(1), or 9346(a) [now 7446(a), 8458(a)(1), or 9446(a)] of title 10, United States Code, in the case of any enlisted member of the Armed Forces who—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" becomes 22 years of age while serving on active duty in the Persian Gulf area of operations in connection with Operation Desert Storm during the Persian Gulf War; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was a candidate for admission to the service academy under the jurisdiction of such Secretary in 1990, was prevented from being admitted to the academy during that year by reason of the service of such person on active duty in the Persian Gulf area of operations in connection with Operation Desert Storm, and became 22 years of age after ","children":[{"tag":"date","attrib":{"date":"1990-07-01"},"text":"July 1, 1990","children":[],"tail":", and before the end of such service in that area of operations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘Operation Desert Storm’ has the meaning given such term in section 3(1) of the Persian Gulf Conflict Supplemental Authorization and Personnel Benefits Act of 1991 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Public Law 102–25","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/105/77"},"text":"105 Stat. 77","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"10 U.S.C. 101","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘Persian Gulf War’ has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101/33"},"text":"section 101(33) of title 38","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaaef3510-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Persons From Countries Assisting U.S. in Vietnam; Service Academy Instruction: Oath of Trainees","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Exemption from oath requirement of subsec. (d) of this section of appointees to the Military Academy, the Naval Academy, and the Air Force Academy from countries assisting U.S. in Vietnam, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/802/s1/g"},"text":"Pub. L. 89–802, § 1(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-09"},"text":"Nov. 9, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1519"},"text":"80 Stat. 1519","children":[],"tail":", formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4344"},"text":"section 4344 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
