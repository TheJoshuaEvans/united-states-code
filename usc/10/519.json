{"tag":"section","attrib":{"id":"ida7d76d21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s519"},"text":null,"children":[{"tag":"num","attrib":{"value":"519"},"text":"§ 519.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary enlistments: during war or emergency","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s505"},"text":"section 505 of this title","children":[],"tail":" and except for enlistments as Reserves of an armed force—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7d76d22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s519/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" temporary enlistments in an armed force entered into in time of war or of emergency declared by Congress shall be for the duration of the war or emergency plus six months; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7d76d23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s519/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only persons at least eighteen years of age and otherwise qualified under regulations to be prescribed by the Secretary concerned are eligible for such enlistments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7d76d24-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/235/s2/a/1/B"},"text":"Pub. L. 90–235, § 2(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/755"},"text":"81 Stat. 755","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
