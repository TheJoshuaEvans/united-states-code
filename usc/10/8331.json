{"tag":"section","attrib":{"id":"idab1ecfeb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8331"},"text":null,"children":[{"tag":"num","attrib":{"value":"8331"},"text":"§ 8331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members of the Fleet Reserve and Fleet Marine Corps Reserve: transfer to the retired list; retired pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab1ecfec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8331/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When he has completed 30 years of service, or when he is found not physically qualified in an examination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8385"},"text":"section 8385 of this title","children":[],"tail":", a member of the Fleet Reserve or the Fleet Marine Corps Reserve shall be transferred—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab1ecfed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8331/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the retired list of the Regular Navy or the Regular Marine Corps, as appropriate, if he was a member of the Regular Navy or the Regular Marine Corps at the time of his transfer to the Fleet Reserve or the Fleet Marine Corps Reserve; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1ecfee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8331/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the appropriate Retired Reserve, if he was a member of the Navy Reserve or the Marine Corps Reserve at the time of his transfer to the Fleet Reserve or the Fleet Marine Corps Reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1ecfef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8331/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of subsection (a), a member’s years of service are computed by adding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab1ecff0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8331/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the years of service credited to him upon his transfer to the Fleet Reserve or the Fleet Marine Corps Reserve;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1ecff1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8331/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" his years of active and inactive service in the armed forces before his transfer to the Fleet Reserve or the Fleet Marine Corps Reserve not credited to him upon that transfer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1ecff2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8331/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" his years of service, active and inactive, in the Fleet Reserve or the Fleet Marine Corps Reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1ecff3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8331/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Unless otherwise entitled to higher pay, each member transferred to the retired list or the Retired Reserve under this section is entitled to retired pay at the same rate as the retainer pay to which he was entitled at the time of his transfer to the retired list or the Retired Reserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab1ecff4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/397"},"text":"70A Stat. 397","children":[],"tail":", § 6331; "},{"tag":"ref","attrib":{"href":"/us/pl/85/583/s1"},"text":"Pub. L. 85–583, § 1","children":[],"tail":"(4–6), "},{"tag":"date","attrib":{"date":"1958-08-01"},"text":"Aug. 1, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/480"},"text":"72 Stat. 480","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s515/b/1/K"},"text":"Pub. L. 109–163, div. A, title V, § 515(b)(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3233"},"text":"119 Stat. 3233","children":[],"tail":"; renumbered § 8331 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 807(b)(15), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":", 1840.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab1ecff5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab1ecff6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab1ecff7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6331","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s854c"},"text":"34 U.S.C. 854c","children":[],"tail":" (4th proviso)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1938-06-25/ch690/s204"},"text":"June 25, 1938, ch. 690, § 204","children":[],"tail":" (4th proviso), "},{"tag":"html:a","attrib":{"href":"/us/stat/52/1179"},"text":"52 Stat. 1179","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1946-08-10/ch952/s2"},"text":"Aug. 10, 1946, ch. 952, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/993"},"text":"60 Stat. 993","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s854e"},"text":"34 U.S.C. 854e","children":[],"tail":" (2d and 4th provisos)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1938-06-25/ch690/s206"},"text":"June 25, 1938, ch. 690, § 206","children":[],"tail":" (2d and 4th provisos), "},{"tag":"html:a","attrib":{"href":"/us/stat/52/1179"},"text":"52 Stat. 1179","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1940-04-25/ch153"},"text":"Apr. 25, 1940, ch. 153","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/54/162"},"text":"54 Stat. 162","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s854"},"text":"34 U.S.C. 854","children":[],"tail":" (note)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608/s803"},"text":"July 9, 1952, ch. 608, § 803","children":[],"tail":" (3d sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/66/505"},"text":"66 Stat. 505","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words “transferred * * * in accordance with the provisions of this section and of sections 853 and 854b of this title”, in the fourth proviso of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s854c"},"text":"34 U.S.C. 854c","children":[],"tail":", and the words “transferred after sixteen years’ or more service in the Regular Navy”, and “men coming under the cognizance of sections 853 and 854b of this title”, in the second proviso of "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s854e"},"text":"34 U.S.C. 854e","children":[],"tail":", are omitted as surplusage since the classes designated by these phrases comprise all members of the Fleet Reserve and Fleet Marine Corps Reserve."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is worded so as to cover all members of the Fleet Reserve and the Fleet Marine Corps Reserve regardless of the law under which they attained that status. A member transferring under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s854b"},"text":"34 U.S.C. 854b","children":[],"tail":" may count only active naval service in computing the service required for that transfer, but in determining his eligibility for retirement he may add to his active naval service all previous active or inactive service in the Army, Navy, Marine Corps, Air Force, or Coast Guard, and his time in the Fleet Reserve. A member transferring to the Fleet Reserve under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s854c"},"text":"34 U.S.C. 854c","children":[],"tail":" may count active service in any armed force toward that transfer, and he determines his eligibility for retirement by adding to the service credited to him at the time of transfer any previous inactive service in the armed forces and his time in the Fleet Reserve. As to the latter member the words “active service” in clause (2) are superfluous, since such service would have been credited to him upon his transfer to the Fleet Reserve, but they are needed in the case of a member transferred under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s854b"},"text":"34 U.S.C. 854b","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c) references to the “allowances to which enlisted men of the Navy are entitled on retirement after thirty years’ service”, in the second and fourth provisos of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s854e"},"text":"34 U.S.C. 854e","children":[],"tail":", are omitted because of the repeal, by § 19 of the Pay Readjustment Act of 1942, "},{"tag":"ref","attrib":{"href":"/us/stat/56/369"},"text":"56 Stat. 369","children":[],"tail":", of the laws authorizing such allowances."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab1ecff8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab1ecff9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s807/b/15"},"text":"Pub. L. 115–232, § 807(b)(15)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6331"},"text":"section 6331 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 8385” for “section 6485” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “Navy Reserve” for “Naval Reserve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/583/s1/4"},"text":"Pub. L. 85–583, § 1(4)","children":[],"tail":", provided for the transfer to the appropriate Retired Reserve of those members of the Fleet Reserve or the Fleet Marine Corps Reserve who had transferred thereto from the Naval Reserve or the Marine Corps Reserve."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/583/s1/5"},"text":"Pub. L. 85–583, § 1(5)","children":[],"tail":", struck out “of clause (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/583/s1/6"},"text":"Pub. L. 85–583, § 1(6)","children":[],"tail":", inserted “or the Retired Reserve” after “retired list” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab1ecffa-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab1ecffb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
