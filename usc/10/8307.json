{"tag":"section","attrib":{"id":"idab1a1624-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8307"},"text":null,"children":[{"tag":"num","attrib":{"value":"8307"},"text":"§ 8307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medal of honor: presentation of Medal of Honor Flag","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President shall provide for the presentation of the Medal of Honor Flag designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s903"},"text":"section 903 of title 36","children":[],"tail":" to each person to whom a medal of honor is awarded under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8291"},"text":"section 8291 of this title","children":[],"tail":". Presentation of the flag shall be made at the same time as the presentation of the medal under section 8291 or 8300 of this title. In the case of a posthumous presentation of the medal, the flag shall be presented to the person to whom the medal is presented."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab1a1625-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/248/tVIII/s8143/c/2/A"},"text":"Pub. L. 107–248, title VIII, § 8143(c)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-23"},"text":"Oct. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1570"},"text":"116 Stat. 1570","children":[],"tail":", § 6257; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tX/s1062/a/16"},"text":"Pub. L. 107–314, div. A, title X, § 1062(a)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2650"},"text":"116 Stat. 2650","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s555/a"},"text":"Pub. L. 109–364, div. A, tit