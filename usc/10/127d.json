{"tag":"section","attrib":{"id":"ida75459fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d"},"text":null,"children":[{"tag":"num","attrib":{"value":"127d"},"text":"§ 127d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support of special operations for irregular warfare","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida75459fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may, with the concurrence of the relevant Chief of Mission, expend up to $20,000,000 during any fiscal year to provide support to foreign forces, irregular forces, groups, or individuals engaged in supporting or facilitating ongoing and authorized irregular warfare operations by United States Special Operations Forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida75459fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds for support under this section in a fiscal year shall be derived from amounts authorized to be appropriated for that fiscal year for the Department of Defense for operation and maintenance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida75459fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida75459fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority in this section shall be exercised in accordance with such procedures as the Secretary shall establish for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida75459ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The procedures required under paragraph (1) shall establish, at a minimum, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7545a00-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Policy guidance for the execution of, and constraints within, activities under the authority in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7545a01-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The processes through which activities under the authority in this section are to be developed, validated, and coordinated, as appropriate, with relevant entities of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7545a02-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The processes through which legal reviews and determinations are made to comply with the authority in this section and ensure that the exercise of such authority is consistent with the national security of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7545a03-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The processes to ensure, to the extent practicable, that before a decision to provide support is made, the recipients of support do not pose a counterintelligence or force protection threat and have not engaged in gross violations of human rights.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7545a04-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The processes by which the Department shall keep the congressional defense committees fully and currently informed of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida7545a05-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/c/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements for the use of the authority in this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7545a06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/c/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities conducted under such authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7545a07-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to congress on procedures and material modifications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall notify the congressional defense committees of the procedures established pursuant to this section before any exercise of the authority in this section, and shall notify such committee of any material modification of the procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7545a08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed to constitute a specific statutory authorization for any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7545a09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The conduct of a covert action, as such term is defined in section 503(e) of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3093/e"},"text":"50 U.S.C. 3093(e)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7545a0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The introduction of United States Armed Forces (including as such term is defined in section 8(c) of the War Powers Resolution (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1547/c"},"text":"50 U.S.C. 1547(c)","children":[],"tail":")) into hostilities or into situations wherein hostilities are clearly indicated by the circumstances."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7545a0b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provision of support to regular forces, irregular forces, groups, or individuals for the conduct of operations that United States Special Operations Forces are not otherwise legally authorized to conduct themselves.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7545a0c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The conduct or support of activities, directly or indirectly, that are inconsistent with the laws of armed conflict.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7545a0d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Delegation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority of the Secretary to make funds available under this section for support of a military operation may not be delegated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7545a0e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Programmatic and Policy Oversight","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Assistant Secretary of Defense for Special Operations and Low-Intensity Conflict shall have primary programmatic and policy oversight within the Office of the Secretary of Defense of support to irregular warfare activities authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7545a0f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7545a10-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 15 days before exercising the authority in this section to make funds available to initiate support of an ongoing and authorized operation or changing the scope or funding level of any support under this section for such an operation by $500,000 or an amount equal to 10 percent of such funding level (whichever is less), the Secretary shall notify the congressional defense committees of the use of such authority with respect to such operation. Any such notification shall be in writing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7545a11-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A notification required by this subsection shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7545a12-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The type of support to be provided to United States Special Operations Forces, and a description of the ongoing and authorized operation to be supported.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7545a13-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the foreign forces, irregular forces, groups, or individuals engaged in supporting or facilitating the ongoing and authorized operation that is to be the recipient of funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7545a14-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The type of support to be provided to the recipient of the funds, and a description of the end-use monitoring to be used in connection with the use of the funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7545a15-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount obligated under the authority to provide support.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7545a16-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/g/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The duration for which the support is expected to be provided, and an identification of the timeframe in which the provision of support will be reviewed by the commander of the applicable combatant command for a determination with respect to the necessity of continuing such support.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7545a17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/g/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The determination of the Secretary that the provision of support does not constitute any of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida7545a18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/g/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An introduction of United States Armed Forces (including as such term is defined in section 8(c) of the War Powers Resolution (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1547/c"},"text":"50 U.S.C. 1547(c)","children":[],"tail":")) into hostilities, or into situations where hostilities are clearly indicated by the circumstances, without specific statutory authorization within the meaning of section 5(b) of such Resolution ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1544/b"},"text":"50 U.S.C. 1544(b)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7545a19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/g/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A covert action, as such term is defined in section 503(e) of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3093/e"},"text":"50 U.S.C. 3093(e)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7545a1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/g/2/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An authorization for the provision of support to regular forces, irregular forces, groups, or individuals for the conduct of operations that United States Special Operations Forces are not otherwise legally authorized to conduct themselves.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7545a1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/g/2/F/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The conduct or support of activities, directly or indirectly, that are inconsistent with the laws of armed conflict.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7545a1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of Suspension or Termination of Support.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7545a1d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 48 hours after suspending or terminating support to any foreign force, irregular force, group, or individual provided pursuant to the authority in this section, the Secretary shall submit to the congressional defense committees a written notice of such suspension or termination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7545a1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The written notice required by paragraph (1) shall include each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7545a1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the reasons for the suspension or termination of such support.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7545a20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of any effect on regional, theater, or global campaign plan objectives anticipated to result from such suspension or termination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7545a21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan for such suspension or termination, and, in the case of support that is planned to be transitioned to any other program of the Department of Defense or to a program of any other Federal department or agency, a detailed description of the transition plan, including the resources, equipment, capabilities, and personnel associated with such plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7545a22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Biannual Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7545a23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report on preceding fiscal year","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 120 days after the close of each fiscal year in which subsection (a) is in effect, the Secretary shall submit to the congressional defense committees a report on the support provided under this section during the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7545a24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report on current calendar year","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 180 days after the submittal of each report required by paragraph (1), the Secretary shall submit to the congressional defense committees a report on the support provided under this section during the first half of the fiscal year in which the report under this paragraph is submitted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7545a25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report required by this subsection shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7545a26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary of the ongoing irregular warfare operations, and associated authorized campaign plans, being conducted by United States Special Operations Forces that were supported or facilitated by foreign forces, irregular forces, groups, or individuals for which support was provided under this section during the period covered by such report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7545a27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the support or facilitation provided by such foreign forces, irregular forces, groups, or individuals to United States Special Operations Forces during such period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7545a28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/i/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The type of recipients that were provided support under this section during such period, identified by authorized category (foreign forces, irregular forces, groups, or individuals).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7545a29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/i/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed description of the support provided to the recipients under this section during such period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7545a2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/i/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total amount obligated for support under this section during such period, including budget details.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7545a2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/i/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The intended duration of support provided under this section during such period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7545a2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/i/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of value of the support provided under this section during such period, including a summary of significant activities undertaken by foreign forces, irregular forces, groups, or individuals to support irregular warfare operations by United States Special Operations Forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7545a2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/i/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total amount obligated for support under this section in prior fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7545a2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quarterly Briefings.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7545a2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less frequently than quarterly, the Secretary shall provide to the congressional defense committees a briefing on the use of the authority provided by this section, and other matters relating to irregular warfare, with the primary purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7545a30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" keeping the congressional defense committees fully and currently informed of irregular warfare requirements and activities, including emerging combatant commands requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7545a31-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consulting with the congressional defense committees regarding such matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7545a32-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each briefing required by paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7545a33-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An update on irregular warfare activities within each geographic combatant command and a description of the manner in which such activities support the respective theater campaign plan and the National Defense Strategy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7545a34-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An overview of relevant authorities and legal issues, including limitations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7545a35-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/j/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An overview of irregular warfare-related interagency activities and initiatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7545a36-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/j/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of emerging combatant command requirements for the use of the authority provided by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7545a37-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127d/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Irregular Warfare Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (d), in this section, the term “irregular warfare” means Department of Defense activities not involving armed conflict that support predetermined United States policy and military objectives conducted by, with, and through regular forces, irregular forces, groups, and individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7545a38-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXII/s1201/a"},"text":"Pub. L. 118–31, div. A, title XII, § 1201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/437"},"text":"137 Stat. 437","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7545a39-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7545a3a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida7545a3b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 127d was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s331"},"text":"section 331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7545a3c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7545a3d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Irregular Warfare Exercise Laboratory","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tX/s1094"},"text":"Pub. L. 119–60, div. A, title X, § 1094","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1066"},"text":"139 Stat. 1066","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tX/s1094"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may establish and maintain an Irregular Warfare Exercise Laboratory to—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the training, experimentation, preparation, and validation of the United States Armed Forces to conduct full-spectrum irregular warfare activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable activities to build the capacity and interoperability of the national security forces of friendly foreign countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out the activities authorized under subsection (a), the Secretary may use the authorities under chapter 16 of title 10, United States Code, or other applicable statutory authorities available to the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Security Forces Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘national security forces’ has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s301"},"text":"section 301 of title 10","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
