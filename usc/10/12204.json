{"tag":"section","attrib":{"id":"idab986d98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12204"},"text":null,"children":[{"tag":"num","attrib":{"value":"12204"},"text":"§ 12204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioned officers: original appointment; limitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab986d99-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12204/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No person may be appointed as a Reserve in a commissioned grade above major or lieutenant commander, unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab986d9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12204/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" he was formerly a commissioned officer of an armed force; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab986d9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12204/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such an appointment is recommended by a board of officers convened by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab986d9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12204/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not apply to adjutants general and assistant adjutants general of the several States, Puerto Rico, and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab986d9d-3a6f-11f1-a58a-d8db54b14ab