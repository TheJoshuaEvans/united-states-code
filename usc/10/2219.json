{"tag":"section","attrib":{"id":"ida941f955-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219"},"text":null,"children":[{"tag":"num","attrib":{"value":"2219"},"text":"§ 2219.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for improvement of Navy ship repair or alterations capability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida941f956-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida941f957-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to the availability of appropriations, the Secretary of the Navy may make grants to an eligible entity for the purpose of carrying out—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida941f958-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a capital improvement project; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f959-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a maritime training program designed to foster technical skills and operational productivity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida941f95a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of a grant under this section may not exceed 75 percent of the total cost of the project or program funded by the grant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida941f95b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A grant provided under this section may not be used to construct buildings or other physical facilities, except for piers, dry docks, and structures in support of piers and dry docks, or to acquire land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida941f95c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may not award a grant to an eligible entity under this section unless the Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida941f95d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entity has access to sufficient non-Federal funding to meet the requirement under paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f95e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entity has authority to carry out the proposed project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f95f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the project or program would improve—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida941f960-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/a/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efficiency, competitive operations, capability, or quality of United States Navy ship repair or alterations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida941f961-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/a/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employee, or potential employee, skills and enhanced productivity related to United States Navy ship repair or alterations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida941f962-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for a grant under this section, an entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida941f963-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a shipyard or other entity that provides ship repair or alteration for non-nuclear ships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida941f964-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit an application, at such time, in such form, and containing such information and assurances as the Secretary may require, including a comprehensive description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida941f965-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for the project or program proposed to be funded under the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f966-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methodology to be used to implement the project or program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f967-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any existing programs or arrangements that could be used to supplement or leverage a grant provided under this section; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida941f968-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enter into an agreement with the Secretary under which the entity agrees—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida941f969-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to complete the project or program funded by the grant within a certain timeframe and without unreasonable delay and the Secretary determines such project or program is likely to be completed within the timeframe provided in such agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f96a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to return to the Secretary any amount of the grant that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida941f96b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not used by the grant recipient for the purpose for which the grant was awarded; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida941f96c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not obligated or expended within the timeframe provided in the agreement;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f96d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain such records as the Secretary may require and make such records available for review and audit by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f96e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not to purchase any product or material for the project or program using grant funds, including any commercially available off-the-shelf item, unless such product or material is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida941f96f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/b/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an unmanufactured article, material, or supply that has been mined or produced in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida941f970-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/b/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a manufactured article, material, or supply that has been manufactured in the United States substantially all from articles, materials, or supplies mined, produced, or manufactured in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida941f971-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidelines","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall issue guidelines to establish appropriate accounting, reporting, and review procedures to ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida941f972-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts awarded as grants under this section are used for the purposes for which such amounts were made available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida941f973-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity that receives a grant under this section complies with the terms of the agreement such entity enters into with the Secretary pursuant to subsection (b)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida941f974-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida941f975-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “commercially available off-the-shelf item”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida941f976-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means any item of supply (including construction material) that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida941f977-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commercial item, as defined by section 2.101 of title 48, Code of Federal Regulations (as in effect on the date of the enactment of the National Defense Authorization Act for Fiscal Year 2024); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida941f978-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sold in substantial quantities in the commercial marketplace; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f979-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include bulk cargo, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s40102/4"},"text":"section 40102(4) of title 46","children":[],"tail":", such as agricultural products and petroleum products."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida941f97a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “product or material”, with respect to a project or program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida941f97b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means an article, material, or supply brought to the site where the project or program is being carried out for incorporation into the project or program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f97c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes an item brought to the site preassembled from articles, materials, or supplies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida941f97d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2219/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “United States” includes the District of Columbia, the Commonwealth of Puerto Rico, the Northern Mariana Islands, Guam, American Samoa, and the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida941f97e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tX/s1017"},"text":"Pub. L. 118–31, div. A, title X, § 1017","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/382"},"text":"137 Stat. 382","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida941f97f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida941f980-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida941f981-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the National Defense Authorization Act for Fiscal Year 2024, referred to in subsec. (d)(1)(A)(i), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida941f982-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2219 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2491c"},"text":"section 2491c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
