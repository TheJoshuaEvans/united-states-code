{"tag":"section","attrib":{"id":"ida960f337-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2275b"},"text":"§ 2275b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for appropriate classification guidance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida960f338-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before a space major defense acquisition program achieves Milestone B approval, or equivalent, the milestone decision authority shall determine whether the classification guidance for the program remains appropriate and—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida960f339-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such guidance is determined to be appropriate, submit to the congressional defense committees a certification of such determination; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f33a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such guidance is determined to be inappropriate, initiate an update to such guidance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida960f33b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida960f33c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Milestone B approval” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4172/e/7"},"text":"section 4172(e)(7) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f33d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “major defense acquisition program” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4201"},"text":"section 4201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f33e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “space major defense acquisition program” means a major defense acquisition program for the acquisition of a satellite, ground system, or command and control system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida960f33f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVI/s1602"},"text":"Pub. L. 118–31, div. A, title XVI, § 1602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/584"},"text":"137 Stat. 584","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVII/s1701/a/27"},"text":"Pub. L. 118–159, div. A, title XVII, § 1701(a)(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2204"},"text":"138 Stat. 2204","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida960f340-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida960f341-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida960f342-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" struck out period at end of section catchline."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
