{"tag":"section","attrib":{"id":"idaa1af4ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3247"},"text":null,"children":[{"tag":"num","attrib":{"value":"3247"},"text":"§ 3247.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts: regulations for bids","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa1af4af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3247/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa1af4b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3247/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe regulations for the preparation, submission, and opening of bids for contracts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa1af4b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3247/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that a bid be accompanied by a written guaranty, signed by one or more responsible persons, undertaking that the bidder, if his bid is accepted, will, within the time prescribed by the Secretary or other officer authorized to make the contract, make a contract and furnish a bond with good and sufficient sureties for the performance of the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa1af4b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3247/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If a bidder, after being notified of the acceptance of his bid, fails within the time prescribed under subsection (a)(2) to enter into a contract and furnish the prescribed bond, the Secretary concerned or other authorized officer shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa1af4b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3247/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contract with another person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa1af4b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3247/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charge against the defaulting bidder and his guarantors the difference between the amount specified by the bidder in his bid and the amount for which a contract is made with the other person, this difference being immediately recoverable by the United States for the use of the military department concerned in an action against the bidder and his guarantors, jointly or severally.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa1af4b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3247/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Proceedings under this section are subject to regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s121"},"text":"section 121 of title 40","children":[],"tail":", unless exempted therefrom under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s501/a/2"},"text":"section 501(a)(2) of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa1af4b6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/136"},"text":"70A Stat. 136","children":[],"tail":", § 2381; "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXIV/s1405/35"},"text":"Pub. L. 98–525, title XIV, § 1405(35)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2624"},"text":"98 Stat. 2624","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/tI/s1507"},"text":"Pub. L. 103–355, title I, § 1507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3298"},"text":"108 Stat. 3298","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/b/6"},"text":"Pub. L. 107–217, § 3(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1295"},"text":"116 Stat. 1295","children":[],"tail":"; renumbered § 3247, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1813/e"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1813(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4181"},"text":"134 Stat. 4181","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa1af4b7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaa1af4b8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaa1af4b9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","