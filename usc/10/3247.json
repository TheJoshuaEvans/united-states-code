tag":"html:p","attrib":{},"text":"5:218 (less 1st and 2d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1878-04-10/ch58"},"text":"Apr. 10, 1878, ch. 58","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/20/36"},"text":"20 Stat. 36","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1883-03-03/ch120"},"text":"Mar. 3, 1883, ch. 120","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/22/487"},"text":"22 Stat. 487","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1951-10-31/ch654/s2/4"},"text":"Oct. 31, 1951, ch. 654, § 2(4)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/65/706"},"text":"65 Stat. 706","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2381(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5:218 (1st 16 words of 1st sentence) [applicability of 5:218 extended to Navy by 5:412b and 41:161 (1st sentence)].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1948-02-19/ch65/s12"},"text":"Feb. 19, 1948, ch. 65, § 12","children":[],"tail":" (1st sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/62/26"},"text":"62 Stat. 26","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the word “may” is substituted for the words “is authorized to”. The words “rules and * * * to be observed” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the word “undertaking” is substituted for the words “to the effect that he or they undertake”. The words “make a contract” are inserted for clarity. The words “in the premises” are omitted as surplusage. The words “for the performance of the contract” are substituted for the words “to furnish the supplies proposed or to perform the service required”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “duly” is omitted as surplusage. The words “with good and sufficient security for the proper fulfillment of its terms” are omitted as covered by subsection (a)(2). The words “the prescribed” are inserted before the word “bond”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b)(1) is substituted for the words “proceed to contract with some other person to furnish the supplies or perform the services required”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2) the word “charge” is substituted for the words “forthwith cause * * * to be charged”. The words “a contract is made with the other person” are substituted for the words “he may have contracted with another party to furnish the supplies or perform the service for the whole period of the proposal”. The words “guarantor or” are omitted as surplusage. The words “this difference being” are substituted for the words “and the sum may be”. The words “of debt” are omitted, since that action no longer exists. The words “the bidder and his guarantors, jointly or severally” are substituted for the words “either or all of such persons”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “Proceedings under this section are” are inserted for clarity. The words “unless exempted therefrom under section 481(a) of that title” are inserted to preserve the possibility of exemption of proceedings under the revised section from the provisions of the Federal Property and Administrative Services Act of 1949, as amended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa1af4ba-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa1af4bb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2381"},"text":"section 2381 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s121"},"text":"section 121 of title 40","children":[],"tail":"” for “section 205 of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s486"},"text":"40 U.S.C. 486","children":[],"tail":")” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s501/a/2"},"text":"section 501(a)(2) of title 40","children":[],"tail":"” for “section 201(a) of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s481/a"},"text":"40 U.S.C. 481(a)","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355"},"text":"Pub. L. 103–355","children":[],"tail":" substituted “The Secretary of Defense may—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) prescribe regulations for the preparation, submission, and opening of bids for contracts; and”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"for “The Secretary of a military department may—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) prescribe regulations for the preparation, submission, and opening of bids for contracts with that department; and”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525"},"text":"Pub. L. 98–525","children":[],"tail":" substituted “section 205 of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s486"},"text":"40 U.S.C. 486","children":[],"tail":")” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s486"},"text":"section 486 of title 40","children":[],"tail":"” and “section 201(a) of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s481/a"},"text":"40 U.S.C. 481(a)","children":[],"tail":")” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s481/a"},"text":"section 481(a) of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa1af4bc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa1af4bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
