{"tag":"section","attrib":{"id":"ida8158844-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s826a"},"text":null,"children":[{"tag":"num","attrib":{"value":"826a"},"text":"§ 826a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 26a. Military magistrates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8158845-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s826a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A military magistrate shall be a commissioned officer of the armed forces who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8158846-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s826a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a member of the bar of a Federal court or a member of the bar of the highest court of a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8158847-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s826a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is certified to be qualified, by reason of education, training, experience, and judicial temperament, for duty as a military magistrate by the Judge Advocate General of the armed force of which the officer is a member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8158848-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s826a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In accordance with regulations prescribed by the Secretary concerned, in addition to duties when designated under section 819 or 830a of this title (article 19 or 30a), a military magistrate may be assigned to perform other duties of a nonjudicial nature.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8158849-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLV/s5185"},"text":"Pub. L. 114–328, div. E, title LV, § 5185","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2901"},"text":"130 Stat. 2901","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida815884a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida815884b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida815884c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on ","children":[{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
