{"tag":"section","attrib":{"id":"ida8a9638e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1169"},"text":null,"children":[{"tag":"num","attrib":{"value":"1169"},"text":"§ 1169.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regular enlisted members: limitations on discharge","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No regular enlisted member of an armed force may be discharged before his term of service expires, except—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8a9638f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1169/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as prescribed by the Secretary concerned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8a96390-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1169/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by sentence of a general or special court martial; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8a96391-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1169/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as otherwise provided by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8a96392-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/235/s3/a/1/A"},"text":"Pub. L. 90–235, § 3(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/757"},"text":"81 Stat. 757","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
