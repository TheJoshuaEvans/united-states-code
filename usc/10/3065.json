nd in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s154/a"},"text":"section 154(a) of this title","children":[],"tail":" shall not be delegable”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa05709d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa05709e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3065 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7065"},"text":"section 7065 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2308"},"text":"section 2308 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/s1503/b/1"},"text":"Pub. L. 103–355, § 1503(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa05709f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1807/d/2/C"},"text":"Pub. L. 116–283, § 1807(d)(2)(C)","children":[],"tail":", (3), in section catchline, substituted “Assignment and delegation of procurement functions and responsibilities: delegation within agency” for “Emergency situations involving weapons of mass destruction” and, in text, struck out subsec. (a) designation and heading “In General” at beginning, and substituted “under any provision of this part that is a chapter 137 legacy provision” for “under this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1807/d/1"},"text":"Pub. L. 116–283, § 1807(d)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2311"},"text":"section 2311 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1807/d/2/A"},"text":"Pub. L. 116–283, § 1807(d)(2)(A)","children":[],"tail":", (B), transferred subsecs. (b) and (c) of this section to sections 3066 and 3067 of this title, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (c)(1), (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “Under Secretary of Defense for Acquisition and Sustainment” for “Under Secretary of Defense for Acquisition, Technology, and Logistics”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (c)(1), (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" substituted “Under Secretary of Defense for Acquisition, Technology, and Logistics” for “Under Secretary of Defense for Acquisition and Technology”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355"},"text":"Pub. L. 103–355","children":[],"tail":" substituted “Assignment and delegation of procurement functions and responsibilities” for “Delegation” as section catchline and amended text generally. Prior to amendment, text read as follows: “Except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2304/d/2"},"text":"section 2304(d)(2) of this title","children":[],"tail":", the head of an agency may delegate, subject to his direction, to any other officer or official of that agency, any power under this chap