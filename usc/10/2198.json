{"tag":"section","attrib":{"id":"ida93ace0f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2198"},"text":null,"children":[{"tag":"num","attrib":{"value":"2198"},"text":"§ 2198.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management training program in Japanese language and culture","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida93ace10-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2198/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense, in coordination with the National Science Foundation, shall establish a program for the making of grants on a competitive basis to United States institutions of higher education and other United States not-for-profit organizations for the conduct of programs for scientists, engineers, and managers to learn Japanese language and culture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93ace11-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2198/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense shall prescribe in regulations the criteria for awarding a grant under the program for activities of an institution or organization referred to in subsection (a), including the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93ace12-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2198/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether scientists, engineers, and managers of defense laboratories and Department of Energy laboratories are permitted a level of participation in such activities that is beneficial to the development and application of defense critical technologies by such laboratories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93ace13-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2198/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whether such activities include the placement of United States scientists, engineers, and managers in Japanese government and industry laboratories—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida93ace14-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2198/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the knowledge of such scientists, engineers, and managers in (i) Japanese language and culture, and (ii) the research and development and management practices of such laboratories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida93ace15-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2198/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide opportunities for the encouragement of technology transfer from Japan to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93ace16-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2198/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether an appropriate share of the costs of such activities will be paid out of funds derived from non-Federal Government sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93ace17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2198/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section, the term “defense critical technology” means a technology that is identified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4816"},"text":"section 4816 of this title","children":[],"tail":" as critical for attaining the national security objectives set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4811/a"},"text":"section 4811(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida93ace18-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVIII/s828/a"},"text":"Pub. L. 102–190, div. A, title VIII, § 828(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1444"},"text":"105 Stat. 1444","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/35/tII/s201/c/3"},"text":"Pub. L. 103–35, title II, § 201(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-05-31"},"text":"May 31, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/98"},"text":"107 Stat. 98","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1073/a/39"},"text":"Pub. L. 105–85, div. A, title X, § 1073(a)(39)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1902"},"text":"111 Stat. 1902","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1867/e/1"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1867(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4282"},"text":"134 Stat. 4282","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida93ace19-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida93ace1a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida93ace1b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “section 4816” for “section 2505” and “section 4811(a)” for “section 2501(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" substituted “that is identified under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2505"},"text":"section 2505 of this title","children":[],"tail":" as critical for attaining the national security objectives set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2501/a"},"text":"section 2501(a) of this title","children":[],"tail":".” for “identified in a defense critical technologies plan submitted to the Congress under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2506"},"text":"section 2506 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/35"},"text":"Pub. L. 103–35","children":[],"tail":" substituted “a defense” for “an annual defense” and “section 2506” for “section 2522”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida93ace1c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida93ace1d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
