{"tag":"section","attrib":{"id":"ida84ec02e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1042"},"text":null,"children":[{"tag":"num","attrib":{"value":"1042"},"text":"§ 1042.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copy of certificate of service","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A fee for a copy of a certificate showing service in the armed forces may not be charged to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84ec02f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1042/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person discharged or released from the armed forces honorably or under honorable conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec030-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1042/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the next of kin of the person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec031-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1042/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a legal representative of the person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida84ec032-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258/s2/b/2/B"},"text":"Pub. L. 97–258, § 2(b)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1052"},"text":"96 Stat. 1052","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8