{"tag":"section","attrib":{"id":"idab369eb5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8635"},"text":null,"children":[{"tag":"num","attrib":{"value":"8635"},"text":"§ 8635.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of the Southern Sea Otter Military Readiness Areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab369eb6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8635/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Navy shall establish areas, to be known as “Southern Sea Otter Military Readiness Areas”, for national defense purposes. Such areas shall include each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab369eb7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8635/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The area that includes Naval Base Ventura County, San Nicolas Island, and Begg Rock and the adjacent and surrounding waters within the following coordinates:","children":[{"tag":"p","attrib":{},"text":"N. Latitude/W. Longitude","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"33°27.8′/119°34.3′","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"33°20.5′/119°15.5′","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"33°13.5′/119°11.8′","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"33°06.5′/119°15.3′","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"33°02.8′/119°26.8′","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"33°08.8′/119°46.3′","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"33°17.2′/119°56.9′","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"33°30.9′/119°54.2′.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369eb8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8635/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The area that includes Naval Base Coronado, San Clemente Island and the adjacent and surrounding waters running parallel to shore to 3 nautical miles from the high tide line designated by part 165 of title 33, Code of Federal Regulations, on ","children":[{"tag":"date","attrib":{"date":"2010-05-20"},"text":"May 20, 2010","children":[],"tail":", as the San Clemente Island 3NM Safety Zone."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab369eb9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8635/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities Within the Southern Sea Otter Military Readiness Areas.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab369eba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8635/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incidental takings under endangered species act of 1973","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sections 4 and 9 of the Endangered Species Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1533"},"text":"16 U.S.C. 1533","children":[],"tail":", 1538) shall not apply with respect to the incidental taking of any southern sea otter in the Southern Sea Otter Military Readiness Areas in the course of conducting a military readiness activity."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369ebb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8635/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incidental takings under marine mammal protection act of 1972","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sections 101 and 102 of the Marine Mammal Protection Act of 1972 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1371"},"text":"16 U.S.C. 1371","children":[],"tail":", 1372) shall not apply with respect to the incidental taking of any southern sea otter in the Southern Sea Otter Military Readiness Areas in the course of conducting a military readiness activity."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369ebc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8635/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment as species proposed to be listed","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of conducting a military readiness activity, any southern sea otter while within the Southern Sea Otter Military Readiness Areas shall be treated for the purposes of section 7 of the Endangered Species Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1536"},"text":"16 U.S.C. 1536","children":[],"tail":") as a member of a species that is proposed to be listed as an endangered species or a threatened species under section 4 of the Endangered Species Act of 1973 ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1533"},"text":"16 U.S.C. 1533","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab369ebd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8635/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Removal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section or any other Federal law shall be construed to require that any southern sea otter located within the Southern Sea Otter Military Readiness Areas be removed from the Areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab369ebe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8635/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revision or Termination of Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Interior may revise or terminate the application of subsection (b) if the Secretary of the Interior, in consultation with the Secretary of the Navy, determines that military activities occurring in the Southern Sea Otter Military Readiness Areas are impeding the southern sea otter conservation or the return of southern sea otters to optimum sustainable population levels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab369ebf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8635/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monitoring.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab369ec0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8635/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy shall conduct monitoring and research within the Southern Sea Otter Military Readiness Areas to determine the effects of military readiness activities on the growth or decline of the southern sea otter population and on the near-shore ecosystem. Monitoring and research parameters and methods shall be determined in consultation with the Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369ec1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8635/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2017-11-25"},"text":"November 25, 2017","children":[],"tail":", and every three years thereafter, the Secretary of the Navy shall report to Congress and the public on monitoring undertaken pursuant to paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab369ec2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8635/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab369ec3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8635/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Southern sea otter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “southern sea otter” means any member of the subspecies Enhydra lutris nereis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369ec4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8635/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Take","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “take”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab369ec5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8635/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when used in reference to activities subject to regulation by the Endangered Species Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.), shall have the meaning given such term in that Act; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab369ec6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8635/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when used in reference to activities subject to regulation by the Marine Mammal Protection Act of 1972 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1361"},"text":"16 U.S.C. 1361","children":[],"tail":" et seq.) shall have the meaning given such term in that Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369ec7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8635/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incidental taking","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “incidental taking” means any take of a southern sea otter that is incidental to, and not the purpose of, the carrying out of an otherwise lawful activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369ec8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8635/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Military readiness activity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “military readiness activity” has the meaning given that term in section 315(f) of the Bob Stump National Defense Authorization Act for Fiscal Year 2003 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s703"},"text":"16 U.S.C. 703","children":[],"tail":" note) and includes all training and operations of the armed forces that relate to combat and the adequate and realistic testing of military equipment, vehicles, weapons, and sensors for proper operation and suitability for combat use."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369ec9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8635/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Optimum sustainable population","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “optimum sustainable population” means, with respect to any population stock, the number of animals that will result in the maximum productivity of the population or the species, keeping in mind the carrying capacity of the habitat and the health of the ecosystem of which they form a constituent element.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab369eca-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tIII/s312/a"},"text":"Pub. L. 114–92, div. A, title III, § 312(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/787"},"text":"129 Stat. 787","children":[],"tail":", § 7235; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1081/a/50"},"text":"Pub. L. 115–91, div. A, title X, § 1081(a)(50)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1597"},"text":"131 Stat. 1597","children":[],"tail":"; renumbered § 8635, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab369ecb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab369ecc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idab369ecd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Endangered Species Act of 1973, referred to in subsec. (f)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/205"},"text":"Pub. L. 93–205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-28"},"text":"Dec. 28, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/884"},"text":"87 Stat. 884","children":[],"tail":", which is classified principally to chapter 35 (§ 1531 et seq.) of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"section 1531 of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Marine Mammal Protection Act of 1972, referred to in subsec. (f)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/522"},"text":"Pub. L. 92–522","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1027"},"text":"86 Stat. 1027","children":[],"tail":", which is classified generally to chapter 31 (§ 1361 et seq.) of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1361"},"text":"section 1361 of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 315 of the Bob Stump National Defense Authorization Act for Fiscal Year 2003, referred to in subsec. (f)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s315"},"text":"section 315 of Pub. L. 107–314","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s703"},"text":"section 703 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab390ece-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8635, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/532"},"text":"70A Stat. 532","children":[],"tail":", set forth restrictions on civilian employment for enlisted members of Air Force on active duty, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/90/235/s6/a/7"},"text":"Pub. L. 90–235, § 6(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/762"},"text":"81 Stat. 762","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 8639 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9239"},"text":"section 9239 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab390ecf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7235"},"text":"section 7235 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2017-11-25"},"text":"November 25, 2017","children":[],"tail":",” for “24 months after the date of the enactment of this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab390ed0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab390ed1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
