{"tag":"section","attrib":{"id":"ida84793e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s994"},"text":null,"children":[{"tag":"num","attrib":{"value":"994"},"text":"§ 994.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military working dogs: veterinary care for retired military working dogs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida84793e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s994/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may establish and maintain a system to provide for the veterinary care of retired military working dogs. No funds may be provided by the Federal Government for this purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84793e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s994/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Dogs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A retired military working dog eligible for veterinary care under this section is any military working dog adopted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2583"},"text":"section 2583 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84793e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s994/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards of Care","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The veterinary care provided under the system authorized by this section shall meet such standards as the Secretary shall establish and from time to time update.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida84793e6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tIII/s371/b/1"},"text":"Pub. L. 112–239, div. A, title III, § 371(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1706"},"text":"126 Stat. 1706","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
