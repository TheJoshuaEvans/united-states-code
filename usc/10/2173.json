{"tag":"section","attrib":{"id":"ida93612d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173"},"text":null,"children":[{"tag":"num","attrib":{"value":"2173"},"text":"§ 2173.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education loan repayment program: commissioned officers in specified health professions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida93612d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Repay Education Loans","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of maintaining adequate numbers of commissioned officers of the armed forces on active duty who are qualified in the various health professions, the Secretary of a military department may repay, in the case of a person described in subsection (b), a loan that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93612d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was used by the person to finance education regarding a health profession; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93612d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was obtained from a governmental entity, private financial institution, school, or other authorized entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93612d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Persons","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to obtain a loan repayment under this section, a person must—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93612d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfy one of the requirements specified in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93612d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be fully qualified for, or hold, an appointment as a commissioned officer in one of the health professions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93612d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sign a written agreement to serve on active duty, or, if on active duty, to remain on active duty for a period in addition to any other incurred active duty obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93612d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Academic and Professional Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"One of the following academic requirements must be satisfied for purposes of determining the eligibility of a person for a loan repayment under this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93612d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The person is fully qualified in a health care profession that the Secretary of the military department concerned has determined to be necessary to meet identified skill shortages.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93612da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The person is enrolled as a full-time student in the final year of a course of study at an accredited educational institution leading to a degree in a health profession other than medicine or osteopathic medicine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93612db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The person is enrolled in the final year of an approved graduate program leading to specialty qualification in medicine, dentistry, osteopathic medicine, or other health profession.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93612dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The person is enrolled in the Armed Forces Health Professions Scholarship and Financial Assistance Program under subchapter I of chapter 105 of this title for a number of years less than is required to complete the normal length of the course of study required for the health profession concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93612dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain Persons Ineligible","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Students of the Uniformed Services University of the Health Sciences established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2112"},"text":"section 2112 of this title","children":[],"tail":" are not eligible for the repayment of an education loan under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93612de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Loan Repayments","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93612df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to the limits established by paragraph (2), a loan repayment under this section may consist of payment of the principal, interest, and related expenses of a loan obtained by a person described in subsection (b) for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida93612e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all educational expenses, comparable to all educational expenses recognized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2127/a"},"text":"section 2127(a) of this title","children":[],"tail":" for participants in the Armed Forces Health Professions Scholarship and Financial Assistance program; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida93612e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable living expenses, not to exceed expenses comparable to the stipend paid under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2121/d"},"text":"section 2121(d) of this title","children":[],"tail":" for participants in the Armed Forces Health Professions Scholarship and Financial Assistance program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93612e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each year of obligated service that a person agrees to serve in an agreement described in subsection (b)(3), the Secretary of the military department concerned may pay not more than $60,000 on behalf of the person. This maximum amount shall be increased annually by the Secretary of Defense effective October 1 of each year by the percentage equal to the percent increase in the average annual cost of educational expenses and stipend costs of a single scholarship under the Armed Forces Health Professions Scholarship and Financial Assistance program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93612e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Active Duty Service Obligation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93612e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person entering into an agreement described in subsection (b)(3) incurs an active duty service obligation. The length of this obligation shall be determined under regulations prescribed by the Secretary of Defense, but those regulations may not provide for a period of obligation of less than one year for each maximum annual amount, or portion thereof, paid on behalf of the person for qualified loans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93612e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For persons on active duty before entering into the agreement, the active duty service obligation shall be served consecutively to any other obligation incurred under the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93612e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Failure To Complete Obligation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93612e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A commissioned officer who is relieved of the officer’s active duty obligation under this section before the completion of that obligation may be given, with or without the consent of the officer, any alternative obligation comparable to any of the alternative obligations authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2123/e"},"text":"section 2123(e) of this title","children":[],"tail":" for participants in the Armed Forces Health Professions Scholarship and Financial Assistance program."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93612e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who does not complete the period of active duty specified in the agreement entered into under subsection (b)(3), or the alternative obligation imposed under paragraph (1), shall be subject to the repayment provisions of section 303a(e) or 373 of title 37.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93612e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2173/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe regulations to carry out this section, including standards for qualified loans and authorized payees and other terms and conditions for the making of loan repayments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida93612ea-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVI/s651/a"},"text":"Pub. L. 105–85, div. A, title VI, § 651(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1802"},"text":"111 Stat. 1802","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tV/s573"},"text":"Pub. L. 107–314, div. A, title V, § 573","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2558"},"text":"116 Stat. 2558","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s687/c/7"},"text":"Pub. L. 109–163, div. A, title VI, § 687(c)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3334"},"text":"119 Stat. 3334","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s537/a"},"text":"Pub. L. 109–364, div. A, title V, § 537(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2209"},"text":"120 Stat. 2209","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tV/s553"},"text":"Pub. L. 111–383, div. A, title V, § 553","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4220"},"text":"124 Stat. 4220","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVI/s618/a/1/I"},"text":"Pub. L. 115–91, div. A, title VI, § 618(a)(1)(I)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1426"},"text":"131 Stat. 1426","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida93612eb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida93612ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida93612ed-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" inserted “or 373” before “of title 37”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" substituted “$60,000” for “$22,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s573/a"},"text":"Pub. L. 107–314, § 573(a)","children":[],"tail":", substituted “Students” for “Participants of the Armed Forces Health Professions Scholarship and Financial Assistance program under subchapter I of chapter 105 of this title and students”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s573/b"},"text":"Pub. L. 107–314, § 573(b)","children":[],"tail":", struck out at end “The total amount that may be repaid on behalf of any person may not exceed an amount determined on the basis of a four-year active duty service obligation.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida93612ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida93612ef-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s537/b"},"text":"Pub. L. 109–364, div. A, title V, § 537(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2209"},"text":"120 Stat. 2209","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/364/dA/tV/s537/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by subsection (a) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2006-10-01"},"text":"October 1, 2006","children":[],"tail":", and shall apply to agreements entered into or revised under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2173"},"text":"section 2173 of title 10","children":[],"tail":", United States Code, on or after that date."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on adjustment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The adjustment required by the second sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2173/e/2"},"text":"section 2173(e)(2) of title 10","children":[],"tail":", United States Code, to be made on "},{"tag":"date","attrib":{"date":"2006-10-01"},"text":"October 1, 2006","children":[],"tail":", shall not be made.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"ida93612f0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For savings provision relating to payment or repayment of any bonus, incentive pay, special pay, or similar pay obligated to be paid before ","children":[{"tag":"date","attrib":{"date":"2006-04-01"},"text":"Apr. 1, 2006","children":[],"tail":", under a provision of this section amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/c"},"text":"section 687(c) of Pub. L. 109–163","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/f"},"text":"section 687(f) of Pub. L. 109–163","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s510"},"text":"section 510 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
