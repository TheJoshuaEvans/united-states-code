{"tag":"section","attrib":{"id":"idaac69d66-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6202"},"text":null,"children":[{"tag":"num","attrib":{"value":"6202"},"text":"§ 6202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hanford waste tank cleanup program reforms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaac69d67-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Office of River Protection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy shall establish an office at the Hanford Reservation, Richland, Washington, to be known as the “Office of River Protection” (in this section referred to as the “Office”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac69d68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Management and Responsibilities of Office","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac69d69-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6202/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall be headed by a senior official of the Department of Energy, who shall report to the Assistant Secretary of Energy for Environmental Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac69d6a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6202/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of the Office shall be responsible for managing all aspects of the River Protection Project, Richland, Washington, including Hanford Tank Farm operations and the Waste Treatment Plant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac69d6b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6202/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac69d6c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6202/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary of Energy for Environmental Management shall delegate in writing responsibility for the management of the River Protection Project, Richland, Washington, to the head of the Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69d6d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6202/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such delegation shall include, at a minimum, authorities for contracting, financial management, safety, and general program management that are equivalent to the authorities of managers of other operations offices of the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69d6e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6202/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of the Office shall, to the maximum extent possible, coordinate all activities of the Office with the manager of the Richland Operations Office of the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac69d6f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Department Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall provide the head of the Office with the resources and personnel necessary to carry out the responsibilities specified in subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac69d70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6202/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Assistant Secretary of Energy for Environmental Management shall submit to the Committee on Armed Services of the Senate and the Committee on Armed Services of the House of Representatives written notification detailing any changes in the roles, responsibilities, and reporting relationships that involve the Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac69d71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6202/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Office shall terminate on ","children":[{"tag":"date","attrib":{"date":"2024-09-30"},"text":"September 30, 2024","children":[],"tail":". The Office may be extended beyond that date if the Assistant Secretary of Energy for Environmental Management determines in writing that termination would disrupt effective management of the Hanford Tank Farm operations."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac69d72-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2)(B), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1399"},"text":"139 Stat. 1399","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac69d73-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac69d74-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac69d75-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6202 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8282"},"text":"section 8282 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2622"},"text":"section 2622 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaac69d76-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
