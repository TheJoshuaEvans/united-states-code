{"tag":"section","attrib":{"id":"idab50dc62-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8858"},"text":null,"children":[{"tag":"num","attrib":{"value":"8858"},"text":"§ 8858.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of prize master","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The prize master shall take the captured vessel to the selected port. On arrival he shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab50dc63-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8858/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deliver immediately to a prize commissioner the documents and papers and the inventory thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc64-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8858/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make affidavit that the documents and papers and the inventory thereof and the prize property are the same and are in the same condition as delivered to him, or explaining any loss or absence or change in their condition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc65-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8858/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report all information respecting the prize and her capture to the United States attorney;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc66-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8858/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deliver the persons sent as witnesses to the custody of the United States marshal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc67-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8858/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain the prize in his custody until it is taken therefrom by process from the prize court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab50dc68-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/476"},"text":"70A Stat. 476","children":[],"tail":", § 7658; renumbered § 8858, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/9"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab50dc69-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab50dc6a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab50dc6b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"