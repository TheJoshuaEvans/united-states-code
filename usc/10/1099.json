{"tag":"section","attrib":{"id":"ida8916e7c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1099"},"text":null,"children":[{"tag":"num","attrib":{"value":"1099"},"text":"§ 1099.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care enrollment system and payment options","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8916e7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1099/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of System","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense, after consultation with the other administering Secretaries, shall establish a system of health care enrollment for covered beneficiaries who reside in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8916e7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1099/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Description of System","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such system shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8916e7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1099/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" allow covered beneficiaries to elect to enroll in a health care plan, or modify a previous election, from eligible health care plans designated by the Secretary of Defense during—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8916e80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1099/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annual open enrollment period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8916e81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1099/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any period based on a qualifying event experienced by the beneficiary, as determined appropriate by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8916e82-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1099/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if necessary in order to ensure full use of facilities of the uniformed services in a geographical area, assign covered beneficiaries who reside in such area to such facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8916e83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1099/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Health Care Plans Available Under System","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A health care plan designated by the Secretary of Defense under the system described in subsection (a) shall provide all health care to which a covered beneficiary is entitled under this chapter. Such a plan may consist of any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8916e84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1099/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Use of facilities of the uniformed services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8916e85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1099/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan under the TRICARE program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8916e86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1099/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other health care plan contracted for by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8916e87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1099/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any combination of the plans described in paragraphs (1), (2), and (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8916e88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1099/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment Options","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8916e89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1099/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member or former member of the uniformed services, or a dependent thereof, eligible for medical care and dental care under section 1074(b) or 1076 of this title shall pay a premium for coverage under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8916e8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1099/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the maximum extent practicable, a premium owed by a member, former member, or dependent under paragraph (1) shall be withheld from the retired, retainer, or equivalent pay of the member, former member, or dependent. In all other cases, a premium shall be paid in a frequency and method determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8916e8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1099/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense, after consultation with the other administering Secretaries, shall prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8916e8c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tVII/s701/a/1"},"text":"Pub. L. 99–661, div. A, title VII, § 701(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3896"},"text":"100 Stat. 3896","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVII/s701/d/1"},"text":"Pub. L. 114–328, div. A, title VII, § 701(d)(1)","children":[],"tail":", (j)(1)(E), "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2186"},"text":"130 Stat. 2186","children":[],"tail":", 2192; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVII/s702/a"},"text":"Pub. L. 116–92, div. A, title VII, § 702(a)","children":[],"tail":", (b)(2)(B), "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1436"},"text":"133 Stat. 1436","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8916e8d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8916e8e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8916e8f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s702/b/2/B"},"text":"Pub. L. 116–92, § 702(b)(2)(B)","children":[],"tail":", inserted “and payment options” after “system” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s702/a"},"text":"Pub. L. 116–92, § 702(a)","children":[],"tail":", added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s701/d/1"},"text":"Pub. L. 114–328, § 701(d)(1)","children":[],"tail":", amended par. (1) generally. Prior to amendment, text read as follows: “allow covered beneficiaries to elect a health care plan from eligible health care plans designated by the Secretary of Defense; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s701/j/1/E"},"text":"Pub. L. 114–328, § 701(j)(1)(E)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “The Civilian Health and Medical Program of the Uniformed Services.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8916e90-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8916e91-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" applicable to health care coverage beginning on or after "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/s702/c"},"text":"section 702(c) of Pub. L. 116–92","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1097a"},"text":"section 1097a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8916e92-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" applicable with respect to the provision of health care under the TRICARE program beginning on "},{"tag":"date","attrib":{"date":"2018-01-01"},"text":"Jan. 1, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s701/k"},"text":"section 701(k) of Pub. L. 114–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072"},"text":"section 1072 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8916e93-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tVII/s701/d/1"},"text":"Pub. L. 99–661, div. A, title VII, § 701(d)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3898"},"text":"100 Stat. 3898","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/661/dA/tVII/s701/d/1"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2), the Secretary of Defense shall prescribe regulations as required by section 1099(d) [now 1099(e)] of title 10, United States Code (as added by subsection (a)(1)) to implement the system of health care enrollment for covered beneficiaries—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on ","children":[{"tag":"date","attrib":{"date":"1987-10-01"},"text":"October 1, 1987","children":[],"tail":", with respect to—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covered beneficiaries included in the demonstration project required under section 702 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1073"},"text":"10 U.S.C. 1073","children":[],"tail":" note]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilities of the uniformed services located in the geographical area covered by the demonstration project; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than ","children":[{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":", for all other covered beneficiaries and facilities of the uniformed services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not assign covered beneficiaries to facilities of the uniformed services, as authorized by section 1099(b)(2) of such title (as added by subsection (a)(1)), before ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"October 1, 1990","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8916e94-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Initial Annual Open Enrollment Period","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVII/s701/d/2"},"text":"Pub. L. 114–328, div. A, title VII, § 701(d)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2186"},"text":"130 Stat. 2186","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/328/dA/tVII/s701/d/2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall implement the initial annual open enrollment period pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1099/b/1"},"text":"section 1099(b)(1) of title 10","children":[],"tail":", United States Code, as amended by paragraph (1), during 2018."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grace period during first year.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At any time during the one-year period beginning on the date on which the initial annual open enrollment period begins pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1099/b/1"},"text":"section 1099(b)(1) of title 10","children":[],"tail":", United States Code, as amended by paragraph (1), a covered beneficiary may make an election, or modify such an election, described in such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If during such one-year period an individual who is eligible to enroll in the TRICARE program, but does not elect to enroll in such program, receives health care services for an episode of care that would be covered under the TRICARE program if such individual were enrolled in the TRICARE program, the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall pay the out-of-network fees only for the first episode of care and inform the individual of the opportunity to enroll in the TRICARE program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not pay any costs relating to any subsequent episode of care if such individual is not enrolled in the TRICARE program.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8916e95-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reports to Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tVII/s701/c/1"},"text":"Pub. L. 99–661, div. A, title VII, § 701(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3898"},"text":"100 Stat. 3898","children":[],"tail":", required Secretary of Defense, not later than "},{"tag":"date","attrib":{"date":"1987-07-01"},"text":"July 1, 1987","children":[],"tail":", to submit to Congress a report detailing any plans to establish or implement a system of health care enrollment (other than as required under section 702(a)(2)(C)) under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1099/a"},"text":"section 1099(a) of this title","children":[],"tail":" and the plan of the Secretary for completing implementation of such system."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
