{"tag":"section","attrib":{"id":"ida84ec083-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1044d"},"text":"§ 1044d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military testamentary instruments: requirement for recognition by States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida84ec084-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Testamentary Instruments To Be Given Legal Effect","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A military testamentary instrument—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84ec085-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is exempt from any requirement of form, formality, or recording before probate that is provided for testamentary instruments under the laws of a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec086-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the same legal effect as a testamentary instrument prepared and executed in accordance with the laws of the State in which it is presented for probate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84ec087-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Military Testamentary Instruments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, a military testamentary instrument is an instrument that is prepared with testamentary intent in accordance with regulations prescribed under this section and that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84ec088-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is executed in accordance with subsection (c) by (or on behalf of) a person, as a testator, who is eligible for military legal assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec089-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes a disposition of property of the testator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec08a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" takes effect upon the death of the testator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84ec08b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for Execution of Military Testamentary Instruments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An instrument is valid as a military testamentary instrument only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84ec08c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the instrument is executed by the testator (or, if the testator is unable to execute the instrument personally, the instrument is executed in the presence of, by the direction of, and on behalf of the testator);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec08d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the execution of the instrument is notarized by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida84ec08e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a military legal assistance counsel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida84ec08f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a person who is authorized to act as a notary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1044a"},"text":"section 1044a of this title","children":[],"tail":" who—"}],"tail":null},{"tag":"clause","attrib":{"id":"ida84ec090-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not an attorney; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida84ec091-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is supervised by a military legal assistance counsel; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida84ec092-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State-licensed notary employed by a military department or the Coast Guard who is supervised by a military legal assistance counsel;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec093-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the instrument is executed in the presence of at least two disinterested witnesses (in addition to the person notarizing the instrument in accordance with paragraph (2)), each of whom attests to witnessing the testator’s execution of the instrument by signing it; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec094-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the instrument is executed in accordance with such additional requirements as may be provided in regulations prescribed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84ec095-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Self-Proving Military Testamentary Instruments","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84ec096-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the document setting forth a military testamentary instrument meets the requirements of paragraph (2), then the signature of a person on the document as the testator, an attesting witness, a notary, or the presiding attorney, together with a written representation of the person’s status as such and the person’s military grade (if any) or other title, is prima facie evidence of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida84ec097-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That the signature is genuine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida84ec098-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That the signatory had the represented status and title at the time of the execution of the will.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida84ec099-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That the signature was executed in compliance with the procedures required under the regulations prescribed under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec09a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A document setting forth a military testamentary instrument meets the requirements of this paragraph if it includes (or has attached to it), in a form and content required under the regulations prescribed under subsection (f), each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida84ec09b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A certificate, executed by the testator, that includes the testator’s acknowledgment of the testamentary instrument.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida84ec09c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An affidavit, executed by each witness signing the testamentary instrument, that attests to the circumstances under which the testamentary instrument was executed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida84ec09d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A notarization, including a certificate of any administration of an oath required under the regulations, that is signed by the notary or other official administering the oath.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84ec09e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statement To Be Included","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84ec09f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed under this section, each military testamentary instrument shall contain a statement that sets forth the provisions of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec0a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) shall not be construed to make inapplicable the provisions of subsection (a) to a testamentary instrument that does not include a statement described in that paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84ec0a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Regulations for the purposes of this section shall be prescribed jointly by the Secretary of Defense and by the Secretary of Homeland Security with respect to the Coast Guard when it is not operating as a service in the Department of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84ec0a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84ec0a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person eligible for military legal assistance” means a person who is eligible for legal assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1044"},"text":"section 1044 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec0a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “military legal assistance counsel” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida84ec0a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a judge advocate (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s801/13"},"text":"section 801(13) of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida84ec0a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a civilian attorney serving as a legal assistance officer under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1044"},"text":"section 1044 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec0a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044d/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” includes the District of Columbia, the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, and each possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida84ec0a8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 551(a)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–123; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/b/1"},"text":"Pub. L. 107–296, title XVII, § 1704(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tV/s523/a"},"text":"Pub. L. 114–328, div. A, title V, § 523(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2116"},"text":"130 Stat. 2116","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida84ec0a9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida84ec0aa-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida84ec0ab-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s523/a/1"},"text":"Pub. L. 114–328, § 523(a)(1)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “the instrument is executed in the presence of a military legal assistance counsel acting as presiding attorney;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s523/a/2"},"text":"Pub. L. 114–328, § 523(a)(2)","children":[],"tail":", substituted “person notarizing the instrument in accordance with paragraph (2)” for “presiding attorney”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida84ec0ac-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida84ec0ad-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
