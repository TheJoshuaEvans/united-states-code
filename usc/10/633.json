{"tag":"section","attrib":{"id":"ida7f1ac4a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s633"},"text":null,"children":[{"tag":"num","attrib":{"value":"633"},"text":"§ 633.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement for years of service: regular and Space Force lieutenant colonels; regular Navy commanders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7f1ac4b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s633/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 28 ","children":[{"tag":"inline","attrib":{},"text":"Years of Active Commissioned Service","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7f1ac4c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s633/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b) and as provided under section 637(b) or 637a of this title, each officer of the Regular Army, Regular Air Force, or Regular Marine Corps who holds the regular grade of lieutenant colonel, and each officer of the Regular Navy who holds the regular grade of commander, who is not on a list of officers recommended for promotion to the regular grade of colonel or captain, respectively, shall, if not earlier retired, be retired on the first day of the month after the month in which he completes 28 years of active commissioned service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f1ac4d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s633/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided under section 637(b) or 637a of this title, each officer of the Space Force who holds the grade of lieutenant colonel who is not on a list of officers recommended for promotion to the grade of colonel shall, if not earlier retired, be retired on the first day of the month after the month in which the officer completes 28 years of active commissioned service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f1ac4e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s633/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7f1ac4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s633/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer of the Navy or Marine Corps who is an officer designated for limited duty to whom section 8146(e) or 8372 of this title applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f1ac50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s633/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer of the Navy or Marine Corps who is a permanent professor at the United States Naval Academy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7f1ac51-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tI/s105"},"text":"Pub. L. 96–513, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2862"},"text":"