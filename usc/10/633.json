 limited duty to whom "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s5596/e"},"text":"section 5596(e) of this title","children":[],"tail":" applies and an officer of the Marine Corps designated for limited duty to whom section 5596(e) or "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6383"},"text":"section 6383 of this title","children":[],"tail":" applies” and struck out at end “During the period beginning on "},{"tag":"date","attrib":{"date":"1993-07-01"},"text":"July 1, 1993","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"October 1, 1999","children":[],"tail":", the preceding sentence shall not apply to an officer of the Navy designated for limited duty to whom "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6383"},"text":"section 6383 of this title","children":[],"tail":" applies.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"October 1, 1999","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1995-10-01"},"text":"October 1, 1995","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":" inserted at end “During the period beginning on "},{"tag":"date","attrib":{"date":"1993-07-01"},"text":"July 1, 1993","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1995-10-01"},"text":"October 1, 1995","children":[],"tail":", the preceding sentence shall not apply to an officer of the Navy designated for limited duty to whom "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6383"},"text":"section 6383 of this title","children":[],"tail":" applies.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s1405/12"},"text":"Pub. L. 98–52