{"tag":"section","attrib":{"id":"ida84793e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s995"},"text":null,"children":[{"tag":"num","attrib":{"value":"995"},"text":"§ 995.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability for contractors using military working dogs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida84793e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s995/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Reporting Requirement for Contractors","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each covered contract shall specify that the contractor is required to submit to the Under Secretary of Defense (Comptroller), on an annual basis for the duration of the covered contract, a report containing an identification of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84793e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s995/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of military working dogs that are in the possession of the covered contractor and located outside of the continental United States in support of a military operation, if any; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84793ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s995/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the primary location of any such military working dogs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84793eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s995/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Contract Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section the term “covered contract” means a contract that the Secretary of Defense determines involves military working dogs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida84793ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tIII/s382/a"},"text":"Pub. L. 117–263, div. A, title III, § 382(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2543"},"text":"136 Stat. 2543","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida84793ed-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida84793ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida84793ef-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tIII/s382/b"},"text":"Pub. L. 117–263, div. A, title III, § 382(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2543"},"text":"136 Stat. 2543","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tIII/s382/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s995"},"text":"Section 995 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to a contract entered into on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida84793f0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Guidance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tIII/s382/d"},"text":"Pub. L. 117–263, div. A, title III, § 382(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2543"},"text":"136 Stat. 2543","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tIII/s382/d"},"text":"“Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"], the Under Secretary of Defense (Comptroller) shall issue the guidance on the annual reporting requirement under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s995"},"text":"section 995 of title 10","children":[],"tail":", United States Code, as added by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
