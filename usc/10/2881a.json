{"tag":"section","attrib":{"id":"ida9eda2b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2881a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2881a"},"text":"§ 2881a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary authority for acquisition or construction of privatized military unaccompanied housing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9eda2b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2881a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may use the authority under this subchapter to enter into contracts with appropriate private sector entities for the acquisition or construction of military unaccompanied housing in the United States, including any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9eda2b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2881a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Housing; Assignment of Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may assign members of the armed forces without dependents to housing units acquired or constructed pursuant to this section, and such housing units shall be considered as quarters of the United States or a housing facility under the jurisdiction of the Secretary for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s403"},"text":"section 403 of title 37","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9eda2ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2881a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Basic Allowance for Housing","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9eda2bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2881a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may prescribe and, under section 403(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of title 37, pay for members of the armed forces without dependents in privatized housing units acquired or constructed pursuant to this section higher rates of partial basic allowance for housing than the rates authorized under paragraph (2) of such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eda2bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2881a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The partial basic allowance for housing paid for a member at a higher rate under this subsection may be paid directly to the private sector source of the housing to whom the member is obligated to pay rent or other charge for residing in such housing if the private sector source credits the amount so paid against the amount owed by the member for the rent or other charge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9eda2bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2881a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9eda2be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2881a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned shall use the Department of Defense Military Unaccompanied Housing Improvement Fund to carry out activities pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eda2bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2881a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to 30 days prior notification to the appropriate committees of Congress in an electronic medium pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s480"},"text":"section 480 of this title","children":[],"tail":", such additional amounts as the Secretary of Defense considers necessary may be transferred to the Department of Defense Military Unaccompanied Housing Improvement Fund from amounts appropriated for construction of military unaccompanied housing in military construction accounts. The amounts so transferred shall be merged with and be available for the same purposes and for the same period of time as amounts appropriated directly to the Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9eda2c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2881a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expiration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority of the Secretary concerned to enter into a contract under this section shall expire ","children":[{"tag":"date","attrib":{"date":"2029-09-30"},"text":"September 30, 2029","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9eda2c1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dB/tXXVIII/s2803/a/1"},"text":"Pub. L. 107–314, div. B, title XXVIII, § 2803(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2703"},"text":"116 Stat. 2703","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1056/c/10"},"text":"Pub. L. 109–163, div. A, title X, § 1056(c)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3440"},"text":"119 Stat. 3440","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dB/tXXVIII/s2812"},"text":"Pub. L. 109–364, div. B, title XXVIII, § 2812","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2473"},"text":"120 Stat. 2473","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dB/tXXVIII/s2803/f"},"text":"Pub. L. 111–383, div. B, title XXVIII, § 2803(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4459"},"text":"124 Stat. 4459","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1051/a/25"},"text":"Pub. L. 115–91, div. A, title X, § 1051(a)(25)","children":[],"tail":", div. B, title XXVIII, § 2801(d)(1), "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1562"},"text":"131 Stat. 1562","children":[],"tail":", 1844; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVI/s613/b"},"text":"Pub. L. 117–263, div. A, title VI, § 613(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2623"},"text":"136 Stat. 2623","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tII/s20001/c"},"text":"Pub. L. 119–21, title II, § 20001(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/113"},"text":"139 Stat. 113","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9eda2c2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9eda2c3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9eda2c4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s20001/c/1"},"text":"Pub. L. 119–21, § 20001(c)(1)","children":[],"tail":", substituted “Temporary authority for acquisition or construction of privatized military unaccompanied housing” for “Pilot projects for acquisition or construction of military unaccompanied housing” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s20001/c/2"},"text":"Pub. L. 119–21, § 20001(c)(2)","children":[],"tail":", (4), substituted “In General” for “Pilot Projects Authorized” in heading, “Secretary concerned” for “Secretary of the Navy”, and “use the authority under this subchapter to enter into contracts with appropriate private sector entities” for “carry out not more than three pilot projects under the authority of this section or another provision of this subchapter to use the private sector”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s20001/c/2"},"text":"Pub. L. 119–21, § 20001(c)(2)","children":[],"tail":", (3), substituted “Secretary concerned” for “Secretary of the Navy” and “pursuant to this section” for “under the pilot projects”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s20001/c/3"},"text":"Pub. L. 119–21, § 20001(c)(3)","children":[],"tail":", (5), substituted “privatized housing units” for “privatized housing” and “pursuant to this section” for “under the pilot projects”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s20001/c/2"},"text":"Pub. L. 119–21, § 20001(c)(2)","children":[],"tail":", (3), substituted “Secretary concerned” for “Secretary of the Navy” and “pursuant to this section” for “under the pilot projects”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s20001/c/7"},"text":"Pub. L. 119–21, § 20001(c)(7)","children":[],"tail":", substituted “under this section” for “under the pilot programs” and “"},{"tag":"date","attrib":{"date":"2029-09-30"},"text":"September 30, 2029","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"September 30, 2009","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s20001/c/6"},"text":"Pub. L. 119–21, § 20001(c)(6)","children":[],"tail":", redesignated subsec. (f) as (e). Former subsec. (e) had been struck out by "},{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":". See 2017 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s20001/c/6"},"text":"Pub. L. 119–21, § 20001(c)(6)","children":[],"tail":", redesignated subsec. (f) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s20001/c/2"},"text":"Pub. L. 119–21, § 20001(c)(2)","children":[],"tail":", substituted “Secretary of the Navy” for “Secretary concerned”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “section 403("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")” for “section 403(n)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s2801/d/1"},"text":"Pub. L. 115–91, § 2801(d)(1)","children":[],"tail":", inserted “in an electronic medium pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s480"},"text":"section 480 of this title","children":[],"tail":"” after “Congress”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1051/a/25"},"text":"Pub. L. 115–91, § 1051(a)(25)","children":[],"tail":", struck out subsec. (e) which required reports describing certain proposed contracts, conveyances, or leases."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" inserted before period at end “or, if earlier, a period of 20 days has elapsed from the date on which a copy of the report is provided in an electronic medium pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s480"},"text":"section 480 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsecs. (d)(2), (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s2812/a"},"text":"Pub. L. 109–364, § 2812(a)","children":[],"tail":", substituted “30 days” for “90 days”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s2812/b"},"text":"Pub. L. 109–364, § 2812(b)","children":[],"tail":", substituted “2009” for “2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “The” for “Notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2885"},"text":"section 2885 of this title","children":[],"tail":", the”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
