{"tag":"section","attrib":{"id":"idaa13c877-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3207"},"text":null,"children":[{"tag":"num","attrib":{"value":"3207"},"text":"§ 3207.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment before contract for acquisition of supplies is entered into","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense shall ensure that before a contract for the delivery of supplies to the Department of Defense is entered into—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa13c878-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3207/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" when the appropriate officials of the Department are making an assessment of the most advantageous source for acquisition of the supplies (considering quality, price, delivery, and other factors), there is a review of the availability and cost of each item of supply—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa13c879-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3207/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through the supply system of the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa13c87a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3207/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under standard Government supply contracts, if the item is in a category of supplies defined under regulations of the Secretary of Defense as being potentially available under a standard Government supply contract; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa13c87b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3207/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a review of both the procurement history of the item and a description of the item, including, when necessary for an adequate description of the item, a picture, drawing, diagram, or other graphic representation of the item.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa13c87c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1811/f"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1811(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4173"},"text":"134 Stat. 4173","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa13c87d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa13c87e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa13c87f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2305"},"text":"section 2305 of this title","children":[],"tail":", which was transferred to this section and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1811/f/2"},"text":"Pub. L. 116–283, § 1811(f)(2)","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXII/s1213/a"},"text":"Pub. L. 98–525, title XII, § 1213(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2591"},"text":"98 Stat. 2591","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa13c880-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3207, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/173"},"text":"70A Stat. 173","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/155/tI/s101/5"},"text":"Pub. L. 85–155, title I, § 101(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-21"},"text":"Aug. 21, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/376"},"text":"71 Stat. 376","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/130/s1/9/C"},"text":"Pub. L. 90–130, § 1(9)(C)","children":[],"tail":", (D), "},{"tag":"date","attrib":{"date":"1967-11-08"},"text":"Nov. 8, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/375"},"text":"81 Stat. 375","children":[],"tail":", prescribed authorized strength of Army Medical Specialist Corps in commissioned officers on active list of Regular Army, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tII/s202"},"text":"Pub. L. 96–513, title II, § 202","children":[],"tail":", title VII, § 701, "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2878"},"text":"94 Stat. 2878","children":[],"tail":", 2955, effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa13c881-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1811/f/2"},"text":"Pub. L. 116–283, § 1811(f)(2)","children":[],"tail":", transferred subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2305"},"text":"section 2305 of this title","children":[],"tail":" to this section and struck out subsec. (c) designation at beginning."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa13c882-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa13c883-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as an Effective Date of 2021 Amendment note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa13c884-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Establishing Biobased Product Merit Guidance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tII/s248"},"text":"Pub. L. 119–60, div. A, title II, § 248","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/799"},"text":"139 Stat. 799","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tII/s248"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"], the Under Secretary of Defense for Research and Engineering, in coordination with the Secretaries of the military departments, shall develop and make publicly available guidance for private entities on how such entities can effectively demonstrate, validate, and verify that a biobased product of such entity provides capabilities meeting the requirements of the Department of Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Analysis","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the guidance required by subsection (a), the Under Secretary of Defense for Research and Engineering shall conduct an analysis of current military specifications for suitable product categories and make such analysis publicly available for use by private entities, such as in industry or academia. Such analysis shall include:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Assessment of all current military specifications and identification of those that may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have existing biobased products that meet such specifications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" could be met with biobased products with some modification; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have no military specification where a new one may be required.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assessment of current validation and verification processes related to military specifications to determine if modifications to such processes are needed to consider biobased product alternatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Review of existing acquisition policy and practices related to procurement of materials meeting military specifications to determine if any changes to such processes are recommended to accommodate biobased products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Biobased Product Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘biobased product’ means a product manufactured, produced, or developed through the application of living organisms to alter living or non-living materials.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa13c885-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Process for Enhanced Supply Chain Scrutiny","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVIII/s807"},"text":"Pub. L. 115–91, div. A, title VIII, § 807","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1456"},"text":"131 Stat. 1456","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/91/dA/tVIII/s807"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":"], the Secretary of Defense shall establish a process for enhancing scrutiny of acquisition decisions in order to improve the integration of supply chain risk management into the overall acquisition decision cycle."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The process under subsection (a) shall include the following elements:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Designation of a senior official responsible for overseeing the development and implementation of the process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development or integration of tools to support commercial due-diligence, business intelligence, or otherwise analyze and monitor commercial activity to understand business relationships with entities determined to be threats to the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development of risk profiles of products or services based on commercial due-diligence tools and data services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development of education and training curricula for the acquisition workforce that supports the process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Integration, as needed, with intelligence sources to develop threat profiles of entities determined to be threats to the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Periodic review and assessment of software products and services on computer networks of the Department of Defense to remove prohibited products or services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Synchronization of the use of current authorities for making supply chain decisions, including ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s806"},"text":"section 806 of Public Law 111–383","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2304"},"text":"10 U.S.C. 2304","children":[],"tail":" note) or improved use of suspension and debarment officials."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordination with interagency, industrial, and international partners, as appropriate, to share information, develop Government-wide strategies for dealing with significant entities determined to be significant threats to the United States, and effectively use authorities in other departments and agencies to provide consistent, Government-wide approaches to supply chain threats.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"“(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other matters as the Secretary considers necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after establishing the process required by subsection (a), the Secretary shall provide a written notification to the Committees on Armed Services of the Senate and House of Representatives that the process has been established. The notification also shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identification of the official designated under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identification of tools and services currently available to the Department of Defense under subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assessment of additional tools and services available under subsection (b)(2) that the Department of Defense should evaluate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identification of, or recommendations for, any statutory changes needed to improve the effectiveness of the process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Projected resource needs for implementing any recommendations made by the Secretary.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
