{"tag":"section","attrib":{"id":"idab2ab722-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8461"},"text":null,"children":[{"tag":"num","attrib":{"value":"8461"},"text":"§ 8461.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Midshipmen: dismissal for best interests of the service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab2ab723-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8461/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever the Superintendent of the Naval Academy believes that the continued presence of any midshipman at the Academy is contrary to the best interest of the service, he shall report in writing to the Secretary of the Navy a full statement of the facts upon which his belief is based. If the Secretary determines from the report that the Superintendent’s belief is well founded, the Secretary shall serve a copy of the report on the midshipman. Within such time as the Secretary considers reasonable, the midshipman shall show cause in writing why he should not be dismissed from the Academy. The Secretary, after consideration of any cause so shown, and with the written approval of the President, may dismiss the midshipman from the Academy and from the naval service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2ab724-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8461/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The truth of any issue of fact raised under subsection (a), except as to the record of demerits, shall be determined by a court of inquiry convened by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab2ab725-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/432"},"text":"70A Stat. 432","children":[],"tail":", § 6961; renumbered § 8461, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/c/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab2ab726-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab2ab727-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab2ab728-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","chi