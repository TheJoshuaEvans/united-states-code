trib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4301(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4301(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4301(c)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4301(d)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4301(e)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4301(f)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4301(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:535 (1st 75 words).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:535 (less 1st 75 words, and less provisos).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:535 (1st proviso).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:535 (words of 2d proviso before semicolon).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:535 (words of 2d proviso after semicolon).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:535 (last proviso).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:535a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-06-03/ch134/s127a"},"text":"June 3, 1916, ch. 134, § 127a","children":[],"tail":" (13th par.); added "},{"tag":"html:a","attrib":{"href":"/us/act/1920-06-04/ch227"},"text":"June 4, 1920, ch. 227","children":[],"tail":", subch. I, § 51 (13th par.); restated "},{"tag":"html:a","attrib":{"href":"/us/act/1926-06-08/ch495"},"text":"June 8, 1926, ch. 495","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1941-05-13/ch113"},"text":"May 13, 1941, ch. 113","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1941-06-30/ch262"},"text":"June 30, 1941, ch. 262","children":[],"tail":" (4th proviso under “Finance Department”); restated "},{"tag":"html:a","attrib":{"href":"/us/act/1948-06-19/ch501/s1"},"text":"June 19, 1948, ch. 501, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/62/477"},"text":"62 Stat. 477","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1948-06-19/ch501/s2"},"text":"June 19, 1948, ch. 501, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/62/478"},"text":"62 Stat. 478","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “members of the Army” are substituted for the words “personnel of the Army of the United States, without regard to component”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “is detailed under subsection (a)” are substituted for the words “receives such instruction”. The words “as long as the detail” are substituted for the words “equal to the duration of his period of instruction”. The words “However, if the detail is for” are substituted for the words “except that where the duration of such training is”. The words “other than one of the Regular Army on the active list” are inserted, since members of the Regular Army on the active list are on continuous active duty. The word “additional” is inserted, since the detail under this section is active duty. The words “the officer may be ordered to that additional duty” are substituted for the words “such subsequent active duty may * * * the officer concerned”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “of whose Army National Guard he is a member” are substituted for the words “whichever is concerned”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “as a condition of a detail under subsection (a)” are substituted for the words “prior to his detail pursuant to the provisions of this paragraph”. The words “accept a discharge” are substituted for the words “be discharged”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “during one enlistment” are inserted for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f), the last sentence is substituted for 10:535 (words within parentheses of last proviso).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (g), the words “under this section” are substituted for 10:535a (9th through 41st words).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaae80862-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaae80863-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4301"},"text":"section 4301 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “State, the Commonwealth of Puerto Rico, the District of Columbia, Guam, or the Virgin Islands” for “State or Territory, Puerto Rico, or the District of Columbia”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" struck out “the Canal Zone,” after “Puerto Rico,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “active-duty list” for “active list” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/169"},"text":"Pub. L. 93–169","children":[],"tail":" struck out provisions which limited to four years the maximum period for which an officer detailed for additional active duty upon termination of detail is required to serve."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaae80864-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaae80865-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaae80866-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701"},"text":"section 701 of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
