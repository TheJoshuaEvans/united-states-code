{"tag":"section","attrib":{"id":"idaa863a87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4660"},"text":null,"children":[{"tag":"num","attrib":{"value":"4660"},"text":"§ 4660.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on collection of political information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa863a88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4660/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Requiring Submission of Political Information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of an agency may not require a contractor to submit political information related to the contractor or a subcontractor at any tier, or any partner, officer, director, or employee of the contractor or subcontractor—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa863a89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4660/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as part of a solicitation, request for bid, request for proposal, or any other form of communication designed to solicit offers in connection with the award of a contract for procurement of property or services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa863a8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4660/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the course of contract performance as part of the process associated with modifying a contract or exercising a contract option.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa863a8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4660/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The prohibition under this section applies to the procurement of commercial products and commercial services, the procurement of commercial-off-the-shelf-items, and the non-commercial procurement of supplies, property, services, and manufactured items, irrespective of contract vehicle, including contracts, purchase orders, task or deliver orders under indefinite delivery/indefinite quantity contracts, blanket purchase agreements, and basic ordering agreements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa863a8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4660/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa863a8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4660/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waiving, superseding, restricting, or limiting the application of the Federal Election Campaign Act of 1971 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"52 U.S.C. 30101","children":[],"tail":" et seq.) or preventing Federal regulatory or law enforcement agencies from collecting or receiving information authorized by law; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa863a8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4660/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" precluding the Defense Contract Audit Agency from accessing and reviewing certain information, including political information, for the purpose of identifying unallowable costs and administering cost principles established pursuant to subchapter I of chapter 273 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa88aa8f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4660/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa88aa90-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4660/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contractor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “contractor” includes contractors, bidders, and offerors, and individuals and legal entities who would reasonably be expected to submit offers or bids for Federal Government contracts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa88aa91-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4660/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Political information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “political information” means information relating to political spending, including any payment consisting of a contribution, expenditure, independent expenditure, or disbursement for an electioneering communication that is made by the contractor, any of its partners, officers, directors or employees, or any of its affiliates or subsidiaries to a candidate or on behalf of a candidate for election for Federal office, to a political committee, to a political party, to a third party entity with the intention or reasonable expectation that it would use the payment to make independent expenditures or electioneering communications, or that is otherwise made with respect to any election for Federal office, party affiliation, and voting history.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa88aa92-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4660/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other terms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each of the terms “contribution”, “expenditure”, “independent expenditure”, “candidate”, “election”, “electioneering communication”, and “Federal office” has the meaning given that term in the Federal Election Campaign Act of 1971 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"52 U.S.C. 30101","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa88aa93-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVIII/s823/a"},"text":"Pub. L. 112–81, div. A, title VIII, § 823(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1502"},"text":"125 Stat. 1502","children":[],"tail":", § 2335; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1071/f/17"},"text":"Pub. L. 113–291, div. A, title X, § 1071(f)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3511"},"text":"128 Stat. 3511","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1081/a/32"},"text":"Pub. L. 115–91, div. A, title X, § 1081(a)(32)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1596"},"text":"131 Stat. 1596","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s836/c/10"},"text":"Pub. L. 115–232, div. A, title VIII, § 836(c)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1866"},"text":"132 Stat. 1866","children":[],"tail":"; renumbered § 4660 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII"},"text":"Pub. L. 116–283, div. A, title XVIII","children":[],"tail":", §§ 1862(b), 1883(b)(2), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4277"},"text":"134 Stat. 4277","children":[],"tail":", 4294; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/d/14"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(d)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2137"},"text":"135 Stat. 2137","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa88aa94-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa88aa95-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaa88aa96-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Election Campaign Act of 1971, referred to in subsecs. (c)(1) and (d)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225"},"text":"Pub. L. 92–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-02-07"},"text":"Feb. 7, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/3"},"text":"86 Stat. 3","children":[],"tail":", which is classified principally to chapter 301 (§ 30101 et seq.) of Title 52, Voting and Elections. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa88aa97-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4681, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/262"},"text":"70A Stat. 262","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s512/19"},"text":"Pub. L. 96–513, title V, § 512(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2930"},"text":"94 Stat. 2930","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/b/24"},"text":"Pub. L. 107–217, § 3(b)(24)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1297"},"text":"116 Stat. 1297","children":[],"tail":", related to sale to States and certain foreign governments of surplus war material, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1253/a/1/D"},"text":"Pub. L. 114–328, div. A, title XII, § 1253(a)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2532"},"text":"130 Stat. 2532","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 4682 to 4690 were renumbered sections 7682 to 7690 of this title, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa88aa98-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1862/b"},"text":"Pub. L. 116–283, § 1862(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2335"},"text":"section 2335 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" substituted “subchapter I of chapter 273” for “section 2324”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1883/b/2"},"text":"Pub. L. 116–283, § 1883(b)(2)","children":[],"tail":", which directed that each reference in the text of title 10 to a section that was redesignated by title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", as such section was in effect before the redesignation, be amended by striking such reference and inserting a reference to the appropriate redesignated section, was not executed with respect to “section 2324”, which was redesignated as multiple sections."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “commercial products and commercial services” for “commercial items”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsecs. (c)(1), (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"52 U.S.C. 30101","children":[],"tail":" et seq.)” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t2/s431"},"text":"2 U.S.C. 431","children":[],"tail":" et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1071/f/17/A"},"text":"Pub. L. 113–291, § 1071(f)(17)(A)","children":[],"tail":", redesignated last sentence as par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1071/f/17/B/ii"},"text":"Pub. L. 113–291, § 1071(f)(17)(B)(ii)","children":[],"tail":", (iii), substituted “that term” for “the term” and “Federal Election Campaign” for “Federal Campaign”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1071/f/17/B/i"},"text":"Pub. L. 113–291, § 1071(f)(17)(B)(i)","children":[],"tail":", which directed amendment of par. (3) by inserting “"},{"tag":"inline","attrib":{},"text":"Other terms","children":[],"tail":".—” before “each of”, was executed by making the insertion before “Each of” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1071/f/17/A"},"text":"Pub. L. 113–291, § 1071(f)(17)(A)","children":[],"tail":", redesignated last sentence of par. (2) as (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa88aa99-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa88aa9a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" to take effect immediately after the amendments made by title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" have taken effect, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/a/3"},"text":"section 1701(a)(3) of Pub. L. 117–81","children":[],"tail":", set out in a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":" and note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa88aa9b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2020-01-01"},"text":"Jan. 1, 2020","children":[],"tail":", subject to a savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s836/h"},"text":"section 836(h) of Pub. L. 115–232","children":[],"tail":", set out as an Effective Date of 2018 Amendment; Savings Provision note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s453b"},"text":"section 453b of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
