{"tag":"section","attrib":{"id":"idaaa7a41d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872"},"text":null,"children":[{"tag":"num","attrib":{"value":"4872"},"text":"§ 4872.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of sensitive materials from non-allied foreign nations: prohibition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaa7a41e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsections (c) and (e), the Secretary of Defense may not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaa7a41f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure any covered material melted or produced in any covered nation, or any end item that contains a covered material manufactured in any covered nation, except as provided by subsections (c) and (e); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaa7a420-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" sell any material from the National Defense Stockpile, if the National Defense Stockpile Manager determines that such a sale is not in the national interests of the United States, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaa7a421-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any covered nation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa7a422-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any third party that the Secretary reasonably believes is acting as a broker or agent for a covered nation or an entity in a covered nation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaa7a423-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall apply to prime contracts and subcontracts at any tier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaa7a424-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a)(1) does not apply under the following circumstances:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaa7a425-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Secretary of Defense or the Secretary of the military department concerned—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaa7a426-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies a specific end item for which a specific covered material of satisfactory quality and quantity, in the required form, cannot be procured as and when needed at a reasonable price; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa7a427-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waives subsection (a)(1) for such specific end item and such specific covered material for a period not exceeding 36 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaa7a428-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the procurement of an end item described in subsection (a)(1) or the sale of any covered material described under subsection (a)(1) by the Secretary outside of the United States in support of contingency operations or for use outside of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaa7a429-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To the purchase by the Secretary of an end item containing a covered material that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaa7a42a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a commercially available off-the-shelf item (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s104"},"text":"section 104 of title 41","children":[],"tail":"), other than—"}],"tail":null},{"tag":"clause","attrib":{"id":"idaaa7a42b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commercially available off-the-shelf item that is 50 percent or more tungsten by weight; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaaa7a42c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mill product, such as bar, billet, slab, wire, cube, sphere, block, blank, plate, or sheet, that has not been incorporated into an end item, subsystem, assembly, or component;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa7a42d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an electronic device, unless the Secretary of Defense, upon the recommendation of the Strategic and Critical Materials Board of Directors pursuant to section 10 of the Strategic and Critical Materials Stock Piling Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s98h–1"},"text":"50 U.S.C. 98h–1","children":[],"tail":"), determines that the domestic availability of a particular electronic device is critical to national security;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa7a42e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a neodymium-iron-boron magnet or samarium-cobalt magnet manufactured from recycled material if the milling of the recycled material and sintering of the final magnet takes place in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa7a42f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tantalum, tungsten, or molybdenum produced from recycled material if the contractor demonstrates to the Secretary that the recycled material was produced outside of a covered nation and the melting of the recycled material and any further processing and manufacturing of the recycled material takes place in the United States or in the country of a qualifying foreign government, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4863/m/11"},"text":"section 4863(m)(11) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaa7a430-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delegation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authorities in subsection (c)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaa7a431-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be delegated to the head of contracting activity for the relevant component for an exception for a single acquisition program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaa7a432-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be delegated to the senior acquisition executive of a military department for an exception for multiple programs within such military department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaa7a433-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be delegated to the Undersecretary of Defense for Acquisition and Sustainment for an exception for more than one military department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaa7a434-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Security Waiver.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaa7a435-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsection (a), the Secretary of Defense or the Secretary of the military department concerned, may accept the delivery of an end item containing covered material manufactured in a covered nation if the Secretary determines in writing that acceptance of such end item is necessary to the national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaa7a436-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delegation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A written determination under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaa7a437-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may be delegated—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaaa7a438-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the senior acquisition executive of the military department concerned for a waiver for one or more acquisition programs within such military department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaaa7a439-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Deputy Secretary of Defense or the Under Secretary of Defense for Acquisition and Sustainment for a waiver applicable to more than one military department;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa7a43a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall specify the quantity of end items to which the waiver applies and the time period over which the waiver applies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa7a43b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be provided to the congressional defense committees prior to making such a determination (except that in the case of an urgent national security requirement, such certification may be provided to the defense committees up to 7 days after it is made).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaa7a43c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of national security waiver for strategic materials","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary of Defense or the authorized delegate has made a determination under subsection (k) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4863"},"text":"section 4863 of this title","children":[],"tail":" for a national security waiver of the restrictions under subsection (a) of that section for a specific end item, the Secretary or authorized delegate may apply that waiver to the restrictions under subsection (a) of this section for the same covered material or end item."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaa7a43d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaa7a43e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered material","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered material” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaa7a43f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" samarium-cobalt magnets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa7a440-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" neodymium-iron-boron magnets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa7a441-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tungsten metal powder;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa7a442-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tungsten heavy alloy or any finished or semi-finished component containing tungsten heavy alloy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa7a443-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/f/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tantalum metals and alloys; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa7a444-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/f/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" molybdenum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaa7a445-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered nation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered nation” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaa7a446-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Democratic People’s Republic of North Korea;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa7a447-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the People’s Republic of China;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa7a448-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Russian Federation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa7a449-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Islamic Republic of Iran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaa7a44a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4872/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"End item","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “end item” has the meaning given in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4863/m"},"text":"section 4863(m) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaa7a44b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s871/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 871(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1904"},"text":"132 Stat. 1904","children":[],"tail":", § 2533c; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVIII/s849"},"text":"Pub. L. 116–92, div. A, title VIII, § 849","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1508"},"text":"133 Stat. 1508","children":[],"tail":"; renumbered § 4872 and amended "},{"tag":"r