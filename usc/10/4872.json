70/d/2"},"text":"Pub. L. 116–283, § 1870(d)(2)","children":[],"tail":", which had initially directed the transfer of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2536"},"text":"section 2536 of this title","children":[],"tail":" to this section, was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/t/2/B"},"text":"Pub. L. 117–81, § 1701(t)(2)(B)","children":[],"tail":", (C), and, after that amendment, such transfer was no longer directed. Instead, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":", transferred "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2533c"},"text":"section 2533c of this title","children":[],"tail":" to this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2536"},"text":"section 2536 of this title","children":[],"tail":" to section 4874."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaaa7a450-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s843/1/A"},"text":"Pub. L. 119–60, § 843(1)(A)","children":[],"tail":", which directed substitution of “subsections (c) and (e)” for “subsection (c) or subsection (e)” was executed by making the substitution for “subsection (c) or (e)” in introductory provisions, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s843/1/B"},"text":"Pub. L. 119–60, § 843(1)(B)","children":[],"tail":", substituted “subsections (c) and (e)” for “subsection (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s844/a/2/B/i"},"text":"Pub. L. 119–60, § 844(a)(2)(B)(i)","children":[],"tail":", inserted “or samarium-cobalt magnet” after “neodymium-iron-boron magnet”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s844/b/2"},"text":"Pub. L. 119–60, § 844(b)(2)","children":[],"tail":", substituted “molybdenum, gallium, or germanium” for “or molybdenum”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s844/a/2/A"},"text":"Pub. L. 119–60, § 844(a)(2)(A)","children":[],"tail":", (B)(ii), (C), added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1701/a/31"},"text":"Pub. L. 119–60, § 1701(a)(31)","children":[],"tail":", which directed substitution of “the Secretary of Defense or the Secretary of the military department concerned” for “the Secretary of Defense of the Secretary or the Secretary of the military department concerned”, could not be executed because of the intervening amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s843/2/A"},"text":"Pub. L. 119–60, § 843(2)(A)","children":[],"tail":". See note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s843/2/A"},"text":"Pub. L. 119–60, § 843(2)(A)","children":[],"tail":", struck out “of the Secretary” after “the Secretary of Defense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s843/2/B"},"text":"Pub. L. 119–60, § 843(2)(B)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s844/a/1"},"text":"Pub. L. 119–60, § 844(a)(1)","children":[],"tail":", added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1)(G), (H). ","children":[{"tag":"ref","attrib