{"tag":"section","attrib":{"id":"ida807305e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s775"},"text":null,"children":[{"tag":"num","attrib":{"value":"775"},"text":"§ 775.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issue of uniform without charge","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida807305f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s775/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issue of Uniform","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may issue a uniform, without charge, to any of the following members:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8073060-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s775/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member who is being repatriated after being held as a prisoner of war.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8073061-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s775/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member who is being treated at or released from a medical treatment facility as a consequence of being wounded or injured during military hostilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8073062-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s775/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member who, as a result of the member’s duties, has unique uniform requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8073063-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s775/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other member, if the Secretary concerned determines, under exceptional circumstances, that the issue of the uniform to that member would significantly benefit the morale and welfare of the member and be advantageous to the armed force concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8073064-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s775/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention of Uniform as a Personal Item","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s771a"},"text":"section 771a of this title","children":[],"tail":", a uniform issued to a member under this section may be retained by the member as a personal item."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8073065-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tIII/s377/a/2"},"text":"Pub. L. 102–484, div. A, title III, § 377(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2386"},"text":"106 Stat. 2386","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8073066-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8073067-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida8073068-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 775 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s776"},"text":"section 776 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
