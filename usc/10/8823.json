{"tag":"section","attrib":{"id":"idab4e92f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8823"},"text":null,"children":[{"tag":"num","attrib":{"value":"8823"},"text":"§ 8823.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Admiralty claims by the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab4e92f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8823/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Navy may settle, or compromise, and receive payment of a claim by the United States for damage to property under the jurisdiction of the Department of the Navy or property for which the Department has assumed an obligation to respond for damage, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab4e92f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8823/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the claim is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab4e92f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8823/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of a kind that is within the admiralty jurisdiction of a district court of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab4e92f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8823/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for damage caused by a vessel or floating object; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4e92f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8823/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the net amount to be received by the United States is not more than $15,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab4e92f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8823/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab4e92f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8823/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In exchange for payment of an amount found to be due the United States under this section, the Secretary may execute a release of the claim on behalf of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4e92f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8823/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab4e92fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8823/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (B), amounts received under this section shall be covered into the Treasury as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab4e92fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8823/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts received under this section for damage or loss to property operated and maintained with funds from a Department of Defense working capital fund or account shall be credited to that fund or account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab4e92fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8823/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case where the amount to be received by the United States is not more than $1,000,000, the Secretary may delegate his authority under this section to any person designated by him.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab4e92fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8823/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon acceptance of payment by the Secretary, the settlement or compromise of a claim under this section is final and conclusive notwithstanding any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab4e92fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8823/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not apply to any claim while there is pending as to that claim a suit filed by or against the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab4e92ff-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/472"},"text":"70A Stat. 472","children":[],"tail":", § 7623; "},{"tag":"ref","attrib":{"href":"/us/pl/89/67"},"text":"Pub. L. 89–67","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-07"},"text":"July 7, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/212"},"text":"79 Stat. 212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXVI/s1633"},"text":"Pub. L. 101–189, div. A, title XVI, § 1633","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1608"},"text":"103 Stat. 1608","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1014/b"},"text":"Pub. L. 107–107, div. A, title X, § 1014(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1212"},"text":"115 Stat. 1212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title X, § 1032, "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4591"},"text":"122 Stat. 4591","children":[],"tail":"; renumbered § 8823, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/9"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab4e9300-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab4e9301-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab4e9302-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7623","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s600a"},"text":"34 U.S.C. 600a","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1945-12-05/ch555/s1"},"text":"Dec. 5, 1945, ch. 555, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/59/596"},"text":"59 Stat. 596","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s600d"},"text":"34 U.S.C. 600d","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1945-12-05/ch555/s4"},"text":"Dec. 5, 1945, ch. 555, § 4","children":[],"tail":"; added "},{"tag":"html:a","attrib":{"href":"/us/act/1946-08-02/ch742"},"text":"Aug. 2, 1946, ch. 742","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/806"},"text":"60 Stat. 806","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s600c"},"text":"34 U.S.C. 600c","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1945-12-05/ch555/s3"},"text":"Dec. 5, 1945, ch. 555, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/59/596"},"text":"59 Stat. 596","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words “consider, ascertain, adjust, determine” are omitted as covered by the word “settle”, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7621/b"},"text":"section 7621(b) of this title","children":[],"tail":". The words “of the United States” (following the word “property”), “by contract or otherwise”, and “thereto” are omitted as surplusage. The words “of a kind that is within the admiralty jurisdiction of” are substituted for the words “cognizable in admiralty in”. The words “receive payment of a claim * * * if the net amount to be received by the United States is not more than $1,000,000” are substituted for the words “receive in payment of any such claim the amount due the United States pursuant to determination, compromise, or settlement as herein authorized * * * "},{"tag":"i","attrib":{},"text":"Provided, further","children":[],"tail":", That no settlement or compromise where there is involved a payment in the net amount of over $1,000,000 shall be authorized by this Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b) the words “and to deliver” are omitted as covered by the word “execute”. The words “Amounts received under this section” are substituted for the words “All such payments” for clarity and uniformity. The words “of the United States as miscellaneous receipts” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c) the words “In any case where the amount to be received by the United States is not more than” are substituted for the words “Where the net amount received in settlement does not exceed” for clarity, since the delegation of authority necessarily precedes receipt of payment. The words “the Secretary may delegate his authority” are substituted for the words “the authority of the Secretary of the Navy * * * may be exercised” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d) the words “but not until then”, “for all purposes”, and “to the contrary” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (e) is worded to insure that the effect of a suit pending at any time is preserved and that the provision is not interpreted to apply only to suits that are pending on the date of enactment of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The first proviso of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s600a"},"text":"34 U.S.C. 600a","children":[],"tail":", stating that this section is supplementary to, and not in lieu of, other laws authorizing the settlement of claims, is omitted as unnecessary, since the other applicable claims laws are restated in this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab4e9303-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab4e9304-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 8841 and 8842, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/192"},"text":"Pub. L. 85–861, § 1(192)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1535"},"text":"72 Stat. 1535","children":[],"tail":", related to separation or transfer to Retired Reserve of female reserve nurses and medical specialists at age 50 if in a Reserve grade below major and at age 55 if in a Reserve grade above captain, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/86/559/s1/66"},"text":"Pub. L. 86–559, § 1(66)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-06-30"},"text":"June 30, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/278"},"text":"74 Stat. 278","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 8843 to 8846 were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1629/c/3"},"text":"Pub. L. 103–337, div. A, title XVI, § 1629(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2963"},"text":"108 Stat. 2963","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 8843, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/192"},"text":"Pub. L. 85–861, § 1(192)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1535"},"text":"72 Stat. 1535","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/86/599/s1/67"},"text":"Pub. L. 86–599, § 1(67)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-06-30"},"text":"June 30, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/278"},"text":"74 Stat. 278","children":[],"tail":", related to transfer or discharge of reserve commissioned officers 60 years of age and below grade of major general. See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s14510"},"text":"section 14510 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 8844, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/192"},"text":"Pub. L. 85–861, § 1(192)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/153