{"tag":"section","attrib":{"id":"idaac1e42a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6161"},"text":null,"children":[{"tag":"num","attrib":{"value":"6161"},"text":"§ 6161.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual Selected Acquisition Reports on certain hardware relating to defense nuclear nonproliferation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaac1e42b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6161/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Selected Acquisition Reports","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac1e42c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6161/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the end of each fiscal year, the Administrator shall submit to the congressional defense committees a report on each covered hardware project. The reports shall be known as Selected Acquisition Reports for the covered hardware project concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac1e42d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6161/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The information contained in the Selected Acquisition Report for a fiscal year for a covered hardware project shall be the information contained in the Selected Acquisition Report for such fiscal year for a major defense acquisition program under section 4351 or any successor system, expressed in terms of the covered hardware project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac1e42e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6161/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Hardware Project Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered hardware project” means a project carried out under the defense nuclear nonproliferation research and development program that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac1e42f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6161/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is focused on the production and deployment of hardware, including with respect to the development and deployment of satellites or satellite payloads; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac1e430-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6161/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exceeds $500,000,000 in total program cost over the course of five years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac1e431-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1385"},"text":"139 Stat. 1385","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac1e432-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac1e433-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac1e434-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6161 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8271"},"text":"section 8271 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2577"},"text":"section 2577 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaac1e435-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) and (2) headings which read as follows: “"},{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":"” and “"},{"tag":"inline","attrib":{},"text":"Matters included","children":[],"tail":"”, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
