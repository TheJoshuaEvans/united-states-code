{"tag":"section","attrib":{"id":"ida8b2d9cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1252"},"text":null,"children":[{"tag":"num","attrib":{"value":"1252"},"text":"§ 1252.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Age 64: permanent professors at academies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8b2d9cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1252/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mandatory Retirement for Age","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless retired or separated earlier, each regular commissioned officer of the Army, Navy, Air Force, Marine Corps, or Space Force covered by subsection (b) shall be retired on the first day of the month following the month in which the officer becomes 64 years of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8b2d9cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1252/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Officers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies to the following officers:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8b2d9ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1252/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who is a permanent professor or the director of admissions of the United States Military Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8b2d9cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1252/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who is a permanent professor at the United States Naval Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8b2d9d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1252/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who is a permanent professor or the registrar of the United States Air Force Academy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8b2d9d1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s509/c/1"},"text":"Pub. L. 109–163, div. A, title V, § 509(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3230"},"text":"119 Stat. 3230","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/3/U"},"text":"Pub. L. 116–283, div. A, title IX, § 924(b)(3)(U)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3821"},"text":"134 Stat. 3821","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8b2d9d2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8b2d9d3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8b2d9d4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Marine Corps, or Space Force” for “or Marine Corps”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
