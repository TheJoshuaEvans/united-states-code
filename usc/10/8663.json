{"tag":"section","attrib":{"id":"idab390efc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8663"},"text":null,"children":[{"tag":"num","attrib":{"value":"8663"},"text":"§ 8663.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number in service in time of peace","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In time of peace, the President may keep in service such vessels of the Navy as are required and keep the rest in reserve.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab390efd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/449"},"text":"70A Stat. 449","children":[],"tail":", § 7293; renumbered § 8663, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/2"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab390efe-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab390eff-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab390f00-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text"