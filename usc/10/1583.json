{"tag":"section","attrib":{"id":"ida8f7f8b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1583"},"text":null,"children":[{"tag":"num","attrib":{"value":"1583"},"text":"§ 1583.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment of certain persons without pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense and the Secretaries of the military departments may each employ, without pay, not more than 10 persons of outstanding experience and ability. However, a person so employed may be allowed transportation, and not more than $15 a day instead of subsistence, while away from his home or regular place of business pursuant to employment under this section.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida8f7f8b3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/118"},"text":"70A Stat. 118","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s14"},"text":"Pub. L. 89–718, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1117"},"text":"80 Stat. 1117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s1/20/A"},"text":"Pub. L. 97–295, § 1(20)(A)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1290"},"text":"96 Stat. 1290","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tXI/s1111"},"text":"Pub. L. 112–81, div. A, title XI, § 1111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"