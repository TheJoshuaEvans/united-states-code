{"tag":"section","attrib":{"id":"idabca7938-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20233"},"text":null,"children":[{"tag":"num","attrib":{"value":"20233"},"text":"§ 20233.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for consideration for promotion: designation as joint qualified officer required before promotion to brigadier general; exceptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabca7939-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20233/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer on the Space Force officer list may not be appointed to the grade of brigadier general unless the officer has been designated as a joint qualified officer in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s661"},"text":"section 661 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabca793a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20233/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (c), the Secretary of Defense may waive subsection (a) in the following circumstances:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabca793b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20233/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When necessary for the good of the service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabca793c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20233/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an officer whose proposed selection for promotion is based primarily upon scientific and technical qualifications for which joint requirements do not exist.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabca793d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20233/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of an officer selected by a promotion board for appointment to the grade of brigadier general while serving in a joint duty assignment if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabca793e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20233/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer’s total consecutive service in joint duty assignments is not less than two years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabca793f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20233/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer has successfully completed a program of education described in subsections (b) and (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2155"},"text":"section 2155 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabca7940-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20233/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of an officer who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabca7941-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20233/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is selected by a promotion board for appointment to the grade of brigadier general;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabca7942-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20233/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not exempted under subsection (g); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabca7943-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20233/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has successfully completed the education requirements prescribed in subparagraph (A) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s661/c/1"},"text":"section 661(c)(1) of this title","children":[],"tail":" but has not been afforded the opportunity to complete the experience requirements described in subparagraph (B) of that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabca7944-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20233/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver to Be Individual","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A waiver may be granted under subsection (b) only on a case-by-case basis in the case of an individual officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabca7945-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20233/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Rule for Good-of-the-service Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a waiver under subsection (b)(1), the Secretary of Defense shall provide that the first duty assignment as a general officer of the officer for whom the waiver is granted shall be in a joint duty assignment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabca7946-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20233/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Delegation of Waiver Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority of the Secretary of Defense to grant a waiver under subsection (b)(4) may only be delegated as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s619a/e"},"text":"section 619a(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabca7947-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20233/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe regulations to carry out this section. The regulations shall specifically identify for purposes of subsection (b)(2) those categories of officers for which selection for promotion to brigadier general is based primarily upon scientific and technical qualifications for which joint requirements do not exist.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabca7948-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20233/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall not apply to an officer who transfers to the Space Force from a reserve component before the first day of the sixth fiscal year beginning after the date of the enactment of this section, and who, as of the date of the transfer, is serving in the grade of major, lieutenant colonel, or colonel or, in the case of the Navy or Coast Guard, lieutenant commander, commander, or captain.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabca7949-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1716/c"},"text":"Pub. L. 118–31, div. A, title XVII, § 1716(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/642"},"text":"137 Stat. 642","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabca794a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabca794b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idabca794c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (g), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
