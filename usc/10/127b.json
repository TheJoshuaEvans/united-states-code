{"tag":"section","attrib":{"id":"ida751e9c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b"},"text":null,"children":[{"tag":"num","attrib":{"value":"127b"},"text":"§ 127b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Defense rewards program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida751e9c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may pay a monetary amount, or provide a payment-in-kind, to a person as a reward for providing United States Government personnel, or government personnel of allied forces participating in a combined operation with the armed forces, with information or nonlethal assistance that is beneficial to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida751e9c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an operation or activity of the armed forces, or of allied forces participating in a combined operation with the armed forces, conducted outside the United States against international terrorism; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida751e9c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" force protection of the armed forces, or of allied forces participating in a combined operation with the armed forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida751e9c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount or value of a reward provided under this section may not exceed $5,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida751e9c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delegation of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida751e9ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The authority of the Secretary of Defense under subsection (a) may be delegated only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida751e9cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Deputy Secretary of Defense and an Under Secretary of Defense, without further redelegation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida751e9cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the commander of a combatant command, but only for a reward in an amount or with a value not in excess of $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida751e9cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A commander of a combatant command to whom authority to provide rewards under this section is delegated under paragraph (1) may further delegate that authority, but only for a reward in an amount or with a value not in excess of $10,000, except that such a delegation may be made to the commander’s deputy commander, or to the commander of a command directly subordinate to that commander, without regard to such limitation. Such a delegation may be made to the commander of a command directly subordinate to the commander of a combatant command only with the approval of the Secretary of Defense, the Deputy Secretary of Defense, or an Under Secretary of Defense to whom authority has been delegated under subparagraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida751e9ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida751e9cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subparagraph (B), an official who has authority delegated under paragraph (1) or (2) may use that authority, acting through government personnel of allied forces, to offer and make rewards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida751e9d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall prescribe policies and procedures for making rewards in the manner described in subparagraph (A), which shall include guidance for the accountability of funds used for making rewards in that manner. The policies and procedures shall not take effect until 30 days after the date on which the Secretary submits the policies and procedures to the congressional defense committees. Rewards may not be made in the manner described in subparagraph (A) except under policies and procedures that have taken effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida751e9d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida751e9d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall prescribe policies and procedures for the offering and making of rewards under this section and otherwise for administering the authority under this section. Such policies and procedures shall be prescribed in consultation with the Secretary of State and the Attorney General and shall ensure that the making of a reward under this section does not duplicate or interfere with the payment of a reward authorized by the Secretary of State or the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida751e9d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall consult with the Secretary of State regarding the making of any reward under this section in an amount or with a value in excess of $2,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida751e9d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Persons Not Eligible","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following persons are not eligible to receive a reward under this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida751e9d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A citizen of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida751e9d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer or employee of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida751e9d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee of a contractor of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida751e9d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida751e9d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than February 1 of each year, the Secretary of Defense shall submit to the Committees on Armed Services of the Senate and the House of Representatives a report on the administration of the rewards program under this section during the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida751e9da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each report for a fiscal year under this subsection shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida751e9db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information on the total amount expended during that fiscal year to carry out the rewards program under this section during that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida751e9dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Specification of the amount, if any, expended during that fiscal year to publicize the availability of rewards under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida751e9dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to each reward provided during that fiscal year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida751e9de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/f/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount or value of the reward and whether the reward was provided as a monetary payment or in some other form;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida751e9df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/f/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient of the reward and the recipient’s geographic location; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida751e9e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/f/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the information or assistance for which the reward was paid, together with an assessment of the significance and benefit of the information or assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida751e9e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the status of program implementation in each geographic combatant command, including in which countries the program is being operated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida751e9e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of efforts to coordinate and de-conflict the authority under subsection (a) with similar rewards programs administered by the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida751e9e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/f/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the effectiveness of the program in meeting its objectives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida751e9e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may submit the report in classified form if the Secretary determines that it is necessary to do so.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida751e9e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determinations by the Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A determination by the Secretary under this section is final and conclusive and is not subject to judicial review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida751e9e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report on Designation of Countries for Which Rewards May Be Paid","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 15 days after the date on which the Secretary designates a country as a country in which an operation or activity of the armed forces is occurring in connection with which rewards may be paid under this section, the Secretary shall submit to the Committees on Armed Services of the Senate and the House of Representatives a report on the designation. Each report shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida751e9e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The country so designated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida751e9e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The reason and justification for the designation of the country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida751e9e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127b/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An estimate of the amount or value of the rewards to be paid as monetary payment or payment-in-kind under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida751e9ea-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tX/s1065/a"},"text":"Pub. L. 107–314, div. A, title X, § 1065(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2655"},"text":"116 Stat. 2655","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1056/c/2"},"text":"Pub. L. 109–163, div. A, title X, § 1056(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3439"},"text":"119 Stat. 3439","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tXIV/s1401"},"text":"Pub. L. 109–364, div. A, title XIV, § 1401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2433"},"text":"120 Stat. 2433","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tX/s1033"},"text":"Pub. L. 110–181, div. A, title X, § 1033","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/307"},"text":"122 Stat. 307","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tX/s1071"},"text":"Pub. L. 111–84, div. A, title X, § 1071","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2470"},"text":"123 Stat. 2470","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1031"},"text":"Pub. L. 111–383, div. A, title X, § 1031","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4351"},"text":"124 Stat. 4351","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tX"},"text":"Pub. L. 112–81, div. A, title X","children":[],"tail":", §§ 1033, 1064(3), "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1572"},"text":"125 Stat. 1572","children":[],"tail":", 1587; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1021/a"},"text":"Pub. L. 112–239, div. A, title X, § 1021(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1911"},"text":"126 Stat. 1911","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1031"},"text":"Pub. L. 113–291, div. A, title X, § 1031","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3491"},"text":"128 Stat. 3491","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tX/s1042/a"},"text":"Pub. L. 114–92, div. A, title X, § 1042(a)","children":[],"tail":"–(d)(1), "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/976"},"text":"129 Stat. 976","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tX/s1063"},"text":"Pub. L. 114–328, div. A, title X, § 1063","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2408"},"text":"130 Stat. 2408","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida751e9eb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida751e9ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida751e9ed-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (h)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1063/1"},"text":"Pub. L. 114–328, § 1063(1)","children":[],"tail":", inserted “and justification” after “reason”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1063/2"},"text":"Pub. L. 114–328, § 1063(2)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) read as follows: “A justification for the designation of the country for purposes of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s1042/d/1"},"text":"Pub. L. 114–92, § 1042(d)(1)","children":[],"tail":", substituted “Department of Defense rewards program” for “Assistance in combating terrorism: rewards” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s1042/a/1"},"text":"Pub. L. 114–92, § 1042(a)(1)","children":[],"tail":", substituted “subparagraph (B)” for “subparagraphs (B) and (C)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s1042/a/2"},"text":"Pub. L. 114–92, § 1042(a)(2)","children":[],"tail":", struck out subpars. (C) and (D) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) Rewards may not be made in the manner described in subparagraph (A) after ","children":[{"tag":"date","attrib":{"date":"2015-09-30"},"text":"September 30, 2015","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) Not later than ","children":[{"tag":"date","attrib":{"date":"2008-04-01"},"text":"April 1, 2008","children":[],"tail":", the Secretary of Defense shall submit to the congressional defense committees a report on the implementation of this paragraph. The report shall identify each reward made in the manner described in subparagraph (A) and, for each such reward—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) identify the type, amount, and recipient of the reward;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) explain the reason for making the reward; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iii) assess the success of the reward in advancing the effort to combat terrorism.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2)(D) to (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s1042/b"},"text":"Pub. L. 114–92, § 1042(b)","children":[],"tail":", redesignated subpars. (E) to (G) as (D) to (F), respectively, inserted “, including in which countries the program is being operated” before period at end of subpar. (D), and struck out former subpar. (D) which read as follows: “Information on the implementation of paragraph (3) of subsection (c).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s1042/c"},"text":"Pub. L. 114–92, § 1042(c)","children":[],"tail":", added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2015-09-30"},"text":"September 30, 2015","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2014-09-30"},"text":"September 30, 2014","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (c)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2014-09-30"},"text":"September 30, 2014","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2013-09-30"},"text":"September 30, 2013","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (c)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s1033/1"},"text":"Pub. L. 112–81, § 1033(1)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2013-09-30"},"text":"September 30, 2013","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2011-09-30"},"text":"September 30, 2011","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" substituted “2011” for “2010”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s1064/3"},"text":"Pub. L. 112–81, § 1064(3)","children":[],"tail":", which directed the substitution of “February 1” for “December 1”, could not be executed because of the intervening amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/s1033/2/A"},"text":"Pub. L. 112–81, § 1033(2)(A)","children":[],"tail":". See note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s1033/2/A"},"text":"Pub. L. 112–81, § 1033(2)(A)","children":[],"tail":", substituted “February” for “December”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s1033/2/B/i"},"text":"Pub. L. 112–81, § 1033(2)(B)(i)","children":[],"tail":", inserted “and the recipient’s geographic location” after “reward”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2)(E) to (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s1033/2/B/ii"},"text":"Pub. L. 112–81, § 1033(2)(B)(ii)","children":[],"tail":", added subpars. (E) to (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (c)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" substituted “2010” for “2009”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1033/b/1/A"},"text":"Pub. L. 110–181, § 1033(b)(1)(A)","children":[],"tail":", in introductory provisions, inserted “, or government personnel of allied forces participating in a combined operation with the armed forces,” after “United States Government personnel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1033/b/1/B"},"text":"Pub. L. 110–181, § 1033(b)(1)(B)","children":[],"tail":", inserted “, or of allied forces participating in a combined operation with the armed forces,” after “armed forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1033/b/1/C"},"text":"Pub. L. 110–181, § 1033(b)(1)(C)","children":[],"tail":", inserted “, or of allied forces participating in a combined operation with the armed forces” after “armed forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1033/a/1"},"text":"Pub. L. 110–181, § 1033(a)(1)","children":[],"tail":", substituted “$5,000,000” for “$200,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1033/a/2"},"text":"Pub. L. 110–181, § 1033(a)(2)","children":[],"tail":", substituted “$1,000,000” for “$50,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1033/b/2"},"text":"Pub. L. 110–181, § 1033(b)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1033/a/3"},"text":"Pub. L. 110–181, § 1033(a)(3)","children":[],"tail":", substituted “$2,000,000” for “$100,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1033/c"},"text":"Pub. L. 110–181, § 1033(c)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" substituted “$10,000” for “$2,500”, inserted “, or to the commander of a command directly subordinate to that commander,” after “deputy commander”, and inserted at end “Such a delegation may be made to the commander of a command directly subordinate to the commander of a combatant command only with the approval of the Secretary of Defense, the Deputy Secretary of Defense, or an Under Secretary of Defense to whom authority has been delegated under subparagraph (1)(A).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “Such policies” for “Such polices”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida75459ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida75459ef-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2021-12-31"},"text":"Dec. 31, 2021","chil