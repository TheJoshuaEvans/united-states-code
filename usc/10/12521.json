{"tag":"section","attrib":{"id":"idaba4536a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12521"},"text":null,"children":[{"tag":"num","attrib":{"value":"12521"},"text":"§ 12521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba4536b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12521/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “insurance program” means the Ready Reserve Mobilization Income Insurance Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12522"},"text":"section 12522 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba4536c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12521/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered service” means active duty performed by a member of a reserve component under an order to active duty for a period of more than 30 days which specifies that the member’s service—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaba4536d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12521/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in support of an operational mission for which members of the reserve components have been ordered to active duty without their consent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaba4536e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12521/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in support of forces activated during a period of war declared by Congress or a period of national emergency declared by the President or Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba4536f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12521/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “insured member” means a member of the Ready Reserve who is enrolled for coverage under the insurance program in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12524"},"text":"section 12524 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba45370-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12521/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba45371-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12521/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Department” means the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba45372-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12521/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Board of Actuaries” means the Department of Defense Board of Actuaries under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s183"},"text":"section 183 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"t