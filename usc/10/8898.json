{"tag":"section","attrib":{"id":"idab534de6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8898"},"text":null,"children":[{"tag":"num","attrib":{"value":"8898"},"text":"§ 8898.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restricted certificate","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Navy may restrict a certificate issued under this chapter so that it stays only the taking of testimony of certain witnesses or the production of evidence on certain subjects. The proceedings not stayed may continue.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab534de7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/485"},"text":"70A Stat. 485","children":[],"tail":", § 7728; renumbered § 8898, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/10"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab534de8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab534de9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab534dea-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}]