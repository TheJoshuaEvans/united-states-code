{"tag":"section","attrib":{"id":"idab9ade2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12213"},"text":null,"children":[{"tag":"num","attrib":{"value":"12213"},"text":"§ 12213.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers; Army Reserve: transfer from Army National Guard of the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab9ade2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12213/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under such regulations as the Secretary of the Army may prescribe, and with the consent of the governor or other appropriate authority of the State concerned, an officer of the Army National Guard of the United States may be transferred in grade to the Army Reserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab9ade2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12213/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Unless discharged from his appointment as a Reserve, an officer of the Army National Guard of the United States whose Federal recognition as a member of the Army National Guard is withdrawn becomes a member of the Army Reserve. An officer who so becomes a member of the Army Reserve ceases to be a member of the Army National Guard of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab9ade2e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/194"},"text":"70A Stat. 194","children":[],"tail":", § 3352; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/80/A"},"text":"Pub. L. 85–861, § 1(80)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1468"},"text":"72 Stat. 1468","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/559/s1/7"},"text":"Pub. L. 86–559, § 1(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-06-30"},"text":"June 30, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/265"},"text":"74 Stat. 265","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXII/s1234/a/1"},"text":"Pub. L. 100–456, div. A, title XII, § 1234(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2059"},"text":"102 Stat. 2059","children":[],"tail":"; renumbered § 12213 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI"},"text":"Pub. L. 103–337, div. A, title XVI","children":[],"tail":", §§ 1636(a), 1662(c)(3), 1675(b)(2), "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2968"},"text":"108 Stat. 2968","children":[],"tail":", 2990, 3017; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1501/b/13/A"},"text":"Pub. L. 104–106, div. A, title XV, § 1501(b)(13)(A)","children":[],"tail":", (14), "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/496"},"text":"110 Stat. 496","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab9ade2f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab9ade30-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab9ade31-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"