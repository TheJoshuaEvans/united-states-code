{"tag":"section","attrib":{"id":"idab17a3f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8267"},"text":null,"children":[{"tag":"num","attrib":{"value":"8267"},"text":"§ 8267.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform: sale to former members of the naval service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab17a3f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8267/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under such regulations as the Secretary of the Navy prescribes, exterior articles of uniform may be sold to a person who has been discharged from the naval service honorably or under honorable conditions. This section does not modify section 772 or 773 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab17a3f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8267/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Money received from sales under this section shall be covered into the Treasury to the credit of the appropriation out of which the articles were purchased.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab17a3f8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/386"},"text":"70A Stat. 386","children":[],"tail":", § 6156; renumbered § 8267, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/10"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1835"},"text":"132