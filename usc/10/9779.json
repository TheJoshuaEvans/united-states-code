{"tag":"section","attrib":{"id":"idab855a2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9779"},"text":null,"children":[{"tag":"num","attrib":{"value":"9779"},"text":"§ 9779.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of public property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab855a30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9779/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the economy of the Air Force or the Space Force so requires, the Secretary of the Air Force shall establish military headquarters in places where suitable buildings are owned by the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab855a31-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9779/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No money appropriated for the support of the Air Force or the Space Force may be spent for base gardens or Air Force exchanges. However, this does not prevent Air Force exchanges from using public buildings or public transportation that, in the opinion of the Secretary, are not needed for other purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab855a32-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/591"},"text":"70A Stat. 591","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dB/tVII/s2721"},"text":"Pub. L. 99–661, div. B, title VII, § 2721","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4042"}