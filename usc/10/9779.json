"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9779(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9779(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1332.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1345.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1879-06-23/ch35/s8"},"text":"June 23, 1879, ch. 35, § 8","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/21/35"},"text":"21 Stat. 35","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9779(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1335.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1914-08-01/ch223"},"text":"Aug. 1, 1914, ch. 223","children":[],"tail":" (2d par. under “Quartermaster Corps”), "},{"tag":"html:a","attrib":{"href":"/us/stat/38/629"},"text":"38 Stat. 629","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1892-07-16/ch195"},"text":"July 16, 1892, ch. 195","children":[],"tail":" (last proviso under “Quartermaster’s Department”), "},{"tag":"html:a","attrib":{"href":"/us/stat/27/178"},"text":"27 Stat. 178","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1950-06-28/ch383/s402/c"},"text":"June 28, 1950, ch. 383, § 402(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/272"},"text":"64 Stat. 272","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “United States” are substituted for the word “Government”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “suitable space” are substituted for the words “proper and suitable room or rooms”. The words “there is a” are substituted for the words “have been established”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “the Secretary” are substituted for the words “the Quartermaster General”, since the functions which, for the Army, are assigned by statute to subordinate officers of the Army, are, for the Air Force, assigned to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab855a36-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab855a37-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/19/A"},"text":"Pub. L. 116–283, § 923(e)(19)(A)","children":[],"tail":", inserted “or the Space Force” after “economy of the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/19/B"},"text":"Pub. L. 116–283, § 923(e)(19)(B)","children":[],"tail":", inserted “or the Space Force” after “support of the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" redesignated subsec. (c) as (b) and struck out former subsec. (b) which directed the Secretary to assign suitable space for postal purposes at each air base where there was a post office."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
