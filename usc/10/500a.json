{"tag":"section","attrib":{"id":"ida7cb8652-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500a"},"text":null,"children":[{"tag":"num","attrib":{"value":"500a"},"text":"§ 500a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance on electromagnetic spectrum operations mission area and joint electromagnetic spectrum operations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7cb8653-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish processes and procedures to develop, integrate, and enhance the electromagnetic spectrum operations mission area and the conduct of joint electromagnetic spectrum operations in all domains across the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb8654-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that such processes and procedures provide for integrated defense-wide strategy, planning, and budgeting with respect to the conduct of such operations by the Department, including activities conducted to counter and deter such operations by malign actors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7cb8655-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVI/s1682/a"},"text":"Pub. L. 118–31, div. A, title XVI, § 1682(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/613"},"text":"137 Stat. 613","children":[],"tail":", § 501; renumbered § 500a, "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVII/s1701/a/10"},"text":"Pub. L. 118–159, div. A, title XVII, § 1701(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2203"},"text":"138 Stat. 2203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7cb8656-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7cb8657-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7cb8658-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s501"},"text":"section 501 of this title","children":[],"tail":", relating to guidance on electromagnetic spectrum operations mission area and joint electromagnetic spectrum operations, as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
