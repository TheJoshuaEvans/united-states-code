{"tag":"section","attrib":{"id":"idab797309-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9453"},"text":null,"children":[{"tag":"num","attrib":{"value":"9453"},"text":"§ 9453.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cadets: degree and commission on graduation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab79730a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9453/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Superintendent of the Academy may, under such conditions as the Secretary of the Air Force may prescribe, confer the degree of bachelor of science upon graduates of the Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab79730b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9453/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, a cadet who completes the prescribed course of instruction may, upon graduation, be appointed a second lieutenant in the Regular Air Force under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s531"},"text":"section 531 of this title","children":[],"tail":" or a second lieutenant in the Space Force under section 531 or 20201 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab79730c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/567"},"text":"70A Stat. 567","children":[],"tail":", § 9353; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":", §§ 1(201), 33(a)(43), "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children"