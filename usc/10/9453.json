, 1947, ch. 512, § 506(f)","children":[],"tail":" (1st sentence, less last 43 words), "},{"tag":"html:a","attrib":{"href":"/us/stat/61/892"},"text":"61 Stat. 892","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the last 27 words are substituted for 10:486a (last sentence). The words “rules and” and “from and after the date of the accrediting of said Academy” are omitted as surplusage. The word “conditions” is substituted for the word “regulations”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “except ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s541"},"text":"section 541 of this title","children":[],"tail":"” are inserted to reflect the authority to appoint graduates of one service academy as officers of another service."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab797310-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab797311-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1958 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children"