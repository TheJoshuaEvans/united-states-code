{"tag":"section","attrib":{"id":"idaab11a9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4981"},"text":null,"children":[{"tag":"num","attrib":{"value":"4981"},"text":"§ 4981.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of loan guarantee program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaab11a9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4981/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to meet the national security objectives in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4811/a"},"text":"section 4811(a) of this title","children":[],"tail":", the Secretary of Defense shall establish a program under which the Secretary may issue guarantees assuring lenders against losses of principal or interest, or both principal and interest, for loans made to qualified commercial firms to fund, in whole or in part, any of the following activities:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab11a9e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4981/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The improvement of the protection of the critical infrastructure of the commercial firms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab11a9f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4981/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The refinancing of improvements previously made to the protection of the critical infrastructure of the commercial firms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab11aa0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4981/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified Commercial Firms","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, a qualified commercial firm is a company or other business entity (including a consortium of such companies or other business entities, as determined by the Secretary) that the Secretary determines—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab11aa1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4981/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducts a significant level of its research, development, engineering, and manufacturing activities in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab11aa2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4981/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is a company or other business entity the majority ownership or control of which is by United States citizens or is a company or other business of a parent company that is incorporated in a country the government of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaab11aa3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4981/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourages the participation of firms so owned or controlled in research and development consortia to which the government of that country provides funding directly or provides funding indirectly through international organizations or agreements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab11aa4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4981/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affords adequate and effective protection for the intellectual property rights of companies incorporated in the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab11aa5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4981/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides technology products or services critical to the operations of the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab11aa6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4981/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets standards of prevention of cyberterrorism applicable to the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab11aa7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4981/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees to submit the report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4985"},"text":"section 4985 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab11aa8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4981/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Loan Limits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The maximum amount of loan principal guaranteed during a fiscal year under this section may not exceed $10,000,000, with respect to all borrowers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab11aa9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4981/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Goals and Standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe regulations setting forth goals for the use of the loan guarantees provided under this section and standards for evaluating whether those goals are met by each entity receiving such loan guarantees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab11aaa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4981/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority Subject to Provisions of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may guarantee a loan under this subchapter only to such extent or in such amounts as may be provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaab11aab-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1033(a)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–258, § 2541; renumbered § 4981 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII"},"text":"Pub. L. 116–283, div. A, title XVIII","children":[],"tail":", §§ 1873(b), (c)(2), (e)(1), 1883(b)(2), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4290"},"text":"134 Stat. 4290","children":[],"tail":", 4294; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/d/19"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(d)(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2138"},"text":"135 Stat. 2138","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaab11aac-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaab11aad-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaab11aae-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1873/b"},"text":"Pub. L. 116–283, § 1873(b)","children":[],"tail":", (c)(2), renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2541"},"text":"section 2541 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","