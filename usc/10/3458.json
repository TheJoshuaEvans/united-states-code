{"tag":"section","attrib":{"id":"idaa26db47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3458"},"text":null,"children":[{"tag":"num","attrib":{"value":"3458"},"text":"§ 3458.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to acquire innovative commercial products and commercial services using general solicitation competitive procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa26db48-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3458/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense and each Secretary of a military department may acquire commercial products, commercial services, or nondevelopmental items through a competitive selection of proposals resulting from a general solicitation and a peer review, technical review, or operational review (as appropriate) of such proposals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa26db49-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3458/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment as Competitive Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Use of general solicitation competitive procedures under subsection (a) shall be considered to be use of competitive procedures for purposes of chapter 221 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa26db4a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3458/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Follow-on Production Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a product, service, or item acquired through the competitive procedures described under subsection (a), the Secretary of Defense or each Secretary of a military department may enter into—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa26db4b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3458/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a follow-on production contract (including a sole source contract), subject to the approval requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3204/e"},"text":"section 3204(e) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa26db4c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3458/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a follow-on production contract or transaction, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4022"},"text":"section 4022 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa26db4d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3458/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa26db4e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3458/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contracts or agreements entered into using the authority under subsection (a) shall be fixed-price, including fixed-price incentive contracts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa26db4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3458/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3451/1"},"text":"section 3451(1) of this title","children":[],"tail":", products and services acquired using the authority under subsection (a) shall be treated as commercial products and commercial services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa26db50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3458/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Notification Required","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa26db51-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3458/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 45 days after the award of a contract for an amount exceeding $100,000,000 using the authority in subsection (a), the Secretary shall notify the congressional defense committees of such award.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa26db52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3458/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notice of an award under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa26db53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3458/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Description of the commercial product, commercial service, or nondevelopmental item acquired.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa26db54-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3458/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Description of the requirement, capability gap, or potential technological advancement with respect to which the commercial product, commercial service, or nondevelopmental item acquired provides a solution or a potential new capability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa26db55-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3458/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amount of the contract awarded.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa26db56-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3458/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identification of the contractor awarded the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa26db57-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added § 2380c, renumbered § 3458, and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVIII/s803/a/1"},"text":"Pub. L. 117–81, div. A, title VIII, § 803(a)(1)","children":[],"tail":", (b)(1), (3), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1814-1816"},"text":"135 Stat. 1814–1816","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVIII/s814/a"},"text":"Pub. L. 117–263, div. A, title VIII, § 814(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2707"},"text":"136 Stat. 2707","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVIII/s1823"},"text":"Pub. L. 119–60, div. A, title XVIII, § 1823","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1247"},"text":"139 Stat. 1247","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa26db58-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa26db59-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa26db5a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1823/1"},"text":"Pub. L. 119–60, § 1823(1)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, text read as follows: “The Secretary of Defense and the Secretaries of the military departments may acquire innovative commercial products and commercial services through a competitive selection of proposals resulting from a general solicitation and the peer review of such proposals.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1823/4"},"text":"Pub. L. 119–60, § 1823(4)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1823/5"},"text":"Pub. L. 119–60, § 1823(5)","children":[],"tail":", redesignated pars. (2) and (3) as (1) and (2), respectively, and struck out former par. (1) which read as follows: “The Secretary may not enter into a contract or agreement in excess of $100,000,000 using the authority under subsection (a) without a written determination from the Under Secretary of Defense for Acquisition and Sustainment or the relevant service acquisition executive of the efficacy of the effort to meet mission needs of the Department of Defense or the relevant military department.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1823/3"},"text":"Pub. L. 119–60, § 1823(3)","children":[],"tail":", redesignated subsec. (c) as (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1823/2"},"text":"Pub. L. 119–60, § 1823(2)","children":[],"tail":", (3), redesignated subsec. (d) as (e) and struck out former subsec. (e). Text of former subsec. (e) read as follows: “In this section, the term ‘innovative’ means—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) any technology, process, or method, including research and development, that is new as of the date of submission of a proposal; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) any application that is new as of the date of submission of a proposal of a technology, process, or method existing as of such date.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1823/6"},"text":"Pub. L. 119–60, § 1823(6)","children":[],"tail":", substituted “commercial product, commercial service, or nondevelopmental item” for “innovative commercial product or commercial service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “fixed-price incentive contracts” for “fixed-price incentive fee contracts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s803/b/1"},"text":"Pub. L. 117–81, § 803(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2380c"},"text":"section 2380c of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s803/b/3/A"},"text":"Pub. L. 117–81, § 803(b)(3)(A)","children":[],"tail":", substituted “chapter 221” for “chapter 137”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s803/b/3/B"},"text":"Pub. L. 117–81, § 803(b)(3)(B)","children":[],"tail":", substituted “section 3451(1)” for “section 2376(1)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa26db5b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa26db5c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVIII/s803/b/4"},"text":"Pub. L. 117–81, div. A, title VIII, § 803(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1816"},"text":"135 Stat. 1816","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dA/tVIII/s803/b/4"},"text":"“The transfer, redesignation, and amendments made by this subsection [amending this section and repealing provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2302"},"text":"section 2302 of this title","children":[],"tail":"] shall take [sic] as if included in title XVIII of the William M. (Mac) Thornberry National Defense Authorization Act for Fiscal Year 2021 ("},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Public Law 116–283","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa26db5d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Focused Commercial Solutions Openings Opportunities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tVIII/s813"},"text":"Pub. L. 118–31, div. A, title VIII, § 813","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/325"},"text":"137 Stat. 325","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVIII/s1802/b/1/A"},"text":"Pub. L. 119–60, div. A, title XVIII, § 1802(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1227"},"text":"139 Stat. 1227","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tXVIII/s1802/b/1/A"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"During each fiscal year beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":"], the Secretary of Defense, in coordination with the service acquisition executives of each military department, shall exercise the authority under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3458"},"text":"section 3458 of title 10","children":[],"tail":", United States Code, not less than four times to acquire goods or services addressing the mission needs of a geographic combatant command."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Execution","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to acquisition carried out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3458"},"text":"section 3458 of title 10","children":[],"tail":", United States Code, pursuant to subsection (a), the Secretary of Defense shall—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assign the responsibility for carrying out such acquisition to a portfolio acquisition executive and a head of a science and technology reinvention laboratory from the same military department, who shall co-lead such acquisition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the portfolio acquisition executive and the head of a science and technology reinvention laboratory assigned as co-leads under paragraph (1) have similar existing requirements and funding for transitioning technologies to acquisition programs within the area of focus for such acquisition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall expire on ","children":[{"tag":"date","attrib":{"date":"2027-09-30"},"text":"September 30, 2027","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms ‘military department’ and ‘services acquisition executive’ have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a"},"text":"section 101(a) of title 10","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘portfolio acquisition executive’ has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1737/a"},"text":"section 1737(a) of title 10","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘science and technology reinvention laboratory’ means a science and technology reinvention laboratory designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4121/b"},"text":"section 4121(b) of title 10","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa26db5e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Data Collection","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVIII/s803/a/3"},"text":"Pub. L. 117–81, div. A, title VIII, § 803(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1815"},"text":"135 Stat. 1815","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dA/tVIII/s803/a/3"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense and each Secretary of a military department shall collect and analyze data on the use of the authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2380c"},"text":"section 2380c of title 10","children":[],"tail":", United States Code [now "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3458"},"text":"10 U.S.C. 3458","children":[],"tail":"], as added by paragraph (1), for the purposes of—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and sharing best practices for achieving the objectives of the authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gathering information on the implementation of the authority and related policy issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informing the congressional defense committees on the use of the authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority under section 2380c [now 3458] of title 10, United States Code, as added by paragraph (1), may not be exercised by the Secretary of Defense or any Secretary of a military department during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2022-10-01"},"text":"October 1, 2022","children":[],"tail":", and ending on the date on which the Secretary of Defense submits to the congressional defense committees a completed plan for carrying out the data collection required un