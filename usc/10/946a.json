{"tag":"section","attrib":{"id":"ida8348114-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a"},"text":null,"children":[{"tag":"num","attrib":{"value":"946a"},"text":"§ 946a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 146a. Annual reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8348115-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Court of Appeals for the Armed Forces","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than December 31 each year, the Court of Appeals for the Armed Forces shall submit a report that, with respect to the previous fiscal year, provides information on the number and status of completed and pending cases before the Court, and such other matters as the Court considers appropriate regarding the operation of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8348116-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than December 31 each year, the Judge Advocates General and the Staff Judge Advocate to the Commandant of the Marine Corps shall each submit a report, with respect to the preceding fiscal year, containing the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8348117-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Data on the number and status of pending cases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8348118-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Data on the number and status of completed cases, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8348119-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on race, ethnicity, rank, and sex demographic for the victim and the accused;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida834811a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enumerated offenses preferred and referred;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida834811b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of court-martial; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida834811c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results for each case, including cases that resulted in nonjudicial punishment or administrative separation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida834811d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Information on the appellate review process, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida834811e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on compliance with processing time goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida834811f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" descriptions of the circumstances surrounding cases in which general or special court-martial convictions were (i) reversed because of command influence or denial of the right to speedy review or (ii) otherwise remitted because of loss of records of trial or other administrative deficiencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8348120-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of each case in which a provision of this chapter was held unconstitutional; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8348121-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of each case in which a Court of Criminal Appeals made a final determination that a finding of a court-martial was clearly against the weight of the evidence, including an explanation of the standard of appellate review applied in such case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8348122-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8348123-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An explanation of measures implemented by the armed force concerned to ensure the ability of judge advocates—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8348124-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to participate competently as trial counsel and defense counsel in cases under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8348125-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to preside as military judges in cases under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8348126-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/b/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to perform the duties of Special Victims’ Counsel, when so designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1044e"},"text":"section 1044e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8348127-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The explanation under subparagraph (A) shall specifically identify the measures that focus on capital cases, national security cases, sexual assault cases, and proceedings of military commissions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8348128-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The independent views of each Judge Advocate General and of the Staff Judge Advocate to the Commandant of the Marine Corps as to the sufficiency of resources available within the respective armed forces, including total workforce, funding, training, and officer and enlisted grade structure, to capably perform military justice functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8348129-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other matters regarding the operation of this chapter as may be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida834812a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under this section shall be submitted—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida834812b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Committee on Armed Services of the Senate and the Committee on Armed Services of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida834812c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Secretary of Defense, the Secretaries of the military departments, and the Secretary of the department in which the Coast Guard is operating when it is not operating as a service in the Navy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida834812d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLXII/s5522"},"text":"Pub. L. 114–328, div. E, title LXII, § 5522","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2964"},"text":"130 Stat. 2964","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tV/s542/d"},"text":"Pub. L. 116–283, div. A, title V, § 542(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3612"},"text":"134 Stat. 3612","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s566/a"},"text":"Pub. L. 118–159, div. A, title V, § 566(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1904"},"text":"138 Stat. 1904","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida834812e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida834812f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8348130-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(2) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" added par. (2) and redesignated former pars. (2) to (5) as (3) to (6), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" added subpar. (D)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8348131-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8348132-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on ","children":[{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
