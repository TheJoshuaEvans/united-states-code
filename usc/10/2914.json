{"tag":"section","attrib":{"id":"ida9f989b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914"},"text":null,"children":[{"tag":"num","attrib":{"value":"2914"},"text":"§ 2914.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military construction projects for energy resilience, energy security, and energy conservation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9f989b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project Authorization Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may carry out such military construction projects for energy resilience, energy security, and energy conservation as are authorized by law, using funds appropriated or otherwise made available for that purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9f989b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of Project Proposals","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9f989ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As part of the Department of Defense Form 1391 submitted to the appropriate committees of Congress for a military construction project covered by subsection (a), the Secretary of Defense shall include the following information:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9f989bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The project title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9f989bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The location of the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9f989bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A brief description of the scope of work.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9f989be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The original project cost estimate and the current working cost estimate, if different.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9f989bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other information as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9f989c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a military construction project for energy conservation, the Secretary also shall include the following information:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9f989c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The original expected savings-to-investment ratio and simple payback estimates and measurement and verification cost estimate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9f989c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The most current expected savings-to-investment ratio and simple payback estimates and measurement and verification plan and costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9f989c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A brief description of the measurement and verification plan and planned funding source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9f989c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a military construction project for energy resilience or energy security, the Secretary also shall include the rationale for how the project would enhance mission assurance, support mission critical functions, and address known vulnerabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9f989c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternative Funding Source","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9f989c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In addition to the authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2805/c"},"text":"section 2805(c) of this title","children":[],"tail":", in carrying out a military construction project for energy resilience, energy security, or energy conservation under this section, the Secretary concerned may use amounts available for operation and maintenance for the military department concerned if the Secretary concerned submits to the congressional defense committees a notification of the decision to carry out the project using such amounts and includes in the notification—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9f989c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current estimate of the cost of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9f989c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the source of funds for the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9f989c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that deferring the project pending the availability of funds appropriated for or otherwise made available for military construction would be inconsistent with the timely assurance of energy resilience, energy security, or energy conservation for one or more critical national security functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9f989ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A project carried out under this section using amounts under paragraph (1) may be carried out only after the end of the seven-day period beginning on the date on which a copy of the notification described in paragraph (1) is provided in an electronic medium pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s480"},"text":"section 480 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9f989cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The maximum aggregate amount that the Secretary concerned may obligate from amounts available to the military department concerned for operation and maintenance in any fiscal year for projects under the authority of this subsection is $100,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9f989cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relation to Certain Other Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project under this section may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9f989cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities related to a utility system authorized under subsections (h), (j), and (k) of section 2688 or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2913"},"text":"section 2913 of this title","children":[],"tail":", notwithstanding that the United States does not own the utility system covered by the project; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9f989ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy-related activities included as a separate requirement in an energy savings performance contract (as defined in section 804(3) of the National Energy Conservation Policy Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8287c/3"},"text":"42 U.S.C. 8287c(3)","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9f989cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incorporation of Cybersecurity Supply Chain Risk Management Tools and Methods","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9f989d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall incorporate into covered projects cybersecurity supply chain risk management tools and solutions to provide continuous analysis, monitoring, and mitigation of cyber vulnerabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9f989d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out the requirements of paragraph (1), the Secretary of Defense shall consider, to the maximum extent practicable, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9f989d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The adoption of commercially available cybersecurity supply chain risk management tools and solutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9f989d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The inclusion of existing databases on cyber vulnerabilities when selecting such tools and solutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9f989d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The need for such tools and methods to provide continuous analysis, monitoring, and mitigation of cyber vulnerabilities in covered projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9f989d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Beginning with fiscal year 2026, documentation for any new requirements for cybersecurity supply chain risk management in annual guidance for covered projects that is submitted along with the annual budget request of the President submitted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9f989d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the term “covered project” means a project connected to a Department of Defense Information Network for which funds are made available under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9f989d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2914/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application to Military Construction Projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall apply to military construction projects covered by subsection (a) for which a Department of Defense Form 1391 is submitted to the appropriate committees of Congress in connection with the budget of the Department of Defense for fiscal year 2023 and thereafter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9f989d8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dB/tXXVIII/s2851/a/1"},"text":"Pub. L. 109–364, div. B, title XXVIII, § 2851(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2493"},"text":"120 Stat. 2493","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dB/tXXVIII/s2805/a/1"},"text":"Pub. L. 114–328, div. B, title XXVIII, § 2805(a)(1)","children":[],"tail":", (b)(1)(A), (2), "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2713"},"text":"130 Stat. 2713","children":[],"tail":", 2714; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dB/tXXVIII"},"text":"Pub. L. 115–91, div. B, title XXVIII","children":[],"tail":", §§ 2801(e)(1), 2831(c)(1), "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1845"},"text":"131 Stat. 1845","children":[],"tail":", 1857; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tX/s1081/a/29"},"text":"Pub. L. 115–232, div. A, title X, § 1081(a)(29)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1985"},"text":"132 Stat. 1985","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dB/tXXVIII"},"text":"Pub. L. 116–283, div. B, title XXVIII","children":[],"tail":", §§ 2805(a), 2823(b), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4321"},"text":"134 Stat. 4321","children":[],"tail":", 4333; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dB/tXXVIII/s2804"},"text":"Pub. L. 117–81, div. B, title XXVIII, § 2804","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2188"},"text":"135 Stat. 2188","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dB/tXXVIII/s2809"},"text":"Pub. L. 118–31, div. B, title XXVIII, § 2809","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/746"},"text":"137 Stat. 746","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9f989d9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9f989da-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9f989db-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" added subsec. (e) and redesignated former subsec. (e) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s2805/a"},"text":"Pub. L. 116–283, § 2805(a)","children":[],"tail":", amended section generally. Prior to amendment, section related to energy resilience and conservation construction projects."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s2823/b"},"text":"Pub. L. 116–283, § 2823(b)","children":[],"tail":", added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s2804/1"},"text":"Pub. L. 117–81, § 2804(1)","children":[],"tail":", redesignated subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “resilience” for “resiliency” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s2831/c/1"},"text":"Pub. L. 115–91, § 2831(c)(1)","children":[],"tail":", substituted “energy resilience” for “energy resiliency” wherever appearing in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s2801/e/1"},"text":"Pub. L. 115–91, § 2801(e)(1)","children":[],"tail":", struck out “in writing” after “shall notify” and “or, if earlier, the end of the 14-day period beginning on the date on which a copy of the notification is provided” after “received by such committees” and substituted “14-day period” for “21-day period”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s2805/a/1/A"},"text":"Pub. L. 114–328, § 2805(a)(1)(A)","children":[],"tail":", inserted “resiliency and” before “conservation construction projects” in section catchline. Text quoted in directory language of amendment was editorially conformed to the style of the catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s2805/a/1/B"},"text":"Pub. L. 114–328, § 2805(a)(1)(B)","children":[],"tail":", substituted “military construction project for energy resiliency, energy security, or energy conservation” for “military construction project for energy conservation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s2805/b/1/A"},"text":"Pub. L. 114–328, § 2805(b)(1)(A)","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s2805/b/2"},"text":"Pub. L. 114–328, § 2805(b)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9f989dc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9f989dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dB/tXXVIII/s2805/b/1/B"},"text":"Pub. L. 114–328, div. B, title XXVIII, § 2805(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2714"},"text":"130 Stat. 2714","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/328/dB/tXXVIII/s2805/b/1/B"},"text":"“The amendment made by subparagraph (A) [amending this section] shall apply with respect to notifications provided during fiscal year 2017 or any succeeding fiscal year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
