{"tag":"section","attrib":{"id":"ida8858768-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1079a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1079a"},"text":"§ 1079a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" TRICARE program: treatment of refunds and other amounts collected","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All refunds and other amounts collected in the administration of the TRICARE program shall be credited to the appropriation available for that program for the fiscal year in which the refund or amount is collected.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida8858769-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tVII/s733/a/1"},"text":"Pub. L. 104–201, div. A, title VII, § 733(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2597"},"text":"110 Stat. 2597","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVII/s701/j/1/D"},"text":"Pub. L. 114–328, div. A, title VII, § 701(j)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2192"},"text":"130 Stat. 2192","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida885876a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida885876b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida885876c-3a6f