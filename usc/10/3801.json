{"tag":"section","attrib":{"id":"idaa39eed2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3801"},"text":null,"children":[{"tag":"num","attrib":{"value":"3801"},"text":"§ 3801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of agency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa39eed3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3801/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of any agency may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa39eed4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3801/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make advance, partial, progress, or other payments under contracts for property or services made by the agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa39eed5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3801/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insert in solicitations for procurement of property or services a provision limiting to small business concerns advance or progress payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa39eed6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3801/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment Dates for Contractors That Are Small Business Concerns.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa39eed7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3801/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prime contractors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For a prime contractor (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s8701"},"text":"section 8701 of title 41","children":[],"tail":") that is a small business concern (as defined in section 3 of the Small Business Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"15 U.S.C. 632","children":[],"tail":")), the Secretary of Defense shall, to the fullest extent permitted by law, establish an accelerated payment date with a goal of 15 days after receipt of a proper invoice for the amount due."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa39eed8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3801/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subcontractors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For a prime contractor that subcontracts with a small business concern, the Secretary of Defense shall, to the fullest extent permitted by law, establish an accelerated payment date with a goal of 15 days after receipt of a proper invoice for the amount due if the prime contractor agrees to make payments to the subcontractor in accordance with the accelerated payment date, to the maximum extent practicable, without any further consideration from or fees charged to the subcontractor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa39eed9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1834/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1834(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4234"},"text":"134 Stat. 4234","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa39eeda-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa39eedb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa39eedc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2307"},"text":"section 2307 of this title","children":[],"tail":", which was transferred to this section and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1834/b"},"text":"Pub. L. 116–283, § 1834(b)","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/131"},"text":"70A Stat. 131","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/800/s9"},"text":"Pub. L. 85–800, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-28"},"text":"Aug. 28, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/967"},"text":"72 Stat. 967","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/tII/s2001/a/2"},"text":"Pub. L. 103–355, title II