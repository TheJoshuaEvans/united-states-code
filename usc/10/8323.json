ag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s410b"},"text":"34 U.S.C. 410b","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-02-21/ch34/s6"},"text":"Feb. 21, 1946, ch. 34, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/27"},"text":"60 Stat. 27","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6323(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s410b–1"},"text":"34 U.S.C. 410b–1","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-04-14/ch52/s1"},"text":"Apr. 14, 1949, ch. 52, § 1","children":[],"tail":" (less applicability to "},{"tag":"html:a","attrib":{"href":"/us/act/1948-06-29/ch708/s301/b"},"text":"Act of June 29, 1948, ch. 708, § 301(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/62/1087"},"text":"62 Stat. 1087","children":[],"tail":"), "},{"tag":"html:a","attrib":{"href":"/us/stat/63/47"},"text":"63 Stat. 47","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b) the words “or the Reserve Components thereof” are omitted because the terms “Navy”, “Marine Corps”, and “Coast Guard” include the reserve components. The words “including active duty for training” are omitted because the term “active duty” is defined in this title as including training duty.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Act of ","children":[{"tag":"date","attrib":{"date":"1949-04-14"},"text":"April 14, 1949","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t34/s410b–1"},"text":"34 U.S.C. 410b–1","children":[],"tail":"), extending the benefits of "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s410b"},"text":"34 U.S.C. 410b","children":[],"tail":" to officers on the honorary retired lists, was enacted because the Comptroller General had held that these officers, being already in a retired status, could not be retired under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s410b"},"text":"34 U.S.C. 410b","children":[],"tail":" (U.S. Code Congressional Service, 1949, p. 1179). The provisions of the Naval Reserve Act of 1938 relating to the honorary retired lists were repealed by § 803 of the Armed Forces Reserve Act of 1952, but insofar as they provided for retirement and retired pay they were reenacted, for a period of 20 years, in § 413 of that act ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1052"},"text":"50 U.S.C. 1052","children":[],"tail":"). Persons on the honorary retired lists when the Armed Forces Reserve Act of 1952 was passed were transferred to the appropriate Retired Reserve under § 213 of the Act. Persons qualifying for retirement under § 413 are likewise placed in the Retired Reserve. The purpose of Congress in enacting § 413 was to preserve the accrued rights of persons who were members of reserve components on "},{"tag":"date","attrib":{"date":"1953-01-01"},"text":"January 1, 1953","children":[],"tail":", the effective date of the Act (U.S. Code Congressional and Administrative News, 1952, p. 3584). One of their rights was the right to apply for retirement under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s410b"},"text":"34 U.S.C. 410b","children":[],"tail":" upon completion of the required service, notwithstanding the fact that, before qualifying for retirement under that section, they had already acquired a retired status. Subsection (c) is worded accordingly."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab1c8678-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab1c8679-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1958 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6323(a), (b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"34 App.:410b.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1955-08-04/ch553/s1"},"text":"Aug. 4, 1955, ch. 553, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/69/493"},"text":"69 Stat. 493","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1955-08-09/ch678/s1/a"},"text":"Aug. 9, 1955, ch. 678, § 1(a)","children":[],"tail":", (b), "},{"tag":"html:a","attrib":{"href":"/us/stat/69/614"},"text":"69 Stat. 614","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6323(c), (e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6323(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6323(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “armed forces” are substituted for the words “Navy, Marine Corps, Army, Air Force, or Coast Guard, or the Reserve Components thereof” because “armed forces”, as defined in this title, is a collective term for these elements.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsections (c) and (e) state rules, formerly stated in section 6325, with respect to officers retired under this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (d) states a rule, formerly stated in section 6325, with respect to warrant officers retired under this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (c) and (e), the words “Unless otherwise entitled to a higher grade” and “Unless otherwise entitled to higher pay” are substituted for 34 App.:410c(b).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the second and third provisos of 34 App.:410b, relating to officers whose basic pay is not based on years of service, is omitted as obsolete. Under the Career Compensation Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s231"},"text":"37 U.S.C. 231","children":[],"tail":" et seq.), the basic pay of all officers is based on years of service. The subsection is worded to conform to the terminology of the Career Compensation Act of 1949 and to make clear the fact that the amount of retired pay is not permanently fixed at the time of retirement but is subject to change when rates of basic pay are changed, as provided in 34 App.:410q."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (f) was formerly subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab1c867a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idab1c867b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 213(b) of the Armed Forces Reserve Act of 1952 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/66/485"},"text":"66 Stat. 485","children":[],"tail":"), referred to in subsec. (f), was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s933"},"text":"section 933 of Title 50","children":[],"tail":", War and National Defense, and was repealed by section 53 of act "},{"tag":"date","attrib":{"date":"1956-08-10"},"text":"Aug. 10, 1956","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab1c867c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “section 1370 or 1370a of this title, as applicable” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1370"},"text":"section 1370 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s807/b/15"},"text":"Pub. L. 115–232, § 807(b)(15)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6323"},"text":"section 6323 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 8333” for “section 6333”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 8327” for “section 6327”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1076/e/6"},"text":"Pub. L. 112–239, § 1076(e)(6)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"January 7, 2011","children":[],"tail":",” for “the date of the enactment of the Ike Skelton National Defense Authorization Act for Fiscal Year 2011”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s505/b"},"text":"Pub. L. 112–239, § 505(b)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2018-09-30"},"text":"September 30, 2018","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2013-09-30"},"text":"September 30, 2013","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" substituted “the date of the enactment of the Ike Skelton National Defense Authorization Act for Fiscal Year 2011 and ending on "},{"tag":"date","attrib":{"date":"2013-09-30"},"text":"September 30, 2013","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"January 6, 2006","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2008-12-31"},"text":"December 31, 2008","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" struck out second comma after “subparagraph (B)” in subpar. (A) and substituted “"},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"January 6, 2006","children":[],"tail":",” for “the date of the enactment of the National Defense Authorization Act for Fiscal Year 2006” in subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s502/b"},"text":"Pub. L. 109–163, § 502(b)","children":[],"tail":", designated existing provisions as subpar. (A), substituted “during the period specified in subparagraph (B),” for “during the period beginning on "},{"tag":"date","attrib":{"date":"1990-10-01"},"text":"October 1, 1990","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2001-12-31"},"text":"December 31, 2001","children":[],"tail":"”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s515/b/1/H"},"text":"Pub. L. 109–163, § 515(b)(1)(H)","children":[],"tail":", substituted “Navy Reserve” for “Naval Reserve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2001-12-31"},"text":"December 31, 2001","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2001-09-30"},"text":"September 30, 2001","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":