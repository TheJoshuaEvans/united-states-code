{"tag":"section","attrib":{"id":"ida959c891-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2265"},"text":null,"children":[{"tag":"num","attrib":{"value":"2265"},"text":"§ 2265.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to broadband internet access service for certain members of the armed forces","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of a military department may provide, to a member of the armed forces who resides in military unaccompanied housing (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2871"},"text":"section 2871 of this title","children":[],"tail":") within the United States, broadband internet access service, at no cost to such member."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida959c892-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVI/s651/a"},"text":"Pub. L. 118–159, div. A, title VI, § 651(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1938"},"text":"138 Stat. 1938","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida959c893-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida959c894-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida959c895-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Guidance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVI/s651/b"},"text":"Pub. L. 118–159, div. A, title VI, § 651(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1938"},"text":"138 Stat. 1938","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tVI/s651/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than 90 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"], the Secretary of Defense shall issue policy and guidance for implementation of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2265"},"text":"section 2265 of title 10","children":[],"tail":", United States Code, as added by this section, that—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets or exceeds any speed benchmark established for broadband internet access service by the Federal Communications Commission under section 706 of the Telecommunications Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1302"},"text":"47 U.S.C. 1302","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximizes access to such service in individual rooms and spaces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allows reasonable internet access, subject to appropriate restrictions applicable to other internet access provided by the Secretary to members of the Armed Forces.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
