{"tag":"section","attrib":{"id":"ida8d8fef6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481"},"text":null,"children":[{"tag":"num","attrib":{"value":"1481"},"text":"§ 1481.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery, care, and disposition of remains: decedents covered","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8d8fef7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary concerned may provide for the recovery, care, and disposition of the remains of the following persons:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8d8fef8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any Regular of an armed force under his jurisdiction who dies while on active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d8fef9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member of a reserve component of an armed force who dies while—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8d8fefa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on active duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8d8fefb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing inactive-duty training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8d8fefc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing authorized travel directly to or from active duty or inactive-duty training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8d8fefd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remaining overnight immediately before the commencement of inactive-duty training, or remaining overnight, between successive periods of inactive-duty training, at or in the vicinity of the site of the inactive-duty training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8d8fefe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" staying at the member’s residence, when so authorized by proper authority, during a period of inactive duty training or between successive days of inactive duty training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8d8feff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hospitalized or undergoing treatment for an injury, illness, or disease incurred or aggravated while on active duty or performing inactive-duty training; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8d8ff00-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8d8ff01-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a/2/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving on funeral honors duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12503"},"text":"section 12503 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s115"},"text":"section 115 of title 32","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8d8ff02-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a/2/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" traveling directly to or from the place at which the member is to so serve; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8d8ff03-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a/2/G/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remaining overnight at or in the vicinity of that place before so serving, if the place is outside reasonable commuting distance from the member’s residence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"status":"repealed","id":"ida8d8ff04-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"[(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tVI/s604/e/3/B"},"text":"Pub. L. 99–661, div. A, title VI, § 604(e)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3877"},"text":"100 Stat. 3877","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d8ff05-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any member of, or applicant for membership in, a reserve officers’ training corps who dies while (A) attending a training camp, (B) on an authorized practice cruise, (C) performing authorized travel to or from such a camp or cruise, or (D) hospitalized or undergoing treatment at the expense of the United States for injury incurred, or disease contracted, while attending such a camp, while on such a cruise, or while performing that travel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d8ff06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any accepted applicant for enlistment in an armed force under his jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d8ff07-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who has been discharged from an enlistment in an armed force under his jurisdiction while a patient in a United States hospital, and who continues to be such a patient until the date of his death.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d8ff08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8d8ff09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dies as a retired member of an armed force under the Secretary’s jurisdiction during a continuous hospitalization of the member as a patient in a United States hospital that began while the member was on active duty for a period of more than 30 days; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8d8ff0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not covered by subparagraph (A) and, while in a retired status by reason of eligibility to retire under chapter 61 of this title, dies during a continuous hospitalization of the person that began while the person was on active duty as a Regular of an armed force under the Secretary’s jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d8ff0b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any military prisoner who dies while in his custody.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d8ff0c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1482/f"},"text":"section 1482(f) of this title","children":[],"tail":", any retired member of an armed force who dies while outside the United States or any individual who dies outside the United States while a dependent of such a member."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d8ff0d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1482/g"},"text":"section 1482(g) of this title","children":[],"tail":", any person not otherwise covered by the preceding paragraphs whose remains (or partial remains) have been retained by the Secretary concerned for purposes of a forensic pathology investigation by the Armed Forces Medical Examiner under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1471"},"text":"section 1471 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d8ff0e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person not otherwise covered by this section whose death entitles a survivor of such person to a death gratuity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1475"},"text":"section 1475 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8d8ff0f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section applies to each person covered by subsection (a)(1)–(7) even though he may have been temporarily absent from active duty, with or without leave, at the time of his death, unless he had been dropped from the rolls of his organization before his death.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8d8ff10-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1481/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section, the term “dependent” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072/2"},"text":"section 1072(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8d8ff11-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/112"},"text":"70A Stat. 112","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/647/tIII/s301/3"},"text":"Pub. L. 88–647, title III, § 301(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1071"},"text":"78 Stat. 1071","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tVI/s604/e/3"},"text":"Pub. L. 99–661, div. A, title VI, § 604(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3877"},"text":"100 Stat. 3877","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tVI/s652/a/1"},"text":"Pub. L. 103–337, div. A, title VI, § 652(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2793"},"text":"108 Stat. 2793","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tVII/s702/b"},"text":"Pub. L. 104–106, div. A, title VII, § 702(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/371"},"text":"110 Stat. 371","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tV/s513/e"},"text":"Pub. L. 105–85, div. A, title V, § 513(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1732"},"text":"111 Stat. 1732","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tVI/s645/a"},"text":"Pub. L. 105–261, div. A, title VI, § 645(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2049"},"text":"112 Stat. 2049","children":[],"tail":", 2050; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s578/i/5"},"text":"Pub. L. 106–65, div. A, title V, § 578(i)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/630"},"text":"113 Stat. 630","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1087(d)(3)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–293; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s513/c"},"text":"Pub. L. 107–107, div. A, title V, § 513(c)","children":[],"tail":", title VI, § 638(b)(2), "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1093"},"text":"115 Stat. 1093","children":[],"tail":", 1147; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s651/b"},"text":"Pub. L. 112–81, div. A, title VI, § 651(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1467"},"text":"125 Stat. 1467","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tVI/s651/a/1"},"text":"Pub. L. 113–66, div. A, title VI, § 651(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/787"},"text":"127 Stat. 787","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVI/s631/b"},"text":"Pub. L. 118–159, div. A, title VI, § 631(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1936"},"text":"138 Stat. 1936","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8d8ff12-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8d8ff13-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida8d8ff14-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1481(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5:2151 (as applicable to armed forces).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"5:2152 (1st 27 words, as applicable to armed forces).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"5:2153 (less 1st 18 words, as applicable to armed forces).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1954-07-15/ch507"},"text":"July 15, 1954, ch. 507","children":[],"tail":", §§ 1, 2 (1st 25 words, as applicable to armed forces), 3 (less 1st 16 words, as applicable to armed forces), 4 (as applicable to armed forces), "},{"tag":"html:a","attrib":{"href":"/us/stat/68/478"},"text":"68 Stat. 478","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1481(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5:2154 (as applicable to armed forces).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), 5:2151 is omitted as covered by the revised sections of this chapter. In clauses (1), (2), (5)–(7), the words “under his jurisdiction” are inserted for clarity. In clause (1) the words “regular member of an armed force, or member of an armed force without component” are substituted for the words “military personnel”, since all other members of the military services are covered by more specific rules set forth in clauses (2) and (7). In clauses (2) and (3), the words “active duty for training” are omitted as covered by the words “active duty”. The words “injury incurred, or disease contracted” are substituted for the words “injuries, illness, or disease contracted or incurred”. The words “by law”, “authorized”, “proper authority”, and “as authorized by law” are omitted as surplusage. In clause (3), the words “while entitled to” are substituted for the words “in respect of duty for which they are entitled by law to receive”. In clause (4), the words “injury incurred, or disease contracted” are substituted for the words “injury, disease or illness contracted or incurred”. The words “as authorized by law” are omitted as surplusage. In clause (6), the word “person” is substituted for the words “former enlisted members”. In clause (7), the words “active duty for a period of more than 30 days” are substituted for the words “extended active duty”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “This section applies to each person * * * even though” are substituted for the words “The benefits of this Act shall not be denied in respect of a person * * * on the ground”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8d8ff15-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8d8ff16-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" added par. (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" added par. (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(2)(E) to (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" added subpar. (E) and redesignated former subpars. (E) and (F) as (F) and (G), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s513/c"},"text":"Pub. L. 107–107, § 513(c)","children":[],"tail":", struck out “, if the site is outside reasonable commuting distance from the member’s residence” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s638/b/2"},"text":"Pub. L. 107–107, § 638(b)(2)","children":[],"tail":", substituted “section 1482(f)” for “section 1482(g)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/s645/b"},"text":"Pub. L. 105–261, § 645(b)","children":[],"tail":". See 1998 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/s645/b"},"text":"Pub. L. 105–261, § 645(b)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":", struck out “, or member of an armed force without component,” after “Regular of an armed force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/s645/a"},"text":"Pub. L. 105–261, § 645(a)","children":[],"tail":", amended par. (7) generally. Prior to amendment, par. (7) read as follows: “Any retired member of an armed force under his jurisdiction who becomes a patient in a United States hospital while he is on active duty for a period of more than 30 days, and who continues to be such a patient until the date of his death.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" inserted “remaining overnight immediately before the commencement of inactive-duty training, or” after “(D)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2)(C) to (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" struck out “or” at end of subpar. (C), added subpar. (D), and redesignated former subpar. (D) as (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s652/a/1/A"},"text":"Pub. L. 103–337, § 652(a)(1)(A)","children":[],"tail":", substituted “the remains of the following persons:” for “the remains of—”, capitalized the first letter of the first word in pars. (1) to (8), substituted a period for the last semicolon in pars. (1) to (6), substituted a period for “; and” in par. (7), and added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s652/a/1/B"},"text":"Pub. L. 103–337, § 652(a)(1)(B)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" added par. (2) and struck out former pars. (2) and (3) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) any Reserve of an armed force under his jurisdiction who dies while (A) on active duty, (B) performing authorized travel to or from that duty, (C) on authorized inactive-duty training, or (D) hospitalized or undergoing treatment at the expense of the United States for injury incurred, or disease contracted, while on that duty or training or while performing that travel;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) any member of the Army National Guard or Air National Guard who dies while entitled to pay from the United States and while (A) on active duty, (B) performing authorized travel to or from that duty, (C) on authorized inactive-duty training, or (D) hospitalized or undergoing treatment at the expense of the United States for injury incurred, or disease contracted, while on that duty or training or while performing that travel;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/647"},"text":"Pub. L. 88–647","children":[],"tail":" substituted “, or applicant for membership in, a reserve officers’ training corps” for “the Army Reserve Officers’ Training Corps, Naval Reserve Officers’ Training Corps, or Air Force Reserve Officers’ Training Corps”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8d8ff17-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8d8ff18-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" applicable to a death that occurs on or after "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/s631/d"},"text":"section 631(d) of Pub. L. 118–159","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1475"},"text":"section 1475 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8d8ff19-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", and applicable with respect to deaths that occur on or after that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/s651/c"},"text":"section 651(c) of Pub. L. 112–81","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1475"},"text":"section 1475 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8d8ff1a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1087(d)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–292, provided that the amendment made by section 1 [[div. A], title X, § 1087(d)(3)] is effective "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", and as if included in the Strom Thurmond National Defense Authorization Act for Fiscal Year 1999, "},{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":"Pub. L. 105–261","children":[],"tail":", as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8d8ff1b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tVI/s645/c"},"text":"Pub. L. 105–261, div. A, title VI, § 645(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2050"},"text":"112 Stat. 2050","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/261/dA/tVI/s645/c"},"text":"“The amendment made by subsection (a) [amending this section] applies with respect to deaths occurring on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8d8ff1c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tVI/s652/a/3"},"text":"Pub. L. 103–337, div. A, title VI, § 652(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2794"},"text":"108 Stat. 2794","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/337/dA/tVI/s652/a/3"},"text":"“The amendments made by this subsection [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1482"},"text":"section 1482 of this title","children":[],"tail":"] shall apply with respect to the remains of, and incidental expenses incident to the recovery, care, and disposition of, an individual who dies after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8d8ff1d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" applicable with respect to persons who, after "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", incur or aggravate an injury, illness, or disease or die, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/s604/g"},"text":"section 604(g) of Pub. L. 99–661","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1074a"},"text":"section 1074a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8d8ff1e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Requirement for Deploying Military Medical Personnel To Be Trained in Preservation of Remains Under Combat or Combat-Related Conditions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s567"},"text":"Pub. L. 109–364, div. A, title V, § 567","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2224"},"text":"120 Stat. 2224","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/364/dA/tV/s567"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of each military department shall ensure that each military health care professional under that Secretary’s jurisdiction who is deployed to a theater of combat operations is trained, before such deployment, in the preservation of remains under combat or combat-related conditions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matters Covered by Training","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The training under subsection (a) shall include, at a minimum, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Best practices and procedures for the preservation of the remains of a member of the Armed Forces after death, taking into account the conditions likely to be encountered and the objective of returning the remains to the member’s family in the best possible condition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Practical case studies based on experience of the Armed Forces in a variety of climactic conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Military Health Care Professionals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term ‘military health care professional’ means—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a physician, nurse, nurse practitioner, physician assistant, or combat medic; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other medical personnel with medical specialties who may provide direct patient care and who are designated by the Secretary of the military department concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall apply with respect to any military health care professional who is deployed to a theater of combat operations after the end of the 90-day period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
