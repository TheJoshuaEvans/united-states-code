{"tag":"section","attrib":{"id":"idaaf8ab4d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7594"},"text":null,"children":[{"tag":"num","attrib":{"value":"7594"},"text":"§ 7594.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Furnishing of heraldic services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaf8ab4e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7594/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations to be prescribed by the Secretary of the Army, an authority designated by him may, upon the request of, and subject to approval by, the Secretary of another military department, design flags, insignia, badges, medals, seals, decorations, guidons, streamers, finial pieces for flagstaffs, buttons, buckles, awards, trophies, marks, emblems, rosettes, scrolls, braids, ribbons, knots, tabs, cords, and similar items for the requesting department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf8ab4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7594/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon request the Secretary of the Army may advise other departments and agencies of the United States on matters of heraldry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf8ab50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7594/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army may prescribe regulations providing for reimbursement for services furnished under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaf8ab51-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/263/s1/1"},"text":"Pub. L. 85–263, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-09-02"},"text":"Sept. 2, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/589"},"text":"71 Stat. 589","children":[],"tail":", § 4594; renumbered § 7594, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/d"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaf8ab52-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaf8ab53-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaaf8ab54-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4594"},"text":"section 4594 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaaf8ab55-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaaf8ab56-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaaf8ab57-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/263/s2"},"text":"Pub. L. 85–263, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-09-02"},"text":"Sept. 2, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/589"},"text":"71 Stat. 589","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/85/263/s2"},"text":"“This Act [enacting this section] takes effect on the first day of the first month after the month in which it is enacted [September 1957].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
