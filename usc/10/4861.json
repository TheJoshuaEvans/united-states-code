"href":"/us/pl/116/283/dA/tXVIII/s1870/c/2"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1870(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4285"},"text":"134 Stat. 4285","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaa077c3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaaa077c4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section is based on ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/365/tVII/s707"},"text":"Pub. L. 93–365, title VII, § 707","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-05"},"text":"Aug. 5, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/406"},"text":"88 Stat. 406","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaa077c5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaaa077c6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2533"},"text":"section 2533 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" substituted “chapter 83 of such title” for “such Act” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/b/37/A"},"text":"Pub. L. 111–350, § 5(b)(37)(A)","children":[],"tail":", substituted “chapter 83 of title 41” for “the Buy American Act” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/b/37/B"},"text":"Pub. L. 111–350, § 5(b)(37)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t41/s8302"},"text":"section 8302 of title 41","children":[],"tail":"” for “section 2 of the Buy American Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s10a"},"text":"41 U.S.C. 10a","children":[],"tail":")” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s10a"},"text":"41 U.S.C. 10a","children":[],"tail":")” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s10a"},"text":"41 U.S.C. 10a","children":[],"tail":"))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" substituted “the Buy American Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s10a"},"text":"41 U.S.C. 10a","children":[],"tail":")) whether application of such Act” for “title III of the Act of "},{"tag":"date","attrib":{"date":"1993-03-03"},"text":"March 3, 1993","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s10a"},"text":"41 U.S.C. 10a","children":[],"tail":"), popularly known as the ‘Buy American Act’, whether application of title III of such Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s812/b/1"},"text":"Pub. L. 103–337, § 812(b)(1)","children":[],"tail":", substituted “Determinations of public interest under the Buy American Act” for “Limitation on use of funds: procurement of goods which are other than American goods” as section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s812/a/1"},"text":"Pub. L. 103–337, § 812(a)(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which read as follows: “Funds appropriated to the Department of Defense may not be obligated under a contract for procurement of goods which are other than American goods (as defined in subsection (c)) unless adequate consideration is given to the following:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The bids or proposals of firms located in labor surplus areas in the United States (as designated by the Department of Labor) which have offered to furnish American goods.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The bids or proposals of small business firms in the United States which have offered to furnish American goods.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) The bids or proposals of all other firms in the United States which have offered to furnish American goods.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) The United States balance of payments.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) The cost of shipping goods which are other than American goods.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) Any duty, tariff, or surcharge which may enter into the cost of using goods which are other than American goods.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s812/a"},"text":"Pub. L. 103–337, § 812(a)","children":[],"tail":", redesignated subsec. (c) as (b) and struck out former subsec. (b) which read as follows: “Consideration of the matters referred to in paragraphs (1) through (6) of subsection (a) shall be given under regulations of the Secretary of Defense and subject to the determinations and exceptions contained in title III of the Act of "},{"tag":"date","attrib":{"date":"1933-03-03"},"text":"March 3, 1933","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s10a"},"text":"41 U.S.C. 10a","children":[],"tail":", 10b), popularly known as the ‘Buy American Act’.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2506"},"text":"section 2506 of this title","children":[],"tail":" as section 2533."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaaa077c7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaaa077c8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaaa077c9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date and applicability of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/s4401"},"text":"section 4401 of Pub. L. 104–106","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2220"},"text":"section 2220 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
