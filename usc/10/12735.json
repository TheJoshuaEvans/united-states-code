{"tag":"section","attrib":{"id":"idabadf09b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12735"},"text":null,"children":[{"tag":"num","attrib":{"value":"12735"},"text":"§ 12735.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inactive status list","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabadf09c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12735/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member who would be eligible for retired pay under this chapter but for the fact that that member is under 60 years of age may be transferred, at his request and by direction of the Secretary concerned, to such inactive status list as may be established for members of his armed force, other than members of a regular component.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabadf09d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12735/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" While on an inactive status list under subsection (a), a member is not required to participate in any training or other program prescribed for his component.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabadf09e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12735/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may at any time recall to active status a member who is on an inactive status list under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabadf09f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/104"},"text":"70A Stat. 104","children":[],"tail":", § 1335; renumbered § 12735 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1662/j/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1662(j)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2998"},"text":"108 Stat. 2998","children":[],"tail":", 3003.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabadf0a0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idabadf0a1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idabadf0a2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}