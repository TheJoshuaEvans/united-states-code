{"tag":"section","attrib":{"id":"ida8510a19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1046"},"text":null,"children":[{"tag":"num","attrib":{"value":"1046"},"text":"§ 1046.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overseas temporary foster care program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8510a1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1046/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may establish a program to provide temporary foster care services outside the United States for children accompanying members of the armed forces on duty at stations outside the United States. The foster care services provided under such a program shall be similar to those services provided by State and local governments in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8510a1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1046/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under regulations prescribed by the Secretary concerned, the expenses related to providing foster care services under subsection (a) may be paid from appropriated funds available to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8510a1c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tVI/s651/a"},"text":"Pub. L. 102–484, div. A, title VI, § 651(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2425"},"text":"106 Stat. 2425","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8510a1d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8510a1e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida8510a1f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1046, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tVII/s708/a/1"},"text":"Pub. L. 98–525, title VII, § 708(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2572"},"text":"98 Stat. 2572","children":[],"tail":", related to preseparation counseling, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tV/s502/b/1"},"text":"Pub. L. 101–510, div. A, title V, § 502(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1557"},"text":"104 Stat. 1557","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
