{"tag":"section","attrib":{"id":"idaa13c83d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206"},"text":null,"children":[{"tag":"num","attrib":{"value":"3206"},"text":"§ 3206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning and solicitation requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa13c83e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Planning and Specifications.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa13c83f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preparing for procurement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In preparing for the procurement of property or services, the head of an agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa13c840-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the agency’s needs and solicit bids or proposals in a manner designed to achieve full and open competition for the procurement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa13c841-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use advance procurement planning and market research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa13c842-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop specifications in such manner as is necessary to obtain full and open competition with due regard to the nature of the property or services to be acquired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa13c843-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements of specifications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each solicitation under chapter 137 legacy provisions shall include specifications which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa13c844-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with the provisions of chapter 137 legacy provisions, permit full and open competition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa13c845-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include restrictive provisions or conditions only to the extent necessary to satisfy the needs of the agency or as authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa13c846-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Types of specifications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of paragraphs (1) and (2), the type of specification included in a solicitation shall depend on the nature of the needs of the agency and the market available to satisfy such needs. Subject to such needs, specifications may be stated in terms of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa13c847-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" function, so that a variety of products or services may qualify;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa13c848-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performance, including specifications of the range of acceptable characteristics or of the minimum acceptable standards; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa13c849-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa13c84a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of solicitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the specifications described in subsection (a), a solicitation for sealed bids or competitive proposals (other than for a procurement for commercial products or commercial services using special simplified procedures or a purchase for an amount not greater than the simplified acquisition threshold) shall at a minimum include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa13c84b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a statement of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa13c84c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all significant factors and significant subfactors which the head of the agency reasonably expects to consider in evaluating sealed bids (including price) or competitive proposals (including cost or price, cost-related or price-related factors and subfactors, and noncost-related or nonprice-related factors and subfactors); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa13c84d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relative importance assigned to each of those factors and subfactors; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa13c84e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa13c84f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of sealed bids—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa13c850-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement that sealed bids will be evaluated without discussions with the bidders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa13c851-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time and place for the opening of the sealed bids; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa13c852-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of competitive proposals—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa13c853-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" either a statement that the proposals are intended to be evaluated with, and award made after, discussions with the offerors, or a statement that the proposals are intended to be evaluated, and award made, without discussions with the offerors (other than discussions conducted for the purpose of minor clarification) unless discussions are determined to be necessary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa13c854-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time and place for submission of proposals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa13c855-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evaluation Factors.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa13c856-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In prescribing the evaluation factors to be included in each solicitation for competitive proposals, the head of an agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa13c857-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall (except as provided in paragraph (3)) clearly establish the relative importance assigned to the evaluation factors and subfactors, including the quality of the product or services to be provided (including technical capability, management capability, prior experience, and past performance of the offeror);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa13c858-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall (except as provided in paragraph (3)) include cost or price to the Federal Government as an evaluation factor that must be considered in the evaluation of proposals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa13c859-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall disclose to offerors whether all evaluation factors other than cost or price, when combined, are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa13c85a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significantly more important than cost or price;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa13c85b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approximately equal in importance to cost or price; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa13c85c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significantly less important than cost or price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa13c85d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restriction on implementing regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations implementing paragraph (1)(C) may not define the terms “significantly more important” and “significantly less important” as specific numeric weights that would be applied uniformly to all solicitations or a class of solicitations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa13c85e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions for certain multiple task or delivery order contracts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the head of an agency issues a solicitation for multiple task or delivery order contracts under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3403/d/1/B"},"text":"section 3403(d)(1)(B) of this title","children":[],"tail":" for the same or similar services and intends to make a contract award to each qualifying offeror—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa13c85f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cost or price to the Federal Government need not, at the Government’s discretion, be considered under paragraph (1)(B) as an evaluation factor for the contract award; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa13c860-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if, pursuant to subparagraph (A), cost or price to the Federal Government is not considered as an evaluation factor for the contract award—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa13c861-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disclosure requirement of paragraph (1)(C) shall not apply; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa13c862-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cost or price to the Federal Government shall be considered in conjunction with the issuance pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3406/c"},"text":"section 3406(c) of this title","children":[],"tail":" of a task or delivery order under any contract resulting from the solicitation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa13c863-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In paragraph (3), the term “qualifying offeror” means an offeror that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa13c864-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined to be a responsible source;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa13c865-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits a proposal that conforms to the requirements of the solicitation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa13c866-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contracting officer has no reason to believe would likely offer other than fair and reasonable pricing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa13c867-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion of applicability to certain contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (3) shall not apply to multiple task or delivery order contracts if the solicitation provides for sole source task or delivery order contracts pursuant to section 8(a) of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/a"},"text":"15 U.S.C. 637(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa13c868-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Information in Solicitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section prohibits an agency from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa13c869-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing additional information in a solicitation, including numeric weights for all evaluation factors and subfactors on a case-by-case basis; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa13c86a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stating in a solicitation that award will be made to the offeror that meets the solicitation’s mandatory requirements at the lowest cost or price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa13c86b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3206/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Evaluation of Purchase Options","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an agency, in issuing a solicitation for a contract to be awarded using sealed bid procedures, may not include in such solicitation a clause providing for the evaluation of prices for options to purchase additional property or services under the contract unless the head of the agency has determined that there is a reasonable likelihood that the options will be exercised.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa13c86c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1811/e"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1811(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4170"},"text":"134 Stat. 4170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/b/4/F"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(b)(4)(F)","children":[],"tail":", (d)(4), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2133"},"text":"135 Stat. 2133","children":[],"tail":", 2136.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa13c86d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa13c86e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa13c86f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2305"},"text":"section 2305 of this title","children":[],"tail":", which was transferred to this section and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1811/e/2"},"text":"Pub. L. 116–283, § 1811(e)(2)","children":[],"tail":"–(7), was based on "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dB/tVII/s2723/b"},"text":"Pub. L. 98–369, div. B, title VII, § 2723(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"t