{"tag":"section","attrib":{"id":"ida7970950-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283"},"text":null,"children":[{"tag":"num","attrib":{"value":"283"},"text":"§ 283.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Situations involving bombings of places of public use, Government facilities, public transportation systems, and infrastructure facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7970951-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon the request of the Attorney General, the Secretary of Defense may provide assistance in support of Department of Justice activities related to the enforcement of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2332f"},"text":"section 2332f of title 18","children":[],"tail":" during situations involving bombings of places of public use, Government facilities, public transportation systems, and infrastructure facilities."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7970952-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rendering-safe Support","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Military explosive ordnance disposal units providing rendering-safe support to Department of Justice activities relating to the enforcement of section 175, 229, or 2332a of title 18 in emergency situations involving weapons of mass destruction shall provide such support in a manner consistent with the provisions of section 382 ","children":[{"tag":"ref","attrib":{"idref":"fn002028"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002028"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7970953-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7970954-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense and the Attorney General shall jointly prescribe regulations concerning the types of assistance that may be provided under this section. Such regulations shall also describe the actions that Department of Defense personnel may take in circumstances incident to the provision of assistance under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7970955-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7970956-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subparagraph (B), the regulations prescribed under paragraph (1) may not authorize any of the following actions:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida7970957-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Arrest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7970958-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any direct participation in conducting a search for or seizure of evidence related to a violation of section 175, 229, or 2332a of title 18.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7970959-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any direct participation in the collection of intelligence for law enforcement purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida797095a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such regulations may authorize an action described in subparagraph (A) to be taken under the following conditions:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida797095b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The action is considered necessary for the immediate protection of human life, and civilian law enforcement officials are not capable of taking the action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida797095c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The action is otherwise authorized under subsection (a) or under otherwise applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida797095d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Explosive Ordnance Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “explosive ordnance”—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida797095e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida797095f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bombs and warheads;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7970960-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guided and ballistic missiles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7970961-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" artillery, mortar, rocket, and small arms ammunition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7970962-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all mines, torpedoes, and depth charges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7970963-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grenades demolition charges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7970964-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pyrotechnics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7970965-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/d/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clusters and dispensers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7970966-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/d/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cartridge- and propellant- actuated devices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7970967-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/d/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electroexplosives devices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7970968-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/d/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clandestine and improvised explosive devices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7970969-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/d/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all similar or related items or components explosive in nature; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida797096a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s283/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes all munitions containing explosives, propellants, nuclear fission or fusion materials, and biological and chemical agents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida797096b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tX/s1082/a"},"text":"Pub. L. 114–92, div. A, title X, § 1082(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1002"},"text":"129 Stat. 1002","children":[],"tail":", § 383; renumbered § 283, "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1241/a/2"},"text":"Pub. L. 114–328, div. A, title XII, § 1241(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2497"},"text":"130 Stat. 2497","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida797096c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida797096d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida797096e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s382"},"text":"Section 382 of this title","children":[],"tail":", referred to in subsec. (b), was renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s282"},"text":"section 282 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1241/a/2"},"text":"Pub. L. 114–328, div. A, title XII, § 1241(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2497"},"text":"130 Stat. 2497","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida797096f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s383"},"text":"section 383 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
