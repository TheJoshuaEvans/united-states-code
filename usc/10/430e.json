{"tag":"section","attrib":{"id":"ida7bd2e6f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430e"},"text":null,"children":[{"tag":"num","attrib":{"value":"430e"},"text":"§ 430e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vendor support to clandestine activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7bd2e70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Oversight, Deconfliction, and Risk Assessment Capability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall establish, maintain, continuously update, and use a secure, centralized technical capability to facilitate oversight, deconfliction, and risk assessments of all commercial vendor support to the Department of Defense for clandestine activities. Such capability shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bd2e71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable the Department of Defense to perform oversight, deconfliction, and risk assessments of past, ongoing, or planned clandestine activity involving support from commercial vendors, including all subcontractors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bd2e72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include use of the minimum information required to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7bd2e73-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430e/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify potential conflicts between clandestine activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bd2e74-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430e/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the need for additional coordination with respect to clandestine activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bd2e75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430e/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct aggregate risk assessments of clandestine activities involving support from commercial vendors; and ","children":[{"tag":"ref","attrib":{"idref":"fn002032"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002032"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bd2e76-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bd2e77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subsection (a), if the Secretary of Defense determines that information concerning a commercial vendor should not be used by the centralized technical capability required by subsection (a) due to operational, counterintelligence, or other national security concerns, the Secretary may exclude such information from use by such centralized technical capability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bd2e78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 7 days after making a determination under paragraph (1), the Secretary shall submit to the congressional defense committees, the Select Committee on Intelligence of the Senate, and the Permanent Select Committee on Intelligence of the House of Representatives notice of the determination that includes the following information disaggregated by the element of the Department of Defense with respect to which such commercial vendor provides support:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7bd2e79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430e/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of commercial vendors with respect to which the Secretary made the determination under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bd2e7a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430e/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the types of activities supported by such commercial vendors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bd2e7b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430e/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rationale for excluding the information concerning such commercial vendors from such capability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bd2e7c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deconfliction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall ensure the centralized technical capability required by subsection (a) is used in each case where a commercial vendor is expected to provide support to a clandestine activity to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bd2e7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deconflict the use of commercial vendors in support of clandestine activities of the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bd2e7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess operational risk and counterintelligence exposure attributable to the use of commercial vendors in support of clandestine activities of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bd2e7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Clandestine Activity Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “clandestine activity” means any activity where it is intended that the role of the United States Government will not be apparent or acknowledged publicly.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7bd2e80-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVI/s1621/a"},"text":"Pub. L. 119–60, div. A, title XVI, § 1621(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1180"},"text":"139 Stat. 1180","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7bd2e81-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7bd2e82-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7bd2e83-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation Deadline and Reports","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVI/s1621/b"},"text":"Pub. L. 119–60, div. A, title XVI, § 1621(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1181"},"text":"139 Stat. 1181","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tXVI/s1621/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation deadline and certification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"], the Secretary of Defense shall—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s430e"},"text":"section 430e of title 10","children":[],"tail":", United States Code, as added by subsection (a) of this section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives], the Select Committee on Intelligence of the Senate, and the Permanent Select Committee on Intelligence of the House of Representatives a certification that such requirements have been implemented.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of plan","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after the date of the enactment of this Act, the Secretary of Defense shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the committees described in paragraph (1)(B) a report containing the plan to implement the requirements of such section 430e; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to such committees a briefing with respect to such plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Progress report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 270 days after the date of the enactment of this Act, the Secretary of Defense shall provide to the committees described in paragraph (1)(B) a briefing describing the progress of the Secretary towards implementing the requirements of such section 430e.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
