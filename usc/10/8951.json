{"tag":"section","attrib":{"id":"idab55bef9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8951"},"text":null,"children":[{"tag":"num","attrib":{"value":"8951"},"text":"§ 8951.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safety and effectiveness information; hydrographic information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab55befa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8951/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Safety and Effectiveness Information","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab55befb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8951/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Navy shall maximize the safety and effectiveness of all maritime vessels, aircraft, and forces of the armed forces by means of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab55befc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8951/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marine data collection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55befd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8951/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" numerical weather and ocean prediction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55befe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8951/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forecasting of hazardous weather and ocean conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab55beff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8951/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may extend similar support to forces of the North Atlantic Treaty Organization, and to coalition forces, that are operating with the armed forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab55bf00-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8951/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hydrographic Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy shall collect, process, and provide to the Director of the National Geospatial-Intelligence Agency hydrographic information to support preparation of maps, charts, books, and geodetic products by that Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab55bf01-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tIII/s363/a"},"text":"Pub. L. 112–81, div. A, title III, § 363(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1379"},"text":"125 Stat. 1379","children":[],"tail":", § 7921; renumbered § 8951, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/16"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab55bf02-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab55bf03-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab55bf04-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 8961 to 8963 were renumbered sections 9341 to 9343 of this title, respectively.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 8963, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/555"},"text":"70A Stat. 555","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/156"},"text":"Pub. L. 85–861, § 1(156)","children":[],"tail":", (198), "},{"tag":"ref","attrib":{"href":"/us/stat/72/1513"},"text":"72 Stat. 1513","children":[],"tail":", 1541; "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s504/21"},"text":"Pub. L. 96–513, title V, § 504(21)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2917"},"text":"94 Stat. 2917","children":[],"tail":", related to higher grade for service during certain periods for regular and reserve commissioned officers, prior to repeal b