{"tag":"section","attrib":{"id":"ida83df745-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s952"},"text":null,"children":[{"tag":"num","attrib":{"value":"952"},"text":"§ 952.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parole","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida83df746-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s952/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may provide a system of parole for offenders who are confined in military correctional facilities and who were at the time of commission of their offenses subject to the authority of that Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida83df747-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s952/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In a case in which parole for an offender serving a sentence of confinement for life is denied, only the President or the Secretary concerned may grant the offender parole on appeal of that denial. The authority to grant parole on appeal in such a case may not be delegated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida83df748-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/377/s1"},"text":"Pub. L. 90–377, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-05"},"text":"July 5, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/287"},"text":"82 Stat. 287","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tV/s582/a"},"text":"Pub. L. 105–85, div. A, title V, § 582(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1760"},"text":"111 Stat. 1760","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida83df749-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida83df74a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida83df74b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida83df74c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida83df74d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tV/s582/b"},"text":"Pub. L. 105–85, div. A, title V, § 582(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1760"},"text":"111 Stat. 1760","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/85/dA/tV/s582/b"},"text":"“Subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s952"},"text":"section 952 of title 10","children":[],"tail":", United States Code (as added by subsection (a)), shall apply only with respect to any decision to deny parole made after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
