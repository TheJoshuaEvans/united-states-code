{"tag":"section","attrib":{"id":"idaad4f5a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7017"},"text":null,"children":[{"tag":"num","attrib":{"value":"7017"},"text":"§ 7017.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of the Army: successors to duties","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If the Secretary of the Army dies, resigns, is removed from office, is absent, or is disabled, the person who is highest on the following list, and who is not absent or disabled, shall perform the duties of the Secretary until the President, under section 3347 ","children":[{"tag":"ref","attrib":{"idref":"fn002151"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002151"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 5, directs another person to perform those duties or until the absence or disability ceases:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad4f5a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7017/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f5a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7017/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretaries of the Army, in the order prescribed by the Secretary of the Army and approved by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f5a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7017/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The General Counsel of the Department of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f5a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7017/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad4f5a9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/159"},"text":"70A Stat. 159","children":[],"tail":", § 3017; "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s23"},"text":"Pub. L. 89–718, § 23","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1118"},"text":"80 Stat. 1118","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/235/s4/a/7"},"text":"Pub. L. 90–235, § 4(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/759"},"text":"81 Stat. 759","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s501/a/6"},"text":"Pub. L. 99–433, title V, § 501(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1038"},"text":"100 Stat. 1038","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tIX/s902/a"},"text":"Pub. L. 103–337, div. A, title IX, § 902(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2823"},"text":"108 Stat. 28