{"tag":"section","attrib":{"id":"idab7be46a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494"},"text":null,"children":[{"tag":"num","attrib":{"value":"9494"},"text":"§ 9494.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities performed as auxiliary of the Air Force","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab7be46b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Air Force Support for Activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Air Force may furnish to the Civil Air Patrol in accordance with this section any equipment, supplies, and other resources that the Secretary determines necessary to enable the Civil Air Patrol to fulfill the missions assigned by the Secretary to the Civil Air Patrol as an auxiliary of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7be46c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Forms of Air Force Support","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Air Force may, under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab7be46d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" give, lend, or sell to the Civil Air Patrol without regard to subtitle I of title 40 and division C (except sections 3302, 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab7be46e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" major items of equipment (including aircraft, motor vehicles, computers, and communications equipment) that are excess to the military departments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab7be46f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary related supplies and training aids that are excess to the military departments;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be470-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit the use, with or without charge, of services and facilities of the Air Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be471-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnish supplies (including fuel, lubricants, and other items required for vehicle and aircraft operations) or provide funds for the acquisition of supplies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be472-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish, maintain, and supply liaison officers of the Air Force at the national, regional, State, and territorial headquarters of the Civil Air Patrol;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be473-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detail or assign any member of the Air Force or any officer, employee, or contractor of the Department of the Air Force to any liaison office at the national, regional, State, or territorial headquarters of the Civil Air Patrol;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be474-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detail any member of the Air Force or any officer, employee, or contractor of the Department of the Air Force to any unit or installation of the Civil Air Patrol to assist in the training programs of the Civil Air Patrol;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be475-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize the payment of travel expenses and allowances, at rates not to exceed those paid to employees of the United States under subchapter I of chapter 57 of title 5, to members of the Civil Air Patrol while the members are carrying out programs or missions specifically assigned by the Air Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be476-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide funds for the national headquarters of the Civil Air Patrol, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab7be477-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds for the payment of staff compensation and benefits, administrative expenses, travel, per diem and allowances, rent, utilities, other operational expenses of the national headquarters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab7be478-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent considered necessary by the Secretary of the Air Force to fulfill Air Force requirements, funds for the payment of compensation and benefits for key staff at regional, State, or territorial headquarters;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be479-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize the payment of expenses of placing into serviceable condition, improving, and maintaining equipment (including aircraft, motor vehicles, computers, and communications equipment) owned or leased by the Civil Air Patrol;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be47a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide funds for the lease or purchase of items of equipment that the Secretary determines necessary for the Civil Air Patrol;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be47b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support the Civil Air Patrol cadet program by furnishing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab7be47c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/b/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" articles of the Air Force uniform to cadets without cost; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab7be47d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/b/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other support that the Secretary of the Air Force determines is consistent with Air Force missions and objectives; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be47e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide support, including appropriated funds, for the Civil Air Patrol aerospace education program to the extent that the Secretary of the Air Force determines appropriate for furthering the fulfillment of Air Force missions and objectives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7be47f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance by Other Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab7be480-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Air Force may arrange for the use by the Civil Air Patrol of such facilities and services under the jurisdiction of the Secretary of the Army, the Secretary of the Navy, or the head of any other department or agency of the United States as the Secretary of the Air Force considers to be needed by the Civil Air Patrol to carry out its mission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be481-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An arrangement for use of facilities or services of a military department or other department or agency under this subsection shall be subject to the agreement of the Secretary of the military department or head of the other department or agency, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be482-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9494/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each arrangement under this subsection shall be made in accordance with regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9498"},"text":"section 9498 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab7be483-