{"tag":"section","attrib":{"id":"ida9bb96f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2697"},"text":null,"children":[{"tag":"num","attrib":{"value":"2697"},"text":"§ 2697.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance and use of landing fees charged for use of military airfields by civil aircraft","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9bb96f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2697/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of a military department may impose landing fees for the use by civil aircraft of military airfields under the jurisdiction of that Secretary and may use any fees received under this section as a source of funding for the operation and maintenance of airfields of that department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9bb96f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2697/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Uniform Landing Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe the amount of the landing fees that may be imposed under this section. Such fees shall be uniform among the military departments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9bb96f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2697/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Proceeds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts received for a fiscal year in payment of landing fees imposed under this section for the use of a military airfield shall be credited to the appropriation that is available for that fiscal year for the operation and maintenance of that military airfield, shall be merged with amounts in the appropriation to which credited, and shall be available for that military airfield for the same period and purposes as the appropriation is available.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9bb96fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2697/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of a military department shall determine whether consideration for a landing fee has been received in a lease, license, or other real estate agreement for an airfield and shall use such a determination to offset appropriate amounts imposed under subsection (a) for that airfield.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9bb96fb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tIII/s341/a"},"text":"Pub. L. 111–383, div. A, title III, § 341(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4189"},"text":"124 Stat. 4189","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dB/tXXVIII/s2846"},"text":"Pub. L. 118–159, div. B, title XXVIII, § 2846","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2264"},"text":"138 Stat. 2264","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9bb96fc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"ida9bb96fd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dB/tXXVIII/s2846/b"},"text":"Pub. L. 118–159, div. B, title XXVIII, § 2846(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2264"},"text":"138 Stat. 2264","children":[],"tail":", provided that, effective "},{"tag":"date","attrib":{"date":"2027-10-01"},"text":"Oct. 1, 2027","children":[],"tail":", this section is amended in the section catchline and subsec. (a) by inserting “domestic” before “military airfields”. See 2024 Amendment notes below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9bb96fe-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9bb96ff-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s2846/b/1"},"text":"Pub. L. 118–159, § 2846(b)(1)","children":[],"tail":", inserted “domestic” before “military airfields” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s2846/a/1"},"text":"Pub. L. 118–159, § 2846(a)(1)","children":[],"tail":", struck out “domestic” before “military airfields” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s2846/b/2"},"text":"Pub. L. 118–159, § 2846(b)(2)","children":[],"tail":", inserted “domestic” before “military airfields”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s2846/a/2"},"text":"Pub. L. 118–159, § 2846(a)(2)","children":[],"tail":", struck out “domestic” before “military airfields”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9bb9700-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9bb9701-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dB/tXXVIII/s2846/b"},"text":"Pub. L. 118–159, div. B, title XXVIII, § 2846(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2264"},"text":"138 Stat. 2264","children":[],"tail":", provided that the amendment made by section 2846(b) is effective "},{"tag":"date","attrib":{"date":"2027-10-01"},"text":"Oct. 1, 2027","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
