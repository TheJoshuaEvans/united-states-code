ea8f7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa3ea8f8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3847, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/94"},"text":"Pub. L. 85–861, § 1(94)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1484"},"text":"72 Stat. 1484","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/559/s1/25"},"text":"Pub. L. 86–559, § 1(25)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-06-30"},"text":"June 30, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/272"},"text":"74 Stat. 272","children":[],"tail":", provided for transfer to Retired Reserve or discharge from his reserve appointment, after "},{"tag":"date","attrib":{"date":"1960-07-01"},"text":"July 1, 1960","children":[],"tail":", of each officer in a reserve grade below lieutenant colonel with 25 years service assigned to Army Nurse Corps, Army Medical Specialist Corps, or Women’s Army Corps who had not been recommended for promotion to reserve grade of lieutenant colonel or who has not remained on active duty since such a recommendation, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/90/130/s1/12/A"},"text":"Pub. L. 90–130, § 1(12)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-11-08"},"text":"Nov. 8, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/376"},"text":"81 Stat. 376","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa3ea8f9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1835/c"},"text":"Pub. L. 116–283, § 1835(c)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2313a"},"text":"section 2313a of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1835/d/3"},"text":"Pub. L. 116–283, § 1835(d)(3)","children":[],"tail":", substituted “section 3842” for “section 2313b”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s811/d/1/A/i"},"text":"Pub. L. 115–91, § 811(d)(1)(A)(i)","children":[],"tail":", inserted “and dollar value” after “number” and “, set forth separately by type of audit” after “pending”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s811/d/1/A/ii"},"text":"Pub. L. 115–91, § 811(d)(1)(A)(ii)","children":[],"tail":", inserted “, both from the date of receipt of a qualified incurred cost submission and from the date the audit begins” after “audit”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s811/d/1/A/iii"},"text":"Pub. L. 115–91, § 811(d)(1)(A)(iii)","children":[],"tail":", amended subpar. (D) generally. Prior to amendment, subpar. (D) read as follows: “the total costs of sustained or recovered costs both as a total number and as a percentage of questioned costs; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(E) to (H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s811/d/1/A/iv"},"text":"Pub. L. 115–91, § 811(d)(1)(A)(iv)","children":[],"tail":", (v), added subpars. (E) to (H) and struck out former subpar. (E) which read as follows: “an assessment of the number and types of audits pending for a period longer than allowed pursuant to guidance of the Defense Contract Audit Agency;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1081/d/5"},"text":"Pub. L. 115–91, § 1081(d)(5)","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s824/d/1/B"},"text":"Pub. L. 114–328, § 824(d)(1)(B)","children":[],"tail":". See 2016 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s811/d/1/B"},"text":"Pub. L. 115–91, § 811(d)(1)(B)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s824/d/1/B"},"text":"Pub. L. 114–328, § 824(d)(1)(B)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1081/d/5"},"text":"Pub. L. 115–91, § 1081(d)(5)","children":[],"tail":", added pars. (4) and (5). Former pars. (4) and (5) redesignated (6) and (7), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s824/d/1/A"},"text":"Pub. L. 114–328, § 824(d)(1)(A)","children":[],"tail":", redesignated pars. (4) and (5) as (6) and (7), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s893/b/1"},"text":"Pub. L. 114–92, § 893(b)(1)","children":[],"tail":", amended subpar. (D) generally. Prior to amendment, subpar. (D) read as follows: “the total dollar value of questioned costs (including a separate category for the dollar value of unsupported costs); and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s893/b/2"},"text":"Pub. L. 114–92, § 893(b)(2)","children":[],"tail":"–(4), added par. (4) and redesignated former par. (4) as (5)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa3ea8fa-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa3ea8fb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa3ea8fc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1081/d"},"text":"Pub. L. 115–91, div. A, title X, § 1081(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1599"},"text":"131 Stat. 1599","children":[],"tail":", provided that the amendment made by section 1081(d)(5) is effective as of "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa3ea8fd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s824/d/2"},"text":"Pub. L. 114–328, div. A, title VIII, § 824(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2279"},"text":"130 Stat. 2279","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/328/dA/tVIII/s824/d/2"},"text":"“The amendments made by this subsection [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2018-10-01"},"text":"October 1, 2018","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
