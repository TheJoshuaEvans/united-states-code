"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-05-05/ch169/s1"},"text":"May 5, 1950, ch. 169, § 1","children":[],"tail":" (Art. 59), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/127"},"text":"64 Stat. 127","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “may” is substituted for the word “shall”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
