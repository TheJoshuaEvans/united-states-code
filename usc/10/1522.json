{"tag":"section","attrib":{"id":"ida8e02b7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1522"},"text":null,"children":[{"tag":"num","attrib":{"value":"1522"},"text":"§ 1522.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Posthumous warrants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8e02b80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1522/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may issue, or have issued, an appropriate warrant in the name of a member of the armed forces who, after ","children":[{"tag":"date","attrib":{"date":"1939-09-08"},"text":"September 8, 1939","children":[],"tail":", was officially recommended for appointment or promotion to a grade other than a commissioned grade but was unable to accept the appointment or promotion because of death."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8e02b81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1522/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A warrant issued under subsection (a) shall issue as of the date of the recommendation, and the member’s name shall be carried on the records of the military or executive department concerned as if he had served in the grade to which posthumously appointed or promoted from the date of the recommendation to the date of his death.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8e02b82-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1522/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A warrant issued under subsection (a) in connection with the promotion of a deceased member to a higher grade shall require a finding by the Secretary concerned that, at the time of death of the member, the member was qualified for appointment to that higher grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8e02b83-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/116"},"text":"70A Stat. 116","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title V, § 502(b), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4433"},"text":"122 Stat. 4433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8e02b84-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8e02b85-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida8e02b86-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1522(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:612 (words before semicolon).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"34:285e (words before semicolon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-07-28/ch528/s4"},"text":"July 28, 1942, ch. 528, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/56/723"},"text":"56 Stat. 723","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1953-07-17/ch220/s1"},"text":"July 17, 1953, ch. 220, § 1","children":[],"tail":" (a)–(d), "},{"tag":"html:a","attrib":{"href":"/us/stat/67/176"},"text":"67 Stat. 176","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1522(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:612 (words after semicolon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"34:285e (words after semicolon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “a member of” are substituted for the words “any person who, while in”, in 10:612 and 34:285e. The words “armed forces” are substituted for the words “the military service of the United States”, in 10:612; and “the naval service of the United States”, in 34:285e (which did not appear in the source statute for the revised section, as amended by the ","children":[{"tag":"ref","attrib":{"href":"/us/act/1953-07-17/ch220/s1/b"},"text":"act of July 17, 1953, ch. 220, § 1(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/177"},"text":"67 Stat. 177","children":[],"tail":"). The words “other than a commissioned grade” are substituted for the words “noncommissioned grade” to make it clear that the revised section covers warrant officers. The words “receive or” are omitted as surplusage."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “appointment or promotion”, “and branch of the service”, “official”, and “by such warrant” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8e02b87-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8e02b88-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s502/b/1"},"text":"Pub. L. 110–417, § 502(b)(1)","children":[],"tail":", struck out “in line of duty” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s502/b/2"},"text":"Pub. L. 110–417, § 502(b)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
