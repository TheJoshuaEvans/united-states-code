{"tag":"section","attrib":{"id":"idab9f9939-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12308"},"text":null,"children":[{"tag":"num","attrib":{"value":"12308"},"text":"§ 12308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention after becoming qualified for retired pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person who has qualified for retired pay under chapter 1223 of this title may, with his consent and by order of the Secretary concerned, be retained on active duty, or in service in a reserve component other than that listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12732/b"},"text":"section 12732(b) of this title","children":[],"tail":". A member so retained shall be credited with that service for all purposes."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab9f993a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/29"},"text":"70A Stat. 29","children":[],"tail":", § 676; renumbered § 12308 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI"},"text":"Pub. L. 103–337, div. A, title XVI","children":[],"tail":", §§ 1662(e)(2), 1675(c)(6), "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2992"},"text":"108 Stat. 2992","children":[],"tail":", 3017.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab9f993b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab9f993c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab9f993d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib"