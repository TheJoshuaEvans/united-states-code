{"tag":"section","attrib":{"id":"idab4e92e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8822"},"text":null,"children":[{"tag":"num","attrib":{"value":"8822"},"text":"§ 8822.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Admiralty claims against the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab4e92e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8822/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Navy may settle, or compromise, and pay in an amount not more than $15,000,000 an admiralty claim against the United States for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab4e92e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8822/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" damage caused by a vessel in the naval service or by other property under the jurisdiction of the Department of the Navy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4e92e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8822/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation for towage and salvage service, including contract salvage, rendered to a vessel in the naval service or to other property under the jurisdiction of the Department of the Navy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4e92e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8822/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" damage caused by a maritime tort committed by any agent or employee of the Department of the Navy or by property under the jurisdiction of the Department of the Navy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab4e92e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8822/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a claim under this section is settled or compromised for more than $15,000,000, the Secretary shall certify it to Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab4e92e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8822/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case where the amount to be paid is not more than $1,000,000, the Secretary may delegate his authority under this section to any person designated by him.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab4e92e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8822/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon acceptance of payment by the claimant, the settlement or compromise of a claim under this section is final and conclusive notwithstanding any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab4e92e8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/472"},"text":"70A Stat. 472","children":[],"tail":", § 7622; "},{"tag":"ref","attrib":{"href":"/us/pl/89/67"},"text":"Pub. L. 89–67","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-07"},"text":"July 7, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/212"},"text":"79 Stat. 212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/417/s1/5"},"text":"Pub. L. 92–417, § 1(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-08-29"},"text":"Aug. 29, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/654"},"text":"86 Stat. 654","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXVI/s1633"},"text":"Pub. L. 101–189, div. A, title XVI, § 1633","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1608"},"text":"103 Stat. 1608","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1014/a"},"text":"Pub. L. 107–107, div. A, title X, § 1014(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1212"},"text":"115 Stat. 1212","children":[],"tail":"; renumbered § 8822, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/9"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab4e92e9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab4e92ea-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab4e92eb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7622","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t46/s797"},"text":"46 U.S.C. 797","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1944-07-03/ch399/s7"},"text":"July 3, 1944, ch. 399, § 7","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/58/726"},"text":"58 Stat. 726","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t46/s799"},"text":"46 U.S.C. 799","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1944-07-03/ch399/s9"},"text":"July 3, 1944, ch. 399, § 9","children":[],"tail":"; added "},{"tag":"html:a","attrib":{"href":"/us/act/1946-08-02/ch739"},"text":"Aug. 2, 1946, ch. 739","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/803"},"text":"60 Stat. 803","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words “consider, ascertain, adjust, determine” are omitted as covered by the word “settle”, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7621/b"},"text":"§ 7621(b) of this title","children":[],"tail":". The words “vessel in the naval service” are substituted for the words “vessels of the Navy or in the naval service”, in view of the definition in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7621/a"},"text":"§ 7621(a) of this title","children":[],"tail":". The words “pay in an amount not more than $1,000,000, a claim” are substituted for the words “pay the amount of any claim, so determined, compromised, or settled” and for the words “the payment of any claim on which a net amount exceeding $1,000,000 is determined to be due from the United States, or which is compromised or settled at a net amount exceeding $1,000,000 payable by the United States, shall not be authorized by this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c) the words “In any case where the amount to be paid is not more than” are substituted for the words “When the net amount paid in settlement does not exceed” for clarity, since the delegation necessarily precedes payment. The words “the Secretary may delegate his authority” are substituted for the words “the authority of the Secretary of the Navy * * * may be exercised by” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d) the words “but not until then”, “for all purposes”, and “to the contrary” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The first proviso in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s797"},"text":"46 U.S.C. 797","children":[],"tail":", stating that this section is supplementary to, and not in lieu of, other laws authorizing the settlement of claims, is omitted as unnecessary, since the other applicable claims laws are restated in this title. The second proviso, forbidding consideration of claims for more than $3,000 if they accrued before "},{"tag":"date","attrib":{"date":"1939-09-08"},"text":"Sept. 8, 1939","children":[],"tail":", is omitted as obsolete. It was designed to avoid reviving stale claims upon enactment of the source law on "},{"tag":"date","attrib":{"date":"1944-07-03"},"text":"July 3, 1944","children":[],"tail":". However, as a matter of practice, no claims are settled under this authority which are more than two years old, in line with the two-year statute of limitations contained in the Suits in Admiralty Act and the Public Vessels Act. This limitation has been officially publicized in the Federal Register for "},{"tag":"date","attrib":{"date":"1947-05-22"},"text":"May 22, 1947","children":[],"tail":", p. 3296, and in 32 C.F.R. 752. The third proviso in "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s797"},"text":"46 U.S.C. 797","children":[],"tail":" is omitted as unnecessary, since the appropriation named therein no longer exists, and the payments are now made from appropriations for the Department of Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab4e92ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab4e92ed-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7622"},"text":"section 7622 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1014/a/1"},"text":"Pub. L. 107–107, § 1014(a)(1)","children":[],"tail":", substituted “$15,000,000” for “$1,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1014/a/2"},"text":"Pub. L. 107–107, § 1014(a)(2)","children":[],"tail":", substituted “$1,000,000” for “$100,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" substituted “$100,000” for “$10,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/417"},"text":"Pub. L. 92–417","children":[],"tail":" substituted “an admiralty claim against the United States” for “a claim against the United States” in text preceding par. (1), in par. (1) inserted “or by other property under the jurisdiction of the Department of the Navy”, in par. (2) inserted “or to other property under the jurisdiction of the Department of the Navy”, and added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/67"},"text":"Pub. L. 89–67","children":[],"tail":" substituted “$10,000” for “$1,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab4e92ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab4e92ef-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab4e92f0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1014/c"},"text":"Pub. L. 107–107, div. A, title X, § 1014(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1212"},"text":"115 Stat. 1212","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/107/dA/tX/s1014/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7623"},"text":"section 7623 of this title","children":[],"tail":"] shall apply with respect to any claim accruing on or after "},{"tag":"date","attrib":{"date":"2001-02-01"},"text":"February 1, 2001","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
