{"tag":"section","attrib":{"id":"idab809f88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9540"},"text":null,"children":[{"tag":"num","attrib":{"value":"9540"},"text":"§ 9540.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Architectural and engineering services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab809f89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9540/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever he considers that it is advantageous to the national defense and that existing facilities of the Department of the Air Force are inadequate, the Secretary of the Air Force may, by contract or otherwise, employ the architectural or engineering services of any person outside that Department for producing and delivering designs, plans, drawings, and specifications needed for any public works or utilities project of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab809f8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9540/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The fee for any service under this section may not be more than 10 percent of the estimated cost, as determined by the Secretary, of the project to which it applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab809f8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9540/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 305, 3324, and 7204, chapter 51, and subchapters III, IV, and VI of chapter 53 of title 5 do not apply to employment under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab809f8c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/577"},"text":"70A Stat. 577","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s28"},"text":"Pub. L. 89–718, § 28","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1119"},"text":"80 Stat. 1119","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tVII/s703/c/3"},"text":"Pub. L. 95–454, title VII, § 703(c)(3)","children":[],"tail":", title VIII, § 801(a)(3)(I), "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1217"},"text":"92 Stat. 1217","children":[],"tail":", 1222; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s514/15"},"text":"Pub. L. 96–513, title V, § 514(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2936"},"text":"94 Stat. 2936","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dB/tXXVIII/s2881/c"},"text":"Pub. L. 118–31, div. B, title XXVIII, § 2881(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/780"},"text":"137 Stat. 780","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab809f8d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab809f8e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab809f8f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","at