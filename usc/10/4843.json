{"tag":"section","attrib":{"id":"idaa9e0735-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843"},"text":null,"children":[{"tag":"num","attrib":{"value":"4843"},"text":"§ 4843.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacturing engineering education program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa9e0736-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Manufacturing Engineering Education Program","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa9e0737-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense shall establish a program under which the Secretary makes grants or other awards to support—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa9e0738-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enhancement of existing programs in manufacturing engineering education to further a mission of the department; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa9e0739-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of new programs in manufacturing engineering education that meet such requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e073a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grants and awards under this section may be made to industry, not-for-profit institutions, institutions of higher education, or to consortia of such institutions or industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e073b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish the program in consultation with the Secretary of Education, the Director of the National Science Foundation, the Director of the Office of Science and Technology Policy, and the secretaries of such other relevant Federal agencies as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e073c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that the program is coordinated with Department programs associated with advanced manufacturing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e073d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program shall be known as the “Manufacturing Engineering Education Program”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa9e073e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographical Distribution of Grants and Awards.—","children":[],"tail":null},{"tag":"content","attrib":{},"text":"In awarding grants and other awards under this subsection, the Secretary shall, to the maximum extent practicable, avoid geographical concentration of awards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa9e073f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A program of engineering education supported pursuant to this section shall meet the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa9e0740-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Components of Program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program of education for which such a grant is made shall be a consolidated and integrated multidisciplinary program of education with an emphasis on the following components:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa9e0741-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Multidisciplinary instruction that encompasses the total manufacturing engineering enterprise and that may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa9e0742-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufacturing engineering education and training through classroom activities, laboratory activities, thesis projects, individual or team projects, internships, cooperative work-study programs, and interactions with industrial facilities, consortia, or such other activities and organizations in the United States and foreign countries as the Secretary considers appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa9e0743-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" faculty development programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa9e0744-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruitment of educators highly qualified in manufacturing engineering to teach or develop manufacturing engineering courses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa9e0745-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" presentation of seminars, workshops, and training for the development of specific manufacturing engineering skills;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa9e0746-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities involving interaction between students and industry, including programs for visiting scholars, personnel exchange, or industry executives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa9e0747-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of new, or updating and modification of existing, manufacturing curriculum, course offerings, and education programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa9e0748-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/d/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishment of programs in manufacturing workforce training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa9e0749-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/d/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishment of joint manufacturing engineering programs with defense laboratories and depots; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa9e074a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/d/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expansion of manufacturing training and education programs and outreach for members of the armed forces, dependents and children of such members, veterans, and employees of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e074b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Opportunities for students to obtain work experience in manufacturing through such activities as internships, summer job placements, or cooperative work-study programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e074c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Faculty and student engagement with industry that is directly related to, and supportive of, the education of students in manufacturing engineering because of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa9e074d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the increased understanding of manufacturing engineering challenges and potential solutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa9e074e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enhanced quality and effectiveness of the instruction that result from that increased understanding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa9e074f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proposals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall solicit proposals for grants and other awards to be made pursuant to this section for the support of programs of manufacturing engineering education that are consistent with the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa9e0750-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Merit Competition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Applications for awards shall be evaluated on the basis of merit pursuant to competitive procedures prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa9e0751-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may select a proposal for an award pursuant to this section if the proposal, at a minimum, does each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa9e0752-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contains innovative approaches for improving engineering education in manufacturing technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e0753-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Demonstrates a strong commitment by the proponents to apply the resources necessary to achieve the objectives for which the award is to be made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e0754-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provides for effective engagement with industry or government organizations that supports the instruction to be provided in the proposed program and is likely to improve manufacturing engineering and technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e0755-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Demonstrates a significant level of involvement of United States industry in the proposed instructional and research activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e0756-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Is likely to attract superior students and promote careers in manufacturing engineering.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e0757-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/g/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Proposes to involve fully qualified personnel who are experienced in manufacturing engineering education and technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e0758-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/g/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Proposes a program that, within three years after the award is made, is likely to attract from sources other than the Federal Government the financial and other support necessary to sustain such program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e0759-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/g/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Proposes to achieve a significant level of participation by women, members of minority groups, and individuals with disabilities through active recruitment of students from among such persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e075a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/g/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Trains students in advanced manufacturing and in relevant emerging technologies and production processes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa9e075b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4843/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Institution of Higher Education Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “institution of higher education” has the meaning given such term in section 101(a) of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"20 U.S.C. 1001(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa9e075c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVIII/s825/a/1"},"text":"Pub. L. 102–190, div. A, title VIII, § 825(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1438"},"text":"105 Stat. 1438","children":[],"tail":", § 2196; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tII/s215"},"text":"Pub. L. 114–328, div. A, title II, § 215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2048"},"text":"130 Stat. 2048","children":[],"tail":"; renumbered § 4843, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1869/d/1"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1869(d)(1)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/p/1/A"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(p)(1)(A)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2148"},"text":"135 Stat. 2148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa9e075d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa9e075e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa9e075f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":