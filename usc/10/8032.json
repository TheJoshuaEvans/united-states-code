{"tag":"section","attrib":{"id":"idab070302-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8032"},"text":null,"children":[{"tag":"num","attrib":{"value":"8032"},"text":"§ 8032.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of the Chief of Naval Operations: general duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab070303-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8032/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of the Chief of Naval Operations shall furnish professional assistance to the Secretary, the Under Secretary, and the Assistant Secretaries of the Navy and to the Chief of Naval Operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab070304-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8032/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under the authority, direction, and control of the Secretary of the Navy, the Office of the Chief of Naval Operations shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab070305-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8032/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsections (c) and (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8014"},"text":"section 8014 of this title","children":[],"tail":", prepare for such employment of the Navy, and for such recruiting, organizing, supplying, equipping (including those aspects of research and development assigned by the Secretary of the Navy), training, servicing, mobilizing, demobilizing, administering, and maintaining of the Navy, as will assist in the execution of any power, duty, or function of the Secretary or the Chief of Naval Operations;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab070306-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8032/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigate and report upon the efficiency of the Navy and its preparation to support military operations by combatant commands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab070307-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8032/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare detailed instructions for the execution of approved plans and supervise the execution of those plans and instructions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab070308-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8032/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as directed by the Secretary or the Chief of Naval Operations, coordinate the action of organizations of the Navy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab070309-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8032/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other duties, not otherwise assigned by law, as may be prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab07030a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s512/b"},"text":"Pub. L. 99–433, title V, § 512(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1049"},"text":"100 Stat. 1049","children":[],"tail":", § 5032; renumbered § 8032 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 807(a)(1), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1834"},"text":"132 Stat. 1834","children":[],"tail":", 1840.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab07030b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab07030c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab07030d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8032 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9032"},"text":"section 9032 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab07030e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s807/a/1"},"text":"Pub. L. 115–232, § 807(a)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s5032"},"text":"section 5032 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “subsections (c) and (d) of section 8014” for “subsections (c) and (d) of section 5014”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab07030f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab070310-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
