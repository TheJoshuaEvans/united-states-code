2, title VIII, § 8122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-26"},"text":"Nov. 26, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1205"},"text":"105 Stat. 1205","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/511/tVIII/s8003"},"text":"Pub. L. 101–511, title VIII, § 8003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1873"},"text":"104 Stat. 1873","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tX/s1021"},"text":"Pub. L. 100–180, div. A, title X, § 1021","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1143"},"text":"101 Stat. 1143","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
