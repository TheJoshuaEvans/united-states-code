{"tag":"section","attrib":{"id":"ida90195ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1622"},"text":null,"children":[{"tag":"num","attrib":{"value":"1622"},"text":"§ 1622.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform allowance: civilian employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida90195ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1622/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense may pay an allowance under this section to any civilian employee of the Defense Intelligence Agency who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90195ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1622/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is assigned to a Defense Attaché Office outside the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90195f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1622/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required by regulation to wear a prescribed uniform in performance of official duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90195f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1622/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5901/a"},"text":"section 5901(a) of title 5","children":[],"tail":", the amount of any such allowance shall be the greater of the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90195f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1622/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount provided for employees of the Department of State assigned to positions outside the United States and required by regulation to wear a prescribed uniform in performance of official duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90195f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1622/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The maximum allowance provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1593/b"},"text":"section 1593(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90195f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1622/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An allowance paid under this section shall be treated in the same manner as is provided in subsection (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5901"},"text":"section 5901 of title 5","children":[],"tail":" for an allowance paid under that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida90195f5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/178/tVI/s601/a"},"text":"Pub. L. 100–178, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-02"},"text":"Dec. 2, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1015"},"text":"101 Stat. 1015","children":[],"tail":", § 1606; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tIII/s336/b"},"text":"Pub.