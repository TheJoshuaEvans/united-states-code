{"tag":"section","attrib":{"id":"ida8289b50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s891"},"text":null,"children":[{"tag":"num","attrib":{"value":"891"},"text":"§ 891.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 91. Insubordinate conduct toward warrant officer, noncommissioned officer, or petty officer","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any warrant officer or enlisted member who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8289b51-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s891/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strikes or assaults a warrant officer, noncommissioned officer, or petty officer, while that officer is in the execution of his office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8289b52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s891/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully disobeys the lawful order of a warrant officer, noncommissioned officer, or petty officer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8289b53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s891/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treats with contempt or is disrespectful in language or deportment toward a warrant officer, noncommissioned officer, or petty officer, while that officer is in the execution of his office;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as a court-martial may direct.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8289b54-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","child