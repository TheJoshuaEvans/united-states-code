il":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-08-02/ch756/s7/a"},"text":"Aug. 2, 1946, ch. 756, § 7(a)","children":[],"tail":" (less applicability to Naval Academy), "},{"tag":"html:a","attrib":{"href":"/us/stat/60/854"},"text":"60 Stat. 854","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s412a"},"text":"5 U.S.C. 412a","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-08-02/ch756/s39"},"text":"Aug. 2, 1946, ch. 756, § 39","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/858"},"text":"60 Stat. 858","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words “for the proper instruction of naval personnel” and in subsection (b) the words “out of naval appropriations” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c) the words “except the authority to prescribe regulations” are omitted, since ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s1071"},"text":"34 U.S.C. 1071","children":[],"tail":" contains no authority for the Secretary to prescribe regulations."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab49b0f0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab49b0f1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8748 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9278"},"text":"section 9278 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab49b0f2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7478"},"text":"section 7478 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s1109/b/1"},"text":"Pub. L. 105–85, § 1109(b)(1)","children":[],"tail":", substituted “Marine Corps University” for “Marine Corps Command and Staff College” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s1109/a"},"text":"Pub. L. 105–85, § 1109(a)","children":[],"tail":", substituted “of the Marine Corps University” for “at the Marine Corps Command and Staff College”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" substituted “Naval War College and Marine Corps Command and Staff College: civilian faculty members” for “Naval War College: employment of civilian professors; compensation” as section catchline and amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) The Secretary of the Navy may employ as many civilians as professors, instructors, and lecturers at the Naval War College as he considers necessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) The compensation of persons employed under this section is as prescribed by the Secretary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) The Secretary, to the extent he considers proper, may delegate the authority conferred by this section to any person in the Department of the Navy, with or without the authority to make successive redelegations.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab49b0f3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab49b0f4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
