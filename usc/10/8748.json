{"tag":"section","attrib":{"id":"idab49b0e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8748"},"text":null,"children":[{"tag":"num","attrib":{"value":"8748"},"text":"§ 8748.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Naval War College and Marine Corps University: civilian faculty members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab49b0e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8748/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy may employ as many civilians as professors, instructors, and lecturers at a school of the Naval War College or of the Marine Corps University as the Secretary considers necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab49b0ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8748/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation of Faculty Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The compensation of persons employed under this section shall be as prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab49b0eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8748/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application to Certain Faculty Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall not apply with respect to professors, instructors, and lecturers employed at a school of the Naval War College or of the Marine Corps University if the duration of the principal course of instruction offered at the school or college involved is less than 10 months.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab49b0ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/464"},"text":"70A Stat. 464","children":[],"tail":", § 7478; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXI/s1124/c/1"},"text":"Pub. L. 101–189, div. A, title XI, § 1124(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1559"},"text":"103 Stat. 1559","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tXI/s1109/a"},"text":"Pub. L. 105–85, div. A, title XI, § 1109(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1927"},"text":"111 Stat. 1927","children":[],"tail":"; renumbered § 8748, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/6"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab49b0ed-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab49b0ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab49b0ef