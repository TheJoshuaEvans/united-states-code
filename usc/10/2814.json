":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" added subsec. (g) and struck out former subsec. (g) which set out notice and wait requirements for a transaction authorized by this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" inserted before period at end “or, if earlier, a period of 20 days has elapsed from the date on which a copy of the notification is provided in an electronic medium pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s480"},"text":"section 480 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (j)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":" substituted “Subchapter II of chapter 5 and sections 541–555 of title 40” for “Sections 202 and 203 of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s483"},"text":"40 U.S.C. 483","children":[],"tail":", 484)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (j)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" substituted “McKinney-Vento Homeless Assistance Act” for “Stewart B. McKinney Homeless Assistance Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" inserted “and” after “Balanced Budget”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
