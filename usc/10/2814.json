{"tag":"section","attrib":{"id":"ida9da909b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814"},"text":null,"children":[{"tag":"num","attrib":{"value":"2814"},"text":"§ 2814.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special authority for development of Ford Island, Hawaii","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9da909c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da909d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), the Secretary of the Navy may exercise any authority or combination of authorities in this section for the purpose of developing or facilitating the development of Ford Island, Hawaii, to the extent that the Secretary determines the development is compatible with the mission of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da909e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Navy may not exercise any authority under this section until—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da909f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary submits to the appropriate committees of Congress a master plan for the development of Ford Island, Hawaii; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da90a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 30 calendar days has elapsed following the date on which the notification is received by those committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da90a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conveyance Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da90a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Navy may convey to any public or private person or entity all right, title, and interest of the United States in and to any real property (including any improvements thereon) or personal property under the jurisdiction of the Secretary in the State of Hawaii that the Secretary determines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da90a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is excess to the needs of the Navy and all of the other armed forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da90a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will promote the purpose of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da90a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A conveyance under this subsection may include such terms and conditions as the Secretary considers appropriate to protect the interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da90a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lease Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da90a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Navy may lease to any public or private person or entity any real property or personal property under the jurisdiction of the Secretary in the State of Hawaii that the Secretary determines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da90a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not needed for current operations of the Navy and all of the other armed forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da90a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will promote the purpose of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da90aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A lease under this subsection shall be subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2667/b/1"},"text":"section 2667(b)(1) of this title","children":[],"tail":" and may include such other terms as the Secretary considers appropriate to protect the interests of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da90ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A lease of real property under this subsection may provide that, upon termination of the lease term, the lessee shall have the right of first refusal to acquire the real property covered by the lease if the property is then conveyed under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da90ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da90ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may provide property support services to or for real property leased under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da90ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent provided in appropriations Acts, any payment made to the Secretary for services provided under this paragraph shall be credited to the appropriation, account, or fund from which the cost of providing the services was paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da90af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition of Leasehold Interest by Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da90b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy may acquire a leasehold interest in any facility constructed under subsection (f) as consideration for a transaction authorized by this section upon such terms as the Secretary considers appropriate to promote the purpose of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da90b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term of a lease under paragraph (1) may not exceed 10 years, unless the Secretary of Defense approves a term in excess of 10 years for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da90b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A lease under this subsection may provide that, upon termination of the lease term, the United States shall have the right of first refusal to acquire the facility covered by the lease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da90b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for Competition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy shall use competitive procedures for purposes of selecting the recipient of real or personal property under subsection (b) and the lessee of real or personal property under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da90b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da90b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As consideration for the conveyance of real or personal property under subsection (b), or for the lease of real or personal property under subsection (c), the Secretary of the Navy shall accept cash, real property, personal property, or services, or any combination thereof, in an aggregate amount equal to not less than the fair market value of the real or personal property conveyed or leased.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da90b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to subsection (i), the services accepted by the Secretary under paragraph (1) may include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da90b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The construction or improvement of facilities at Ford Island.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da90b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The restoration or rehabilitation of real property at Ford Island.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da90b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provision of property support services for property or facilities at Ford Island.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da90ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice and Wait Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy may carry out a transaction authorized by this section only after the end of the 20-day period beginning on the date on which the Secretary submits, in an electronic medium pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s480"},"text":"section 480 of this title","children":[],"tail":", to the appropriate committees of Congress notice of the transaction, including a detailed description of the transaction and a justification for the transaction specifying the manner in which the transaction will meet the purposes of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da90bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ford Island Improvement Account","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da90bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established on the books of the Treasury an account to be known as the “Ford Island Improvement Account”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da90bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There shall be deposited into the account the following amounts:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da90be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts authorized and appropriated to the account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da90bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (c)(4)(B), the amount of any cash payment received by the Secretary for a transaction under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da90c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Account","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da90c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (2), to the extent provided in advance in appropriations Acts, funds in the Ford Island Improvement Account may be used as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da90c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To carry out or facilitate the carrying out of a transaction authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da90c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To carry out improvements of property or facilities at Ford Island.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da90c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/i/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To obtain property support services for property or facilities at Ford Island.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da90c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To extent that the authorities provided under subchapter IV of this chapter are available to the Secretary of the Navy, the Secretary may not use the authorities in this section to acquire, construct, or improve family housing units, military unaccompanied housing units, or ancillary supporting facilities related to military housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da90c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da90c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may transfer funds from the Ford Island Improvement Account to the following funds:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9da90c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/i/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Defense Family Housing Improvement Fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2883/a/1"},"text":"section 2883(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9da90c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/i/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Defense Military Unaccompanied Housing Improvement Fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2883/a/2"},"text":"section 2883(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da90ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts transferred under subparagraph (A) to a fund referred to in that subparagraph shall be available in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2883"},"text":"section 2883 of this title","children":[],"tail":" for activities authorized under subchapter IV of this chapter at Ford Island."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da90cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of Certain Property Management Laws","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this section, transactions under this section shall not be subject to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da90cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 2667 and 2696 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da90cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 501 of the McKinney-Vento Homeless Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11411"},"text":"42 U.S.C. 11411","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da90ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subchapter II of chapter 5 and sections 541–555 of title 40.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da90cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scoring","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to waive the applicability to any lease entered into under this section of the budget scorekeeping guidelines used to measure compliance with the Balanced Budget and Emergency Deficit Control Act of 1985.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da90d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Property Support Service Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “property support service” means the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da90d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any utility service or other service listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2686/a"},"text":"section 2686(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da90d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2814/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other service determined by the Secretary to be a service that supports the operation and maintenance of real property, personal property, or facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9da90d3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dB/tXXVIII/s2802/a/1"},"text":"Pub. L. 106–65, div. B, title XXVIII, § 2802(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/845"},"text":"113 Stat. 845","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1087(a)(16)], "},{"tag":"date","attrib":{"date":"2000-10-30"},