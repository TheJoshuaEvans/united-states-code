{"tag":"section","attrib":{"id":"idaba453df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12532"},"text":null,"children":[{"tag":"num","attrib":{"value":"12532"},"text":"§ 12532.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination for nonpayment of premiums; forfeiture","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaba453e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12532/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination for Nonpayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The coverage of a member under the insurance program shall terminate without prior notice upon a failure of the member to make required monthly payments of premiums for two consecutive months. The Secretary may provide in the regulations for reinstatement of insurance coverage terminated under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba453e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12532/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Forfeiture","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person convicted of mutiny, treason, spying, or desertion, or who refuses to perform service in the armed forces or refuses to wear the uniform of any of the armed forces shall forfeit all rights to insurance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaba453e2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s512/a/1"},"text":"Pub. L. 104–106, div. A, title V, § 512(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/305"},"text":"110 Stat. 305","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
