/us/stat/53/555"},"text":"53 Stat. 555","children":[],"tail":")”, are omitted as obsolete, since training formerly performed under that act is now performed under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9301"},"text":"section 9301 of this title","children":[],"tail":". The words “personnel of the Departments” are substituted for the words “flying cadets”, since the authority is reciprocal, and to conform to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9656"},"text":"section 9656 of this title","children":[],"tail":". The words “flying cadet” are omitted as obsolete. 10:298c (last 28 words) is omitted to reflect Title IV of the National Security Act of 1947, as amended ("},{"tag":"ref","attrib":{"href":"/us/stat/63/585"},"text":"63 Stat. 585","children":[],"tail":"), which authorized the Secretary of Defense to prescribe regulations governing the use and sale of certain inventories at cost, including applicable administrative expenses. (See opinion of the Assistant General Counsel (Fiscal Matters) of the Office of the Secretary of Defense, "},{"tag":"date","attrib":{"date":"1955-01-04"},"text":"January 4, 1955","children":[],"tail":".)"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
