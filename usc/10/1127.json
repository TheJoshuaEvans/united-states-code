{"tag":"section","attrib":{"id":"ida89b0bb4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1127"},"text":null,"children":[{"tag":"num","attrib":{"value":"1127"},"text":"§ 1127.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Precedence of the award of the Purple Heart","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In prescribing regulations establishing the order of precedence of awards and decorations authorized to be displayed on the uniforms of members of the armed forces, the Secretary of the military department concerned shall accord the Purple Heart a position of precedence, in relation to other awards and decorations authorized to be displayed, not lower than that immediately following the bronze star.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida89b0bb5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tV/s553/a"},"text":"Pub. L. 98–525, title V, § 553(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2532"},"text":"98 Stat. 2532","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tV/s533"},"text":"Pub. L. 99–145, title V, § 533","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/634"},"text":"99 Stat. 634","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida89b0bb6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida89b0bb7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida89b0bb8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" substituted “the bronze star” for “the lowest position accorded any award or decoration for valor”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
