{"tag":"section","attrib":{"id":"ida8c85d40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1445"},"text":null,"children":[{"tag":"num","attrib":{"value":"1445"},"text":"§ 1445.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correction of administrative deficiencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever he considers it necessary, the Secretary concerned may, under regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1444/a"},"text":"section 1444(a) of this title","children":[],"tail":", correct any election, or any change or revocation of an election, under this subchapter when he considers it necessary to correct an administrative error. Except when procured by fraud, a correction under this section is final and conclusive on all officers of the United States."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida8c85d41-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/381/s6/1"},"text":"Pub. L. 87–381, § 6(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-10-04"},"text":"Oct. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/811"},"text":"75 Stat. 811","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/92/425/s1/2/A"},"text":"Pub. L. 92–425, § 1(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-21"},"text":"Sept. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/706"},"text":"86 Stat. 706","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8c85d42-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8c85d43-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8c85d44-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/425"},"text":"Pub. L. 92–425","children":[],"tail":" substituted “subchapter” for “chapter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
