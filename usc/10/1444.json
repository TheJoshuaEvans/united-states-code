{"tag":"section","attrib":{"id":"ida8c85d28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1444"},"text":null,"children":[{"tag":"num","attrib":{"value":"1444"},"text":"§ 1444.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations; determinations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8c85d29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1444/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall prescribe regulations to carry out this subchapter. Those regulations shall, so far as practicable, be uniform for the armed forces, the National Oceanic and Atmospheric Administration, and the Public Health Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8c85d2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1444/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Determinations and certifications of eligibility for, and payments of, annuities and other payments or refunds under this subchapter shall be made by the department concerned. However, in the case of a department other than a military department, payments shall be made through the disbursing facilities of the Department of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8c85d2b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/111"},"text":"70A Stat. 111","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/381/s5"},"text":"Pub. L. 87–381, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-10-04"},"text":"Oct. 4, 1961","children":[],"tail":", "},{"tag":"ref