{"tag":"section","attrib":{"id":"idab68d164-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9233"},"text":null,"children":[{"tag":"num","attrib":{"value":"9233"},"text":"§ 9233.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of exemplary conduct","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"All commanding officers and others in authority in the Air Force and in the Space Force are required—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab68d165-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9233/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to show in themselves a good example of virtue, honor, patriotism, and subordination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab68d166-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9233/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be vigilant in inspecting the conduct of all persons who are placed under their command;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab68d167-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9233/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to guard against and suppress all dissolute and immoral practices, and to correct, according to the laws and regulations of the Air Force or the Space Force, respectively, all persons who are guilty of them; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab68d168-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9233/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take all necessary and proper measures, under the laws, regulations, and customs of the Air Force or the Space Force, respectively, to promote and safeguard the morale, the physical well-being, and the general welfare of the officers and enlisted persons under their command or charge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab68d169-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tV/s507/b/1"},"text":"Pub. L. 105–85, div. A, title V, § 507(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1727"},"text":"111 Stat. 1727","children":[],"tail":", § 8583; renumbered § 9233, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/b/7"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1832"},"text":"132 Stat. 1832","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s923/c/7"},"text":"Pub. L. 116–283, div. A, title IX, § 923(c)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3811"},"text":"134 Stat. 3811","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab68d16a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab68d16b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab68d16c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/c/7/A"},"text":"Pub. L. 116–283, § 923(c)(7)(A)","children":[],"tail":", inserted “and in the Space Force” after “the Air Force” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/c/7/B"},"text":"Pub. L. 116–283, § 923(c)(7)(B)","children":[],"tail":", inserted “or the Space Force, respectively” after “the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8583"},"text":"section 8583 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab68d16d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab68d16e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
