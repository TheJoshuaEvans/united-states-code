{"tag":"section","attrib":{"id":"idaab38b59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514"},"text":null,"children":[{"tag":"num","attrib":{"value":"5514"},"text":"§ 5514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition accountability on the missile defense system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaab38b5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Baselines Required","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab38b5b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In accordance with paragraph (2), the Director of the Missile Defense Agency shall establish and maintain an acquisition baseline for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaab38b5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each program element of the missile defense system, as specified in section 223 ","children":[{"tag":"ref","attrib":{"idref":"fn002132"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002132"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab38b5d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each designated major subprogram of such program elements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab38b5e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director shall establish an acquisition baseline required by paragraph (1) before the date on which the program element or major subprogram enters—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaab38b5f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engineering and manufacturing development (or its equivalent); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab38b60-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" production and deployment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab38b61-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided by subsection (c), the Director may not adjust or revise an acquisition baseline established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab38b62-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements of Baselines","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each acquisition baseline required by subsection (a) for a program element or major subprogram shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab38b63-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A comprehensive schedule, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaab38b64-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and development milestones;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab38b65-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition milestones, including design reviews and key decision points;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab5fc66-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" key test events, including ground, flight, and cybersecurity tests and ballistic missile defense system tests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab5fc67-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delivery and fielding schedules;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab5fc68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quantities of assets planned for acquisition and delivery in total and by fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab5fc69-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planned contract award dates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab5fc6a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A detailed technical description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaab5fc6b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capability to be developed, including hardware and software;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab5fc6c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" system requirements, including performance requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab5fc6d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" how the proposed capability satisfies a capability requirement or performance attribute identified through—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaab5fc6e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the missile defense warfighter involvement process, as governed by United States Strategic Command Instruction 538–03, or such successor document; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaab5fc6f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" processes and products reviewed by the Joint Chiefs of Staff or Joint Requirements Oversight Council;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab5fc70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" key knowledge points that must be achieved to permit continuation of the program and to inform production and deployment decisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab5fc71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Director plans to improve the capability over time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab5fc72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A cost estimate, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaab5fc73-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a life-cycle cost estimate that separately identifies the costs regarding research and development, procurement, military construction, operations and sustainment, and disposal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab5fc74-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" program acquisition unit costs for the program element;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab5fc75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" average procurement unit costs and program acquisition costs for the program element;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab5fc76-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of when the document regarding the program joint cost analysis requirements description is scheduled to be approved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab5fc77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation for why a program joint cost analysis requirements description has not been prepared and approved, and, if a program joint cost analysis requirements description is not applicable, the rationale for such inapplicability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab5fc78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A test baseline summarizing the comprehensive test program for the program element or major subprogram outlined in the integrated master test plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab5fc79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception to Limitation on Revision","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director may adjust or revise an acquisition baseline established under this section if the Director submits to the congressional defense committees notification of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab5fc7a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a justification for such adjustment or revision;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab5fc7b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific adjustments or revisions made to the acquisition baseline, including to the elements described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab5fc7c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective date of the adjusted or revised acquisition baseline.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab5fc7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operations and Sustainment Cost Estimates","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall ensure that each life-cycle cost estimate included in an acquisition baseline pursuant to subsection (b)(3)(A) includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab5fc7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all of the operations and sustainment costs for which the Director is responsible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab5fc7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the operations and sustainment functions and costs for which a military department is responsible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab5fc80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of operations and sustainment costs (dollar value and base year) for which the military department or other element of the Department of Defense is responsible; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab5fc81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaab5fc82-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a citation to the source (such as a joint cost estimate or one or more military department estimates) that captures the operations and sustainment costs for which a military department or other element of the Department of Defense is responsible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab5fc83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date the source was prepared; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab5fc84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5514/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if and when the source was independently verified by the Office for Cost Assessment and Program Evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaab5fc85-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1649/a"},"text":"Pub. L. 118–159, div. A, title XVI, § 1649(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2191"},"text":"138 Stat. 2191","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVIII/s1811/g/5"},"text":"Pub. L. 119–60, div. A, title XVIII, § 1811(g)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1243"},"text":"139 Stat. 1243","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaab5fc86-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaab5fc87-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaab5fc88-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s223"},"text":"Section 223 of this title","children":[],"tail":", referred to in subsec. (a)(1)(A), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1649/b/1"},"text":"Pub. L. 118–159, div. A, title XVI, § 1649(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2199"},"text":"138 Stat. 2199","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s5511"},"text":"section 5511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaab5fc89-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s225"},"text":"section 225 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1649/b/1"},"text":"Pub. L. 118–159, div. A, title XVI, § 1649(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2199"},"text":"138 Stat. 2199","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaab5fc8a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(2)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “reviewed” for “approved”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaab5fc8b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaab5fc8c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Improvement to Operations and Sustainment Cost Estimates","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tII/s231/a"},"text":"Pub. L. 113–66, div. A, title II, § 231(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/710"},"text":"127 Stat. 710","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/66/dA/tII/s231/a"},"text":"“In preparing the acquisition accountability reports on the ballistic missile defense system required by [former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s225"},"text":"section 225 of title 10","children":[],"tail":", United States Code, the Director of the Missile Defense Agency shall improve the quality of cost estimates relating to operations and sustainment that are included in such reports under subsection (b)(3)(A) of such section, including with respect to the confidence levels of such cost estimates.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
