{"tag":"section","attrib":{"id":"ida78b21f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222f"},"text":null,"children":[{"tag":"num","attrib":{"value":"222f"},"text":"§ 222f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unfunded priorities of the Under Secretary of Defense for Research and Engineering: annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida78b21f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 10 days after the date on which the budget of the President for a fiscal year is submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", the Secretary of Defense, after coordinating with the Secretaries of the military departments, shall submit to the congressional defense committees a report on the unfunded priorities of the Department of Defense related to activities for which the Under Secretary of Defense for Research and Engineering has authority."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida78b21f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida78b21f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c), each report submitted under subsection (a) shall specify, for each unfunded priority covered by such report, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida78b21f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222f/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary description of such priority, including the objectives to be achieved if such priority is funded (whether in whole or in part).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b21f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222f/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The additional amount of funds recommended in connection with the objectives under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b21f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222f/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Account information with respect to such priority, including the following (as applicable):","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida78b21fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222f/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Line Item Number (LIN) for applicable procurement accounts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida78b21fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222f/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Program Element (PE) number for applicable research, development, test, and evaluation accounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b21fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prioritization of priorities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The report under subsection (a) shall present the unfunded priorities covered by such report in order of urgency of priority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida78b21fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion of Priorities Covered in Other Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report submitted under subsection (a) shall not include unfunded priorities or requirements covered in reports submitted under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida78b21fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 222a or 222b ","children":[{"tag":"ref","attrib":{"idref":"fn002017"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002017"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b21ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 2806 of the National Defense Authorization Act for Fiscal Year 2018 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Public Law 115–91","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s222a"},"text":"10 U.S.C. 222a","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida78b2200-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form of Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each report submitted under subsection (a) shall be submitted in classified form, but may include an unclassified summary as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida78b2201-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unfunded Priority Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “unfunded priority”, in the case of a fiscal year, means a program, activity, or mission requirement, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida78b2202-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222f/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not funded in the budget of the President for the fiscal year as submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b2203-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222f/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" would have been recommended for funding through that budget if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida78b2204-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222f/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional resources had been available for the budget to fund the program, activity, or mission requirement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b2205-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222f/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program, activity, or mission requirement has emerged since the budget was formulated; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b2206-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222f/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a military construction project, has reached 35 percent design.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida78b2207-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tII/s211"},"text":"Pub. L. 118–31, div. A, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/182"},"text":"137 Stat. 182","children":[],"tail":", § 222e; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tII/s212"},"text":"Pub. L. 118–159, div. A, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1824"},"text":"138 Stat. 1824","children":[],"tail":"; renumbered § 222f, "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVII/s1701/a/7"},"text":"Pub. L. 119–60, div. A, title XVII, § 1701(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1208"},"text":"139 Stat. 1208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida78b2208-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida78b2209-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida78b220a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s222b"},"text":"Section 222b of this title","children":[],"tail":", referred to in subsec. (c)(1), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1649/b/1"},"text":"Pub. L. 118–159, div. A, title XVI, § 1649(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2199"},"text":"138 Stat. 2199","children":[],"tail":". For provisions similar to those in former "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s222b"},"text":"section 222b of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s5513"},"text":"section 5513 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida78b220b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s222e"},"text":"section 222e of this title","children":[],"tail":" relating to annual report on unfunded priorities of the Under Secretary of Defense for Research and Engineering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s212/1"},"text":"Pub. L. 118–159, § 212(1)","children":[],"tail":", substituted “the Secretary of Defense, after coordinating with the Secretaries of the military departments, shall” for “the Secretary of Defense shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s212/2"},"text":"Pub. L. 118–159, § 212(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
