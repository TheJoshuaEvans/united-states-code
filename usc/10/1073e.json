{"tag":"section","attrib":{"id":"ida86db983-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1073e"},"text":"§ 1073e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of armed forces from infectious diseases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida86db984-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall develop and implement a plan to ensure that the armed forces have the diagnostic equipment, testing capabilities, and personal protective equipment necessary to protect members of the armed forces from the threat of infectious diseases and to treat members who contract infectious diseases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida86db985-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Secretary shall ensure the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida86db986-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each military medical treatment facility has the testing capabilities described in such subsection, as appropriate for the mission of the facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida86db987-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each deployed naval vessel has access to the testing capabilities described in such subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida86db988-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the armed forces deployed in support of a contingency operation outside of the United States have access to the testing capabilities described in such subsection, including at field hospitals, combat support hospitals, field medical stations, and expeditionary medical facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida86db989-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Department of Defense maintains—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida86db98a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073e/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 30-day supply of personal protective equipment in a quantity sufficient for each member of the armed forces, including the reserve components thereof; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida86db98b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073e/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capability to rapidly resupply such equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida86db98c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Research and Development","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida86db98d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall include with the defense budget materials (as defined by section 231(f) ","children":[{"tag":"ref","attrib":{"idref":"fn002049"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002049"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title) for a fiscal year a plan to research and develop vaccines, diagnostics, and therapeutics for infectious diseases."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida86db98e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that the medical laboratories of the Department of Defense are equipped with the technology needed to facilitate rapid research and development of vaccines, diagnostics, and therapeutics in the case of a pandemic.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida86db98f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVII/s712/a"},"text":"Pub. L. 116–283, div. A, title VII, § 712(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3691"},"text":"134 Stat. 3691","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida86db990-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida86db991-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida86db992-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s231/f"},"text":"Section 231(f) of this title","children":[],"tail":", referred to in subsec. (c)(1), was redesignated as "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s231/g"},"text":"section 231(g) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tIII/s352/a/2"},"text":"Pub. L. 117–263, div. A, title III, § 352(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2533"},"text":"136 Stat. 2533","children":[],"tail":", and subsequently was redesignated as "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s231/h"},"text":"section 231(h) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tX/s1021/1"},"text":"Pub. L. 118–159, div. A, title X, § 1021(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2052"},"text":"138 Stat. 2052","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
