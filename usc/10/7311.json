{"tag":"section","attrib":{"id":"idaae326e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7311"},"text":null,"children":[{"tag":"num","attrib":{"value":"7311"},"text":"§ 7311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Twenty years or more: regular or reserve commissioned officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaae326ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7311/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army may, upon the officer’s request, retire a regular or reserve commissioned officer of the Army who has at least 20 years of service computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7326"},"text":"section 7326 of this title","children":[],"tail":", at least 10 years of which have been active service as a commissioned officer."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaae326eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaae326ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7311/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may authorize the Secretary of the Army, during the period specified in paragraph (2), to reduce the requirement under subsection (a) for at least 10 years of active service as a commissioned officer to a period (determined by the Secretary of the Army) of not less than eight years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaae326ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7311/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The period specified in this paragraph is the period beginning on ","children":[{"tag":"date","attrib":{"date":"2011-01-07"},"text":"January 7, 2011","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2018-09-30"},"text":"September 30, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaae326ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/224"},"text":"70A Stat. 224","children":[],"tail":", § 3911; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tV/s523/a"},"text":"Pub. L. 101–510, div. A, title V, § 523(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1562"},"text":"104 Stat. 1562","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tV/s561/c"},"text":"Pub. L. 103–160, div. A, title V, § 561(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1667"},"text":"107 Stat. 1667","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tV/s561/e"},"text":"Pub. L. 105–261, div. A, title V, § 561(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2025"},"text":"112 Stat. 2025","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 571(e)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href"