{"tag":"section","attrib":{"id":"ida8027538-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714"},"text":null,"children":[{"tag":"num","attrib":{"value":"714"},"text":"§ 714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senior leaders of the Department of Defense and other specified persons: authority to provide protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8027539-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protection for Department Leadership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense, under regulations prescribed by the Secretary and in accordance with guidelines approved by the Secretary and the Attorney General, may authorize qualified members of the armed forces and qualified civilian employees of the Department of Defense to provide physical protection and personal security to the following persons who, by nature of their positions, require continuous security and protection:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida802753a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida802753b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Deputy Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida802753c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chairman of the Joint Chiefs of Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida802753d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Vice Chairman of the Joint Chiefs of Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida802753e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Secretaries of the military departments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida802753f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Joint Chiefs of Staff in addition to the Chairman and Vice Chairman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8027540-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Commanders of combatant commands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8027541-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protection for Former or Retired Department Leadership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense, under regulations prescribed by the Secretary and in accordance with guidelines approved by the Secretary and the Attorney General, may authorize qualified members of the armed forces and qualified civilian employees of the Department of Defense to provide physical protection and personal security to a former or retired official who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8027542-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" previously served in a position identified in paragraphs (1) through (7) ","children":[{"tag":"ref","attrib":{"idref":"fn002040"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002040"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “of subsection (a)”."}],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8027543-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" faces serious and credible threats arising from duties performed while employed by the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8027544-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protection for Additional Personnel.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8027545-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to provide","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense, under regulations prescribed by the Secretary and in accordance with guidelines approved by the Secretary and the Attorney General, may authorize qualified members of the armed forces and qualified civilian employees of the Department of Defense to provide physical protection and personal security to individuals other than individuals described in subsection (a) or (b) if the Secretary determines that such protection and security are necessary because—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8027546-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a serious and credible threat to the safety of the individual for whom protection is to be provided; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8027547-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compelling operational considerations make such protection essential to the conduct of official Department of Defense business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8027548-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Individuals authorized to receive physical protection and personal security under this subsection include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8027549-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any official or employee of the Department of Defense or member of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida802754a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A former or retired official who faces serious and credible threats arising from duties performed while employed by the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida802754b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A head of a foreign state, an official representative of a foreign government, or any other distinguished foreign visitor to the United States who is primarily conducting official business with the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida802754c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any member of the immediate family of a person authorized to receive physical protection and personal security under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida802754d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual who has been designated by the President, and who has received the advice and consent of the Senate, to serve as Secretary of Defense, but who has not yet been appointed as Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida802754e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on delegation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority of the Secretary of Defense to authorize the provision of physical protection and personal security under this subsection may be delegated only to the Deputy Secretary of Defense or the Under Secretary of Defense for Intelligence and Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida802754f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Temporary protection","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may temporarily provide physical protection and personal security under this subsection to an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8027550-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pending the determination of the Secretary under paragraph (4) regarding such individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8027551-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a period not to exceed 30 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8027552-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for Written Determination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A determination of the Secretary of Defense whether to provide physical protection and personal security under subsection (b) or (c), or reimbursement under subsection (h), shall be in writing, shall be based on a threat assessment by an appropriate law enforcement, security, or intelligence organization, and shall include the name and title of the officer, employee, or other individual affected, the reason for such determination, the duration of any authorized protection and security for such officer, employee, or individual, and the nature of any arrangements for such protection and security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8027553-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration of Protection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall require periodic reviews, not less than once every six months, of the duration of protection provided to individuals under subsection (b) or (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8027554-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submissions to Congress.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8027555-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (4), the Secretary of Defense shall submit to the congressional defense committee determinations made pursuant to this section as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8027556-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An initial determination made under subsection (d), not later than 15 days after the date on which the determination is made, including the justification for such determination and a current threat assessment by an appropriate law enforcement, security, or intelligence organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8027557-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A determination to deny the renewal of physical protection and security under subsection (b) or (c), or reimbursement under subsection (j), not later than 15 days after the date on which the determination is made, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8027558-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the justification for such determination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8027559-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a current threat assessment by an appropriate law enforcement, security, or intelligence organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida802755a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/f/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that threats to the individual arising from duties performed while employed by the Department of Defense can be sufficiently mitigated without physical protection and security or reimbursement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida804be4b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A determination to terminate physical protection and security under subsection (b) or (c), or reimbursement under subsection (j), during a previously authorized period of protection, not later than 48 hours after the date on which the determination is made, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida804be4c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/f/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the justification for such determination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida804be4d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/f/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a current threat assessment by an appropriate law enforcement, security, or intelligence organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida804be4e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/f/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that threats to the individual arising from duties performed while employed by the Department of Defense can be sufficiently mitigated without protection and security or reimbursement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida804be4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A determination to deny a request for reimbursement of an individual described in subsection (b), not later than 15 days after the date on which the determination is made, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida804be50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/f/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the justification for such determination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida804be51-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/f/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a current threat assessment by an appropriate law enforcement, security, or intelligence organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida804be52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/f/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that threats to the individual arising from duties performed while employed by the Department of Defense can be sufficiently mitigated without reimbursement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida804be53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form of report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A report submitted under paragraph (1) may be made in classified form.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida804be54-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations and guidelines","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall submit to the congressional defense committees the regulations and guidelines prescribed pursuant to subsections (b) and (c)(1), and a description of any changes to such guidelines, not less than 20 days before the date on which such regulations take effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida804be55-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) does not apply to determinations made with respect to the following individuals:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida804be56-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual described in subsection (c)(2)(C) who is otherwise sponsored by the Secretary of Defense, the Deputy Secretary of Defense, the Chairman of the Joint Chiefs of Staff, or the Vice Chairman of the Joint Chiefs of Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida804be57-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual described in subsection (c)(2)(E).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida804be58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification to Certain Protected Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall provide written notification to any individual receiving physical protection and personal security under subsection (a) or (b), or reimbursement under subsection (j), at least 90 days prior to terminating or denying the renewal of protection and security protection or reimbursement, as the case may be, for such individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida804be59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the terms “qualified members of the armed forces” and “qualified civilian employees of the Department of Defense” refer collectively to members or employees who are assigned to investigative, law enforcement, or security duties of any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida804be5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Army Criminal Investigation Command.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida804be5b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Naval Criminal Investigative Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida804be5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Air Force Office of Special Investigations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida804be5d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Defense Criminal Investigative Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida804be5e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Pentagon Force Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida804be5f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida804be60-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No additional law enforcement or arrest authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Other than the authority to provide protection and security under this section, nothing in this section may be construed to bestow any additional law enforcement or arrest authority upon the qualified members of the armed forces and qualified civilian employees of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida804be61-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Posse comitatus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to abridge ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1385"},"text":"section 1385 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida804be62-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorities of other departments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section may be construed to preclude or limit, in any way, the express or implied powers of the Secretary of Defense or other Department of Defense officials, or the duties and authorities of the Secretary of State, the Director of the United States Secret Service, the Director of the United States Marshals Service, or any other Federal law enforcement agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida804be63-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s714/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may reimburse a former or retired official who faces serious and credible threats arising from duties performed while employed by the Department for security services and equipment procured at the personal expense of the official, not to exceed an aggregate of $15,000,000 in any fiscal year for all former and retired officials authorized by the Secretary of Defense for such reimbursement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida804be64-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tIX/s952/c/1"},"text":"Pub. L. 114–328, div. A, title IX, § 952(c)(1)","children":[],"tail":", (4)–(6), "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2375"},"text":"130 Stat. 2375","children":[],"tail":", 2376; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tV/s529A"},"text":"Pub. L. 118–31, div. A, title V, § 529A","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/256"},"text":"137 Stat. 256","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s522"},"text":"Pub. L. 118–159, div. A, title V, § 522","children":[],"tail":", title XVII, § 1701(a)(16), "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1883"},"text":"138 Stat. 1883","children":[],"tail":", 2204; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tX/s1042"},"text":"Pub. L. 119–60, div. A, title X, § 1042","children":[],"tail":", title XVII, § 1701(a)(12), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1035"},"text":"139 Stat. 1035","children":[],"tail":", 1208.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida804be65-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida804be66-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida804be67-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Text of section, as added by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":", is based on text of subsecs. (a) to (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1074"},"text":"section 1074 of Pub. L. 110–181","children":[],"tail":", div. A, title X, "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/330"},"text":"122 Stat. 330","children":[],"tail":", as amended, which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s113"},"text":"section 113 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tIX/s952/c/3"},"text":"Pub. L. 114–328, div. A, title IX, § 952(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2375"},"text":"130 Stat. 2375","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida804be68-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 714, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tV/s597/a"},"text":"Pub. L. 105–85, div. A, title V, § 597(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1766"},"text":"111 Stat. 1766","children":[],"tail":", related to required grade of officer selected for assignment to position of defense attaché to United States embassy in France, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tV/s503/a"},"text":"Pub. L. 108–136, div. A, title V, § 503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1456"},"text":"117 Stat. 1456","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 714, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/33"},"text":"70A Stat. 33","children":[],"tail":", related to reports to Congress on length of tours of duty outside the United States by members of the Army and Air Force, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/86/533/s1/5/A"},"text":"Pub. L. 86–533, § 1(5)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-06-29"},"text":"June 29, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/246"},"text":"74 Stat. 246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida804be69-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1042/3"},"text":"Pub. L. 119–60, § 1042(3)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1042/2"},"text":"Pub. L. 119–60, § 1042(2)","children":[],"tail":", redesignated subsec. (b) as (c). Former subsec. (c) redesignated (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1042/4/A"},"text":"Pub. L. 119–60, § 1042(4)(A)","children":[],"tail":", substituted “subsection (a) or (b)” for “paragraphs (1) through (7) of subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1042/4/B"},"text":"Pub. L. 119–60, § 1042(4)(B)","children":[],"tail":", redesignated par. (7) as (4) and struck out former pars. (4) and (5) which related to requirement for written determination and duration of protection, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1042/4/B"},"text":"Pub. L. 119–60, § 1042(4)(B)","children":[],"tail":", struck out par. (6) which related to submission to Congress of certain determinations and regulations and guidelines."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1701/a/12"},"text":"Pub. L. 119–60, § 1701(a)(12)","children":[],"tail":", which directed amendment of subsec. (b)(6)(A) by inserting “a” before “determination” in the second sentence, could not be executed because of the intervening amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1042/2"},"text":"Pub. L. 119–60, § 1042(2)","children":[],"tail":", (4)(B), redesignating subsec. (b) as (c) and striking par. (6). See above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1042/4/B"},"text":"Pub. L. 119–60, § 1042(4)(B)","children":[],"tail":", redesignated par. (7) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1042/5"},"text":"Pub. L. 119–60, § 1042(5)","children":[],"tail":", added subsecs. (d) to (g). Former subsecs. (d) and (e) redesignated (i) and (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (h) to (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1042/1"},"text":"Pub. L. 119–60, § 1042(1)","children":[],"tail":", redesignated subsecs. (c) to (e) as (h) to (j), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s522/a/1"},"text":"Pub. L. 118–159, § 522(a)(1)","children":[],"tail":", which directed striking out “"},{"tag":"inline","attrib":{},"text":"within the united states","children":[],"tail":"” in section catchline, was executed by striking out “within the United States” after “provide protection” to reflect the probable intent of Congress and the style used in the catchline of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s522/a/2"},"text":"Pub. L. 118–159, § 522(a)(2)","children":[],"tail":", (3), struck out “within the United States” after “personal security” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1701/a/16"},"text":"Pub. L. 118–159, § 1701(a)(16)","children":[],"tail":", substituted “a serious” for “an serious”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s522/b"},"text":"Pub. L. 118–159, § 522(b)","children":[],"tail":", inserted “or the Under Secretary of Defense for Intelligence and Security” after “only to the Deputy Secretary of Defense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s522/c"},"text":"Pub. L. 118–159, § 522(c)","children":[],"tail":", inserted “whether” before “to provide”, and substituted “any authorized” for “the authorized” and “any arrangements for such” for “the arrangements for the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s522/d"},"text":"Pub. L. 118–159, § 522(d)","children":[],"tail":", substituted “an initial determination made under paragraph (4), or a determination to deny the renewal of protection and security” for “each determination made under paragraph (4) to provide protection and security to an individual” and inserted at end “In the case of determination to continue protection and security, the Secretary shall make such submission not less than twice each year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s522/e"},"text":"Pub. L. 118–159, § 522(e)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s529A/a/1"},"text":"Pub. L. 118–31, § 529A(a)(1)","children":[],"tail":", substituted “serious and credible threat” for “imminent and credible threat”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s529A/a/2"},"text":"Pub. L. 118–31, § 529A(a)(2)","children":[],"tail":", struck out “for a period of up to two years beginning on the date on which the official separates from the Department” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s529A/a/3"},"text":"Pub. L. 118–31, § 529A(a)(3)","children":[],"tail":", amended par. (5) generally. Prior to amendment, par. (5) consisted of subpars. (A) to (C) relating to initial period of protection, subsequent period of protection, and requirement for compliance with regulations, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s529A/a/4"},"text":"Pub. L. 118–31, § 529A(a)(4)","children":[],"tail":", struck out “and of each determination under paragraph (5)(B) to extend such protection and security” after “an individual”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s529A/b"},"text":"Pub. L. 118–31, § 529A(b)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s952/c/4/A"},"text":"Pub. L. 114–328, § 952(c)(4)(A)","children":[],"tail":", substituted “armed forces” for “Armed Forces” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s952/c/5/A/i"},"text":"Pub. L. 114–328, § 952(c)(5)(A)(i)","children":[],"tail":", substituted “Members of the Joint Chiefs of Staff in addition to the Chairman and Vice Chairman” for “Chiefs of the Services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s952/c/5/A/ii"},"text":"Pub. L. 114–328, § 952(c)(5)(A)(ii)","children":[],"tail":", (iii), redesignated par. (8) as (7) and struck out former par. (7) which read as follows: “Chief of the National Guard Bureau.”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s952/c/4/A"},"text":"Pub. L. 114–328, § 952(c)(4)(A)","children":[],"tail":", (5)(B), in introductory provisions, substituted “armed forces” for “Armed Forces” and “through (7)” for “through (8)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s952/c/6"},"text":"Pub. L. 114–328, § 952(c)(6)","children":[],"tail":", struck out “, military member,” after “official” and inserted “or member of the armed forces” after “of the Department of Defense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s952/c/4/B"},"text":"Pub. L. 114–328, § 952(c)(4)(B)","children":[],"tail":", substituted “section, the terms ‘qualified members of the armed forces’ and” for “section:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"Congressional defense committees","children":[],"tail":".—The term ‘congressional defense committees’ means the Committee on Appropriations and the Committee on Armed Services of the Senate and the Committee on Appropriations and the Committee on Armed Services of the House of Representatives."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Qualified members of the armed forces and qualified civilian employees of the department of defense","children":[],"tail":".—The terms ‘qualified members of the Armed Forces’ and”; redesignated subpars. (A) to (E) of former par. (2) as pars. (1) to (5), respectively, of subsec. (c); and realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s952/c/4/A"},"text":"Pub. L. 114–328, § 952(c)(4)(A)","children":[],"tail":", substituted “armed forces” for “Armed Forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s952/c/4/C"},"text":"Pub. L. 114–328, § 952(c)(4)(C)","children":[],"tail":", struck out “, United States Code” after “title 18”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida804be6a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida804be6b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Temporary Extension of Authority To Provide Security for Former Department of Defense Officials","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tXI/s1105"},"text":"Pub. L. 117–263, div. A, title XI, § 1105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2817"},"text":"136 Stat. 2817","children":[],"tail":", provided authority to provide security for former Department of Defense Officials from "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", to "},{"tag":"date","attrib":{"date":"2024-01-01"},"text":"Jan. 1, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
