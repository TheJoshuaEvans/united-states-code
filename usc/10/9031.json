{"tag":"section","attrib":{"id":"idab5cc34c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9031"},"text":null,"children":[{"tag":"num","attrib":{"value":"9031"},"text":"§ 9031.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" The Air Staff: function; composition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab5cc34d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9031/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is in the executive part of the Department of the Air Force an Air Staff. The function of the Air Staff is to assist the Secretary of the Air Force in carrying out his responsibilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab5cc34e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9031/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Air Staff is composed of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab5cc34f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9031/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5cc350-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9031/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Vice Chief of Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5cc351-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9031/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Deputy Chiefs of Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5cc352-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9031/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Chiefs of Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5cc353-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9031/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Surgeon General of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5cc354-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9031/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Judge Advocate General of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5cc355-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9031/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of the Air Force Reserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5cc356-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9031/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other members of the Air Force or the Space Force assigned or detailed to the Air Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5cc357-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9031/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Civilian employees in the Department of the Air Force assigned or detailed to the Air Staff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab5cc358-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9031/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise specifically prescribed by law, the Air Staff shall be organized in such manner, and its members shall perform such duties and have such titles, as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab5cc359-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/490"},"text":"70A Stat. 490","children":[],"tail":", § 8031; "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s45"},"text":"Pub. L. 89–718, § 45","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1121"},"text":"80 Stat. 1121","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/608/s1/5"},"text":"Pub. L. 93–608, § 1(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1968"},"text":"88 Stat. 1968","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tV/s515"},"text":"Pub. L. 98–525, title V, § 515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2522"},"text":"98 Stat. 2522","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s522/a"},"text":"Pub. L. 99–433, title V, § 522(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1060"},"text":"100 Stat. 1060","children":[],"tail":"; renumbered § 9031, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/c"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1833"},"text":"132 Stat. 1833","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s923/b/5"},"text":"Pub. L. 116–283, div. A, title IX, § 923(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3809"},"text":"134 Stat. 3809","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab5cc35a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab5cc35b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab5cc35c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8031(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8031(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1811(a).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1811(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1951-09-19/ch407/s201"},"text":"Sept. 19, 1951, ch. 407, § 201","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/65/327"},"text":"65 Stat. 327","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8031(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1811(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8031(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1811(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “an Air Staff consisting of—” are substituted for the words “a staff, which shall be known as the Air Staff, and which shall consist of—”. The words “under regulations prescribed by the Secretary of the Air Force” are omitted, since the Secretary has inherent authority to issue regulations appropriate to exercising his statutory functions.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), 10:1811(b) (proviso) is omitted as superseded by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s264/c"},"text":"section 264(c) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the third sentence is substituted for 10:1811(c) (1st 13 words and 1st proviso). The words “officers and employees * * * or under the jurisdiction of” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (c) and (d), the word “hereafter” is omitted, since all wars and emergencies declared by Congress before ","children":[{"tag":"date","attrib":{"date":"1951-09-19"},"text":"September 19, 1951","children":[],"tail":", have been terminated."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “now or hereafter” are omitted as surplusage and as executed. The second sentence is substituted for 10:1811(d) (last 31 words of 1st sentence). The third sentence is substituted for 10:1811(d) (2d sentence). 10:1811(d) (1st 13 words of last sentence) is omitted as executed. The words “This subsection does not apply” are substituted for the words “and shall be inapplicable”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab5cc35d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab5cc35e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" inserted “or the Space Force” after “of the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8031"},"text":"section 8031 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433"},"text":"Pub. L. 99–433","children":[],"tail":" amended section generally, substituting “The Air Staff: function; composition” for “Composition: assignment and detail of members of Air Force and civilians” in section catchline and substituting in text provisions relating to establishment and composition of the Air Staff and authorizing the Secretary to prescribe the organization, duties, and titles of the Air Staff for provisions relating to establishment and composition of the Air Staff, authorizing the Secretary to prescribe the organization, duties, and titles of the Air Staff, and limiting the number of officers who may be assigned or detailed to permanent duty in the executive part of the Department of the Air Force."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525"},"text":"Pub. L. 98–525","children":[],"tail":" struck out subsec. (d) which had provided that no commissioned officer who was assigned or detailed to duty in the executive part of the Department of the Air Force could serve for a tour of duty of more than four years, but that the Secretary could extend such a tour of duty if he made a special finding that the extension was necessary in the public interest, that no officer could be assigned or detailed to duty in the executive part of the Department of the Air Force within two years after relief from that duty, except upon a special finding by the Secretary that the assignment or detail was necessary in the public interest, and that the subsection did not apply in time of war, or of national emergency declared by Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/608"},"text":"Pub. L. 93–608","children":[],"tail":" struck out requirement of annual report to Congress on the number of officers in the executive part of the Department of the Air Force and the justification therefor."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/718"},"text":"Pub. L. 89–718","children":[],"tail":" changed the reporting requirement from quarterly to annually."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab5cc35f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab5cc360-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab5cc361-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tV/s515"},"text":"Pub. L. 98–525, title V, § 515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2522"},"text":"98 Stat. 2522","children":[],"tail":", provided in part that the repeal of subsec. (d) of this section is effective "},{"tag":"date","attrib":{"date":"1984-10-01"},"text":"Oct. 1, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
