{"tag":"section","attrib":{"id":"ida87e5bb6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1076e"},"text":"§ 1076e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" TRICARE program: TRICARE Retired Reserve coverage for certain members of the Retired Reserve who are qualified for a non-regular retirement but are not yet age 60","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida87e5bb7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida87e5bb8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), a member of the Retired Reserve of a reserve component of the armed forces who is qualified for a non-regular retirement at age 60 under chapter 1223 of this title, but is not age 60, is eligible for health benefits under TRICARE Retired Reserve as provided in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida87e5bb9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) does not apply to a member who is enrolled, or is eligible to enroll, in a health benefits plan under chapter 89 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida87e5bba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Eligibility Upon Obtaining Other TRICARE Coverage","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Eligibility for TRICARE Retired Reserve coverage of a member under this section shall terminate upon the member becoming eligible for TRICARE coverage at age 60 under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1086"},"text":"section 1086 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida87e5bbb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Family Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"While a member of a reserve component is covered by TRICARE Retired Reserve under this section, the members of the immediate family of such member are eligible for TRICARE Retired Reserve coverage as dependents of the member. If a member of a reserve component dies while in a period of coverage under this section, the eligibility of the members of the immediate family of such member for TRICARE Retired Reserve coverage under this section shall continue for the same period of time that would be provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1086"},"text":"section 1086 of this title","children":[],"tail":" if the member had been eligible at the time of death for TRICARE coverage under such section (instead of under this section)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida87e5bbc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Premiums","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida87e5bbd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of a reserve component covered by TRICARE Retired Reserve under this section shall pay a premium for that coverage. Such premium shall apply instead of any enrollment fees required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1075"},"text":"section 1075 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida87e5bbe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall prescribe for the purposes of this section one premium for TRICARE Retired Reserve coverage of members without dependents and one premium for TRICARE Retired Reserve coverage of members with dependents referred to in subsection (f)(1). The premium prescribed for a coverage shall apply uniformly to all members of the reserve components covered under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida87e5bbf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076e/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The monthly amount of the premium in effect for a month for TRICARE Retired Reserve coverage under this section shall be the amount equal to the cost of coverage that the Secretary determines on an appropriate actuarial basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida87e5bc0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076e/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe the requirements and procedures applicable to the payment of premiums under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida87e5bc1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076e/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts collected as premiums under this subsection shall be credited to the appropriation available for the Defense Health Program Account under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1100"},"text":"section 1100 of this title","children":[],"tail":", shall be merged with sums in such Account that are available for the fiscal year in which collected, and shall be available under subsection (b) of such section for such fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida87e5bc2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense, in consultation with the other administering Secretaries, shall prescribe regulations for the administration of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida87e5bc3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076e/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida87e5bc4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076e/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “immediate family”, with respect to a member of a reserve component, means all of the member’s dependents described in subparagraphs (A), (D), and (I) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072/2"},"text":"section 1072(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida87e5bc5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076e/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “TRICARE Retired Reserve” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida87e5bc6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076e/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical care at facilities of the uniformed services to which a dependent described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1076/a/2"},"text":"section 1076(a)(2) of this title","children":[],"tail":" is entitled; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida87e5bc7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076e/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health benefits under the TRICARE Select self-managed, preferred provider network option under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1075"},"text":"section 1075 of this title","children":[],"tail":" made available to beneficiaries by reason of this section and subject to the cost-sharing requirements set forth in such section 1075."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida87e5bc8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tVII/s705/a"},"text":"Pub. L. 111–84, div. A, title VII, § 705(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2374"},"text":"123 Stat. 2374","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVII/s701/j/1/C"},"text":"Pub. L. 114–328, div. A, title VII, § 701(j)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2192"},"text":"130 Stat. 2192","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVII/s701/b"},"text":"Pub. L. 115–91, div. A, title VII, § 701(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1432"},"text":"131 Stat. 1432","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXVII/s1731/a/25"},"text":"Pub. L. 116–92, div. A, title XVII, § 1731(a)(25)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1813"},"text":"133 Stat. 1813","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida87e5bc9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida87e5bca-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida87e5bcb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1075"},"text":"section 1075 of this title","children":[],"tail":"” for “section 1075 of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s701/b/1"},"text":"Pub. L. 115–91, § 701(b)(1)","children":[],"tail":", struck out “Retired Reserve” after “TRICARE” in heading. See first 2016 Amendment note for subsec. (b) below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s701/b/2"},"text":"Pub. L. 115–91, § 701(b)(2)","children":[],"tail":", struck out “Retired Reserve” before “coverage under such section” in last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s701/b/3"},"text":"Pub. L. 115–91, § 701(b)(3)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “The term ‘TRICARE Retired Reserve’ means the TRICARE Select self-managed, preferred-provider network option under section 1075 made available to beneficiaries by reason of this section and in accordance with subsection (d)(1).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s701/j/1/C/iv"},"text":"Pub. L. 114–328, § 701(j)(1)(C)(iv)","children":[],"tail":", substituted “TRICARE Retired Reserve” for “TRICARE Standard” in section catchline and wherever appearing in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s701/j/1/C/iv"},"text":"Pub. L. 114–328, § 701(j)(1)(C)(iv)","children":[],"tail":", which directed substitution of “TRICARE Retired Reserve” for “TRICARE Standard” wherever appearing in text, was also executed to heading of subsec. (b) to reflect the probable intent of Congress and the subsequent amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/s701/b/1"},"text":"Pub. L. 115–91, § 701(b)(1)","children":[],"tail":", which could be executed only if the substitution had taken place."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s701/j/1/C/iii"},"text":"Pub. L. 114–328, § 701(j)(1)(C)(iii)","children":[],"tail":", substituted “TRICARE coverage at” for “TRICARE Standard coverage at”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s701/j/1/C/i"},"text":"Pub. L. 114–328, § 701(j)(1)(C)(i)","children":[],"tail":", inserted at end “Such premium shall apply instead of any enrollment fees required under section 1075 of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s701/j/1/C/ii"},"text":"Pub. L. 114–328, § 701(j)(1)(C)(ii)","children":[],"tail":", added par. (2) and struck out former par. (2) which defined the term “TRICARE Standard”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida87e5bcc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida87e5bcd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" applicable with respect to the provision of health care under the TRICARE program beginning on "},{"tag":"date","attrib":{"date":"2018-01-01"},"text":"Jan. 1, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s701/k"},"text":"section 701(k) of Pub. L. 114–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072"},"text":"section 1072 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida87e5bce-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tVII/s705/c"},"text":"Pub. L. 111–84, div. A, title VII, § 705(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2375"},"text":"123 Stat. 2375","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/84/dA/tVII/s705/c"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1076e"},"text":"Section 1076e of title 10","children":[],"tail":", United States Code, as inserted by subsection (a), shall apply to coverage for months beginning on or after "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"October 1, 2009","children":[],"tail":", or such earlier date as the Secretary of Defense may specify.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
