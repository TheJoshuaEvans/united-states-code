{"tag":"section","attrib":{"id":"ida90d7d17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1765"},"text":null,"children":[{"tag":"num","attrib":{"value":"1765"},"text":"§ 1765.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competency development","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For each acquisition workforce career field, the Secretary of Defense shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90d7d18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1765/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish, for the civilian personnel in that career field, defined proficiency standards and technical and nontechnical competencies which shall be used in personnel qualification assessments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90d7d19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1765/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assign resources to accomplish such technical and nontechnical competencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida90d7d1a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVIII/s861/i/1"},"text":"Pub. L. 116–92, div. A, title VIII, § 861(i)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1518"},"text":"133 Stat. 1518","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida90d7d1b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida90d7d1c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida90d7d1d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVIII/s861/i/3"},"text":"Pub. L. 116–92, div. A, title VIII, § 861(i)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1519"},"text":"133 Stat. 1519","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dA/tVIII/s861/i/3"},"text":"“Not later than the end of the two-year period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"], the Secretary of Defense shall carry out the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1765"},"text":"section 1765 of title 10","children":[],"tail":", United States Code (as added by paragraph (1)).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
