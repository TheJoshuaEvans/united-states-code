{"tag":"section","attrib":{"id":"idaba45331-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12408"},"text":null,"children":[{"tag":"num","attrib":{"value":"12408"},"text":"§ 12408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Guard in Federal service: physical examination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaba45332-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12408/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed by the President, each member of the National Guard called into Federal service under section 12301(a), 12302, or 12304 of this title shall be examined as to physical fitness, without further commission or enlistment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba45333-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12408/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Immediately before such a member is mustered out of Federal service, he shall be examined as to physical fitness. The record of this examination shall be retained by the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaba45334-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1662/f/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1662(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2994"},"text":"108 Stat. 2994","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s523"},"text":"Pub. L. 104–201, div. A, title V, § 523","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2517"},"text":"110 Stat. 2517","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaba45335-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaba45336-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaba45337-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 3502 and 8502 of this title, prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1662/f/2"},"text":"Pub. L. 103–337, § 1662(f)(2)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaba45338-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" inserted “under section 12301(a), 12302, or 12304 of this title” after “called into Federal service”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaba45339-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaba4533a-3a6f-11f1-a58a-d8db54b14ab5"},"te