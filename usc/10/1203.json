d and last provisos), the provisions of 37:272(a) (less clause (5), and less 1st proviso), 272(b) (less clause (5), and less 1st proviso) and 272(f) (less applicability to 37:272(c) and (e)), also contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1201"},"text":"section 1201 of this title","children":[],"tail":", are repeated. The words “the member may be separated” are substituted for the words “the member concerned shall not be eligible for any disability retirement provided in this section, but may be separated for physical disability,” in 37:272(a) (2d proviso) and 37:272(b) (2d proviso)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clause (1) is inserted for clarity, since a member who had over 20 years of service would qualify under section 1201 or 1202 of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clause (4)(A) is substituted for 37:272(a) (1st 20 words of 2d proviso).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clause (4)(B) is substituted for 37:272(b) (lst 20 words of 2d proviso).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clause (4)(C) is substituted for 37:272(b) (last proviso).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The last sentence of the revised section, relating to transfer to the inactive status list, is inserted for clarity because of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1209"},"text":"section 1209 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8ae1e56-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida8ae1e57-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1958 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1203","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The amendment reflects the ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-04-23/ch209"},"text":"Act of April 23, 1956, ch. 209","children":[],"tail":" (70 Stat 115). (See opinion of Comp. Gen., B–130269, "},{"tag":"date","attrib":{"date":"1957-03-18"},"text":"March 18, 1957","children":[],"tail":".)"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8ae1e58-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1962 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"The changes correct typographical errors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8ae1e59-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8ae1e5a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1075/e/12"},"text":"Pub. L. 111–383, § 1075(e)(12)","children":[],"tail":", made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/s727/b/2"},"text":"Pub. L. 110–417, § 727(b)(2)","children":[],"tail":". See 2008 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1075/b/19"},"text":"Pub. L. 111–383, § 1075(b)(19)","children":[],"tail":", substituted “determination,” for “determination,,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s727/b/2"},"text":"Pub. L. 110–417, § 727(b)(2)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1075/e/12"},"text":"Pub. L. 111–383, § 1075(e)(12)","children":[],"tail":", substituted “(unless clear and unmistakable evidence demonstrates that the disability existed before the member’s entrance on active duty and was not aggravated by active military service)” for “(unless evidence or medical judgment is such to warrant a finding that the disability existed before the member’s entrance on active duty)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s727/b/1"},"text":"Pub. L. 110–417, § 727(b)(1)","children":[],"tail":", struck out “the member has six months or more of active military service, and” before “the disability was not noted”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" substituted “, the member has six months or more of active military service, and the disability was not noted at the time of the member’s entrance on active duty (unless evidence or medical judgment is such to warrant a finding that the disability existed before the member’s entrance on active duty)” for “and the member has at least eight years of service computed under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1208"},"text":"section 1208 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" added subsec. (a), designated existing provisions as subsec. (b), and substituted introductory provisions of subsec. (b) for “Upon a determination by the Secretary concerned that a member of a regular component of the armed forces entitled to basic pay, or any other member of the armed forces entitled to basic pay who has been called or ordered to active duty (other than for training under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10148/a"},"text":"section 10148(a) of this title","children":[],"tail":") for a period of more than 30 days, is unfit to perform the duties of his office, grade, rank, or rating because of physical disability incurred while entitled to basic pay, the member may be separated from his armed force, with severance pay computed under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1212"},"text":"section 1212 of this title","children":[],"tail":", if the Secretary also determines that—”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" substituted “10148(a)” for “270(b)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Par. (4)(A) to (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" substituted “Department of Veterans Affairs” for “Veterans’ Administration” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Par. (4)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “after "},{"tag":"date","attrib":{"date":"1978-09-14"},"text":"September 14, 1978","children":[],"tail":"” for “during the period beginning on "},{"tag":"date","attrib":{"date":"1978-09-15"},"text":"September 15, 1978","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":", except that the condition provided for in this item shall not be effective during such period unless the President determines that such condition should be effective during such period and issues an Executive order to that effect”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/343/s10/c/2"},"text":"Pub. L. 96–343, § 10(c)(2)","children":[],"tail":", added cl. (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[]