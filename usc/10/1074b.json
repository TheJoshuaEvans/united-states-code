{"tag":"section","attrib":{"id":"ida8727522-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1074b"},"text":"§ 1074b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical and dental care: Academy cadets and midshipmen; members of, and designated applicants for membership in, Senior ROTC","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8727523-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under joint regulations prescribed by the administering Secretaries, the following persons are, except as provided in subsection (c), entitled to the benefits described in subsection (b):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8727524-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A cadet at the United States Military Academy, the United States Air Force Academy, or the Coast Guard Academy, and a midshipman at the United States Naval Academy, who incurs or aggravates an injury, illness, or disease in the line of duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8727525-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member of, and a designated applicant for membership in, the Senior Reserve Officers’ Training Corps who incurs or aggravates an injury, illness, or disease—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8727526-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the line of duty while performing duties under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2109"},"text":"section 2109 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8727527-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while traveling directly to or from the place at which that member or applicant is to perform or has performed duties pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2109"},"text":"section 2109 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8727528-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074b/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the line of duty while remaining overnight immediately before the commencement of duties performed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2109"},"text":"section 2109 of this title","children":[],"tail":" or, while remaining overnight, between successive periods of performing duties pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2109"},"text":"section 2109 of this title","children":[],"tail":", at or in the vicinity of the site of the duties performed pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2109"},"text":"section 2109 of this title","children":[],"tail":", if the site is outside reasonable commuting distance from the residence of the member or designated applicant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8727529-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Benefits","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person eligible for benefits under subsection (a) for an injury, illness, or disease is entitled to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida872752a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the medical and dental care under this chapter that is appropriate for the treatment of the injury, illness, or disease until the injury, illness, disease, or any resulting disability cannot be materially improved by further hospitalization or treatment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida872752b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meals during hospitalization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida872752c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for Gross Negligence or Misconduct","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person is not entitled to benefits under subsection (b) for an injury, illness, or disease, or the aggravation of an injury, illness, or disease that is a result of the gross negligence or the misconduct of that person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida872752d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s555/a/1"},"text":"Pub. L. 108–375, div. A, title V, § 555(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1913"},"text":"118 Stat. 1913","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida872752e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida872752f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida8727530-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1074b, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVI/s640/a/2"},"text":"Pub. L. 102–190, div. A, title VI, § 640(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1385"},"text":"105 Stat. 1385","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1501/c/10"},"text":"Pub. L. 104–106, div. A, title XV, § 1501(c)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/499"},"text":"110 Stat. 499","children":[],"tail":", which related to transitional medical and dental care for members on active duty in support of contingency operations, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tVII/s736/c/1"},"text":"Pub. L. 107–107, div. A, title VII, § 736(c)(1)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1173"},"text":"115 Stat. 1173","children":[],"tail":", with provision that the section, as in effect before "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", was to continue to apply to a member of the Armed Forces who was released from active duty in support of a contingency operation before that date."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 1074b was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1074c"},"text":"section 1074c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
