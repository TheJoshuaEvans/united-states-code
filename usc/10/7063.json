{"tag":"section","attrib":{"id":"idaad9b0e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7063"},"text":null,"children":[{"tag":"num","attrib":{"value":"7063"},"text":"§ 7063.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basic branches","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaad9b0e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7063/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Army may assign members of the Army to its basic branches. The basic branches are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad9b0e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7063/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Infantry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b0e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7063/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Armor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b0e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7063/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Artillery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b0e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7063/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Corps of Engineers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b0ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7063/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Signal Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b0eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7063/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adjutant General’s Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b0ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7063/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Quartermaster Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b0ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7063/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Finance Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b0ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7063/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ordnance Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b0ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7063/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chemical Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b0f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7063/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b0f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7063/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Military Police Corps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b0f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7063/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other basic branches as the Secretary considers necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad9b0f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7063/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may discontinue or consolidate basic branches of the Army for the duration of any war, or of any national emergency declared by Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad9b0f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7063/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not assign to a basic branch any commissioned officer appointed in a special branch.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad9b0f5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/166"},"text":"70A Stat. 166","children":[],"tail":", § 3063; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tV/s582/a"},"text":"Pub. L. 115–91, div. A, title V, § 582(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1415"},"text":"131 Stat. 1415","children":[],"tail":"; renumbered § 7063, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1838"},"text":"132 Stat. 1838","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaad9b0f6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaad9b0f7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaad9b0f8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3063(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1g(a) (less words of 1st sentence after semicolon, and less last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-06-28/ch383/s306/a"},"text":"June 28, 1950, ch. 383, § 306(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/269"},"text":"64 Stat. 269","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3063(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1g(a) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3063(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1g(a) (words of 1st sentence after semicolon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “The basic branches are” are substituted for the words “There shall be in the Army certain branches, which shall be known as basic branches of the Army” and “The basic branches of the Army shall be”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “enumerated in this subsection” are omitted as surplusage. The word “hereafter” is omitted, since all wars and emergencies declared by Congress before ","children":[{"tag":"date","attrib":{"date":"1950-06-29"},"text":"June 29, 1950","children":[],"tail":", have been terminated."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “and commissioned” are omitted as covered by the word “appointed”. The words “specified in subsection (b) of this section” are omitted as surplusage. The word “commissioned” is inserted before the word “officer”, for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaad9b0f9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaad9b0fa-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3063"},"text":"section 3063 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(13), (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":", which directed the redesignation of par. (13) as (14) and the addition of a new par. (13) “Explosive Ordnance Disposal Corps; and”, was not executed pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/s582/b"},"text":"section 582(b) of Pub. L. 115–91","children":[],"tail":", set out as an Effective Date and Condition on Execution of 2017 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaad9b0fb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaad9b0fc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaad9b0fd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date and Condition on Execution of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tV/s582/b"},"text":"Pub. L. 115–91, div. A, title V, § 582(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1415"},"text":"131 Stat. 1415","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tV/s593"},"text":"Pub. L. 116–283, div. A, title V, § 593","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3666"},"text":"134 Stat. 3666","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dA/tV/s593"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsection (a) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2025-10-01"},"text":"October 1, 2025","children":[],"tail":", but only if the report required by paragraph (2) is not submitted before that date as required by such paragraph."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":", the Secretary of the Army shall submit to the Committees on Armed Services of the Senate and the House of Representatives a report containing certifications that the following actions have occurred as of that date:"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The defense budget materials display funding requirements for explosive ordnance disposal separately and a program of record is established and maintained for explosive ordnance disposal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A process has been established to ensure that, by not later than five years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":"], there is, and will continue to be, at least one general officer in the Army, the explosive ordnance disposal commandant (chief of explosive ordnance disposal), qualified regarding issues involving explosive ordnance disposal to ensure officer professional development and upward mobility."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Ordnance Personnel Proponency Office is, and will continue to be, manned with an explosive ordnance disposal officer to oversee explosive ordnance disposal officer and enlisted personnel proponency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Explosive ordnance disposal officer education has been included in a basic officer leadership course, a captains career course, and a policy and planning course specific to explosive ordnance disposal as part of intermediate level education and pre-command courses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The office of the Army Deputy Chief of Staff, G8, and the office of the Army Deputy Chief of Staff, G3, have, and will continue to be, manned with explosive ordnance disposal officers responsible for the decision management decision packages, ammunition organizational integration, and force modernization related to explosive ordnance disposal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Army has established and maintained explosive ordnance disposal cells at the Army Forces Command, Army Service Component Commands, Army Special Operations Command, Army Training and Doctrine Command, and the Army Capability and Integration Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"“(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The explosive ordnance disposal commandant (chief of explosive ordnance disposal) has determined whether explosive ordnance disposal soldiers have the appropriate skills necessary to support missions of special operations forces (as identified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s167/j"},"text":"section 167(j) of title 10","children":[],"tail":", United States Code). Such skills may include airborne, air assault, combat diver, fast roping insertion and extraction, helocasting, military free-fall, and off-road driving."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army shall notify the Law Revision Counsel of the House of Representatives of the submission of the report under paragraph (2) so that the Law Revision Counsel does not execute the amendments made by subsection (a).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[The report required by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s582/b/2"},"text":"section 582(b)(2) of Pub. L. 115–91","children":[],"tail":", set out above, was submitted to Congress on "},{"tag":"date","attrib":{"date":"2020-09-17"},"text":"Sept. 17, 2020","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaad9b0fe-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Philippine Scouts","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041/s42"},"text":"Act Aug. 10, 1956, ch. 1041, § 42","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/636"},"text":"70A Stat. 636","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1956-08-10/ch1041/s42"},"text":"“The President is authorized to form the Philippine Scouts into such branches and tactical units as he may deem expedient, within the limit of strength prescribed by law, organized similarly to those of the Regular Army.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
