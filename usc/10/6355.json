{"tag":"section","attrib":{"id":"idaad0149c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6355"},"text":null,"children":[{"tag":"num","attrib":{"value":"6355"},"text":"§ 6355.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Energy energy parks program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaad0149d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6355/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy may establish a program to permit the establishment of energy parks on former defense nuclear facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad0149e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6355/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Objectives","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The objectives for establishing energy parks pursuant to subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad0149f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6355/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide locations to carry out a broad range of projects relating to the development and deployment of energy technologies and related advanced manufacturing technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad014a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6355/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide locations for the implementation of pilot programs and demonstration projects for new and developing energy technologies and related advanced manufacturing technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad014a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6355/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To set a national example for the development and deployment of energy technologies and related advanced manufacturing technologies in a manner that will promote energy security, energy sector employment, and energy independence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad014a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6355/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To create a business environment that encourages collaboration and interaction between the public and private sectors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad014a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6355/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing an energy park pursuant to subsection (a), the Secretary shall consult with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad014a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6355/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the local government with jurisdiction over the land on which the energy park will be located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad014a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6355/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the local governments of adjacent areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad014a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6355/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any community reuse organization recognized by the Secretary at the former defense nuclear facility on which the energy park will be located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad014a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6355/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2011-01-07"},"text":"January 7, 2011","children":[],"tail":", the Secretary shall submit to the Committee on Armed Services of the Senate and the Committee on Armed Services of the House of Representatives a report on the implementation of the program under subsection (a). The report shall include such recommendations for additional legislative actions as the Secretary considers appropriate to facilitate the development of energy parks on former defense nuclear facilities."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad014a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6355/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defense Nuclear Facility Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “defense nuclear facility” has the meaning given the term “Department of Energy defense nuclear facility” in section 318 of the Atomic Energy Act of 1954 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2286g"},"text":"42 U.S.C. 2286g","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad014a9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1455"},"text":"139 Stat. 1455","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaad014aa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaad014ab-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaad014ac-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2814"},"text":"section 2814 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/7"},"text":"Pub. L. 119–60, § 3111(b)(7)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
