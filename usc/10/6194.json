{"tag":"section","attrib":{"id":"idaac42e3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194"},"text":null,"children":[{"tag":"num","attrib":{"value":"6194"},"text":"§ 6194.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan for deactivation and decommissioning of nonoperational defense nuclear facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaac42e3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy shall, every four years beginning in 2025, develop and subsequently carry out a plan for the activities of the Department of Energy relating to the deactivation and decommissioning of nonoperational defense nuclear facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac42e3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan required by subsection (a) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac42e3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A list of nonoperational defense nuclear facilities, prioritized for deactivation and decommissioning based on the potential to reduce risks to human health, property, or the environment and to maximize cost savings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42e3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An assessment of the life cycle costs of each nonoperational defense nuclear facility during the period beginning on the date on which the plan is submitted under subsection (d) and ending on the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac42e3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 25 years after the date on which the plan is submitted; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42e40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated date for deactivation and decommissioning of the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42e41-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An estimate of the cost and time needed to deactivate and decommission each nonoperational defense nuclear facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42e42-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A schedule for when the Office of Environmental Management will accept each nonoperational defense nuclear facility for deactivation and decommissioning.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42e43-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An estimate of costs that could be avoided by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac42e44-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accelerating the cleanup of nonoperational defense nuclear facilities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42e45-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other means, such as reusing such facilities for another purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac42e46-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan for Transfer of Responsibility for Certain Facilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall, during 2025, develop and subsequently carry out a plan under which the Administrator shall transfer, by ","children":[{"tag":"date","attrib":{"date":"2029-03-31"},"text":"March 31, 2029","children":[],"tail":", to the Assistant Secretary for Environmental Management the responsibility for decontaminating and decommissioning facilities of the Administration that the Secretary determines are nonoperational as of "},{"tag":"date","attrib":{"date":"2024-09-30"},"text":"September 30, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac42e47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2025-03-31"},"text":"March 31, 2025","children":[],"tail":", and every four years thereafter, the Secretary shall submit to the appropriate congressional committees a report that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac42e48-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan required by subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42e49-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the deactivation and decommissioning actions expected to be taken during the following fiscal year pursuant to the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42e4a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the report submitted during 2025, the plan required by subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42e4b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the deactivation and decommissioning actions taken at each nonoperational defense nuclear facility during the period following the date on which the previous report required by this section was submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac42e4c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirements of this section shall terminate after the submission to the appropriate congressional committees of the report required by subsection (d) to be submitted not later than ","children":[{"tag":"date","attrib":{"date":"2033-03-31"},"text":"March 31, 2033","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac42e4d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac42e4e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac42e4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional defense committees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42e50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Natural Resources of the Senate and the Committee on Energy and Commerce of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42e51-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “life cycle costs”, with respect to a facility, means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac42e52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the present and future costs of all resources and associated cost elements required to develop, produce, deploy, or sustain the facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42e53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the present and future costs to deactivate, decommission, and deconstruct the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42e54-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6194/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “nonoperational defense nuclear facility” means a production facility or utilization facility (as those terms are defined in section 11 of the Atomic Energy Act of 1954 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2014"},"text":"42 U.S.C. 2014","children":[],"tail":")) under the control or jurisdiction of the Secretary of Energy and operated for national security purposes that is no longer needed for the mission of the Department of Energy, including the National Nuclear Security Administration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac42e55-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1397"},"text":"139 Stat. 1397","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac42e56-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac42e57-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac42e58-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2603"},"text":"section 2603 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
