{"tag":"section","attrib":{"id":"idaa1fb04d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403"},"text":null,"children":[{"tag":"num","attrib":{"value":"3403"},"text":"§ 3403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task and delivery order contracts: general authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa1fb04e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Award","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the requirements of this section, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3406"},"text":"section 3406 of this title","children":[],"tail":", and other applicable law, the head of an agency may enter into a task or delivery order contract (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3401"},"text":"section 3401 of this title","children":[],"tail":") for procurement of services or property."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa1fb04f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Solicitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The solicitation for a task or delivery order contract shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa1fb050-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The period of the contract, including the number of options to extend the contract and the period for which the contract may be extended under each option, if any.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa1fb051-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The maximum quantity or dollar value of the services or property to be procured under the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa1fb052-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement of work, specifications, or other description that reasonably describes the general scope, nature, complexity, and purposes of the services or property to be procured under the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa1fb053-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Restriction on Use of Noncompetitive Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of an agency may use procedures other than competitive procedures to enter into a task or delivery order contract under this section only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa222054-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an exception in subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3204"},"text":"section 3204 of this title","children":[],"tail":" applies to the contract; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa222055-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of such procedures is approved in accordance with subsection (e) of such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa222056-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Single and Multiple Contract Awards.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa222057-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exercise of authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of an agency may exercise the authority provided in this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa222058-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to award a single task or delivery order contract; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa222059-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the solicitation states that the head of the agency has the option to do so, to award separate task or delivery order contracts for the same or similar services or property to two or more sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa22205a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination not required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No determination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3203"},"text":"section 3203 of this title","children":[],"tail":" is required for award of multiple task or delivery order contracts under paragraph (1)(B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa22205b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When Single Source Awards for Task or Delivery Order Contracts Exceeding","children":[],"tail":" $100,000,000 "},{"tag":"inline","attrib":{},"text":"Are Allowed","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa22205c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided under subparagraph (B), no task or delivery order contract in an amount estimated to exceed $100,000,000 (including all options) may be awarded to a single source unless the head of the agency determines in writing that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa22205d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the task or delivery orders expected under the contract are so integrally related that only a single source can efficiently perform the work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa22205e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the contract provides only for firm, fixed price task orders or delivery orders for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idaa22205f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/d/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" products for which unit prices are established in the contract; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idaa222060-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/d/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services for which prices are established in the contract for the specific tasks to be performed;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa222061-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/d/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only one source is qualified and capable of performing the work at a reasonable price to the government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa222062-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/d/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of exceptional circumstances, it is necessary in the public interest to award the contract to a single source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa222063-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A task or delivery order contract in an amount estimated to exceed $100,000,000 (including all options) may be awarded to a single source without the written determination otherwise required under subparagraph (A) if the head of the agency has made a written determination pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3204/a"},"text":"section 3204(a) of this title","children":[],"tail":" that procedures other than competitive procedures may be used for the awarding of such contract."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa222064-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations implementing this subsection shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa222065-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a preference for awarding, to the maximum extent practicable, multiple task or delivery order contracts for the same or similar services or property under the authority of paragraph (1)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa222066-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish criteria for determining when award of multiple task or delivery order contracts would not be in the best interest of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa222067-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract Modifications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A task or delivery order may not increase the scope, period, or maximum value of the task or delivery order contract under which the order is issued. The scope, period, or maximum value of the contract may be increased only by modification of the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa222068-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract Period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an agency entering into a task or delivery order contract under this section may provide for the contract to cover any period up to five years and may extend the contract period for one or more successive periods pursuant to an option provided in the contract or a modification of the contract. The total contract period as extended may not exceed 10 years unless such head of an agency determines in writing that exceptional circumstances necessitate a longer contract period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa222069-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability to Contracts for Advisory and Assistance Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise specifically provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3405"},"text":"section 3405 of this title","children":[],"tail":", this section does not apply to a task or delivery order contract for the procurement of advisory and assistance services (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/g"},"text":"section 1105(g) of title 31","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa22206a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3403/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Contracting Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section may be construed to limit or expand any authority of the head of an agency or the Administrator of General Services to enter into schedule, multiple award, or task or delivery order contracts under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa22206b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355/tI/s1004/a/1"},"text":"Pub. L. 103–355, title I, § 1004(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3249"},"text":"108 Stat. 3249","children":[],"tail":", § 2304a; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tVIII/s843/b"},"text":"Pub. L. 108–136, div. A, title VIII, § 843(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1553"},"text":"117 Stat. 1553","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVIII/s813/a"},"text":"Pub. L. 108–375, div. A, title VIII, § 813(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2014"},"text":"118 Stat. 2014","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVIII/s843/a/1"},"text":"Pub. L. 110–181, div. A, title VIII, § 843(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/236"},"text":"122 Stat. 236","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tVIII/s814/a"},"text":"Pub. L. 111–84, div. A, title VIII, § 814(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2407"},"text":"123 Stat. 2407","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVIII/s809/b"},"text":"Pub. L. 112–81, div. A, title VIII, § 809(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1490"},"text":"125 Stat. 1490","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s816"},"text":"Pub. L. 115–232, div. A, title VIII, § 816","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1852"},"text":"132 Stat. 1852","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVIII/s816"},"text":"Pub. L. 116–92, div. A, title VIII, § 816","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1487"},"text":"133 Stat. 1487","children":[],"tail":"; renumbered § 3403 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1820/c"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1820(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4191"},"text":"134 Stat. 4191","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/b/8/B"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(b)(8)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2133"},"text":"135 Stat. 2133","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa22206c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa22206d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa22206e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1820/c/1"},"text":"Pub. L. 116–283, § 1820(c)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2304a"},"text":"section 2304a of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1820/c/2"},"text":"Pub. L. 116–283, § 1820(c)(2)","children":[],"tail":", substituted “section 3406” for “section 2304c” and “section 3401” for “section 2304d”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1820/c/3"},"text":"Pub. L. 116–283, § 1820(c)(3)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/b/8/B"},"text":"Pub. L. 117–81, § 1701(b)(8)(B)","children":[],"tail":", inserted dash after “only if”, reorganized remainder of text of subsec. (c) into designated pars. (1) and (2), and substituted “subsection (a) of section 3204” for “subsection (c) of section 2304” and “subsection (e)” for “subsection (f)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1820/c/4/A"},"text":"Pub. L. 116–283, § 1820(c)(4)(A)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1820/c/4/B"},"text":"Pub. L. 116–283, § 1820(c)(4)(B)","children":[],"tail":", inserted heading and substituted “section 3203” for “section 2304(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1820/c/4/C"},"text":"Pub. L. 116–283, § 1820(c)(4)(C)","children":[],"tail":", inserted he