{"tag":"section","attrib":{"id":"ida7cb861f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500"},"text":null,"children":[{"tag":"num","attrib":{"value":"500"},"text":"§ 500.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electromagnetic Spectrum Operations Executive Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7cb8620-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is within the Department of Defense an Electromagnetic Spectrum Operations Executive Committee (in this section referred to as the “Executive Committee”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7cb8621-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Executive Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7cb8622-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the principal forum within the Department of Defense to inform, coordinate, and evaluate matters relating to electromagnetic warfare;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb8623-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide senior oversight, coordination, and budget and capability harmonization with respect to such matters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb8624-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" act as an advisory body to the Secretary of Defense, the Deputy Secretary of Defense, and the Management Action Group of the Deputy Secretary with respect to such matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7cb8625-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Executive Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7cb8626-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise key senior level decision-making bodies of the Department of Defense with respect to the development and implementation of acquisition investments relating to electromagnetic warfare and electromagnetic spectrum operations of the Department, including relevant acquisition policies, projects, programs, modeling, and test and evaluation infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb8627-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide a forum to enable synchronization and integration support with respect to the development and acquisition of electromagnetic warfare capabilities by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7cb8628-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aligning the processes of the Department for requirements, research, development, acquisition, testing, and sustainment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb8629-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out other related duties; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb862a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" act as the senior level review forum for the portfolio of capability investments of the Department relating to electromagnetic warfare and electromagnetic spectrum operations and other related matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7cb862b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination With Intelligence Community","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Executive Committee, acting through the Under Secretary of Defense for Intelligence and Security, shall coordinate with the intelligence community (as defined in section 3 of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"50 U.S.C. 3003","children":[],"tail":")) to generate requirements, facilitate collaboration, establish interfaces, and align efforts of the Department of Defense with respect to capabilities and acquisition activities related to electromagnetic spectrum operations in areas of dependency or mutual interest."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7cb862c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7cb862d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Executive Committee shall hold meetings not less frequently than quarterly and as necessary to address particular issues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb862e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Executive Committee may hold meetings by video conference.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7cb862f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Executive Committee shall be composed of the following principal members:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7cb8630-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense for Acquisition and Sustainment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb8631-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Vice Chairman of the Joint Chiefs of Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb8632-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense for Intelligence and Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb8633-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense for Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb8634-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commander of the United States Strategic Command.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb8635-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Information Officer of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb8636-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other Federal officers or employees as the Secretary of Defense considers appropriate, consistent with other authorities of the Department of Defense and publications of the Joint Staff, including the Charter for the Electronic Warfare Executive Committee, dated ","children":[{"tag":"date","attrib":{"date":"2015-03-17"},"text":"March 17, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7cb8637-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Co-chairs of Executive Committee","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7cb8638-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense for Acquisition and Sustainment and the Vice Chairman of the Joint Chiefs of Staff, or their designees, shall serve as co-chairs of the Executive Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb8639-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The co-chairs of the Executive Committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7cb863a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preside at all Executive Committee meetings or have their designees preside at such meetings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb863b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide administrative control of the Executive Committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb863c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" jointly guide the activities and actions of the Executive Committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb863d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve all agendas for and summaries of meetings of the Executive Committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb863e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/g/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charter tailored working groups to conduct mission area analysis, as required, under subsection (i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb863f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/g/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other duties as may be necessary to ensure the good order and functioning of the Executive Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7cb8640-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Electromagnetic Spectrum Operations Capability Team","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7cb8641-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There is within the Executive Committee an electromagnetic spectrum operations capability team, which shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7cb8642-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a flag officer level focus group and executive secretariat subordinate to the Executive Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb8643-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in that capacity—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida7cb8644-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/h/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide initial senior level coordination on key electromagnetic spectrum operations issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7cb8645-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/h/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare recommended courses of action to present to the Executive Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7cb8646-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/h/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform other related duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb8647-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The electromagnetic spectrum operations capability team shall be co-chaired by one representative from the Office of the Under Secretary of Defense for Acquisition and Sustainment and one representative from the Force Structure, Resources, and Assessment Directorate of the Joint Staff (J–8).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb8648-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The principal members of the Executive Committee shall designate representatives from their respective staffs to the electromagnetic spectrum operations capability team.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7cb8649-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mission Area Working Groups","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7cb864a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Executive Committee shall establish mission area working groups on a temporary basis—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7cb864b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address specific issues and mission areas relating to electromagnetic spectrum operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb864c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to involve subject matter experts and components of the Department of Defense with expertise in electromagnetic spectrum operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb864d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/i/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to perform other related duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb864e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Executive Committee shall dissolve a mission area working group established under paragraph (1) once the issue the working group was established to address is satisfactorily resolved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7cb864f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Under Secretary of Defense for Acquisition and Sustainment shall administratively support the Executive Committee, including by designating not fewer than two officials of the Department of Defense to support the day-to-day operations of the Executive Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7cb8650-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2024-02-28"},"text":"February 28, 2024","children":[],"tail":", and annually thereafter through 2030, the Executive Committee shall submit to the congressional defense committees a summary of activities of the Executive Committee during the preceding fiscal year."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7cb8651-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVI/s1682/a"},"text":"Pub. L. 118–31, div. A, title XVI, § 1682(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/611"},"text":"137 Stat. 611","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
