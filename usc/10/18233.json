"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2233(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2233(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2233(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:882.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:883(c) (1st sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:884.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-09-11/ch945"},"text":"Sept. 11, 1950, ch. 945","children":[],"tail":", §§ 3, 4(c) (1st sentence), 5, "},{"tag":"html:a","attrib":{"href":"/us/stat/64/830"},"text":"64 Stat. 830","children":[],"tail":", 831."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the 16th through the 31st words are omitted as executed on ","children":[{"tag":"date","attrib":{"date":"1955-07-01"},"text":"July 1, 1955","children":[],"tail":", the end of the 5-year period."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “to the extent required” are omitted as covered by the word “necessary”. The words “use jointly by units of two or more of the reserve components of the armed forces” are substituted for the words “joint utilization of such facilities” to reflect 50:886(d).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a)(2) and (3), the words “Territory, Puerto Rico, or the District of Columbia” are inserted to reflect 50:886(b).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), the words “to be required” are substituted for the words “to have been made essential”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “real or personal” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “all or * * * part”, “conferred”, “imposed”, “without relieving himself of the responsibility therefor”, “or officers”, and “as he may designate from time to time” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idabc34d48-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idabc34d49-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"chil