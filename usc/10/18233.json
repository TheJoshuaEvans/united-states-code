{"tag":"section","attrib":{"id":"idabc34d35-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233"},"text":null,"children":[{"tag":"num","attrib":{"value":"18233"},"text":"§ 18233.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabc34d36-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to sections 18233a, 18234, 18235, 18236, and 18238 of this title and to subsection (c), the Secretary of Defense may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc34d37-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire by purchase, lease, or transfer, and construct, expand, rehabilitate, or convert and equip, such facilities as are authorized by law to carry out the purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc34d38-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute to any State such amounts as he determines to be necessary to expand, rehabilitate, or convert facilities owned by it or by the United States for use jointly by units of two or more reserve components of the armed forces or to acquire or construct facilities for such use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc34d39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute to any State such amounts as he determines to be necessary to expand, rehabilitate, or convert facilities owned by it (or to acquire, construct, expand, rehabilitate, or convert additional facilities) made necessary by the conversion, redesignation, or reorganization of units of the Army National Guard of the United States or the Air National Guard of the United States authorized by the Secretary of the military department concerned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc34d3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute to any State such amounts for the acquisition, construction, expansion, rehabilitation, or conversion by it of additional facilities as he determines to be required by any increase in the strength of the Army National Guard of the United States or the Air National Guard of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc34d3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute to any State amounts for the acquisition, construction, expansion, rehabilitation, and conversion by such State of such additional facilities as the Secretary determines to be required because of the failure of existing facilities to meet the purposes of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc34d3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute to any State such amounts for the construction, alteration, or rehabilitation of critical portions of facilities as the Secretary determines to be required to meet a change in Department of Defense construction criteria or standards related to the execution of the Federal military mission assigned to the unit using the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc34d3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Title to property acquired by the United States under subsection (a)(1) vests in the United States. Such property may be transferred to any State incident to the expansion, rehabilitation, or conversion of such property under subsection (a)(2) so long as the transfer of such property does not result in the creation of an enclave owned by a State within a Federal installation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc34d3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may delegate any of his authority or functions under this chapter to any department, agency, or officer of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc34d3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The expenses of leasing property under subsection (a)(1) may be paid from appropriations available for the payment of rent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc34d40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may procure, or contribute to any State such amounts as the Secretary determines to be necessary to procure, architectural and engineering services and construction design in connection with facilities to be established or developed under this chapter which are not otherwise authorized by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc34d41-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc34d42-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Authority provided by law to construct, expand, rehabilitate, convert, or equip any facility under this section includes authority to expend funds for surveys, administration, overhead, planning, design, and supervision incident to any such activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc34d43-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Authority to acquire real property under this section includes authority to make surveys and to acquire interests in land (including temporary interests) by purchase or gift.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc34d44-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/121"},"text":"7