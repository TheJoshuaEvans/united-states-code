{"tag":"section","attrib":{"id":"ida8f0cc92-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1564a"},"text":"§ 1564a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counterintelligence polygraph program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8f0cc93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority for Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may carry out a program for the administration of counterintelligence polygraph examinations to persons described in subsection (b). The program shall be conducted in accordance with the standards specified in subsection (e).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f0cc94-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Persons Covered","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (d), the following persons are subject to this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8f0cc95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to persons whose duties are described in subsection (c)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8f0cc96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" military and civilian personnel of the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8f0cc97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel of defense contractors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8f0cc98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons assigned or detailed to the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8f0cc99-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicants for a position in the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f0cc9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8f0cc9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national of the United States (as such term is defined in section 101 of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"8 U.S.C. 1101","children":[],"tail":")) and also a national of a foreign state; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8f0cc9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8f0cc9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a civilian employee or contractor who requires access to classified information; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8f0cc9e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the armed forces who requires access to classified information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f0cc9f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Types of Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may provide, under standards established by the Secretary, that a person described in subsection (b)(1) is subject to this section if that person’s duties involve—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8f0cca0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" access to information that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8f0cca1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been classified at the level of top secret; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8f0cca2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designated as being within a special access program under section 4.4(a) of Executive Order No. 12958 (or a successor Executive order); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f0cca3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assistance in an intelligence or military mission in a case in which the unauthorized disclosure or manipulation of information, as determined under standards established by the Secretary of Defense, could reasonably be expected to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8f33da4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" jeopardize human life or safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8f33da5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" result in the loss of unique or uniquely productive intelligence sources or methods vital to United States security; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8f33da6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compromise technologies, operational plans, or security procedures vital to the strategic advantage of the United States and its allies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f33da7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions From Coverage for Certain Intelligence Agencies and Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not apply to the following persons:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8f33da8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person assigned or detailed to the Central Intelligence Agency or to an expert or consultant under a contract with the Central Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f33da9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8f33daa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employed by or assigned or detailed to the National Security Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8f33dab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an expert or consultant under contract to the National Security Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8f33dac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of a contractor of the National Security Agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8f33dad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person applying for a position in the National Security Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f33dae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person assigned to a space where sensitive cryptographic information is produced, processed, or stored.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f33daf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person employed by, or assigned or detailed to, an office within the Department of Defense for the collection of specialized national foreign intelligence through reconnaissance programs or a contractor of such an office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f33db0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8f33db1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Polygraph examinations conducted under this section shall comply with all applicable laws and regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f33db2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such examinations may be authorized for any of the following purposes:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8f33db3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To assist in determining the initial eligibility for duties described in subsection (c) of, and aperiodically thereafter, on a random basis, to assist in determining the continued eligibility of, persons described in subsections (b)(1) and (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8f33db4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With the consent of, or upon the request of, the examinee, to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8f33db5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resolve serious credible derogatory information developed in connection with a personnel security investigation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8f33db6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exculpate him- or herself of allegations or evidence arising in the course of a counterintelligence or personnel security investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8f33db7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To assist, in a limited number of cases when operational exigencies require the immediate use of a person’s services before the completion of a personnel security investigation, in determining the interim eligibility for duties described in subsection (c) of the person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8f33db8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to persons described in subsection (b)(2), to assist in assessing any counterintelligence threats identified in an authorized investigation of foreign preference or foreign influence risks, as described in part 147 of title 32, Code of Federal Regulations, or such successor regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f33db9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Polygraph examinations conducted under this section shall provide adequate safeguards, prescribed by the Secretary of Defense, for the protection of the rights and privacy of persons subject to this section under subsection (b) who are considered for or administered polygraph examinations under this section. Such safeguards shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8f33dba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The examinee shall receive timely notification of the examination and its intended purpose and may only be given the examination with the consent of the examinee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8f33dbb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The examinee shall be advised of the examinee’s right to consult with legal counsel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8f33dbc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All questions asked concerning the matter at issue, other than technical questions necessary to the polygraph technique, must have a relevance to the subject of the inquiry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f33dbd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Oversight","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8f33dbe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish a process to monitor responsible and effective application of polygraph examinations within the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f33dbf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall make information on the use of polygraphs within the Department of Defense available to the congressional defense committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f33dc0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Polygraph Research Program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out a continuing research program to support the polygraph examination activities of the Department of Defense. The program shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8f33dc1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An on-going evaluation of the validity of polygraph techniques used by the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f33dc2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Research on polygraph countermeasures and anti-countermeasures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f33dc3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1564a/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developmental research on polygraph techniques, instrumentation, and analytic methods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8f33dc4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tX/s1041/a/1"},"text":"Pub. L. 108–136, div. A, title X, § 1041(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1607"},"text":"117 Stat. 1607","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1054/a"},"text":"Pub. L. 109–163, div. A, title X, § 1054(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3436"},"text":"119 Stat. 3436","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVI/s1623/a"},"text":"Pub. L. 115–232, div. A, title XVI, § 1623(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2119"},"text":"132 Stat. 2119","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8f33dc5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8f33dc6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida8f33dc7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order No. 12958, referred to in subsec. (c)(1)(B), which was formerly set out as a note under section 435 (now section 3161) of Title 50, War and National Defense, was revoked by Ex. Ord. No. 13526, § 6.2(g), ","children":[{"tag":"date","attrib":{"date":"2009-12-29"},"text":"Dec. 29, 2009","children":[],"tail":", 75 F.R. 731."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida8f33dc8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/tXI/s1121"},"text":"Pub. L. 100–180, title XI, § 1121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1147"},"text":"101 Stat. 1147","children":[],"tail":", as amended, which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s113"},"text":"section 113 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tX/s1041/b"},"text":"Pub. L. 108–136, div. A, title X, § 1041(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1608"},"text":"117 Stat. 1608","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8f33dc9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1623/a"},"text":"Pub. L. 115–232, § 1623(a)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, text read as follows: “Except as provided in subsection (d), the following persons, if their duties are described in subsection (c), are subject to this section:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Military and civilian personnel of the Department of Defense.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Personnel of defense contractors.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) A person assigned or detailed to the Department of Defense.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) An applicant for a position in the Department of Defense.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1623/c/1"},"text":"Pub. L. 115–232, § 1623(c)(1)","children":[],"tail":", substituted “subsection (b)(1)” for “subsection (b)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1623/c/2"},"text":"Pub. L. 115–232, § 1623(c)(2)","children":[],"tail":", substituted “subsections (b)(1) and (c)” for “subsections (b) and (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1623/b"},"text":"Pub. L. 115–232, § 1623(b)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" reenacted section catchline without change and amended text generally. Prior to amendment, section related to authority for program for administration of counterintelligence polygraph examinations in subsec. (a), persons covered in subsec. (b), exceptions from coverage for certain intelligence agencies and functions in subsec. (c), oversight in subsec. (d), and polygraph research program in subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8f33dca-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8f33dcb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1054/b"},"text":"Pub. L. 109–163, div. A, title X, § 1054(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3438"},"text":"119 Stat. 3438","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/163/dA/tX/s1054/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply with respect to polygraph examinations administered beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8f33dcc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVI/s1623/d"},"text":"Pub. L. 115–232, div. A, title XVI, § 1623(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2119"},"text":"132 Stat. 2119","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/232/dA/tXVI/s1623/d"},"text":"“Nothing in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1564a"},"text":"section 1564a of title 10","children":[],"tail":", United States Code, as amended by this section, shall be construed to prohibit the granting of a security clearance to persons described in subsection (b)(2) of such section absent information relevant to the adjudication process, as described in part 147 of title 32, Code of Federal Regulations, or such successor regulations.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
