{"tag":"section","attrib":{"id":"ida88f24be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1095f"},"text":"§ 1095f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" TRICARE program: referrals and preauthorizations under TRICARE Prime","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida88f24bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Referrals","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida88f24c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided by paragraph (2), a beneficiary enrolled in TRICARE Prime shall be required to obtain a referral for care through a designated primary care manager (or other care coordinator) prior to obtaining care under the TRICARE program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida88f24c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida88f24c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095f/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may waive the referral requirement in paragraph (1) in such circumstances as the Secretary may establish for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida88f24c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095f/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall waive the referral requirement in paragraph (1) in the case of a member of the armed forces serving on active duty who seeks to obtain any of the following kinds of care in a military medical treatment facility:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida88f24c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095f/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Physical therapy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida88f24c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095f/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nutritional.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida88f24c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095f/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Audiological.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida88f24c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095f/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Optometric.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida88f24c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095f/a/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Podiatric.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida88f24c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cost-sharing amounts for a beneficiary enrolled in TRICARE Prime who does not obtain a referral for care under paragraph (1) (or a waiver pursuant to paragraph (2) for such care) shall be determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1075a/c"},"text":"section 1075a(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida88f24ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preauthorization","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A beneficiary enrolled in TRICARE Prime shall be required to obtain preauthorization only with respect to a referral for the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida88f24cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Inpatient hospitalization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida88f24cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Inpatient care at a skilled nursing facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida88f24cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Inpatient care at a rehabilitation facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida88f24ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095f/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Inpatient care at a residential treatment center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida88f24cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition Regarding Prior Authorization for Certain Referrals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall ensure that no contract for managed care support under the TRICARE program includes any requirement that a managed care support contractor require a primary care or specialty care provider to obtain prior authorization before referring a patient to a specialty care provider that is part of the network of health care providers or institutions of the contractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida88f24d0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VII, § 728(a)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–189; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVII/s701/c"},"text":"Pub. L. 114–328, div. A, title VII, § 701(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2186"},"text":"130 Stat. 2186","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVII/s739/e/1"},"text":"Pub. L. 115–91, div. A, title VII, § 739(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1447"},"text":"131 Stat. 1447","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVII/s703"},"text":"Pub. L. 118–159, div. A, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1942"},"text":"138 Stat. 1942","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida88f24d1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida88f24d2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida88f24d3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" designated existing provisions as subpar. (A) and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “The Secretary of Defense shall ensure that no contract for managed care support under the TRICARE program includes any requirement that a managed care support contractor require a primary care or specialty care provider to obtain prior authorization before referring a patient to a specialty care provider that is part of the network of health care providers or institutions of the contractor.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida88f24d4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida88f24d5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" applicable with respect to the provision of health care under the TRICARE program beginning on "},{"tag":"date","attrib":{"date":"2018-01-01"},"text":"Jan. 1, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s701/k"},"text":"section 701(k) of Pub. L. 114–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072"},"text":"section 1072 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida88f24d6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VII, § 728(c)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–189, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/398/s1/dA"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1095f"},"text":"Section 1095f of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to a TRICARE managed care support contract entered into by the Department of Defense after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida88f24d7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Streamlining of TRICARE Prime Beneficiary Referral Process","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVII/s714"},"text":"Pub. L. 115–232, div. A, title VII, § 714","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1812"},"text":"132 Stat. 1812","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVII/s703/a"},"text":"Pub. L. 117–263, div. A, title VII, § 703(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2647"},"text":"136 Stat. 2647","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tVII/s703/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall streamline the process under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1095f"},"text":"section 1095f of title 10","children":[],"tail":", United States Code, by which beneficiaries enrolled in TRICARE Prime are referred to the civilian provider network for inpatient or outpatient care under the TRICARE program."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Objectives","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the requirement in subsection (a), the Secretary shall meet the following objectives:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The referral process shall model best industry practices for referrals from primary care managers to specialty care providers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The process shall limit administrative requirements for enrolled beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Beneficiary preferences for communications relating to appointment referrals using state-of-the-art information technology shall be used to expedite the process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be effective and efficient processes to determine the availability of appointments at military medical treatment facilities and, when unavailable, to make prompt referrals to network providers under the TRICARE program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirement in subsection (a) shall be implemented for referrals under TRICARE Prime in calendar year 2019.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evaluation and Improvement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"After 2019, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the referral process described in subsection (a) not less often than annually; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make appropriate improvements to the process in light of such evaluations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Improvement of Specialty Care Referrals During Permanent Changes of Station","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In conducting evaluations and improvements under subsection (d) to the referral process described in subsection (a), the Secretary shall ensure beneficiaries enrolled in TRICARE Prime who are undergoing a permanent change of station receive referrals from their primary care manager to such specialty care providers in the new location as the beneficiary may need before undergoing the permanent change of station.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the terms ‘TRICARE program’ and ‘TRICARE Prime’ have the meaning given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072"},"text":"section 1072 of title 10","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
