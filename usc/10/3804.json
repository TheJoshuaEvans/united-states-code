{"tag":"section","attrib":{"id":"idaa39eefb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3804"},"text":null,"children":[{"tag":"num","attrib":{"value":"3804"},"text":"§ 3804.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for progress payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa39eefc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3804/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment Commensurate With Work","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall ensure that any payment for work in progress (including materials, labor, and other items) under a defense contract that provides for such payments is commensurate with the work accomplished that meets standards established under the contract. The contractor shall provide such information and evidence as the Secretary of Defense determines necessary to permit the Secretary to carry out the preceding sentence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa39eefd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3804/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that progress payments referred to in subsection (a) are not made for more than 80 percent of the work accomplished under a defense contract so long as the Secretary has not made the contractual terms, specifications, and price definite.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa39eefe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3804/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section applies to any contract in an amount greater than $25,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa39eeff-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1834/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1834(a)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4234"},"text":"134 Stat. 4234","children":[],"tail":", 4236.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa39ef00-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa39ef01-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa39ef02-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2307"},"text":"section 2307 of this title","children":[],"tail":", which was transferred to this section and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1834/e"},"text":"Pub. L. 116–283, § 1834(e)","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/pl/100/370/s1/f/1/A"},"text":"Pub. L. 100–370, § 1(f)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-07-19"},"text":"July 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/846"},"text":"102 Stat. 846","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIII/s1322/a/4/B"},"text":"Pub. L. 101–510, div. A, title XIII, § 1322(a)(4)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1671"},"text":"104 Stat. 1671","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/25/tVII/s701/d/4"},"text":"Pub. L. 102–25, title VII, § 701(d)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-04-06"},"text":"Apr. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/114"},"text":"105 Stat. 114","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/tII/s2001/a/5"},"text":"Pub. L. 103–355, title II, § 2001(a)(5)","children":[],"tail":", (7), (e), "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3301"},"text":"108 Stat. 3301","children":[],"tail":", 3302."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa39ef03-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1834/e/1"},"text":"Pub. L. 116–283, § 1834(e)(1)","children":[],"tail":", transferred subsec. (e) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2307"},"text":"section 2307 of this title","children":[],"tail":" to this section and struck out subsec. (e) designation and heading “Conditions for Progress Payments” at beginning."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1834/e/1/B"},"text":"Pub. L. 116–283, § 1834(e)(1)(B)","children":[],"tail":", (2), after transfer of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2307/e"},"text":"section 2307(e) of this title","children":[],"tail":" to this section, redesignated par. (1) as subsec. (a) and inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1834/e/1/B"},"text":"Pub. L. 116–283, § 1834(e)(1)(B)","children":[],"tail":", (3), after transfer of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2307/e"},"text":"section 2307(e) of this title","children":[],"tail":" to this section, redesignated par. (2) as subsec. (b), inserted heading, and substituted “subsection (a)” for “paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1834/e/1/B"},"text":"Pub. L. 116–283, § 1834(e)(1)(B)","children":[],"tail":", (4), after transfer of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2307/e"},"text":"section 2307(e) of this title","children":[],"tail":" to this section, redesignated par. (3) as subsec. (c), inserted heading, and substituted “This section” for “This subsection”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa39ef04-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa39ef05-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as an Effective Date of 2021 Amendment note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa39ef06-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pilot Program To Incentivize Progress Payments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tVIII/s874"},"text":"Pub. L. 118–31, div. A, title VIII, § 874","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/352"},"text":"137 Stat. 352","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dA/tVIII/s874"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pilot Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Under Secretary of Defense for Acquisition and Sustainment shall establish and implement a pilot program to incentivize contractor performance by paying covered contractors a progress payment rate that is up to 10 percent higher than the customary progress payment rate on a contract-by-contract basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incentive Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Under Secretary shall develop and establish clear and measurable criteria for the payment to contractors of higher progress payments as described in subsection (a), including criteria for qualifying for such payments and the amount of such payments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Under Secretary shall apply the criteria established under subsection (b) and any associated incentive on a contract-by-contract basis when determining whether to pay a contractor a higher progress payment under the pilot program established under subsection (a) and the amount of such payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participation Voluntary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Participation in the pilot program established under subsection (a) shall be on a voluntary basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice and Comment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Under Secretary shall issue the regulations implementing the pilot program established under subsection (a) and establishing the criteria required by subsection (b) after notice and an opportunity for public comment of not more than 30 days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2024-09-30"},"text":"September 30, 2024","children":[],"tail":", and annually thereafter, the Under Secretary for Acquisition and Sustainment shall submit to the Committees on Armed Services of the Senate and House of Representatives a report on the implementation and activities of the pilot program established under subsection (a), including a comprehensive list of contractors that received increased progress payments under the pilot program and the contracts with respect to which such increased progress payments were made."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered contractor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘covered contractor’ means a contractor of the Department of Defense that is eligible for progress payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3804"},"text":"section 3804 of title 10","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Customary progress payment rate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘customary progress payment rate’ refers to the rate of progress payments provided for under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3804"},"text":"section 3804 of title 10","children":[],"tail":", United States Code, and payable in accordance with the applicable provisions of the Federal Acquisition Regulation and the Defense Federal Acquisition Regulation Supplement."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Under secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Under Secretary’ means the Under Secretary for Acquisition and Sustainment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"“(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided by paragraph (2), the authority to carry out the pilot program established under subsection (a) shall terminate on ","children":[{"tag":"date","attrib":{"date":"2029-01-01"},"text":"January 1, 2029","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Existing contracts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (1), a contractor that the Under Secretary determines under the pilot program established under subsection (a) shall be paid a higher progress payment under such pilot program with respect to a contract in effect as of the date described in paragraph (1) shall receive such higher progress payments until the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the termination or expiration of the contract; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the contractor becomes ineligible for progress payments or higher progress payments under such pilot program.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa39ef07-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Waivers of Certain Conditions for Progress Payments Under Certain Contracts During the COVID–19 National Emergency","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVIII/s891"},"text":"Pub. L. 116–283, div. A, title VIII, § 891","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3793"},"text":"134 Stat. 3793","children":[],"tail":", which related to waivers of certain conditions for progress payments under certain contracts during the COVID–19 national emergency, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVIII/s811/b/3/C"},"text":"Pub. L. 119–60, div. A, title VIII, § 811(b)(3)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/948"},"text":"139 Stat. 948","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
