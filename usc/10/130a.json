{"tag":"section","attrib":{"id":"ida7591515-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130a"},"text":null,"children":[{"tag":"num","attrib":{"value":"130a"},"text":"§ 130a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Defense support for funerals and memorial events for Members and former Members of Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7591516-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support for Funerals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (b), the Secretary of Defense may provide such support as the Secretary considers appropriate for a funeral or memorial event for a Member or former Member of Congress, including support with respect to transportation to and from such a funeral or memorial event, in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7591517-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requests for Support; Secretary Determination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide support under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7591518-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon request from the Speaker of the House of Representatives, the Minority Leader of the House of Representatives, the Majority Leader of the Senate, or the Minority Leader of the Senate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7591519-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary determines such support is necessary to carry out duties or responsibilities of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida759151a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may use funds authorized to be appropriated for operation and maintenance to provide support under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida759151b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tX/s1042/a"},"text":"Pub. L. 117–263, div. A, title X, § 1042(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2770"},"text":"136 Stat. 2770","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida759151c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida759151d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n