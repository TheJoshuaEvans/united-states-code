{"tag":"section","attrib":{"id":"ida8f7f8a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1582"},"text":null,"children":[{"tag":"num","attrib":{"value":"1582"},"text":"§ 1582.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistive technology, assistive technology devices, and assistive technology services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8f7f8a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1582/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may provide assistive technology, assistive technology devices, and assistive technology services to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8f7f8aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1582/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Defense employees with disabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f7f8ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1582/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Organizations within the Department that have requirements to make programs or facilities accessible to, and usable by, persons with disabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f7f8ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1582/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other department or agency of the Federal Government, upon the request of the head of that department or agency, for its employees with disabilities or for satisfying a requirement to make its programs or facilities accessible to, and usable by, persons with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f7f8ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1582/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the terms “assistive technology”, “assistive technology device”, “assistive technology service”, and “disability” have the meanings given those terms in section 3 of the Assistive Technology Act of 1998 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3002"},"text":"29 U.S.C. 3002","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8f7f8ae-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XI, § 1102(a)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–311.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8f7f8af-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8f7f8b0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida8f7f8b1-3