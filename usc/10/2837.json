{"tag":"section","attrib":{"id":"ida9e1bcbe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2837"},"text":null,"children":[{"tag":"num","attrib":{"value":"2837"},"text":"§ 2837.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Housing Requirements and Market Analysis","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9e1bcbf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2837/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less frequently than once every five years and in accordance with the requirements of this section, the Secretary concerned shall conduct a Housing Requirements and Market Analysis (in this section referred to as an “HRMA”) for each military installation under the jurisdiction of the Secretary concerned that is located in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e1bcc0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2837/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prioritization of Installations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9e1bcc1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2837/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), the Secretary concerned shall prioritize the conduct of HRMAs for military installations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9e1bcc2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2837/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which an HRMA has not been conducted during the five-year period preceding the date of the enactment of this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e1bcc3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2837/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in locations with housing shortages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e1bcc4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2837/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Existing 5-year requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) shall not apply to a military department that required an HRMA to be conducted for each military installation not less frequently than once every five years before the date of the enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e1bcc5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2837/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submittal to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall include with the budget materials for the Department of Defense for fiscal year 2024 and each subsequent fiscal year (as submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", United States Code) a list of the military installations for which the Secretary concerned plans to conduct an HRMA during the fiscal year covered by such budget materials."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e1bcc6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2837/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Housing Requirements and Market Analysis","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Housing Requirements and Market Analysis”or “HRMA” means, with respect to a military installation, a structured analytical process under which an assessment is made of both the suitability and availability of the private sector rental housing market using assumed specific standards related to affordability, location, features, physical condition, and the housing requirements of the total population of such installation, including members of the armed forces, civilian employees of the Department of Defense, and defense contractors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9e1bcc7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dB/tXXVIII/s2821/a"},"text":"Pub. L. 117–263, div. B, title XXVIII, § 2821(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2999"},"text":"136 Stat. 2999","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dB/tXXVIII/s2821/a"},"text":"Pub. L. 119–60, div. B, title XXVIII, § 2821(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1304"},"text":"139 Stat. 1304","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9e1bcc8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9e1bcc9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida9e1bcca-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2837, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dB/tXXVIII/s2803/a"},"text":"Pub. L. 103–337, div. B, title XXVIII, § 2803(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3051"},"text":"108 Stat. 3051","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dB/tXXVIII/s2802"},"text":"Pub. L. 104–106, div. B, title XXVIII, § 2802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/551"},"text":"110 Stat. 551","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1066/a/28"},"text":"Pub. L. 106–65, div. A, title X, § 1066(a)(28)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/772"},"text":"113 Stat. 772","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tX/s1031/a/44"},"text":"Pub. L. 108–136, div. A, title X, § 1031(a)(44)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1602"},"text":"117 Stat. 1602","children":[],"tail":", authorized the Secretary of a military department to enter into limited partnerships with private developers of housing through "},{"tag":"date","attrib":{"date":"2000-09-30"},"text":"Sept. 30, 2000","children":[],"tail":", further authorized such Secretary to enter into collateral incentive agreements with those private developers, and established the Defense Housing Investment Account, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dB/tXXVIII/s2802/a/1"},"text":"Pub. L. 113–66, div. B, title XXVIII, § 2802(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1006"},"text":"127 Stat. 1006","children":[],"tail":". For effects of repeal on existing contracts and on the Defense Housing Investment Account, see section 2802(b) and (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":", set out as notes below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9e1bccb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “total population of such installation, including members of the armed forces, civilian employees of the Department of Defense, and defense contractors” for “total military population of such installation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9e1bccc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9e1bccd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Housing Requirements and Market Analysis: Time Frame and Submittal of Information","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dB/tXXVIII/s2821/b"},"text":"Pub. L. 117–263, div. B, title XXVIII, § 2821(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2999"},"text":"136 Stat. 2999","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dB/tXXVIII/s2821/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time Frame.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"During each of fiscal years 2023 through 2027, the Secretary concerned shall conduct an HRMA for 20 percent of the military installations under the jurisdiction of the Secretary concerned located in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submittal of information to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2023-01-15"},"text":"January 15, 2023","children":[],"tail":", the Secretary concerned shall submit to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] a list of military installations for which the Secretary concerned plans to conduct an HRMA during fiscal year 2023."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘HRMA’ means, with respect to a military installation, a structured analytical process under which an assessment is made of both the suitability and availability of the private sector rental housing market using assumed specific standards related to affordability, location, features, physical condition, and the housing requirements of the total military population of such installation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘military installation’ has the meaning given in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2801"},"text":"section 2801 of title 10","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘Secretary concerned’ has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a"},"text":"section 101(a) of title 10","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9e1bcce-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effect on Existing Contracts","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/dB/tXXVIII/s2802/b"},"text":"Pub. L. 113–66, div. B, title XXVIII, § 2802(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1006"},"text":"127 Stat. 1006","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/66/dB/tXXVIII/s2802/b"},"text":"“The repeal of [former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2837"},"text":"section 2837 of title 10","children":[],"tail":", United States Code, shall not affect the validity or terms of any contract in connection with a limited partnership under subsection (a) or a collateral incentive agreement under subsection (b) of such section entered into before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9e1bccf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effect on Defense Housing Investment Account","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/dB/tXXVIII/s2802/c"},"text":"Pub. L. 113–66, div. B, title XXVIII, § 2802(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1006"},"text":"127 Stat. 1006","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/66/dB/tXXVIII/s2802/c"},"text":"“Any unobligated amounts remaining in the Defense Housing Investment Account on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":"] shall be transferred to the Department of Defense Family Housing Improvement Fund. Amounts transferred shall be merged with amounts in such fund and shall be available for the same purposes, and subject to the same conditions and limitations, as amounts in such fund.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
