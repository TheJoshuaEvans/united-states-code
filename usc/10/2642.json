{"tag":"section","attrib":{"id":"ida997baaa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2642"},"text":null,"children":[{"tag":"num","attrib":{"value":"2642"},"text":"§ 2642.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation services provided to certain non-Department of Defense agencies and entities: use of Department of Defense reimbursement rate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida997baab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2642/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), the Secretary of Defense may authorize the use of the Department of Defense reimbursement rate for military transportation services provided by a component of the Department of Defense as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida997baac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2642/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For military transportation services provided to the Central Intelligence Agency, if the Secretary of Defense determines that those military transportation services are provided for activities related to national security objectives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida997baad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2642/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For military transportation services provided to the Department of State for the transportation of armored motor vehicles to a foreign country to meet requirements of the Department of State for armored motor vehicles associated with the overseas travel of the Secretary of State in that country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida997baae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2642/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For military transportation services provided to any element of the Federal Government outside the Department of Defense in circumstances other than those specified in paragraphs (1) and (2), but only if the Secretary of Defense determines that the provision of such services will promote the improved use of transportation capacity without any negative effect on the national security objectives or the national security interests contained within the United States commercial transportation industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida997baaf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2642/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For military transportation services provided in support of foreign military sales.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida997bab0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2642/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For military transportation services provided to a State, local, or tribal agency (including any organization composed of State, local, or tribal agencies).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida997bab1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2642/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For military transportation services provided to a Department of Defense contractor when transporting supplies that are for, or destined for, a Department of Defense entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida997bab2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2642/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Authority for Certain Categories of Transportation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provisions of paragraphs (3), (4), (5), and (6) of subsection (a) shall apply only to military transportation services provided before ","children":[{"tag":"date","attrib":{"date":"2026-10-01"},"text":"October 1, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida997bab3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2642/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “Department of Defense reimbursement rate” means the amount charged a component of the Department of Defense by another component of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida997bab4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/88/tV/s501/a"},"text":"Pub. L. 102–88, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/435"},"text":"105 Stat. 435","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tX/s1006/a"},"text":"Pub. L. 108–136, div. A, title X, § 1006(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1585"},"text":"117 Stat. 1585","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tIII/s351/a"},"text":"Pub. L. 111–84, div. A, title III, § 351(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2262"},"text":"123 Stat. 2262","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/b/40"},"text":"Pub. L. 111–383, div. A, title X, § 1075(b)(40)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4371"},"text":"124 Stat. 4371","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tX/s1073/a"},"text":"Pub. L. 113–66, div. A, title X, § 1073(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/869"},"text":"127 Stat. 869","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX"},"text":"Pub. L. 113–291, div. A, title X","children":[],"tail":", §§ 1044(a)–(c)(1), 1071(f)(22), (g)(4), "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3493"},"text":"128 Stat. 3493","children":[],"tail":", 3494, 3511; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1081/f"},"text":"Pub. L. 115–91, div. A, title X, § 1081(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1601"},"text":"131 Stat. 1601","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIII/s373"},"text":"Pub. L. 116–92, div. A, title III, § 373","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1332"},"text":"133 Stat. 1332","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tIII/s351"},"text":"Pub. L. 118–159, div. A, title III, § 351","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1857"},"text":"138 Stat. 1857","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida997bab5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida997bab6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida997bab7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2026-10-01"},"text":"October 1, 2026","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"October 1, 2024","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"October 1, 2024","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2019-10-01"},"text":"October 1, 2019","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1081/f"},"text":"Pub. L. 115–91, § 1081(f)","children":[],"tail":", which directed substitution of “September 30” for “October 28” in the amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1044/a/2/A"},"text":"Pub. L. 113–291, § 1044(a)(2)(A)","children":[],"tail":", was executed by making the substitution the second place appearing in the quoted language to be stricken by that amendment, to reflect the probable intent of Congress. See 2014 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1044/c/1"},"text":"Pub. L. 113–291, § 1044(c)(1)","children":[],"tail":", amended section catchline generally, substituting “Transportation services provided to certain non-Department of Defense agencies and entities: use of Department of Defense reimbursement rate” for “Transportation services provided to certain other agencies: use of Department of Defense reimbursement rate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1044/a/1"},"text":"Pub. L. 113–291, § 1044(a)(1)","children":[],"tail":", substituted “Subject to subsection (b), the Secretary” for “The Secretary” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1071/g/4"},"text":"Pub. L. 113–291, § 1071(g)(4)","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1073/a/2/B"},"text":"Pub. L. 113–66, § 1073(a)(2)(B)","children":[],"tail":". See 2013 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1071/f/22"},"text":"Pub. L. 113–291, § 1071(f)(22)","children":[],"tail":", inserted “and” before “military transportation services provided in support”. Amendment was executed prior to amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1044/a/2/B"},"text":"Pub. L. 113–291, § 1044(a)(2)(B)","children":[],"tail":", see below, pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1071/k"},"text":"section 1071(k) of Pub. L. 113–291","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1044/a/2/B"},"text":"Pub. L. 113–291, § 1044(a)(2)(B)","children":[],"tail":", substituted “Department of Defense” for “Department of Defense and military transportation services provided in support of foreign military sales”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1044/a/2/A"},"text":"Pub. L. 113–291, § 1044(a)(2)(A)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1081/f"},"text":"Pub. L. 115–91, § 1081(f)","children":[],"tail":", substituted “For” for “During the period beginning on "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"October 28, 2009","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2019-09-30"},"text":"September 30, 2019","children":[],"tail":", for”. See 2017 Amendment note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1044/a/3"},"text":"Pub. L. 113–291, § 1044(a)(3)","children":[],"tail":", added pars. (4) to (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1044/b"},"text":"Pub. L. 113–291, § 1044(b)","children":[],"tail":", added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1073/b"},"text":"Pub. L. 113–66, § 1073(b)","children":[],"tail":", substituted “Transportation” for “Airlift” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1073/a/1"},"text":"Pub. L. 113–66, § 1073(a)(1)","children":[],"tail":", substituted “transportation services” for “airlift services” wherever appearing and “transportation capacity” for “airlift capacity” in par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1073/a/2/B"},"text":"Pub. L. 113–66, § 1073(a)(2)(B)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1071/g/4"},"text":"Pub. L. 113–291, § 1071(g)(4)","children":[],"tail":", inserted “military transportation services provided in support of foreign military sales” after “Department of Defense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1073/a/2/A"},"text":"Pub. L. 113–66, § 1073(a)(2)(A)","children":[],"tail":", (C), substituted “"},{"tag":"date","attrib":{"date":"2019-09-30"},"text":"September 30, 2019","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2014-10-28"},"text":"October 28, 2014","children":[],"tail":"” and “transportation industry” for “air industry”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" substituted “During the period beginning on "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"October 28, 2009","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2014-10-28"},"text":"October 28, 2014","children":[],"tail":"” for “During the five-year period beginning on the date of the enactment of the National Defense Authorization Act for Fiscal Year 2010”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1006/b/1"},"text":"Pub. L. 108–136, § 1006(b)(1)","children":[],"tail":", substituted “Airlift services provided to certain other agencies: use of Department of Defense reimbursement rate” for “Reimbursement rate for airlift services provided to Central Intelligence Agency” as section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1006/a"},"text":"Pub. L. 108–136, § 1006(a)","children":[],"tail":", inserted “as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) For military airlift services provided”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"before “to the Central Intelligence Agency”, and added par. (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida997bab8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida997bab9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1081/f"},"text":"Pub. L. 115–91, div. A, title X, § 1081(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1601"},"text":"131 Stat. 1601","children":[],"tail":", provided that the amendment made by section 1081(f) is effective as of "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida997baba-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1071/g"},"text":"Pub. L. 113–291, div. A, title X, § 1071(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3511"},"text":"128 Stat. 3511","children":[],"tail":", provided that the amendment made by section 1071(g)(4) is effective as of "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida997babb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Executive Branch Support for Recently Enacted Commissions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tX/s1050"},"text":"Pub. L. 117–263, div. A, title X, § 1050","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2775"},"text":"136 Stat. 2775","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tX/s1082/b"},"text":"Pub. L. 118–31, div. A, title X, § 1082(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/417"},"text":"137 Stat. 417","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dA/tX/s1082/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance From Department of Defense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At the request of a covered commission, the Secretary of Defense may provide to the covered commission, on a reimbursable basis, such services, funds, facilities, staff, and other support services as necessary for the performance of the functions of the commission. Amounts provided to a covered commission pursuant to this section may be provided from amounts appropriated for the Department of Defense, as provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of Travel Support to Certain Commissions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purpose of providing support to facilitate overseas travel requests from a legislative branch commission, or any commission so designated for support under this subsection jointly by the Majority Leader of the Senate, the Speaker of the House of Representatives, the Minority Leader of the Senate, and the Minority Leader of the House of Representatives, the Secretary of Defense and the Secretary of State shall consider such requests as equivalent to a request from Congress, and apply the same standards in determining the extent to which such support may be provided under law and regulation. Any support so provided shall be funded out of amounts appropriated for the operation of such commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Commission Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term ‘covered commission’ means a commission established pursuant to any of the following sections of the National Defense Authorization Act for Fiscal Year 2022 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Public Law 117–81","children":[],"tail":"):"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 1004 [","children":[{"tag":"ref","attrib":{"href":"/us/stat/135/1884"},"text":"135 Stat. 1884","children":[],"tail":"] (Commission on Planning, Programming, Budgeting, and Execution Reform)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1091 [","children":[{"tag":"ref","attrib":{"href":"/us/stat/135/1929"},"text":"135 Stat. 1929","children":[],"tail":"] (National Security Commission on Emerging Biotechnology)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1094 [","children":[{"tag":"ref","attrib":{"href":"/us/stat/135/1935"},"text":"135 Stat. 1935","children":[],"tail":"] (Afghanistan War Commission)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1095 [","children":[{"tag":"ref","attrib":{"href":"/us/stat/135/1943"},"text":"135 Stat. 1943","children":[],"tail":"] (Commission on the National Defense Strategy)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1687 [","children":[{"tag":"ref","attrib":{"href":"/us/stat/135/2126"},"text":"135 Stat. 2126","children":[],"tail":"] (Congressional Commission on the Strategic Posture of the United States).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
