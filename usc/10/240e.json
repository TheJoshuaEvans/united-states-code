{"tag":"section","attrib":{"id":"ida7924dd7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240e"},"text":null,"children":[{"tag":"num","attrib":{"value":"240e"},"text":"§ 240e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits: use of commercial data integration and analysis products in preparing audits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7924dd8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deployment of Data Analytics Capabilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall use competitive procedures under chapter 137 ","children":[{"tag":"ref","attrib":{"idref":"fn002020"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002020"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title to procure or develop technologies or services, including those based on commercially available information technologies and services to improve data collection and analyses to support preparation of auditable financial statements for the Department of Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7924dd9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funding and Resources","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may use science and technology funding, prototypes, and test and evaluation resources as appropriate in support of 