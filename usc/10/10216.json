{"tag":"section","attrib":{"id":"idab8c8745-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216"},"text":null,"children":[{"tag":"num","attrib":{"value":"10216"},"text":"§ 10216.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military technicians (dual status)","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab8c8746-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8c8747-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section and any other provision of law, a military technician (dual status) is a Federal civilian employee who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab8c8748-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is employed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3101"},"text":"section 3101 of title 5","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s709/b"},"text":"section 709(b) of title 32","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8c8749-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required as a condition of that employment to maintain membership in the Selected Reserve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8c874a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is assigned to a civilian position as a technician in the organizing, administering, instructing, or training of the Selected Reserve or in the maintenance and repair of supplies or equipment issued to the Selected Reserve or the armed forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c874b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Military technicians (dual status) shall be authorized and accounted for as a separate category of civilian employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c874c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A military technician (dual status) who is employed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3101"},"text":"section 3101 of title 5","children":[],"tail":" may perform the following additional duties to the extent that the performance of those duties does not interfere with the performance of the primary duties described in paragraph (1):"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab8c874d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supporting operations or missions assigned in whole or in part to the technician’s unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8c874e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Supporting operations or missions performed or to be performed by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idab8c874f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit composed of elements from more than one component of the technician’s armed force; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab8c8750-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a joint forces unit that includes—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idab8c8751-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/a/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more units of the technician’s component; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idab8c8752-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/a/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the technician’s component whose reserve component assignment is in a position in an element of the joint forces unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8c8753-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Instructing or training in the United States or the Commonwealth of Puerto Rico or possessions of the United States of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idab8c8754-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" active-duty members of the armed forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab8c8755-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of foreign military forces (under the same authorities and restrictions applicable to active-duty members providing such instruction or training);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab8c8756-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/a/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Defense contractor personnel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab8c8757-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/a/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Defense civilian employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c8758-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Priority for Management of Military Technicians (Dual Status)","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8c8759-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As a basis for making the annual request to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s115/d"},"text":"section 115(d) of this title","children":[],"tail":" for authorization of end strengths for military technicians (dual status) of the Army and Air Force reserve components, the Secretary of Defense shall give priority to supporting authorizations for military technicians (dual status) in the following high-priority units and organizations:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab8c875a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Units of the Selected Reserve that are scheduled to deploy no later than 90 days after mobilization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8c875b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Units of the Selected Reserve that are or will deploy to relieve active duty peacetime operations tempo.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8c875c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Those organizations with the primary mission of providing direct support surface and aviation maintenance for the reserve components of the Army and Air Force, to the extent that the military technicians (dual status) in such units would mobilize and deploy in a skill that is compatible with their civilian position skill.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c875d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each fiscal year, the Secretary of Defense shall, for the high-priority units and organizations referred to in paragraph (1), seek to achieve a programmed manning level for military technicians (dual status) that is not less than 90 percent of the programmed manpower structure for those units and organizations for military technicians (dual status) for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c875e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Military technician (dual status) authorizations and personnel shall be exempt from any requirement (imposed by law or otherwise) for reductions in Department of Defense civilian personnel and shall only be reduced as part of military force structure reductions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c875f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information Required To Be Submitted With Annual End Strength Authorization Request","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8c8760-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense shall include as part of the budget justification documents submitted to Congress with the budget of the Department of Defense for any fiscal year the following information with respect to the end strengths for military technicians (dual status) requested in that budget pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s115/d"},"text":"section 115(d) of this title","children":[],"tail":", shown separately for each of the Army and Air Force reserve components:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab8c8761-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of military technicians (dual status) in the high priority units and organizations specified in subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8c8762-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of technicians other than military technicians (dual status) in the high priority units and organizations specified in subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8c8763-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of military technicians (dual status) in other than high priority units and organizations specified in subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8c8764-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of technicians other than military technicians (dual status) in other than high priority units and organizations specified in subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c8765-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab8c8766-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the budget submitted to Congress for any fiscal year requests authorization for that fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s115/d"},"text":"section 115(d) of this title","children":[],"tail":" of a military technician (dual status) end strength for a reserve component of the Army or Air Force in a number that constitutes a reduction from the end strength minimum established by law for that reserve component for the fiscal year during which the budget is submitted, the Secretary of Defense shall submit to the congressional defense committees with that budget a justification providing the basis for that requested reduction in technician end strength."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8c8767-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any justification submitted under subparagraph (A) shall clearly delineate the specific force structure reductions forming the basis for such requested technician reduction (and the numbers related to those reductions).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c8768-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unit Membership Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8c8769-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Unless specifically exempted by law, each individual who is hired as a military technician (dual status) after ","children":[{"tag":"date","attrib":{"date":"1995-12-01"},"text":"December 1, 1995","children":[],"tail":", shall be required as a condition of that employment to maintain membership in—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab8c876a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unit of the Selected Reserve by which the individual is employed as a military technician; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8c876b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of the Selected Reserve that the individual is employed as a military technician to support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c876c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) does not apply to a military technician (dual status) who is employed by the Army Reserve in an area other than Army Reserve troop program units.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c876d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) does not apply to a military technician (dual status) who is employed by the Air Force Reserve in an area other than the Air Force Reserve unit program, except that not more than 50 of such technicians may be assigned outside of the unit program at the same time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c876e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dual Status Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8c876f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds appropriated for the Department of Defense may not (except as provided in paragraph (2)) be used for compensation as a military technician of any individual hired as a military technician (dual status) after ","children":[{"tag":"date","attrib":{"date":"1996-02-10"},"text":"February 10, 1996","children":[],"tail":", who is no longer a member of the Selected Reserve."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c8770-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided by law, the Secretary concerned may pay compensation described in paragraph (1) to an individual described in that paragraph who is no longer a member of the Selected Reserve for a period up to 12 months following the individual’s loss of membership in the Selected Reserve if the Secretary determines that such loss of membership was not due to the failure of that individual to meet military standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c8771-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority for Deferral of Mandatory Separation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army and the Secretary of the Air Force may each implement personnel policies so as to allow, at the discretion of the Secretary concerned, a military technician (dual status) who continues to meet the requirements of this section for dual status to continue to serve beyond a mandatory removal date, and any applicable maximum years of service limitation, until the military technician (dual status) reaches age 62 and attains eligibility for an unreduced annuity (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s10218/c"},"text":"section 10218(c) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c8772-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention of Military Technicians Who Lose Dual Status Due to Combat-Related Disability","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8c8773-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding subsection (d) of this section or subsections (a)(3) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s10218"},"text":"section 10218 of this title","children":[],"tail":", if a military technician (dual status) loses such dual status as the result of a combat-related disability (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1413a"},"text":"section 1413a of this title","children":[],"tail":"), the person may be retained as a non-dual status technician so long as—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab8c8774-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the combat-related disability does not prevent the person from performing the non-dual status functions or position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8c8775-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person, while a non-dual status technician, is not disqualified from performing the non-dual status functions or position because of performance, medical, or other reasons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c8776-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person so retained shall be removed not later than 30 days after becoming eligible for an unreduced annuity and becoming 60 years of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c8777-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10216/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Persons retained under the authority of this subsection do not count against the limitations of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s10217/c"},"text":"section 10217(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab8c8778-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s513/c/1"},"text":"Pub. L. 104–106, div. A, title V, § 513(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/306"},"text":"110 Stat. 306","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tIV/s413/b"},"text":"Pub. L. 104–201, div. A, title IV, § 413(b)","children":[],"tail":", (c), title XII, § 1214, "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2507"},"text":"110 Stat. 2507","children":[],"tail":", 2508, 2695; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tV/s522/a"},"text":"Pub. L. 105–85, div. A, title V, § 522(a)","children":[],"tail":", (b), (f)–(h)(1), "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1734-1736"},"text":"111 Stat. 1734–1736","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s521"},"text":"Pub. L. 106–65, div. A, title V, § 521","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/595"},"text":"113 Stat. 595","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tIV/s403/c"},"text":"Pub. L. 108–136, div. A, title IV, § 403(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1452"},"text":"117 Stat. 1452","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s513/a"},"text":"Pub. L. 109–163, div. A, title V, § 513(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3232"},"text":"119 Stat. 3232","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s525/b"},"text":"Pub. L. 109–364, div. A, title V, § 525(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2194"},"text":"120 Stat. 2194","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tV/s511"},"text":"Pub. L. 110–181, div. A, title V, § 511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/98"},"text":"122 Stat. 98","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title V, § 511, "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4439"},"text":"122 Stat. 4439","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tV/s512"},"text":"Pub. L. 111–383, div. A, title V, § 512","children":[],"tail":", title X, § 1075(b)(52), "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4210"},"text":"124 Stat. 4210","children":[],"tail":", 4372; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s514/a"},"text":"Pub. L. 112–81, div. A, title V, § 514(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1394"},"text":"125 Stat. 1394","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s511/a"},"text":"Pub. L. 118–159, div. A, title V, § 511(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1875"},"text":"138 Stat. 1875","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVII/s1701/a/40"},"text":"Pub. L. 119–60, div. A, title XVII, § 1701(a)(40)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1210"},"text":"139 Stat. 1210","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab8c8779-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab8c877a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab8c877b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" struck out period after “age 62”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “62.” for “60”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsecs. (b)(1), (c)(1), (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1075/b/52"},"text":"Pub. L. 111–383, § 1075(b)(52)","children":[],"tail":", substituted “section 115(d)” for “section 115(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s512"},"text":"Pub. L. 111–383, § 512","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" inserted “Authority for” before “Deferral of Mandatory Separation” in heading, and in text, substituted “may each implement” for “shall implement”, inserted “, at the discretion of the Secretary concerned,” after “so as to allow”, and struck out “for officers” after “mandatory removal date”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" inserted “and the Secretary of the Air Force” after “Secretary of the Army”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s525/b/1"},"text":"Pub. L. 109–364, § 525(b)(1)","children":[],"tail":", substituted “organizing, administering, instructing, or” for “administration and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s525/b/2"},"text":"Pub. L. 109–364, § 525(b)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsecs. (b)(1), (c)(1), (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" substituted “section 115(c)” for “115(g)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s521/a/1"},"text":"Pub. L. 106–65, § 521(a)(1)","children":[],"tail":", substituted “section 709(b)” for “section 709”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s521/a/2"},"text":"Pub. L. 106–65, § 521(a)(2)","children":[],"tail":", inserted “civilian” after “is assigned to a”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s521/b/1"},"text":"Pub. L. 106–65, § 521(b)(1)","children":[],"tail":", inserted “(dual status)” after “military technician” the second place it appeared."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s521/b/2"},"text":"Pub. L. 106–65, § 521(b)(2)","children":[],"tail":", substituted “Except as otherwise provided by law, the Secretary” for “The Secretary” and “up to 12 months” for “not to exceed six months”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s522/h"},"text":"Pub. L. 105–85, § 522(h)","children":[],"tail":", inserted “(dual status)” after “military technicians” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s522/a"},"text":"Pub. L. 105–85, § 522(a)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—Military technicians are Federal civilian employees hired under title 5 and title 32 who are required to maintain dual-status as drilling reserve component members as a condition of their Federal civilian employment. Such employees shall be authorized and accounted for as a separate category of dual-status civilian employees, exempt as specified in subsection (b)(3) from any general or regulatory requirement for adjustments in Department of Defense civilian personnel.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s522/g/1"},"text":"Pub. L. 105–85, § 522(g)(1)","children":[],"tail":", inserted “("},{"tag":"inline","attrib":{},"text":"dual status","children":[],"tail":")” after “"},{"tag":"inline","attrib":{},"text":"military technicians","children":[],"tail":"” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s522/g/2/A"},"text":"Pub. L. 105–85, § 522(g)(2)(A)","children":[],"tail":", (B), in introductory provisions, inserted “(dual status)” after “for military technicians” and substituted “military technicians (dual status)” for “dual status military technicians”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s522/g/2/C"},"text":"Pub. L. 105–85, § 522(g)(2)(C)","children":[],"tail":", inserted “(dual status)” after “military technicians”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s522/g/3"},"text":"Pub. L. 105–85, § 522(g)(3)","children":[],"tail":", inserted “(dual status)” after “military technicians” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s522/g/4"},"text":"Pub. L. 105–85, § 522(g)(4)","children":[],"tail":", inserted “(dual status)” after “Military technician”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s522/g/5/A"},"text":"Pub. L. 105–85, § 522(g)(5)(A)","children":[],"tail":", inserted “(dual status)” after “military technicians” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A) to (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s522/f"},"text":"Pub. L. 105–85, § 522(f)","children":[],"tail":", (g)(5)(B), substituted “subsection (b)(1)” for “subsection (a)(1)” and “military technicians (dual status)” for “dual-status technicians”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s522/g/5/C"},"text":"Pub. L. 105–85, § 522(g)(5)(C)","children":[],"tail":", inserted “(dual status)” after “military technician”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s522/g/5/D"},"text":"Pub. L. 105–85, § 522(g)(5)(D)","children":[],"tail":", substituted “delineate the specific force structure reductions” for “delineate—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) in the case of a reduction that includes a reduction in technicians described in subparagraph (A) or (C) of paragraph (1), the specific force structure reductions forming the basis for such requested technician reduction (and the numbers related to those force structure reductions); and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) in the case of a reduction that includes reductions in technicians described in subparagraphs (B) or (D) of paragraph (1), the specific force structure reductions, Department of Defense civilian personnel reductions, or other reasons”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s522/b"},"text":"Pub. L. 105–85, § 522(b)","children":[],"tail":", added subsecs. (d) and (e) and struck out former subsec. (d) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(d) ","children":[{"tag":"inline","attrib":{},"text":"Dual-Status Requirement","children":[],"tail":".—The Secretary of Defense shall require the Secretary of the Army and the Secretary of the Air Force to establish as a condition of employment for each individual who is hired after "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"February 10, 1996","children":[],"tail":", as a military technician that the individual maintain membership in the Selected Reserve (so as to be a so-called ‘dual-status’ technician) and shall require that the civilian and military position skill requirements of dual-status military technicians be compatible. No Department of Defense funds may be spent for compensation for any military technician hired after "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"February 10, 1996","children":[],"tail":", who is not a member of the Selected Reserve, except that compensation may be paid for up to six months following loss of membership in the Selected Reserve if such loss of membership was not due to the failure to meet military standards.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1214/2"},"text":"Pub. L. 104–201, § 1214(2)","children":[],"tail":", added subsec. (a). Former subsec. (a) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s413/c/1"},"text":"Pub. L. 104–201, § 413(c)(1)","children":[],"tail":", substituted “section 115(g)” for “section 115” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1214/1"},"text":"Pub. L. 104–201, § 1214(1)","children":[],"tail":", (3), redesignated subsec. (a) as (b) and struck out “in high-priority units and organizations specified in paragraph (1)” after “authorizations and personnel” in par. (3). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s413/b/2"},"text":"Pub. L. 104–201, § 413(b)(2)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1214/1"},"text":"Pub. L. 104–201, § 1214(1)","children":[],"tail":", redesignated subsec. (b) as (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s413/b/1"},"text":"Pub. L. 104–201, § 413(b)(1)","children":[],"tail":", (c)(2), redesignated subsec. (b) as (c) and substituted “after "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"February 10, 1996","children":[],"tail":",” for “after the date of the enactment of this section” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1214/1"},"text":"Pub. L. 104–201, § 1214(1)","children":[],"tail":", redesignated subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab8ef67c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab8ef67d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s513/b"},"text":"Pub. L. 109–163, div. A, title V, § 513(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3232"},"text":"119 Stat. 3232","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/163/dA/tV/s513/b"},"text":"“The Secretary of the Army shall implement subsection (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s10216"},"text":"section 10216 of title 10","children":[],"tail":", United States Code, as added by subsection (a), not later than 90 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab8ef67e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2021-12-31"},"text":"Dec. 31, 2021","children":[],"tail":", of provisions in subsec. (c) of this section requiring submittal of annual report to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1061"},"text":"section 1061 of Pub. L. 114–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s111"},"text":"section 111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab8ef67f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Conversion of Certain Military Technician (Dual Status) Positions to Civilian Positions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tX/s1053/a"},"text":"Pub. L. 114–92, div. A, title X, § 1053(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/981"},"text":"129 Stat. 981","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tX/s1084/a"},"text":"Pub. L. 114–328, div. A, title X, § 1084(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2421"},"text":"130 Stat. 2421","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1083"},"text":"Pub. L. 115–91, div. A, title X, § 1083","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1602"},"text":"131 Stat. 1602","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/91/dA/tX/s1083"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"By not later than ","children":[{"tag":"date","attrib":{"date":"2017-10-01"},"text":"October 1, 2017","children":[],"tail":", the Secretary of Defense shall convert not fewer than 12.6 percent of all military technician positions to positions filled by individuals who are employed under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3101"},"text":"section 3101 of title 5","children":[],"tail":", United States Code, or "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1601"},"text":"section 1601 of title 10","children":[],"tail":", United States Code, and are not military technicians. The positions to be converted are described in paragraph (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered positions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The positions described in this paragraph are military technician (dual status) positions as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Military technician (dual status) positions identified as general administration, clerical, finance, and office service occupations by the Army Reserve, the Air Force Reserve, the National Guard Bureau, State adjutants general, and the Secretary of Defense in the course of reviewing all military technician positions for purposes of implementing this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other military technician (dual status) positions as the Secretary shall specify for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of incumbents","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a position converted under paragraph (1) for which there is an incumbent employee, the Secretary shall fill that position, as converted, with the incumbent employee without regard to any requirement concerning competition or competitive hiring procedures.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
