{"tag":"section","attrib":{"id":"ida8406863-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s982"},"text":null,"children":[{"tag":"num","attrib":{"value":"982"},"text":"§ 982.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members: service on State and local juries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8406864-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s982/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member of the armed forces on active duty may not be required to serve on a State or local jury if the Secretary concerned determines that such service—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8406865-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s982/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would unreasonably interfere with the performance of the member’s military duties; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8406866-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s982/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would adversely affect the readiness of the unit, command, or activity to which the member is assigned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8406867-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s982/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A determination by the Secretary concerned under this section is conclusive.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8406868-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s982/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned shall prescribe regulations for the administration of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8406869-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s982/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section, the term “State” includes the District of Columbia, the Commonwealth of Puerto Rico, and each territory of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida840686a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tV/s502/a"},"text":"Pub. L. 99–661, div. A, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3863"},"text":"100 Stat. 3863","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
