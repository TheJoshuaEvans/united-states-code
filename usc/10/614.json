{"tag":"section","attrib":{"id":"ida7e8365c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s614"},"text":null,"children":[{"tag":"num","attrib":{"value":"614"},"text":"§ 614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of convening of selection boards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7e8365d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s614/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least 30 days before a selection board is convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s611/a"},"text":"section 611(a) of this title","children":[],"tail":" to recommend officers in a grade for promotion to the next higher grade, the Secretary concerned (1) shall notify in writing the officers eligible for consideration for promotion of the date on which the board is to convene and the name and date of rank of the junior officer, and of the senior officer, in the promotion zone as of the date of the notification, or (2) shall issue a general written notice to the armed force concerned regarding the convening of the board which shall include the convening date of the board and the name and date of rank of the junior officer, and of the senior officer, in the promotion zone as of the date of the notification."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e8365e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s614/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer eligible for consideration by a selection board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s611/a"},"text":"section 611(a) of this title","children":[],"tail":" may send a written communication to the board, to arrive not later than 10 calendar days before the date the board convenes, calling attention to any matter concerning himself that the officer considers important to his case. The selection board shall give consideration to any timely communication under this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7e8365f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tI/s105"},"text":"Pub. L. 96–513, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2852"},"text":"94 Stat. 2852","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/22/s4/b"},"text":"Pub. L. 97–22, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-07-10"},"text":"July 10, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/126"},"text":"95 Stat. 126","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tV/s504/a/2/A"},"text":"Pub. L. 102–190, div. A, title V, § 504(a)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1357"},"text":"105 Stat. 1357","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s505/a"},"text":"Pub. L. 109–163, div. A, title V, § 505(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3227"},"text":"119 Stat. 3227","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tV/s501/a"},"text":"Pub. L. 115–91, div. A, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1373"},"text":"131 Stat. 1373","children":[],"tail":".)"}],