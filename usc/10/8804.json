{"tag":"section","attrib":{"id":"idab4e9292-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8804"},"text":null,"children":[{"tag":"num","attrib":{"value":"8804"},"text":"§ 8804.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ships’ stores: sale of goods and services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab4e9293-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8804/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under such regulations and at such prices as the Secretary of the Navy may prescribe, the Secretary may provide for the sale of goods and services from ships’ stores to members of the naval service and to such other persons as provided by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab4e9294-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8804/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incidental Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy may provide financial services, space, utilities, and labor to ships’ stores on a nonreimbursable basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab4e9295-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8804/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Items Sold","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Merchandise sold by ship stores afloat may include items in the following categories:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab4e9296-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8804/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Health, beauty, and barber items.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4e9297-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8804/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prerecorded music and videos.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4e9298-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8804/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Photographic batteries and related supplies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4e9299-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8804/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appliances and accessories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4e929a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8804/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Uniform items, emblematic and athletic clothing, and equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4e929b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8804/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Luggage and leather goods.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4e929c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8804/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Stationery, magazines, books, and supplies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4e929d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8804/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sundry, games, and souvenirs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4e929e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8804/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Beverages and related food and snacks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4e929f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8804/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Laundry, tailor, and cleaning supplies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4e92a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8804/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tobacco products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab4e92a1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tIII/s329/a/1"},"text":"Pub. L. 101–510, div. A, title III, § 329(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"da