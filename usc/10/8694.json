{"tag":"section","attrib":{"id":"idab403b7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8694"},"text":null,"children":[{"tag":"num","attrib":{"value":"8694"},"text":"§ 8694.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on ship maintenance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab403b7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8694/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than October 15 of each year, the Secretary of the Navy shall submit to the Committees on Armed Services of the Senate and House of Representatives a report setting forth each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab403b7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8694/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of all ship maintenance planned for the fiscal year during which the report is submitted, by hull.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403b80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8694/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The estimated cost of the maintenance described pursuant to paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403b81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8694/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary of all ship maintenance conducted by the Secretary during the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403b82-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8694/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed description of any ship maintenance that was deferred during the previous fiscal year, including specific reasons for the delay or cancellation of any availability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403b83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8694/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A detailed description of the effect of each of the planned ship maintenance actions that were delayed or cancelled during the previous fiscal year, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403b84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8694/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the effects on the costs and schedule for each delay or cancellation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403b85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8694/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accrued operational and fiscal cost of all the deferments over the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403b86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8694/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form of Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":" Each report submitted under subsection (a) shall be submitted in unclassified form and made publicly available on an appropriate internet website in a searchable format, but may contain a classified annex.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab403b87-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tX/s1016/a"},"text":"Pub. L. 117–81, div. A, title X, § 1016(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1895"},"text":"135 Stat. 1895","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
