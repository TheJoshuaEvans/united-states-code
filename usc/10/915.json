{"tag":"section","attrib":{"id":"ida82ae5da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s915"},"text":null,"children":[{"tag":"num","attrib":{"value":"915"},"text":"§ 915.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 115. Communicating threats","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida82ae5db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s915/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Communicating Threats Generally","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person subject to this chapter who wrongfully communicates a threat to injure the person, property, or reputation of another shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82ae5dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s915/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Communicating Threat to Use Explosive, etc","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person subject to this chapter who wrongfully communicates a threat to injure the person or property of another by use of (1) an explosive, (2) a weapon of mass destruction, (3) a biological or chemical agent, substance, or weapon, or (4) a hazardous material, shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82ae5dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s915/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Communicating False Threat Concerning Use of Explosive, etc","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person subject to this chapter who maliciously communicates a false threat concerning injury to the person or property of another by use of (1) an explosive, (2) a weapon of mass destruction, (3) a biological or chemical agent, substance, or weapon, or (4) a hazardous material, shall be punished as a court-martial may direct. As used in the preceding sentence, the term “false threat” means a threat that, at the time the threat is communicated, is known to be false by the person communicating the threat.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida82ae5de-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/72"},"text":"70A Stat. 72","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLX/s5427"},"text":"Pub. L. 114–328, div. E, title LX, § 5427","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2948"},"text":"130 Stat. 2948","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida82ae5df-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida82ae5e0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida82ae5e1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],