{"tag":"section","attrib":{"id":"idaadc219e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7081"},"text":null,"children":[{"tag":"num","attrib":{"value":"7081"},"text":"§ 7081.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dental Corps: Chief, functions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaadc219f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7081/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of the Dental Corps shall be an officer of that corps appointed as prescribed in section 3039 ","children":[{"tag":"ref","attrib":{"idref":"fn002154"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002154"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaadc21a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7081/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under such regulations as the Secretary of the Army may prescribe, all dental functions of the Army shall be under the direction of the Chief of the Dental Corps. All matters relating to dentistry shall be referred to the Chief of the Dental Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaadc21a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7081/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Chief of the Dental Corps shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaadc21a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7081/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish professional standards and policies for dental practice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaadc21a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7081/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initiate and recommend action pertaining to organization requirements and utilization of the Dental Corps and dental auxiliary strength, appointments, advancement, training assignments, and transfer of dental personnel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaadc21a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7081/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the adviser to the Office of the Surgeon General on all matters relating directly to dentistry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaadc21a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7081/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under such regulations as the Secretary of the Army may prescribe, dental and dental auxiliary personnel throughout the Army shall be organized into units commanded by a designated commissioned officer of the Army Medical Department. Such officer will be directly responsible to the commander of installations, organizations, and activities for all professional and technical matters and such administrative matters as may be prescribed by regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaadc21a6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"r