{"tag":"section","attrib":{"id":"idaa863a77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4659"},"text":null,"children":[{"tag":"num","attrib":{"value":"4659"},"text":"§ 4659.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on contracting with entities that comply with the secondary Arab boycott of Israel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa863a78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4659/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under section 3(5)(A) ","children":[{"tag":"ref","attrib":{"idref":"fn002121"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002121"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Export Administration Act of 1979 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4602/5/A"},"text":"50 U.S.C. 4602(5)(A)","children":[],"tail":"), it is the policy of the United States to oppose restrictive trade practices or boycotts fostered or imposed by foreign countries against other countries friendly to the United States or against any other United States person."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa863a79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4659/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa863a7a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4659/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consistent with the policy referred to in subsection (a), the Department of Defense may not award a contract for an amount in excess of the simplified acquisition threshold (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s134"},"text":"section 134 of title 41","children":[],"tail":") to a foreign entity unless that entity certifies to the Secretary of Defense that it does not comply with the secondary Arab boycott of Israel."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa863a7b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4659/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In paragraph (1), the term “foreign entity” means a foreign person, a foreign company, or any other foreign entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa863a7c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4659/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may waive the prohibition in subsection (b) in specific instances when the Secretary determines that the waiver is necessary in the national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa863a7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4659/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (b) does not apply—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa863a7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4659/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to contracts for consumable supplies, provisions, or services that are intended to be used for the support of United States forces or of allied forces in a foreign country; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa863a7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4659/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to contracts pertaining to the use of any equipment, technology, data, or services for intelligence or classified purposes by the United States Government in the interests of national security or to the acquisition or lease of any such equipment, technology, data, or services by the United States Government in the interests of national security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa863a80-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tXIII/s1332/a"},"text":"Pub. L. 102–484, div. A, title XIII, § 1332(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2555"},"text":"106 Stat. 2555","children":[],"tail":", § 2410i; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":", §§ 4, 5(b)(31), "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3841"},"text":"124 Stat. 3841","children":[],"tail":", 3845; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tX/s1081/b/3/D"},"text":"Pub. L. 114–328, div. A, title X, § 1081(b)(3)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2419"},"text":"130 Stat. 2419","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1051/a/16"},"text":"Pub. L. 115–91, div. A, title X, § 1051(a)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1561"},"text":"131 Stat. 1561","children":[],"tail":"; renumbered § 4659, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1862/b"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1862(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4277"},"text":"134 Stat. 4277","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa863a81-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa863a82-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaa863a83-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3(5)(A) of the Export Administration Act of 1979 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4602/5/A"},"text":"50 U.S.C. 4602(5)(A)","children":[],"tail":"), referred to in subsec. (a), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1766/a"},"text":"Pub. L. 115–232, div. A, title XVII, § 1766(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2232"},"text":"132 Stat. 2232","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa863a84-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2410i"},"text":"section 2410i of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" struck out at end “Within 15 days after the end of each fiscal year, the Secretary shall submit to Congress a report identifying each contract for which a waiver was granted under this subsection during that fiscal year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4602/5/A"},"text":"50 U.S.C. 4602(5)(A)","children":[],"tail":")” for “(50 U.S.C. App. 2402(5)(A))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":" substituted “simplified acquisition threshold (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s134"},"text":"section 134 of title 41","children":[],"tail":")” for “small purchase threshold (as defined in section 4(11) of the Office of Federal Procurement Policy Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s403/11"},"text":"41 U.S.C. 403(11)","children":[],"tail":"))”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa863a85-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa863a86-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
