{"tag":"section","attrib":{"id":"idaacb591f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6277"},"text":null,"children":[{"tag":"num","attrib":{"value":"6277"},"text":"§ 6277.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conceptual and construction design","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaacb5920-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6277/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conceptual Design","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacb5921-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6277/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2) and except as provided in paragraph (3), before submitting to Congress a request for funds for a construction project that is in support of a national security program of the Department of Energy, the Secretary of Energy shall complete a conceptual design for that project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacb5922-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6277/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the estimated cost of completing a conceptual design for a construction project exceeds $5,000,000, the Secretary shall submit to Congress a request for funds for the conceptual design before submitting a request for funds for the construction project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacb5923-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6277/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The requirement in paragraph (1) does not apply to a request for funds—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacb5924-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6277/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a construction project the total estimated cost of which is less than the minor construction threshold; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacb5925-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6277/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for emergency planning, design, and construction activities under section 6278.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacb5926-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6277/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction Design","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacb5927-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6277/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within the amounts authorized by a DOE national security authorization, the Secretary may carry out construction design (including architectural and engineering services) in connection with any proposed construction project if the total estimated cost for such design does not exceed $5,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacb5928-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6277/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the total estimated cost for construction design in connection with any construction project exceeds $5,000,000, funds for that design must be specifically authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaacb5929-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1428"},"text":"139 Stat. 1428","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaacb592a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaacb592b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaacb592c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2746"},"text":"section 2746 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaacb592d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) to (3) headings which read as follows: “"},{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":"”, “"},{"tag":"inline","attrib":{},"text":"Requests for conceptual design funds","children":[],"tail":"”, and “"},{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":"”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) and (2) headings which read as follows: “"},{"tag":"inline","attrib":{},"text":"Authority”","children":[],"tail":" and “"},{"tag":"inline","attrib":{},"text":"Limitation on availability of funds for certain projects","children":[],"tail":"”, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
