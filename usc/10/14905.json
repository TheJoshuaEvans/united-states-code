{"tag":"section","attrib":{"id":"idabb9d818-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14905"},"text":null,"children":[{"tag":"num","attrib":{"value":"14905"},"text":"§ 14905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officer considered for removal: retirement or discharge","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabb9d819-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voluntary Retirement or Discharge","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At any time during proceedings under this chapter with respect to the removal of an officer from an active status, the Secretary of the military department concerned may grant a request by the officer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb9d81a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14905/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for voluntary retirement, if the officer is qualified for retirement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb9d81b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14905/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for transfer to the Retired Reserve if the officer has completed the years of service required for eligibility for retired pay under chapter 1223 of this title and is otherwise eligible for transfer to the Retired Reserve; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb9d81c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14905/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for discharge in accordance with subsection (b)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb9d81d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Retirement or Discharge","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An officer removed from an active status under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14903"},"text":"section 14903 of this title","children":[],"tail":" shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb9d81e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14905/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if eligible for voluntary retirement under any provision of law on the date of such removal, be retired in the grade and with the retired pay for which he would be eligible if retired under that provision;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb9d81f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14905/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if eligible for transfer to the Retired Reserve and has completed the years of service required for retired pay under chapter 1223 of this title, be transferred to the Retired Reserve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb9d820-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14905/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if ineligible for retirement or transfer to the Retired Reserve under paragraph (1) or (2) on the date of such removal—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabb9d821-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14905/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be honorably discharged in the grade then held, in the case of an officer whose case was brought under subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14902"},"text":"section 14902 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabb9d822-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14905/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be discharged in the grade then held, in the case of an officer whose case was brought under subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14902"},"text":"section 14902 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb9d823-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Separation Pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who is discharged under subsection (b)(3) is entitled, if eligible therefor, to separation pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1174/c"},"text":"section 1174(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabb9d824-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2959"},"text":"108 Stat. 2959","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb9d825-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabb9d826-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabb9d827-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691/b/1"},"text":"section 1691(b)(1) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
