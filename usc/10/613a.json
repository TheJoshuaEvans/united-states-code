{"tag":"section","attrib":{"id":"ida7e8364f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s613a"},"text":null,"children":[{"tag":"num","attrib":{"value":"613a"},"text":"§ 613a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondisclosure of board proceedings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7e83650-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s613a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Disclosure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The proceedings of a selection board convened under section 573, 611, 628, or 20211 of this title may not be disclosed to any person not a member of the board, except as authorized or required to process the report of the board. This prohibition is a statutory exemption from disclosure, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/3"},"text":"section 552(b)(3) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e83651-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s613a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibited Uses of Board Discussions, Deliberations, Notes, and Records","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The discussions and deliberations of a selection board described in subsection (a) and any written or documentary record of such discussions and deliberations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7e83652-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s613a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are immune from legal process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7e83653-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s613a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be admitted as evidence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7e83654-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s613a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be used for any purpose in any action, suit, or judicial or administrative proceeding without the consent of the Secretary of the military department concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e83655-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s613a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section applies to all selection boards convened under section 573, 611, 628, or 20211 of this title, regardless of the date on which the board was convened.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7e83656-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s547/a/1"},"text":"Pub. L. 109–364, div. A, title V, § 547(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2215"},"text":"120 Stat. 2215","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tV/s503/a"},"text":"Pub. L. 111–383, div. A, title V, § 503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4207"},"text":"124 Stat. 4207","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1722/b/1"},"text":"Pub. L. 118–31, div. A, title XVII, § 1722(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/668"},"text":"137 Stat. 668","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7e83657-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7e83658-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7e83659-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsecs. (a), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" substituted “573, 611, 628, or 20211” for “573, 611, or 628”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s503/a/1"},"text":"Pub. L. 111–383, § 503(a)(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a). Prior to amendment, text read as follows: “The proceedings of a selection board convened under section 611 this title may not be disclosed to any person not a member of the board.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s503/a/2"},"text":"Pub. L. 111–383, § 503(a)(2)","children":[],"tail":", substituted “Notes, and Records” for “and Records” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s503/a/3"},"text":"Pub. L. 111–383, § 503(a)(3)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7e8365a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida7e8365b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s547/c"},"text":"Pub. L. 109–364, div. A, title V, § 547(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2216"},"text":"120 Stat. 2216","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/364/dA/tV/s547/c"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s613a"},"text":"Section 613a of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to the proceedings of all selection boards convened under section 611 of that title, including selection boards convened before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":"]. Section 14104 of such title, as amended by subsection (b), shall apply with respect to the proceedings of all selection boards convened under section 14101 of that title, including selection boards convened before the date of the enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
