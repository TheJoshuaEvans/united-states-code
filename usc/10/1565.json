{"tag":"section","attrib":{"id":"ida8f33ddf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565"},"text":null,"children":[{"tag":"num","attrib":{"value":"1565"},"text":"§ 1565.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DNA identification information: collection from certain offenders; use","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8f33de0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Collection of DNA Samples","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8f33de1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned shall collect a DNA sample from each member of the armed forces under the Secretary’s jurisdiction who is, or has been, convicted of a qualifying military offense (as determined under subsection (d)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f33de2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each member described in paragraph (1), if the Combined DNA Index System (in this section referred to as “CODIS”) of the Federal Bureau of Investigation contains a DNA analysis with respect to that member, or if a DNA sample has been or is to be collected from that member under section 3(a) of the DNA Analysis Backlog Elimination Act of 2000, the Secretary concerned may (but need not) collect a DNA sample from that member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f33de3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may enter into agreements with other Federal agencies, units of State or local government, or private entities to provide for the collection of samples described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f33de4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Analysis and Use of Samples","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned shall furnish each DNA sample collected under subsection (a) to the Secretary of Defense. The Secretary of Defense shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8f33de5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out a DNA analysis on each such DNA sample in a manner that complies with the requirements for inclusion of that analysis in CODIS; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f33de6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnish the results of each such analysis to the Director of the Federal Bureau of Investigation for inclusion in CODIS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f33de7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8f33de8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “DNA sample” means a tissue, fluid, or other bodily sample of an individual on which a DNA analysis can be carried out.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f33de9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “DNA analysis” means analysis of the deoxyribonucleic acid (DNA) identification information in a bodily sample.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f33dea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifying Military Offenses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The offenses that shall be treated for purposes of this section as qualifying military offenses are the following offenses, as determined by the Secretary of Defense, in consultation with the Attorney General:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8f33deb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any offense under the Uniform Code of Military Justice for which a sentence of confinement for more than one year may be imposed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f33dec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other offense under the Uniform Code of Military Justice that is comparable to a qualifying Federal offense (as determined under section 3(d) of the DNA Analysis Backlog Elimination Act of 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14135a/d"},"text":"42 U.S.C. 14135a(d)","children":[],"tail":"))."},{"tag":"ref","attrib":{"idref":"fn002068"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002068"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f33ded-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expungement","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8f33dee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall promptly expunge, from the index described in subsection (a) of section 210304 of the Violent Crime Control and Law Enforcement Act of 1994, the DNA analysis of a person included in the index on the basis of a qualifying military offense if the Secretary receives, for each conviction of the person of a qualifying offense, a certified copy of a final court order establishing that such conviction has been overturned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f33def-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of paragraph (1), the term “qualifying offense” means any of the following offenses:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8f33df0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A qualifying Federal offense, as determined under section 3 of the DNA Analysis Backlog Elimination Act of 2000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8f33df1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A qualifying District of Columbia offense, as determined under section 4 of the DNA Analysis Backlog Elimination Act of 2000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8f33df2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A qualifying military offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f33df3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of paragraph (1), a court order is not “final” if time remains for an appeal or application for discretionary review with respect to the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f33df4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall be carried out under regulations prescribed by the Secretary of Defense, in consultation with the Secretary of Homeland Security and the Attorney General. Those regulations shall apply, to the extent practicable, uniformly throughout the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8f33df5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/546/s5/a/1"},"text":"Pub. L. 106–546, § 5(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-19"},"text":"Dec. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2731"},"text":"114 Stat. 2731","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/b/1"},"text":"Pub. L. 107–296, title XVII, § 1704(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/405/tII/s203/c"},"text":"Pub. L. 108–405, title II, § 203(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2270"},"text":"118 Stat. 2270","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8f33df6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8f33df7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida8f33df8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3 of the DNA Analysis Backlog Elimination Act of 2000, referred to in subsecs. (a)(2), (d)(2), and (e)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/546/s3"},"text":"section 3 of Pub. L. 106–546","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s14135a"},"text":"section 14135a of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification as "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s40702"},"text":"section 40702 of Title 34","children":[],"tail":", Crime Control and Law Enforcement."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4 of the DNA Analysis Backlog Elimination Act of 2000, referred to in subsec. (e)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/546/s4"},"text":"section 4 of Pub. L. 106–546","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s40703"},"text":"section 40703 of Title 34","children":[],"tail":", Crime Control and Law Enforcement."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Uniform Code of Military Justice, referred to in subsec. (d), is classified to chapter 47 (§ 801 et seq.) of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 210304 of the Violent Crime Control and Law Enforcement Act of 1994, referred to in subsec. (e)(1), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12592"},"text":"section 12592 of Title 34","children":[],"tail":", Crime Control and Law Enforcement."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8f33df9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/405"},"text":"Pub. L. 108–405","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Subject to paragraph (2), the Secretary of Defense, in consultation with the Attorney General, shall determine those felony or sexual offenses under the Uniform Code of Military Justice that shall be treated for purposes of this section as qualifying military offenses.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) An offense under the Uniform Code of Military Justice that is comparable to a qualifying Federal offense (as determined under section 3(d) of the DNA Analysis Backlog Elimination Act of 2000), as determined by the Secretary in consultation with the Attorney General, shall be treated for purposes of this section as a qualifying military offense.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8f33dfa-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8f33dfb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8f33dfc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Initial Determination of Qualifying Military Offenses","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/546/s5/b"},"text":"Pub. L. 106–546, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-19"},"text":"Dec. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2733"},"text":"114 Stat. 2733","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/546/s5/b"},"text":"“The initial determination of qualifying military offenses under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1565/d"},"text":"section 1565(d) of title 10","children":[],"tail":", United States Code, as added by subsection (a)(1), shall be made not later than 120 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2000-12-19"},"text":"Dec. 19, 2000","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8f33dfd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Commencement of Collection","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/546/s5/c"},"text":"Pub. L. 106–546, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-19"},"text":"Dec. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2733"},"text":"114 Stat. 2733","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/546/s5/c"},"text":"“Collection of DNA samples under section 1565(a) of such title, as added by subsection (a)(1), shall, subject to the availability of appropriations, commence not later than the date that is 60 days after the date of the initial determination referred to in subsection (b) [set out above].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
