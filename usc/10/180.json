{"tag":"section","attrib":{"id":"ida77cc9c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s180"},"text":null,"children":[{"tag":"num","attrib":{"value":"180"},"text":"§ 180.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service academy athletic programs: review board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida77cc9c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s180/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Independent Review Board","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall appoint a board to review the administration of the athletics programs of the United States Military Academy, the United States Naval Academy, and the United States Air Force Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida77cc9c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s180/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition of Board","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall appoint the members of the board from among distinguished administrators of institutions of higher education, members of Congress, members of the Boards of Visitors of the academies, and other experts in collegiate athletics programs. The Superintendents of the three academies shall be members of the board. The Secretary shall designate one member of the board, other than a Superintendent of an academy, as Chairman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida77cc9ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s180/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The board shall, on an annual basis—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida77cc9cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s180/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" review all aspects of the athletics programs of the United States Military Academy, the United States Naval Academy, and the United States Air Force Academy, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida77cc9cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s180/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the policies relating to the administration of such programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida77cc9cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s180/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriateness of the balance between the emphasis placed by each academy on athletics and the emphasis placed by such academy on academic pursuits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida77cc9ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s180/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which all athletes in all sports are treated equitably under the athletics program of each academy; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida77cc9cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s180/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine ways in which the administration of the athletics programs at the academies can serve as models for the administration of athletics programs at civilian institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida77cc9d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s180/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida77cc9d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s180/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member of the board who is not an officer or employee of the Federal Government shall be compensated at a rate equal to the daily equivalent of the annual rate of basic pay prescribed for Executive Schedule Level IV under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":", for each day (including travel time) during which such member is engaged in the performance of the duties of the board. Members of the board who are officers or employees of the United States shall serve without compensation in addition to that received for their services as officers or employees of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida77cc9d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s180/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The members of the board shall be allowed travel expenses, including per diem in lieu of subsistence, at rates authorized for employees of agencies under subchapter I of chapter 57 of title 5, while away from their homes or regular places of business in the performance of services for the board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida77cc9d3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tV/s513/a"},"text":"Pub. L. 102–190, div. A, title V, § 513(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1360"},"text":"105 Stat. 1360","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1066/a/2"},"text":"Pub. L. 106–65, div. A, title X, § 1066(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/770"},"text":"113 Stat. 770","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1087(a)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–290.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida77cc9d4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida77cc9d5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida77cc9d6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" substituted “section 5315” for “section 5376”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “Executive Schedule Level IV under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of title 5","children":[],"tail":"” for “grade GS–18 of the General Schedule under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
