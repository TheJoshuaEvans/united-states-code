{"tag":"section","attrib":{"id":"ida7c210f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s481a"},"text":null,"children":[{"tag":"num","attrib":{"value":"481a"},"text":"§ 481a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workplace and gender relations issues: surveys of Department of Defense civilian employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7c210f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s481a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7c210f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s481a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall carry out every other fiscal year a survey of civilian employees of the Department of Defense to solicit information on gender issues, including issues relating to gender-based assault (including unwanted sexual contact), harassment, and discrimination, and the climate in the Department for forming professional relationships between male and female civilian employees of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c210fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s481a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each survey under this section shall be known as a “Department of Defense Civilian Employee Workplace and Gender Relations Survey”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7c210fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s481a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each survey conducted under this section shall be conducted so as to solicit information on the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7c210fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s481a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indicators of positive and negative trends for professional and personal relationships between male and female civilian employees of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c210fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s481a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The specific types of assault (including unwanted sexual contact) on civilian employees of the Department by other personnel of the Department (including contractor personnel) that have occurred, and the number of times each respondent has been so assaulted during the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c210fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s481a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The effectiveness of Department policies designed to improve professional relationships between male and female civilian employees of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c210ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s481a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The effectiveness of current processes for complaints on and investigations into gender-based assault (including unwanted sexual contact), harassment, and discrimination involving civilian employees of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c21100-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s481a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other issues relating to assault (including unwanted sexual contact), harassment, or discrimination involving civilian employees of the Department that the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7c21101-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s481a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon the completion of a survey under this section, the Secretary shall submit to Congress a report containing the results of the survey.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7c21102-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s481a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Postponement","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7c21103-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s481a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may postpone the conduct of a survey under this section if the Secretary determines that conducting such survey is not practicable due to a war or national emergency declared by the President or Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c21104-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s481a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that a survey postponed under paragraph (1) is conducted as soon as practicable after the end of the period of war or national emergency concerned, or earlier if the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c21105-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s481a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall notify Congress of a determination under paragraph (1) not later than 30 days after the date on which the Secretary makes such determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7c21106-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1073/a/1"},"text":"Pub. L. 113–291, div. A, title X, § 1073(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3517"},"text":"128 Stat. 3517","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tV/s591/b"},"text":"Pub. L. 116–92, div. A, title V, § 591(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1414"},"text":"133 Stat. 1414","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tV/s552/c"},"text":"Pub. L. 116–283, div. A, title V, § 552(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3632"},"text":"134 Stat. 3632","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7c21107-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7c21108-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7c21109-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" inserted “(including unwanted sexual contact)” after “assault” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7c2110a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7c2110b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", and applicable with respect to surveys under this section that are initiated after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/s591/c"},"text":"section 591(c) of Pub. L. 116–92","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s481"},"text":"section 481 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7c2110c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2021-12-31"},"text":"Dec. 31, 2021","children":[],"tail":", of provisions in subsec. (c) of this section requiring submittal of report to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1061"},"text":"section 1061 of Pub. L. 114–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s111"},"text":"section 111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7c2110d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Initial Survey","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1073/a/3"},"text":"Pub. L. 113–291, div. A, title X, § 1073(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3518"},"text":"128 Stat. 3518","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/291/dA/tX/s1073/a/3"},"text":"“The Secretary of Defense shall carry out the first survey required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s481a"},"text":"section 481a of title 10","children":[],"tail":", United States Code (as added by this subsection), during fiscal year 2016.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
