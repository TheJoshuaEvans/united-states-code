{"tag":"section","attrib":{"id":"idab34545d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8605"},"text":null,"children":[{"tag":"num","attrib":{"value":"8605"},"text":"§ 8605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion of health and prevention of accidents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab34545e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Navy may make such expenditures as he considers appropriate to prevent accidents and to promote the safety and occupational health of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab34545f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8605/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the naval service on active duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab345460-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8605/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" civilian officers and employees of the Department of the Navy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab345461-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8605/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the Coast Guard when it is operating as a service in the Navy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab345462-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8605/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the National Oceanic and Atmospheric Administration serving with the Navy.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The expenditures may include payments for clothing, equipment, and other materials necessary for the purposes of this section. Any appropriation available for the activities in which the personnel are engaged shall be available for these purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab345463-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, to the extent he considers proper, may delegate the authority conferred by this section to any person in the Department of the Navy, with or without the authority to make successive redelegations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab345464-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/443"},"text":"70A Stat. 443","children":[],"tail":", § 7205; "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s8/a"},"text":"Pub. L. 89–718, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1117"},"text":"80 Stat. 1117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s513/24"},"text":"Pub. L. 96–513, title V, § 513(24)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2932"},"text":"94 Stat. 2932","children":[],"tail":"; r