{"tag":"section","attrib":{"id":"idaabab78c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6105"},"text":null,"children":[{"tag":"num","attrib":{"value":"6105"},"text":"§ 6105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Common financial reporting system for the nuclear security enterprise","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaabab78d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"By not later than four years after the date of the enactment of the National Defense Authorization Act for Fiscal Year 2017 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Public Law 114–328","children":[],"tail":"), the Administrator shall, in consultation with the National Nuclear Security Administration Council established by section 6103, complete, to the extent practicable, the implementation of a common financial reporting system for the nuclear security enterprise."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabab78e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The common financial reporting system implemented pursuant to subsection (a) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabab78f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Common data reporting requirements for work performed using funds of the Administration, including reporting of financial data by standardized labor categories, labor hours, functional elements, and cost elements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab790-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A common work breakdown structure for the Administration that aligns contractor work breakdown structures with the budget structure of the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab791-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6105/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Definitions and methodologies for identifying and reporting costs for programs of records and base capabilities within the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab792-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6105/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A capability to leverage, where appropriate, the Defense Cost Analysis Resource Center of the Office of Cost Assessment and Program Evaluation of the Department of Defense using historical costing data by the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabab793-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabab794-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6105/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"2017-03-01"},"text":"March 1, 2017","children":[],"tail":", and annually thereafter, the Administrator shall, in consultation with the National Nuclear Security Administration Council, submit to the congressional defense committees a report on progress of the Administration toward implementing a common financial reporting system for the nuclear security enterprise as required by subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab795-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6105/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each report under this subsection shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaabab796-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6105/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary of activities, accomplishments, challenges, benefits, and costs related to the implementation of a common financial reporting system for the nuclear security enterprise during the year preceding the year in which such report is submitted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabab797-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6105/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary of planned activities in connection with the implementation of a common financial reporting system for the nuclear security enterprise in the year in which such report is submitted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabab798-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6105/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of any anticipated modifications to the schedule for implementing a common financial reporting system for the nuclear security enterprise, including an update on possible risks, challenges, and costs related to such implementation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab799-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6105/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No report is required under this subsection after the completion of the implementation of a common financial reporting system for the nuclear security enterprise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaabab79a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1342"},"text":"139 Stat. 1342","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaabab79b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaabab79c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaabab79d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the National Defense Authorization Act for Fiscal Year 2017, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaabab79e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3113"},"text":"section 3113 of Pub. L. 114–328","children":[],"tail":", which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2512"},"text":"section 2512 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/9"},"text":"Pub. L. 119–60, § 3111(b)(9)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaabab79f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) to (3) headings which read as follows: “"},{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":"”, “"},{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":"”, and “"},{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":"”, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
