{"tag":"section","attrib":{"id":"ida8073051-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s774"},"text":null,"children":[{"tag":"num","attrib":{"value":"774"},"text":"§ 774.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Religious apparel: wearing while in uniform","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8073052-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s774/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided under subsection (b), a member of the armed forces may wear an item of religious apparel while wearing the uniform of the member’s armed force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8073053-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s774/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may prohibit the wearing of an item of religious apparel—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8073054-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s774/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in circumstances with respect to which the Secretary determines that the wearing of the item would interfere with the performance of the member’s military duties; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8073055-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s774/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary determines, under regulations under subsection (c), that the item of apparel is not neat and conservative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8073056-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s774/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall prescribe regulations concerning the wearing of religious apparel by members of the armed forces under the Secretary’s jurisdiction while the members are wearing the uniform. Such regulations shall be consistent with subsections (a) and (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8073057-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s774/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Religious Apparel Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “religious apparel” means apparel the wearing of which is part of the observance of the religious faith practiced by the member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8073058-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tV/s508/a/2"},"text":"Pub. L. 100–180, div. A, title V, § 508(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1086"},"text":"101 Stat. 1086","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8073059-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida807305a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida807305b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 774 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s776"},"text":"section 776 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida807305c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida807305d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tV/s508/c"},"text":"Pub. L. 100–180, div. A, title V, § 508(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1087"},"text":"101 Stat. 1087","children":[],"tail":", directed the Secretary concerned to prescribe the regulations required by subsec. (c) of this section not later than the end of the 120-day period beginning on "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
