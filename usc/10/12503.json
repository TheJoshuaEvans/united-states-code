{"tag":"section","attrib":{"id":"idaba45350-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12503"},"text":null,"children":[{"tag":"num","attrib":{"value":"12503"},"text":"§ 12503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ready Reserve: funeral honors duty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaba45351-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Order to Duty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the Ready Reserve may be ordered to funeral honors duty, with the consent of the member, in preparation for or to perform funeral honors functions at the funeral of a veteran as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1491"},"text":"section 1491 of this title","children":[],"tail":". Performance of funeral honors duty by a Reserve not on active duty shall be treated as inactive-duty training (including with respect to travel to and from such duty) for purposes of any provision of law other than sections 206 and 435 of title 37."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba45352-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service Credit","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member ordered to funeral honors duty under this section shall be required to perform a minimum of two hours of such duty in order to receive—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba45353-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" service credit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12732/a/2/E"},"text":"section 12732(a)(2)(E) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba45354-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as directed by the Secretary concerned, either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaba45355-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12503/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the allowance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s435"},"text":"section 435 of title 37","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaba45356-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12503/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of title 37","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba45357-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursable Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member who performs funeral honors duty under this section may be reimbursed for travel and transportation expenses incurred in conjunction with such duty as authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s452"},"text":"section 452 of title 37","children":[],"tail":" if such duty is performed at a location 50 miles or more from the member’s residence."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba45358-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12503/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The exercise of authority under subsection (a) is subject to regulations prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba45359-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12503/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members of the National Guard","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not apply to members of the Army National Guard of the United States or the Air National Guard of the United States. The performance of funeral honors duty by those members is provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s115"},"text":"section 115 of title 32","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaba4535a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s578/g/3"},"text":"Pub. L. 106–65, div. A, title V, § 578(g)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/628"},"text":"113 Stat. 628","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 575(a)(2)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–138; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s562/a"},"text":"Pub. L. 107–107, div. A, title V, § 562(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1119"},"text":"115 Stat. 1119","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s631/f/4/A"},"text":"Pub. L. 112–81, div. A, title VI, § 631(f)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1465"},"text":"125 Stat. 1465","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/a/9"},"text":"Pub. L. 112–239, div. A, title X, § 1076(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1948"},"text":"126 Stat. 1948","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVI/s626/c/9"},"text":"Pub. L. 117–263, div. A, title VI, § 626(c)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2628"},"text":"136 Stat. 2628","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaba4535b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","a