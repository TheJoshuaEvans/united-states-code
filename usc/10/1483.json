{"tag":"section","attrib":{"id":"ida8db6f6d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1483"},"text":null,"children":[{"tag":"num","attrib":{"value":"1483"},"text":"§ 1483.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prisoners of war and interned enemy aliens","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may provide for the care and disposition of the remains of prisoners of war and interned enemy aliens who die while in his custody and, incident thereto, pay the necessary expenses of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8db6f6e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1483/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notification to the next of kin or other appropriate person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8db6f6f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1483/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparation of the remains for burial, including cremation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8db6f70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1483/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnishing of clothing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8db6f71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1483/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnishing of a casket or urn, or both, with outside box;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8db6f72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1483/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation of the remains to the cemetery or other place selected by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8db6f73-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1483/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interment of the remains.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8db6f74-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/113"},"text":"70A Stat. 113","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8db6f75-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8db6f76-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida8db6f77-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1483","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5:2155 (as applicable to armed forces).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1954-07-15/ch507/s5"},"text":"July 15, 1954, ch. 507, § 5","children":[],"tail":" (as applicable to armed forces), "},{"tag":"html:a","attrib":{"href":"/us/stat/68/479"},"text":"68 Stat. 479","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The list of payable expenses has been rearranged to produce a generally chronological result. The words “incurred for”, and the words “articles of” in clause (3), are omitted as surplusage. In clause (5), the words “cemetery or other place” are substituted for the words “town, city, or cemetery”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
