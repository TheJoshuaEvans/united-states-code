{"tag":"section","attrib":{"id":"ida8916e2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1097b"},"text":"§ 1097b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" TRICARE program: financial management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8916e2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement of Providers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8916e2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), the Secretary of Defense may reimburse health care providers under the TRICARE program at rates higher than the reimbursement rates otherwise authorized for the providers under that program if the Secretary determines that application of the higher rates is necessary in order to ensure the availability of an adequate number of qualified health care providers under that program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8916e2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount of reimbursement provided under paragraph (1) with respect to a health care service may not exceed the lesser of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8916e30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount equal to the local fee for service charge for the service in the service area in which the service is provided as determined by the Secretary based on one or more of the following payment rates:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8916e31-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097b/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Usual, customary, and reasonable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8916e32-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097b/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Health Care Finance Administration’s Resource Based Relative Value Scale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8916e33-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097b/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Negotiated fee schedules.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8916e34-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097b/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Global fees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8916e35-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097b/a/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sliding scale individual fee allowances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8916e36-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount equal to 115 percent of the CHAMPUS maximum allowable charge for the service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8916e37-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In establishing rates and procedures for reimbursement of providers and other administrative requirements, including those contained in provider network agreements, the Secretary shall, to the extent practicable, maintain adequate networks of providers, including institutional, professional, and pharmacy. For the purpose of determining whether network providers under such provider network agreements are subcontractors for purposes of the Federal Acquisition Regulation or any other law, a TRICARE managed care support contract that includes the requirement to establish, manage, or maintain a network of providers may not be considered to be a contract for the performance of health care services or supplies on the basis of such requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8916e38-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Third-Party Collections","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8916e39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A medical treatment facility of the uniformed services under the TRICARE program has the same right as the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1095"},"text":"section 1095 of this title","children":[],"tail":" to collect from a third-party payer the reasonable charges for health care services described in paragraph (2) that are incurred by the facility on behalf of a covered beneficiary under that program."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8916e3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense shall prescribe regulations for the administration of this subsection. The regulations shall set forth the method to be used for the computation of the reasonable charges for inpatient, outpatient, and other health care services. The method of computation may be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8916e3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a method that is based on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8916e3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097b/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" per diem rates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8916e3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097b/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all-inclusive rates for each visit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8916e3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097b/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diagnosis-related groups; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8916e3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097b/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rates prescribed under the regulations implementing sections 1079 and 1086 of this title; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8916e40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other method considered appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8916e41-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall carry out the responsibilities under this section after consultation with the other administering Secretaries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8916e42-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVII/s716/a/1"},"text":"Pub. L. 106–65, div. A, title VII, § 716(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/690"},"text":"113 Stat. 690","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVII/s715"},"text":"Pub. L. 112–81, div. A, title VII, § 715","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1477"},"text":"125 Stat. 1477","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8916e43-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8916e44-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8916e45-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8916e46-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8916e47-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVII/s716/d"},"text":"Pub. L. 106–65, div. A, title VII, § 716(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/692"},"text":"113 Stat. 692","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/65/dA/tVII/s716/d"},"text":"“The amendments made by subsection (a) [enacting this section] shall take effect one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8916e48-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVII/s716/b"},"text":"Pub. L. 106–65, div. A, title VII, § 716(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/691"},"text":"113 Stat. 691","children":[],"tail":", directed the Secretary of Defense to submit to Congress a report assessing the effects of the implementation of the requirements and authorities set forth in this section not later than 6 months after "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
