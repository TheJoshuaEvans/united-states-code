{"tag":"section","attrib":{"id":"ida984a8f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2492a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2492a"},"text":"§ 2492a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on Department of Defense entities competing with private sector in offering personal information services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida984a8f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2492a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida984a8f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2492a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2492"},"text":"section 2492 of this title","children":[],"tail":", the Secretary of Defense may not authorize a Department of Defense entity to offer or provide personal information services directly to users using Department resources, personnel, or equipment, or compete for contracts to provide such personal information services directly to users, if users will be charged a fee for the personal information services to recover the cost incurred to provide the services or to earn a profit."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida984a8f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2492a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The limitation in paragraph (1) shall not be construed to prohibit or preclude the use of Department resources, personnel, or equipment to administer or facilitate personal information services contracts with private contractors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida984a8f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2492a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The limitation in subsection (a) shall not apply if the Secretary of Defense determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida984a8f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2492a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private sector vendor is not available to provide the personal information services at specific locations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida984a8f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2492a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interests of the user population would be best served by allowing the Government to provide such services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida984a8f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2492a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" circumstances (as specified by the Secretary for purposes of this section) are such that the provision of such services by a Department entity is in the best interest of the Government or military users in general.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida984a8f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2492a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personal Information Services Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “personal information services” means the provision of Internet, telephone, or television services to consumers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida984a8fa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tVI/s651/a"},"text":"Pub. L. 111–84, div. A, title VI, § 651(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2368"},"text":"123 Stat. 2368","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida984a8fb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida984a8fc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"ida984a8fd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tVI/s651/c"},"text":"Pub. L. 111–84, div. A, title VI, § 651(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2369"},"text":"123 Stat. 2369","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/84/dA/tVI/s651/c"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2492a"},"text":"Section 2492a of title 10","children":[],"tail":", United States Code, as added by subsection (a), does not affect the validity or terms of any contract for the provision of personal information services entered into before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
