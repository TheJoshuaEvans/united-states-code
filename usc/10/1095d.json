{"tag":"section","attrib":{"id":"ida88f24a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1095d"},"text":"§ 1095d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" TRICARE program: waiver of certain deductibles","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida88f24a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may waive the deductible payable for medical care provided under the TRICARE program to an eligible dependent of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida88f24a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of a reserve component on active duty pursuant to a call or order to active duty for a period of more than 30 days; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida88f24aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the National Guard on full-time National Guard duty pursuant to a call or order to full-time National Guard duty for a period of more than 30 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida88f24ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Dependent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As used in this section, the term “eligible dependent” means a dependent described in subparagraph (A), (D), or (I) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072/2"},"text":"section 1072(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida88f24ac-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVII/s714/a"},"text":"Pub. L. 106–65, div. A, title VII, § 714(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/689"},"text":"113 Stat. 689","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1087(a)(7)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–290; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVII/s704"},"text":"Pub. L. 108–375, div. A, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1983"},"text":"118 Stat. 1983","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida88f24ad-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida88f24ae-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida88f24af-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" substituted “more than 30 days” for “less than one year” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" substituted “subparagraph” for “subparagraphs”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
