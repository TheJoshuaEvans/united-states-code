{"tag":"section","attrib":{"id":"ida7a7d21b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s381"},"text":null,"children":[{"tag":"num","attrib":{"value":"381"},"text":"§ 381.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidated budget","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7a7d21c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s381/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consolidated Budget","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The budget of the President for each fiscal year, as submitted to Congress by the President pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", shall set forth by budget function and as a separate item the amounts requested for the Department of Defense for such fiscal year for all security cooperation programs and activities of the Department of Defense, including the military departments, to be conducted in such fiscal year, including the specific country or region and the applicable authority, to the extent practicable."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a7d21d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s381/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Semiannual Report on Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit to the appropriate committees of Congress a report on the obligation and expenditure of funds for security cooperation programs and activities of the Department of Defense—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a7d21e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s381/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by not later than August 31 of each year, for the first six-month period of that year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a7d21f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s381/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by not later than February 28 of each year, for the second six-month period of the preceding year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7a7d220-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1249/a"},"text":"Pub. L. 114–328, div. A, title XII, § 1249(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2526"},"text":"130 Stat. 2526","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXII/s1204"},"text":"Pub. L. 116–92, div. A, title XII, § 1204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1622"},"text":"133 Stat. 1622","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tX/s1061/a"},"text":"Pub. L. 118–31, div. A, title X, § 1061(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/398"},"text":"137 Stat. 398","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVII/s1701/a/6"},"text":"Pub. L. 118–159, div. A, title XVII, § 1701(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2203"},"text":"138 Stat. 2203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7a7d221-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7a7d222-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida7a7d223-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 381 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s281"},"text":"section 281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7a7d224-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “Defense—” for “Defense—.” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":", in heading, substituted “Semiannual Report” for “Quarterly Report”, and, in text, substituted “The” for “Not later than 60 days after the end of each calendar quarter, the” and “Defense—” for “Defense during such calendar quarter” and added pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “60 days” for “30 days”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7a7d225-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida7a7d226-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date; Applicability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1249/b"},"text":"Pub. L. 114–328, div. A, title XII, § 1249(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2526"},"text":"130 Stat. 2526","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/328/dA/tXII/s1249/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendment made by subsection (a) [enacting this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":"], and shall apply as follows:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s381"},"text":"section 381 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall apply to budgets submitted to Congress by the President pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", United States Code, for each fiscal year after fiscal year 2018."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (b) of such section 381, as so added, shall apply to calendar quarters beginning on or after the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
