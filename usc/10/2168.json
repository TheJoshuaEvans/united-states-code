{"tag":"section","attrib":{"id":"ida93612a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2168"},"text":null,"children":[{"tag":"num","attrib":{"value":"2168"},"text":"§ 2168.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defense Language Institute Foreign Language Center: degree of Associate or Bachelor of Arts in foreign language","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida93612a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2168/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to subsection (b), the Commandant of the Defense Language Institute may confer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93612a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2168/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Associate of Arts degree in a foreign language upon any graduate of the Foreign Language Center of the Institute who fulfills the requirements for that degree; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93612a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2168/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Bachelor of Arts degree in a foreign language upon any graduate of the Foreign Language Center of the Institute who fulfills the requirements for that degree.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93612a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2168/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A degree may be conferred upon a student under this section only if the Provost of the Center certifies to the Commandant that the student has satisfied all the requirements prescribed for the degree.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93612a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2168/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority provided by subsection (a) shall be exercised under regulations prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida93612a6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s531/a"},"text":"Pub. L. 107–107, div. A, title V, § 531(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1104"},"text":"115 Stat. 1104","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tV/s556/a"},"text":"Pub. L. 117–81, div. A, title V, § 556(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1739"},"text":"135 Stat. 1739","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida93612a7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida93612a8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida93612a9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s556/a/1"},"text":"Pub. L. 117–81, § 556(a)(1)","children":[],"tail":", substituted “Associate or Bachelor” for “Associate” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s556/a/2"},"text":"Pub. L. 117–81, § 556(a)(2)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “Subject to subsection (b), the Commandant of the Defense Language Institute may confer an Associate of Arts degree in a foreign language upon any graduate of the Foreign Language Center of the Institute who fulfills the requirements for that degree.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
