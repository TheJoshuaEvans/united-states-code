os), "},{"tag":"html:a","attrib":{"href":"/us/stat/41/813"},"text":"41 Stat. 813","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1938-06-30/ch851/s1"},"text":"June 30, 1938, ch. 851, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/52/1252"},"text":"52 Stat. 1252","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1944-06-17/ch262"},"text":"June 17, 1944, ch. 262","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/58/280"},"text":"58 Stat. 280","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab44f5bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab44f5be-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 8722, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/539"},"text":"70A Stat. 539","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/190/B"},"text":"Pub. L. 85–861, § 1(190)(B)","children":[],"tail":", (C), "},{"tag":"ref","attrib":{"href":"/us/stat/72/1534"},"text":"72 Stat. 1534","children":[],"tail":", related to hospital and related benefits for members of a Citizens’ Air Training Camp and for members of Air Force not covered by former "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8721"},"text":"section 8721 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tVI/s604/f/1/A"},"text":"Pub. L. 99–661, div. A, title VI, § 604(f)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3877"},"text":"100 Stat. 3877","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab44f5bf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s807/d/5"},"text":"Pub. L. 115–232, § 807(d)(5)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7422"},"text":"section 7422 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 8730(b)(2)” for “section 7430(b)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 8730” for “section 7430”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/178"},"text":"Pub. L. 108–178","children":[],"tail":" substituted “land’ within the meaning of those sections” for “lands’ within the meaning of that Act” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":" substituted “sections 3114–3116 and 3118 of title 40” for “the Act of "},{"tag":"date","attrib":{"date":"1931-02-26"},"text":"February 26, 1931","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s258a–258e"},"text":"40 U.S.C. 258a–258e","children":[],"tail":")” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" substituted “180 days before” for “one hundred eighty days prior to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (c)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" inserted “(other than natural gas liquids)” after “petroleum”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/413/s1/a/1"},"text":"Pub. L. 99–413, § 1(a)(1)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “to produce such reserves at the maximum efficient rate consistent with sound engineering practices for a period ending not later than "},{"tag":"date","attrib":{"date":"1982-04-05"},"text":"April 5, 1982","children":[],"tail":";”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/413/s1/a/2"},"text":"Pub. L. 99–413, § 1(a)(2)","children":[],"tail":", struck out par. (3) which conditioned the production authorization for Naval Petroleum Reserve Numbered 1 upon private owners’ agreements with the Secretary to continue operations of such reserve under a unitized plan contract that protected the public interest."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525"},"text":"Pub. L. 98–525","children":[],"tail":" struck out “of this section” after “subsection (c)” in provisions preceding par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (c)(1). ","children":[{"tag":"ref","attri