{"tag":"section","attrib":{"id":"idab44f5a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8722"},"text":null,"children":[{"tag":"num","attrib":{"value":"8722"},"text":"§ 8722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab44f5a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8722/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, directly or by contract, lease, or otherwise, shall explore, prospect, conserve, develop, use, and operate the naval petroleum reserves in his discretion, subject to the provisions of subsection (c) and the other provisions of this chapter; except that no petroleum leases shall be granted at Naval Petroleum Reserves Numbered 1 and 3.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab44f5aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8722/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as otherwise provided in this chapter, particularly subsection (c), the naval petroleum reserves shall be used and operated for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab44f5ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8722/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection, conservation, maintenance, and testing of those reserves; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab44f5ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8722/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production of petroleum whenever and to the extent that the Secretary, with the approval of the President, finds that such production is needed for national defense purposes and the production is authorized by a joint resolution of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab44f5ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8722/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab44f5ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8722/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In administering Naval Petroleum Reserves Numbered 1, 2, and 3, the Secretary is authorized and directed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab44f5af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8722/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to further explore, develop, and operate such reserves;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab44f5b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8722/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to produce, during any extension of a period under paragraph (2), such reserves—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idab44f5b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8722/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the maximum efficient rate consistent with sound engineering practices; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab44f5b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8722/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a lesser rate consistent with sound engineering practices and the protection, conservation, maintenance, and testing of such reserves if the Secretary determines that the minimum price described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8730/b/2"},"text":"section 8730(b)(2) of this title","children":[],"tail":" cannot be attained for the United States share of petroleum (other than natural gas liquids) produced from such Reserves;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab44f5b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8722/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during such production period or any extension thereof to sell or otherwise dispose of the United States share of such petroleum produced from such reserves as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8730"},"text":"section 8730 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab44f5b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8722/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to construct, acquire, or contract for the use of storage and shipping facilities on and off the reserves and pipelines and associated facilities on and off the reserves for transporting petroleum from such reserves to the points where the production from such reserves will be refined or shipped.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Any pipeline in the vicinity of a naval petroleum reserve not otherwise operated as a common carrier may be acquired by the Secretary by condemnation, if necessary, if the owner thereof refuses to accept, convey, and transport without discrimination and at reasonable rates any petroleum produced at such reserve. With the approval of the Secretary, rights-of-way for new pipelines and associated facilities may be acquired by the exercise of the right of eminent domain in the appropriate United States district court. Such rights-of-way may be acquired in the manner set forth in sections 3114–3116 and 3118 of title 40, and the prospective holder of the right-of-way is “the authority empowered by law to acquire the land” within the meaning of those sections. Such new pipelines shall accept, convey, and transport without discrimination and at reasonable rates any petroleum produced at such reserves as a common carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab44f5b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8722/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" After ","children":[{"tag":"date","attrib":{"date":"1982-04-05"},"text":"April 5, 1982","children":[],"tail":", the President may extend the period of production in the case of any naval petroleum reserve for additional periods of not to exceed three years each—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab44f5b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8722/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the President requires an investigation to be made, in the case of each extension, to determine the necessity for continued production from such naval petroleum reserve;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab44f5b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8722/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the President submits to the Congress, at least 180 days before the expiration of the current production period prescribed by this section, or any extension thereof, a copy of the report made to him on such investigation together with a certification by him that continued production from such naval petroleum reserve is in the national interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab44f5b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8722/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if neither House of Congress within ninety days after receipt of such report and certification adopts a resolution disapproving further production from such naval petroleum reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab44f5b9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/458"},"text":"70A Stat. 458","children":[],"tail":", § 7422; "},{"tag":"ref","attrib":{"href":"/us/pl/87/599/s1"},"text":"Pub. L. 87–599, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-08-24"},"text":"Aug. 24, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/401"},"text":"76 Stat. 401","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/796/s1/2"},"text":"Pub. L. 87–796, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-11"},"text":"Oct. 11, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/904"},"text":"76 Stat. 904","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/258/tII/s201/3"},"text":"Pub. L. 94–258, title II, § 201(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-05"},"text":"Apr. 5, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/307"},"text":"90 Stat. 307","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/137/s3/a"},"text":"Pub. L. 96–137, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-12"},"text":"Dec. 12, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1061"},"text":"93 Stat. 1061","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s513/31"},"text":"Pub. L. 96–513, title V, § 513(31)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2933"},"text":"94 Stat. 2933","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXIV/s1405/51"},"text":"Pub. L. 98–525, title XIV, § 1405(51)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2625"},"text":"98 Stat. 2625","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/413/s1/a"},"text":"Pub. L. 99–413, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-29"},"text":"Aug. 29, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/944"},"text":"100 Stat. 944","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/g/tII/s201"},"text":"Pub. L. 100–202, § 101(g) [title II, § 201]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-213"},"text":"101 Stat. 1329–213","children":[],"tail":", 1329–242; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXVI/s1622/f/2"},"text":"Pub. L. 101–189, div. A, title XVI, § 1622(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1605"},"text":"103 Stat. 1605","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/b/30"},"text":"Pub. L. 107–217, § 3(b)(30)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1297"},"text":"116 Stat. 1297","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/178/s4/b/6"},"text":"Pub. L. 108–178, § 4(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-15"},"text":"Dec. 15, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2641"},"text":"117 Stat. 2641","children":[],"tail":"; renumbered § 8722 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 807(d)(5), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":", 1840.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab44f5ba-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab44f5bb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab44f5bc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib