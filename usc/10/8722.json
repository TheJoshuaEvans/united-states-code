t. 401","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/87/599/s3"},"text":"“The Federal agency or agencies in control of any pipeline between gas wells in the South Barrow gas field and the town of Barrow may authorize purchasers of the gas or carriers of the gas to install connections to such pipeline.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
