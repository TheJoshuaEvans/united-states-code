{"tag":"section","attrib":{"id":"idab7be41a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9483"},"text":null,"children":[{"tag":"num","attrib":{"value":"9483"},"text":"§ 9483.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation and subsistence during travel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab7be41b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9483/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There may be furnished to a person attending a school or camp established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9481"},"text":"section 9481 of this title","children":[],"tail":", for travel to and from that school or camp—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab7be41c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9483/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation and subsistence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be41d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9483/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation in kind and a subsistence allowance of one cent a mile; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be41e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9483/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a travel allowance of five cents a mile.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7be41f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9483/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The travel allowance for the return trip may be paid in advance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7be420-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9483/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this section, distance is computed by the shortest usually traveled route, within such territorial limits as the Secretary of the Air Force may prescribe, from the authorized starting point to the school or camp and return.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab7be421-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/572"},"text":"70A Stat. 572","children":[],"tail":", § 9413; renumbered § 9483 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 806(a)(2), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1832"},"text":"132 Stat. 1832","children":[],"tail":", 1840.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab7be422-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab7be423-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab7be424-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col"