{"tag":"section","attrib":{"id":"idab8a1600-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10147"},"text":null,"children":[{"tag":"num","attrib":{"value":"10147"},"text":"§ 10147.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ready Reserve: training requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab8a1601-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10147/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as specifically provided in regulations to be prescribed by the Secretary of Defense, or by the Secretary of Homeland Security with respect to the Coast Guard when it is not operating as a service in the Navy, each person who is enlisted, inducted, or appointed in an armed force, and who becomes a member of the Ready Reserve under any provision of law except section 513 or 10145(b) of this title, shall be required, while in the Ready Reserve, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8a1602-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10147/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in at least 48 scheduled drills or training periods during each year and serve on active duty for training of not less than 14 days (exclusive of traveltime) during each year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8a1603-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10147/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve on active duty for training not more than 30 days during each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8a1604-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10147/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member who has served on active duty for one year or longer may not be required to perform a period of active duty for training if the first day of that period falls during the last 120 days of the member’s required membership in the Ready Reserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab8a1605-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1661/a/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1661(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2973"},"text":"108 Stat. 2973","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/b/1"},"text":"Pub. L. 107–296, title XVII, § 1704(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab8a1606-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab8a1607-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab8a1608-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","childr