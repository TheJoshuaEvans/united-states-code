{"tag":"section","attrib":{"id":"idaacdca64-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6322"},"text":null,"children":[{"tag":"num","attrib":{"value":"6322"},"text":"§ 6322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition and report ","children":[{"tag":"ref","attrib":{"idref":"fn002147"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002147"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Requirement to submit report was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" without corresponding amendment to section catchline."}],"tail":" on bonuses to contractors operating defense nuclear facilities"}],"tail":null},{"tag":"subsection","attrib":{"id":"idaacdca65-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy may not provide any bonuses, award fees, or other form of performance- or production-based awards to a contractor operating a Department of Energy defense nuclear facility unless, in evaluating the performance or production under the contract, the Secretary considers the contractor’s compliance with all applicable environmental, safety, and health statutes, regulations, and practices for determining both the size of, and the contractor’s qualification for, such bonus, award fee, or other award. The prohibition in this subsection applies with respect to contracts entered into, or contract options exercised, after ","children":[{"tag":"date","attrib":{"date":"1989-11-29"},"text":"November 29, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdca66-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy shall promulgate regulations to implement subsection (a) not later than ","children":[{"tag":"date","attrib":{"date":"1990-03-01"},"text":"March 1, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaacdca67-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1441"},"text":"139 Stat. 1441","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaacdca68-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaacdca69-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaacdca6a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6322 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8322"},"text":"section 8322 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2782"},"text":"section 2782 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
