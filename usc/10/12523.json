{"tag":"section","attrib":{"id":"idaba45384-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12523"},"text":null,"children":[{"tag":"num","attrib":{"value":"12523"},"text":"§ 12523.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Risk insured","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaba45385-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12523/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The insurance program shall insure members of the Ready Reserve against the risk of being ordered into covered service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba45386-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12523/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Entitlement to Benefits","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba45387-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12523/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An insured member ordered into covered service shall be entitled to payment of a benefit for each month (and fraction thereof) of covered service that exceeds 30 days of covered service, except that no member may be paid under the insurance program for more than 12 months of covered service served during any period of 18 consecutive months.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba45388-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12523/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment shall be based solely on the insured status of a member and on the period of covered service served by the member. Proof of loss of income or of expenses incurred as a result of covered service may not be required.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaba45389-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s512/a/1"},"text":"Pub. L. 104–106, div. A, title V, § 512(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/300"},"text":"110 Stat. 300","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
