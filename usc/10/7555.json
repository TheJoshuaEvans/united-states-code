{"tag":"section","attrib":{"id":"idaaf8aad6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7555"},"text":null,"children":[{"tag":"num","attrib":{"value":"7555"},"text":"§ 7555.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ARMS Initiative loan guarantee program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaf8aad7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7555/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (b), the Secretary may carry out a loan guarantee program to encourage commercial firms to use eligible facilities under this chapter. Under any such program, the Secretary may guarantee the repayment of any loan made to a commercial firm to fund, in whole or in part, the establishment of a commercial activity to use an eligible facility under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf8aad8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7555/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advanced Budget Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Loan guarantees under this section may not be committed except to the extent that appropriations of budget authority to cover their costs are made in advance, as required by section 504 of the Federal Credit Reform Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661c"},"text":"2 U.S.C. 661c","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf8aad9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7555/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Administration","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaf8aada-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7555/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may enter into an agreement with any of the officials named in paragraph (2) under which that official may, for the purposes of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaf8aadb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7555/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" process applications for loan guarantees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaf8aadc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7555/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guarantee repayment of loans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaf8aadd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7555/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide any other services to the Secretary to administer the loan guarantee program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf8aade-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7555/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The officials referred to in paragraph (1) are as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaf8aadf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7555/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Small Business Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaf8aae0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7555/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The head of any appropriate agency in the Department of Agriculture, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaaf8aae1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7555/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Farmers Home Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaaf8aae2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7555/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Rural Development Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf8aae3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7555/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each official authorized to do so under an agreement entered into under paragraph (1) may guarantee loans under this section to commercial firms of any size, notwithstanding any limitations on the size of applicants imposed on other loan guarantee programs that the official administers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf8aae4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7555/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent practicable, each official processing loan guarantee applications under this section pursuant to an agreement entered into under paragraph (1) shall use the same processing procedures as the official uses for processing loan guarantee applications under other loan guarantee programs that the official administers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf8aae5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7555/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Loan Limits","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The maximum amount of loan principal guaranteed during a fiscal year under this section may not exceed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaf8aae6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7555/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000, with respect to any single borrower; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf8aae7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7555/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $320,000,000 with respect to all borrowers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf8aae8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7555/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may transfer to an official providing services under subsection (c), and that official may accept, such funds as may be necessary to administer the loan guarantee program under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaf8aae9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title III, § 344(a)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–70, § 4555; renumbered § 7555, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/d"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaf8aaea-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaf8aaeb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaaf8aaec-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4555"},"text":"section 4555 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaaf8aaed-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaaf8aaee-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
