{"tag":"section","attrib":{"id":"ida96cda5f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350e"},"text":null,"children":[{"tag":"num","attrib":{"value":"2350e"},"text":"§ 2350e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NATO Airborne Warning and Control System (AWACS) program: authority of Secretary of Defense","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida96cda60-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority Under AWACS Program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense, in carrying out an AWACS memorandum of understanding, may do the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida96cda61-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Waive reimbursement for the cost of the following functions performed by personnel other than personnel employed in the United States Air Force Airborne Warning and Control System (AWACS) program office:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida96cda62-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350e/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Auditing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida96cda63-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350e/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Quality assurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida96cda64-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350e/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Codification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida96cda65-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350e/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Inspection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida96cda66-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350e/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contract administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida96cda67-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350e/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Acceptance testing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida96cda68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350e/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Certification services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida96cda69-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350e/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Planning, programming, and management services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida96cda6a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Waive any surcharge for administrative services otherwise chargeable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida96cda6b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In connection with that Program, assume contingent liability for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida96cda6c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350e/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" program losses resulting from the gross negligence of any contracting officer of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida96cda6d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350e/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifiable taxes, customs duties, and other charges levied within the United States on the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida96cda6e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350e/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States share of the unfunded termination liability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida96cda6f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract Authority Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Authority under this section to enter into contracts shall be effective for any fiscal year only to such extent or in such amounts as are provided in appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida96cda70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “AWACS memorandum of understanding” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida96cda71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Multilateral Memorandum of Understanding Between the North Atlantic Treaty Organization (NATO) Ministers of Defence on the NATO E–3A Cooperative Programme, signed by the Secretary of Defense on ","children":[{"tag":"date","attrib":{"date":"1978-12-06"},"text":"December 6, 1978","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida96cda72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Memorandum of Understanding for Operations and Support of the NATO Airborne Early Warning and Control Force, signed by the United States Ambassador to NATO on ","children":[{"tag":"date","attrib":{"date":"1984-09-26"},"text":"September 26, 1984","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida96cda73-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350e/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Addendum to the Multilateral Memorandum of Understanding Between the North Atlantic Treaty Organization (NATO) Ministers of Defence on the NATO E–3A Cooperative Programme (dated ","children":[{"tag":"date","attrib":{"date":"1978-12-06"},"text":"December 6, 1978","children":[],"tail":") relating to the modernization of the NATO Airborne Early Warning and Control (NAEW&C) System, dated "},{"tag":"date","attrib":{"date":"1990-12-07"},"text":"December 7, 1990","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida96cda74-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350e/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other follow-on support agreement for the NATO E–3A Cooperative Programme.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida96cda75-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tIX/s932/a/1"},"text":"Pub. L. 101–189, div. A, title IX, § 932(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1536"},"text":"103 Stat. 1536","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tX/s1051"},"text":"Pub. L. 102–190, div. A, title X, § 1051","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1470"},"text":"105 Stat. 1470","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tXIV/s1413"},"text":"Pub. L. 103–160, div. A, title XIV, § 1413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1829"},"text":"107 Stat. 1829","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida96cda76-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida96cda77-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida96cda78-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/86/tI/s103"},"text":"Pub. L. 97–86, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-01"},"text":"Dec. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1100"},"text":"95 Stat. 1100","children":[],"tail":", as amended, which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2407"},"text":"section 2407 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/s932/b"},"text":"Pub. L. 101–189, § 932(b)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida96cda79-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":" struck out subsec. (d) which read as follows: “"},{"tag":"inline","attrib":{},"text":"Expiration","children":[],"tail":".—The authority provided by this section expires on "},{"tag":"date","attrib":{"date":"1993-09-30"},"text":"September 30, 1993","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (c)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/s1051/1"},"text":"Pub. L. 102–190, § 1051(1)","children":[],"tail":", added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/s1051/2"},"text":"Pub. L. 102–190, § 1051(2)","children":[],"tail":", substituted “1993” for “1991”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
