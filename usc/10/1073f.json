{"tag":"section","attrib":{"id":"ida86db993-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1073f"},"text":"§ 1073f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care fraud and abuse prevention program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida86db994-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida86db995-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may carry out a program under this section to prevent and remedy fraud and abuse in the health care programs of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida86db996-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the discretion of the Secretary, such program may be administered jointly by the Inspector General of the Department of Defense and the Director of the Defense Health Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida86db997-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out such program, the authorities granted to the Secretary of Defense and the Inspector General of the Department of Defense under section 1128A(m) of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7a/m"},"text":"42 U.S.C. 1320a–7a(m)","children":[],"tail":") shall be available to the Secretary and the Inspector General."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida86db998-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Monetary Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida86db999-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the provisions of section 1128A of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7a"},"text":"42 U.S.C. 1320a–7a","children":[],"tail":") shall apply with respect to any civil monetary penalty imposed in carrying out the program authorized under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida86db99a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1079a"},"text":"section 1079a of this title","children":[],"tail":", amounts recovered in connection with any such civil monetary penalty imposed—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida86db99b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073f/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be credited to appropriations available as of the time of the collection for expenses of the health care program of the Department of Defense affected by the fraud and abuse for which such penalty was imposed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida86db99c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073f/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be used to support the administration of the program authorized under subsection (a), including to support any interagency agreements entered into under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida86db99d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interagency Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may enter into agreements with the Secretary of Health and Human Services, the Attorney General, or the heads of other Federal agencies, for the effective and efficient implementation of the program authorized under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida86db99e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Joint administration of the program authorized under subsection (a) may not be construed as limiting the authority of the Inspector General of the Department of Defense under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida86db99f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fraud and Abuse Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “fraud and abuse” means any conduct specified in subsection (a) or (b) of section 1128A of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7a"},"text":"42 U.S.C. 1320a–7a","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida86db9a0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVII/s713/a"},"text":"Pub. L. 117–81, div. A, title VII, § 713(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1784"},"text":"135 Stat. 1784","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
