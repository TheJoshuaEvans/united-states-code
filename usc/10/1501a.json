{"tag":"section","attrib":{"id":"ida8ddba2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1501a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1501a"},"text":"§ 1501a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public-private partnerships; other forms of support","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8ddba2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1501a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public-private Partnerships","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may enter into arrangements known as public-private partnerships with appropriate entities outside the Government for the purposes of facilitating the activities of the designated Defense Agency. The Secretary may only partner with foreign governments or foreign entities with the concurrence of the Secretary of State. Any such arrangement shall be entered into in accordance with authorities provided under this section or any other authority otherwise available to the Secretary. Regulations prescribed under subsection (f)(1) shall include provisions for the establishment and implementation of such partnerships. An employee of an entity outside the Government that has entered into a public-private partnership, cooperative agreement, or a grant arrangement with, or in direct support of, the designated Defense Agency under this section shall be considered to be an employee of the Federal Government by reason of participation in such partnership, cooperative agreement, or grant, only for the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":" (relating to maintenance of records on individuals)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ddba2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1501a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance of Voluntary Personal Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may accept voluntary services to facilitate accounting for missing persons in the same manner as the Secretary of a military department may accept such services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1588/a/9"},"text":"section 1588(a)(9) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ddba2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1501a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperative Agreements and Grants.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ddba30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1501a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may enter into a cooperative agreement with, or make a grant to, a private entity for purposes related to support of the activities of the designated Defense Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ddba31-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1501a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of certain contract requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3201/e"},"text":"section 3201(e) of this title","children":[],"tail":", the Secretary may enter such cooperative agreements or grants on a sole-source basis pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3204/a/5"},"text":"section 3204(a)(5) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ddba32-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1501a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Department of Defense Personal Property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may allow a private entity to use, at no cost, personal property of the Department of Defense to assist the entity in supporting the activities of the designated Defense Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ddba33-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1501a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance of Gifts.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ddba34-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1501a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to accept","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (f)(2), the Secretary may accept, hold, administer, spend, and use any gift of personal property, money, or services made on the condition that the gift be used for the purpose of facilitating accounting for missing persons pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1501/a/2/C"},"text":"section 1501(a)(2)(C) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ddba35-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1501a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Gift funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Gifts and bequests of money accepted under this subsection shall be deposited in the Treasury in the Department of Defense General Gift Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ddba36-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1501a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of gifts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Personal property and money accepted under this subsection may be used by the Secretary, and services accepted under this subsection may be performed, without further specific authorization in law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ddba37-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1501a/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expenses of transfer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may pay all necessary expenses in connection with the conveyance or transfer of a gift accepted under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ddba38-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1501a/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expenses of care","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may pay all reasonable and necessary expenses in connection with the care of a gift accepted under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ddba39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1501a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ddba3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1501a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe regulations to implement this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ddba3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1501a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Such regulations shall provide that acceptance of a gift (including a gift of services) or use of a gift under this section may not occur if the nature or circumstances of the acceptance or use would compromise the integrity, or the appearance of integrity, of any program of the Department of Defense or any individual involved in such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ddba3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1501a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ddba3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1501a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperative agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “cooperative agreement” means an authorized cooperative agreement as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6305"},"text":"section 6305 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ddba3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1501a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “grant” means an authorized grant as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6304"},"text":"section 6304 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ddba3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1501a/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Gift","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “gift” includes a devise or bequest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8ddba40-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tIX/s916/b"},"text":"Pub. L. 113–291, div. A, title IX, § 916(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3477"},"text":"128 Stat. 3477","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tV/s523"},"text":"Pub. L. 115–232, div. A, title V, § 523","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1756"},"text":"132 Stat. 1756","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1883/b/2"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1883(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4294"},"text":"134 Stat. 4294","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8ddba41-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8ddba42-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8ddba43-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “3201(e) of this title” for “2304(k) of this title” and “3204(a)(5) of this title” for “2304(c)(5) of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s523/a"},"text":"Pub. L. 115–232, § 523(a)","children":[],"tail":", (c), substituted “subsection (f)(1)” for “subsection (e)(1)” and inserted at end “An employee of an entity outside the Government that has entered into a public-private partnership, cooperative agreement, or a grant arrangement with, or in direct support of, the designated Defense Agency under this section shall be considered to be an employee of the Federal Government by reason of participation in such partnership, cooperative agreement, or grant, only for the purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":" (relating to maintenance of records on individuals).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s523/b/1"},"text":"Pub. L. 115–232, § 523(b)(1)","children":[],"tail":", (2), added subsec. (e) and redesignated former subsec. (e) as (f). Former subsec. (f) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s523/b/1"},"text":"Pub. L. 115–232, § 523(b)(1)","children":[],"tail":", (3), redesignated subsec. (f) as (g) and added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8ddba44-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8ddba45-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
