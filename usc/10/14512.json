{"tag":"section","attrib":{"id":"idabb76736-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14512"},"text":null,"children":[{"tag":"num","attrib":{"value":"14512"},"text":"§ 14512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separation at age 66: officers holding certain offices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabb76737-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14512/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Army and Air Force","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb76738-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14512/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Unless retired, transferred to the Retired Reserve, or discharged at an earlier date, a reserve officer of the Army or Air Force who is specified in paragraph (2) shall on the last day of the month in which the officer becomes 66 years of age, be separated in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14515"},"text":"section 14515 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb76739-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14512/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) applies to a reserve officer of the Army or Air Force who is any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabb7673a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14512/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of the Army Reserve, Chief of the Air Force Reserve, Director of the Army National Guard, or Director of the Air National Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabb7673b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14512/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An adjutant general.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabb7673c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14512/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a reserve officer of the Army, the commanding general of the troops of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb7673d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14512/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Navy and Marine Corps","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb7673e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14512/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy may defer the retirement under section 14510 or 14511 of a reserve officer of the Navy in a grade above captain or a reserve officer of the Marine Corps in a grade above colonel and retain the officer in an active status until the officer becomes 66 years of age. Not more than 10 officers may be so deferred at any one time, distributed between the Navy Reserve and the Marine Corps Reserve as the Secretary determines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb7673f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14512/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may defer the retirement of a reserve officer serving in the position of Chief of the Navy Reserve or Commander of the Marine Forces Reserve, but such deferment may not extend beyond the first day of the month following the month in which the officer becomes 66 years of age. A deferment under this paragraph shall not count toward the limitation on the total number of officers whose retirement may be deferred at any one time under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabb76740-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2953"},"text":"108 Stat. 2953","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV"},"text":"Pub. L. 109–163, div. A, title V","children":[],"tail":", §§ 511, 515(b)(1)(UU), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3231"},"text":"119 Stat. 3231","children":[],"tail":", 3234; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s503/d"},"text":"Pub. L. 109–364, div. A, title V, § 503(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2178"},"text":"120 Stat. 2178","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tXVIII/s1825/b"},"text":"Pub. L. 110–181, div. A, title XVIII, § 1825(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/502"},"text":"122 Stat. 502","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb76741-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabb76742-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idabb76743-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 3845, 6391(b), and 8845 of this title, prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1629/a/3"},"text":"Pub. L. 103–337, § 1629(a)(3)","children":[],"tail":", (b)(3), (c)(3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabb76744-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1825/b/1"},"text":"Pub. L. 110–181, § 1825(b)(1)","children":[],"tail":", redesignated subpars. (B) to (D) as (A) to (C), respectively, and struck out former subpar. (A) which read as follows: “The Chief of the National Guard Bureau.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1825/b/2"},"text":"Pub. L. 110–181, § 1825(b)(2)","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s503/d/2"},"text":"Pub. L. 109–364, § 503(d)(2)","children":[],"tail":", substituted “66” for “64” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s511"},"text":"Pub. L. 109–163, § 511","children":[],"tail":", designated existing provisions as par. (1), substituted “who is specified in paragraph (2)” for “who is Chief of the National Guard Bureau, an adjutant general, or if a reserve officer of the Army, commanding general of the troops of a State,”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s503/d/1"},"text":"Pub. L. 109–364, § 503(d)(1)","children":[],"tail":", substituted “66” for “64”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s503/d/1"},"text":"Pub. L. 109–364, § 503(d)(1)","children":[],"tail":", substituted “66” for “64”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s515/b/1/UU"},"text":"Pub. L. 109–163, § 515(b)(1)(UU)","children":[],"tail":", substituted “Navy Reserve” for “Naval Reserve”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabb76745-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabb76746-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib"