{"tag":"section","attrib":{"id":"ida8f7f8c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1585"},"text":null,"children":[{"tag":"num","attrib":{"value":"1585"},"text":"§ 1585.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carrying of firearms","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Under regulations to be prescribed by the Secretary of Defense, civilian officers and employees of the Department of Defense may carry firearms or other appropriate weapons while assigned investigative duties or such other duties as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida8f7f8c5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/577/s1/1"},"text":"Pub. L. 85–577, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-07-31"},"text":"July 31, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/455"},"text":"72 Stat. 455","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
