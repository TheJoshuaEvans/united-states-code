{"tag":"section","attrib":{"id":"ida9908e9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2601a"},"text":"§ 2601a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct acceptance of gifts by members of the armed forces and Department of Defense and Coast Guard employees and their families","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9908e9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations Governing Acceptance of Gifts","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9908e9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense (and the Secretary of Homeland Security in the case of the Coast Guard when it is not operating as a service in the Navy) shall prescribe regulations to provide that, subject to such limitations as may be specified in such regulations, the following individuals may accept gifts from nonprofit organizations, private parties, and other sources outside the Department of Defense or the Department of Homeland Security:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9908e9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the armed forces described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9908e9e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A civilian employee of the Department of Defense or Coast Guard described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9908e9f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The family members of such a member or employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9908ea0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601a/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Survivors of such a member or employee who is killed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908ea1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The regulations required by this subsection shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9908ea2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply uniformly to all elements of the Department of Defense and, to the maximum extent feasible, to the Coast Guard; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9908ea3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require review and approval by a designated agency ethics official before acceptance of a gift to ensure that acceptance of the gift complies with the Joint Ethics Regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9908ea4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies to a member of the armed forces who, while performing active duty, full-time National Guard duty, or inactive-duty training on or after ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":", incurred an injury or illness—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9908ea5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1413a/e/2"},"text":"section 1413a(e)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908ea6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an operation or area designated as a combat operation or a combat zone, respectively, by the Secretary of Defense in accordance with the regulations prescribed under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908ea7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that results in enrollment in a Warriors in Transition program, as defined in section 738(e) of the National Defense Authorization Act for Fiscal Year 2013 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Public Law 112–239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1071"},"text":"10 U.S.C. 1071","children":[],"tail":" note); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908ea8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under other circumstances determined by the Secretary concerned to warrant treatment analogous to members covered by paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9908ea9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section applies to a civilian employee of the Department of Defense or Coast Guard who, while an employee on or after ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":", incurred an injury or illness under a circumstance described in subsection (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9908eaa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Gifts From Certain Sources Prohibited","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations prescribed under subsection (a) may not authorize the acceptance of a gift from a foreign government or international organization or their agents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9908eab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of Certain Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent provided in the regulations issued under subsection (a) to implement subsection (b)(2), the regulations shall apply to the acceptance of gifts received after ","children":[{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":", for injuries or illnesses incurred on or after "},{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9908eac-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tV/s591/a"},"text":"Pub. L. 111–383, div. A, title V, § 591(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4231"},"text":"124 Stat. 4231","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s543"},"text":"Pub. L. 112–81, div. A, title V, § 543","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1411"},"text":"125 Stat. 1411","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/f/32"},"text":"Pub. L. 112–239, div. A, title X, § 1076(f)(32)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1954"},"text":"126 Stat. 1954","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1071/e/4"},"text":"Pub. L. 113–291, div. A, title X, § 1071(e)(4)","children":[],"tail":", (f)(19), "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3510"},"text":"128 Stat. 3510","children":[],"tail":", 3511; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tV/s522"},"text":"Pub. L. 117–263, div. A, title V, § 522","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2570"},"text":"136 Stat. 2570","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9908ead-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9908eae-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9908eaf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s522/1"},"text":"Pub. L. 117–263, § 522(1)","children":[],"tail":", added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s522/2"},"text":"Pub. L. 117–263, § 522(2)","children":[],"tail":", struck out “paragraph (1), (2) or (3) of” before “subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1071/f/19/A"},"text":"Pub. L. 113–291, § 1071(f)(19)(A)","children":[],"tail":", substituted “prescribe” for “issue”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1071/f/19/B"},"text":"Pub. L. 113–291, § 1071(f)(19)(B)","children":[],"tail":", substituted “prescribed” for “issued”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1071/e/4"},"text":"Pub. L. 113–291, § 1071(e)(4)","children":[],"tail":", substituted “after "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":",” for “after the date of the enactment of the National Defense Authorization Act for Fiscal Year 2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" inserted “when it is not operating as a service in the Navy” after “Coast Guard” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s543/1"},"text":"Pub. L. 112–81, § 543(1)","children":[],"tail":", added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s543/2"},"text":"Pub. L. 112–81, § 543(2)","children":[],"tail":", substituted “paragraph (1), (2) or (3) of subsection (b)” for “paragraph (1) or (2) of subsection (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s543/3"},"text":"Pub. L. 112–81, § 543(3)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
