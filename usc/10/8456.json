"34 U.S.C. 1040","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-08-13/ch962/s14"},"text":"Aug. 13, 1946, ch. 962, § 14","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/1061"},"text":"60 Stat. 1061","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6956(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s1049"},"text":"34 U.S.C. 1049","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-06-30/ch421/s4"},"text":"June 30, 1950, ch. 421, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/305"},"text":"64 Stat. 305","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6956(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s1047"},"text":"34 U.S.C. 1047","children":[],"tail":" (1st proviso)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-06-30/ch421/s2"},"text":"June 30, 1950, ch. 421, § 2","children":[],"tail":" (1st proviso), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/304"},"text":"64 Stat. 304","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The section is worded to indicate that all appointments are made by the President, and that, before appointment, prospective midshipmen are “nominees” or “candidates”, as appropriate.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b) the provision authorizing the Secretary of the Navy to nominate candidates in the event nominations to fill vacancies under subsection (a) are not made by March fourth is omitted as covered by subsection (e), the purpose of which was to assure the entrance of a full class each year.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference in subsection (e) to the strength of the “brigade of midshipmen” is dropped, since there is no statutory requirement that the midshipmen at the Academy be so organized, and the term is a recognition of current organization only. The language authorizing the Secretary, in his discretion, to nominate additional midshipmen to meet the needs of the armed services but not to exceed the authorized strength of the Academy is changed to authorize the Secretary to “fill the vacancies by nominating additional midshipmen”. In exercising his discretion under this subsection, these factors are necessarily considered by the Secretary, irrespective of a specific provision so instructing him.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f) the word “admission” is changed to the word “appointment”, since the admission of a person is a consequence of, and follows automatically from, his appointment. The statement of reasons for failure to complete the course is omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab286cdd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab286cde-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s807/c/1"},"text":"Pub. L. 115–232, § 807(c)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6956"},"text":"section 6956 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 8454(a)” for “section 6954(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" substituted “paragraphs” for “clauses”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “Navy Reserve” for “Naval Reserve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1322/a/14"},"text":"Pub. L. 101–510, § 1322(a)(14)","children":[],"tail":", redesignated subsec. (b) as (a) and struck out former subsec. (a) which read as follows: “The Secretary of the Navy shall, as soon as possible after the first of June of each year, notify in writing each Senator, Representative, and delegate in Congress of any vacancy that will exist at the Naval Academy because of graduation in the following year, or that may occur for other reasons, for which the member or delegate is entitled to nominate a candidate and nine alternates.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1322/a/14/B"},"text":"Pub. L. 101–510, § 1322(a)(14)(B)","children":[],"tail":", redesignated subsec. (c) as (b). Former subsec. (b) redesignated (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1322/a/14/B"},"text":"Pub. L. 101–510, § 1322(a)(14)(B)","children":[],"tail":", redesignated subsec. (d) as (c). Former subsec. (c) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s532/b/2"},"text":"Pub. L. 101–510, § 532(b)(2)","children":[],"tail":", substituted “clauses (2) through (8)” for “clauses (2)–(9)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1322/a/14/B"},"text":"Pub. L. 101–510, § 1322(a)(14)(B)","children":[],"tail":", redesignated subsec. (d) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/60"},"text":"Pub. L. 97–60","children":[],"tail":" redesignated subsecs. (d), (e), and (f) as (b), (c), and (d), respectively. Former subsec. (b) providing that a nomination following notification under subsection (a) be made by the fourth of March of the year following that in which notice of the vacancy was given and that, if the candidate died or declined the nomination, or if the nomination could not be made by reason of a vacancy in the membership of the Senate or the House of Representatives, the nomination could be made, as determined by the Secretary, not later than the date of the final entrance examination for that year, and former subsec. (c) providing that the nomination of candidates to fill vacancies for the District of Columbia, and selection of all candidates at large, be made by the fourth of March of the year in which the candidates were to enter the Academy, were struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/106"},"text":"Pub. L. 94–106","children":[],"tail":" substituted “enlisted members” for “enlisted men” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/171"},"text":"Pub. L. 93–171","children":[],"tail":" substituted reference to clauses (2)–(9) of section 6954(a) for reference to clauses (2)–(8) of section 6954(a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/374"},"text":"Pub. L. 90–374","children":[],"tail":" substituted “nine alternates” for “five alternates”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/276/s3/1"},"text":"Pub. L. 88–276, § 3(1)","children":[],"tail":", substituted “five alternates” for “one or more alternates”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/276/s3/2"},"text":"Pub. L. 88–276, § 3(2)","children":[],"tail":", substituted “three-fourths of those nominated” for “two-thirds of those nominated”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab286cdf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab286ce0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab286ce1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1973 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/171"},"text":"Pub. L. 93–171","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/171/s4"},"text":"section 4 of Pub. L. 93–171","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7442"},"text":"section 7442 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab286ce2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Number of Alternate-Appointees From Congressional Sources Not To Be Reduced Because of Additional Presidential Appointments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nonreduction of number of appointees from congressional sources under this section because of additional presidential appointments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s6954/b/1"},"text":"section 6954(b)(1) of this title","children":[],"tail":", see note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7443"},"text":"section 7443 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
