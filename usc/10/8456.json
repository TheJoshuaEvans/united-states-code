{"tag":"section","attrib":{"id":"idab286cd2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8456"},"text":null,"children":[{"tag":"num","attrib":{"value":"8456"},"text":"§ 8456.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Midshipmen: nomination and selection to fill vacancies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab286cd3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8456/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the annual quota of midshipmen from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab286cd4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8456/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enlisted members of the Regular Navy and the Regular Marine Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab286cd5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8456/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enlisted members of the Navy Reserve and the Marine Corps Reserve; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab286cd6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8456/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at large by the President;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is not filled, the Secretary may fill the vacancies by nominating for appointment other candidates from any of these sources who were found best qualified on examination for admission and not otherwise nominated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab286cd7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8456/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If it is determined that, upon the admission of a new class to the Academy, the number of midshipmen at the Academy will be below the authorized number, the Secretary may fill the vacancies by nominating additional midshipmen from qualified candidates designated as alternates and from other qualified candidates who competed for nomination and are recommended and found qualified by the Academic Board. At least three-fourths of those nominated under this subsection shall be from qualified alternates under paragraphs (2) through (8) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8454/a"},"text":"section 8454(a) of this title","children":[],"tail":", and the remainder shall be from qualified candidates who competed for appointment under any other provision of law. An appointment of a nominee under this subsection is an additional appointment and is not in place of an appointment otherwise authorized by law."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab286cd8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8456/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The failure of a member of a graduating class to complete the course with his class does not delay the appointment of his successor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab286cd9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/430"},"text":"70A Stat. 430","children":[],"tail":", § 6956; "},{"tag":"ref","attrib":{"href":"/us/pl/88/276/s3"},"text":"Pub. L. 88–276, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-03-03"},"text":"Mar. 3, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/151"},"text":"78 Stat. 151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/374"},"text":"Pub. L. 90–374","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-05"},"text":"July 5, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/283"},"text":"82 Stat. 283","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/171/s2/4"},"text":"Pub. L. 93–171, § 2(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-11-29"},"text":"Nov. 29, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/690"},"text":"87 Stat. 690","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/106/tVIII/s803/b/2"},"text":"Pub. L. 94–106, title VIII, § 803(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-10-07"},"text":"Oct. 7, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/538"},"text":"89 Stat. 538","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/60/tII/s206"},"text":"Pub. L. 97–60, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-10-14"},"text":"Oct. 14, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1007"},"text":"95 Stat. 1007","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tV/s532/b/2"},"text":"Pub. L. 101–510, div. A, title V, § 532(b)(2)","children":[],"tail":", title XIII, § 1322(a)(14), "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1563"},"text":"104 Stat. 1563","children":[],"tail":", 1671; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s515/b/1/R"},"text":"Pub. L. 109–163, div. A, title V, § 515(b)(1)(R)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3233"},"text":"119 Stat. 3233","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/f/41"},"text":"Pub. L. 112–239, div. A, title X, § 1076(f)(41)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1954"},"text":"126 Stat. 1954","children":[],"tail":"; renumbered § 8456 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 807(c)(1), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":", 1840.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab286cda-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab286cdb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab286cdc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"