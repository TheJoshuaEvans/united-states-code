{"tag":"section","attrib":{"id":"idabb9d828-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14906"},"text":null,"children":[{"tag":"num","attrib":{"value":"14906"},"text":"§ 14906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers eligible to serve on boards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabb9d829-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition of Boards","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each board convened under this chapter shall consist of officers appointed as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb9d82a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14906/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member of the board shall be an officer of the same armed force as the officer being required to show cause for retention in an active status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb9d82b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14906/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member of the board shall hold a grade above major or lieutenant commander, except that at least one member of the board shall hold a grade above lieutenant colonel or commander.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb9d82c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14906/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member of the board shall be senior in grade to any officer to be considered by the board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb9d82d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person may not be a member of more than one board convened under this chapter to consider the same officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabb9d82e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2960"},"text":"108 Stat. 2960","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s504/b"},"text":"Pub. L. 106–65, div. A, title V, § 504(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/591"},"text":"113 Stat. 591","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb9d82f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabb9d830-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabb9d831-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" amended heading and text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Each officer who serves on a board convened under this chapter shall be an officer of the same armed force as the officer being required to show cause for retention in an active status.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) An officer may not serve on a board under this chapter unless the officer holds a grade above lieutenant colonel or commander and is senior in grade and rank to any officer considered by the board.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabb9d832-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabb9d833-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691/b/1"},"text":"section 1691(b)(1) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
