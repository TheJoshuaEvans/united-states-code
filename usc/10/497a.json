{"tag":"section","attrib":{"id":"ida7c93cb4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s497a"},"text":null,"children":[{"tag":"num","attrib":{"value":"497a"},"text":"§ 497a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification required for reduction or consolidation of dual-capable aircraft based in Europe","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7c93cb5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s497a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less than 90 days before the date on which the Secretary of Defense reduces or consolidates the dual-capable aircraft of the United States that are based in Europe, the Secretary shall submit to the congressional defense committees a notification of such planned reduction or consolidation, including the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7c93cb6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s497a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The reasons for such planned reduction or consolidation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c93cb7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s497a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any effects of such planned reduction or consolidation on the extended deterrence mission of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c93cb8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s497a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The manner in which the military requirements of the North Atlantic Treaty Organization (NATO) will continue to be met in light of such planned reduction or consolidation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c93cb9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s497a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement by the Secretary on the response of NATO to such planned reduction or consolidation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c93cba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s497a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether there is any change in the force posture of the Russian Federation as a result of such planned reduction or consolidation, including with respect to the nonstrategic nuclear weapons of Russia that are within range of the member states of NATO.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7c93cbb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s497a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dual-capable Aircraft Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “dual-capable aircraft” means aircraft that can perform both conventional and nuclear missions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7c93cbc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tX/s1051/b/1"},"text":"Pub. L. 113–66, div. A, title X, § 1051(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/858"},"text":"127 Stat. 858","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
