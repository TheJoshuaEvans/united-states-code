{"tag":"section","attrib":{"id":"ida9385c6e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2192b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2192b"},"text":"§ 2192b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program on enhancement of preparation of dependents of members of armed forces for careers in science, technology, engineering, and mathematics","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9385c6f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2192b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall carry out a program to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9385c70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2192b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the preparation of students at covered schools for careers in science, technology, engineering, and mathematics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9385c71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2192b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assistance to teachers at covered schools to enhance preparation described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9385c72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2192b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program, the Secretary shall coordinate with the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9385c73-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2192b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretaries of the military departments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9385c74-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2192b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9385c75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2192b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9385c76-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2192b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other organizations as the Secretary of Defense considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9385c77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2192b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities under the program may include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9385c78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2192b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishment of targeted internships and cooperative research opportunities at defense laboratories and other technical centers for students and teachers at covered schools.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9385c79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2192b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishment of scholarships and fellowships for students at covered schools.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9385c7a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2192b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Efforts and activities that improve the quality of science, technology, engineering, and mathematics educational and training opportunities for students and teachers at covered schools, including with respect to improving the development of curricula at covered schools.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9385c7b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2192b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development of travel opportunities, demonstrations, mentoring programs, and informal science education for students and teachers at covered schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9385c7c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2192b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Metrics","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish outcome-based metrics and internal and external assessments to evaluate the merits and benefits of activities conducted under the program with respect to the needs of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9385c7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2192b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Schools Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “covered schools” means elementary or secondary schools at which the Secretary determines a significant number of dependents of members of the armed forces are enrolled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9385c7e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tII/s211/a"},"text":"Pub. L. 116–92, div. A, title II, § 211(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1254"},"text":"133 Stat. 1254","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
