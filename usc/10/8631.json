{"tag":"section","attrib":{"id":"idab369e6e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8631"},"text":null,"children":[{"tag":"num","attrib":{"value":"8631"},"text":"§ 8631.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounting for expenditures for obtaining information","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When the Secretary of the Navy decides that an expenditure by the Department of the Navy from an appropriation for obtaining information from anywhere in the world may be made public, the expenditure shall be accounted for specifically. When the Secretary decides that an expenditure should not be made public, the Secretary shall make a certificate on the amount of the expenditure. The certificate is a sufficient voucher for the amount stated to have been spent.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab369e6f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258/s2/b/11/B"},"text":"Pub. L. 97–258, § 2(b)(11)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1057"},"text":"96 Stat. 1057","children":[],"tail":", § 7231; renumbered § 8631, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab369e70-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab369e71-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table