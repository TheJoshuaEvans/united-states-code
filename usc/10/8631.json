attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-08-29/ch417"},"text":"Aug. 29, 1916, ch. 417","children":[],"tail":" (2d proviso under heading “Pay, Miscellaneous”), "},{"tag":"html:a","attrib":{"href":"/us/stat/39/557"},"text":"39 Stat. 557","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “anywhere in the world” are substituted for “abroad and at home”, and the words “decides that an expenditure should not be made public” are substituted for “may think it advisable not to specify”, for clarity and consistency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab369e73-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab369e74-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8631, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/532"},"text":"70A Stat. 532","children":[],"tail":", prohibited any officer of Air Force who was engaged in procurement or sale of quartermaster supplies from dealing in said supplies, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/90/235/s7/b/1"},"text":"Pub. L. 90–235, § 7(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/763"},"text":"81 Stat. 763","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 8632, ",