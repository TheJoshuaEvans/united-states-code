{"tag":"section","attrib":{"id":"ida8e02af3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1507"},"text":null,"children":[{"tag":"num","attrib":{"value":"1507"},"text":"§ 1507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendation of status of death","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8e02af4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements Relating to Recommendation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A board appointed under section 1503, 1504, or 1505 of this title may not recommend that a person be declared dead unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8e02af5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1507/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" credible evidence exists to suggest that the person is dead;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8e02af6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1507/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States possesses no credible evidence that suggests that the person is alive; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8e02af7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1507/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" representatives of the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8e02af8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1507/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have made a complete search of the area where the person was last seen (unless, after making a good faith effort to obtain access to such area, such representatives are not granted such access); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8e02af9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1507/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have examined the records of the government or entity having control over the area where the person was last seen (unless, after making a good faith effort to obtain access to such records, such representatives are not granted such access).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8e02afa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submittal of Information on Death","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a board appointed under section 1503, 1504, or 1505 of this title makes a recommendation that a missing person be declared dead, the board shall include in the report of the board with respect to the person under that section the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8e02afb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1507/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed description of the location where the death occurred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8e02afc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1507/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement of the date on which the death occurred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8e02afd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1507/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the location of the body, if recovered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8e02afe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1507/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the body has been recovered and is not identifiable through visual means, a certification by a forensic pathologist that the body recovered is that of the missing person. In determining whether to make such a certification, the forensic pathologist shall consider, as determined necessary by the Secretary of the military department concerned, additional evidence and information provided by appropriate specialists in forensic medicine or other appropriate medical sciences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8e02aff-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s569/b/1"},"text":"Pub. L. 104–106, div. A, title V, § 569(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/347"},"text":"110 Stat. 347","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s578/e"},"text":"Pub. L. 104–201, div. A, title V, § 578(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2537"},"text":"110 Stat. 2537","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tV/s599/c"},"text":"Pub. L. 105–85, div. A, title V, § 599(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1768"},"text":"111 Stat. 1768","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8e02b00-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8e02b01-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8e02b02-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" added pars. (3) and (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" struck out pars. (3) and (4) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) A description of the location of the body, if recovered.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) If the body has been recovered and is not identifiable through visual means, a certification by a practitioner of an appropriate forensic science that the body recovered is that of the missing person.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
