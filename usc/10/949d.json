{"tag":"section","attrib":{"id":"ida836cc2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949d"},"text":null,"children":[{"tag":"num","attrib":{"value":"949d"},"text":"§ 949d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sessions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida836cc30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sessions Without Presence of Members","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida836cc31-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" At any time after the service of charges which have been referred for trial by military commission under this chapter, the military judge may call the military commission into session without the presence of the members for the purpose of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida836cc32-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949d/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hearing and determining motions raising defenses or objections which are capable of determination without trial of the issues raised by a plea of not guilty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida836cc33-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949d/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hearing and ruling upon any matter which may be ruled upon by the military judge under this chapter, whether or not the matter is appropriate for later consideration or decision by the members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida836cc34-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949d/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if permitted by regulations prescribed by the Secretary of Defense, receiving the pleas of the accused; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida836cc35-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949d/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing any other procedural function which may be performed by the military judge under this chapter or under rules prescribed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s949a"},"text":"section 949a of this title","children":[],"tail":" and which does not require the presence of the members."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida836cc36-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsections (b), (c), and (d), any proceedings under paragraph (1) shall be conducted in the presence of the accused, defense counsel, and trial counsel, and shall be made part of the record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida836cc37-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deliberation or Vote of Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the members of a military commission under this chapter deliberate or vote, only the members may be present.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida836cc38-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Closure of Proceedings","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida836cc39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The military judge may close to the public all or part of the proceedings of a military commission under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida836cc3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The military judge may close to the public all or a portion of the proceedings under paragraph (1) only upon making a specific finding that such closure is necessary to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida836cc3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949d/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect information the disclosure of which could reasonably be expected to cause damage to the national security, including intelligence or law enforcement sources, methods, or activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida836cc3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949d/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the physical safety of individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida836cc3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A finding under paragraph (2) may be based upon a presentation, including a presentation ex parte or in camera, by either trial counsel or defense counsel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida836cc3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion of Accused From Certain Proceedings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The military judge may exclude the accused from any portion of a proceeding upon a determination that, after being warned by the military judge, the accused persists in conduct that justifies exclusion from the courtroom—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida836cc3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure the physical safety of individuals; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida836cc40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent disruption of the proceedings by the accused.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida836cc41-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tXVIII/s1802"},"text":"Pub. L. 111–84, div. A, title XVIII, § 1802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2585"},"text":"123 Stat. 2585","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida836cc42-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida836cc43-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida836cc44-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 949d, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/366/s3/a/1"},"text":"Pub. L. 109–366, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2611"},"text":"120 Stat. 2611","children":[],"tail":", related to sessions of military commissions, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
