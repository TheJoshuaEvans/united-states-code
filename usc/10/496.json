{"tag":"section","attrib":{"id":"ida7c93c91-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s496"},"text":null,"children":[{"tag":"num","attrib":{"value":"496"},"text":"§ 496.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of expansion of nuclear forces of other countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7c93c92-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s496/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report and Certification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days before the President recommends any reductions to the nuclear forces of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7c93c93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s496/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the President shall transmit to the appropriate congressional committees a report detailing, for each country with nuclear weapons, the high-, medium-, and low- confidence assessment of the intelligence community (as defined in section 3(4) of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003/4"},"text":"50 U.S.C. 3003(4)","children":[],"tail":")) with respect to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7c93c94-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s496/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of each type of nuclear weapons possessed by such country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7c93c95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s496/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the modernization plans for such weapons of such country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7c93c96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s496/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production capacity of nuclear warheads and strategic delivery systems (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s495/e/2"},"text":"section 495(e)(2) of this title","children":[],"tail":") of such country;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7c93c97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s496/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nuclear doctrine of such country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7c93c98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s496/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of such recommended reductions on the deterrence and extended deterrence capabilities of the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c93c99-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s496/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Commander of the United States Strategic Command shall certify to the appropriate congressional committees whether such recommended reductions in the nuclear forces of the United States will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7c93c9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s496/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" impair the ability of the United States to address—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida7c93c9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s496/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unplanned strategic or geopolitical events; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7c93c9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s496/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical challenge; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7c93c9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s496/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" degrade the deterrence or assurance provided by the United States to friends and allies of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7c93c9e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s496/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The reports required by subsection (a)(1) shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7c93c9f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s496/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate Congressional Committees Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees” means the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7c93ca0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s496/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The congressional defense committees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c93ca1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s496/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Foreign Affairs of the House of Representatives and the Committee on Foreign Relations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7c93ca2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1036/a"},"text":"Pub. L. 112–239, div. A, title X, § 1036(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1924"},"text":"126 Stat. 1924","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1071/c/10"},"text":"Pub. L. 113–291, div. A, title X, § 1071(c)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3509"},"text":"128 Stat. 3509","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7c93ca3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7c93ca4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7c93ca5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003/4"},"text":"50 U.S.C. 3003(4)","children":[],"tail":")” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s401a/4"},"text":"50 U.S.C. 401a(4)","children":[],"tail":")” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
