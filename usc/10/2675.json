{"tag":"section","attrib":{"id":"ida9a61355-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2675"},"text":null,"children":[{"tag":"num","attrib":{"value":"2675"},"text":"§ 2675.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leases: foreign countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9a61356-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2675/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lease Authority; Duration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of a military department may acquire by lease in foreign countries structures and real property relating to structures that are needed for military purposes other than for military family housing. A lease under this section may be for a period of up to 10 years, or 15 years in the case of a lease in Korea, and the rental for each yearly period may be paid from funds appropriated to that military department for that year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9a61357-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2675/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Appropriations available to the Department of Defense for operation and maintenance or construction may be used for the acquisition of interests in land under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9a61358-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/51"},"text":"Pub. L. 85–861, § 1(51)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1460"},"text":"72 Stat. 1460","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/511/tVI/s608"},"text":"Pub. L. 91–511, title VI, § 608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1224"},"text":"84 Stat. 1224","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/107/tVI/s607/10"},"text":"Pub. L. 94–107, title VI, § 607(10)","children":[],"tail":", (11), "},{"tag":"date","attrib":{"date":"1975-10-07"},"text":"Oct. 7, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/567"},"text":"89 Stat. 567","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/82/tV/s505/a"},"text":"Pub. L. 95–82, title V, § 505(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-01"},"text":"Aug. 1, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/371"},"text":"91 Stat. 371","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/356/tV/s503/b"},"text":"Pub. L. 95–356, title V, § 503(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-08"},"text":"Sept. 8, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/579"},"text":"92 Stat. 579","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/125/tV/s502/b"},"text":"Pub. L. 96–125, title V, § 502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-26"},"text":"Nov. 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/940"},"text":"93 Stat. 940","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/418/tV/s504/b"},"text":"Pub. L. 96–418, title V, § 504(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1765"},"text":"94 Stat. 1765","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/99/tVI/s604"},"text":"Pub. L. 97–99, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-23"},"text":"Dec. 23, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1374"},"text":"95 Stat. 1374","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/214/s8"},"text":"Pub. L. 97–214, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-07-12"},"text":"July 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/174"},"text":"96 Stat. 174","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXIV/s1405/40"},"text":"Pub. L. 98–525, title XIV, § 1405(40)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2624"},"text":"98 Stat. 2624","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIII/s1322/a/11"},"text":"Pub. L. 101–510, div. A, title XIII, § 1322(a)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1671"},"text":"104 Stat. 1671","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dB/tXXVIII/s2804/b"},"text":"Pub. L. 108–136, div. B, title XXVIII, § 2804(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1719"},"text":"117 Stat. 1719","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dB/tXXVIII/s2821/d/3"},"text":"Pub. L. 108–375, div. B, title XXVIII, § 2821(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2130"},"text":"118 Stat. 2130","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dB/tXXVIII/s2824"},"text":"Pub. L. 109–364, div. B, title XXVIII, § 2824","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2476"},"text":"120 Stat. 2476","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9a61359-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida9a6135a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida9a6135b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2675","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5:171z–3.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-08-03/ch939/s417"},"text":"Aug. 3, 1956, ch. 939, § 417","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/70/1018"},"text":"70 Stat. 1018","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “that are not located on a military base” are substituted for the words “off-base”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9a6135c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9a6135d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" substituted “10 years” for “five years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" inserted “or 15 years in the case of a lease in Korea,” after “five years,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" struck out “(a)” before “The Secretary” and struck out subsec. (b) which read as follows: “A lease may not be entered into under this section for structures or related real property in any foreign country if the average estimated annual rental during the term of the lease if more than $250,000 until after the expiration of 30 days from the date upon which a report of the facts concerning the proposed lease is submitted to the Committees on Armed Services of the Senate and House of Representatives.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525"},"text":"Pub. L. 98–525","children":[],"tail":" substituted “30” for “thirty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/214/s8/a"},"text":"Pub. L. 97–214, § 8(a)","children":[],"tail":", substituted provisions that the Secretary of a military department may acquire by lease in foreign countries, structures and real property needed for military purposes other than for military family housing for up to a period of five years with the rental to be paid from funds appropriated to that military department for that year, for former provisions that had allowed such leases including leases for military family housing and in the latter case for a period of up to 10 years."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/214/s8/b"},"text":"Pub. L. 97–214, § 8(b)","children":[],"tail":", struck out “or any other provision of law” after “into under this section”, and “, family housing facilities,” after “for structures”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/214/s8/c"},"text":"Pub. L. 97–214, § 8(c)","children":[],"tail":", struck out subsec. (c) which provided that a statement in a lease that the requirements of this section have been met, or that the lease is not subject to this section is conclusive, and subsec. (d) which related to limitations on expenditures for the rental of family housing in foreign countries and limitations on the number of family housing units which may be leased in a foreign country at any one time."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/99/s604/1"},"text":"Pub. L. 97–99, § 604(1)","children":[],"tail":", substituted “250” for “150”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/99/s604/2"},"text":"Pub. L. 97–99, § 604(2)","children":[],"tail":", substituted “22,000” for “17,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/418"},"text":"Pub. L. 96–418","children":[],"tail":" substituted “Expenditures for the rental of family housing in foreign countries (including the cost of utilities and maintenance and operation) may not exceed $1,115 per month for any unit” for “The average unit rental for Department of Defense family housing acquired by lease in foreign countries may not exceed $550 per month for the Department, and in no event shall the rental for any one unit exceed $970 per month, including the costs of operation, maintenance, and utilities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/125/s502/b/1"},"text":"Pub. L. 96–125, § 502(b)(1)","children":[],"tail":", substituted “$550” for “$485” and “$970” for “$850”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/125/s502/b/2"},"text":"Pub. L. 96–125, § 502(b)(2)","children":[],"tail":", substituted “17,000” for “18,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/356/s503/b/1"},"text":"Pub. L. 95–356, § 503(b)(1)","children":[],"tail":", substituted “$485” for “$435” and “$850” for “$760”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/356/s503/b/2"},"text":"Pub. L. 95–356, § 503(b)(2)","children":[],"tail":", substituted “18,000” for “15,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/82/s505/a/1"},"text":"Pub. L. 95–82, § 505(a)(1)","children":[],"tail":", inserted provisions relating to military family housing facilities and real property related thereto."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/82/s505/a/2"},"text":"Pub. L. 95–82, § 505(a)(2)","children":[],"tail":", inserted “or any other provision of law for structures, family housing facilities, or related real property in any foreign country,” after “section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/82/s505/a/3"},"text":"Pub. L. 95–82, § 505(a)(3)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/107"},"text":"Pub. L. 94–107","children":[],"tail":" struck out reference to structures not on a military base in section catchline, and struck out “that are not located on a military base and” after “structures and real property relating thereto” in subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/511"},"text":"Pub. L. 91–511","children":[],"tail":" designated existing provisions as subsec. (a) and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9a6135e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9a6135f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/214"},"text":"Pub. L. 97–214","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", and applicable to military construction projects, and to construction and acquisition of military family housing authorized before, on, or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/214/s12/a"},"text":"section 12(a) of Pub. L. 97–214","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2801"},"text":"section 2801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9a61360-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/418/tVI/s608"},"text":"Pub. L. 96–418, title VI, § 608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1774"},"text":"94 Stat. 1774","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/418/tVI/s608"},"text":"“Titles I, II, III, IV, and V [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2775"},"text":"section 2775 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1594h–3"},"text":"section 1594h–3 of Title 42","children":[],"tail":", The Public Health and Welfare, amending this section, "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2686"},"text":"section 2686 of this title","children":[],"tail":", and sections 1594a–1 and 1594h–2 of Title 42, and repealing provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4593"},"text":"section 4593 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"October 1, 1980","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9a61361-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/82/tV/s505/c"},"text":"Pub. L. 95–82, title V, § 505(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-01"},"text":"Aug. 1, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/372"},"text":"91 Stat. 372","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/82/tV/s505/c"},"text":"“The amendments made by subsection (a) [amending this section] and the repeal made by subsection (b) [repealing ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/166/s507/b"},"text":"section 507(b) of Pub. L. 93–166","children":[],"tail":", which was not classified to the Code] shall take effect "},{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
