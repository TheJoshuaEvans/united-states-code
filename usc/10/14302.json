{"tag":"section","attrib":{"id":"idabb2ab4e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14302"},"text":null,"children":[{"tag":"num","attrib":{"value":"14302"},"text":"§ 14302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion zones","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabb2ab4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Promotion Zones Generally","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, a promotion zone is an eligibility category for the consideration of officers by a mandatory promotion board. A promotion zone consists of those officers on the reserve active-status list who are in the same grade and competitive category and who meet the requirements of both paragraphs (1) and (2) or the requirements of paragraph (3), as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb2ab50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14302/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabb2ab51-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14302/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of officers in grades below colonel, for reserve officers of the Army, Air Force, and Marine Corps, or captain, for officers of the Navy Reserve, those who have neither (i) failed of selection for promotion to the next higher grade, nor (ii) been removed from a list of officers recommended for promotion to that grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabb2ab52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14302/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of officers in the grade of colonel or brigadier general, for reserve officers of the Army and Marine Corps, or in the grade of captain or rear admiral (lower half), for reserve officers of the Navy, those who have neither (i) been recommended for promotion to the next higher grade when considered in the promotion zone, nor (ii) been removed from a list of officers recommended for promotion to that grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb2ab53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14302/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Those officers who are senior to the officer designated by the Secretary of the military department concerned to be the junior officer in the promotion zone eligible for consideration for promotion to the next higher grade and the officer so designated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb2ab54-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14302/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Those officers who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabb2ab55-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14302/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have been selected from below the zone for promotion to the next higher grade or by a vacancy promotion board, but whose names were removed from the list of officers recommended for promotion to that next higher grade resulting from that selection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabb2ab56-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14302/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have not failed of selection for promotion to that next higher grade; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabb2ab57-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14302/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are senior to the officer designated by the Secretary of the military department concerned to be the junior officer in the promotion zone eligible for consideration for promotion to that next higher grade and the officer so designated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb2ab58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers Above the Zone","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Officers on the reserve active-status list are considered to be above the promotion zone for a grade and competitive category if they—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb2ab59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are eligible for consideration for promotion to the next higher grade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb2ab5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are in the same grade as those officers in the promotion zone for that competitive category; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb2ab5b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14302/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are senior to the senior officer in the promotion zone for that competitive category.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb2ab5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers Below the Zone","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Officers on the reserve active-status list are considered to be below the promotion zone for a grade and competitive category if they—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb2ab5d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14302/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are eligible for consideration for promotion to the next higher grade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb2ab5e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14302/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are in the same grade as those officers in the promotion zone for that competitive category; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb2ab5f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14302/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are junior to the junior officer in the promotion zone for that competitive category.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabb2ab60-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2932"},"text":"108 Stat. 2932","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s515/b/1/RR"},"text":"Pub. L. 109–163, div. A, title V, § 515(b)(1)(RR)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3234"},"text":"119 Stat. 3234","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb2ab61-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabb2ab62-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabb2ab63-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “Navy Reserve” for “Naval Reserve”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabb2ab64-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabb2ab65-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691/b/1"},"text":"section 1691(b)(1) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
