{"tag":"section","attrib":{"id":"ida8db6f83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1485"},"text":null,"children":[{"tag":"num","attrib":{"value":"1485"},"text":"§ 1485.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dependents of members of armed forces","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8db6f84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1485/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may, if a dependent of a member of an armed force dies while the member is on active duty (other than for training), provide for, and pay the necessary expenses of, transporting the remains of the deceased dependent to the home of the decedent or to any other place that the Secretary determines to be the appropriate place of interment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8db6f85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1485/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may furnish mortuary services and supplies, on a reimbursable basis, for persons covered by subsection (a), if (1) that action is practicable, and (2) local commercial mortuary services and supplies are not available or the Secretary believes that their cost is prohibitive.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8db6f86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1485/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reimbursement for mortuary services and supplies furnished under this section shall be collected and credited to appropriations available, at the time of reimbursement, for those services and supplies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8db6f87-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/114"},"text":"70A Stat. 114","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/150/s1/1"},"text":"Pub. L. 89–150, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-28"},"text":"Aug. 28, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/585"},"text":"79 Stat. 585","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8db6f88-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8db6f89-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida8db6f8a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1485(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1485(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5:2157 (1st sentence, as applicable to armed forces).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"5:2157 (2d sentence, as applicable to armed forces).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1954-07-15/ch507/s7/a"},"text":"July 15, 1954, ch. 507, § 7(a)","children":[],"tail":" (as applicable to armed forces), "},{"tag":"html:a","attrib":{"href":"/us/stat/68/479"},"text":"68 Stat. 479","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1485(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5:2157 (less 1st and 2d sentences, as applicable to armed forces).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “a member of an armed force” are substituted for the words “military personnel”. The words “the continental limits * * * or in Alaska” are omitted as covered by the definition of “United States” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/1"},"text":"section 101(1) of this title","children":[],"tail":". The words “while traveling” are substituted for the words “while in transit”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “services” is substituted for the word “facilities”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “the authority of” and “the payments of” are omitted as surplusage. The words “at the time of reimbursement” are substituted for the word “current”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8db6f8b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8db6f8c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/150"},"text":"Pub. L. 89–150","children":[],"tail":" struck out “; death while outside United States” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/150"},"text":"Pub. L. 89–150","children":[],"tail":" substituted provision for payment of transportation expenses of remains of deceased dependent of a member of an armed force while the member is on active duty (other than for training), for former provision for payment of the expenses where the member of the armed force is on active duty at a place outside the United States and the dependent dies while residing with that member or while traveling to or from that place."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
