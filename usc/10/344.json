{"tag":"section","attrib":{"id":"ida7a560d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s344"},"text":null,"children":[{"tag":"num","attrib":{"value":"344"},"text":"§ 344.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation in multinational centers of excellence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7a560d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s344/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participation Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may, with the concurrence of the Secretary of State, authorize the participation of members of the armed forces and Department of Defense civilian personnel in any multinational center of excellence for purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a560d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s344/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing the ability of military forces and civilian personnel of the nations participating in such center to engage in joint exercises or coalition or international military operations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a560d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s344/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving interoperability between the armed forces and the military forces of friendly foreign nations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a560d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s344/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Memorandum of Understanding","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a560d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s344/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The participation of members of the armed forces or Department of Defense civilian personnel in a multinational center of excellence under subsection (a) shall be in accordance with the terms of one or more memoranda of understanding entered into by the Secretary of Defense, with the concurrence of the Secretary of State, or entered into by the Secretary of State, and the foreign nation or nations concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a560d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s344/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If Department of Defense facilities, equipment, or funds are used to support a multinational center of excellence under subsection (a), the memoranda of understanding under paragraph (1) with respect to that center shall provide details of any cost-sharing arrangement or other funding arrangement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a560d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s344/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Appropriated Funds","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a560d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s344/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Funds appropriated to the Department of Defense for operation and maintenance are available as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a560da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s344/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To pay the United States share of the operating expenses of any multinational center of excellence in which the United States participates under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a560db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s344/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To pay the costs of the participation of members of the armed forces and Department of Defense civilian personnel in multinational centers of excellence under this section, including the costs of expenses of such participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a560dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s344/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No funds may be used under this section to fund the pay or salaries of members of the armed forces and Department of Defense civilian personnel who participate in multinational centers of excellence under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a560dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s344/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Department of Defense Facilities and Equipment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Facilities and equipment of the Department of Defense may be used for purposes of the support of multinational centers of excellence under this section that are hosted by the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a560de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s344/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days before the date on which the Secretary of Defense authorizes participation under subsection (a) in a new multinational center of excellence, the Secretary shall notify the congressional defense committees of such participation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a560df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s344/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multinational Center Of Excellence Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “multinational center of excellence” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a560e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s344/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an entity sponsored by one or more nations that is accredited and approved by the Military Committee of the North Atlantic Treaty Organization (NATO) as offering recognized expertise and experience to personnel participating in the activities of such entity for the benefit of NATO by providing such personnel opportunities to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a560e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s344/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance education and training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a560e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s344/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve interoperability and capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a560e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s344/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in the development of doctrine;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a560e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s344/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" validate concepts through experimentation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a560e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s344/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the European Centre of Excellence for Countering Hybrid Threats, established in 2017 and located in Helsinki, Finland; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a560e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s344/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the International Special Training Centre, established in 1979 and located in Pfullendorf, Germany.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7a560e7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title XII, § 1232(a)(1), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4637"},"text":"122 Stat. 4637","children":[],"tail":", § 2350m; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/f/25"},"text":"Pub. L. 112–239, div. A, title X, § 1076(f)(25)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1953"},"text":"126 Stat. 1953","children":[],"tail":"; renumbered § 344 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1241/g"},"text":"Pub. L. 114–328, div. A, title XII, § 1241(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2507"},"text":"130 Stat. 2507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII/s1206/a"},"text":"Pub. L. 116–283, div. A, title XII, § 1206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3912"},"text":"134 Stat. 3912","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tXII/s1203"},"text":"Pub. L. 117–263, div. A, title XII, § 1203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2826"},"text":"136 Stat. 2826","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7a560e8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7a560e9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7a560ea-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1206/a/1"},"text":"Pub. L. 116–283, § 1206(a)(1)","children":[],"tail":"–(3), in section catchline, substituted “multinational centers of excellence” for “multinational military centers of excellence” and, in text, substituted “multinational center of excellence” for “multinational military center of excellence” and “multinational centers of excellence” for “multinational military centers of excellence” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1206/a/4"},"text":"Pub. L. 116–283, § 1206(a)(4)","children":[],"tail":", inserted “or entered into by the Secretary of State,” after “Secretary of State,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/283/s1206/a/7"},"text":"Pub. L. 115–283, § 1206(a)(7)","children":[],"tail":", added subsec. (e). Former subsec. (e) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1206/a/5/B"},"text":"Pub. L. 116–283, § 1206(a)(5)(B)","children":[],"tail":"–(F), substituted “means—” for “means”, designated remainder of existing provisions as par. (1), redesignated former pars. (1) to (4) as subpars. (A) to (D), respectively, of par. (1) and realigned margins, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1206/a/5/A"},"text":"Pub. L. 116–283, § 1206(a)(5)(A)","children":[],"tail":", substituted “Multinational Center Of Excellence” for “Multinational Military Center of Excellence” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1206/a/6"},"text":"Pub. L. 116–283, § 1206(a)(6)","children":[],"tail":", redesignated subsec. (e) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1241/g/1"},"text":"Pub. L. 114–328, § 1241(g)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2350m"},"text":"section 2350m of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1241/g/2"},"text":"Pub. L. 114–328, § 1241(g)(2)","children":[],"tail":", redesignated subsec. (f) as (e) and struck out former subsec. (e) which required the Secretary of Defense, not later than October 31 of each year, to submit to the Committee on Armed Services of the Senate and the Committee on Armed Services of the House of Representatives a report on the use of the authority in this section during the preceding fiscal year."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" substituted “Not later than October 31 each year” for “Not later than "},{"tag":"date","attrib":{"date":"2009-10-31"},"text":"October 31, 2009","children":[],"tail":", and annually thereafter”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7a560eb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida7a560ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title XII, § 1232(c), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4639"},"text":"122 Stat. 4639","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/417"},"text":"“The amendments made by this section [enacting this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2008-10-01"},"text":"October 1, 2008","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
