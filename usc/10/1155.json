{"tag":"section","attrib":{"id":"ida8a6f232-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1155"},"text":null,"children":[{"tag":"num","attrib":{"value":"1155"},"text":"§ 1155.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8a6f233-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1155/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Before Separation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days before a member retires, is released, is discharged, or otherwise separates from the armed forces (or as soon as is practicable in the case of an unanticipated separation), the Secretary concerned shall provide that member with a current assessment of all benefits to which that member may be entitled under laws administered by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8a6f234-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1155/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8a6f235-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1155/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8a6f236-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1155/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statement for Reserves","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall provide a member of a reserve component with a current assessment of benefits described in subsection (a) upon release of that member from active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8a6f237-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tV/s522/a"},"text":"Pub. L. 115–232, div. A, title V, § 522(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1756"},"text":"132 Stat. 1756","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
