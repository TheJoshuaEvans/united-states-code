{"tag":"section","attrib":{"id":"idab61a5ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9068"},"text":null,"children":[{"tag":"num","attrib":{"value":"9068"},"text":"§ 9068.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Air Force Global Strike Command","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab61a5cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9068/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is in the Air Force a major command, which shall be known as Air Force Global Strike Command.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab61a5cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9068/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commander","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab61a5cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9068/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commander of Air Force Global Strike Command shall hold the grade of general while serving in that position, without vacating that officer’s permanent grade. The commander shall be appointed to that grade by the President, by and with the advice and consent of the Senate, for service in that position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab61a5ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9068/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The commander shall serve as the single accountable officer responsible to the Secretary of the Air Force and the Chief of Staff of the Air Force for carrying out all aspects of Air Force nuclear and long-range strike missions in support of United States Strategic Command, including such aspects described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab61a5cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9068/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commander of Air Force Global Strike Command shall be responsible for carrying out all aspects and activities of the Air Force nuclear and long-range strike missions in support of United States Strategic Command. Such aspects include nuclear weapons, nuclear weapon delivery systems, long-range strike bomber aircraft, and the nuclear command, control, and communication systems. Such activities include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab61a5d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9068/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing combat-ready nuclear and long-range conventional strike forces in support of Presidential and combatant commander directives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab61a5d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9068/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Administrating, organizing, training, and equipping assigned and gained forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab61a5d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9068/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assessing the readiness of assigned and gained forces and submitting to the Secretary and the Air Force Chief of Staff periodic reports with respect to such assessments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab61a5d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9068/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Leading development in the Air Force of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab61a5d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9068/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" military requirements with respect to nuclear and long-range strike missions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab61a5d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9068/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" budget proposals necessary to carry out the missions of the Air Force Global Strike Command;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab61a5d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9068/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" long-range investment plans and priorities to sustain, modernize, and recapitalize assigned forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab61a5d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9068/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employment strategies, concepts, tactics, techniques, and procedures with respect to strategic deterrence, nuclear deterrence operation, and long-range strike operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab61a5d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9068/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advising the Secretary, as necessary, on the adequacy of resources of the Department of the Air Force dedicated to support and execute nuclear missions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab61a5d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9068/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other functions as the Secretary determines necessary or appropriate for execution of nuclear deterrence and long-range strike missions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab61a5da-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVI/s1642/a"},"text":"Pub. L. 119–60, div. A, title XVI, § 1642(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1191"},"text":"139 Stat. 1191","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab61a5db-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab61a5dc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab61a5dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9068"},"text":"section 9068 of this title","children":[],"tail":" resulted from the redesignation of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9084"},"text":"section 9084 of this title","children":[],"tail":" as "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9068"},"text":"section 9068 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/s952/b/1"},"text":"section 952(b)(1) of Pub. L. 116–92","children":[],"tail":". Such section 9068 was renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9083"},"text":"section 9083 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/s952/e"},"text":"section 952(e) of Pub. L. 116–92","children":[],"tail":" and subsequently repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s921/a"},"text":"Pub. L. 116–283, div. A, title IX, § 921(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3804"},"text":"134 Stat. 3804","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 9069 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9064"},"text":"section 9064 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 9074 was renumbered ","children":[{"tag":"ref","attr