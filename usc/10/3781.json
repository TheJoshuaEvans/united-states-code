{"tag":"section","attrib":{"id":"idaa377d23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3781"},"text":null,"children":[{"tag":"num","attrib":{"value":"3781"},"text":"§ 3781.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical data: contractor justification for restrictions; review of restrictions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa377d24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3781/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracts Covered by Subchapter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subchapter applies to any contract for supplies or services entered into by the Department of Defense that includes provisions for the delivery of technical data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa377d25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3781/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contractor Justification for Restrictions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contract subject to this subchapter shall provide that a contractor under the contract and any subcontractor under the contract at any tier shall be prepared to furnish to the contracting officer a written justification for any use or release restriction (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3786"},"text":"section 3786 of this title","children":[],"tail":") asserted by the contractor or subcontractor."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa377d26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3781/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of Restrictions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa377d27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3781/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall ensure that there is a thorough review of the appropriateness of any use or release restriction asserted with respect to technical data by a contractor or subcontractor at any tier under a contract subject to this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa377d28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3781/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The review of an asserted use or release restriction under paragraph (1) shall be conducted before the end of the three-year period beginning on the later of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa377d29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3781/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which final payment is made on the contract under which the technical data is required to be delivered; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa377d2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3781/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the technical data is delivered under the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa377d2b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1833/g"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1833(g)","children":[],"tail":", (h), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4231"},"text":"134 Stat. 4231","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa377d2c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa377d2d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa377d2e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsecs. (a), (b), and (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2321"},"text":"section 2321 of this title","children":[],"tail":", which were transferred to this section and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/h"},"text":"Pub. L. 116–283, § 1833(h)","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s7/a/5/A/ii"},"text":"Pub. L. 100–26, § 7(a)(5)(A)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/276"},"text":"101 Stat. 276","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa377d2f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag"