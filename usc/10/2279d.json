{"tag":"section","attrib":{"id":"ida9633d09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279d"},"text":"§ 2279d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on construction on United States territory of satellite positioning ground monitoring stations of certain foreign governments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9633d0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9633d0b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9633d0c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President may not authorize or permit the construction of a global navigation satellite system ground monitoring station directly or indirectly controlled by a foreign government (including a ground monitoring station owned, operated, or controlled on behalf of a foreign government) in the territory of the United States unless the Secretary of Defense and the Director of National Intelligence jointly certify to the appropriate congressional committees that such ground monitoring station will not possess the capability or potential to be used for the purpose of gathering intelligence in the United States or improving any foreign weapon system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9633d0d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each certification under subparagraph (A) shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9633d0e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National security waiver","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense and the Director of National Intelligence may jointly waive the certification requirement in paragraph (1) for a ground monitoring station if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9633d0f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary and the Director jointly determine that the waiver is in the vital interests of the national security of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9633d10-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary and the Director ensure that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9633d11-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all data collected or transmitted from ground monitoring stations covered by the waiver are not encrypted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9633d12-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all persons involved in the construction, operation, and maintenance of such ground monitoring stations are United States persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9633d13-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such ground monitoring stations are not located in geographic proximity to sensitive United States national security sites;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9633d14-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States approves all equipment to be located at such ground monitoring stations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9633d15-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/a/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate actions are taken to ensure that any such ground monitoring stations do not pose a cyber espionage or other threat, including intelligence or counterintelligence, to the national security of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9633d16-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/a/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any improvements to such ground monitoring stations do not reduce or compete with the advantages of Global Positioning System technology for users.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9633d17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each waiver under paragraph (2), the Secretary of Defense and the Director of National Intelligence, in consultation with the Secretary of State, shall jointly submit to the appropriate congressional committees a report containing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9633d18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reason why it is not possible to provide the certification under paragraph (1) for the ground monitoring stations covered by such waiver;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9633d19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the impact of the exercise of authority under paragraph (2) with respect to such ground monitoring stations on the national security of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9633d1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the means to be used to mitigate any such impact to the United States for the duration that such ground monitoring stations are operated in the territory of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9633d1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information in connection with the waiver that the Secretary of Defense and the Director of National Intelligence, in consultation with the Secretary of State, consider appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9633d1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days before the exercise of the authority to waive under paragraph (2) the certification requirement under paragraph (1) for a ground monitoring station, the Secretary of Defense and the Director of National Intelligence shall jointly provide to the appropriate congressional committees notice of the exercise of such authority and the report required under paragraph (3) with respect to such ground monitoring station.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9633d1d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate congressional committees defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9633d1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services, the Committee on Foreign Relations, and the Select Committee on Intelligence of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9633d1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services, the committee on Foreign Affairs, and the Permanent Select Committee on Intelligence of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9633d20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The limitation in subsection (a) shall not apply to foreign governments that are allies of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9633d21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The limitation in subsection (a) shall terminate on ","children":[{"tag":"date","attrib":{"date":"2023-12-31"},"text":"December 31, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9633d22-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tXVI/s1602"},"text":"Pub. L. 115–91, div. A, title XVI, § 1602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1721"},"text":"131 Stat. 1721","children":[],"tail":", § 2279c; renumbered § 2279d, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tX/s1081/a/18/A"},"text":"Pub. L. 115–232, div. A, title X, § 1081(a)(18)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1984"},"text":"132 Stat. 1984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXVII/s1731/a/35"},"text":"Pub. L. 116–92, div. A, title XVII, § 1731(a)(35)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1814"},"text":"133 Stat. 1814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9633d23-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9633d24-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida9633d25-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1602/b"},"text":"Section 1602(b) of Pub. L. 113–66","children":[],"tail":", formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2281"},"text":"section 2281 of this title","children":[],"tail":", which was transferred to and inserted as the first subsection of this section, redesignated as subsec. (a), and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1602/b"},"text":"Pub. L. 115–91, § 1602(b)","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tXVI/s1602/b"},"text":"Pub. L. 113–66, div. A, title XVI, § 1602(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/943"},"text":"127 Stat. 943","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9633d26-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" struck out period at end of section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2279c"},"text":"section 2279c of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1602/b"},"text":"Pub. L. 115–91, § 1602(b)","children":[],"tail":", transferred "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1602/b"},"text":"section 1602(b) of Pub. L. 113–66","children":[],"tail":" to this section, inserted it as the first subsection of this section, designated it as subsec. (a), substituted “Limitation” for “Limitation on Construction on United States Territory of Satellite Positioning Ground Monitoring Stations of Foreign Governments” in heading, and struck out par. (6). Prior to amendment, text of par. (6) read as follows: “Effective on the date that is five years after the date of the enactment of this Act, paragraphs (1) through (5) are repealed.” See Codification note above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
