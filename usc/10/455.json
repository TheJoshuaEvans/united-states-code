{"tag":"section","attrib":{"id":"ida7bf9f6d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s455"},"text":null,"children":[{"tag":"num","attrib":{"value":"455"},"text":"§ 455.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maps, charts, and geomatics data: public availability; exceptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7bf9f6e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s455/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Geospatial-Intelligence Agency shall offer for sale maps and charts at scales of 1:500,000 and smaller, except those withheld in accordance with subsection (b) or those specifically authorized under criteria established by Executive order to be kept secret in the interest of national defense or foreign policy and in fact properly classified pursuant to such Executive order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bf9f6f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s455/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bf9f70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s455/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of law, the Secretary of Defense may withhold from public disclosure any geomatics product in the possession of, or under the control of, the Department of Defense—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7bf9f71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s455/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that was obtained or produced, or that contains information that was provided, pursuant to an international agreement that restricts disclosure of such product or information to government officials of the agreeing parties or that restricts use of such product or information to government purposes only;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bf9f72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s455/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that contains information that the Secretary of Defense has determined in writing would, if disclosed, reveal sources and methods, or capabilities, used to obtain source material for production of the geomatics product; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bf9f73-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s455/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that contains information that the Director of the National Geospatial-Intelligence Agency has determined in writing would, if disclosed, jeopardize or interfere with ongoing military or intelligence operations, reveal military operational or contingency plans, or reveal, jeopardize, or compromise military or intelligence capabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bf9f74-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s455/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the term “geomatics product” means imagery, imagery intelligence, or geospatial information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bf9f75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s455/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bf9f76-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s455/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Regulations to implement this section (including any amendments to such regulations) shall be published in the Federal Register for public comment for a period of not less than 30 days before they take effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bf9f77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s455/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Regulations under this section shall address the conditions under which release of geomatics products authorized under subsection (b) to be withheld from public disclosure would be appropriate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7bf9f78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s455/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of allies of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bf9f79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s455/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of qualified United States contractors (including contractors that are small business concerns) who need such products for use in the performance of contracts with the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7bf9f7a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/88/tV/s502/a/1"},"text":"Pub. L. 102–88, title V, § 502(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/435"},"text":"105 Stat. 435","children":[],"tail":", § 2796; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/359/tV/s502"},"text":"Pub. L. 103–359, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3430"},"text":"108 Stat. 3430","children":[],"tail":"; renumbered § 455 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXI/s1112/b"},"text":"Pub. L. 104–201, div. A, title XI, § 1112(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2682"},"text":"110 Stat. 2682","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tIX/s933/a"},"text":"Pub. L. 105–85, div. A, title IX, § 933(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1866"},"text":"111 Stat. 1866","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1074], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–280; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tIX/s921/d/2/A"},"text":"Pub. L. 108–136, div. A, title IX, § 921(d)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1568"},"text":"117 Stat. 1568","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVI/s1621/d/1"},"text":"Pub. L. 116–283, div. A, title XVI, § 1621(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4053"},"text":"134 Stat. 4053","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7bf9f7b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7bf9f7c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7bf9f7d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “geomatics” for “geodetic” in section catchline and wherever appearing in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsecs. (a), (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" substituted “National Geospatial-Intelligence Agency” for “National Imagery and Mapping Agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" substituted “, reveal military operational or contingency plans, or reveal, jeopardize, or compromise military or intelligence capabilities” for “or reveal military operational or contingency plans”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s933/a"},"text":"Pub. L. 105–85, § 933(a)","children":[],"tail":", inserted “, or capabilities,” after “methods”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s933/b/1"},"text":"Pub. L. 105–85, § 933(b)(1)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “In this subsection, the term ‘geodetic product’ means any map, chart, geodetic data, or related product.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2796"},"text":"section 2796 of this title","children":[],"tail":" as this section and substituted “National Imagery and Mapping Agency” for “Defense Mapping Agency” in subsecs. (a) and (b)(1)(C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/359"},"text":"Pub. L. 103–359","children":[],"tail":" inserted “jeopardize or interfere with ongoing military or intelligence operations or” after “disclosed,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7bf9f7e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7bf9f7f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1124"},"text":"section 1124 of Pub. L. 104–201","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s193"},"text":"section 193 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7bf9f80-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/88/tV/s502/b"},"text":"Pub. L. 102–88, title V, § 502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/436"},"text":"105 Stat. 436","children":[],"tail":", directed that regulations to implement section 2796 (now 455) of this title be published in the Federal Register for public comment in accordance with subsec. (c) of that section not later than 90 days after "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
