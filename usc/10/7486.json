{"tag":"section","attrib":{"id":"idaaf3efa1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7486"},"text":null,"children":[{"tag":"num","attrib":{"value":"7486"},"text":"§ 7486.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Academy of Health Sciences: admission of civilians in physician assistant training program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaf3efa2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7486/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Army may, pursuant to an agreement entered into with an accredited institution of higher education—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaf3efa3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7486/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit students of the institution to attend the didactic portion of the physician assistant training program conducted by the Army Medical Department at the Academy of Health Sciences at Fort Sam Houston, Texas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf3efa4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7486/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept from the institution academic services to support the physician assistant training program at the Academy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf3efa5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7486/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement for Exchange of Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An agreement entered into with an institution of higher education under this section shall require the institution, in exchange for services provided under paragraph (1) of subsection (a), to provide academic services described in paragraph (2) of such subsection that the Secretary and authorized representatives of the institution consider appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf3efa6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7486/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection of Students","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In consultation with the authorized representatives of the institution of higher education concerned, the Secretary shall prescribe the qualifications and methods of selection for students of the institution to receive instruction at the Academy under this section. The qualifications shall be comparable to those generally required for admission to the physician assistant training program at the Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf3efa7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7486/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rules of Attendance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as the Secretary determines necessary, a student who receives instruction at the Academy under this section shall be subject to the same regulations governing attendance, discipline, discharge, and dismissal as apply to other persons attending the Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf3efa8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7486/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaf3efa9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7486/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That the Army Medical Department, in carrying out an agreement under this section, does not incur costs in excess of the costs that the department would incur to obtain, by means other than the agreement, academic services that are comparable to those provided by the institution pursuant to the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf3efaa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7486/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That attendance of civilian students at the Academy under this section does not cause a decrease in the number of members of the armed forces enrolled in the physician assistant training program at the Academy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaf3efab-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVII/s741/a/1"},"text":"Pub. L. 105–85, div. A, title VII, § 741(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1816"},"text":"111 Stat. 1816","children":[],"tail":", § 4416; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tX/s1041/a/19"},"text":"Pub. L. 107–314, div. A, title X, § 1041(a)(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2645"},"text":"116 Stat. 2645","children":[],"tail":"; renumbered § 7486, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/c/2"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaf3efac-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaf3efad-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaaf3efae-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4416"},"text":"section 4416 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" struck out heading and text of subsec. (f). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Each year, the Secretary shall submit to Congress a report on the exchange of services under this section during the year. The report shall contain the following:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) The number of civilian students who receive instruction at the Academy under this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) An assessment of the benefits derived by the United States.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Reports are required under paragraph (1) only for years during which an agreement is in effect under this section.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaaf3efaf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaaf3efb0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
