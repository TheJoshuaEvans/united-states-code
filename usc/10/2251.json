{"tag":"section","attrib":{"id":"ida959c7e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2251"},"text":null,"children":[{"tag":"num","attrib":{"value":"2251"},"text":"§ 2251.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Household furnishings and other property: personnel outside the United States or in Alaska or Hawaii","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida959c7e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2251/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), the Secretary of the military department concerned may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida959c7e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2251/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase household furnishings and automobiles from members of the armed forces and civilian employees of the Department of Defense on duty outside the United States or in Hawaii for resale at cost to incoming personnel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c7e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2251/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide household furnishings, without charge, in other than public quarters occupied by members of the armed forces or civilian employees of the Department of Defense who are on duty outside the United States or in Alaska or Hawaii.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida959c7e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2251/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Determination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority provided in subsection (a) may be used only when it is determined, under regulations approved by the Secretary of Defense, that the use of that authority would be advantageous to the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida959c7e9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/370/s1/e/1"},"text":"Pub. L. 100–370, § 1(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-07-19"},"text":"July 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/845"},"text":"102 Stat. 845","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida959c7ea-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida959c7eb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section is based on ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/212/tVII/s723"},"text":"Pub. L. 98–212, title VII, § 723","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-08"},"text":"Dec. 8, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1443"},"text":"97 Stat. 1443","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
