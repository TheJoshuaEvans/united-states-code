{"tag":"section","attrib":{"id":"idab9622b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12009"},"text":null,"children":[{"tag":"num","attrib":{"value":"12009"},"text":"§ 12009.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Army and Air Force reserve components: temporary increases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab9622ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12009/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authorized strength in any reserve grade, as prescribed under this chapter, for any reserve component under the jurisdiction of the Secretary of the Army or the Secretary of the Air Force is automatically increased to the minimum extent necessary to give effect to each appointment made in that grade under section 1211(a), 7036, 14304(b), 14314, or 14317 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab9622bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12009/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An authorized strength so increased is increased for no other purpose. While an officer holds that grade, the officer whose appointment caused the increase is counted for the purpose of determining when other appointments, not under those sections, may be made in that grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab9622bc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1662/a/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1662(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2987"},"text":"108 Stat. 2987","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s809/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 809(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1840"},"text":"132 Stat. 1840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab9622bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab9622be-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab9622bf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 3212 and 8212 of this title, prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1662/a/3"},"text":"Pub. L. 103–337, § 1662(a)(3)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab9622c0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “section 1211(a), 7036,” for “section 1211(a), 3036,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab9622c1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text"