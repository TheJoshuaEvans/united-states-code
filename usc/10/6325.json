{"tag":"section","attrib":{"id":"idaacdca7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6325"},"text":null,"children":[{"tag":"num","attrib":{"value":"6325"},"text":"§ 6325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice-and-wait requirement applicable to certain third-party financing arrangements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaacdca7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6325/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice-and-wait Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy may not enter into an arrangement described in subsection (b) until 30 days after the date on which the Secretary notifies the congressional defense committees in writing of the proposed arrangement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdca7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6325/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Arrangements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacdca80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6325/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2), an arrangement referred to in subsection (a) is any alternative financing arrangement, third-party financing arrangement, public-private partnership, privatization arrangement, private capital arrangement, or other financing arrangement that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacdca81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6325/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entered into in connection with a project conducted using funds authorized to be appropriated to the Department of Energy to carry out programs necessary for national security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdca82-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6325/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves a contractor or Federal agency obtaining and charging to the Department of Energy as an allowable cost under a contract the use of office space, facilities, or other real property assets with a value of at least $5,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdca83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6325/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An arrangement referred to in subsection (a) does not include an arrangement that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacdca84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6325/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves the Department of Energy or a contractor acquiring or entering into a capital lease for office space, facilities, or other real property assets; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdca85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6325/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entered into in connection with a capital improvement project undertaken as part of an energy savings performance contract under section 801 of the National Energy Conservation Policy Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8287"},"text":"42 U.S.C. 8287","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaacdca86-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1443"},"text":"139 Stat. 1443","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaacdca87-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaacdca88-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaacdca89-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6325 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8325"},"text":"section 8325 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2784"},"text":"section 2784 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaacdca8a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) and (2) headings which read as follows: "},{"tag":"inline","attrib":{},"text":"“In general”","children":[],"tail":" and "},{"tag":"inline","attrib":{},"text":"“Exception”","children":[],"tail":", respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
