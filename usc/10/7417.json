{"tag":"section","attrib":{"id":"idaaea52a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7417"},"text":null,"children":[{"tag":"num","attrib":{"value":"7417"},"text":"§ 7417.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military history fellowships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaea52a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7417/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fellowships","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army shall prescribe regulations under which the Secretary may award fellowships in military history of the Army to the persons described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaea52a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7417/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Persons","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The persons eligible for awards of fellowships under this section are citizens and nationals of the United States who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaea52aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7417/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are graduate students in United States military history;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaea52ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7417/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have completed all requirements for a doctoral degree other than preparation of a dissertation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaea52ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7417/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree to prepare a dissertation in a subject area of military history determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaea52ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7417/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations prescribed under this section shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaea52ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7417/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the criteria for award of fellowships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaea52af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7417/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procedures for selecting recipients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaea52b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7417/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis for determining the amount of a fellowship; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaea52b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7417/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount that may be awarded as fellowships during an academic year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaea52b2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1076/a"},"text":"Pub. L. 102–484, div. A, title X, § 1076(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2511"},"text":"106 Stat. 2511","children":[],"tail":", § 4316; renumbered § 4317, "},{"tag":"ref","attrib":{"href":"/us/pl/103/35/tII/s201/b/2/A"},"text":"Pub. L. 103–35, title II, § 201(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-05-31"},"text":"May 31, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/98"},"text":"107 Stat. 98","children":[],"tail":"; renumbered § 7417, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/c/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaea52b3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaea52b4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","a