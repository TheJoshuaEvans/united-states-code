{"tag":"section","attrib":{"id":"ida9f98989-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2912"},"text":null,"children":[{"tag":"num","attrib":{"value":"2912"},"text":"§ 2912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability and use of energy cost savings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9f9898a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An amount of the funds appropriated to the Department of Defense for a fiscal year that is equal to the amount of energy cost savings realized by the Department, including financial benefits resulting from shared energy savings contracts entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2913"},"text":"section 2913 of this title","children":[],"tail":", and, in the case of operational energy, from both training and operational missions, shall remain available for obligation under subsection (b) or (c), as the case may be, for that fiscal year and the succeeding fiscal year, without additional authorization or appropriation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9f9898b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c) with respect to operational energy cost savings, the Secretary of Defense shall provide that the amount that remains available for obligation under subsection (a) and the funds made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2916/b/2"},"text":"section 2916(b)(2) of this title","children":[],"tail":" shall be used as follows:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9f9898c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2912/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One-half of the amount shall be used for the implementation of additional energy resilience, mission assurance, weather damage repair and prevention, energy conservation, and energy security measures, including energy resilience and energy conservation construction projects, at buildings, facilities, or installations of the Department of Defense or related to vehicles and equipment of the Department, which are designated, in accordance with regulations prescribed by the Secretary of Defense, by the head of the department, agency, or instrumentality that realized the savings referred to in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9f9898d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2912/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" One-half of the amount shall be used at the installation at which the savings were realized, as determined by the commanding officer of such installation consistent with applicable law and regulations, for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9f9898e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2912/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improvements to existing military family housing units;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9f9898f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2912/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any unspecified minor construction project that will enhance the quality of life of personnel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9f98990-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2912/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any morale, welfare, or recreation facility or service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9f98991-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2912/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Operational Energy Cost Savings","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9f98992-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2912/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount that remains available for obligation under subsection (a) that relates to operational energy cost savings realized by the Department shall be used for the implementation of operational energy initiatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9f98993-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2912/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall design operational energy initiatives under paragraph (1) to advance the objectives of the Department in the areas of energy resilience and fuel efficiency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9f98994-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2912/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operational energy initiatives carried out under paragraph (1) may directly contribute to enhanced mission and combat capabilities, fund operational environment training activities, or establish programs to incentivize demonstrable reductions in energy expenditures within the department, agency, or instrumentality credited with achieving the energy cost savings under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9f98995-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2912/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Certain Financial Incentives","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Financial incentives received from gas or electric utilities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2913"},"text":"section 2913 of this title","children":[],"tail":" shall be credited to an appropriation designated by the Secretary of Defense. Amounts so credited shall be merged with the appropriation to which credited and shall be available for the same purposes and the same period as the appropriation with which merged."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9f98996-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2912/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9f98997-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2912/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 60 days after being notified of amounts described in subsection (a) that remain available for obligation, the Secretary of Defense shall transfer such amounts to other funding accounts of the Department of Defense if the purpose for which such amounts will be used is a purpose specified in subsection (b) or (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9f98998-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2912/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts transferred to a funding account of the Department under paragraph (1) shall be available for obligation for the same period as amounts in that account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9f98999-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2912/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the end of each fiscal year, the Secretary of Defense shall submit to Congress a report detailing any funds transferred pursuant to paragraph (1) during that fiscal year, including a detailed description of the purpose for which such amounts have been used.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9f9899a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2912/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operational Energy Cost Savings Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “operational energy cost savings” means the monetary savings achieved through measures to reduce energy expenditures relative to the amount that would have been necessary to sustain an equivalent level of capability in the absence of such measures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9f9899b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dB/tXXVIII/s2851/a/1"},"text":"Pub. L. 109–364, div. B, title XXVIII, § 2851(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2491"},"text":"120 Stat. 2491","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dB/tXXVIII/s2822"},"text":"Pub. L. 112–239, div. B, title XXVIII, § 2822","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2152"},"text":"126 Stat. 2152","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1051/a/26"},"text":"Pub. L. 115–91, div. A, title X, § 1051(a)(26)","children":[],"tail":", div. B, title XXVIII, § 2832, "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1562"},"text":"131 Stat. 1562","children":[],"tail":", 1858; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tIII/s312/h"},"text":"Pub. L. 115–232, div. A, title III, § 312(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1711"},"text":"132 Stat. 1711","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIII/s317"},"text":"Pub. L. 116–92, div. A, title III, § 317","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1304"},"text":"133 Stat. 1304","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIII/s317"},"text":"Pub. L. 116–283, div. A, title III, § 317","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3519"},"text":"134 Stat. 3519","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tIII/s315"},"text":"Pub. L. 117–81, div. A, title III, § 315","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1630"},"text":"135 Stat. 1630","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tIII/s313"},"text":"Pub. L. 119–60, div. A, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/804"},"text":"139 Stat. 804","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9f9899c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9f9899d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9f9899e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s313/1"},"text":"Pub. L. 119–60, § 313(1)","children":[],"tail":", designated existing provisions as par. (1), substituted “operational energy initiatives.” for “additional operational energy resilience, efficiencies, mission assurance, energy conservation, or energy security within the department, agency, or instrumentality that realized that savings.” and added pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s313/2"},"text":"Pub. L. 119–60, § 313(2)","children":[],"tail":", substituted “Not later than 60 days after being notified of amounts described in subsection (a) that remain available for obligation, the Secretary of Defense shall transfer such amounts” for “The Secretary of Defense may transfer amounts described in subsection (a) that remain available for obligation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s313/3"},"text":"Pub. L. 119–60, § 313(3)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s315/1"},"text":"Pub. L. 117–81, § 315(1)","children":[],"tail":", substituted “for that fiscal year and the succeeding fiscal year” for “until expended”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" inserted “and, in the case of operational energy, from both training and operational missions,” after “under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2913"},"text":"section 2913 of this title","children":[],"tail":",”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s315/2"},"text":"Pub. L. 117–81, § 315(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s317/1"},"text":"Pub. L. 116–92, § 317(1)","children":[],"tail":", substituted “subsection (b) or (c), as the case may be,” for “subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s317/2"},"text":"Pub. L. 116–92, § 317(2)","children":[],"tail":", substituted “Except as provided in subsection (c) with respect to operational energy cost savings, the Secretary of Defense” for “The Secretary of Defense” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s317/3"},"text":"Pub. L. 116–92, § 317(3)","children":[],"tail":", (4), added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" inserted “, including energy resilience and energy conservation construction projects,” after “energy security measures”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s2832"},"text":"Pub. L. 115–91, § 2832","children":[],"tail":", substituted “energy resilience, mission assurance, weather damage repair and prevention, energy conservation, and” for “energy conservation and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1051/a/26"},"text":"Pub. L. 115–91, § 1051(a)(26)","children":[],"tail":", struck out subsec. (d). Text read as follows: “The Secretary of Defense shall include in the budget material submitted to Congress in connection with the submission of the budget for a fiscal year pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":" a separate statement of the amounts available for obligation under this section in that fiscal year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" inserted “and energy security” after “additional energy conservation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9f9899f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9f989a0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Funds for Energy and Water Efficiency in Federal Buildings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/148/dA/tVIII/s8054"},"text":"Pub. L. 109–148, div. A, title VIII, § 8054","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-30"},"text":"Dec. 30, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2710"},"text":"119 Stat. 2710","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/148/dA/tVIII/s8054"},"text":"“Appropriations available under the heading ‘Operation and Maintenance, Defense-Wide’ for the current fiscal year and hereafter for increasing energy and water efficiency in Federal buildings may, during their period of availability, be transferred to other appropriations or funds of the Department of Defense for projects related to increasing energy and water efficiency, to be merged with and to be available for the same general purposes, and for the same time period, as the appropriation or fund to which transferred.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions for specified fiscal years were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/287/tVIII/s8058"},"text":"Pub. L. 108–287, title VIII, § 8058","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-05"},"text":"Aug. 5, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/983"},"text":"118 Stat. 983","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/87/tVIII/s8058"},"text":"Pub. L. 108–87, title VIII, § 8058","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1085"},"text":"117 Stat. 1085","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/248/tVIII/s8059"},"text":"Pub. L. 107–248, title VIII, § 8059","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-23"},"text":"Oct. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1550"},"text":"116 Stat. 1550","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/117/dA/tVIII/s8064"},"text":"Pub. L. 107–117, div. A, title VIII, § 8064","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"Jan. 10, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2261"},"text":"115 Stat. 2261","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/259/tVIII/s8063"},"text":"Pub. L. 106–259, title VIII, § 8063","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-08-09"},"text":"Au