{"tag":"section","attrib":{"id":"idab0702ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8031"},"text":null,"children":[{"tag":"num","attrib":{"value":"8031"},"text":"§ 8031.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of the Chief of Naval Operations: function; composition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab0702ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8031/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is in the executive part of the Department of the Navy an Office of the Chief of Naval Operations. The function of the Office of the Chief of Naval Operations is to assist the Secretary of the Navy in carrying out his responsibilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0702f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8031/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Office of the Chief of Naval Operations is composed of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab0702f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8031/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Naval Operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0702f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8031/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Vice Chief of Naval Operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0702f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8031/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Deputy Chiefs of Naval Operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0702f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8031/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Chiefs of Naval Operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0702f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8031/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Surgeon General of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0702f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8031/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Naval Personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0702f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8031/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Chaplains of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0702f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8031/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other members of the Navy and Marine Corps assigned or detailed to the Office of the Chief of Naval Operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0702f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8031/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Civilian employees in the Department of the Navy assigned or detailed to the Office of the Chief of Naval Operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0702fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8031/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise specifically prescribed by law, the Office of the Chief of Naval Operations shall be organized in such manner, and its members shall perform such duties and have such titles, as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab0702fb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s512/b"},"text":"Pub. L. 99–433, title V, § 512(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1048"},"text":"100 Stat. 1048","children":[],"tail":", § 5031; renumbered § 8031, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/a/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1834"},"text":"132 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab0702fc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab0702fd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"childre