{"tag":"section","attrib":{"id":"ida781abb3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s184"},"text":null,"children":[{"tag":"num","attrib":{"value":"184"},"text":"§ 184.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civilian Protection Center of Excellence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida781abb4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s184/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall operate the Civilian Protection Center of Excellence. The purpose of the Center shall be to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida781abb5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s184/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the focal point for matters related to civilian casualties and other forms of civilian harm resulting from military operations involving the United States Armed Forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abb6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s184/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutionalize and advance knowledge, practices, and tools for preventing, mitigating, and responding to civilian harm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida781abb7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s184/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Center shall be used to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida781abb8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s184/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop standardized civilian-harm operational reporting and data management processes to improve data collection, sharing, and learning across the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abb9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s184/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, recommend, and review guidance, and the implementation of guidance, on how the Department responds to civilian harm;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s184/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop recommended guidance for addressing civilian harm across the full spectrum of armed conflict and for use in doctrine and operational plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abbb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s184/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend training and exercises for the prevention and investigation of civilian harm;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abbc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s184/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a repository of civilian casualty and civilian harm information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abbd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s184/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capture lessons learned from assessments and investigations of civilian casualty incidents and supporting institutionalization of such lessons learned within policy, doctrine, training, exercises, and tactics, techniques, and procedures of the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abbe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s184/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the coordination and synchronization of efforts across combatant commands, the Department of State, and other relevant United States Government departments and agencies to prevent, mitigate, and respond to incidents of civilian harm;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abbf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s184/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage with nongovernmental organizations and civilian casualty experts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida781abc0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s184/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other functions as the Secretary of Defense may specify.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida781abc1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s184/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall submit to the congressional defense committees, and make publicly available on an appropriate website of the Department, an annual report on the activities of the Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida781abc2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tX/s1082/a/1"},"text":"Pub. L. 117–263, div. A, title X, § 1082(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2799"},"text":"136 Stat. 2799","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida781abc3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida781abc4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida781abc5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 184 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s185"},"text":"section 185 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida781abc6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 184 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s342"},"text":"section 342 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida781abc7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida781abc8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Establishment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tX/s1082/b"},"text":"Pub. L. 117–263, div. A, title X, § 1082(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2799"},"text":"136 Stat. 2799","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tX/s1082/b"},"text":"“The Civilian Protection Center of Excellence, as required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s184"},"text":"section 184 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall be established by not later than 90 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
