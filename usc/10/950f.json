{"tag":"section","attrib":{"id":"ida8393ca2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950f"},"text":null,"children":[{"tag":"num","attrib":{"value":"950f"},"text":"§ 950f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review by United States Court of Military Commission Review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8393ca3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is a court of record to be known as the “United States Court of Military Commission Review” (in this section referred to as the “Court”). The Court shall consist of one or more panels, each composed of not less than three judges on the Court. For the purpose of reviewing decisions of military commissions under this chapter, the Court may sit in panels or as a whole, in accordance with rules prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8393ca4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Judges","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8393ca5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Judges on the Court shall be assigned or appointed in a manner consistent with the provisions of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8393ca6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may assign persons who are appellate military judges to be judges on the Court. Any judge so assigned shall be a commissioned officer of the armed forces, and shall meet the qualifications for military judges prescribed by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s948j/b"},"text":"section 948j(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8393ca7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may appoint, by and with the advice and consent of the Senate, additional judges to the United States Court of Military Commission Review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8393ca8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950f/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No person may serve as a judge on the Court in any case in which that person acted as a military judge, counsel, or reviewing official.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8393ca9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950f/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8393caa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950f/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of sections 203, 205, 207, 208, and 209 of title 18, the term “special Government employee” shall include a judge of the Court appointed under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8393cab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950f/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person appointed as a judge of the Court under paragraph (3) shall be considered to be an officer or employee of the United States with respect to such person’s status as a judge, but only during periods in which such person is performing the duties of such a judge. Any provision of law that prohibits or limits the political or business activities of an employee of the United States shall only apply to such a judge during such periods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8393cac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950f/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8393cad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950f/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":" (A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term of an appellate military judge assigned or appointed to the Court under this subsection shall expire on the earlier of the date on which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8393cae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950f/b/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the judge leaves active duty; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8393caf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950f/b/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the judge is reassigned to other duties in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s949b/b/4"},"text":"section 949b(b)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8393cb0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950f/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term of a civilian judge of the Court appointed under paragraph (3) shall expire on the date that is 10 years after the date on which the judge was appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8393cb1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950f/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Judges of the Court may be removed from office by the President (in the case of a judge appointed under paragraph (3)) or the Secretary of Defense (in the case of an appellate military judge assigned under paragraph (2)) upon notice and hearing, for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8393cb2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950f/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" neglect of duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8393cb3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950f/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" misconduct; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8393cb4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950f/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mental or physical disability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8393cb5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cases To Be Reviewed","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Court shall, in accordance with procedures prescribed under regulations of the Secretary, review the record in each case that is referred to the Court by the convening authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s950c"},"text":"section 950c of this title","children":[],"tail":" with respect to any matter properly raised by the accused."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8393cb6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standard and Scope of Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a case reviewed by the Court under this section, the Court may act only with respect to the findings and sentence as approved by the convening authority. The Court may affirm only such findings of guilty, and the sentence or such part or amount of the sentence, as the Court finds correct in law and fact and determines, on the basis of the entire record, should be approved. In considering the record, the Court may weigh the evidence, judge the credibility of witnesses, and determine controverted questions of fact, recognizing that the military commission saw and heard the witnesses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8393cb7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rehearings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Court sets aside the findings or sentence, the Court may, except where the setting aside is based on lack of sufficient evidence in the record to support the findings, order a rehearing. If the Court sets aside the findings or sentence and does not order a rehearing, the Court shall order that the charges be dismissed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8393cb8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tXVIII/s1802"},"text":"Pub. L. 111–84, div. A, title XVIII, § 1802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2603"},"text":"123 Stat. 2603","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tX/s1034/c"},"text":"Pub. L. 112–81, div. A, title X, § 1034(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1573"},"text":"125 Stat. 1573","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1082"},"text":"Pub. L. 115–91, div. A, title X, § 1082","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1602"},"text":"131 Stat. 1602","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tV/s541/a"},"text":"Pub. L. 115–232, div. A, title V, § 541(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1761"},"text":"132 Stat. 1761","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s567/a"},"text":"Pub. L. 118–159, div. A, title V, § 567(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1905"},"text":"138 Stat. 1905","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8393cb9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8393cba-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida8393cbb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 950f, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/366/s3/a/1"},"text":"Pub. L. 109–366, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2621"},"text":"120 Stat. 2621","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tX/s1063/a/6"},"text":"Pub. L. 110–181, div. A, title X, § 1063(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/322"},"text":"122 Stat. 322","children":[],"tail":", related to review by Court of Military Commission Review, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8393cbc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s567/a/1"},"text":"Pub. L. 118–159, § 567(a)(1)","children":[],"tail":", designated existing provisions as subpar. (A), redesignated former subpars. (A) and (B) as cls. (i) and (ii), respectively, of subpar. (A), and realigned margins; substituted “The term of an appellate military judge assigned or appointed to the Court under this subsection” for “The term of an appellate military judge assigned to the Court under paragraph (2) or appointed to the Court under paragraph (3)”; and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s567/a/2"},"text":"Pub. L. 118–159, § 567(a)(2)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" substituted “judges on the Court” for “appellate military judges” in second sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8393cbd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8393cbe-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s567/b"},"text":"Pub. L. 118–159, div. A, title V, § 567(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1905"},"text":"138 Stat. 1905","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tV/s567/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsection (a) [amending this section] shall take effect on the date that is 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability to existing civilian judges","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term of any civilian judge of the United States Court of Military Commission Review who will have served as such a judge for a period of 10 or more years as of the effective date described in paragraph (1) shall expire on such effective date.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8393cbf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tV/s541/b"},"text":"Pub. L. 115–232, div. A, title V, § 541(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1762"},"text":"132 Stat. 1762","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/232/dA/tV/s541/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to each judge of the United States Court of Military Commission Review serving on that court on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":"] and each judge assigned or appointed to that court on or after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
