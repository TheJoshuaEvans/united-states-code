{"tag":"section","attrib":{"id":"idaad4f615-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7031"},"text":null,"children":[{"tag":"num","attrib":{"value":"7031"},"text":"§ 7031.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" The Army Staff: function; composition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaad4f616-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7031/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is in the executive part of the Department of the Army an Army Staff. The function of the Army Staff is to assist the Secretary of the Army in carrying out his responsibilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad4f617-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7031/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Army Staff is composed of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad4f618-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7031/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f619-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7031/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Vice Chief of Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f61a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7031/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Deputy Chiefs of Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f61b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7031/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Chiefs of Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f61c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7031/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Engineers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f61d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7031/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Surgeon General of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f61e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7031/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Judge Advocate General of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f61f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7031/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Chaplains of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f620-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7031/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Army Reserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f621-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7031/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other members of the Army assigned or detailed to the Army Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f622-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7031/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Civilian employees of the Department of the Army assigned or detailed to the Army Staff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad4f623-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7031/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise specifically prescribed by law, the Army Staff shall be organized in such manner, and its members shall perform such duties and have such titles, as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad4f624-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/150"},"text":"70A Stat. 150","children":[],"tail":", § 3031; "},{"tag":"ref","attrib":{"href":"/us/pl/93/547"},"text":"Pub. L. 93–547","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-26"},"text":"Dec. 26, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1742"},"text":"88 Stat. 1742","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/608/s1/6"},"text":"Pub. L. 93–608, § 1(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1968"},"text":"88 Stat. 1968","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tV/s515"},"text":"Pub. L. 98–525, title V, § 515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2522"},"text":"98 Stat. 2522","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s502/a"},"text":"Pub. L. 99–433, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1039"},"text":"100 Stat. 1039","children":[],"tail":"; renumbered § 7031, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1838"},"text":"132 Stat. 1838","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaad4f625-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaad4f626-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaad4f627-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3031(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3031(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:21a(a).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:21a(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-06-28/ch383/s201"},"text":"June 28, 1950, ch. 383, § 201","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/265"},"text":"64 Stat. 265","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3031(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:21a(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3031(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:21a(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “an Army Staff consisting of—” are substituted for the words “a staff, which shall be known as the Army Staff, and which shall consist of—”. The words “under regulations prescribed by the Secretary of the Army” are omitted, since the Secretary has inherent authority to issue regulations appropriate to exercising his statutory functions.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the third sentence is substituted for 10:21a(c) (1st 13 words and 1st proviso). The words “officers and employees * * * or under the jurisdiction of” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (c) and (d), the word “hereafter” is omitted, since all wars and emergencies declared by Congress before ","children":[{"tag":"date","attrib":{"date":"1950-06-24"},"text":"June 24, 1950","children":[],"tail":", have been terminated."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the second sentence is substituted for 10:21a(d) (last 31 words of 1st sentence). The third sentence is substituted for 10:21a(d) (2d sentence). 10:21a(d) (1st 13 words of last sentence) is omitted as executed. The words “This subsection does not apply” are substituted for the words “and shall be in applicable”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaad4f628-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaad4f629-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3031"},"text":"section 3031 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433"},"text":"Pub. L. 99–433","children":[],"tail":" amended section generally, substituting “The Army Staff: function; composition” for “Composition: assignment and detail of members of Army and civilians” in section catchline and substituting in text provisions relating to establishment and composition of the Army Staff and authorizing the Secretary to prescribe the organization, duties, and titles of the Army Staff for provisions relating to establishment and composition of the Army Staff, authorizing the Secretary to prescribe the organization, duties, and titles of the Army Staff and authorizing part of the Army Staff to be designated as the Army General Staff, and limiting the number of officers who may be assigned or detailed to permanent duty in the executive part of the Department of the Army and on or with the Army General Staff."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525"},"text":"Pub. L. 98–525","children":[],"tail":" struck out subsec. (d) which provided that no commissioned officer who was assigned or detailed to duty in the executive part of the Department of the Army could serve for a tour of duty of more than four years, but that the Secretary could extend such a tour of duty if he made a special finding that the extension was necessary in the public interest, that no officer could be assigned or detailed to duty in the executive part of the Department of the Army within two years after relief from that duty, except upon a special finding by the Secretary that the assignment or detail was necessary in the public interest, and that the subsection did not apply in time of war, or of national emergency declared by Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/608"},"text":"Pub. L. 93–608","children":[],"tail":" struck out requirement of quarterly report to Congress on the number of officers in the executive part of the Department of the Army and the number of commissioned officers on or with the Army General Staff and the justification therefor."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/547"},"text":"Pub. L. 93–547","children":[],"tail":" increased the number of Deputy Chiefs of Staff from three to four."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaad4f62a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaad4f62b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaad4f62c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tV/s515"},"text":"Pub. L. 98–525, title V, § 515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2522"},"text":"98 Stat. 2522","children":[],"tail":", provided that the amendment made by that section is effective "},{"tag":"date","attrib":{"date":"1984-10-01"},"text":"Oct. 1, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
