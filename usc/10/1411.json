{"tag":"section","attrib":{"id":"ida8c37ac2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1411"},"text":null,"children":[{"tag":"num","attrib":{"value":"1411"},"text":"§ 1411.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8c37ac3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1411/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction of “First Became a Member”","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this chapter and other provisions of law providing for computation of retired or retainer pay of members of the uniformed services, a person shall be considered to first become a member of a uniformed service on the date the person is first enlisted, inducted, or appointed in a uniformed service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8c37ac4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1411/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"References in Tables","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section references in tables in this chapter are to sections of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8c37ac5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/348/tI/s105"},"text":"Pub. L. 99–348, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-07-01"},"text":"July 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/691"},"text":"100 Stat. 691","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
