{"tag":"section","attrib":{"id":"idab42ab7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8715"},"text":null,"children":[{"tag":"num","attrib":{"value":"8715"},"text":"§ 8715.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Naval Observatory: administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab42ab7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8715/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Naval Observatory shall be attached to the Office of the Chief of Naval Operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab42ab7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8715/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Superintendent of the Naval Observatory shall be detailed from officers in the line of the Navy serving in the grade of captain or above.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab42ab80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8715/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy may detail any officer of the Navy, competent for that duty, to supervise the Nautical Almanac.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab42ab81-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/457"},"text":"70A Stat. 457","children":[],"tail":", § 7395; renumbered § 8715, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/4"},"text":"Pub. L. 115–232, div. A, title VIII,