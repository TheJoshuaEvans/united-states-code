{"tag":"section","attrib":{"id":"ida9719562-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350r"},"text":null,"children":[{"tag":"num","attrib":{"value":"2350r"},"text":"§ 2350r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" North Atlantic Treaty Organization Allied Special Operations Forces Command","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9719563-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of the amounts authorized to be appropriated for each fiscal year for operation and maintenance for the Army, the Secretary of Defense is authorized to use up to $55,000,000, to be derived from amounts made available for support of North Atlantic Treaty Organization (referred to in this section as “NATO”) operations, for each such fiscal year for the purposes set forth in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9719564-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide funds for the NATO Allied Special Operations Forces Command—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9719565-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350r/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve coordination and cooperation between the special operations forces of NATO countries and countries approved by the North Atlantic Council as NATO partners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9719566-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350r/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate joint operations by the special operations forces of NATO countries and such NATO partners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9719567-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350r/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support special operations forces peculiar command, control, and communications capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9719568-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350r/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote special operations forces intelligence and informational requirements within the NATO structure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9719569-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350r/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote interoperability through the development of common equipment standards, tactics, techniques, and procedures, and through execution of a multinational education and training program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida971956a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tXII/s1271/a"},"text":"Pub. L. 117–263, div. A, title XII, § 1271(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2860"},"text":"136 Stat. 2860","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXIII/s1301/a"},"text":"Pub. L. 118–159, div. A, title XIII, § 1301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2110"},"text":"138 Stat. 2110","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida971956b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida971956c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida971956d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1301/a/1"},"text":"Pub. L. 118–159, § 1301(a)(1)","children":[],"tail":", substituted “Allied Special Operations Forces Command” for “Special Operations Headquarters” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1301/a/2"},"text":"Pub. L. 118–159, § 1301(a)(2)","children":[],"tail":", substituted “$55,000,000” for “$50,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1301/a/3"},"text":"Pub. L. 118–159, § 1301(a)(3)","children":[],"tail":", substituted “Allied Special Operations Forces Command” for “Special Operations Headquarters” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida971956e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"ida971956f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXIII/s1301/b"},"text":"Pub. L. 118–159, div. A, title XIII, § 1301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2110"},"text":"138 Stat. 2110","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tXIII/s1301/b"},"text":"“Any reference to the North Atlantic Treaty Organization Special Operations Headquarters or NATO Special Operations Headquarters in any law, regulation, map, document, record, or other paper of the United States shall be deemed to be a reference to the North Atlantic Treaty Organization Allied Special Operations Forces Command.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
