trib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1492"},"text":"72 Stat. 1492","children":[],"tail":", and amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s503/26"},"text":"Pub. L. 96–513, title V, § 503(26)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2913"},"text":"94 Stat. 2913","children":[],"tail":", related to ranking of officers in active status in Naval Reserve and Marine Corps Reserve, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1673/d/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1673(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3016"},"text":"108 Stat. 3016","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 5507, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/316"},"text":"70A Stat. 316","children":[],"tail":", related to pay and allowances of rear admirals. See "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s202"},"text":"section 202 of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/87/649/s14c/26"},"text":"Pub. L. 87–649, § 14c(26)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/501"},"text":"76 Stat. 501","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1962-11-01"},"text":"Nov. 1, 1962","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 5508 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8118"},"text":"section 8118 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaab38b1c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “Defense Agency” for “defense agency” in section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaab38b1d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaab38b1e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rescission of Memorandum on Missile Defense Governance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVI/s1667"},"text":"Pub. L. 118–31, div. A, title XVI, § 1667","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/607"},"text":"137 Stat. 607","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dA/tXVI/s1667"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than ","children":[{"tag":"date","attrib":{"date":"2024-05-31"},"text":"May 31, 2024","children":[],"tail":", the Secretary of Defense shall—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rescind Directive-type Memorandum 20-002 relating to ‘Missile Defense System Policies and Governance’; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in accordance with [former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s205/b"},"text":"section 205(b) of title 10","children":[],"tail":", United States Code, replace such memorandum with governance documents, policies, and procedures, that balance—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing the Missile Defense Agency with greater flexibility and agility, particularly with regards to milestone a [probably should be “Milestone A”] (or equivalent) acquisition decisions to rapidly meet warfighter needs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for continued oversight to ensure integration into joint-force air and missile defense capabilities.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaab38b1f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Directed Energy Programs for Ballistic and Hypersonic Missile Defense","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVI/s1664"},"text":"Pub. L. 117–81, div. A, title XVI, § 1664","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2104"},"text":"135 Stat. 2104","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dA/tXVI/s1664"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of the Missile Defense Agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall delegate to the Director of the Missile Defense Agency the authority to budget for, direct, and manage directed energy programs applicable for ballistic and hypersonic missile defense missions, in coordination with other directed energy efforts of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prioritization","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In budgeting for and directing directed energy programs applicable for ballistic and hypersonic defensive missions pursuant to subsection (a), the Director of the Missile Defense Agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritize the early research and development of technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address the transition of such technologies to industry to support future operationally relevant capabilities.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
