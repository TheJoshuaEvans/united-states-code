{"tag":"section","attrib":{"id":"idaab38afe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502"},"text":null,"children":[{"tag":"num","attrib":{"value":"5502"},"text":"§ 5502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Missile Defense Agency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaab38aff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment of Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Missile Defense Agency shall be a general or flag officer appointed for a six-year term.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab38b00-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deputy Director","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab38b01-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is a Deputy Director of the Missile Defense Agency, who shall be appointed by the Secretary of Defense from among the general officers on active duty in the Army, Air Force, Marine Corps, or Space Force, or from among the flag officers on active duty in the Navy. In selecting an individual to serve as the Deputy Director, the Secretary of Defense shall select an individual who serves in a different armed force than the armed force in which the Director serves.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab38b02-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Deputy Director shall be appointed for a term of not fewer than two, and not more than four years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab38b03-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Deputy Director shall be under the authority, direction, and control of the Director of the Missile Defense Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab38b04-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Deputy Director shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaab38b05-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out such responsibilities as may be assigned by the Director; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab38b06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as acting director during periods of absence by the Director, or at such times as the office of the Director is vacant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab38b07-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of Changes to Non-standard Acquisition and Requirements Processes and Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab38b08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense may not make any changes to the missile defense non-standard acquisition and requirements processes and responsibilities unless, with respect to those proposed changes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaab38b09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary, without delegation, has taken each of the actions specified in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab38b0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 120 days has elapsed following the date on which the Secretary submits the report under subparagraph (C) of such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab38b0b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Secretary proposes to make changes to the missile defense non-standard acquisition and requirements processes and responsibilities, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaab38b0c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Under Secretary of Defense for Research and Engineering, the Under Secretary of Defense for Acquisition and Sustainment, the Under Secretary of Defense for Policy, the Secretaries of the military departments, the Chairman of the Joint Chiefs of Staff, the Commander of the United States Strategic Command, the Commander of the United States Northern Command, and the Director of the Missile Defense Agency, regarding the changes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab38b0d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify to the congressional defense committees that the Secretary has coordinated the changes with, and received the views of, the individuals referred to in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab38b0e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the congressional defense committees a report that contains—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaab38b0f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the changes, the rationale for the changes, and the views of the individuals referred to in subparagraph (A) with respect to the changes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaab38b10-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that the changes will not impair the missile defense capabilities of the United States nor degrade the unique special acquisition authorities of the Missile Defense Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaab38b11-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any such changes to Department of Defense Directive 5134.09, or successor directive issued in accordance with this subsection, a final draft of the proposed modified directive, both in an electronic format and in a hard copy format; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab38b12-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any such changes to Department of Defense Directive 5134.09, or successor directive issued in accordance with this subsection, provide to such committees a briefing on the proposed modified directive described in subparagraph (C)(iii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab38b13-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection, the term “non-standard acquisition and requirements processes and responsibilities” means the processes and responsibilities described in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaab38b14-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the memorandum of the Secretary of Defense titled “Missile Defense Program Direction” signed on ","children":[{"tag":"date","attrib":{"date":"2002-01-02"},"text":"January 2, 2002","children":[],"tail":", as in effect on the date of the enactment of this subsection or as modified in accordance with this subsection, or any successor memorandum issued in accordance with this subsection;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab38b15-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Defense Directive 5134.09, as in effect on the date of the enactment of this subsection (without regard to any modifications described in Directive-type Memorandum 20–002 of the Deputy Secretary of Defense, or any amendments or extensions thereto made before the date of such enactment), or as modified in accordance with this subsection, or any successor directive issued in accordance with this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab38b16-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5502/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States Strategic Command Instruction 538–3 titled “MD Warfighter Involvement Process”, as in effect on the date of the enactment of this subsection or as modified in accordance with this subsection, or any successor instruction issued in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaab38b17-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1649/a"},"text":"Pub. L. 118–159, div. A, title XVI, § 1649(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2187"},"text":"138 Stat. 2187","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVII/s1701/a/32"},"text":"Pub. L. 119–60, div. A, title XVII, § 1701(a)(32)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1209"},"text":"139 Stat. 1209","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaab38b18-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaab38b19-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaab38b1a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this subsection, referred to in subsec. (c)(3), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaab38b1b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5502 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8112"},"text":"section 8112 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s205"},"text":"section 205 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1649/b/1"},"text":"Pub. L. 118–159, div. A, title XVI, § 1649(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2199"},"text":"138 Stat. 2199","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 5503 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8113"},"text":"section 8113 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 5504 and 5505 were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tIII/s314"},"text":"Pub. L. 96–513, title III, § 314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2892"},"text":"94 Stat. 2892","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 5504, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/