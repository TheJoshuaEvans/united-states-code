{"tag":"section","attrib":{"id":"ida916f269-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1789"},"text":null,"children":[{"tag":"num","attrib":{"value":"1789"},"text":"§ 1789.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chaplain-led programs: authorized support","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida916f26a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1789/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of a military department may provide support services described in subsection (b) to support a chaplain-led program to assist a covered individual in building and maintaining a strong family structure, or to support the resiliency, suicide prevention, or holistic wellness of such covered individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida916f26b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1789/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Support Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The support services referred to in subsection (a) are costs of transportation, food, lodging, child care, supplies, fees, and training materials for a covered individual while participating in a program referred to in that subsection, including participation at a retreat or conference.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida916f26c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1789/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Individual Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered individual” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida916f26d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1789/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the armed forces on active duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida916f26e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1789/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the reserve components in an active status; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida916f26f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1789/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dependent of an individual described in paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida916f270-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tV/s582/a/1"},"text":"Pub. L. 108–136, div. A, title V, § 582(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1489"},"text":"117 Stat. 1489","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tV/s571/a"},"text":"Pub. L. 117–263, div. A, title V, § 571(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2600"},"text":"136 Stat. 2600","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVIII/s1801/a/17"},"text":"Pub. L. 118–31, div. A, title XVIII, § 1801(a)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/684"},"text":"137 Stat. 684","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida916f271-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida916f272-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida916f273-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" substituted “paragraph (1) or (2)” for “subparagraph (A) or (B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s571/a/1"},"text":"Pub. L. 117–263, § 571(a)(1)","children":[],"tail":", substituted “a chaplain-led program to assist a covered individual” for “chaplain-led programs to assist members of the armed forces on active duty and their immediate family members, and members of reserve components in an active status and their immediate family members,” and inserted “, or to support the resiliency, suicide prevention, or holistic wellness of such covered individual” after “structure”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s571/a/2"},"text":"Pub. L. 117–263, § 571(a)(2)","children":[],"tail":", substituted “a covered individual” for “members of the armed forces and their family members”, “a program” for “programs”, and “a retreat or conference” for “retreats and conferences”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s571/a/3"},"text":"Pub. L. 117–263, § 571(a)(3)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c) which defined “immediate family members”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida916f274-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida916f275-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tV/s582/b"},"text":"Pub. L. 108–136, div. A, title V, § 582(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1490"},"text":"117 Stat. 1490","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/136/dA/tV/s582/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1789"},"text":"Section 1789 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall take effect on "},{"tag":"date","attrib":{"date":"2003-10-01"},"text":"October 1, 2003","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
