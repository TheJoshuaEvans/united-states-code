rib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-06-28/ch383/s307"},"text":"June 28, 1950, ch. 383, § 307","children":[],"tail":" (last sentence, less 5th through 14th words), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/270"},"text":"64 Stat. 270","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3068(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3068(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:156b.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:156d.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1947-08-04/ch459"},"text":"Aug. 4, 1947, ch. 459","children":[],"tail":", §§ 101 (less 2d sentence), 102(a), (b), "},{"tag":"html:a","attrib":{"href":"/us/stat/61/734"},"text":"61 Stat. 734","children":[],"tail":", 735; "},{"tag":"html:a","attrib":{"href":"/us/act/1954-03-23/ch103"},"text":"Mar. 23, 1954, ch. 103","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/68/30"},"text":"68 Stat. 30","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), 10:156a (1st 20 words) is omitted as superseded by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3067"},"text":"section 3067 of this title","children":[],"tail":", which establishes the Medical Service Corps in the Army Medical Service. 10:156a (last 16 words of 1st sentence) is omitted as superseded by "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3012/e"},"text":"section 3012(e) of this title","children":[],"tail":", which authorizes the Secretary of the Army to prescribe the duties of members of the Army. 10:81–1 (last sentence, less 5th through 14th words) is omitted as surplusage."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “of the Regular Army in that corps whose regular grade is above captain” are substituted for the words “commissioned in the Medical Service Corps, Regular Army, in the permanent grade of major or above”. The words “If he holds a lower regular grade” are substituted for the words “if commissioned in permanent grade below colonel”. The words “is entitled” are substituted for the words “shall * * * have”. The words “ranks above” are substituted for the words “shall be superior in rank”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “is the Surgeon General’s consultant” are substituted for the words “who shall be consultants to him”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaad9b141-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaad9b142-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3068"},"text":"section 3068 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Par. (5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s594/1"},"text":"Pub. L. 111–383, § 594(1)","children":[],"tail":", substituted “Administrative Health Services” for “Pharmacy, Supply, and Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s594/2"},"text":"Pub. L. 111–383, § 594(2)","children":[],"tail":", substituted “Preventive Medicine Sciences” for “Sanitary Engineering”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s594/3"},"text":"Pub. L. 111–383, § 594(3)","children":[],"tail":", substituted “Clinical Health Sciences” for “Optometry”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" redesignated cls. (a), (b), (c), (d), and (e) as subpars. (A), (B), (C), (D), and (E), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaad9b143-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaad9b144-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","ch