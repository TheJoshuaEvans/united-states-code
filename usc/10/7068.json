{"tag":"section","attrib":{"id":"idaad9b132-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7068"},"text":null,"children":[{"tag":"num","attrib":{"value":"7068"},"text":"§ 7068.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical Service Corps: organization; Chief and assistant chiefs","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"There is a Medical Service Corps in the Army. The Medical Service Corps consists of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad9b133-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7068/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chief of the Medical Service Corps, who shall be appointed by the Secretary of the Army from among the officers of the Medical Service Corps whose regular grade is above captain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b134-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7068/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assistant chiefs of the Medical Service Corps, who shall be designated by the Surgeon General from officers in that Corps and who shall be his consultants on activities relating to their sections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b135-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7068/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commissioned officers of the Regular Army appointed therein;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b136-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7068/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other members of the Army assigned thereto by the Secretary of the Army; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b137-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7068/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the following sections—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaad9b138-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7068/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrative Health Services Section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad9b139-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7068/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Medical Allied Sciences Section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad9b13a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7068/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Preventive Medicine Sciences Section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad9b13b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7068/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Clinical Health Sciences Section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad9b13c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7068/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other sections considered necessary by the Secretary of the Army.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad9b13d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/603/s1/1"},"text":"Pub. L. 89–603, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-24"},"text":"Sept. 24, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/846"},"text":"80 Stat. 846","children":[],"tail":", § 3068; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s1/37"},"text":"Pub. L. 97–295, § 1(37)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1296"},"text":"96 Stat. 1296","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tV/s594"},"text":"Pub. L. 111–383, div. A, title V, § 594","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4234"},"text":"124 Stat. 4234","children":[],"tail":"; renumbered § 7068, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1838"},"text":"132 Stat. 1838","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaad9b13e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaad9b13f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaad9b140-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","childr