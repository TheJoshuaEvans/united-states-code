{"tag":"section","attrib":{"id":"ida8c5ecbc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1435"},"text":null,"children":[{"tag":"num","attrib":{"value":"1435"},"text":"§ 1435.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible beneficiaries","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Only the following persons are eligible to be made the beneficiaries of, or to receive payments under, an annuity elected under this subchapter by a member of the armed forces:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8c5ecbd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1435/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The spouse of the member on the date when the member is retired or becomes entitled to retired or retainer pay or, if the member was already retired or entitled to retired or retainer pay on ","children":[{"tag":"date","attrib":{"date":"1953-11-01"},"text":"November 1, 1953","children":[],"tail":", the spouse on that date."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8c5ecbe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1435/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The children of the member who are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8c5ecbf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1435/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unmarried;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8c5ecc0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1435/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under eighteen years of age, or incapable of supporting themselves because of a mental defect or physical incapacity existing before their eighteenth birthday, or at least eighteen, but under twenty-three, years of age and pursuing a full-time course of study or training in a high school, trade school, technical or vocational institute, junior college, college, university, or comparable recognized educational institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8c5ecc1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1435/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legitimate or adopted children of, or stepchildren in fact dependent for their support upon, the member;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8c5ecc2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1435/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" living on the date when the member is retired or becomes entitled to retired or retainer pay or, if the member was already retired or entitled to retired or retainer pay on ","children":[{"tag":"date","attrib":{"date":"1953-11-01"},"text":"November 1, 1953","children":[],"tail":", living on that date; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8c5ecc3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1435/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" born on or before the date prescribed in clause (D).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For the purposes of clause (2)(B), a child is considered to be pursuing a full-time course of study or training during an interval between school years that does not exceed one hundred and fifty days if he has demonstrated to the satisfaction of the Secretary concerned that he has a bonafide intention of commencing, resuming, or continuing to pursue a full-time course of study or training in a recognized educational institution immediately after that interval.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8c5ecc4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/110"},"text":"70A Stat. 110","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/485/s1/4"},"text":"Pub. L. 90–485, § 1(4)","children":[],"tail":", (5), "},{"tag":"date","attrib":{"date":"1968-08-13"},"text":"Aug. 13, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/752"},"text":"82 Stat. 752","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/425/s1/2/A"},"text":"Pub. L. 92–425, § 1(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-21"},"text":"Sept. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/706"},"text":"86 Stat. 706","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8c5ecc5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8c5ecc6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida8c5ecc7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1435(1)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1435(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:371(e).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"37:371(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1953-08-08/ch393/s2/e"},"text":"Aug. 8, 1953, ch. 393, § 2(e)","children":[],"tail":", (f), "},{"tag":"html:a","attrib":{"href":"/us/stat/67/501"},"text":"67 Stat. 501","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clauses (1) and (2), the words “is retired or becomes entitled to retired or retainer pay” are substituted for the words “retired member”, since the words “retired member”, as defined in the source statute, included former members who have been awarded that pay.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), the words “ ‘widow’ includes a widower” are omitted as covered by the definition of “spouse” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/32"},"text":"section 101(32) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8c85cc8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8c85cc9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/425"},"text":"Pub. L. 92–425","children":[],"tail":" substituted “subchapter” for “chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/485"},"text":"Pub. L. 90–485","children":[],"tail":" inserted provisions in cl. (2)(B) concerning children of the member who are at least 18, but under 23 and pursuing a full-time course of study or training and inserted text following cl. (2)(E) relating to children considered to be pursuing a full-time course of study or training."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8c85cca-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8c85ccb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/485"},"text":"Pub. L. 90–485","children":[],"tail":" effective on first day of third calendar month following "},{"tag":"date","attrib":{"date":"1968-08-13"},"text":"Aug. 13, 1968","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/485/s6"},"text":"section 6 of Pub. L. 90–485","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1431"},"text":"section 1431 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
