{"tag":"section","attrib":{"id":"ida99570e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2633"},"text":null,"children":[{"tag":"num","attrib":{"value":"2633"},"text":"§ 2633.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stevedoring and terminal services: vessels carrying cargo or passengers sponsored by military department","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida99570e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2633/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1301/a"},"text":"section 1301(a) of title 31","children":[],"tail":", the Secretary of a military department may, under such regulations as he may prescribe, furnish stevedoring and terminal services and facilities to vessels carrying cargo, or passengers, or both, sponsored by his department."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida99570e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2633/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The furnishing of services and facilities under this section shall be at fair and reasonable rates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida99570e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2633/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The proceeds from furnishing services and facilities under this section shall be paid to the credit of the appropriation or fund out of which the services or facilities were supplied.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida99570e9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","c