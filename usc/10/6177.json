attrib":{},"text":"Collaboration required","children":[],"tail":"”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out headings for par. (4) “"},{"tag":"inline","attrib":{},"text":"Agreements to carry out projects","children":[],"tail":"” and subpars. (A) to (D) “"},{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":"”, “"},{"tag":"inline","attrib":{},"text":"Selection","children":[],"tail":"”, “"},{"tag":"inline","attrib":{},"text":"Cost-sharing","children":[],"tail":"”, and “"},{"tag":"inline","attrib":{},"text":"Briefing","children":[],"tail":"”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) and (2) headings which read as follows: “"},{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":"” and “"},{"tag":"inline","attrib":{},"text":"Areas of focus","children":[],"tail":"”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out headings for par. (3) “"},{"tag":"inline","attrib":{},"text":"Project selection","children":[],"tail":"” and subpars. (A) and (B) “"},{"tag":"inline","attrib":{},"text":"Selection","children":[],"tail":"” and “"},{"tag":"inline","attrib":{},"text":"Briefing","children":[],"tail":"”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) to (6) headings which read as follows: “"},{"tag":"inline","attr