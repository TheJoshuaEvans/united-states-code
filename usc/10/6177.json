{"tag":"section","attrib":{"id":"idaac42d88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177"},"text":null,"children":[{"tag":"num","attrib":{"value":"6177"},"text":"§ 6177.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other programs relating to technology development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaac42d89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incremental Technology Development Program","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac42d8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may establish a program, to be known as the “Incremental Technology Development Program”, to improve the efficiency and effectiveness of the defense environmental cleanup processes of the Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac42d8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out the Incremental Technology Development Program, the Secretary shall focus on the continuous improvement of new or available technologies, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaac42d8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decontamination chemicals and techniques;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaac42d8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remote sensing and wireless communication to reduce manpower and laboratory efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaac42d8f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detection, assay, and certification instrumentation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaac42d90-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" packaging materials, methods, and shipping systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42d91-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may include in the Incremental Technology Development Program mission-relevant development, demonstration, and deployment activities unrelated to the focus areas described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d92-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac42d93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out the Incremental Technology Development Program, the Secretary shall ensure that site offices of the Office conduct technology development, demonstration, testing, permitting, and deployment of new and emerging technologies to establish a sound technical basis for the selection of technologies for defense environmental cleanup or infrastructure operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42d94-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall collaborate, to the extent practicable, with the heads of other departments and agencies of the Federal Government, the National Laboratories, other Federal laboratories, appropriate State regulators and agencies, and the Department of Labor in the development, demonstration, testing, permitting, and deployment of new technologies under the Incremental Technology Development Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac42d96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out the Incremental Technology Development Program, the Secretary may enter into agreements with nongovernmental entities for technology development, demonstration, testing, permitting, and deployment projects to improve technologies in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42d97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall select projects under subparagraph (A) through a rigorous process that involves—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaac42d98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transparent and open competition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaac42d99-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review process that, if practicable, is conducted in an independent manner consistent with Department guidance on selecting and funding public-private partnerships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42d9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal share of the costs of the development, demonstration, testing, permitting, and deployment of new technologies carried out under this paragraph shall be not more than 70 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42d9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 120 days before the date on which the Secretary enters into the first agreement under subparagraph (A), the Secretary shall provide to the congressional defense committees a briefing on the process of selecting and funding efforts within the Incremental Technology Development Program, including with respect to the plans of the Secretary to ensure a scientifically rigorous process that minimizes potential conflicts of interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac42d9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"High-Impact Technology Development Program","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac42d9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall establish a program, to be known as the “High-Impact Technology Development Program”, under which the Secretary shall enter into agreements with nongovernmental entities for projects that pursue technologies that, with respect to the mission—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac42d9e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holistically address difficult challenges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42d9f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold the promise of breakthrough improvements; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42da0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" align existing or in-use technologies with difficult challenges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42da1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may include as areas of focus for a project carried out under the High-Impact Technology Development Program the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac42da2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Developing and demonstrating improved methods for source and plume characterization and monitoring, with an emphasis on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaac42da3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" real-time field acquisition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaac42da4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of indicator species analyses with advanced contaminant transport models to enable better understanding of contaminant migration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42da5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing and determining the limits of performance for remediation technologies and integrated remedial systems that prevent migration of contaminants, including by producing associated guidance and design manuals for technologies that could be widely used across the complex.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42da6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Demonstrating advanced monitoring approaches that use multiple lines of evidence for monitoring long-term performance of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaac42da7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remediation systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaac42da8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" noninvasive near-field monitoring techniques.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42da9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Developing and demonstrating methods to characterize the physical and chemical attributes of waste that control behavior, with an emphasis on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaac42daa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rapid and nondestructive examination and assay techniques; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaac42dab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods to determine radio-nuclide, heavy metals, and organic constituents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42dac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Demonstrating the technical basis for determining when enhanced or natural attenuation is an appropriate approach for remediation of complex sites.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42dad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing and demonstrating innovative methods to achieve real-time and, if practicable, in situ characterization data for tank waste and process streams that could be useful for all phases of the waste management program, including improving the accuracy and representativeness of characterization data for residual waste in tanks and ancillary equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42dae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Adapting existing waste treatment technologies or demonstrating new waste treatment technologies at the pilot plant scale using real wastes or realistic surrogates—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaac42daf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address engineering adaptations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaac42db0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure compliance with waste treatment standards and other applicable requirements under Federal and State law and any existing agreements or consent decrees to which the Department is a party; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaac42db1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2/G/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enable successful deployment at full-scale and in support of operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42db2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Developing and demonstrating rapid testing protocols that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaac42db3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are accepted by the Environmental Protection Agency, the Nuclear Regulatory Commission, the Department, and the scientific community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaac42db4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can be used to measure long-term waste form performance under realistic disposal environments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaac42db5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2/H/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can determine whether a stabilized waste is suitable for disposal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaac42db6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2/H/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the need for extensive, time-consuming, and costly analyses on every batch of waste prior to disposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42db7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing and demonstrating direct stabilization technologies to provide waste forms for disposing of elemental mercury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42db8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing and demonstrating innovative and effective retrieval methods for removal of waste residual materials from tanks and ancillary equipment, including mobile retrieval equipment or methods capable of immediately removing waste from leaking tanks, and connecting pipelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42db9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac42dba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall select projects to be carried out under the High-Impact Technology Development Program through a rigorous process that involves—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaac42dbb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transparent and open competition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaac42dbc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review process that, if practicable, is conducted in an independent manner consistent with Department guidance on selecting and funding public-private partnerships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42dbd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 120 days before the date on which the Secretary enters into the first agreement under paragraph (1), the Secretary shall provide to the congressional defense committees a briefing on the process of selecting and funding efforts within the High-Impact Technology Development Program, including with respect to the plans of the Secretary to ensure a scientifically rigorous process that minimizes potential conflicts of interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac42dbe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Environmental Management University Program","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac42dbf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall establish a program, to be known as the “Environmental Management University Program”, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac42dc0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage faculty, post-doctoral fellows or researchers, and graduate students of institutions of higher education on subjects relating to the mission to show a clear path for students for employment within the environmental management enterprise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42dc1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide institutions of higher education and the Department access to advances in engineering and science;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42dc2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clearly identify to institutions of higher education the tools necessary to enter into the environmental management field professionally; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42dc3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage current employees of the Department to pursue advanced degrees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42dc4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may include as areas of focus for a grant made under the Environmental Management University Program the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac42dc5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The atomic- and molecular-scale chemistries of waste processing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42dc6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contaminant immobilization in engineered and natural systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42dc7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing innovative materials, with an emphasis on nanomaterials or biomaterials, that could enable sequestration of challenging hazardous or radioactive constituents such as technetium and iodine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42dc8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Elucidating and exploiting complex speciation and reactivity far from equilibrium.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42dc9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Understanding and controlling chemical and physical processes at interfaces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42dca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Harnessing physical and chemical processes to revolutionize separations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42dcb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tailoring waste forms for contaminants in harsh chemical environments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac42dcc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Predicting and understanding subsurface system behavior and response to perturbations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42dcd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out the Environmental Management University Program, the Secretary may make individual research grants to faculty, post-doctoral fellows or researchers, and graduate students of institutions of higher education for three-year research projects, with an option for an extension of one additional two-year period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42dce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out the Environmental Management University Program, the Secretary may make research grants for strategic partnerships among scientists, faculty, post-doctoral fellows or researchers, and graduate students of institutions of higher education for three-year research projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42dcf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out the Environmental Management University Program, the Secretary may establish a summer internship program for undergraduates of institutions of higher education to work on projects relating to environmental management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42dd0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out the Environmental Management University Program, the Secretary may hold workshops with the Office of Environmental Management, the Office of Science, and members of academia and industry concerning environmental management challenges and solutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac42dd1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac42dd2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “complex” means all sites managed in whole or in part by the Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42dd3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Department” means the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42dd4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “institution of higher education” has the meaning given the term in section 101(a) of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"20 U.S.C. 1001(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42dd5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “mission” means the mission of the Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42dd6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “National Laboratory” has the meaning given the term in section 2 of the Energy Policy Act of 2005 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801"},"text":"42 U.S.C. 15801","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42dd7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Office” means the Office of Environmental Management of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42dd8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6177/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Energy, acting through the Assistant Secretary for Environmental Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac42dd9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1389"},"text":"139 Stat. 1389","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac42dda-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac42ddb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac42ddc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"re