{"tag":"section","attrib":{"id":"ida836cc71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949j"},"text":null,"children":[{"tag":"num","attrib":{"value":"949j"},"text":"§ 949j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity to obtain witnesses and other evidence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida836cc72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida836cc73-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Defense counsel in a military commission under this chapter shall have a reasonable opportunity to obtain witnesses and other evidence as provided in regulations prescribed by the Secretary of Defense. The opportunity to obtain witnesses and evidence shall be comparable to the opportunity available to a criminal defendant in a court of the United States under article III of the Constitution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida836cc74-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Process issued in military commissions under this chapter to compel witnesses to appear and testify and to compel the production of other evidence—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida836cc75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949j/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be similar to that which courts of the United States having criminal jurisdiction may lawfully issue; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida836cc76-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949j/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall run to any place where the United States shall have jurisdiction thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida836cc77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disclosure of Exculpatory Evidence","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida836cc78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As soon as practicable, trial counsel in a military commission under this chapter shall disclose to the defense the existence of any evidence that reasonably tends to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida836cc79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949j/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" negate the guilt of the accused of an offense charged; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida836cc7a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949j/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the degree of guilt of the accused with respect to an offense charged.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida836cc7b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The trial counsel shall, as soon as practicable, disclose to the defense the existence of evidence that reasonably tends to impeach the credibility of a witness whom the government intends to call at trial.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida836cc7c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949j/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The trial counsel shall, as soon as practicable upon a finding of guilt, disclose to the defense the existence of evidence that is not subject to paragraph (1) or paragraph (2) but that reasonably may be viewed as mitigation evidence at sentencing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida836cc7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949j/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The disclosure obligations under this subsection encompass evidence that is known or reasonably should be known to any government officials who participated in the investigation and prosecution of the case against the defendant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida836cc7e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tXVIII/s1802"},"text":"Pub. L. 111–84, div. A, title XVIII, § 1802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2587"},"text":"123 Stat. 2587","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida836cc7f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida836cc80-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida836cc81-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 949j, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/366/s3/a/1"},"text":"Pub. L. 109–366, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2614"},"text":"120 Stat. 2614","children":[],"tail":", related to the opportunity to obtain witnesses and other evidence, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
