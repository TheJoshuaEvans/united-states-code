{"tag":"section","attrib":{"id":"idabb7671a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14509"},"text":null,"children":[{"tag":"num","attrib":{"value":"14509"},"text":"§ 14509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separation at age 62: reserve officers in grades below brigadier general or rear admiral (lower half)","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each reserve officer of the Army, Navy, Air Force, or Marine Corps in a grade below brigadier general or rear admiral (lower half) who has not been recommended for promotion to the grade of brigadier general or rear admiral (lower half) and is not a member of the Retired Reserve shall, on the last day of the month in which that officer becomes 62 years of age, be separated in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14515"},"text":"section 14515 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idabb7671b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2952"},"text":"108 Stat. 2952","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s503/c"},"text":"Pub. L. 109–364, div. A, title V, § 503(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2178"},"text":"120 Stat. 2178","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb7671c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editori