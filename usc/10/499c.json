{"tag":"section","attrib":{"id":"ida7cb85ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c"},"text":null,"children":[{"tag":"num","attrib":{"value":"499c"},"text":"§ 499c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Portfolio management framework for nuclear forces","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7cb8600-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2024-01-01"},"text":"January 1, 2024","children":[],"tail":", the Secretary of Defense shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7cb8601-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" implement a portfolio management framework for nuclear forces of the United States that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7cb8602-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifies the portfolio of nuclear forces covered by the framework;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb8603-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes a portfolio governance structure for such forces that takes advantage of, or is modeled on, an existing portfolio governance structure, such as the Deputy’s Management Action Group described in Department of Defense Directive 5105.79;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb8604-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outlines the approach of the Secretary for identifying and managing risk relating to such forces and prioritizing the efforts among such forces, including how the Secretary, acting through the Under Secretary of Defense for Acquisition and Sustainment, will coordinate such identification, management, and prioritization with the Administrator for Nuclear Security using the coordination processes of the Nuclear Weapons Council; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb8605-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporates the findings and recommendations identified by the Comptroller General of the United States in the report titled “Nuclear Enterprise: DOD and NNSA Could Further Enhance How They Manage Risk and Prioritize Efforts” (GAO–22–104061) and dated January 2022; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb8606-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete a comprehensive assessment of the portfolio management capabilities required to identify and manage risk in the portfolio of nuclear forces, including how to draw upon public and private sector resources and the program management expertise within the Defense Acquisition University.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7cb8607-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Briefings; Notifications","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7cb8608-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In conjunction with the submission of the budget of the President to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":" for fiscal year 2025 and each fiscal year thereafter through the date specified in subsection (c), the Secretary shall provide to the congressional defense committees a briefing on identifying and managing risk relating to nuclear forces and prioritizing the efforts among such forces, including, with respect to the period covered by the briefing—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7cb8609-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current and projected operational requirements for nuclear forces that were used for such identification, management, and prioritization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb860a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" key areas of risk identified; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb860b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the actions proposed or carried out to mitigate such risk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb860c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may provide the briefings under paragraph (1) in classified form.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb860d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a House of Congress adopts a bill authorizing or appropriating funds that, as determined by the Secretary, provides funds in an amount that will result in a significant delay in the nuclear certification or delivery of nuclear forces, the Secretary shall notify the congressional defense committees of the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7cb860e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of this section shall terminate 90 days after the date on which the Secretary certifies to the congressional defense committees that each of the following have achieved full operational capability:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7cb860f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The LGM–35A Sentinel intercontinental ballistic missile weapon system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb8610-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Columbia-class ballistic missile submarine program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb8611-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The long-range standoff weapon program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb8612-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The B–21 Raider bomber aircraft program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb8613-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The F–35A dual-capable aircraft program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7cb8614-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nuclear Forces Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “nuclear forces” includes, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7cb8615-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nuclear weapons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb8616-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the delivery platforms and systems for nuclear weapons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb8617-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nuclear command, control, and communications systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb8618-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s499c/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the infrastructure and facilities of the Department of Defense and the National Nuclear Security Administration that support nuclear weapons, the delivery platforms and systems for nuclear weapons, and nuclear command, control, and communications systems, including with respect to personnel, construction, operation, and maintenance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7cb8619-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tXVI/s1634/a"},"text":"Pub. L. 117–263, div. A, title XVI, § 1634(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2938"},"text":"136 Stat. 2938","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
