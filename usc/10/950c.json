{"tag":"section","attrib":{"id":"ida8393c6e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950c"},"text":null,"children":[{"tag":"num","attrib":{"value":"950c"},"text":"§ 950c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appellate referral; waiver or withdrawal of appeal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8393c6f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Automatic Referral for Appellate Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), in each case in which the final decision of a military commission under this chapter (as approved by the convening authority) includes a finding of guilty, the convening authority shall refer the case to the United States Court of Military Commission Review. Any such referral shall be made in accordance with procedures prescribed under regulations of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8393c70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver of Right of Review","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8393c71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except in a case in which the sentence as approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s950b"},"text":"section 950b of this title","children":[],"tail":" extends to death, an accused may file with the convening authority a statement expressly waiving the right of the accused to appellate review by the United States Court of Military Commission Review under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s950f"},"text":"section 950f of this title","children":[],"tail":" of the final decision of the military commission under this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8393c72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A waiver under paragraph (1) shall be signed by both the accused and a defense counsel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8393c73-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A waiver under paragraph (1) must be filed, if at all, within 10 days after notice of the action is served on the accused or on defense counsel under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s950b/c/4"},"text":"section 950b(c)(4) of this title","children":[],"tail":". The convening authority, for good cause, may extend the period for such filing by not more than 30 days."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8393c74-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Withdrawal of Appeal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except in a case in which the sentence as approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s950b"},"text":"section 950b of this title","children":[],"tail":" extends to death, the accused may withdraw an appeal at any time."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8393c75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Waiver or Withdrawal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A waiver of the right to appellate review or the withdrawal of an appeal under this section bars review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s950f"},"text":"section 950f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8393c76-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tXVIII/s1802"},"text":"Pub. L. 111–84, div. A, title XVIII, § 1802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2600"},"text":"123 Stat. 2600","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8393c77-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8393c78-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida8393c79-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 950c, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/366/s3/a/1"},"text":"Pub. L. 109–366, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2620"},"text":"120 Stat. 2620","children":[],"tail":", related to appellate referral and waiver or withdrawal of appeal, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
