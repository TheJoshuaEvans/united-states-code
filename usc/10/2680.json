{"tag":"section","attrib":{"id":"ida9a8838e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680"},"text":null,"children":[{"tag":"num","attrib":{"value":"2680"},"text":"§ 2680.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum capital investment for facilities sustainment, restoration, and modernization for military departments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9a8838f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum Investment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning in fiscal year 2027, and each fiscal year thereafter, each Secretary of a military department shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9a88390-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" calculate (in accordance with subsection (b)) the cumulative plant replacement value of the total inventory of covered facilities on each military installation under the jurisdiction of the Secretary concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a88391-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" invest in the budget for facilities sustainment, restoration, and modernization of that military department, a total amount equal to not less than the percentage specified in subsection (c) of the cumulative plant replacement value described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9a88392-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In making any calculation pursuant to paragraph (1) of subsection (a), each Secretary of a military department shall exclude any covered facility under the jurisdiction of such Secretary that is scheduled for demolition during the two-year period beginning after the date of such calculation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9a88393-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Percentage Specified","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The percentage of the specified in this subsection is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9a88394-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2027, 1.75 percent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a88395-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2028, 2.5 percent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a88396-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2029, 3.25 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a88397-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2030 and each subsequent fiscal year, 4 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9a88398-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the annual budget submission of the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", each Secretary of each military department shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9a88399-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification to the congressional defense committees that the military department is in compliance with this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a8839a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of covered facilities under the jurisdiction of that Secretary, disaggregated by military installation and location, that are scheduled for demolition during the two-year period beginning after the date of the submission of such budget, which shall include cost and schedule estimates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9a8839b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9a8839c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered facility” means a facility (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2801"},"text":"section 2801 of this title","children":[],"tail":"), except that such term does not include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9a8839d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a facility identified as closed, disposed of, or scheduled for divestment from the inventory of the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9a8839e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a facility in which the Department does not have a total ownership interest, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9a8839f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a facility leased by the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9a883a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a facility in which the Department has a lesser property interest under a governing legal instrument; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9a883a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a facility for which the Department uses—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9a883a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/e/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonappropriated funds; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9a883a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/e/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts appropriated or otherwise made available for military family housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a883a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “plant replacement value” means, with respect to a covered facility, the cost to replace the covered facility using amounts appropriated for facilities sustainment, restoration, and modernization from the following accounts:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9a883a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operation and maintenance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9a883a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Military construction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9a883a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Research, development, test, and evaluation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9a883a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2680/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Working capital funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9a883a9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dB/tXXVIII/s2841/a"},"text":"Pub. L. 118–159, div. B, title XXVIII, § 2841(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2262"},"text":"138 Stat. 2262","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dB/tXXVIII/s2841"},"text":"Pub. L. 119–60, div. B, title XXVIII, § 2841","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1316"},"text":"139 Stat. 1316","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9a883aa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9a883ab-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida9a883ac-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2680, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dB/tXXVIII/s2863/a/1"},"text":"Pub. L. 102–190, div. B, title XXVIII, § 2863(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1560"},"text":"105 Stat. 1560","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dB/tXXVIII/s2807/a"},"text":"Pub. L. 103–160, div. B, title XXVIII, § 2807(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1887"},"text":"107 Stat. 1887","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dB/tXXVIII/s2820/a"},"text":"Pub. L. 104–106, div. B, title XXVIII, § 2820(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/556"},"text":"110 Stat. 556","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1067/1"},"text":"Pub. L. 106–65, div. A, title X, § 1067(1)","children":[],"tail":", div. B, title XXVIII, § 2811, "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/774"},"text":"113 Stat. 774","children":[],"tail":", 851; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tX/s1062/a/13"},"text":"Pub. L. 107–314, div. A, title X, § 1062(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2650"},"text":"116 Stat. 2650","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tX/s1031/a/31"},"text":"Pub. L. 108–136, div. A, title X, § 1031(a)(31)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1600"},"text":"117 Stat. 1600","children":[],"tail":", related to leases of land for special operations activities, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dB/tXXVIII/s2814/a"},"text":"Pub. L. 111–383, div. B, title XXVIII, § 2814(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4464"},"text":"124 Stat. 4464","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2680, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/651/tI/s112/c"},"text":"Pub. L. 87–651, title I, § 112(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/511"},"text":"76 Stat. 511","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s20"},"text":"Pub. L. 89–718, § 20","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1118"},"text":"80 Stat. 1118","children":[],"tail":", authorized reimbursement of moving expenses to owners of property acquired for public works projects, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/91/646/tII/s220/a/3"},"text":"Pub. L. 91–646, title II, § 220(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-02"},"text":"Jan. 2, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1903"},"text":"84 Stat. 1903","children":[],"tail":". See section 4601 et seq. of Title 42, The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9a883ad-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s2841/1"},"text":"Pub. L. 119–60, § 2841(1)","children":[],"tail":", substituted “total inventory of covered facilities” for “total inventory of facilities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s2841/2"},"text":"Pub. L. 119–60, § 2841(2)","children":[],"tail":", substituted “covered facility” for “facility”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s2841/3"},"text":"Pub. L. 119–60, § 2841(3)","children":[],"tail":", substituted “covered facilities” for “facilities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s2841/4"},"text":"Pub. L. 119–60, § 2841(4)","children":[],"tail":", added subsec. (e) and struck out former subsec. (e). Prior to amendment, text read as follows: “In this section, the term ‘plant replacement value’ means, with respect to a facility, the cost to replace such facility using construction costs (including labor and materials) and standards (including methodologies and codes) in effect as of the date such cost is calculated.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9a883ae-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9a883af-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effect of Repeal","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/dB/tXXVIII/s2814/b"},"text":"Pub. L. 111–383, div. B, title XXVIII, § 2814(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4464"},"text":"124 Stat. 4464","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/383/dB/tXXVIII/s2814/b"},"text":"“The amendment made by subsection (a) [repealing former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2680"},"text":"section 2680 of this title","children":[],"tail":"] shall not affect the validity of any contract entered into under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2680"},"text":"section 2680 of title 10","children":[],"tail":", United States Code, on or before "},{"tag":"date","attrib":{"date":"2005-09-30"},"text":"September 30, 2005","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
