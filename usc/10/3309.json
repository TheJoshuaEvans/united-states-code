{"tag":"section","attrib":{"id":"idaa1d3e72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3309"},"text":null,"children":[{"tag":"num","attrib":{"value":"3309"},"text":"§ 3309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on release of contractor proposals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa1d3e73-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3309/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “proposal” means any proposal, including a technical, management, or cost proposal, submitted by a contractor in response to the requirements of a solicitation for a competitive proposal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa1d3e74-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3309/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (c), a proposal in the possession or control of an agency named in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3063"},"text":"section 3063 of this title","children":[],"tail":" may not be made available to any person under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa1d3e75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3309/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (b) does not apply to any proposal that is set forth or incorporated by reference in a contract entered into between the Department and the contractor that submitted the proposal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa1d3e76-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1816/d"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1816(d)","children":[],"tail":", (f), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4185"},"text":"134 Stat. 4185","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa1d3e77-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa1d3e78-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa1d3e79-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2305"},"text":"section 2305 of this title","children":[],"tail":", which was transferred to this section and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1816/f"},"text":"Pub. L. 116–283, § 1816(f)","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tVIII/s821/a"},"text":"Pub. L. 104–201, div. A, title VIII, § 821(a)","children":[],"tai