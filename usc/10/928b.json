{"tag":"section","attrib":{"id":"ida82fc653-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s928b"},"text":null,"children":[{"tag":"num","attrib":{"value":"928b"},"text":"§ 928b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 128b. Domestic violence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida82fc654-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s928b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82fc655-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s928b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commits a violent offense against a spouse, an intimate partner, a dating partner, or an immediate family member of that person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc656-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s928b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with intent to threaten or intimidate a spouse, an intimate partner, a dating partner, or an immediate family member of that person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida82fc657-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s928b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commits an offense under this chapter against any person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82fc658-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s928b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commits an offense under this chapter against any property, including an animal;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc659-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s928b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with intent to threaten or intimidate a spouse, an intimate partner, a dating partner, or an immediate family member of that person, violates a protection order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc65a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s928b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with intent to commit a violent offense against a spouse, an intimate partner, a dating partner, or an immediate family member of that person, violates a protection order; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc65b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s928b/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assaults a spouse, an intimate partner, a dating partner, or an immediate family member of that person by strangling or suffocating;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82fc65c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s928b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","c