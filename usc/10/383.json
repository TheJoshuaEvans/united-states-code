{"tag":"section","attrib":{"id":"ida7a7d233-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s383"},"text":null,"children":[{"tag":"num","attrib":{"value":"383"},"text":"§ 383.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment, monitoring, and evaluation of programs and activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7a7d234-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s383/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall maintain a program of assessment, monitoring, and evaluation in support of the security cooperation programs and activities of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a7d235-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s383/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Elements and Requirements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a7d236-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s383/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program under subsection (a) shall provide for the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a7d237-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s383/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Initial assessments of partner capability requirements, potential programmatic risks, baseline information, and indicators of efficacy for purposes of planning, monitoring, and evaluation of security cooperation programs and activities of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a7d238-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s383/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Monitoring of implementation of such programs and activities in order to measure progress in execution and, to the extent possible, achievement of desired outcomes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a7d239-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s383/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evaluation of the efficiency and effectiveness of such programs and activities in achieving desired outcomes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a7d23a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s383/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identification of lessons learned in carrying out such programs and activities, and development of recommendation for improving future security cooperation programs and activities of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a7d23b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s383/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Incorporation of lessons learned from prior security cooperation programs and activities of the Department of Defense that were carried out any time on or after ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a7d23c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s383/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Best practices","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The program shall be conducted in accordance with international best practices, interagency standards, and, if applicable, the Government Performance and Results Act of 1993 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/62"},"text":"Public Law 103–62","children":[],"tail":"), and the amendments made by that Act, and the GPRA Modernization Act of 2010 ("},{"tag":"ref","attrib":{"href":"/us/pl/111/352"},"text":"Public Law 111–352","children":[],"tail":"), and the amendments made by that Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a7d23d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s383/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Funds.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a7d23e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s383/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds available to the Defense Security Cooperation Agency, and other funds available to the Department of Defense for security cooperation programs and activities of the Department of Defense, may be used to carry out the program required by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a7d23f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s383/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Budget justification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds described in paragraph (1) for a fiscal year shall be identified, with appropriate justification, in the consolidated budget for such fiscal year required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s381"},"text":"section 381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a7d240-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s383/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a7d241-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s383/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports to congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit to the congressional defense committees each year a report on the program under subsection (a) during the previous year. Each report shall include, for the year covered by such report, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a7d242-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s383/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the activities under the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a7d243-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s383/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An evaluation of the lessons learned, including a description of challenges in executing the program, and best practices identified through activities under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a7d244-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s383/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information for the public on evaluations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall make available to the public, on an Internet website of the Department of Defense available to the public, a summary of each evaluation conducted pursuant to subsection (b)(1)(C). In making a summary so available, the Secretary may redact or omit any information that the Secretary determines should not be disclosed to the public in order to protect the interest of the United States or the foreign country or countries covered by such evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7a7d245-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1241/m"},"text":"Pub. L. 114–328, div. A, title XII, § 1241(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2510"},"text":"130 Stat. 2510","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXII/s1211/c"},"text":"Pub. L. 115–232, div. A, title XII, § 1211(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2024"},"text":"132 Stat. 2024","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXII/s1203"},"text":"Pub. L. 118–159, div. A, title XII, § 1203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2094"},"text":"138 Stat. 2094","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7a7d246-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7a7d247-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida7a7d248-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Government Performance and Results Act of 1993, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/62"},"text":"Pub. L. 103–62","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-03"},"text":"Aug. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/285"},"text":"107 Stat. 285","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s306"},"text":"section 306 of Title 5","children":[],"tail":", Government Organization and Employees, sections 1115 to 1119, 9703, and 9704 of Title 31, Money and Finance, and sections 2801 to 2805 of Title 39, Postal Service, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of Title 31","children":[],"tail":", and enacted provisions set out as notes under sections 1101 and 1115 of Title 31. For complete classification of this Act to the Code, see Short Title of 1993 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1101"},"text":"section 1101 of Title 31","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The GPRA Modernization Act of 2010, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/352"},"text":"Pub. L. 111–352","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3866"},"text":"124 Stat. 3866","children":[],"tail":", which enacted sections 1115, 1116, and 1120 to 1125 of Title 31, Money and Finance, and "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s306"},"text":"section 306 of Title 5","children":[],"tail":", Government Organization and Employees, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of Title 31","children":[],"tail":", repealed sections 1115 and 1116 of Title 31 and "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s306"},"text":"section 306 of Title 5","children":[],"tail":", and enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1115"},"text":"section 1115 of Title 31","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5105"},"text":"section 5105 of Title 5","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2011 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1101"},"text":"section 1101 of Title 31","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida7a7d249-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 383 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s283"},"text":"section 283 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7a7d24a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" inserted “, including a description of challenges in executing the program,” after “lessons learned”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" added subpar. (E)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
