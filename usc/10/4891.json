:"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1425"},"text":"102 Stat. 1425","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4565/a"},"text":"section 4565(a) of Title 50","children":[],"tail":", War and National Defense. Section 721(a) of the Act was struck out, and a new section 721(a) was added, by "},{"tag":"ref","attrib":{"href":"/us/pl/110/49/s2"},"text":"Pub. L. 110–49, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-07-26"},"text":"July 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/246"},"text":"121 Stat. 246","children":[],"tail":". As so added, section 721(a) does not refer to investigations by the President or the President’s designee."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaaa9ef08-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2537"},"text":"section 2537 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" redesignated subsec. (c) as (b) and struck out former subsec. (b) which required annual reports to Congress regarding the information collected under subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4565/a"},"text":"50 U.S.C. 4565(a)","children":[],"tail":")” for “(50 U.S.C. App. 2170(a))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" substituted “$10,000,000” for “$100,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/35/s201/d/5"},"text":"Pub. L. 103–35, § 201(d)(5)","children":[],"tail":", substituted “respectively, that” for “respectively, which”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/35/s201/h/2"},"text":"Pub. L. 103–35, § 201(h)(2)","children":[],"tail":", struck out subsec. (d) which read as follows: “In this section, the term ‘defense critical technology’ has the meaning provided that term by "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2491/8"},"text":"section 2491(8) of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaaa9ef09-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaaa9ef0a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"ta