{"tag":"section","attrib":{"id":"ida84ec038-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044"},"text":null,"children":[{"tag":"num","attrib":{"value":"1044"},"text":"§ 1044.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida84ec039-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to the availability of legal staff resources, the Secretary concerned may provide legal assistance in connection with their personal civil legal affairs to the following persons:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84ec03a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the armed forces who are on active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec03b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members and former members entitled to retired or retainer pay or equivalent pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec03c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Officers of the commissioned corps of the Public Health Service or the commissioned officer corps of the National Oceanic and Atmospheric Administration who are on active duty or entitled to retired or equivalent pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec03d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of reserve components not covered by paragraph (1) or (2) following release from active duty under a call or order to active duty for more than 30 days issued under a mobilization authority (as determined by the Secretary), for a period of time (prescribed by the Secretary) that begins on the date of the release and is not less than twice the length of the period served on active duty under that call or order to active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec03e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Dependents of members and former members described in paragraphs (1), (2), (3), and (4).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec03f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Survivors of a deceased member or former member described in paragraphs (1), (2), (3), and (4) who were dependents of the member or former member at the time of the death of the member or former member, except that the eligibility of such survivors shall be determined pursuant to regulations prescribed by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec040-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Civilian employees of the Federal Government serving in locations where legal assistance from non-military legal assistance providers is not reasonably available, except that the eligibility of civilian employees shall be determined pursuant to regulations prescribed by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84ec041-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under such regulations as may be prescribed by the Secretary concerned, the Judge Advocate General (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s801/1"},"text":"section 801(1) of this title","children":[],"tail":") under the jurisdiction of the Secretary, and within the Marine Corps the Staff Judge Advocate to the Commandant of the Marine Corps, is responsible for the establishment and supervision of legal assistance programs under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84ec042-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not authorize legal counsel to be provided to represent a member or former member of the uniformed services described in subsection (a), or the dependent of such a member or former member, in a legal proceeding if the member or former member can afford legal fees for such representation without undue hardship.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84ec043-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84ec044-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any law regarding the licensure of attorneys, a judge advocate or civilian attorney who is authorized to provide military legal assistance is authorized to provide that assistance in any jurisdiction, subject to such regulations as may be prescribed by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec045-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Military legal assistance may be provided only by a judge advocate or a civilian attorney who is a member of the bar of a Federal court or of the highest court of a State and, for purposes of service as a Special Victims’ Counsel under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1044e"},"text":"section 1044e of this title","children":[],"tail":", satisfies the additional qualifications and training requirements specified in subsection (d) of such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec046-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection, the term “military legal assistance” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida84ec047-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legal assistance provided under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida84ec048-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legal assistance contemplated by sections 1044a, 1044b, 1044c, 1044d, 1044e, 1565b(a)(1)(A), and 2894(b)(4) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84ec049-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned shall define “dependent” for the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida84ec04a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tVI/s651/a"},"text":"Pub. L. 98–525, title VI, § 651(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2549"},"text":"98 Stat. 2549","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s583"},"text":"Pub. L. 104–201, div. A, title V, § 583","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2538"},"text":"110 Stat. 2538","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 524(a), (b)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–108; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s555"},"text":"Pub. L. 109–163, div. A, title V, § 555","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3265"},"text":"119 Stat. 3265","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tV/s541"},"text":"Pub. L. 110–181, div. A, title V, § 541","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/114"},"text":"122 Stat. 114","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tV/s513"},"text":"Pub. L. 111–84, div. A, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2282"},"text":"123 Stat. 2282","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tV/s531/d/2"},"text":"Pub. L. 112–239, div. A, title V, § 531(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1726"},"text":"126 Stat. 1726","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tXVII/s1716/a/3/A"},"text":"Pub. L. 113–66, div. A, title XVII, § 1716(a)(3)(A)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/969"},"text":"127 Stat. 969","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1071/f/12"},"text":"Pub. L. 113–291, div. A, title X, § 1071(f)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3510"},"text":"128 Stat. 3510","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tV/s535/c"},"text":"Pub. L. 114–92, div. A, title V, § 535(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/816"},"text":"129 Stat. 816","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dB/tXXX/s3022/b"},"text":"Pub. L. 116–92, div. B, title XXX, § 3022(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1934"},"text":"133 Stat. 1934","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXVII/s11707"},"text":"Pub. L. 117–263, div. K, title CXVII, § 11707","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4158"},"text":"136 Stat. 4158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida84ec04b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida84ec04c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida84ec04d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" inserted “or the commissioned officer corps of the National Oceanic and Atmospheric Administration” after “Public Health Service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (d)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “1565b(a)(1)(A), and 2894(b)(4)” for “and 1565b(a)(1)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" substituted “satisfies the additional qualifications and training requirements specified in subsection (d)” for “meets the additional qualifications specified in subsection (d)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" substituted “such section.” for “such section..”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" inserted “, and within the Marine Corps the Staff Judge Advocate to the Commandant of the Marine Corps,” after “jurisdiction of the Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1716/a/3/A"},"text":"Pub. L. 113–66, § 1716(a)(3)(A)","children":[],"tail":", inserted before period at end “and, for purposes of service as a Special Victims’ Counsel under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1044e"},"text":"section 1044e of this title","children":[],"tail":", meets the additional qualifications specified in subsection (d)(2) of such section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1716/a/3/B"},"text":"Pub. L. 113–66, § 1716(a)(3)(B)","children":[],"tail":", substituted “1044d, 1044e, and 1565b(a)(1)(A)” for “and 1044d”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" substituted “the Secretary), for a period of time (prescribed by the Secretary)” for “the Secretary of Defense), for a period of time, prescribed by the Secretary of Defense,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" added pars. (6) and (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 524(a)(2)], added par. (4). Former par. (4) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 524(b)], substituted “(3), and (4)” for “and (3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 524(a)(1)], redesignated par. (4) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s583/d/1"},"text":"Pub. L. 104–201, § 583(d)(1)","children":[],"tail":", substituted “to the following persons:” for “to—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s583/c"},"text":"Pub. L. 104–201, § 583(c)","children":[],"tail":", (d)(2), (3), substituted “Members” for “members”, struck out “under his jurisdiction” after “armed forces”, and substituted a period for the semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s583/c"},"text":"Pub. L. 104–201, § 583(c)","children":[],"tail":", (d)(2), (4), substituted “Members and” for “members and”, struck out “under his jurisdiction” after “former members”, and substituted a period for “; and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s583/a"},"text":"Pub. L. 104–201, § 583(a)","children":[],"tail":", added pars. (3) and (4) and struck out former par. (3) which read as follows: “dependents of members and former members described in clauses (1) and (2).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s583/b"},"text":"Pub. L. 104–201, § 583(b)","children":[],"tail":", substituted “uniformed services described in subsection (a)” for “armed forces” and inserted “such” after “dependent of”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida84ec04e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida84ec04f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 524(c)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–108, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/398/s1/dA"},"text":"“Regulations to implement the amendments made by this section [amending this section] shall be prescribed not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida84ec050-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Legal Counsel for Victims of Alleged Domestic Violence Offenses","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tV/s548"},"text":"Pub. L. 116–92, div. A, title V, § 548","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1378"},"text":"133 Stat. 1378","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dA/tV/s548"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2020-12-01"},"text":"December 1, 2020","children":[],"tail":", the Secretary of Defense shall carry out a program to provide legal counsel (referred to in this section as ‘Counsel’) to victims of alleged domestic violence offenses who are otherwise eligible for military legal assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1044"},"text":"section 1044 of title 10","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form of Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The program required under subsection (a) may be carried out as part of another program of the Department of Defense or through the establishment of a separate program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training and Terms","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall ensure that Counsel—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive specialized training in legal issues commonly associated with alleged domestic violence offenses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, serve as Counsel for a period of not less than 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attorney-client Relationship","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The relationship between a Counsel and a victim in the provision of legal advice and assistance shall be the relationship between an attorney and client.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Paralegal Support","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall ensure that sufficient trained paralegal support is provided to Counsel under the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report Required.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"], the Secretary of Defense shall submit to the Committees on Armed Services of the Senate and the House of Representatives a report on the implementation of the program under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description and assessment of the manner in which the Department of Defense will implement the program required under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An explanation of whether the program will be carried out as part of another program of the Department or through the establishment of a separate program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A comprehensive description of the additional personnel, resources, and training that will be required to implement the program, including identification of the specific number of additional billets that will be needed to staff the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommendations for any modifications to law that may be necessary to effectively and efficiently implement the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alleged Domestic Violence Offense Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term ‘alleged domestic violence offense’ means any allegation of—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a violation of section 928(b), 928b(1), 928b(5), or 930 of title 10, United States Code (article 128(b), 128b(1), 128b(5), or 130 of the Uniform Code of Military Justice), when committed against a spouse, intimate partner, or immediate family member;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a violation of any other provision of subchapter X of chapter 47 of such title (the Uniform Code of Military Justice), when committed against a spouse, intimate partner, or immediate family member; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an attempt to commit an offense specified in paragraph (1) or (2) as punishable under section 880 of such title (article 80 of the Uniform Code of Military Justice).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
