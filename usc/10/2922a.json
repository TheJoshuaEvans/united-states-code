{"tag":"section","attrib":{"id":"ida9fbfba4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2922a"},"text":"§ 2922a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts for energy or fuel for military installations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9fbfba5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to subsection (b), the Secretary of a military department may enter into contracts for periods of up to 30 years—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9fbfba6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2917"},"text":"section 2917 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fbfba7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the provision and operation of energy production facilities on real property under the Secretary’s jurisdiction or on private property and the purchase of energy produced from such facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9fbfba8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contract may be made under subsection (a) only after the approval of the proposed contract by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9fbfba9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The costs of contracts under this section for any year may be paid from annual appropriations for that year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9fbfbaa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned shall ensure energy security and energy resilience are included as critical factors in the provision and operation of energy production facilities under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9fbfbab-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/214/s6/a/1"},"text":"Pub. L. 97–214, § 6(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-07-12"},"text":"July 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/171"},"text":"96 Stat. 171","children":[],"tail":", § 2394; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/321/tVIII/s805/b/3"},"text":"Pub. L. 97–321, title VIII, § 805(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1573"},"text":"96 Stat. 1573","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s7/k/2"},"text":"Pub. L. 100–26, § 7(k)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/284"},"text":"10