alNotes","id":"ida9fbfbad-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9fbfbae-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “energy resilience are included as critical factors” for “resilience are prioritized and included”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" amended subsec. (d) generally. Prior to amendment, subsec. (d) read as follows: “The Secretary concerned shall prioritize energy security and resilience.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s2851/b/2"},"text":"Pub. L. 109–364, § 2851(b)(2)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2394"},"text":"section 2394 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s2851/b/3/C"},"text":"Pub. L. 109–364, § 2851(b)(3)(C)","children":[],"tail":", substituted “section 2917” for “section 2689”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" substituted “only after the approval of the proposed contract by the Secretary of Defense” for “only—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) after the approval of the proposed contract by the Secretary of Defense; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) after the Committees on Armed Services and on Appropriations of the Senate and House of Representatives have been notified of the terms of the proposed contract, including the dollar amount of the contract and the amount of energy or fuel to be delivered to the Government under the contract”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/26"},"text":"Pub. L. 100–26","children":[],"tail":", which directed that “The term” be inserted in each paragraph after the paragraph designation and the first word after the first quotation marks in each paragraph be revised so that the initial letter of such word is lowercase, could not be executed because subsec. (c) contained no paragraphs and no quoted words. The probable intent of Congress was to amend "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2393/c"},"text":"section 2393(c) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/321/s805/b/3/A"},"text":"Pub. L. 97–321, § 805(b)(3)(A)","children":[],"tail":", substituted “subsection (b)” for “subsection (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/321/s805/b/3/B"},"text":"Pub. L. 97–321, § 805(b)(3)(B)","children":[],"tail":", redesignated subsec. (d) as (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9fbfbaf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9fbfbb0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", and applicable to military construction projects, and to construction and acquisition of military family housing authorized before, on, or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/214/s12/a"},"text":"section 12(a) of Pub. L. 97–214","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2801"},"text":"section 2801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
