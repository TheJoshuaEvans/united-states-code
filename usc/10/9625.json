and 50:70, since those sales may be made to officers of the Coast Guard under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s114/c"},"text":"section 114(c) of Title 14","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab83102c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab83102d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/12/B"},"text":"Pub. L. 116–283, § 923(e)(12)(B)","children":[],"tail":", amended section catchline generally. Prior to amendment, catchline read as follows: “Ordnance property: officers of armed forces; civilian employees of Air Force; American National Red Cross; educational institutions; homes for veterans’ orphans”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/12/A/i"},"text":"Pub. L. 116–283, § 923(e)(12)(A)(i)","children":[],"tail":", inserted “or the Space Force” after “officers of the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/12/A/ii"},"text":"Pub. L. 116–283, § 923(e)(12)(A)(ii)","children":[],"tail":", substituted “the Department of the Air Force” for “the Air Force”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
