ib":{},"text":" Program lead software.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida903df9e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan of Action","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall develop and implement a plan of action for recruiting, training, and ensuring appropriate career development of military and civilian personnel to achieve the objective established in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida903df9f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tVIII/s824/a/1"},"text":"Pub. L. 112–239, div. A, title VIII, § 824(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1832"},"text":"126 Stat. 1832","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVIII/s812"},"text":"Pub. L. 116–283, div. A, title VIII, § 812","children":[],"tail":", title XVIII, § 1846(i)(3), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3749"},"text":"134 Stat. 3749","children":[],"tail":", 4252; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1846/j"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1846(j)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/b/15/C"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(b)(15)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail"