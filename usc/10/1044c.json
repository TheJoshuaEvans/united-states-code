{"tag":"section","attrib":{"id":"ida84ec070-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1044c"},"text":"§ 1044c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance medical directives of members and dependents: requirement for recognition by States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida84ec071-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Instruments To Be Given Legal Effect Without Regard to State Law","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An advance medical directive executed by a person eligible for legal assistance—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84ec072-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is exempt from any requirement of form, substance, formality, or recording that is provided for advance medical directives under the laws of a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec073-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be given the same legal effect as an advance medical directive prepared and executed in accordance with the laws of the State concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84ec074-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advance Medical Directives","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, an advance medical directive is any written declaration that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84ec075-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sets forth directions regarding the provision, withdrawal, or withholding of life-prolonging procedures, including hydration and sustenance, for the declarant whenever the declarant has a terminal physical condition or is in a persistent vegetative state; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec076-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizes another person to make health care decisions for the declarant, under circumstances stated in the declaration, whenever the declarant is incapable of making informed health care decisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84ec077-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statement To Be Included","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84ec078-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed by the Secretary concerned, an advance medical directive prepared by an attorney authorized to provide legal assistance shall contain a statement that sets forth the provisions of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec079-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) shall not be construed to make inapplicable the provisions of subsection (a) to an advance medical directive that does not include a statement described in that paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84ec07a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"States Not Recognizing Advance Medical Directives","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) does not make an advance medical directive enforceable in a State that does not otherwise recognize and enforce advance medical directives under the laws of the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84ec07b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84ec07c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” includes the District of Columbia, the Commonwealth of Puerto Rico, and a possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec07d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person eligible for legal assistance” means a person who is eligible for legal assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1044"},"text":"section 1044 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84ec07e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044c/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “legal assistance” means legal services authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1044"},"text":"section 1044 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida84ec07f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tVII/s749/a/1"},"text":"Pub. L. 104–106, div. A, title VII, § 749(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/388"},"text":"110 Stat. 388","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida84ec080-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida84ec081-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida84ec082-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tVII/s749/b"},"text":"Pub. L. 104–106, div. A, title VII, § 749(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/389"},"text":"110 Stat. 389","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/106/dA/tVII/s749/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1044c"},"text":"Section 1044c of title 10","children":[],"tail":", United States Code, shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":"] and shall apply to advance medical directives referred to in that section that are executed before, on, or after that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
