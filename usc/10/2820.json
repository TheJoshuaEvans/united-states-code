{"tag":"section","attrib":{"id":"ida9dcda7a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2820"},"text":null,"children":[{"tag":"num","attrib":{"value":"2820"},"text":"§ 2820.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of infrastructure improvement plan for each military department","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9dcda7b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2820/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than the date on which the budget of the President for fiscal year 2027 is submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", and once every five years thereafter, each Secretary concerned shall submit to the congressional defense committees each of the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9dcda7c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2820/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A detailed plan with respect to the improvement of infrastructure and facilities under the jurisdiction of the Secretary concerned during the 20-year period beginning after the date on which the plan is submitted that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9dcda7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2820/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of major efforts of the Secretary concerned to be carried out pursuant to the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9dcda7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2820/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" milestones and specific goals for such major efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9dcda7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2820/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of objectives of the Secretary concerned to manage and improve such infrastructure and facilities during such period, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9dcda80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2820/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utility systems (electric, water and wastewater systems, energy distribution systems, transportation, and communication networks); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9dcda81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2820/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all physical structures located on a military installation under the jurisdiction of the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9dcda82-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2820/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A certification that the budget of the President for the applicable fiscal year and the future-years defense program submitted to Congress in relation to such budget under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s221"},"text":"section 221 of this title","children":[],"tail":" provide for funding of planning, design, and construction at a level that is sufficient to meet the requirements specified in the plan under paragraph (1) on the schedule provided in such plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9dcda83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2820/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each plan submitted by a Secretary concerned under subsection (a)(1) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9dcda84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2820/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The estimated costs of necessary infrastructure and facility improvements and a description of how such costs would be addressed by the budget request of the Department of Defense and the future-years defense program submitted for the applicable fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9dcda85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2820/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of how the military department is accurately accounting for the costs of sustaining facilities and addressing the identified necessary improvements of infrastructure and facilities as outlined in the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9dcda86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2820/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incorporation of Results-oriented Management Practices","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each plan under subsection (a)(1) shall incorporate the leading results-oriented management practices, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9dcda87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2820/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analytically based goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9dcda88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2820/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results-oriented metrics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9dcda89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2820/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of required resources, risks, and stakeholders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9dcda8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2820/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regular reporting on progress to decision makers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9dcda8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2820/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service Chief Assessment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each service chief (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3101"},"text":"section 3101 of this title","children":[],"tail":") shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9dcda8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2820/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess each plan and certification developed by the Secretary concerned under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9dcda8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2820/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the congressional defense committees, not later than the date on which the Secretary concerned submits the plan and certification to such committees, an unaltered copy of the results of such assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9dcda8e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dB/tXXVIII/s2803"},"text":"Pub. L. 119–60, div. B, title XXVIII, § 2803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1293"},"text":"139 Stat. 1293","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
