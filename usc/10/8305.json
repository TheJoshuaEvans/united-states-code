{"tag":"section","attrib":{"id":"idab1a1612-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8305"},"text":null,"children":[{"tag":"num","attrib":{"value":"8305"},"text":"§ 8305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commemorative or special medals: facsimiles and ribbons","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary of the Navy, members of the naval service may wear, in place of commemorative or special medals awarded to them, miniature facsimiles of such medals and ribbons symbolic of the awards.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab1a1613-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/391"},"text":"70A Stat. 391","children":[],"tail":", § 6255; renumbered § 8305, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/13"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab1a1614-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab1a1615-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab1a1616-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"