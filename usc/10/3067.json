{"tag":"section","attrib":{"id":"idaa0570b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3067"},"text":null,"children":[{"tag":"num","attrib":{"value":"3067"},"text":"§ 3067.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval required for military department termination or reduction in participation in joint acquisition programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa0570b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3067/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval of Terminations and Reductions of Joint Acquisition Programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe regulations that prohibit each military department participating in a joint acquisition program approved by the Under Secretary of Defense for Acquisition and Sustainment from terminating or substantially reducing its participation in such program without the approval of the Under Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa0570b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3067/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Content of Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations shall include the following provisions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa0570b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3067/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A requirement that, before any such termination or substantial reduction in participation is approved, the proposed termination or reduction be reviewed by the Joint Requirements Oversight Council of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa0570b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3067/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A provision that authorizes the Under Secretary of Defense for Acquisition and Sustainment to require a military department whose participation in a joint acquisition program has been approved for termination or substantial reduction to continue to provide some or all of the funding necessary for the acquisition program to be continued in an efficient manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa0570b6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1807/d/2/B"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1807(d)(2)(B)","children":[],"tail":", (E), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4158"},"text":"134 Stat. 4158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa0570b7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa0570b8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa0570b9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2311"},"text":"section 2311 of this title","children":[],"tail":", which was transferred first to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3065/c"},"text":"section 3065(c) of this title","children":[],"tail":" and then to this section and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1807/d/1"},"text":"Pub. L. 116–283, § 1807(d)(1)","children":[],"tail":", (2)(B), (E), was based on "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/tI/s1503/a/1"},"text":"Pub. L. 103–355, title I, § 1503(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3296"},"text":"108 Stat. 3296","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/b/2"},"text":"Pub. L. 107–107, div. A, title X, § 1048(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1225"},"text":"115 Stat. 1225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s902/49"},"text":"Pub. L. 116–92, div. A, title IX, § 902(49)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1548"},"text":"133 Stat. 1548","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa0570ba-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3067 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7067"},"text":"section 7067 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa0570bb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1807/d/2/E"},"text":"Pub. L. 116–283, § 1807(d)(2)(E)","children":[],"tail":", redesignated subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3065"},"text":"section 3065 of this title","children":[],"tail":" as subsec. (a) of this section, struck out par. (1) designation before “The Secretary of Defense shall”, redesignated par. (2) and its subpars. (A) and (B) as subsec. (b) and pars. (1) and (2), respectively, and inserted subsec. (b) heading."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa0570bc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa0570bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as an Effective Date of 2021 Amendment note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"t