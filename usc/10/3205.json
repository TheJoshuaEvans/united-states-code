{"tag":"section","attrib":{"id":"idaa11582e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3205"},"text":null,"children":[{"tag":"num","attrib":{"value":"3205"},"text":"§ 3205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Simplified procedures for small purchases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa11582f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3205/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to promote efficiency and economy in contracting and to avoid unnecessary burdens for agencies and contractors, the Federal Acquisition Regulation shall provide for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa115830-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3205/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special simplified procedures for purchases of property and services for amounts not greater than the simplified acquisition threshold; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa115831-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3205/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special simplified procedures for purchases of property and services for amounts greater than the simplified acquisition threshold but not greater than $5,000,000 with respect to which the contracting officer reasonably expects, based on the nature of the property or services sought and on market research, that offers will include only commercial products or commercial services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa115832-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3205/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Dividing Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A proposed purchase or contract for an amount above the simplified acquisition threshold may not be divided into several purchases or contracts for lesser amounts in order to use the simplified procedures required by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa115833-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3205/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Promotion of Competition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In using simplified procedures, the head of an agency shall promote competition to the maximum extent practicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa115834-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3205/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance With Special Requirements of Federal Acquisition Regulation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an agency shall comply with the Federal Acquisition Regulation provisions referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1901/e"},"text":"section 1901(e) of title 41","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa115835-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1811/d/1"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1811(d)(1)","children":[],"tail":", (9), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4166"},"text":"134 Stat. 4166","children":[],"tail":", 4170.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa115836-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa115837-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa115838-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2304"},"text":"section 2304 of this title","children":[],"tail":", which was transferred to this section and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1811/d/9"},"text":"Pub. L. 116–283, § 1811(d)(9)","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dB/tVII/s2723/a/1/C"},"text":"Pub. L. 98–369, div. B, title VII, § 2723(a)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1187"},"text":"98 Stat. 1187","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s7/d/3/A"},"text":"Pub. L. 100–26, § 7(d)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"