{"tag":"section","attrib":{"id":"ida959c865-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2261"},"text":null,"children":[{"tag":"num","attrib":{"value":"2261"},"text":"§ 2261.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presentation of recognition items for recruitment and retention purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida959c866-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2261/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expenditures for Recognition Items","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed by the Secretary of Defense, appropriated funds may be expended—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida959c867-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2261/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to procure recognition items of nominal or modest value for recruitment or retention purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c868-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2261/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to present such items—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida959c869-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2261/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to members of the armed forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida959c86a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2261/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to members of the families of members of the armed forces, and other individuals, recognized as providing support that substantially facilitates service in the armed forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida959c86b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2261/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of Meals and Refreshments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s520c"},"text":"section 520c of this title","children":[],"tail":" and any regulation prescribed to implement that section, functions conducted for the purpose of presenting recognition items described in subsection (a) shall be treated as recruiting functions, and recipients of such items shall be treated as persons who are the objects of recruiting efforts."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida959c86c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2261/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recognition Items of Nominal or Modest Value","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “recognition item of nominal or modest value” means a commemorative coin, medal, trophy, badge, flag, poster, painting, or other similar item that is valued at less than $50 per item and is designed to recognize or commemorate service in the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida959c86d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s589/a/1"},"text":"Pub. L. 109–163, div. A, title V, § 589(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3279"},"text":"119 Stat. 3279","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s594"},"text":"Pub. L. 109–364, div. A, title V, § 594","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2235"},"text":"120 Stat. 2235","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida959c86e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida959c86f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida959c870-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" struck out heading and text of subsec. (d). Text read as follows: “The authority under this section shall expire "},{"tag":"date","attrib":{"date":"2007-12-31"},"text":"December 31, 2007","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
