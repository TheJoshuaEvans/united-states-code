g":"html:span","attrib":{},"text":"The Chaplains","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"1","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"1","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Army and Air Force, exclusive of the above","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"184","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"150","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"   Total","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"201","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"156","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"After the enactment of the Officer Personnel Act of 1947, section 308 of the Army Organization Act of 1950 (10:61–1) provided for an Assistant Judge Advocate General and three brigadier generals in the Judge Advocate General’s Corps of the Army. The creation of these four general officer spaces served to increase the mentioned authorized strength figure from 357 to 361, and the figure 201 to 205. The opinion of the Judge Advocate General of the Army (JAGA 1948/5806, 2 Sept. 1948) is in accord with that conclusion.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The revised section reflects the authorized strength of the Regular Army in general officers on the active list resulting from the mentioned allocation to the Air Force and the addition of four general officer spaces in the Judge Advocate General’s Corps.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"That allocation, and those mentioned in the explanation of [former] subsection (c), below, have had the force of law since ","children":[{"tag":"date","attrib":{"date":"1950-07-26"},"text":"July 26, 1950","children":[],"tail":", when the period for transfers, including the administrative authority to change these allocations, expired."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “regular” is substituted for the word “permanent” throughout the revised section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), 10:506a(a) (1st proviso) is omitted, since there is no authority to appoint to a Regular grade above major general. 10:506a(a) (last 65 words of 2d proviso) is omitted as executed by the declaration of a national emergency on ","children":[{"tag":"date","attrib":{"date":"1950-12-16"},"text":"December 16, 1950","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the figures “12” and “6” result from the allocation of the original figures “16” and “8”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the figures “3” and “2” result from the allocation of the original figures “4” and “2”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(3), the figure “1” results from the allocation of the original figure “1”. None was allocated to the Air Force.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(4), the figure “1” results from the allocation of the original figures “2” and “1”. (The major general was allocated to the Army, the brigadier general to the Air Force.)","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(5), the figures “188” and “94” result from the allocation of the original figures “334” and “167”. The allocation of 188 corresponds to the allotment made by the Secretary of War between the Air Corps and the Army exclusive of the Air Corps, the Medical Department, and the Chaplains, under 10:506a(a) (3d proviso). That proviso is omitted as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “by law to hold any civil office under the United States” are substituted for the words “by Acts of Congress to hold appointments in the Diplomatic or Consular Service of the Government or to hold any civil office under the Government”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaadc21fb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaadc21fc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1958 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3210(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10 App.:506a(a)(1) (less 3d, 4th, 5th, and last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-07-20/ch646/s302"},"text":"July 20, 1956, ch. 646, § 302","children":[],"tail":" (1st par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/70/587"},"text":"70 Stat. 587","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3210(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10 App.:506a(a)(1) (3d and 4th sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3210(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10 App.:506a(a)(1) (5th sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3210(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10 App.:506a(a)(1) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3202/a"},"text":"section 3202(a) of this title","children":[],"tail":"” are inserted for clarity."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaadc21fd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaadc21fe-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3210"},"text":"section 3210 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" substituted “section 526” for “section 3202(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/22"},"text":"Pub. L. 97–22","children":[],"tail":" struck out “, exclusive of the number authorized for the Army Medical Department and the Chaplains,” before “is 75/10,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/22"},"text":"Pub. L. 97–22","children":[],"tail":", which directed amendment of subsec. (a) by striking out “, exclusive of the number of commissioned officers on the active-duty list authorized for the Army Medical Department and the Chaplains”, was executed by striking out “, exclusive of the number of commissioned officers on the active list authorized for the Army Medical Department and the Chaplains” before period at end of first sentence, to reflect the probable intent of Congress. See 1980 Amendment note and Effective Date of 1980 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s502/5/A"},"text":"Pub. L. 96–513, § 502(5)(A)","children":[],"tail":", (B), substituted “active-duty list” for “active list” wherever appearing and struck out provisions that, of the authorized strength, not more than one-half could be in a regular grade above brigadier general."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s502/5/A"},"text":"Pub. L. 96–513, § 502(5)(A)","children":[],"tail":", (C), substituted “active-duty list” for “active list” wherever appearing and substituted paragraphed references to “(1) each corps of the Army Medical Department” and “(2) the Chaplains” for former paragraphed references to “(1) The Medical Corps”, “(2) the Dental Corps”, “(3) the Veterinary Corps”, and “(4) the Chaplains”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s502/5/D"},"text":"Pub. L. 96–513, § 502(5)(D)","children":[],"tail":", struck out subsec. (d) which provided that general officers on the active list of the Regular Army who were specifically authorized by law to hold a civil office under the United States or any instrumentality thereof were not counted in determining authorized strength under this section and subsec. (e) which had provided that the authorized strength of the Medical Service Corps in general officers on the active list of the Regular Army was one commissioned officer in the regular grade of brigadier general."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/329"},"text":"Pub. L. 90–329","children":[],"tail":" substituted “Army Medical Department” for “Army Medical Service” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/603"},"text":"Pub. L. 89–603","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/66/A"},"text":"Pub. L. 85–861, § 1(66)(A)","children":[],"tail":", substituted “Subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3202/a"},"text":"section 3202(a) of this title","children":[],"tail":", the” for “The”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/66/B"},"text":"Pub. L. 85–861, § 1(66)(B)","children":[],"tail":", struck out subsec. (c) which prescribed the number of general officers authorized for the active list of the Regular Army, and redesignated subsecs. (d) and (e) as (c) and (d), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaadc21ff-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaadc2200-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaadc2201-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701"},"text":"section 701 of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail"