{"tag":"section","attrib":{"id":"idab68d1d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9272"},"text":null,"children":[{"tag":"num","attrib":{"value":"9272"},"text":"§ 9272.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Air Force cross: award","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President may award an Air Force cross of appropriate design, with ribbons and appurtenances, to a person who, while serving in any capacity with the Air Force or the Space Force, distinguishes himself by extraordinary heroism not justifying the award of a medal of honor—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab68d1d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9272/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while engaged in an action against an enemy of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab68d1d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9272/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while engaged in military operations involving conflict with an opposing foreign force; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab68d1d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9272/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while serving with friendly foreign forces engaged in an armed conflict against an opposing armed force in which the United States is not a belligerent party.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab68d1da-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/540"},"text":"70A Stat. 540","children":[],"tail":", § 8742; "},{"tag":"ref","attrib":{"href":"/us/pl/86/593/s1/1"},"text":"Pub. L. 86–593, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-06"},"text":"July 6, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/331"},"text":"74 Stat. 331","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/77/s3/2"},"text":"Pub. L. 88–77, § 3(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-07-25"},"text":"July 25, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/94"},"text":"77 Stat. 94","children":[],"tail":"; renumbered § 9272, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/b/11"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(b)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1833"},"text":"132 Stat. 1833","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s923/c/12/A/ii"},"text":"Pub. L. 116–283, div. A, title IX, § 923(c)(12)(A)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3811"},"text":"134 Stat. 3811","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab68d1db-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab68d1dc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab68d1dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8742","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1406.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1918-07-09/ch143"},"text":"July 9, 1918, ch. 143","children":[],"tail":" (9th par. under “Ordnance Department”), "},{"tag":"html:a","attrib":{"href":"/us/stat/40/870"},"text":"40 Stat. 870","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “but not in the name of Congress” are omitted as surplusage, since a medal is presented in the name of Congress only if the law so directs. The words “since the 6th day of April, 1917” are omitted as executed. The word “award” is substituted for the word “present” to cover the determination of the recipients as well as the actual presentation of the medal, and to conform to other sections of this chapter. The words “or herself” are omitted, since, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t1/s1"},"text":"section 1 of title 1","children":[],"tail":", words importing the masculine gender include the feminine. The words “or who shall hereafter distinguish” are omitted as surplusage."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab68d1de-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab68d1df-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" inserted “or the Space Force” after “the Air Force” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8742"},"text":"section 8742 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/77"},"text":"Pub. L. 88–77","children":[],"tail":" enlarged the authority to award the Air Force cross, which was limited to those cases in which persons distinguished themselves in connection with military operations against an armed enemy, to permit its award for extraordinary heroism not justifying the award of a medal of honor, while engaged in military operations involving conflict with an opposing foreign force, or while serving with friendly foreign forces engaged in an armed conflict against an opposing armed force in which the United States is not a belligerent party."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/593"},"text":"Pub. L. 86–593","children":[],"tail":" substituted “Air Force cross” for “Distinguished-service cross” in section catchline, and substituted “an Air Force cross” for “a distinguished-service cross” in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab68d1e0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab68d1e1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab68d1e2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Distinguished-Service Cross and Soldier’s Medal Considered Made to Air Force Cross and Airman’s Medal","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/593/s3"},"text":"Pub. L. 86–593, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-06"},"text":"July 6, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/332"},"text":"74 Stat. 332","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/86/593/s3"},"text":"“References that other laws, regulations, and orders make, with respect to the Air Force, to the distinguished-service cross and the Soldier’s Medal shall be considered to be made to the Air Force cross and the Airman’s Medal, respectively.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
