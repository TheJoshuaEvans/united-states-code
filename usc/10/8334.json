{"tag":"section","attrib":{"id":"idab1ed01a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8334"},"text":null,"children":[{"tag":"num","attrib":{"value":"8334"},"text":"§ 8334.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Higher grade after 30 years of service: warrant officers and enlisted members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab1ed01b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8334/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member of the naval service covered by subsection (b) who, after ","children":[{"tag":"date","attrib":{"date":"1987-12-04"},"text":"December 4, 1987","children":[],"tail":", is retired with less than 30 years of active service or is transferred to the Fleet Reserve or Fleet Marine Corps Reserve is entitled, when his active service plus his service on the retired list or his service in the Fleet Reserve or the Fleet Marine Corps Reserve totals 30 years, to be advanced on the retired list to the highest grade in which he served on active duty satisfactorily, as determined by the Secretary of the Navy."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1ed01c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8334/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section applies to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab1ed01d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8334/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" warrant officers of the naval service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1ed01e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8334/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enlisted members of the Regular Navy and Regular Marine Corps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1ed01f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8334/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reserve enlisted members of the Navy and Marine Corps who, at the time of retirement or transfer to the Fleet Reserve or Fleet Marine Corps Reserve, are serving on active duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1ed020-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8334/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An enlisted member of the naval service who is advanced on the retired list under this section is entitled to recompute his retired or retainer pay under formula A of the following table, and a warrant officer of the naval service so advanced is entitled to recompute his retired pay under formula B of that table. The amount recomputed, if not a multiple of $1, shall be rounded to the next lower multiple of $1.","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab1ed021-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Formula","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Column 1 Take","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Column 2 Multiply by","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tfoot","attrib":{},"text":null,"children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"name":"TAB_684_0"},"text":null,"children":[],"tail":null},{"tag":"html:sup","attrib":{},"text":"1","children":[],"tail":" In determining the retired pay multiplier, credit each full month of service that is in addition to the number of full years of service creditable to the member as "},{"tag":"html:sup","attrib":{},"text":"1","children":[],"tail":"⁄"},{"tag":"html:sub","attrib":{},"text":"12","children":[],"tail":" of a year and disregard any remaining fractional part of a month."}],"tail":"\n"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"A","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Retired pay base as computed under section 1406(d) or 1407 of this title","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"The retired pay multiplier prescribed in ","children":[{"tag":"html:a","attrib":{"href":"/us/usc/t10/s1409"},"text":"section 1409 of this title","children":[],"tail":" for the number of years creditable for his retainer or retired pay at the time of retirement."},{"tag":"html:a","attrib":{"h