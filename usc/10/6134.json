{"tag":"section","attrib":{"id":"idaabf72c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6134"},"text":null,"children":[{"tag":"num","attrib":{"value":"6134"},"text":"§ 6134.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incorporation of integrated surety architecture","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaabf72c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6134/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Shipments","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabf72c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6134/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator shall ensure that shipments described in paragraph (2) incorporate surety technologies relating to transportation and shipping developed by the Integrated Surety Architecture program of the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabf72c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6134/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A shipment described in this paragraph is an over-the-road shipment of the Administration that involves any nuclear weapon planned to be in the active stockpile after 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabf72c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6134/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain Programs","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabf72c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6134/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator, in coordination with the Chairman of the Nuclear Weapons Council, shall ensure that each program described in paragraph (2) incorporates integrated designs compatible with the Integrated Surety Architecture program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabf72c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6134/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A program described in this subsection is a program of the Administration that is a warhead development program, a life extension program, or a warhead major alteration program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabf72c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6134/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabf72ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6134/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If, on a case-by-case basis, the Administrator determines that a shipment under subsection (a) will not incorporate some or all of the surety technologies described in such subsection, or that a program under subsection (b) will not incorporate some or all of the integrated designs described in such subsection, the Administrator shall submit such determination to the congressional defense committees, including the results of an analysis conducted pursuant to paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabf72cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6134/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each determination made under paragraph (1) shall be based on a documented, system risk analysis that considers security risk reduction, operational impacts, and technical risk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabf72cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6134/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirements of subsections (a) and (b) shall terminate on ","children":[{"tag":"date","attrib":{"date":"2029-12-31"},"text":"December 31, 2029","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaabf72cd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2)(B), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1369"},"text":"139 Stat. 1369","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaabf72ce-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaabf72cf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaabf72d0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2538d"},"text":"section 2538d of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaabf72d1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
