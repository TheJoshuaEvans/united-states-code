{"tag":"section","attrib":{"id":"ida82fc620-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s926"},"text":null,"children":[{"tag":"num","attrib":{"value":"926"},"text":"§ 926.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 126. Arson; burning property with intent to defraud","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida82fc621-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s926/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aggravated Arson","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person subject to this chapter who, willfully and maliciously, burns or sets on fire an inhabited dwelling, or any other structure, movable or immovable, wherein, to the knowledge of that person, there is at the time a human being, is guilty of aggravated arson and shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82fc622-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s926/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Simple Arson","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person subject to this chapter who, willfully and maliciously, burns or sets fire to the property of another is guilty of simple arson and shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82fc623-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s926/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Burning Property With Intent to Defraud","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person subject to this chapter who, willfully, maliciously, and with intent to defraud, burns or sets fire to any property shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida82fc624-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/74"},"text":"70A Stat. 74","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLX/s5440"},"text":"Pub. L. 114–328, div. E, title LX, § 5440","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2953"},"text":"130 Stat. 2953","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida82fc625-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida82fc626-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida82fc627-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail"