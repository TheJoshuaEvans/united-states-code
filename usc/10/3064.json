{"tag":"section","attrib":{"id":"idaa05708c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3064"},"text":null,"children":[{"tag":"num","attrib":{"value":"3064"},"text":"§ 3064.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of chapter 137 legacy provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa05708d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3064/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any provision of this part that is a chapter 137 legacy provision applies to the procurement by any of the agencies named in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3063"},"text":"section 3063 of this title","children":[],"tail":", for its use or otherwise, of all property (other than land) and all services for which payment is to be made from appropriated funds."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa05708e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3064/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability to Contracts for Installation or Alteration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provisions of this part that are chapter 137 legacy provisions that apply to the procurement of property apply also to contracts for its installation or alteration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa05708f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1807/c/1"},"text":"Pub. L. 116–28