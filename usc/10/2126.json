{"tag":"section","attrib":{"id":"ida92c7604-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2126"},"text":null,"children":[{"tag":"num","attrib":{"value":"2126"},"text":"§ 2126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members of the program: service credit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida92c7605-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2126/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service Not Creditable","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), service performed while a member of the program shall not be counted—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida92c7606-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2126/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in determining eligibility for retirement other than by reason of a physical disability incurred while on active duty as a member of the program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c7607-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2126/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in computing years of service creditable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s205"},"text":"section 205 of title 37","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92c7608-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2126/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service Creditable for Certain Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida92c7609-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2126/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary concerned may authorize service performed by a member of the program in pursuit of a course of study under this subchapter to be counted in accordance with this subsection if the member—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida92c760a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2126/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completes the course of study;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92c760b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2126/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completes the active duty obligation imposed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2123/a"},"text":"section 2123(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92c760c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2126/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possesses a specialty designated by the Secretary concerned as critically needed in wartime.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c760d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2126/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Service credited under paragraph (1) counts only for the award of retirement points for computation of years of service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12732"},"text":"section 12732 of this title","children":[],"tail":" and for computation of retired pay under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12733"},"text":"section 12733 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c760e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2126/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of points credited to a member under paragraph (1) for a year of participation in a course of study is 50. The points shall be credited to the member for one of the years of that participation at the end of each year after the completion of the course of study that the member serves in the Selected Reserve and is credited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12732/a/2"},"text":"section 12732(a)(2) of this title","children":[],"tail":" with at least 50 points. The points credited for the participation shall be recorded in the member’s records as having been earned in the year of the participation in the course of study."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c760f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2126/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Service may not be counted under paragraph (1) for more than four years of participation in a course of study as a member of the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c7610-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2126/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Selected Reserve may be considered to be in an active status while pursuing a course of study under this subchapter only for purposes of sections 12732(a) and 12733(3) of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c7611-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2126/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member is not entitled to any retroactive award of, or increase in, pay or allowances under title 37 by reason of an award of service credit under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida92c7612-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/426/s2/a"},"text":"Pub. L. 92–426, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-21"},"text":"Sept. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/718"},"text":"86 Stat. 718","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s501/22"},"text":"Pub. L. 96–513, title V, § 501(22)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2908"},"text":"94 Stat. 2908","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s543/a"},"text":"Pub. L. 104–201, div. A, title V, § 543(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2521"},"text":"110 Stat. 2521","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s544"},"text":"Pub. L. 106–65, div. A, title V, § 544","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/608"},"text":"113 Stat. 608","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida92c7613-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida92c7614-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida92c7615-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s544/1"},"text":"Pub. L. 106–65, § 544(1)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “Service credited under paragraph (1) counts only for the following purposes:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) Award of retirement points for computation of years of service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12732"},"text":"section 12732 of this title","children":[],"tail":" and for computation of retired pay under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12733"},"text":"section 12733 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) Computation of years of service creditable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s205"},"text":"section 205 of title 37","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s544/1"},"text":"Pub. L. 106–65, § 544(1)","children":[],"tail":", added par. (3) and struck out former par. (3) which read as follows: “For purposes of paragraph (2)(A), a member may be credited in accordance with paragraph (1) with not more than 50 points for each year of participation in a course of study that the member satisfactorily completes as a member of the program.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s544/2"},"text":"Pub. L. 106–65, § 544(2)","children":[],"tail":", (3), added par. (5) and redesignated former par. (5) as (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, substituted “Except as provided in subsection (b), service performed” for “Service performed”, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Cl. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" struck out “, other than subsection (a)(7) and (8),” after “section 205”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida92c7616-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida92c7617-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701"},"text":"section 701 of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
