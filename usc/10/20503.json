{"tag":"section","attrib":{"id":"idabccea88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20503"},"text":null,"children":[{"tag":"num","attrib":{"value":"20503"},"text":"§ 20503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of officer: action by Secretary upon recommendation of retention board","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Air Force may remove an officer from space force active status if the removal of such officer from space force active status is recommended by a retention board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20502"},"text":"section 20502 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idabccea89-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1719"},"text":"Pub. L. 118–31, div. A, title XVII, § 1719","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/661"},"text":"137 Stat. 661","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
