{"tag":"section","attrib":{"id":"ida8abad50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1175a"},"text":"§ 1175a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary separation pay and benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8abad51-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under regulations approved by the Secretary of Defense, the Secretary concerned may provide voluntary separation pay and benefits in accordance with this section to eligible members of the armed forces who are voluntarily separated from active duty in the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8abad52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Members","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8abad53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2), a member of the armed forces is eligible for voluntary separation pay and benefits under this section if the member—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8abad54-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has served on active duty for more than 6 years but not more than 20 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8abad55-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has served at least 5 years of continuous active duty immediately preceding the date of the member’s separation from active duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8abad56-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not been approved for payment of a voluntary separation incentive under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1175"},"text":"section 1175 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8abad57-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" meets such other requirements as the Secretary concerned may prescribe, which may include requirements relating to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8abad58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" years of service, skill, rating, military specialty, or competitive category;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8abad59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grade or rank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8abad5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/b/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remaining period of obligated service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8abad5b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/b/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any combination of these factors; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8abad5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requests separation from active duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8abad5d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following members are not eligible for voluntary separation pay and benefits under this section:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8abad5e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members discharged with disability severance pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1212"},"text":"section 1212 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8abad5f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members transferred to the temporary disability retired list under section 1202 or 1205 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8abad60-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members being evaluated for disability retirement under chapter 61 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8abad61-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members who have been previously discharged with voluntary separation pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8abad62-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members who are subject to pending disciplinary action or who are subject to administrative separation or mandatory discharge under any other provision of law or regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8abad63-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned shall determine each year the number of members to be separated, and provided separation pay and benefits, under this section during the fiscal year beginning in such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8abad64-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Separation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each eligible member of the armed forces whose request for separation from active duty under subsection (b)(1)(E) is approved shall be separated from active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8abad65-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Service in Ready Reserve","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of the number of members of the armed forces to be separated from active duty in a fiscal year, as determined under subsection (b)(3), the Secretary concerned shall determine a number of such members, in such skill and grade combinations as the Secretary concerned shall designate, who shall serve in the Ready Reserve, after separation from active duty, for a period of not less than three years, as a condition of the receipt of voluntary separation pay and benefits under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8abad66-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Separation Pay and Benefits","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8abad67-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the armed forces who is separated from active duty under subsection (c) shall be paid voluntary separation pay in accordance with subsection (g) in an amount determined by the Secretary concerned pursuant to subsection (f).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8abad68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member who is not entitled to retired or retainer pay upon separation shall be entitled to the benefits and services provided under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8abad69-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 58 of this title during the 180-day period beginning on the date the member is separated (notwithstanding any termination date for such benefits and services otherwise applicable under the provisions of such chapter); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8abad6a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 452 and 453(c) of title 37.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8abad6b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Computation of Voluntary Separation Pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall specify the amount of voluntary separation pay that an individual or defined group of members of the armed forces may be paid under subsection (e)(1). No member may receive as voluntary separation pay an amount greater than four times the full amount of separation pay for a member of the same pay grade and years of service who is involuntarily separated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1174"},"text":"section 1174 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8abad6c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of Voluntary Separation Pay","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8abad6d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Voluntary separation pay under this section may be paid in a single lump sum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8abad6e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a member of the armed forces who, at the time of separation under subsection (c), has completed at least 15 years, but less than 20 years, of active service, voluntary separation pay may be paid, at the election of the Secretary concerned, in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8abad6f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a single lump sum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8abad70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" installments over a period not to exceed 10 years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8abad71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a combination of lump sum and such installments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8abad72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination With Retired or Retainer Pay and Disability Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8abad73-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member who is paid voluntary separation pay under this section and who later qualifies for retired or retainer pay under this title or title 14 shall have deducted from each payment of such retired or retainer pay an amount, in such schedule of monthly installments as the Secretary concerned shall specify, until the total amount deducted from such retired or retainer pay is equal to the total amount of voluntary separation pay so paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8abad74-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8abad75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraphs (B) and (C), a member who is paid voluntary separation pay under this section shall not be deprived, by reason of the member’s receipt of such pay, of any disability compensation to which the member is entitled under the laws administered by the Secretary of Veterans Affairs, but there shall be deducted from such disability compensation an amount, in such schedule of monthly installments as the Secretary concerned shall specify, until the total amount deducted from such disability compensation is equal to the total amount of voluntary separation pay so paid, less the amount of Federal income tax withheld from such pay (such withholding being at the flat withholding rate for Federal income tax withholding, as in effect pursuant to regulations prescribed under chapter 24 of the Internal Revenue Code of 1986).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8abad76-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No deduction shall be made from the disability compensation paid to an eligible disabled uniformed services retiree under section 1413, or to an eligible combat-related disabled uniformed services retiree under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1413a"},"text":"section 1413a of this title","children":[],"tail":", who is paid voluntary separation pay under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8abad77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No deduction may be made from the disability compensation paid to a member for the amount of voluntary separation pay received by the member because of an earlier discharge or release from a period of active duty if the disability which is the basis for that disability compensation was incurred or aggravated during a later period of active duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8abad78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The requirement under this subsection to repay voluntary separation pay following retirement from the armed forces does not apply to a member who was eligible to retire at the time the member applied and was accepted for voluntary separation pay and benefits under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8abad79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may waive the requirement to repay voluntary separation pay under paragraphs (1) and (2) if the Secretary determines that recovery would be against equity and good conscience or would be contrary to the best interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8abad7a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retirement Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “retirement” includes a transfer to the Fleet Reserve or Fleet Marine Corps Reserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8abad7b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment for Members Who Return to Active Duty","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8abad7c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraphs (2), (3), and (4), a member of the armed forces who, after having received all or part of voluntary separation pay under this section, returns to active duty shall have deducted from each payment of basic pay, in such schedule of monthly installments as the Secretary concerned shall specify, until the total amount deducted from such basic pay equals the total amount of voluntary separation pay received.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8abad7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members who are involuntarily recalled to active duty or full-time National Guard duty in accordance with section 12301(a), 12301(b), 12301(g), 12302, 12303, 12304, 12304a, or 12304b of this title or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s502/f/1/A"},"text":"section 502(f)(1)(A) of title 32","children":[],"tail":" shall not be subject to this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8abad7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members who are recalled or perform active duty or full-time National Guard duty in accordance with section 101(d)(1), 101(d)(2), 101(d)(5), 12301(d) (insofar as the period served is less than 180 consecutive days with the consent of the member), 12319, or 12503 of this title, or section 114, 115, or 502(f)(1)(B) of title 32 (insofar as the period served is less than 180 consecutive days with consent of the member), shall not be subject to this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8abad7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This subsection shall not apply to a member who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8abad80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/j/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is involuntarily recalled to active duty or full-time National Guard duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8abad81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/j/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the course of such duty, incurs a service-connected disability rated as total under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1155"},"text":"section 1155 of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8abad82-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/j/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may waive, in whole or in part, repayment required under paragraph (1) if the Secretary determines that recovery would be against equity and good conscience or would be contrary to the best interests of the United States. The authority in this paragraph may be delegated only to the Undersecretary of Defense for Personnel and Readiness and the Principal Deputy Undersecretary of Defense for Personnel and Readiness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8abad83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8abad84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority to separate a member of the armed forces from active duty under subsection (c) shall terminate on ","children":[{"tag":"date","attrib":{"date":"2030-12-31"},"text":"December 31, 2030","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8abad85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1175a/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member who separates by the date specified in paragraph (1) may continue to be provided voluntary separation pay and benefits under this section until the member has received the entire amount of pay and benefits to which the member is entitled under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8abad86-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s643/a/1"},"text":"Pub. L. 109–163, div. A, title VI, § 643(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3306"},"text":"119 Stat. 3306","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tVI/s623/a/1"},"text":"Pub. L. 109–364, div. A, title VI, § 623(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2256"},"text":"120 Stat. 2256","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tX/s1073/a/14"},"text":"Pub. L. 111–84, div. A, title X, § 1073(a)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2473"},"text":"123 Stat. 2473","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/3