{"tag":"section","attrib":{"id":"idab1a15c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8297"},"text":null,"children":[{"tag":"num","attrib":{"value":"8297"},"text":"§ 8297.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not more than one Navy cross, distinguished-service medal, silver star medal, distinguished flying cross, or Navy and Marine Corps Medal may be awarded to a person. However, for each succeeding act or service that would otherwise justify the award of such a medal or cross, the President may award a suitable bar, emblem, or insignia to be worn with the decoration and corresponding rosette or other device.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab1a15c3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/390"},"text":"70A Stat. 390","children":[],"tail":", § 6247; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tV/s561/b"},"text":"Pub. L. 113–66, div. A, title V, § 561(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/766"},"text":"127 Stat. 766","children":[],"tail":"; renumbered § 8297, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/13"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab1a15c4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"no