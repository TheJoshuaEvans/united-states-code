{"tag":"section","attrib":{"id":"ida933a214-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2164c"},"text":"§ 2164c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of dual or concurrent enrollment programs for students of Defense Dependent Schools","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida933a215-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense, acting through the Director of the Department of Defense Education Activity, may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida933a216-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into arrangements with institutions of higher education to provide students of Defense Dependent Schools with access to postsecondary course credit through dual or concurrent enrollment programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a217-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsection (b), provide financial assistance to students to cover the costs associated with such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida933a218-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of financial assistance provided to an individual student under subsection (a)(2) may not exceed $1,500 per school year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida933a219-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Credit Transferability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall, to the greatest extent practicable, ensure that the Department of Defense Education Activity, in facilitating dual or concurrent enrollment programs with institutions of higher education under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida933a21a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes articulation or credit transfer agreements that promote the transferability of academic credits earned by participating students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a21b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritizes agreements with institutions that offer broad acceptance of such credits across degree programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida933a21c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Institutional Integrity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In entering into contracts or other agreements with institutions of higher education for purposes of dual or concurrent enrollment programs under this section, the Secretary of Defense shall ensure that such institutions have a program participation agreement in effect under section 487 of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1094"},"text":"20 U.S.C. 1094","children":[],"tail":") and are not provisionally or temporarily certified."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida933a21d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preparation and Informing Families and Educators","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In implementing dual or concurrent enrollment programs under this section, the Secretary of Defense, acting through the Director of the Department of Defense Education Activity, shall do the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida933a21e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Course sequence alignment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Design a sequence of courses for such programs to match the academic content standards and level of rigor of the corresponding postsecondary courses, in consultation and collaboration with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida933a21f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educators from Defense Dependent Schools serving the military-connected community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida933a220-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" faculty members from institutions of higher education offering dual or concurrent enrollment programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida933a221-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the school advisory committee (or the equivalent advisory body) of each Defense Dependent School.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a222-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Outreach and information dissemination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Establish outreach and awareness efforts targeted toward elementary and secondary school students, particularly those in the middle grades and their families, educators, school counselors, and principals, to provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida933a223-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" general information regarding the availability and benefits of dual or concurrent enrollment programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida933a224-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidance on eligibility requirements, academic expectations, and necessary preparatory coursework for such programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida933a225-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resources to support informed decisionmaking and successful student participation in such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida933a226-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Teacher Certification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall ensure that all dual or concurrent enrollment courses facilitated by the Department of Defense Education Activity are taught by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida933a227-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a postsecondary faculty member who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida933a228-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is employed by a two-year or four-year institution of higher education (which may include a community college); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida933a229-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the applicable postsecondary accreditation standards for instructional staff; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a22a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a classroom teacher employed by a local educational agency or by the Department of Defense Education Activity, who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida933a22b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is qualified to teach in accordance with applicable law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida933a22c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has received training or certification to deliver the dual or concurrent enrollment course curriculum in alignment with the standards of the partnering institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida933a22d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out this section, the Secretary of Defense shall consult with the School Advisory Committees (or the equivalent advisory bodies) and Parent Teacher Associations of participating Defense Dependent Schools.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida933a22e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Briefings.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida933a22f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after the date of the enactment of this section, and annually thereafter for four years, the Secretary of Defense shall provide to the appropriate congressional committees a briefing on the status of the dual and concurrent enrollment programs authorized under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a230-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each briefing under paragraph (1) shall include, with respect to the period covered by the briefing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida933a231-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of students who participated in dual or concurrent enrollment programs authorized under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida933a232-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total cost to the Department of Defense of providing such programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida933a233-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an explanation of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida933a234-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/h/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether and to what extent such programs consisted of online classes or in-person instruction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida933a235-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/h/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the subjects taught in postsecondary classes taken by students participating in such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a236-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disaggregation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The information required under paragraph (2) shall be set forth separately for each region served by the Department of Defense Education Activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida933a237-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida933a238-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida933a239-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida933a23a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services and the Committee on Education and Workforce of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a23b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “Defense Dependent School” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida933a23c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a school operated under the Defense Dependents’ Education System, as authorized under the Defense Dependents’ Education Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s921"},"text":"20 U.S.C. 921","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida933a23d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Department of Defense domestic dependent elementary and secondary school, as authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2164"},"text":"section 2164 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a23e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “dual or concurrent enrollment program” means a program offered by an arrangement between the Department of Defense Education Activity and an institution of higher education and through which a student enrolled in a Defense Dependent School who has not graduated from high school with a regular high school diploma is able to enroll in one or more postsecondary courses and earn credit that applies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida933a23f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" toward completion of a postsecondary degree or recognized educational credential as described in the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"20 U.S.C. 1001","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida933a240-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" toward completion of high school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a241-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164c/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “institution of higher education” has the meaning given that term in section 102 of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"20 U.S.C. 1002","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida933a242-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tV/s584"},"text":"Pub. L. 119–60, div. A, title V, § 584","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/889"},"text":"139 Stat. 889","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida933a243-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"ida933a244-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida933a245-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (h)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Defense Dependents’ Education Act of 1978, referred to in subsec. (i)(2)(A), is title XIV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561"},"text":"Pub. L. 95–561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2365"},"text":"92 Stat. 2365","children":[],"tail":", which is classified principally to chapter 25A (§ 921 et seq.) of Title 20, Education. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s921"},"text":"section 921 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Higher Education Act of 1965, referred to in subsec. (i)(3)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329"},"text":"Pub. L. 89–329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1219"},"text":"79 Stat. 1219","children":[],"tail":", which is classified generally to chapter 28 (§ 1001 et seq.) of Title 20, Education. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
