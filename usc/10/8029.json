{"tag":"section","attrib":{"id":"idab0702c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029"},"text":null,"children":[{"tag":"num","attrib":{"value":"8029"},"text":"§ 8029.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Naval Air Warfare Rapid Capabilities Office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab0702c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established within the Department of the Navy an office to be known as the Naval Air Warfare Rapid Capabilities Office (in this section referred to as the “Office”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0702c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Head of Office","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of the Office shall be the designee of the Commander of the Naval Air Systems Command.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0702ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mission","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The mission of the Office shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab0702cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to fulfill naval and joint military operational requirements by supporting the identification and rapid development of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab0702cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new naval aviation weapons and airborne electronic warfare capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab0702cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" innovative applications for existing naval aviation weapons and airborne electronic warfare capabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab0702ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other innovative solutions to enhance the effectiveness of naval aviation weapons and airborne electronic warfare capabilities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0702cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to contribute to the rapid experimentation, development, testing, and fielding of unclassified and classified naval aviation weapons and airborne electronic warfare capabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0702d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition Authorities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab0702d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To procure goods or services for the Office, the senior contracting official (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1737"},"text":"section 1737 of this title","children":[],"tail":") and any members of the acquisition workforce for the Department of the Navy may use—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab0702d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any applicable pathway of the adaptive acquisition framework (as described in Department of Defense Instruction 5000.02, “Operation of the Adaptive Acquisition Framework”); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab0702d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other alternative acquisition pathway that allows for accelerated or flexible methods of contracting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0702d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of jcids","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Joint Capabilities Integration and Development System process shall not apply to procurements described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0702d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Program Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Navy shall ensure, within budget program elements for naval air warfare programs, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab0702d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are separate, dedicated program elements for naval air warfare rapid capabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0702d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office executes the responsibilities of the Office using such program elements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0702d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive Oversight Board.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab0702d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is an executive oversight board for the Office which shall consist of the officials specified in paragraph (2). The executive oversight board shall provide prioritization, oversight, and approval of projects of the Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0702da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officials specified","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The officials specified in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab0702db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Vice Chief of Naval Operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab0702dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Commandant of the Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab0702dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary of the Navy for Research, Development and Acquisition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab0702de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commander of the Naval Air Systems Command.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0702df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Reports and Briefings.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab0702e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On an annual basis, the head of the Office shall submit to the executive oversight board described in subsection (f) a report on the activities of the Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0702e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On an annual basis following the submittal of the report under paragraph (1), the Assistant Secretary of the Navy for Research, Development and Acquisition shall provide to the Committees on Armed Services of the Senate and the House of Representatives a briefing on the activities of the Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0702e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under paragraph (1) and briefing under paragraph (2) shall include, with respect to the year preceding the date of the report or briefing (as applicable), a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab0702e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding allocations for the projects of the Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab0702e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capability gaps addressed by the Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab0702e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/g/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress of the Office in experimenting, developing, testing, and fielding capabilities described in subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab0702e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8029/g/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any barriers to the ability of the Office to carry out its mission, including any legislative or regulatory barriers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab0702e7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tII/s215"},"text":"Pub. L. 118–31, div. A, title II, § 215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/184"},"text":"137 Stat. 184","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
