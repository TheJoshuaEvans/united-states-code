{"tag":"section","attrib":{"id":"idaac1e3e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6157"},"text":null,"children":[{"tag":"num","attrib":{"value":"6157"},"text":"§ 6157.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International agreements on nuclear weapons data","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy may, with the concurrence of the Secretary of State and in coordination with the Secretary of Defense, the Secretary of Homeland Security, and the Director of National Intelligence, enter into agreements with countries or international organizations to conduct data collection and analysis to determine accurately and in a timely manner the source of any components of, or fissile material used or attempted to be used in, a nuclear device or weapon.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idaac1e3e7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1382"},"text":"139 Stat. 1382","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac1e3e8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac1e3e9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac1e3ea-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tai