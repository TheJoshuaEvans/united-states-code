{"tag":"section","attrib":{"id":"idaa39ee89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3791"},"text":null,"children":[{"tag":"num","attrib":{"value":"3791"},"text":"§ 3791.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of intellectual property matters within the Department of Defense","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa39ee8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3791/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense, acting through the Under Secretary of Defense for Acquisition and Sustainment, shall develop policy on the acquisition or licensing of intellectual property—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa39ee8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3791/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enable coordination and consistency across the military departments and the Department of Defense in strategies for acquiring or licensing intellectual property and communicating with industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa39ee8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3791/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that program managers are aware of the rights afforded the Federal Government and contractors in intellectual property and that program managers fully consider and use all available techniques and best practices for acquiring or licensing intellectual property early in the acquisition process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa39ee8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3791/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage customized intellectual property strategies for each system based on, at a minimum, the unique characteristics of the system and its components, the product support strategy for the system, the organic industrial base strategy of the military department concerned, and the commercial market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa39ee8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3791/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cadre of Intellectual Property Experts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For a provision requiring establishment of a cadre of personnel who are experts in intellectual property matters, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1707"},"text":"section 1707 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa39ee8f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3791/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidelines and Resources.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa39ee90-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3791/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense, acting through the Under Secretary of Defense for Acquisition and Sustainment, shall develop guidelines and resources on the acquisition or licensing of intellectual property, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa39ee91-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3791/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intellectual property strategies and other mechanisms supporting the use of modular open system approaches (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4401/b"},"text":"section 4401(b) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa39ee92-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3791/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluation and negotiation of intellectual property licenses in competitive and non-competitive awards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa39ee93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3791/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" models and best practices for specially negotiated licenses, including specially negotiated licenses described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3774/c"},"text":"section 3774(c) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa39ee94-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3791/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" definitions, key terms, examples, and case studies that clarify differences between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa39ee95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3791/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detailed manufacturing and process data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa39ee96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3791/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" form, fit, and function data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa39ee97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3791/c/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data required for operations, maintenance, installation, and training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa39ee98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3791/c/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modular system interfaces (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4401/b"},"text":"section 4401(b) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa39ee99-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3791/c/1/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical data pertaining to an interface between an item or process and other items or processes necessary for the segregation of an item or process from, or the reintegration of that item or process (or a functionally equivalent item or process) with, other items or processes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa39ee9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3791/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidelines and resources limit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The guidelines and resources developed under paragraph (1) may not alter or affect any authority or duty under this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1707"},"text":"section 1707 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa39ee9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3791/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review and consultation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the guidelines and resources described in paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa39ee9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3791/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the applicable statutory and regulatory history, including among the definitions and key terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3771"},"text":"section 3771 of this title","children":[],"tail":", to ensure consistency; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa39ee9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3791/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regularly consult with appropriate government and industry persons and organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa39ee9e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3791/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall ensure that the acquisition workforce receives training on the guidelines and resources developed under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa39ee9f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1833/n"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1833(n)","children":[],"tail":", ("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4234"},"text":"134 Stat. 4234","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/b/12/A"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(b)(12)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2134"},"text":"135 Stat. 2134","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVIII/s841"},"text":"Pub. L. 117–263, div. A, title VIII, § 841","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2716"},"text":"136 Stat. 2716","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa39eea0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa39eea1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa39eea2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2322"},"text":"section 2322 of this title","children":[],"tail":", which was transferred to this section by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833"},"text":"Pub. L. 116–283, § 1833","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1), was based on "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVIII/s802/a/1"},"text":"Pub. L. 115–91, div. A, title VIII, § 802(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1450"},"text":"131 Stat. 1450","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa39eea3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 3791 and 3792 were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tII/s213"},"text":"Pub. L. 96–513, title II, § 213","children":[],"tail":", title VII, § 701, "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2885"},"text":"94 Stat. 2885","children":[],"tail":", 2955, effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3791, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/616/s3/a"},"text":"Pub. L. 86–616, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/388"},"text":"74 Stat. 388","children":[],"tail":", authorized Secretary of the Army to convene at any time a board of general officers to review record of any commissioned officer on active list of Regular Army to determine whether he should be required, because of moral dereliction, professional dereliction, or because his retention is not clearly consistent with interests of national security, to show cause for his retention on active list. See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1181/b"},"text":"section 1181(b) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3792, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/616/s3/a"},"text":"Pub. L. 86–616, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/388"},"text":"74 Stat. 388","children":[],"tail":", provided for boards of inquiry, composed of three or more general officers, to be convened at such places as Secretary of the Army prescribes, to receive evidence and make findings and recommendations whether an officer, required to show cause under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3791"},"text":"section 3791 of this title","children":[],"tail":", should be retained on active list of Regular Army. See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1182"},"text":"section 1182 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa39eea4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s841/1"},"text":"Pub. L. 117–263, § 841(1)","children":[],"tail":", substituted “Department of Defense” for “department of defense” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s841/2"},"text":"Pub. L. 117–263, § 841(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/b/12/A"},"text":"Pub. L. 117–81, § 1701(b)(12)(A)","children":[],"tail":", which directed amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/n"},"text":"section 1833(n) of Pub. L. 116–283","children":[],"tail":", which enacted this section, by substituting “DEPARTMENT OF DEFENSE” for “DEPARTMENT OF DEFENSE” in text of section catchline, could not be executed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833"},"text":"Pub. L. 116–283, § 1833","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1), transferred subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2322"},"text":"section 2322 of this title","children":[],"tail":" to this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa39eea5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa39eea6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" applicable as if included in the enactment of title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" as enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/a/2"},"text":"section 1701(a)(2) of Pub. L. 117–81","children":[],"tail":", set out in a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":" and Effective Date note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa39eea7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as an Effective Date of 2021 Amendment note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa39eea8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pilot Program for the Use of Innovative Intellectual Property Strategies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tVIII/s808"},"text":"Pub. L. 118–31, div. A, title VIII, § 808","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/319"},"text":"137 Stat. 319","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dA/tVIII/s808"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall establish a pilot program for the use of innovative intellectual property strategies that meet the criteria described in subsection (b) to acquire the necessary technical data rights required for the operation, maintenance, and installation of, and training for, covered programs designated under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria for Strategies","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The innovative intellectual property strategies used in a pilot program established under this section may include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use of an escrow account to verify and hold intellectual property data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use of royalties or licenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other strategies, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Covered Programs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2024-05-01"},"text":"May 1, 2024","children":[],"tail":", and with respect to the pilot program established under this section—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of each military department shall designate one covered program within the military department under the jurisdiction of such Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary of Defense for Acquisition and Sustainment shall designate one covered program within the Defense Agencies or Department of Defense Field Activities (as defined, respectively, in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of title 10","children":[],"tail":", United States Code)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefing Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":"], the Under Secretary of Defense for Acquisition and Sustainment, in coordination with the Secretaries of the military departments, shall provide a briefing to the Committees on Armed Services of the Senate and the House of Representatives with a detailed plan to implement the pilot program required under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning on the date on which the first program is designated under subsection (c) and until the termination date in subsection (f), the Under Secretary of Defense for Acquisition and Sustainment, in coordination with the Secretaries of the military departments, shall provide an annual report to the Committees on Armed Services of the Senate and the House of Representatives on—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of the pilot program in acquiring the necessary technical data rights necessary to support timely, cost-effective maintenance and sustainment of the acquisition programs designated under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations for the applicability of lessons learned from the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority to carry out the pilot program established under this section shall terminate on ","children":[{"tag":"date","attrib":{"date":"2028-12-31"},"text":"December 31, 2028","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘covered program’ means an acquisition program under which procurements are conducted using a pathway of the adaptive acquisition framework (as described in Department of Defense Instruction 5000.02, ‘Operation of the Adaptive Acquisition Framework’).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘technical data rights’ has the meaning given in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3771"},"text":"section 3771 of title 10","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
