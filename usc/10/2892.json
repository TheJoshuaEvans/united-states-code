{"tag":"section","attrib":{"id":"ida9f25e37-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2892"},"text":null,"children":[{"tag":"num","attrib":{"value":"2892"},"text":"§ 2892.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance work order system for housing units","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9f25e38-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2892/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Electronic Work Order System Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall require that each landlord of a housing unit have an electronic work order system to track all maintenance requests relating to the housing unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9f25e39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2892/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access by Department Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall require each landlord of a housing unit to provide access to the maintenance work order system of the landlord relating to the housing unit to the following persons:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9f25e3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2892/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Personnel of the housing management office at the installation for which the housing unit is provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9f25e3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2892/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Personnel of the installation and engineer command or center of the military department concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9f25e3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2892/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other personnel of the Department of Defense as the Secretary determines necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9f25e3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2892/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access by Tenants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall require each landlord of a housing unit to provide access to the maintenance work order system of the landlord relating to the housing unit to the tenant of the housing unit to permit the tenant, at a minimum, to track the status and progress of work orders for maintenance requests relating to the housing unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9f25e3e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dB/tXXX"},"text":"Pub. L. 116–92, div. B, title XXX","children":[],"tail":", §§ 3017, 3018, "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1930"},"text":"133 Stat. 1930","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9f25e3f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9f25e40-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9f25e41-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3018"},"text":"Pub. L. 116–92, § 3018","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
