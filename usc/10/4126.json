ldren":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" added identical sections."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa5b5921-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1844/b/1"},"text":"Pub. L. 116–283, § 1844(b)(1)","children":[],"tail":", which directed the renumbering of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2367"},"text":"section 2367 of this title","children":[],"tail":" as section 4147 instead of this section, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/u/5/B"},"text":"Pub. L. 117–81, § 1701(u)(5)(B)","children":[],"tail":", effective as if included therein, so that such renumbering was no longer directed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1843/b/1"},"text":"Pub. L. 116–283, § 1843(b)(1)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/u/4/A"},"text":"Pub. L. 117–81, § 1701(u)(4)(A)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2367"},"text":"section 2367 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1883/b/2"},"text":"Pub. L. 116–283, § 1883(b)(2)","children":[],"tail":", substituted “section 3004” for “section 2302(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s1041/a/12"},"text":"Pub. L. 107–314, § 1041(a)(12)","children":[],"tail":", struck out designations for pars. (1) and (2) and text of par. (1). Prior to amendment par. (1) read as follows: “In the documents provided to Congress by the Secretary of Defense in support of the budget submitted by the President under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":" for any fiscal year, the Secretary shall set forth the proposed amount of the man-years of effort to be funded by the Department of Defense for each federally funded research and development center for the fiscal year covered by that budget.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “and the Committee on Armed Services” for “and the Committee on National Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" substituted “the Committee on Armed Services and the Committee on Appropriations of the Senate and the Committee on National Security and the Committee on Appropriations of the” for “the Committees on Armed Services and the Committees on Appropriations of the Senate and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa5b5922-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note",