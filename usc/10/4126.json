ail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1330"},"text":"105 Stat. 1330","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/190/dA/tII/s256/a/2"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) of subsection (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2367"},"text":"section 2367 of title 10","children":[],"tail":", United States Code [now "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4126"},"text":"10 U.S.C. 4126","children":[],"tail":"], as added by paragraph (1), shall take effect with respect to the budget submitted for fiscal year 1994."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (2) of such subsection shall take effect with respect to fiscal year 1992.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa5b5925-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2021-12-31"},"text":"Dec. 31, 2021","children":[],"tail":", of provisions in subsec. (d) of this section requiring submittal of annual report to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1061"},"text":"section 1061 of Pub. L. 114–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s111"},"text":"section 111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa5b5926-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pilot Program on Disclosure of Certain Sensitive Information to Federally Funded Research and Development Centers","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tII/s235"},"text":"Pub. L. 114–328, div. A, title II, § 235","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2064"},"text":"130 Stat. 2064","children":[],"tail":", which authorized the Secretary of Defense to carry out a pilot program on disclosure of certain sensitive information to federally funded research and development centers of the Department of Defense, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVIII/s811/a/1/E"},"text":"Pub. L. 118–159, div. A, title VIII, § 811(a)(1)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1979"},"text":"138 Stat. 1979","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
