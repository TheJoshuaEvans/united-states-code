{"tag":"section","attrib":{"id":"idaa5b5914-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4126"},"text":null,"children":[{"tag":"num","attrib":{"value":"4126"},"text":"§ 4126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of federally funded research and development centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa5b5915-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4126/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Use of Centers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), the Secretary of Defense may not place work with a federally funded research and development center unless such work is within the purpose, mission, and general scope of effort of such center as established in the sponsoring agreement of the Department of Defense with such center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa5b5916-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4126/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for Applied Scientific Research","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not apply to a federally funded research and development center that performs applied scientific research under laboratory conditions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa5b5917-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4126/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Creation of New Centers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa5b5918-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4126/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The head of an agency may not obligate or expend amounts appropriated to the Department of Defense for purposes of operating a federally funded research center that was not in existence before ","children":[{"tag":"date","attrib":{"date":"1986-06-02"},"text":"June 2, 1986","children":[],"tail":", until—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa5b5919-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4126/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of the agency submits to Congress a report with respect to such center that describes the purpose, mission, and general scope of effort of the center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa5b591a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4126/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 60 days beginning on the date such report is received by Congress has elapsed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b591b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4126/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the term “head of an agency” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3004"},"text":"section 3004 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa5b591c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4126/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Identification to Congress of FFRDC Workload Effort","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After the close of a fiscal year, and not later than January 1 of the next year, the Secretary shall submit to the Committee on Armed Services and the Committee on Appropriations of the Senate and the Committee on Armed Services and the Committee on Appropriations of the House of Representatives a report setting forth the actual obligations and the actual man-years of effort expended at each federally funded research and development center during that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa5b591d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/c/tX/s912/a/1"},"text":"Pub. L. 99–500, § 101(c) [title X, § 912(a)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-82"},"text":"100 Stat. 1783–82","children":[],"tail":", 1783–146, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/c/tX/s912/a/1"},"text":"Pub. L. 99–591, § 101(c) [title X, § 912(a)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-82"},"text":"100 Stat. 3341–82","children":[],"tail":", 3341–146, § 2367; "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tIX"},"text":"Pub. L. 99–661, div. A, title IX","children":[],"tail":", formerly title IV, § 912(a)(1), "},{"tag":"date"