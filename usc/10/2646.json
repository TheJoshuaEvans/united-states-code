{"tag":"section","attrib":{"id":"ida997bae1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2646"},"text":null,"children":[{"tag":"num","attrib":{"value":"2646"},"text":"§ 2646.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel services: procurement for official and unofficial travel under one contract","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida997bae2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2646/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an agency may enter into a contract for travel-related services that provides for the contractor to furnish services for both official travel and unofficial travel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida997bae3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2646/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Credits, Discounts, Commissions, Fees","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida997bae4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2646/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contract entered into under this section may provide for credits, discounts, or commissions or other fees to accrue to the Department of Defense. The accrual and amounts of credits, discounts, or commissions or other fees may be determined on the basis of the volume (measured in the number or total amount of transactions or otherwise) of the travel-related sales that are made by the contractor under the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida997bae5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2646/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The evaluation factors applicable to offers for a contract under this section may include a factor that relates to the estimated aggregate value of any credits, discounts, commissions, or other fees that would accrue to the Department of Defense for the travel-related sales made under the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida997bae6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2646/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Commissions or fees received by the Department of Defense as a result of travel-related sales made under a contract entered into under this section shall be distributed as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida997bae7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2646/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For amounts relating to sales for official travel, credit to appropriations available for official travel for the fiscal year in which the amounts were charged.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida997bae8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2646/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For amounts relating to sales for unofficial travel, deposit in nonappropriated fund accounts available for morale, welfare, and recreation programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida997bae9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2646/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida997baea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2646/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “head of an agency” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3004"},"text":"section 3004 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida997baeb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2646/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “official travel” means travel at the expense of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida997baec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2646/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “unofficial travel” means personal travel or other travel that is not paid for or reimbursed by the Federal Government out of appropriated funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida997baed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2646/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability to Coast Guard and NASA","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not apply to the Coast Guard when it is not operating as a service in the Navy, nor to the National Aeronautics and Space Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida997baee-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tVIII/s813/a"},"text":"Pub. L. 105–261, div. A, title VIII, § 813(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2087"},"text":"112 Stat. 2087","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1806/e/1/B"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1806(e)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4155"},"text":"134 Stat. 4155","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida997baef-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida997baf0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida997baf1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “section 3004” for “section 2302(1)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida997baf2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida997baf3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"ida997baf4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
