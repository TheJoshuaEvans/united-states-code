{"tag":"section","attrib":{"id":"idab55be67-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8931"},"text":null,"children":[{"tag":"num","attrib":{"value":"8931"},"text":"§ 8931.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Oceanographic Partnership Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab55be68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8931/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy shall establish a program to be known as the “National Oceanographic Partnership Program”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab55be69-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8931/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the program are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab55be6a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8931/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To promote the national goals of assuring national security, advancing economic development, protecting quality of life, ensuring environmental stewardship, and strengthening science education and communication through improved knowledge of the ocean.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab55be6b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8931/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To coordinate and strengthen oceanographic efforts in support of those goals by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab55be6c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8931/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating and carrying out partnerships among Federal agencies, academia, industry, and other members of the oceanographic community in the areas of science, data, technology development, resources, education, and communication; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55be6d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8931/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accepting, planning, and executing oceanographic research projects funded by grants, contracts, cooperative agreements, or other vehicles as appropriate, that contribute to assuring national security, advancing economic development, protecting quality of life, ensuring environmental stewardship, and strengthening science education and communication through improved knowledge of the ocean.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab55be6e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tII/s282/a/1"},"text":"Pub. L. 104–201, div. A, title II, § 282(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2470"},"text":"110 Stat. 2470","children":[],"tail":", § 7901; renumbered § 8931, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/14"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tX/s1055/a"},"text":"Pub. L. 116–283, div. A, title X, § 1055(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3851"},"text":"134 Stat. 3851","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab55be6f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab55be70-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab55be71-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" amended section generally. Prior to amendment, section related to establishment and purposes of National Oceanographic Partnership Program. As enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", “SEC.” preceding section designation and catchline text were editorially conformed to the style used in this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7901"},"text":"section 7901 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab55be72-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab55be73-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab55be74-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tII/s281"},"text":"Pub. L. 104–201, div. A, title II, § 281","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2469"},"text":"110 Stat. 2469","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/201/dA/tII/s281"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds the following:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The oceans and coastal areas of the United States are among the Nation’s most valuable natural resources, making substantial contributions to economic growth, quality of life, and national security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Oceans drive global and regional climate. Hence, they contain information affecting agriculture, fishing, and the prediction of severe weather.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Understanding of the oceans through basic and applied research is essential for using the oceans wisely and protecting their limited resources. Therefore, the United States should maintain its world leadership in oceanography as one key to its competitive future.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ocean research and education activities take place within Federal agencies, academic institutions, and industry. These entities often have similar requirements for research facilities, data, and other resources (such as oceanographic research vessels).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The need exists for a formal mechanism to coordinate existing partnerships and establish new partnerships for the sharing of resources, intellectual talent, and facilities in the ocean sciences and education, so that optimal use can be made of this most important natural resource for the well-being of all Americans.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
