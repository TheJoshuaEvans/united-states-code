{"tag":"section","attrib":{"id":"idab8a155b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10105"},"text":null,"children":[{"tag":"num","attrib":{"value":"10105"},"text":"§ 10105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Army National Guard of the United States: composition","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Army National Guard of the United States is the reserve component of the Army that consists of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8a155c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10105/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" federally recognized units and organizations of the Army National Guard; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8a155d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10105/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the Army National Guard who are also Reserves of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab8a155e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1661/a/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1661(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2970"},"text":"108 Stat. 2970","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab8a155f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab8a1560-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab8a1561-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3077"},"text":"section 3077 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1661/a/3/A"},"text":"Pub. L. 103–337, § 1661(a)(3)(A)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab8a1562-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idab8a1563-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691"},"text":"section 1691 of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab8a1564-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Active Component Support for Reserve Training","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tV/s515"},"text":"Pub. L. 103–160, div. A, title V, § 515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1650"},"text":"107 Stat. 1650","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/160/dA/tV/s515"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement To Establish","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army shall, not later than ","children":[{"tag":"date","attrib":{"date":"1995-09-30"},"text":"September 30, 1995","children":[],"tail":", establish one or more active-component units of the Army with the primary mission of providing training support to reserve units. Each such unit shall be part of the active Army force structure and shall have a commander who is on the active-duty list of the Army."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation Plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army shall during fiscal year 1994 submit to the Committees on Armed Services of the Senate and House of Representatives a plan to meet the requirement in subsection (a). The plan shall include a proposal for any statutory changes that the Secretary considers to be necessary for the implementation of the plan.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab8a1565-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Test Program for Reserve Combat Maneuver Unit Integration","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tV/s516"},"text":"Pub. L. 103–160, div. A, title V, § 516","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1650"},"text":"107 Stat. 1650","children":[],"tail":", directed Secretary of the Army to prepare a plan for carrying out a test program to determine feasibility and advisability of applying the roundout and roundup models for integration of active and reserve component Army units at the battalion and company levels and submit to Congress not later than "},{"tag":"date","attrib":{"date":"1994-03-31"},"text":"Mar. 31, 1994","children":[],"tail":", a report that includes the plan for the test program."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab8a1566-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Army National Guard Combat Readiness Reform","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tXI"},"text":"Pub. L. 102–484, div. A, title XI","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2536"},"text":"106 Stat. 2536","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/35/tII/s202/a/11"},"text":"Pub. L. 103–35, title II, § 202(a)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-05-31"},"text":"May 31, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/101"},"text":"107 Stat. 101","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tV/s520"},"text":"Pub. L. 103–160, div. A, title V, § 520","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1651"},"text":"107 Stat. 1651","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tV/s516"},"text":"Pub. L. 103–337, div. A, title V, § 516","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2754"},"text":"108 Stat. 2754","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV"},"text":"Pub. L. 104–106, div. A, title V","children":[],"tail":", §§ 514, 515, title VII, § 704(b), "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/307"},"text":"110 Stat. 307","children":[],"tail":", 308, 372; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tIII/s321/b"},"text":"Pub. L. 114–328, div. A, title III, § 321(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2075"},"text":"130 Stat. 2075","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tV/s520"},"text":"Pub. L. 116–92, div. A, title V, § 520","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1351"},"text":"133 Stat. 1351","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dA/tV/s520"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1101"},"text":"“SEC. 1101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This title may be cited as the ‘Army National Guard Combat Readiness Reform Act of 1992’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subtitle","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“Subtitle A—","children":[],"tail":null},{"tag":"heading","attrib":{},"text":"Deployability Enhancements","children":[],"tail":null},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1111"},"text":"“SEC. 1111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" PRIOR ACTIVE-DUTY PERSONNEL.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Prior Active Duty Officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army shall increase the number of qualified prior active-duty officers in the Army National Guard by providing a program that permits the separation of officers on active duty with at least two, but less than three, years of active service upon condition that the officer is accepted for appointment in the Army National Guard. The Secretary shall have a goal of having not fewer than 150 officers become members of the Army National Guard each year under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Prior Active Duty Enlisted Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army shall increase the number of qualified prior active-duty enlisted members in the Army National Guard through the use of enlistments as described in section 8020 of the Department of Defense Appropriations Act, 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/139"},"text":"Public Law 103–139","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/stat/107/1441"},"text":"107 Stat. 1441","children":[],"tail":"]. The Secretary shall enlist not fewer than 1,000 new enlisted members each year under enlistments described in that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified Prior Active-Duty Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, qualified prior active-duty personnel are members of the Army National Guard with not less than two years of active duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1112"},"text":"“SEC. 1112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SERVICE IN SELECTED RESERVE IN LIEU OF ACTIVE-DUTY SERVICE.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Academy Graduates and Distinguished ROTC Graduates To Serve in Selected Reserve for Period of Active-duty Service Obligation Not Served on Active Duty","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who is a graduate of one of the service academies or who was commissioned as a distinguished Reserve Officers’ Training Corps graduate and who is permitted to be released from active duty before the completion of the active-duty service obligation applicable to that officer shall serve the remaining period of such active-duty service obligation as a member of the Selected Reserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may waive paragraph (1) in a case in which the Secretary determines that there is no unit position available for the officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"ROTC Graduates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army shall provide a program under which graduates of the Reserve Officers’ Training Corps program may perform their minimum period of obligated service by a combination of (A) two years of active duty, and (B) such additional period of service as is necessary to complete the remainder of such obligation, to be served in the Selected Reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{"status":"repealed"},"text":null,"children":[{"tag":"num","attrib":{"value":"1113"},"text":"“[SEC. 1113.","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tV/s520"},"text":"Pub. L. 116–92, div. A, title V, § 520","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1351"},"text":"133 Stat. 1351","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1114"},"text":"“SEC. 1114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NONCOMMISSIONED OFFICER EDUCATION REQUIREMENTS.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonwaivability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any standard prescribed by the Secretary of the Army establishing a military education requirement for noncommissioned officers that must be met as a requirement for promotion to a higher noncommissioned officer grade may be waived only if the Secretary determines that the waiver is necessary in order to preserve unit leadership continuity under combat conditions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Training Positions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army shall ensure that there are sufficient training positions available to enable compliance with subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1115"},"text":"“SEC. 1115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" INITIAL ENTRY TRAINING AND NONDEPLOYABLE PERSONNEL ACCOUNT.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Personnel Account","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army shall establish a personnel accounting category for members of the Army Selected Reserve to be used for categorizing members of the Selected Reserve who have not completed the minimum training required for deployment or who are otherwise not available for deployment. The account shall be designed so that it is compatible with the decentralized personnel systems of the Army Guard and Reserve. The account shall be used for the reporting of personnel readiness and may not be used as a factor in establishing the level of Army Guard and Reserve force structure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Account","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Until a member of the Army Selected Reserve has completed the minimum training necessary for deployment, the member may not be assigned to fill a position in a Selected Reserve unit but shall be carried in the account established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time for Qualification for Deployment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If at the end of 24 months after a member of the Army Selected Reserve enters the Army Selected Reserve, the member has not completed the minimum training required for deployment, the member shall be discharged.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army may waive the requirement in paragraph (1) in the case of health care providers and in other cases determined necessary. The authority to make such a waiver may not be delegated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1116"},"text":"“SEC. 1116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" MINIMUM PHYSICAL DEPLOYABILITY STANDARDS.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“The Secretary of the Army shall transfer the personnel classification of a member of the Army Selected Reserve from the Selected Reserve unit of the member to the personnel account established pursuant to section 1115 if the member does not meet minimum physical profile standards required for deployment. Any such transfer shall be made not later than 90 days after the date on which the determination that the member does not meet such standards is made.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“[SECS. 1117, 1118. Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tVII/s704/b"},"text":"Pub. L. 104–106, div. A, title VII, § 704(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/372"},"text":"110 Stat. 372","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1119"},"text":"“SEC. 1119.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" COMBAT UNIT TRAINING.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“The Secretary of the Army shall establish a program to minimize the post-mobilization training time required for combat units of the Army National Guard. The program shall require—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that unit premobilization training emphasize—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individual soldier qualification and training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collective training and qualification at the crew, section, team, and squad level; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maneuver training at the platoon level as required of all Army units; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that combat training for command and staff leadership include annual multi-echelon training to develop battalion, brigade, and division level skills, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1120"},"text":"“SEC. 1120.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" USE OF COMBAT SIMULATORS.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“The Secretary of the Army shall expand the use of simulations, simulators, and advanced training devices and technologies in order to increase training opportunities for members and units of the Army National Guard and the Army Reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null},{"tag":"subtitle","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“Subtitle B—","children":[],"tail":null},{"tag":"heading","attrib":{},"text":"Assessment of National Guard Capability","children":[],"tail":null},{"tag":"section","attrib":{"status":"repealed"},"text":null,"children":[{"tag":"num","attrib":{"value":"1121"},"text":"“[SEC. 1121.","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tIII/s321/b"},"text":"Pub. L. 114–328, div. A, title III, § 321(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2075"},"text":"130 Stat. 2075","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1122"},"text":"“SEC. 1122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" INSPECTIONS.","children":[],"tail":null},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab8a1567-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"“[Amended ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s105"},"text":"section 105 of Title 32","children":[],"tail":", National Guard.]"}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":null},{"tag":"subtitle","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“Subtitle C—","children":[],"tail":null},{"tag":"heading","attrib":{},"text":"Compatibility of Guard Units With Active Component Units","children":[],"tail":null},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1131"},"text":"“SEC. 1131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ACTIVE DUTY ASSOCIATE UNIT RESPONSIBILITY.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Associate Units","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Army shall require—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that each ground combat maneuver brigade of the Army National Guard that (as determined by the Secretary) is essential for the execution of the National Military Strategy be associated with an active-duty combat unit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that combat support and combat service support units of the Army Selected Reserve that (as determined by the Secretary) are essential for the execution of the National Military Strategy be associated with active-duty units.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The commander (at a brigade or higher level) of the associated active duty unit for any National Guard unit or Army Selected Reserve unit that (as determined by the Secretary under subsection (a)) is essential for the execution of the National Military Strategy shall be responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approving the training program of that unit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing the readiness report of that unit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the manpower, equipment, and training resources requirements of that unit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" validating, not less often than annually, the compatibility of that unit with the active duty forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army shall begin to implement subsection (a) during fiscal year 1993 and shall achieve full implementation of the plan not later than ","children":[{"tag":"date","attrib":{"date":"1995-10-01"},"text":"October 1, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1132"},"text":"“SEC. 1132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" TRAINING COMPATIBILITY.","children":[],"tail":null},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab8a1568-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"“[Amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/s414/c"},"text":"section 414(c) of Pub. L. 102–190","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12001"},"text":"section 12001 of this title","children":[],"tail":".]"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1133"},"text":"“SEC. 1133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SYSTEMS COMPATIBILITY.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compatibility Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army shall develop and implement a program to ensure that Army personnel systems, Army supply systems, Army maintenance management systems, and Army finance systems are compatible across all Army components.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1993-09-30"},"text":"September 30, 1993","children":[],"tail":", the Secretary shall submit to the Committees on Armed Services of the Senate and House of Representatives a report describing the program under subsection (a) and setting forth a plan for implementation of the program by the end of fiscal year 1997."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1134"},"text":"“SEC. 1134.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" EQUIPMENT COMPATIBILITY.","children":[],"tail":null},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab8a1569-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"“[Amended section 115b(b) [now 10541(b)] of this title.]","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{"status":"repealed"},"text":null,"children":[{"tag":"num","attrib":{"value":"1135"},"text":"“[SEC. 1135.","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tIII/s321/b"},"text":"Pub. L. 114–328, div. A, title III, § 321(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2075"},"text":"130 Stat. 2075","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1136"},"text":"“SEC. 1136.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" QUALIFICATION FOR PRIOR-SERVICE ENLISTMENT BONUS.","children":[],"tail":null},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab8a156a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"“[Amended ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s308i/c"},"text":"section 308i(c) of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services.]"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1137"},"text":"“SEC. 1137.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" STUDY OF IMPLEMENTATION FOR ALL RESERVE COMPONENTS.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“The Secretary of Defense shall conduct an assessment of the feasibility of implementing the provisions of this title for all reserve components. Not later than ","children":[{"tag":"date","attrib":{"date":"1993-12-31"},"text":"December 31, 1993","children":[],"tail":", the Secretary shall submit to the Committees on Armed Services of the Senate and House of Representatives a report containing a plan for such implementation.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
