{"tag":"section","attrib":{"id":"idab070239-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8017"},"text":null,"children":[{"tag":"num","attrib":{"value":"8017"},"text":"§ 8017.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of the Navy: successors to duties","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If the Secretary of the Navy dies, resigns, is removed from office, is absent, or is disabled, the person who is highest on the following list, and who is not absent or disabled, shall perform the duties of the Secretary until the President, under section 3347 ","children":[{"tag":"ref","attrib":{"idref":"fn002158"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002158"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 5, directs another person to perform those duties or until the absence or disability ceases:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab07023a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8017/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab07023b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8017/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretaries of the Navy, in the order prescribed by the Secretary of the Navy and approved by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab07023c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8017/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The General Counsel of the Department of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab07023d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8017/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Naval Operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab07023e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8017/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commandant of the Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab07023f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s511/c/4"},"text":"Pub. L. 99–433, title V, § 511(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1047"},"text":"100 Stat. 1047","children":[],"tail":", § 5017; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tIX/s902/b"},"text":"Pub. L. 103–337, div. A, title IX, § 902(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2823"},"text":"108 Stat. 2823","children":[],"tail":"; renumbered § 8017, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/a/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1834"},"text":"132 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab070240-3a6f-1