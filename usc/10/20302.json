{"tag":"section","attrib":{"id":"idabccea1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20302"},"text":null,"children":[{"tag":"num","attrib":{"value":"20302"},"text":"§ 20302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enlisted members: term of enlistment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabccea1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term of Original Enlistments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Air Force may accept original enlistments of persons for the duration of their minority or for a period of at least two but not more than eight years in the Space Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabccea1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term of Reenlistments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Air Force may accept a reenlistment in the Space Force for a period determined in accordance with paragraphs (2), (3), and (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s505/d"},"text":"section 505(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabccea1d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1717/a"},"text":"Pub. L. 118–31, div. A, title XVII, § 1717(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/654"},"text":"137 Stat. 654","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
