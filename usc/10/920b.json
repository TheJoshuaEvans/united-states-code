{"tag":"section","attrib":{"id":"ida82d557a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b"},"text":null,"children":[{"tag":"num","attrib":{"value":"920b"},"text":"§ 920b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 120b. Rape and sexual assault of a child","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida82d557b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rape of a Child","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82d557c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commits a sexual act upon a child who has not attained the age of 12 years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d557d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" commits a sexual act upon a child who has attained the age of 12 years by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida82d557e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using force against any person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82d557f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" threatening or placing that child in fear;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82d5580-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rendering that child unconscious; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82d5581-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administering to that child a drug, intoxicant, or other similar substance;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is guilty of rape of a child and shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82d5582-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sexual Assault of a Child","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person subject to this chapter who commits a sexual act upon a child who has attained the age of 12 years is guilty of sexual assault of a child and shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82d5583-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sexual Abuse of a Child","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person subject to this chapter who commits a lewd act upon a child is guilty of sexual abuse of a child and shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82d5584-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Age of Child.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82d5585-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Under 12 years","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a prosecution under this section, it need not be proven that the accused knew the age of the other person engaging in the sexual act or lewd act. It is not a defense that the accused reasonably believed that the child had attained the age of 12 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d5586-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Under 16 years","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a prosecution under this section, it need not be proven that the accused knew that the other person engaging in the sexual act or lewd act had not attained the age of 16 years, but it is a defense in a prosecution under subsection (b) (sexual assault of a child) or subsection (c) (sexual abuse of a child), which the accused must prove by a preponderance of the evidence, that the accused reasonably believed that the child had attained the age of 16 years, if the child had in fact attained at least the age of 12 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82d5587-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proof of Threat","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a prosecution under this section, in proving that a person made a threat, it need not be proven that the person actually intended to carry out the threat or had the ability to carry out the threat.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82d5588-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Lack of consent is not an element and need not be proven in any prosecution under this section. A child cannot consent to any sexual act, lewd act, or use of force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82d5589-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82d558a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sexual act and sexual contact","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms “sexual act” and “sexual contact” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s920/g"},"text":"section 920(g) of this title","children":[],"tail":" (article 120(g)), except that the term “sexual act” also includes the intentional touching, not through the clothing, of the genitalia of another person who has not attained the age of 16 years with an intent to abuse, humiliate, harass, degrade, or arouse or gratify the sexual desire of any person."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d558b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Force","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “force” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida82d558c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of a weapon;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82d558d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of such physical strength or violence as is sufficient to overcome, restrain, or injure a child; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82d558e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inflicting physical harm.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In the case of a parent-child or similar relationship, the use or abuse of parental or similar authority is sufficient to constitute the use of force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d558f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Threatening or placing that child in fear","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “threatening or placing that child in fear” means a communication or action that is of sufficient consequence to cause the child to fear that non-compliance will result in the child or another person being subjected to the action contemplated by the communication or action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d5590-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Child","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “child” means any person who has not attained the age of 16 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d5591-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lewd act","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “lewd act” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida82d5592-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/g/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any sexual contact with a child;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82d5593-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/g/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intentionally exposing one’s genitalia, anus, buttocks, or female areola or nipple to a child by any means, including via any communication technology, with an intent to abuse, humiliate, or degrade any person, or to arouse or gratify the sexual desire of any person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82d5594-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/g/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intentionally communicating indecent language to a child by any means, including via any communication technology, with an intent to abuse, humiliate, or degrade any person, or to arouse or gratify the sexual desire of any person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82d5595-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920b/g/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any indecent conduct, intentionally done with or in the presence of a child, including via any communication technology, that amounts to a form of immorality relating to sexual impurity which is grossly vulgar, obscene, and repugnant to common propriety, and tends to excite sexual desire or deprave morals with respect to sexual relations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida82d5596-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s541/b"},"text":"Pub. L. 112–81, div. A, title V, § 541(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1407"},"text":"125 Stat. 1407","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/a/3"},"text":"Pub. L. 112–239, div. A, title X, § 1076(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1948"},"text":"126 Stat. 1948","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLX/s5430/c"},"text":"Pub. L. 114–328, div. E, title LX, § 5430(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2950"},"text":"130 Stat. 2950","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s565"},"text":"Pub. L. 118–159, div. A, title V, § 565","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1904"},"text":"138 Stat. 1904","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida82d5597-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida82d5598-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida82d5599-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" redesignated subsec. (g) as (f), struck out “not legally married to the person committing the sexual act, lewd act, or use of force” before “cannot consent to any sexual act”, and struck out former subsec. (f). Prior to amendment, text of subsec. (f) read as follows: “In a prosecution under subsection (b) (sexual assault of a child) or subsection (c) (sexual abuse of a child), it is a defense, which the accused must prove by a preponderance of the evidence, that the persons engaging in the sexual act or lewd act were at that time married to each other, except where the accused commits a sexual act upon the person when the accused knows or reasonably should know that the other person is asleep, unconscious, or otherwise unaware that the sexual act is occurring or when the other person is incapable of consenting to the sexual act due to impairment by any drug, intoxicant, or other similar substance, and that condition was known or reasonably should have been known by the accused.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s565/2"},"text":"Pub. L. 118–159, § 565(2)","children":[],"tail":", redesignated subsec. (h) as (g). Former subsec. (g) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (h)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" inserted before period at end “, except that the term ‘sexual act’ also includes the intentional touching, not through the clothing, of the genitalia of another person who has not attained the age of 16 years with an intent to abuse, humiliate, harass, degrade, or arouse or gratify the sexual desire of any person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":", which enacted this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida82d559a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida82d559b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. No. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida82d559c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/a"},"text":"Pub. L. 112–239, div. A, title X, § 1076(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1947"},"text":"126 Stat. 1947","children":[],"tail":", provided that the amendment made by section 1076(a)(3) is effective "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida82d559d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", and applicable with respect to offenses committed on or after such effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/s541/f"},"text":"section 541(f) of Pub. L. 112–81","children":[],"tail":", set out as an Effective Date of 2011 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s843"},"text":"section 843 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
