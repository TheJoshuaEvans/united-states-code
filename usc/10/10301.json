{"tag":"section","attrib":{"id":"idab8ef6ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301"},"text":null,"children":[{"tag":"num","attrib":{"value":"10301"},"text":"§ 10301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve Forces Policy Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab8ef6eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s175"},"text":"section 175 of this title","children":[],"tail":", there is in the Office of the Secretary of Defense a board known as the “Reserve Forces Policy Board” (in this section referred to as the “Board”)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8ef6ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall serve as an independent adviser to the Secretary of Defense to provide advice and recommendations to the Secretary on strategies, policies, and practices designed to improve and enhance the capabilities, efficiency, and effectiveness of the reserve components.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8ef6ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board consists of 20 members, appointed or designated as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8ef6ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A civilian appointed by the Secretary of Defense from among persons determined by the Secretary to have the knowledge of, and experience in, policy matters relevant to national security and reserve component matters necessary to carry out the duties of chair of the Board, who shall serve as chair of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef6ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Two active or retired reserve officers or enlisted members designated by the Secretary of Defense upon the recommendation of the Secretary of the Army—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab8ef6f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one of whom shall be a member of the Army National Guard of the United States or a former member of the Army National Guard of the United States in the Retired Reserve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8ef6f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one of whom shall be a member or retired member of the Army Reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef6f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Two active or retired reserve officers or enlisted members designated by the Secretary of Defense upon the recommendation of the Secretary of the Navy—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab8ef6f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one of whom shall be an active or retired officer of the Navy Reserve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8ef6f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one of whom shall be an active or retired officer of the Marine Corps Reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef6f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Two active or retired reserve officers or enlisted members designated by the Secretary of Defense upon the recommendation of the Secretary of the Air Force—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab8ef6f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one of whom shall be a member of the Air National Guard of the United States or a former member of the Air National Guard of the United States in the Retired Reserve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8ef6f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one of whom shall be a member or retired member of the Air Force Reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef6f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One active or retired reserve officer or enlisted member of the Coast Guard designated by the Secretary of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef6f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Ten persons appointed or designated by the Secretary of Defense, each of whom shall be a United States citizen having significant knowledge of and experience in policy matters relevant to national security and reserve component matters and shall be one of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab8ef6fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual not employed in any Federal or State department or agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8ef6fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual employed by a Federal or State department or agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8ef6fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An officer of a regular component of the armed forces on active duty, or an officer of a reserve component of the armed forces in an active status, who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idab8ef6fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/c/6/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is serving or has served in a senior position on the Joint Staff, the headquarters staff of a combatant command, or the headquarters staff of an armed force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab8ef6fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/c/6/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has experience in joint professional military education, joint qualification, and joint operations matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef6ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A reserve officer of the Army, Navy, Air Force, or Marine Corps who is a general or flag officer recommended by the chair and designated by the Secretary of Defense, who shall serve without vote—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab8ef700-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as military adviser to the chair;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8ef701-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as military executive officer of the Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8ef702-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/c/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as supervisor of the operations and staff of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef703-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A senior enlisted member of a reserve component recommended by the chair and designated by the Secretary of Defense, who shall serve without vote as enlisted military adviser to the chair.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8ef704-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matters To Be Acted on","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board may act on those matters referred to it by the chair and on any matter raised by a member of the Board or the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8ef705-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Staff","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall be supported by a staff consisting of one full-time officer from each of the reserve components listed in paragraphs (1) through (6) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s10101"},"text":"section 10101 of this title","children":[],"tail":" who holds the grade of colonel (or in the case of the Navy, the grade of captain) or who has been selected for promotion to that grade. These officers shall also serve as liaisons between their respective components and the Board. They shall perform their staff and liaison duties under the supervision of the military executive officer of the Board in an independent manner reflecting the independent nature of the Board."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8ef706-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10301/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Service Reserve Policy Committees and Boards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not affect the committees and boards prescribed within the military departments by sections 10302 through 10305 of this title, and a member of such a committee or board may, if otherwise eligible, be a member of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab8ef707-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1661/b/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1661(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2980"},"text":"108 Stat. 2980","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/b/1"},"text":"Pub. L. 107–296, title XVII, § 1704(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s515/b/1/CC"},"text":"Pub. L. 109–163, div. A, title V, § 515(b)(1)(CC)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3233"},"text":"119 Stat. 3233","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tV/s514/a/1"},"text":"Pub. L. 111–383, div. A, title V, § 514(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4211"},"text":"124 Stat. 4211","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab8ef708-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab8ef709-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab8ef70a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s175"},"text":"section 175 of this title","children":[],"tail":", prior to amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1661/b/3"},"text":"Pub. L. 103–337, § 1661(b)(3)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab8ef70b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" amended section generally. Prior to amendment, section related to the composition and functions of the Reserve Forces Policy Board."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “Navy Reserve” for “Naval Reserve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab8ef70c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab8ef70d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tV/s514/a/2"},"text":"Pub. L. 111–383, div. A, title V, § 514(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4213"},"text":"124 Stat. 4213","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/383/dA/tV/s514/a/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2011-07-01"},"text":"July 1, 2011","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab8ef70e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idab8ef70f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691"},"text":"section 1691 of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
