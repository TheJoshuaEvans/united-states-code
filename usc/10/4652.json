{"tag":"section","attrib":{"id":"idaa8639ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4652"},"text":null,"children":[{"tag":"num","attrib":{"value":"4652"},"text":"§ 4652.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of funds for documenting economic or employment impact of certain acquisition programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No funds appropriated by the Congress may be obligated or expended to assist any contractor of the Department of Defense in preparing any material, report, lists, or analysis with respect to the actual or projected economic or employment impact in a particular State or congressional district of an acquisition program for which all research, development, testing, and evaluation has not been completed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idaa8639ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355/tVII/s7202/a/1"},"text":"Pub. L. 103–355, title VII, § 7202(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3379"},"text":"108 Stat. 3379","children":[],"tail":", § 2247; renumbered § 2249, "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dD/tXLIII/s4321/b/2/A"},"text":"Pub. L. 104–106, div. D, title XLIII, § 4321(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/672"},"text":"110 Stat. 672","children":[],"tail":"; renumbered § 4652, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1862/b"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1862(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":