{"tag":"section","attrib":{"id":"idaba935d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12684"},"text":null,"children":[{"tag":"num","attrib":{"value":"12684"},"text":"§ 12684.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserves: separation for absence without authority or sentence to imprisonment","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President or the Secretary concerned may drop from the rolls of the armed force concerned any Reserve—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba935d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12684/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has been absent without authority for at least three months;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba935d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12684/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who may be separated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12687"},"text":"section 12687 of this title","children":[],"tail":" by reason of a sentence to confinement adjudged by a court-martial; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba935d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12684/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is sentenced to confinement in a Federal or State penitentiary or correctional institution after having been found guilty of an offense by a court other than a court-martial or other military court, and whose sentence has become final.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaba935d5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1662/i/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1662(i)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2998"},"text":"108 Stat. 2998","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s563/b/2"},"text":"Pub. L. 104–106, div. A, title V, § 563(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/325"},"text":"110 Stat. 325","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaba935d6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaba935d7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaba935d8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1163/b"},"text":"section 1163(b) of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1662/i/2"},"text":"Pub. L. 103–337, § 1662(i)(2)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaba935d9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"ta