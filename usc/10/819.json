{"tag":"section","attrib":{"id":"ida813176b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s819"},"text":null,"children":[{"tag":"num","attrib":{"value":"819"},"text":"§ 819.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 19. Jurisdiction of special courts-martial","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida813176c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s819/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s817"},"text":"section 817 of this title","children":[],"tail":" (article 17), special courts-martial have jurisdiction to try persons subject to this chapter for any noncapital offense made punishable by this chapter and, under such regulations as the President may prescribe, for capital offenses. Special courts-martial may, under such limitations as the President may prescribe, adjudge any punishment not forbidden by this chapter except death, dishonorable discharge, dismissal, confinement for more than one year, hard labor without confinement for more than three months, forfeiture of pay exceeding two-thirds pay per month, or forfeiture of pay for more than one year."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida813176d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s819/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Neither a bad-conduct discharge, nor confinement for more than six months, nor forfeiture of pay for more than six months may be adjudged if charges and specifications are referred to a special court-martial consisting of a military judge alone under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s816/c/2/A"},"text":"section 816(c)(2)(A) of this title","children":[],"tail":" (article 16(c)(2)(A))."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida813176e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s819/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Military Magistrate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If charges and specifications are referred to a special court-martial consisting of a military judge alone under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s816/c/2/A"},"text":"section 816(c)(2)(A) of this title","children":[],"tail":" (article 16(c)(2)(A)), the military judge, with the consent of the parties, may designate a military magistrate to preside over the special court-martial."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida813176f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/43"},"text":"70A Stat. 43","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/632/s2/5"},"text":"Pub. L. 90–632, § 2(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-24"},"text":"Oct. 24, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1335"},"text":"82 Stat. 1335","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s577/a"},"text":"Pub. L. 106–65, div. A, title V, § 577(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/625"},"text":"113 Stat. 625","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/g/4"},"text":"Pub. L. 107–107, div. A, title X, § 1048(g)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1228"},"text":"115 Stat. 1228","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLIV/s5163"},"text":"Pub. L. 114–328, div. E, title LIV, § 5163","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2898"},"text":"130 Stat. 2898","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8131770-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8131771-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida8131772-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"819","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:579.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-05-05/ch169/s1"},"text":"May 5, 1950, ch. 169, § 1","children":[],"tail":" (Art. 19), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/114"},"text":"64 Stat. 114","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “shall” in the first sentence is omitted as surplusage. The words “for more than” are substituted for the words “in excess of”. The words “more than” are substituted for the words “a period exceeding”. The word “may” is substituted for the word “shall” in the last sentence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8131773-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8131774-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" designated existing provisions as subsec. (a) and inserted heading, struck out “A bad-conduct discharge, confinement for more than six months, or forfeiture of pay for more than six months may not be adjudged unless a complete record of the proceedings and testimony has been made, counsel having the qualifications prescribed under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s827/b"},"text":"section 827(b) of this title","children":[],"tail":" (article 27(b)) was detailed to represent the accused, and a military judge was detailed to the trial, except in any case in which a military judge could not be detailed to the trial because of physical conditions or military exigencies. In any such case in which a military judge was not detailed to the trial, the convening authority shall make a detailed written statement, to be appended to the record, stating the reason or reasons a military judge could not be detailed.” after “one year.”, and added subsecs. (b) and (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1048/g/4"},"text":"Pub. L. 107–107, § 1048(g)(4)","children":[],"tail":", amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/s577/a/2"},"text":"Pub. L. 106–65, § 577(a)(2)","children":[],"tail":". See 1999 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s577/a/2"},"text":"Pub. L. 106–65, § 577(a)(2)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1048/g/4"},"text":"Pub. L. 107–107, § 1048(g)(4)","children":[],"tail":", inserted “, confinement for more than six months, or forfeiture of pay for more than six months” after “A bad-conduct discharge” in third sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s577/a/1"},"text":"Pub. L. 106–65, § 577(a)(1)","children":[],"tail":", substituted “one year” for “six months” in two places in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/632"},"text":"Pub. L. 90–632","children":[],"tail":" provided that before a bad-conduct discharge may be adjudged by a special court-martial the accused must be detailed counsel who is legally qualified under the Code and a military judge must be detailed to the trial, with a detailed written statement appended to the record if a military judge was not detailed to the trial, because of physical conditions and military exigencies, stating the reasons that a military judge could not be so detailed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8131775-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8131776-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. No. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8131777-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/g"},"text":"Pub. L. 107–107, div. A, title X, § 1048(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1228"},"text":"115 Stat. 1228","children":[],"tail":", provided that the amendment made by section 1048(g)(4) is effective as of "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8131778-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s577/b"},"text":"Pub. L. 106–65, div. A, title V, § 577(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/625"},"text":"113 Stat. 625","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/65/dA/tV/s577/b"},"text":"“The amendments made by subsection (a) [amending this section] shall take effect on the first day of the sixth month beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":"] and shall apply with respect to charges referred on or after that effective date to trial by special courts-martial.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8131779-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/632"},"text":"Pub. L. 90–632","children":[],"tail":" effective first day of tenth month following October 1968, see "},{"tag":"ref","attrib":{"href":"/us/pl/90/632/s4"},"text":"section 4 of Pub. L. 90–632","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
