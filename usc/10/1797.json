{"tag":"section","attrib":{"id":"ida91962e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1797"},"text":null,"children":[{"tag":"num","attrib":{"value":"1797"},"text":"§ 1797.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early childhood education program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense shall require that all military child development centers meet standards of operation necessary for accreditation by an appropriate national early childhood programs accrediting body.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida91962e4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s568/a/1"},"text":"Pub. L. 104–106, div. A, title V, § 568(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/335"},"text":"110 Stat. 335","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
