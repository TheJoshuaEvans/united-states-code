{"tag":"section","attrib":{"id":"idaa8d65a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4753"},"text":null,"children":[{"tag":"num","attrib":{"value":"4753"},"text":"§ 4753.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplies: identification of supplier and sources","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa8d65aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4753/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall require that the contractor under a contract with the Department of Defense for the furnishing of supplies to the United States shall mark or otherwise identify supplies furnished under the contract with the identity of the contractor, the national stock number for the supplies furnished (if there is such a number), and the contractor’s identification number for the supplies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa8d65ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4753/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa8d65ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4753/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense shall prescribe regulations requiring that, whenever practicable, each contract requiring the delivery of supplies (other than a contract described in paragraph (2)) shall require that the contractor identify—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa8d65ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4753/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual manufacturer or producer of the item or of all sources of supply of the contractor for that item;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa8d65ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4753/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national stock number of the item (if there is such a number) and the identification number of the actual manufacturer or producer of the item or of each source of supply of the contractor for the item; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa8d65af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4753/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the source of any technical data delivered under the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8d65b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4753/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The regulations prescribed pursuant to paragraph (1) do not apply to a contract that requires the delivery of supplies that are commercial products (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s103"},"text":"section 103 of title 41","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8d65b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4753/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The regulations prescribed pursuant to paragraph (1) do not apply to a contract for an amount not greater than the simplified acquisition threshold (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s134"},"text":"section 134 of title 41","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa8d65b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4753/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identification of supplies and technical data under this section shall be made in the manner and with respect to the supplies prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa8d65b3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/137"},"text":"70A Stat. 137","children":[],"tail":", § 2384; "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXII/s1231/a"},"text":"Pub. L. 98–525, title XII, § 1231(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2599"},"text":"98 Stat. 2599","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/c/tX/s928/a"},"text":"Pub. L. 99–500, § 101(c) [title X, § 928(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-82"},"text":"100 Stat. 1783–82","children":[],"tail":", 1783–156, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/c/tX/s928/a"},"text":"Pub. L. 99–591, § 101(c) [title X, § 928(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-82"},"text":"100 Stat. 3341–82","childre