{"tag":"section","attrib":{"id":"idab2d27bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8471"},"text":null,"children":[{"tag":"num","attrib":{"value":"8471"},"text":"§ 8471.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Midshipmen’s store, trade shops, dairy, and laundry: nonappropriated fund instrumentality and accounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab2d27bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8471/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation as Nonappropriated Fund Instrumentality","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Superintendent of the Naval Academy shall operate the Naval Academy activities referred to in subsection (b) as a nonappropriated fund instrumentality under the jurisdiction of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2d27be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8471/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The nonappropriated fund instrumentality required under subsection (a) shall consist of the following Naval Academy activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab2d27bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8471/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The midshipmen’s store.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2d27c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8471/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The barber shop.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2d27c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8471/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cobbler shop.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2d27c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8471/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The tailor shop.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2d27c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8471/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The dairy (if any).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2d27c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8471/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The laundry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2d27c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8471/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonappropriated Fund Accounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Superintendent of the Naval Academy shall administer a separate nonappropriated fund account for each of the Naval Academy activities included in the nonappropriated fund instrumentality required under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2d27c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8471/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Crediting of Revenue","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Superintendent shall credit all revenue received from a Naval Academy activity referred to in subsection (b) to the account administered with respect to that activity under subsection (c), and amounts so credited shall be available for operating expenses of that activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2d27c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8471/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall be carried out under regulations prescribed by the Secretary of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab2d27c8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/435"},"text":"70A Stat. 435","children":[],"tail":", § 6971; "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s38"},"text":"Pub. L. 89–718, § 38","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1120"},"text":"80 Stat. 1120