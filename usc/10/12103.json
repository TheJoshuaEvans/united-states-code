-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab986d15-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1958 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"511(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:1012.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1955-08-09/ch665/s2/i"},"text":"Aug. 9, 1955, ch. 665, § 2(i)","children":[],"tail":" (1st 2 pars.), "},{"tag":"html:a","attrib":{"href":"/us/stat/69/600"},"text":"69 Stat. 600","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “respectively, pursuant to the provisions of this section” are omitted as surplusage. The words “as a Reserve for service” are inserted to reflect ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s510"},"text":"section 510 of this title","children":[],"tail":". The last six words of the first sentence are substituted for 50:1012(b) (1st sentence)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab986d16-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idab986d17-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Military Selective Service Act, referred to in subsecs. (b) and (d), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-24/ch625"},"text":"act June 24, 1948, ch. 625","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/604"},"text":"62 Stat. 604","children":[],"tail":", which is classified principally to chapter 49 (§ 3801 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3801"},"text":"section 3801 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab986d18-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1081/b/1/A/vii/I"},"text":"Pub. L. 114–328, § 1081(b)(1)(A)(vii)(I)","children":[],"tail":", substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3801"},"text":"50 U.S.C. 3801","children":[],"tail":" et seq.)” for “(50 U.S.C. App. 451 et seq.)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1081/b/1/A/vii"},"text":"Pub. L. 114–328, § 1081(b)(1)(A)(vii)","children":[],"tail":", substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3801"},"text":"50 U.S.C. 3801","children":[],"tail":" et seq.)” for “(50 U.S.C. App. 451 et seq.)” and “clauses (ii) and (iii) of section 6(c)(2)(A) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3806/c/2/A"},"text":"50 U.S.C. 3806(c)(2)(A)","children":[],"tail":")” for “section 6(c)(2)(A)(ii) and (iii) of such Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsecs. (b), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “Navy Reserve” for “Naval Reserve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" substituted “one year” for “270 days” in last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s511"},"text":"section 511 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/s1022/a/1/A"},"text":"Pub. L. 98–94, § 1022(a)(1)(A)","children":[],"tail":", substituted “not less than six years nor more than eight years” for “six years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/s1022/a/1/B"},"text":"Pub. L. 98–94, § 1022(a)(1)(B)","children":[],"tail":", substituted “not less than six years nor more than eight years” for “six years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" substituted “(50 U.S.C. App. 451 et seq.)” for “(50 U.S.C. App. 451–473)” after “Military Selective Service Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/252"},"text":"Pub. L. 97–252","children":[],"tail":" extended to 270 from 180 days requirement for commencement of initial period of active duty for training after date of enlistment."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “Military Selective Service Act (50 U.S.C. App. 451 et seq.)” for “Military Selective Service Act of 1967 (50 App. U.S.C. 451–473)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/107"},"text":"Pub. L. 96–107","children":[],"tail":" struck out requirement that a non-prior-service person be under 26 years of age."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/485"},"text":"Pub. L. 95–485","children":[],"tail":", in provision preceding cl. (1), substituted “the Secretary of Defense, and by the Secretary of Transportation with respect to the Coast Guard when it is not operating as a service in the Navy” for “the Secretary concerned” and “the Military Selective Service Act (50 U.S.C. App. 451–473)” for “sections 451–473 of title 50, appendix”, in cl. (1), substituted “not less than two years; and” for “two years;”, struck out former cl. (2), requiring a person enlisted under this subsec. to serve satisfactorily as a member of the Ready Reserve for a period which when added to his active duty under cl. (1) totals five years, redesignated former cl. (3) as (2), and in cl. (2) as so redesignated, substituted “Ready Reserve” for “Standby Reserve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/106"},"text":"Pub. L. 94–106","children":[],"tail":" reduced initial period of active duty for training for persons enlisted under this subsection from four months to twelve weeks."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/168"},"text":"Pub. L. 90–168","children":[],"tail":" substituted the Secretary of Transportation for the Secretary of the Treasury as the prescribing authority for regulations covering the Coast Guard when not operating as part of the Navy, inserted exception as provided in section 6(c)(2)(A)(ii) and (iii) of the Military Selective Service Act of 1967, added requirement that the initial period of four months’ service commence insofar as practicable within 180 days after the date of enlistment, an