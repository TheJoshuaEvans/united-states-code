xt":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1954-09-03/ch1257/s411/c"},"text":"Sept. 3, 1954, ch. 1257, § 411(c)","children":[],"tail":" (1st sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/68/1170"},"text":"68 Stat. 1170","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6389(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:1311(a) (as applicable to 1311(c)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1954-09-03/ch1257/s411/a"},"text":"Sept. 3, 1954, ch. 1257, § 411(a)","children":[],"tail":" (as applicable to 411(c)), "},{"tag":"html:a","attrib":{"href":"/us/stat/68/1169"},"text":"68 Stat. 1169","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6389(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:1311(c) (2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1954-09-03/ch1257/s411/c"},"text":"Sept. 3, 1954, ch. 1257, § 411(c)","children":[],"tail":" (2d sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/68/1170"},"text":"68 Stat. 1170","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6389(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:1311(c) (less 1st and 2d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1954-09-03/ch1257/s411/c"},"text":"Sept. 3, 1954, ch. 1257, § 411(c)","children":[],"tail":" (less 1st and 2d sentences), "},{"tag":"html:a","attrib":{"href":"/us/stat/68/1170"},"text":"68 Stat. 1170","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6389(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “who is considered as having twice failed of selection for promotion” are substituted for the words “after failing of selection for promotion * * * a second time” to conform to similar statements in this title. (See the revision note on section 5776.) The words “may be retained in” are omitted as surplusage, since the authority to eliminate such officers from an active status is discretionary with the Secretary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (e) is added to avoid conflict with 50:1311(d) and (e), codified in sections 6397 and 6403 of this title. 50:1311(d) and (e) contain special provisions for “women officers” and officers in the Nurse Corps, respectively, so that officers in these categories must be excepted from this section. Women officers appointed under the ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-24/ch457"},"text":"act of June 24, 1952, ch. 457","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/66/155"},"text":"66 Stat. 155","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s21e"},"text":"34 U.S.C. 21e","children":[],"tail":") (codified in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s5581"},"text":"section 5581 of this title","children":[],"tail":"), are not “women officers” within the meaning of 50:1311(d), however, but are required to be promoted, retired, or eliminated from active status as if they were men. (See the revision note on "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s5665"},"text":"section 5665 of this title","children":[],"tail":".) The application of this section to these officers is therefore made explicit."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Both men and women are eligible for appointment as reserve officers in the Nurse Corps and are subject to the special provisions relating to that corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab214186-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab214187-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8373, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/172/s1"},"text":"Pub. L. 89–172, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-08"},"text":"Sept. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/662"},"text":"79 Stat. 662","children":[],"tail":", related to promotion of officers to grades of brigadier general and major general of Air Force Reserve, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1629/c/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1629(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2963"},"text":"108 Stat. 2963","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s14315"},"text":"section 14315 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 8373, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/178/C"},"text":"Pub. L. 85–861, § 1(178)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1528"},"text":"72 Stat. 1528","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/86/559/s1/58"},"text":"Pub. L. 86–559, § 1(58)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-06-30"},"text":"June 30, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/277"},"text":"74 Stat. 277","children":[],"tail":", containing similar subject matter, expired by its own terms on "},{"tag":"date","attrib":{"date":"1964-06-30"},"text":"June 30, 1964","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab214188-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6389"},"text":"section 6389 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s515/b/3/C"},"text":"Pub. L. 109–163, § 515(b)(3)(C)","children":[],"tail":", substituted “Navy Reserve” for “Naval Reserve” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s515/b/1/M"},"text":"Pub. L. 109–163, § 515(b)(1)(M)","children":[],"tail":", substituted “Navy Reserve” for “Naval Reserve” wherever appearing in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" substituted “section 12732” for “section 1332”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1673/c"},"text":"Pub. L. 103–337, § 1673(c)","children":[],"tail":", substituted “12645” for “1005”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1628/1"},"text":"Pub. L. 103–337, § 1628(1)","children":[],"tail":", inserted “while on the active-duty list” after “to the next higher grade” and “or released from active duty and placed on the reserve active-status list” after “from an active status”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1628/2"},"text":"Pub. L. 103–337, § 1628(2)","children":[],"tail":", struck out “or (f)” after “subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1628/3/H"},"text":"Pub. L. 103–337, § 1628(3)(H)","children":[],"tail":", designated last sentence as par. (4) and in that sentence substituted “paragraph (1)” for “the first two sentences of this subsection” and struck out “captain or” after “permanent grade of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1628/3/G"},"text":"Pub. L. 103–337, § 1628(3)(G)","children":[],"tail":", designated 4th sentence as par. (3) and in that sentence substituted “paragraph (1)” for “the first two sentences of this subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1628/3/F"},"text":"Pub. L. 103–337, § 1628(3)(F)","children":[],"tail":", designated sentence after table as par. (2) and in that sentence substituted “the first sentence of paragraph (1)” for “the first sentence of this subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1628/3/E"},"text":"Pub. L. 103–337, § 1628(3)(E)","children":[],"tail":", in table struck out line relating to grades of captain in Navy and colonel in Marine Corps and substituted “28 years” for “26 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1628/3/D"},"text":"Pub. L. 103–337, § 1628(3)(D)","children":[],"tail":", inserted “while on the active-duty list” after “to the next higher grade” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1628/3/C"},"text":"Pub. L. 103–337, § 1628(3)(C)","children":[],"tail":", substituted “major or lieutenant colonel” for “major or above” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1628/3/B"},"text":"Pub. L. 103–337, § 1628(3)(B)","children":[],"tail":", substituted “lieutenant commander or commander” for “lieutenant commander or above” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1628/3/A"},"text":"Pub. L. 103–337, § 1628(3)(A)","children":[],"tail":", inserted “(1)” after “(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1628/4"},"text":"Pub. L. 103–337, § 1628(4)","children":[],"tail":", struck out subsec. (e) which read as follows: “This section does not apply to women reserve officers or to reserve officers in the Nurse Corps.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1628/4"},"text":"Pub. L. 103–337, § 1628(4)","children":[],"tail":", struck out subsec. (f) which provided for transfer or discharge of rear admirals (lower half) in Naval Reserve and brigadier generals in Marine Corps Reserve on completion of 30 years service or five years in grade and for rear admirals in Naval Reserve and major generals in Marine Corps Reserve on completion of 35 years service or five years in grade and provided that rear admirals (lower half) and rear admirals in Naval Reserve and brigadier generals and major generals in Marine Corps Reserve could be considered for early retirement by continuation board. See sections 14508 and 14705 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1628/4"},"text":"Pub. L. 103–337, § 1628(4)","children":[],"tail":", struck out subsec. (g) which read as follows: “An officer in an active status in the Naval Reserve in the permanent grade of ensign who is found not qualified for promotion to the grade of lieutenant (junior grade), and an officer in an active status in the Marine Corps Reserve in the permanent grade of second lieutenant who is found not qualified for promotion to the grade of first lieutenant, may (unless he is sooner promoted) be eliminated from an active status.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" substituted “W–5” for “W–4”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (f)(1), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" substituted “rear admiral (lower half)” for “commodore”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525"},"text":"Pub. L. 98–525","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (f)(1), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/86"},"text":"Pub. L. 97–86","children":[],"tail":" substituted “commodore” for “commodore admiral”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s337/a/1"},"text":"Pub. L. 96–513, § 337(a)(1)","children":[],"tail":", substituted “subsection (a) or (f)” for “subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s337/a/2"},"text":"Pub. L. 96–513, § 337(a)(2)","children":[],"tail":", substituted “as the years of active commissioned service of any regular officer on the active-duty” for “as any officer in the line on the active” and “or any regular officer on the active-duty list of the Marine Corps” for “or any officer on the active list of the Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s337/a/3"},"text":"Pub. L. 96–513, § 337(a)(3)","children":[],"tail":", substituted “does not apply to” for “applies to women officers appointed under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s5581"},"text":"section 5581 of this title","children":[],"tail":", but not to other”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s337/a/4"},"text":"Pub. L. 96–513, § 337(a)(4)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/559"},"text":"Pub. L. 86–559","children":[],"tail":" empowered the Secretary to defer the retirement or discharge of officers serving in the grade of lieutenant commander in the Ready Reserve, in the permanent grade of lieutenant commander or above in the Naval Reserve, in the permanent grade of major or above in the Marine Corps Reserve, and in the permanent grade of captain or commander in the Medical Corps, Chaplain Corps, or Dental Corps in the Naval Reserve."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab214189-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab21418a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{