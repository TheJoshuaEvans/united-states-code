{"tag":"section","attrib":{"id":"ida7e109c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s574"},"text":null,"children":[{"tag":"num","attrib":{"value":"574"},"text":"§ 574.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Warrant officer active-duty lists; competitive categories; number to be recommended for promotion; promotion zones","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7e109c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s574/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned shall maintain for each armed force under the jurisdiction of that Secretary a single list of all warrant officers (other than warrant officers described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s582"},"text":"section 582 of this title","children":[],"tail":") who are on active duty."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e109c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s574/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may establish competitive categories for promotion. Warrant officers in the same competitive category shall compete among themselves for promotion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e109c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s574/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Before convening a selection board under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s573"},"text":"section 573 of this title","children":[],"tail":", the Secretary concerned shall determine for each grade (or grade and competitive category) to be considered by the board the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7e109ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s574/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The maximum number of warrant officers to be recommended for promotion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7e109cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s574/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A promotion zone for warrant officers on the warrant officer active-duty list.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e109cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s574/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The position of a warrant officer on the warrant officer active-duty list shall be determined as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7e109cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s574/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Warrant officers shall be carried in the order of seniority of the grade in which they are serving on active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7e109ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s574/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Warrant officers serving in the same grade shall be carried in the order of their rank in that grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7e109cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s574/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A warrant officer on the warrant officer active-duty list who receives a temporary appointment or a temporary assignment in a grade other than a warrant officer grade or chief warrant officer grade shall retain his position on the warrant officer active-duty list while so serving.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e109d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s574/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A chief warrant officer may not be considered for promotion to the next higher grade under this chapter until the officer has completed two years of service on active duty in the grade in which the officer is serving.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7e109d1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tXI/s1112/a"},"text":"Pub. L. 102–190, div. A, title XI, § 1112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1494"},"text":"105 Stat. 1494","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1052/3"},"text":"Pub. L. 102–484, div. A, title X, § 1052(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2499"},"text":"106 Stat. 2499","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tV/s541/b/2"},"text":"Pub. L. 103–337, div. A, title V, § 541(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2764"},"text":"108 Stat. 2764","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s506/a"},"text":"Pub. L. 104–201, div. A, title V, § 506(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2512"},"text":"110 Stat. 2512","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7e109d2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7e109d3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7e109d4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" substituted “two years of service” for “three years of service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" substituted “Secretary concerned” for “Secretary of each military department”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":" substituted “active-duty list” for “active duty list” before “while”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7e109d5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7e109d6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" effective on the first day of the fourth month beginning after "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s541/h"},"text":"section 541(h) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s571"},"text":"section 571 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida7e109d7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1992-02-01"},"text":"Feb. 1, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/s1132"},"text":"section 1132 of Pub. L. 102–190","children":[],"tail":", set out as an Effective Date of 1991 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s521"},"text":"section 521 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
