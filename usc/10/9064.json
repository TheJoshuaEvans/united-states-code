{"tag":"section","attrib":{"id":"idab61a59e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9064"},"text":null,"children":[{"tag":"num","attrib":{"value":"9064"},"text":"§ 9064.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Air Force nurses: Chief; appointment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab61a59f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9064/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Position of Chief","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is a Chief of the Air Force Nurse Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab61a5a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9064/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chief","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Air Force shall appoint the Chief from the officers of the Regular Air Force designated as Air Force nurses whose regular grade is above lieutenant colonel and who are recommended by the Surgeon General. The Chief serves during the pleasure of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab61a5a1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s502/b"},"text":"Pub. L. 104–201, div. A, title V, § 502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2511"},"text":"110 Stat. 2511","children":[],"tail":", § 8069; amended "},{"tag":"ref","attrib":{"href