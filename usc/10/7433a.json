{"tag":"section","attrib":{"id":"idaaecc33b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7433a"},"text":null,"children":[{"tag":"num","attrib":{"value":"7433a"},"text":"§ 7433a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Superintendent: condition for detail to position","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaecc33c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7433a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As a condition for detail to the position of Superintendent of the Academy, an officer shall acknowledge that upon termination of that detail the officer shall be retired pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7321/a"},"text":"section 7321(a) of this title","children":[],"tail":", unless such retirement is waived under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7321/b"},"text":"section 7321(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaecc33d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7433a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum Tour of Duty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who is detailed to the position of Superintendent of the Academy shall be so detailed for a period of not less than three years. In any case in which an officer serving as Superintendent is reassigned or retires before having completed three years service as Superintendent, or otherwise leaves that position (other than due to death) without having completed three years service in that position, the Secretary of the Army shall submit to Congress notice that such officer left the position of Superintendent without having completed three years service in that position, together with a statement of the reasons why that officer did not complete three years service in that position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaecc33e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s532/a/1/B"},"text":"Pub. L. 106–65, div. A, title V, § 532(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/603"},"text":"113 Stat. 603","children":[],"tail":", § 4333a; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s541/b/1"},"text":"Pub. L. 108–375, div. A, title V, § 541(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1902"},"text":"118 Stat. 1902","children":[],"tail":"; renumbered § 7433a and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 808(c)(1), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":", 1840.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaecc33f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaecc340-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaaecc341-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s808/c/1"},"text":"Pub. L. 115–232, § 808(c)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4333a"},"text":"section 4333a of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 7321(a)” for “section 3921(a)” and “section 7321(b)” for “section 3921(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, inserted “pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3921/a"},"text":"section 3921(a) of this title","children":[],"tail":", unless such retirement is waived under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3921/b"},"text":"section 3921(b) of this title","children":[],"tail":"” before period at end, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaaecc342-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaaecc343-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attr