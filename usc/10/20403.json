{"tag":"section","attrib":{"id":"idabccea3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20403"},"text":null,"children":[{"tag":"num","attrib":{"value":"20403"},"text":"§ 20403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers: standards and qualifications for retention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabccea3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards and Qualifications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be retained in an active status, a Space Force officer must—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabccea40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20403/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any applicable yearly period, attain the number of points under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12732/a/2"},"text":"section 12732(a)(2) of this title","children":[],"tail":" that are prescribed by the Secretary of the Air Force; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabccea41-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20403/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conform to such other standards and qualifications as the Secretary may prescribe for officers of the Space Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabccea42-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Minimum Number of Points","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not prescribe a minimum of more than 50 points under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabccea43-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20403/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Result of Failure to Comply","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Space Force officer who fails to attain the number of points prescribed under subsection (a)(1), or to conform to the standards and qualifications prescribed under subsection (a)(2), may be referred to a board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20501/a"},"text":"section 20501(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabccea44-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1718/a"},"text":"Pub. L. 118–31, div. A, title XVII, § 1718(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/656"},"text":"137 Stat. 656","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
