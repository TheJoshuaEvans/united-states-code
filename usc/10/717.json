{"tag":"section","attrib":{"id":"ida804be7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s717"},"text":null,"children":[{"tag":"num","attrib":{"value":"717"},"text":"§ 717.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members of the armed forces: participation in international sports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida804be7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s717/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense, or the Secretary of Homeland Security with respect to the Coast Guard when it is not operating as a service in the Navy, may permit members of the armed forces under his jurisdiction to train for, attend, and participate in any of the following sports competitions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida804be7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s717/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Pan-American Games and the Olympic Games, and qualifying events and preparatory competition for those games.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida804be80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s717/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Paralympic Games, if eligible to participate in those games, and qualifying events and preparatory competition for those games.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida804be81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s717/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other international competition in amateur sports, if the Secretary of State determines that the interests of the United States will be served by participation in that competition, and qualifying events and preparatory competition for that competition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida804be82-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s717/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to subsections (c) and (d), the Secretary of Defense or the Secretary of Homeland Security, as the case may be, may spend such funds, and acquire and use such supplies, as he determines to be necessary to provide for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida804be83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s717/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training of members of the armed forces for the competitions covered by subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida804be84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s717/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" their attendance at and participation in those competitions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida804be85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s717/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training of animals of the armed forces for, and their attendance at and participation in, those competitions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida804be86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s717/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida804be87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s717/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than $3,000,000, to be apportioned among the military departments as the Secretary of Defense prescribes, may be spent during each successive four-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1980-10-01"},"text":"October 1, 1980","children":[],"tail":", for the participation of members of the Army, Navy, Air Force, Marine Corps, and Space Force in the competitions covered by subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida804be88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s717/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than $100,000 may be spent during each successive four-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1980-10-01"},"text":"October 1, 1980","children":[],"tail":", for the participation of members of the Coast Guard in the competitions covered by subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida804be89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s717/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appropriations available to the Department of Defense or to the Department of Homeland Security, as the case may be, may be used to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida804be8a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/17"},"text":"Pub. L. 85–861, § 1(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1442"},"text":"72 Stat. 1442","children":[],"tail":", § 716; renumbered § 717, "},{"tag":"ref","attrib":{"href":"/us/pl/87/651/tI/s103/a"},"text":"Pub. L. 87–651, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/508"},"text":"76 Stat. 508","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/348/s1/12"},"text":"Pub. L. 89–348, § 1(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1311"},"text":"79 Stat. 1311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s7"},"text":"Pub. L. 89–718, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1117"},"text":"80 Stat. 1117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s511/22"},"text":"Pub. L. 96–513, title V, § 511(22)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2921"},"text":"94 Stat. 2921","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXV/s1534"},"text":"Pub. L. 98–525, title XV, § 1534","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2632"},"text":"98 Stat. 2632","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/b/1"},"text":"Pub. L. 107–296, title XVII, § 1704(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s561"},"text":"Pub. L. 109–163, div. A, title V, § 561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3266"},"text":"119 Stat. 3266","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/1/F"},"text":"Pub. L. 116–283, div. A, title IX, § 924(b)(1)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3820"},"text":"134 Stat. 3820","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida804be8b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida804be8c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida804be8d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1958 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"716 [now 717]","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"22:1981.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"22:1982.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"22:1983.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1955-03-14/ch11"},"text":"Mar. 14, 1955, ch. 11","children":[],"tail":" (less last 2 pars.), "},{"tag":"html:a","attrib":{"href":"/us/stat/69/11"},"text":"69 Stat. 11","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the first 27 words are substituted for section 1 of the source statute. The reference to the Second Pan-American Games, the Seventh Olympic Winter Games, and the Games of the XVI Olympiad are omitted as covered by clause (1) of the revised subsection. The words “subject to the limitation contained in subsection (b) herein” are omitted as covered by revised subsection (b). The words “any other” are substituted for the words “other * * * not specified in (1) above”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “entry” is substituted for the word “commitment” for clarity. The words “or the Secretary of the Treasury, as the case may be” are inserted since, under subsection (a), the Secretary of the Treasury has the prescribed authority with respect to members of the Coast Guard when it is not operating as a service in the Navy.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “materiel, and equipment” are omitted as covered by the word “supplies” as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/26"},"text":"section 101(26) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida804be8e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1962 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This section corrects a duplication in numbering occasioned by the addition of a duplicate section 716 by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":". (The first section 716 was added by "},{"tag":"ref","attrib":{"href":"/us/pl/85/599"},"text":"Pub. L. 85–599","children":[],"tail":".)"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida804be8f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida804be90-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Marine Corps, and Space Force” for “and Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “participate in any of the following sports competitions:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The Pan-American Games and the Olympic Games, and qualifying events and preparatory competition for those games.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The Paralympic Games, if eligible to participate in those games, and qualifying events and preparatory competition for those games.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) Any other”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"for “participate in—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Pan-American Games and Olympic Games and qualifying events and preparatory competition for those games; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) any other”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsecs. (a), (b), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s1534/1"},"text":"Pub. L. 98–525, § 1534(1)","children":[],"tail":", included qualifying events and preparatory competition."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s1534/2"},"text":"Pub. L. 98–525, § 1534(2)","children":[],"tail":", included qualifying events and preparatory competition."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s1534/3"},"text":"Pub. L. 98–525, § 1534(3)","children":[],"tail":", struck out reference to subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s1534/4"},"text":"Pub. L. 98–525, § 1534(4)","children":[],"tail":", (6), designated existing provisions as par. (1), substituted “$3,000,000” for “$800,000” and “"},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"October 1, 1980","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1955-03-14"},"text":"March 14, 1955","children":[],"tail":"”, redesignated subsec. (d) as par. (2), and substituted “"},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"October 1, 1980","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1955-03-14"},"text":"March 14, 1955","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s1534/7"},"text":"Pub. L. 98–525, § 1534(7)","children":[],"tail":", redesignated subsec. (e) as (d). Former subsec. (d) redesignated par. (2) of subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s511/22/A"},"text":"Pub. L. 96–513, § 511(22)(A)","children":[],"tail":", substituted “Transportation” for “the Treasury”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s511/22"},"text":"Pub. L. 96–513, § 511(22)","children":[],"tail":", redesignated subsec. (c) as (b) and substituted reference to subsec. (c) for reference to subsec. (f), and “Transportation” for “the Treasury”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s511/22/C"},"text":"Pub. L. 96–513, § 511(22)(C)","children":[],"tail":", redesignated subsecs. (d) and (e) as (c) and (d), respectively. Former subsec. (c) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s511/22"},"text":"Pub. L. 96–513, § 511(22)","children":[],"tail":" (A), (C), redesignated subsec. (f) as (e) and substituted “Transportation” for “the Treasury”. Former subsection (e) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/718"},"text":"Pub. L. 89–718","children":[],"tail":" repealed subsec. (b) which required the Secretary of Defense or the Secretary of the Treasury to report to the Committees on Armed Services of the Senate and House of Representatives the details of the proposed participation by members of the Armed Forces under his jurisdiction in international amateur sports competition. See also "},{"tag":"ref","attrib":{"href":"/us/pl/89/348/s1/12"},"text":"Pub. L. 89–348, § 1(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1311"},"text":"79 Stat. 1311","children":[],"tail":", which earlier repealed the reporting requirement of subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/348"},"text":"Pub. L. 89–348","children":[],"tail":" repealed provision of subsec. (b) which required the Secretary of Defense or the Secretary of the Treasury, as the case may be, to report to the Committees on the Armed Services of the Senate and House of Representatives the details of the proposed participation by members of the Armed Forces under his jurisdiction in international amateur sports competition."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida804be91-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida804be92-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida804be93-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/b/3"},"text":"section 701(b)(3) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
