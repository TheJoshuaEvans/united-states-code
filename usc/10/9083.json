{"tag":"section","attrib":{"id":"idab63ef12-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9083"},"text":null,"children":[{"tag":"num","attrib":{"value":"9083"},"text":"§ 9083.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vice Chief of Space Operations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab63ef13-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9083/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is a Vice Chief of Space Operations, appointed by the President, by and with the advice and consent of the Senate, from the general officers of the Space Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab63ef14-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9083/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grade","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Vice Chief of Space Operations, while so serving, has the grade of general without vacating the permanent grade of the officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab63ef15-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9083/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Vice Chief of Space Operations shall have such authorities and duties with respect to the Space Force as the Chief of Space Operations, with the approval of the Secretary of the Air Force, may delegate to or prescribe for the Vice Chief of Space Operations. Orders issued by the Vice Chief of Space Operations in performing such duties have the same effect as orders issued by the Chief of Space Operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab63ef16-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s509C/a/2"},"text":"Pub. L. 118–159, div. A, title V, § 509C(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1873"},"text":"138 Stat. 1873","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab63ef17-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab63ef18-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab63ef19-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 9083 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9084"},"text":"section 9084 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 9083, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tIX/s912/a"},"text":"Pub. L. 107–107, div. A, title IX, § 912(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1196"},"text":"115 Stat. 1196","children":