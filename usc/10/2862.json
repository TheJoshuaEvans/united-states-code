{"tag":"section","attrib":{"id":"ida9e6780c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2862"},"text":null,"children":[{"tag":"num","attrib":{"value":"2862"},"text":"§ 2862.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Turn-key selection procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9e6780d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2862/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Use for Certain Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may use one-step turn-key selection procedures for the purpose of entering into a contract for any of the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9e6780e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2862/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The construction of an authorized military construction project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e6780f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2862/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A repair project (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2811/e"},"text":"section 2811(e) of this title","children":[],"tail":") with an approved cost equal to or less than $4,000,000."},{"tag":"ref","attrib":{"idref":"fn002097"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002097"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Temporary Expansion of Authority for Use of One-Step Turn-Key Procedures for Repair Projects note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e67810-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2862/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The construction of a facility as part of an authorized security assistance activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e67811-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2862/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9e67812-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2862/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “one-step turn-key selection procedures” means procedures used for the selection of a contractor on the basis of price and other evaluation criteria to perform, in accordance with the provisions of a firm fixed-price contract, both the design and construction of a facility using performance specifications supplied by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e67813-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2862/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “security assistance activity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9e67814-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2862/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" humanitarian and civic assistance authorized by sections 401 and 2561 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e67815-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2862/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign disaster assistance authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s404"},"text":"section 404 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e67816-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2862/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign military construction sales authorized by section 29 of the Arms Export Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2769"},"text":"22 U.S.C. 2769","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e67817-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2862/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign assistance authorized under sections 607 and 632 of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2357"},"text":"22 U.S.C. 2357","children":[],"tail":", 2392); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e67818-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2862/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other international security assistance specifically authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9e67819-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/167/tVIII/s807/a"},"text":"Pub. L. 99–167, title VIII, § 807(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-03"},"text":"Dec. 3, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/988"},"text":"99 Stat. 988","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s7/k/3"},"text":"Pub. L. 100–26, § 7(k)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/284"},"text":"101 Stat. 284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dB"},"text":"Pub. L. 100–180, div. B","children":[],"tail":", subdiv. 3, title I, § 2301, "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1214"},"text":"101 Stat. 1214","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dB/tXXVIII/s2806"},"text":"Pub. L. 101–189, div. B, title XXVIII, § 2806","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1647"},"text":"103 Stat. 1647","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dB/tXXVIII/s2802"},"text":"Pub. L. 102–190, div. B, title XXVIII, § 2802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1537"},"text":"105 Stat. 1537","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dB/tXXVIII/s2804"},"text":"Pub. L. 113–291, div. B, title XXVIII, § 2804","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3697"},"text":"128 Stat. 3697","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9e6781a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9e6781b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9e6781c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" amended section generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"Authority to Use","children":[],"tail":".—The Secretary concerned may use one-step turn-key selection procedures for the purpose of entering into contracts for the construction of authorized military construction projects."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—In this section, the term ‘one-step turn-key selection procedures’ means procedures used for the selection of a contractor on the basis of price and other evaluation criteria to perform, in accordance with the provisions of a firm fixed-price contract, both the design and construction of a facility using performance specifications supplied by the Secretary concerned.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" redesignated par. (1) of subsec. (a) as entire subsec. (a) and inserted heading, redesignated par. (2) of subsec. (a) as (b), inserted heading, and struck out former subsecs. (b) and (c) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) The Secretary of Defense, with respect to any Defense Agency, or the Secretary of a military department may not, during any fiscal year, enter into more than three contracts for military construction projects using procedures authorized by this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) The authority under this section shall expire on ","children":[{"tag":"date","attrib":{"date":"1991-10-01"},"text":"October 1, 1991","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s2806/1"},"text":"Pub. L. 101–189, § 2806(1)","children":[],"tail":", struck out at end “Such procedures may be used by the Secretary of a military department only with the approval of the Secretary of Defense.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s2806/2"},"text":"Pub. L. 101–189, § 2806(2)","children":[],"tail":", substituted “1991” for “1990”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/s2301/1"},"text":"Pub. L. 100–180, § 2301(1)","children":[],"tail":", substituted “The Secretary concerned” for “The Secretaries of the military departments, with the approval of the Secretary of Defense,” and inserted provision at end that such procedures may be used by the Secretary of a military department only with the approval of the Secretary of Defense."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/26"},"text":"Pub. L. 100–26","children":[],"tail":" inserted “the term” after “In this section,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/s2301/2"},"text":"Pub. L. 100–180, § 2301(2)","children":[],"tail":", inserted “Secretary of Defense, with respect to any Defense Agency, or the” after “The”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9e6781d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9e6781e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/167/tVIII/s807/c"},"text":"Pub. L. 99–167, title VIII, § 807(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-03"},"text":"Dec. 3, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/989"},"text":"99 Stat. 989","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/167/tVIII/s807/c"},"text":"“The amendments made by this section [enacting this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1986-10-01"},"text":"October 1, 1986","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9e8e81f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Temporary Expansion of Authority for Use of One-Step Turn-Key Procedures for Repair Projects","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dB/tXXVIII/s2806"},"text":"Pub. L. 118–31, div. B, title XXVIII, § 2806","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/745"},"text":"137 Stat. 745","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dB/tXXVIII/s2806"},"text":"“During the five-year period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":"], "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2862/a/2"},"text":"section 2862(a)(2) of title 10","children":[],"tail":", United States Code, shall be applied and administered by substituting ‘$8,000,000’ for ‘$4,000,000’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
