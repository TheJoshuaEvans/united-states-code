{"tag":"section","attrib":{"id":"idaade6be2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7233"},"text":null,"children":[{"tag":"num","attrib":{"value":"7233"},"text":"§ 7233.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of exemplary conduct","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"All commanding officers and others in authority in the Army are required—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaade6be3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7233/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to show in themselves a good example of virtue, honor, patriotism, and subordination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaade6be4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7233/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be vigilant in inspecting the conduct of all persons who are placed under their command;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaade6be5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7233/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to guard against and suppress all dissolute and immoral practices, and to correct, according to the laws and regulations of the Army, all persons who are guilty of them; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaade6be6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7233/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take all necessary and proper measures, under the laws, regulations, and customs of the Army, to promote and safeguard the morale, the physical well-being, and the general welfare of the officers and enlisted persons under their command or charge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaade6be7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tV/s507/a/1"},"text":"Pub. L. 105–85, div. A, title V, § 507(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1726"},"text":"111 Stat. 1726","children":[],"tail":", § 3583; renumbered § 7233, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/b/7"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1838"},"text":"132 Stat. 1838","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaade6be8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaade6be9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaade6bea-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 7233 to 7235 were renumbered sections 8633 to 8635 of this title, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaade6beb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3583"},"text":"section 3583 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaade6bec-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaade6bed-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
