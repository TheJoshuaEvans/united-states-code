t the requirement specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7101"},"text":"section 7101 of title 10","children":[],"tail":", United States Code, as added by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
