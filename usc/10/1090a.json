{"tag":"section","attrib":{"id":"ida887f881-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1090a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1090a"},"text":"§ 1090a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identifying and treating eating disorders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida887f882-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1090a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Identification, Treatment, and Rehabilitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense, and the Secretary of Homeland Security with respect to the Coast Guard when it is not operating as a service in the Navy, shall prescribe regulations, implement procedures using each practical and available method, and provide necessary facilities to identify, treat, and rehabilitate members of the armed forces who have an eating disorder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida887f883-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1090a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Facilities Available","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida887f884-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1090a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section, the term “necessary facilities” includes facilities that provide the services specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1079/r/1"},"text":"section 1079(r)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida887f885-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1090a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1079/r/1/B"},"text":"section 1079(r)(1)(B) of this title","children":[],"tail":", residential services shall be provided to a member pursuant to this section only if the member has a primary diagnosis of an eating disorder and treatment at such facility is medically indicated for treatment of that eating disorder."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida887f886-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1090a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eating Disorder Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “eating disorder” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1079/r"},"text":"section 1079(r) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida887f887-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVII/s701/c/1/B"},"text":"Pub. L. 117–81, div. A, title VII, § 701(c)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1778"},"text":"135 Stat. 1778","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVIII/s1801/a/13"},"text":"Pub. L. 118–31, div. A, title XVIII, § 1801(a)(13)","children":[],"tail":", "},{