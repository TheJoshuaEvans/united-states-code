{"tag":"section","attrib":{"id":"idaaf8aaa0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7553"},"text":null,"children":[{"tag":"num","attrib":{"value":"7553"},"text":"§ 7553.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Armament Retooling and Manufacturing Support Initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaf8aaa1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7553/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority for Initiative","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may carry out a program to be known as the “Armament Retooling and Manufacturing Support Initiative”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf8aaa2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7553/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the ARMS Initiative are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaf8aaa3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7553/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To encourage commercial firms, to the maximum extent practicable, to use eligible facilities for commercial purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf8aaa4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7553/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To increase the opportunities for small businesses (including socially and economically disadvantaged small business concerns and new small businesses) to use eligible facilities for those purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf8aaa5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7553/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To maintain in the United States a work force having the skills necessary to meet industrial emergency planned requirements for national security purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf8aaa6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7553/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To demonstrate innovative business practices, to support Department of Defense acquisition reform, and to serve as both a model and a laboratory for future defense conversion initiatives of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf8aaa7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7553/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the maximum extent practicable, to allow the operation of eligible facilities to be rapidly responsive to the forces of free market competition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf8aaa8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7553/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To reduce or eliminate the cost of Government ownership of eligible facilities, including the costs of operations and maintenance, the costs of environmental remediation, and other costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf8aaa9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7553/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To reduce the cost of products of the Department of Defense produced at eligible facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf8aaaa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7553/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To leverage private investment at eligible facilities through long-term facility use contracts, property management contracts, leases, or other agreements that support and advance the policies and purposes of this chapter, for the following activities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaf8aaab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7553/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recapitalization of plant and equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaf8aaac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7553/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Environmental remediation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaf8aaad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7553/b/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promotion of commercial business ventures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaf8aaae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7553/b/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other activities approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf8aaaf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7553/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To foster cooperation between the Department of the Army, property managers, commercial interests, and State and local agencies in the implementation of sustainable development strategies and investment in eligible facilities made available for purposes of the ARMS Initiative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf8aab0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7553/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To reduce or eliminate the cost of asset disposal that would be incurred if property at an eligible facility was declared excess to the needs of the Department of the Army.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf8aab1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7553/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Facilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may make any eligible facility available for the purposes of the ARMS Initiative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf8aab2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7553/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration for Leases","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s1302"},"text":"Section 1302 of title 40","children":[],"tail":" shall not apply to uses of property or facilities in accordance with the ARMS Initiative."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf8aab3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7553/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Support","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaf8aab4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7553/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds appropriated for purposes of the ARMS Initiative may be used for administrative support and management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf8aab5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7553/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A full annual accounting of such expenses for each fiscal year shall be provided to the Committee on Armed Services and the Committee on Appropriations of the Senate and the Committee on Armed Services and the Committee on Appropriations of the House of Representatives not later than March 30 of the following fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaf8aab6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title III, § 344(a)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–68, § 4553; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/178/s4/b/5"},"text":"Pub. L. 108–178, § 4(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-15"},"text":"Dec. 15, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2641"},"text":"117 Stat. 2641","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tIII/s323/d"},"text":"Pub. L. 109–163, div. A, title III, § 323(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3194"},"text":"119 Stat. 3194","children":[],"tail":"; renumbered § 7553, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/d"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaf8aab7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaf8aab8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaaf8aab9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4553"},"text":"section 4553 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" struck out “in manufacturing processes that are” after “having the skills”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/178"},"text":"Pub. L. 108–178","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s1302"},"text":"Section 1302 of title 40","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/act/1932-06-30/s321"},"text":"Section 321 of the Act of June 30, 1932","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s303b"},"text":"40 U.S.C. 303b","children":[],"tail":"),”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaaf8aaba-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaaf8aabb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" eff