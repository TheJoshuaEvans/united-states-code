g":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa7f0e38-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVIII/s804/b"},"text":"Pub. L. 108–375, div. A, title VIII, § 804(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2008"},"text":"118 Stat. 2008","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/375/dA/tVIII/s804/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2383"},"text":"Section 2383 of title 10","children":[],"tail":", United States Code [now "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4508"},"text":"10 U.S.C. 4508","children":[],"tail":"] (as added by subsection (a)), shall apply to contracts entered into on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
