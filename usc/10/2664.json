l}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “property” is substituted for the word “estate”. The words “not owned by the United States” are substituted for the words “not in Federal ownership”. The words “or shall be” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida99ee6f7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida99ee6f8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2661/c"},"text":"section 2661(c) of this title","children":[],"tail":", which was transferred to this section and redesignated subsec. (b) by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s2821/d"},"text":"Pub. L. 109–163, § 2821(d)","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dB/tXXVIII/s2821/a/1"},"text":"Pub. L. 108–375, div. B, title XXVIII, § 2821(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2129"},"text":"118 Stat. 2129","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida99ee6f9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2664, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/148"},"text":"70A Stat. 148","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s33/a/15"},"text":"Pub. L. 85–861, § 33(a)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1565"},"text":"72 Stat. 1565","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s511/90"},"text":"Pub. L. 96–513, title V, § 511(90)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2928"},"text":"94 Stat. 2928","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/31/s12/3/A"},"text":"Pub. L. 97–31, § 12(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-06"},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/153"},"text":"95 Stat. 153","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s1/32"},"text":"Pub. L. 97–295, § 1(32)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1296"},"text":"96 Stat. 1296","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s7/d/6"},"text":"Pub. L. 100–26, § 7(d)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/281"},"text":"101 Stat. 281","children":[],"tail":", related to acquisition of property for lumber production, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dB/tXXVIII/s2821/b"},"text":"Pub. L. 108–375, div. B, title XXVIII, § 2821(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2129"},"text":"118 Stat. 2129","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida99ee6fa-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" struck out “written” before “notification of the facts” and “or, if over sooner, a period of 14 days elapses from the date on which a copy of that notification is provided” before “in an electronic medium” and substituted “the end of the 14-day period beginning on” for “a period of 21 days elapses from”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":", which directed substitution “division C (except sections 3302, 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41” for “title III of the Federal Property and Administrative Services Act of 1949, as amended ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s251"},"text":"41 U.S.C. 251","children":[],"tail":" et seq.)”, was executed by making the substitution for “title III of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s251"},"text":"41 U.S.C. 251","children":[],"tail":" et seq.)” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s2821/c"},"text":"Pub. L. 109–163, § 2821(c)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2676"},"text":"section 2676 of this title","children":[],"tail":" as this section and substituted “Limitations on real property acquisition” for “Acquisition: limitation” in section catchline."}],"tail":"\n"},{"tag":"p"