{"tag":"section","attrib":{"id":"ida7a317a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343"},"text":null,"children":[{"tag":"num","attrib":{"value":"343"},"text":"§ 343.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Western Hemisphere Institute for Security Cooperation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7a317a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment and Administration","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a317a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may operate an education and training facility for the purpose set forth in subsection (b). The facility shall be known as the “Western Hemisphere Institute for Security Cooperation”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a317a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may designate the Secretary of a military department as the Department of Defense executive agent for carrying out the responsibilities of the Secretary of Defense under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a317aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of the Institute is to provide professional education and training to eligible personnel of countries of the Western Hemisphere within the context of the democratic principles set forth in the Charter of the Organization of American States (such charter being a treaty to which the United States is a party), while fostering mutual knowledge, transparency, confidence, and cooperation among the participating countries and promoting democratic values, respect for human rights, and knowledge and understanding of United States customs and traditions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a317ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a317ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (2), personnel of countries of the Western Hemisphere are eligible for education and training at the Institute as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a317ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Military personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a317ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Law enforcement personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a317af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Civilian personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a317b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of State shall be consulted in the selection of foreign personnel for education or training at the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a560a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Curriculum","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a560a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The curriculum of the Institute shall include mandatory instruction for each student, for at least 8 hours, on human rights, the rule of law, due process, civilian control of the military, and the role of the military in a democratic society.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a560a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The curriculum may include instruction and other educational and training activities on the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a560a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Leadership development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a560a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Counterdrug operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a560a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Peace support operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a560a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Disaster relief.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a560a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other matter that the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a560a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Board of Visitors","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a560aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There shall be a Board of Visitors for the Institute. The Board shall be composed of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a560ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chairman and ranking minority member of the Committee on Armed Services of the Senate, or a designee of either of them.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a560ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chairman and ranking minority member of the Committee on Armed Services of the House of Representatives, or a designee of either of them.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a560ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Six persons designated by the Secretary of Defense including, to the extent practicable, persons from academia and the religious and human rights communities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a560ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One person designated by the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a560af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The senior military officer responsible for training and doctrine for the Army or, if the Secretary of the Navy or the Secretary of the Air Force is designated as the executive agent of the Secretary of Defense under subsection (a)(2), the senior military officer responsible for training and doctrine for the Navy or Marine Corps or for the Air Force or Space Force, respectively, or a designee of the senior military officer concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a560b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The commanders of the combatant commands having geographic responsibility for the Western Hemisphere, or the designees of those officers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a560b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vacancy in a position on the Board shall be filled in the same manner as the position was originally filled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a560b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board shall meet at least once each year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a560b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a560b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board shall inquire into the curriculum, instruction, physical equipment, fiscal affairs, and academic methods of the Institute, other matters relating to the Institute that the Board decides to consider, and any other matter that the Secretary of Defense determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a560b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Board shall review the curriculum of the Institute to determine whether—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida7a560b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the curriculum complies with applicable United States laws and regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7a560b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the curriculum is consistent with United States policy goals toward Latin America and the Caribbean;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7a560b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the curriculum adheres to current United States doctrine; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7a560b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the instruction under the curriculum appropriately emphasizes the matters specified in subsection (d)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a560ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 60 days after its annual meeting, the Board shall submit to the Secretary of Defense a written report of its activities and of its views and recommendations pertaining to the Institute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a560bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Board shall not be compensated by reason of service on the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a560bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With the approval of the Secretary of Defense, the Board may accept and use the services of voluntary and uncompensated advisers appropriate to the duties of the Board without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a560bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Members of the Board and advisers whose services are accepted under paragraph (7) shall be allowed travel and transportation expenses, including per diem in lieu of subsistence, while away from their homes or regular places of business in the performance of services for the Board. Allowances under this paragraph shall be computed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a560be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of members of the Board who are officers or employees of the United States, at rates authorized for employees of agencies under subchapter I of chapter 57 of title 5; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a560bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of other members of the Board and advisers, as authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":" for employees serving without pay."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a560c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/e/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 10 of title 5, other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of title 5","children":[],"tail":" (relating to termination after two years), shall apply to the Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a560c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Accept Foreign Gifts and Donations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a560c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may, on behalf of the Institute, accept foreign gifts or donations in order to defray the costs of, or enhance the operation of, the Institute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a560c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds received by the Secretary under paragraph (1) shall be credited to appropriations available for the Department of Defense for the Institute. Funds so credited shall be merged with the appropriations to which credited and shall be available for the Institute for the same purposes and same period as the appropriations with which merged.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a560c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall notify Congress if the total amount of money accepted under paragraph (1) exceeds $1,000,000 in any fiscal year. Any such notice shall list each of the contributors of such money and the amount of each contribution in such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a560c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this subsection, a foreign gift or donation is a gift or donation of funds, materials (including research materials), property, or services (including lecture services and faculty services) from a foreign government, a foundation or other charitable organization in a foreign country, or an individual in a foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a560c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fixed Costs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The fixed costs of operating and maintaining the Institute for a fiscal year may be paid from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a560c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any funds available for that fiscal year for operation and maintenance for the executive agent designated under subsection (a)(2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a560c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if no executive agent is designated under subsection (a)(2), any funds available for that fiscal year for the Department of Defense for operation and maintenance for Defense-wide activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a560c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tuition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Tuition fees charged for persons who attend the Institute may not include the fixed costs of operating and maintaining the Institute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a560ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s343/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than March 15 of each year, the Secretary of Defense shall submit to Congress a detailed report on the activities of the Institute during the preceding year. The report shall include a copy of the latest report of the Board of Visitors received by the Secretary under subsection (e)(5), together with any comments of the Secretary on the Board’s report. The report shall be prepared in consultation with the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7a560cb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title IX, § 911(a)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–226, § 2166; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/a/16"},"text":"Pub. L. 107–107, div. A, title X, § 1048(a)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1223"},"text":"115 Stat. 1223","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tIX/s932"},"text":"Pub. L. 107–314, div. A, title IX, § 932","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2625"},"text":"116 Stat. 2625","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tIX/s956"},"text":"Pub. L. 110–181, div. A, title IX, § 956","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/296"},"text":"122 Stat. 296","children":[],"tail":"; renumbered § 343 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1241/f"},"text":"Pub. L. 114–328, div. A, title XII, § 1241(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2507"},"text":"130 Stat. 2507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/12"},"text":"Pub. L. 116–283, div. A, title IX, § 924(b)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3823"},"text":"134 Stat. 3823","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/45"},"text":"Pub. L. 117–286, § 4(a)(45)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4310"},"text":"136 Stat. 4310","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7a560cc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7a560cd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7a560ce-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (e)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5, other than "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of title 5","children":[],"tail":"” for “The Federal Advisory Committee Act (5 U.S.C. App.), other than section 14”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (e)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" inserted “or Space Force” after “for the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1241/f/1"},"text":"Pub. L. 114–328, § 1241(f)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2166"},"text":"section 2166 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1241/f/2"},"text":"Pub. L. 114–328, § 1241(f)(2)","children":[],"tail":", substituted “countries” for “nations” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (e)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" amended subpar. (F) generally. Prior to amendment, subpar. (F) read as follows: “The commander of the unified combatant command having geographic responsibility for Latin America, or a designee of that officer.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsecs. (f) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s932/a"},"text":"Pub. L. 107–314, § 932(a)","children":[],"tail":", added subsec. (f) and redesignated former subsecs. (f) and (g) as (g) and (h), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s932/a/1"},"text":"Pub. L. 107–314, § 932(a)(1)","children":[],"tail":", (b), redesignated subsec. (h) as (i) and inserted after first sentence “The report shall include a copy of the latest report of the Board of Visitors received by the Secretary under subsection (e)(5), together with any comments of the Secretary on the Board’s report.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (e)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" substituted “(5 U.S.C. App.)” for “(5 U.S.C. App. 2)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7a560cf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7a560d0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2021-12-31"},"text":"Dec. 31, 2021","children":[],"tail":", of provisions in subsec. (i) of this section requiring submittal of annual report to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1061"},"text":"section 1061 of Pub. L. 114–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s111"},"text":"section 111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
