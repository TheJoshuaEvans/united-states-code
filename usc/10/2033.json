{"tag":"section","attrib":{"id":"ida9230071-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2033"},"text":null,"children":[{"tag":"num","attrib":{"value":"2033"},"text":"§ 2033.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Instructor qualifications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9230072-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2033/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In order for a retired officer or noncommissioned officer to be employed as an instructor in the program, the officer must be certified by the Secretary of the military department concerned as a qualified instructor in leadership, wellness and fitness, civics, and other courses related to the content of the program, according to the qualifications set forth in subsection (b)(2) or (c)(2), as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9230073-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2033/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Senior Military Instructors.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9230074-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2033/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Role","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Senior military instructors shall be retired officers of the armed forces and shall serve as instructional leaders who oversee the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9230075-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2033/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A senior military instructor shall have the following qualifications:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9230076-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2033/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Professional military qualification, as determined by the Secretary of the military department concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9230077-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2033/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Award of a baccalaureate degree from an institution of higher learning.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9230078-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2033/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Completion of secondary education teaching certification requirements for the program as established by the Secretary of the military department concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9230079-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2033/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Award of an advanced certification by the Secretary of the military department concerned in core content areas based on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida923007a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2033/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accumulated points for professional activities, services to the profession, awards, and recognitions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida923007b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2033/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professional development to meet content knowledge and instructional skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida923007c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2033/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performance evaluation of competencies and standards within the program through site visits and inspections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida923007d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2033/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Non-Senior Military Instructors.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida923007e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2033/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Role","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Non-senior military instructors shall be retired noncommissioned officers of the armed forces and shall serve as instructional leaders and teach independently of, but share program responsibilities with, senior military instructors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida923007f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2033/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A non-senior military instructor shall demonstrate a depth of experience, proficiency, and expertise in coaching, mentoring, and practical arts in executing the program, and shall have the following qualifications:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9230080-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2033/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Professional military qualification, as determined by the Secretary of the military department concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9230081-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2033/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Award of an associates degree from an institution of higher learning within five years of employment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9230082-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2033/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Completion of secondary education teaching certification requirements for the program as established by the Secretary of the military department concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9230083-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2033/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Award of an advanced certification by the Secretary of the military department concerned in core content areas based on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9230084-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2033/c/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accumulated points for professional activities, services to the profession, awards, and recognitions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9230085-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2033/c/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professional development to meet content knowledge and instructional skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9230086-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2033/c/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performance evaluation of competencies and standards within the program through site visits and inspections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9230087-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s539/a"},"text":"Pub. L. 109–364, div. A, title V, § 539(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2210"},"text":"120 Stat. 2210","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9230088-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9230089-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida923008a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2033, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s547/a/1"},"text":"Pub. L. 106–65, div. A, title V, § 547(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/608"},"text":"113 Stat. 608","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 577(d)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–140, provided that certain excess amounts appropriated for the National Guard Challenge Program were to be made available for the Junior Reserve Officers’ Training Corps 