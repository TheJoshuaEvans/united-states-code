{"tag":"section","attrib":{"id":"idaae0dcc1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7282"},"text":null,"children":[{"tag":"num","attrib":{"value":"7282"},"text":"§ 7282.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medals: posthumous award and presentation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaae0dcc2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7282/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a person dies before the award of a medal of honor, distinguished-service cross, distinguished-service medal, distinguished flying cross, or device in place thereof, to which he is entitled, the award may be made and the medal or device presented to his representative, as designated by the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaae0dcc3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7282/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a person dies before an authorized service medal or device prescribed as a part thereof is presented to him under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7281"},"text":"section 7281 of this title","children":[],"tail":", it shall be presented to his family."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaae0dcc4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/217"},"text":"70A Stat. 217","children":[],"tail":", § 3752; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s33/a/23"},"text":"Pub. L. 85–861, § 33(a)(23)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","chil