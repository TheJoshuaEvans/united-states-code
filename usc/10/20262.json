{"tag":"section","attrib":{"id":"idabccea07-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20262"},"text":null,"children":[{"tag":"num","attrib":{"value":"20262"},"text":"§ 20262.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement: selective early retirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Sections 638 and 638a of this title shall apply to the retirement of officers on the Space Force officer list in the same manner as to officers of the Regular Air Force.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idabccea08-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1716/c"},"text":"Pub. L. 118–31, div. A, title XVII, § 1716(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/653"},"text":"137 Stat. 653","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
