{"tag":"section","attrib":{"id":"idab403c4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8701"},"text":null,"children":[{"tag":"num","attrib":{"value":"8701"},"text":"§ 8701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to provide for necessary salvage facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab403c50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy may provide, by contract or otherwise, necessary salvage facilities for public and private vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403c51-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination With Secretary of Homeland Security","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall submit to the Secretary of Homeland Security for comment each proposed contract for salvage facilities that affects the interests of the Department of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403c52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8701/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy may enter into a term contract under subsection (a) only if the Secretary determines that available commercial salvage facilities are inadequate to meet the requirements of national defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403c53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8701/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not enter into a contract under subsection (a) until the Secretary has provided public notice of the intent to enter into such a contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403c54-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8701/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Salvage Facilities Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “salvage facilities” includes equipment and gear utilized to prevent, abate, or minimize damage to the environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab403c55-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tX/s1015"},"text":"Pub. L. 104–106, div. A, title X, § 1015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/424"},"text":"110 Stat. 424","children":[],"tail":", § 7361; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/b/1"},"text":"Pub. L. 107–296, title XVII, § 1704(b)(1)","children":[],"tail":", (6), "},{"tag":"date","