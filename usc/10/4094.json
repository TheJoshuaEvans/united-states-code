{"tag":"section","attrib":{"id":"idaa58e860-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4094"},"text":null,"children":[{"tag":"num","attrib":{"value":"4094"},"text":"§ 4094.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced pay authority for certain research and technology positions in science and technology reinvention laboratories","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa58e861-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4094/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may carry out a program using the pay authority specified in subsection (d) to fix the rate of basic pay for positions described in subsection (c) in order to assist the military departments in attracting and retaining high quality acquisition and technology experts in positions responsible for managing and performing complex, high-cost research and technology development efforts in the science and technology reinvention laboratories of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa58e862-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4094/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The program may be carried out in a military department only with the approval of the service acquisition executive of the military department concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa58e863-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4094/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Positions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The positions described in this subsection are positions in the science and technology reinvention laboratories of the Department of Defense that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa58e864-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4094/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require expertise of an extremely high level in a scientific, technical, professional, or acquisition management field; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa58e865-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4094/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are critical to the successful accomplishment of an important research or technology development mission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa58e866-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4094/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rate of Basic Pay","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The pay authority specified in this subsection is authority as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa58e867-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4094/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Authority to fix the rate of basic pay for a position at a rate not to exceed 150 percent of the rate of basic pay payable for level I of the Executive Schedule, upon the approval of the service acquisition executive concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa58e868-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4094/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Authority to fix the rate of basic pay for a position at a rate in excess of 150 percent of the rate of basic pay payable for level I of the Executive Schedule, upon the approval of the Secretary of the military department concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa58e869-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4094/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa58e86a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4094/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority in subsection (a) may be used only to the extent necessary to competitively recruit or retain individuals exceptionally well qualified for positions described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa58e86b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4094/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Number of positions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority in subsection (a) may not be used with respect to more than five positions in each military department at any one time, unless the Under Secretary of Defense for Research and Engineering, in concurrence with the Secretaries of the military departments concerned, authorizes the transfer of positions from one military department to another.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa58e86c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4094/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term of positions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority in subsection (a) may be used only for positions having a term of less than five years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa58e86d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4094/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Science and Technology Reinvention Laboratories of the Department of Defense Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “science and technology reinvention laboratories of the Department of Defense” means the laboratories designated as science and technology reinvention laboratories by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4121/b"},"text":"section 4121(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa58e86e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tXI/s1106/a"},"text":"Pub. L. 117–263, div. A, title XI, § 1106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2817"},"text":"136 Stat. 2817","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa58e86f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa58e870-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa58e871-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 4094, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXI/s1115/a"},"text":"Pub. L. 116–283, div. A, title XI, § 1115(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3895"},"text":"134 Stat. 3895","children":[],"tail":", § 2358c; renumbered § 4094 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tII/s215/d/14"},"text":"Pub. L. 117–81, div. A, title II, § 215(d)(14)","children":[],"tail":", title XVII, § 1701(e)(3)(A), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1595"},"text":"135 Stat. 1595","children":[],"tail":", 2138, which related to enhanced pay authority for certain research and technology positions in science and technology reinvention laboratories and was substantially identical to this section, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVIII/s1801/a/32"},"text":"Pub. L. 118–31, div. A, title XVIII, § 1801(a)(32)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/685"},"text":"137 Stat. 685","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa58e872-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa58e873-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tXI/s1106/c"},"text":"Pub. L. 117–263, div. A, title XI, § 1106(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2818"},"text":"136 Stat. 2818","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tXI/s1106/c"},"text":"“This section [enacting this section] shall take effect immediately after section 881 of this Act [section 881(a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4027"},"text":"section 4027 of this title","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
