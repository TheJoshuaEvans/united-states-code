{"tag":"section","attrib":{"id":"idab44f5d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8724"},"text":null,"children":[{"tag":"num","attrib":{"value":"8724"},"text":"§ 8724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of oil reserves; contracts for conservation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab44f5d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8724/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To consolidate and protect the oil lands owned by the United States, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab44f5d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8724/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contract with owners and lessees of land inside or adjoining naval petroleum reserves for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab44f5d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8724/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conservation of oil and gas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab44f5d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8724/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation for estimated drainage in lieu of drilling or operating offset wells; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab44f5d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8724/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" acquire privately owned lands or leases inside Naval Petroleum Reserve Numbered 1 by exchange of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab44f5d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8724/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lands of the United States inside Naval Petroleum Reserve Numbered 1;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab44f5d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8724/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right to royalty production from any of the naval petroleum reserves; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab44f5d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8724/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right to any money due the United States as a result of the wrongful extraction of petroleum products from lands inside Naval Petroleum Reserve Numbered 1.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab44f5d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8724/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall report annually to Congress all agreements under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab44f5da-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":",