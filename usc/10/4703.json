{"tag":"section","attrib":{"id":"idaa8af433-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703"},"text":null,"children":[{"tag":"num","attrib":{"value":"4703"},"text":"§ 4703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Displaced contractor employees: assistance to obtain certification and employment as teachers or employment as teachers’ aides","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa8af434-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance Program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may enter into a cooperative agreement with a defense contractor in order—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa8af435-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to assist an eligible scientist or engineer employed by the contractor whose employment is terminated to obtain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa8af436-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certification or licensure as an elementary or secondary school teacher; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa8af437-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the credentials necessary to serve as a teacher’s aide; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8af438-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to facilitate the employment of the scientist or engineer by a local educational agency that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa8af439-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is receiving a grant under title I of the Elementary and Secondary Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"20 U.S.C. 6301","children":[],"tail":" et seq.) as a result of having within its jurisdiction concentrations of children from low-income families; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa8af43a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is also experiencing a shortage of teachers or teachers’ aides.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa8af43b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Defense Contractors","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa8af43c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall establish an application and selection process for the participation of defense contractors in a cooperative agreement authorized under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8af43d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall determine which defense contractors are eligible to participate in the placement program on the basis of applications submitted under subsection (c). The Secretary shall limit participation to those defense contractors or subcontractors that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa8af43e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produce goods or services for the Department of Defense pursuant to a defense contract or operate nuclear weapons manufacturing facilities for the Department of Energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa8af43f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have recently reduced operations, or are likely to reduce operations, due to the completion or termination of a defense contract or program or by reductions in defense spending.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8af440-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall give special consideration to defense contractors who are located in areas that have been hit particularly hard by reductions in defense spending.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa8af441-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defense Contractor Applications","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa8af442-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A defense contractor desiring to enter into a cooperative agreement with the Secretary of Defense under subsection (a) shall submit an application to the Secretary containing the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa8af443-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evidence that the contractor has been, or is expected to be, adversely affected by the completion or termination of a defense contract or program or by reductions in defense spending.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa8af444-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An explanation that scientists and engineers employed by the contractor have been terminated, laid off, or retired, or are likely to be terminated, laid off, or retired, as a result of the completion or termination of a defense contract or program or reductions in defense spending.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa8af445-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of programs implemented or proposed by the contractor to assist these scientists and engineers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa8af446-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A commitment to help fund the costs associated with the placement program by paying 50 percent of the stipend provided under subsection (g) to an employee or former employee of the contractor selected to receive assistance under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8af447-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Once a cooperative agreement is entered into under subsection (a) between the Secretary and the defense contractor, the contractor shall publicize the program and distribute applications to prospective participants, and assist the prospective participants with the State screening process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa8af448-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Scientists and Engineers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual shall be eligible for selection by the Secretary of Defense to receive assistance under this section if the individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa8af449-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is employed or has been employed for not less than five years as a scientist or engineer with a private defense contractor that has entered into an agreement under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8af44a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has received—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa8af44b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an individual applying for assistance for placement as an elementary or secondary school teacher, a baccalaureate or advanced degree from an accredited institution of higher education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa8af44c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an individual applying for assistance for placement as a teacher’s aide in an elementary or secondary school, an associate, baccalaureate, or advanced degree from an accredited institution of higher education or a junior or community college; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8af44d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been terminated or laid off (or received notice of termination or lay off) as a result of the completion or termination of a defense contract or program or reductions in defense spending; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8af44e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfies such other criteria for selection as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa8af44f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection of Participants","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa8af450-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In selecting participants to receive assistance for placement as elementary or secondary school teachers, the Secretary shall give priority to individuals who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa8af451-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have educational, military, or employment experience in science, mathematics, or engineering and agree to seek employment as science, mathematics, or engineering teachers in elementary or secondary schools; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa8af452-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have educational, military, or employment experience in another subject area identified by the Secretary, in consultation with the Secretary of Education, as important for national educational objectives and agree to seek employment in that subject area in elementary or secondary schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8af453-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not select an individual under this section unless the Secretary has sufficient appropriations to carry out this section available at the time of the selection to satisfy the obligations to be incurred by the United States under this section with respect to that individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa8af454-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual selected under this section shall be required to enter into an agreement with the Secretary in which the participant agrees—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa8af455-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain, within such time as the Secretary may require, certification or licensure as an elementary or secondary school teacher or the necessary credentials to serve as a teacher’s aide in an elementary or secondary school; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8af456-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to accept—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa8af457-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an individual selected for assistance for placement as a teacher, an offer of full-time employment as an elementary or secondary school teacher for not less than two school years with a local educational agency identified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1151/b/2"},"text":"section 1151(b)(2) of this title","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"1999-10-04"},"text":"October 4, 1999","children":[],"tail":", to begin the school year after obtaining that certification or licensure; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa8af458-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an individual selected for assistance for placement as a teacher’s aide, an offer of full-time employment as a teacher’s aide in an elementary or secondary school for not less than two school years with a local educational agency identified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1151/b/3"},"text":"section 1151(b)(3) of this title","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"1999-10-04"},"text":"October 4, 1999","children":[],"tail":", to begin the school year after obtaining the necessary credentials."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa8af459-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Stipend for Participants","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa8af45a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense shall pay to each participant in the placement program a stipend in an amount equal to the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa8af45b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa8af45c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total costs of the type described in paragraphs (1), (2), (3), (8), and (9) ","children":[{"tag":"ref","attrib":{"idref":"fn002122"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002122"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of section 472 of the Higher Education Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087"},"text":"20 U.S.C. 1087","children":[],"tail":null},{"tag":"i","attrib":{},"text":"ll","children":[],"tail":") incurred by the participant while obtaining teacher certification or licensure or the necessary credentials to serve as a teacher’s aide and employment as an elementary or secondary school teacher or teacher aide."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8af45d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A stipend provided under this section shall be taken into account in determining the eligibility of the participant for Federal student financial assistance provided under title IV of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070"},"text":"20 U.S.C. 1070","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa8af45e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4703/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Placement of Participants as Teachers and Teachers’ Aides","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsections (h) through (k) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1151"},"text":"section 1151 of this title","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"1999-10-04"},"text":"October 4, 1999","children":[],"tail":", shall apply with respect to the placement as teachers and teachers’ aides of individuals selected under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa8af45f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dD/tXLIV/s4443/a"},"text":"Pub. L. 102–484, div. D, title XLIV, § 4443(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2732"},"text":"106 Stat. 2732","children":[],"tail":", § 2410c; renumbered § 2410j and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/35/tII/s201/b/1/A"},"text":"Pub. L. 103–35, title II, § 201(b)(1)(A)","children":[],"tail":", (g)(6), "},{"tag":"date","attrib":{"date":"1993-05-31"},"text":"May 31, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/97"},"text":"107 Stat. 97","children":[],"tail":", 100; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tXIII/s1331/c/3"},"text":"Pub. L. 103–160, div. A, title XIII, § 1331(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1792"},"text":"107 Stat. 1792","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s391/b/5"},"text":"Pub. L. 103–382, title III, § 391(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4022"},"text":"108 Stat. 4022","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1503/a/23"},"text":"Pub. L. 104–106, div. A, title XV, § 1503(a)(23)","children":[],"tail":", "},{"tag":"date","att