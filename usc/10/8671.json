{"tag":"section","attrib":{"id":"idab3b7f8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8671"},"text":null,"children":[{"tag":"num","attrib":{"value":"8671"},"text":"§ 8671.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of vessel delivery dates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab3b7f8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8671/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The delivery of a covered vessel shall be deemed to occur on the date on which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab3b7f8f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8671/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Navy determines that the vessel is assembled and complete; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab3b7f90-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8671/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" custody of the vessel and all systems contained in the vessel transfers to the Navy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab3b7f91-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8671/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion in Budget and Acquisition Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The delivery dates of covered vessels shall be included—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab3b7f92-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8671/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the materials submitted to Congress by the Secretary of Defense in support of the budget of the President for each fiscal year (as submitted to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", United States Code); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab3b7f93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8671/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any relevant Selected Acquisition Report submitted to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4351"},"text":"section 4351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab3b7f94-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8671/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Listing as Battle Force Ship in Naval Vessel Register","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A covered vessel may not be listed in the Naval Vessel Register or other fleet inventory measures as a battle force ship until the delivery date specified in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab3b7f95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8671/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab3b7f96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8671/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered vessel” means any vessel of the Navy that is under construction or constructed using amounts authorized to be appropriated for the Department of Defense for shipbuilding and conversion, Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab3b7f97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8671/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “battle force ship” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab3b7f98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8671/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A commissioned United States Ship warship capable of contributing to combat operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab3b7f99-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8671/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A United States Naval Ship that contributes directly to Navy warfighting or support missions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab3b7f9a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tI/s121/a/1"},"text":"Pub. L. 114–328, div. A, title I, § 121(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2029"},"text":"130 Stat. 2029","children":[],"tail":", § 7301; renumbered § 8671 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/2"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(2)","children":[],"tail":", title X, § 1014, "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":", 1948; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1849/f"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1849(f)","children":[],"tail":", formerly § 1849(m), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4264"},"text":"134 Stat. 4264","children":[],"tail":", renumbered § 1849(f) and amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(5)(B), (6)(D), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2147"},"text":"135 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab3b7f9b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab3b7f9c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab3b7f9d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1849/f"},"text":"Pub. L. 116–283, § 1849(f)","children":[],"tail":", formerly § 1849(m), as renumbered and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701"},"text":"Pub. L. 117–81, § 1701","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(5)(B), (6)(D), substituted “section 4351” for “section 2432”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s807/d/2"},"text":"Pub. L. 115–232, § 807(d)(2)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7301"},"text":"section 7301 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1014/a/2"},"text":"Pub. L. 115–232, § 1014(a)(2)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1014/b"},"text":"Pub. L. 115–232, § 1014(b)","children":[],"tail":", added subsec. (d) and struck out former subsec. (d). Prior to amendment, text read as follows: “In this section, the term ‘covered vessel’ means any vessel of the Navy that is under construction on or after the date of the enactment of this section using amounts authorized to be appropriated for the Department of Defense for shipbuilding and conversion, Navy.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1014/a/1"},"text":"Pub. L. 115–232, § 1014(a)(1)","children":[],"tail":", redesignated subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab3b7f9e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab3b7f9f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" applicable as if included in the enactment of title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" as enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/a/2"},"text":"section 1701(a)(2) of Pub. L. 117–81","children":[],"tail":", set out in a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":" and note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab3b7fa0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s807/d/2"},"text":"section 807(d)(2) of Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab3b7fa1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Certification","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tI/s121/b"},"text":"Pub. L. 114–328, div. A, title I, § 121(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2030"},"text":"130 Stat. 2030","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/328/dA/tI/s121/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2017-01-01"},"text":"January 1, 2017","children":[],"tail":", the Secretary of the Navy shall certify to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] that the delivery dates of the following vessels have been adjusted in accordance with section 7301 [now 8671] of title 10, United States Code, as added by subsection (a):"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The U.S.S. John F. Kennedy (CVN–79).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The U.S.S. Zumwalt (DDG–1000).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The U.S.S. Michael Monsoor (DDG–1001).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The U.S.S. Lyndon B. Johnson (DDG–1002).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other vessel of the Navy that is under construction on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The certification under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of each vessel for which the delivery date was adjusted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the delivery date of each such vessel, as so adjusted.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
