{"tag":"section","attrib":{"id":"idab8a153e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10102a"},"text":null,"children":[{"tag":"num","attrib":{"value":"10102a"},"text":"§ 10102a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deployment prioritization and readiness of Army components","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab8a153f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10102a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deployment Prioritization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army shall maintain a system for identifying the priority of deployment for units of all components of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8a1540-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10102a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deployability Readiness Rating","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Army shall maintain a readiness rating system for units of all components of the Army that provides an accurate assessment of the deployability of a unit and those shortfalls of a unit that require the provision of additional resources. The system shall ensure—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8a1541-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10102a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that the personnel readiness rating of a unit reflects—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab8a1542-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10102a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" both the percentage of the overall personnel requirement of the unit that is manned and deployable and the fill and deployability rate for critical occupational specialties necessary for the unit to carry out its basic mission requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8a1543-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10102a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of personnel in the unit who are qualified in their primary military occupational specialty; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8a1544-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10102a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that the equipment readiness assessment of a unit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab8a1545-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10102a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documents all equipment required for deployment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8a1546-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10102a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflects only that equipment that is directly possessed by the unit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8a1547-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10102a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifies the effect of substitute items; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8a1548-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10102a/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assesses the effect of missing components and sets on the readiness of major equipment items.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab8a1549-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tIII/s321/a/1"},"text":"Pub. L. 114–328, div. A, title III, § 321(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2074"},"text":"130 Stat. 2074","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
