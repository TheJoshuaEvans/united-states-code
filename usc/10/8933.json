{"tag":"section","attrib":{"id":"idab55bec2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8933"},"text":null,"children":[{"tag":"num","attrib":{"value":"8933"},"text":"§ 8933.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ocean Research Advisory Panel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab55bec3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8933/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab55bec4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8933/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Ocean Policy Committee shall establish an Ocean Research Advisory Panel (in this section referred to as the “Advisory Panel”). The Advisory Panel shall consist of not fewer than 10 and not more than 18 members appointed by the co-chairs of the Committee, including each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab55bec5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8933/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members who represent the National Academies of Sciences, Engineering, and Medicine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55bec6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8933/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members selected from among individuals who represent the views of ocean industries, State, tribal, territorial or local governments, academia, and such other views as the co-chairs consider appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab55bec7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8933/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members selected from among individuals eminent in the fields of marine science, marine technology, and marine policy, or related fields.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab55bec8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8933/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee shall ensure that an appropriate balance of academic, scientific, industry, and geographical interests and gender and racial diversity are represented by the members of the Advisory Panel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab55bec9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8933/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall assign the following responsibilities to the Advisory Panel:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab55beca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8933/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To advise the Committee on policies and procedures to implement the National Oceanographic Partnership Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab55becb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8933/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To advise the Committee on matters relating to national oceanographic science, engineering, facilities, or resource requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab55becc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8933/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To advise the Committee on improving diversity, equity, and inclusion in the ocean sciences and related fields.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab55becd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8933/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To advise the Committee on national ocean research priorities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab55bece-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8933/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any additional responsibilities that the Committee considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab55becf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8933/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall require the Advisory Panel to meet not less frequently than two times each year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab55bed0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8933/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative and Technical Support","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the National Oceanic and Atmospheric Administration shall provide to the Advisory Panel such administrative and technical support as the Advisory Panel may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab55bed1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8933/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 14 of the Federal Advisory Committee Act (5 U.S.C. App.),","children":[{"tag":"ref","attrib":{"idref":"fn002165"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002165"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" the Advisory Panel shall terminate on "},{"tag":"date","attrib":{"date":"2040-01-01"},"text":"January 1, 2040","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab55bed2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tII/s282/a/1"},"text":"Pub. L. 104–201, div. A, title II, § 282(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2473"},"text":"110 Stat. 2473","children":[],"tail":", § 7903; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tII/s241/b/1"},"text":"Pub. L. 105–85, div. A, title II, § 241(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1666"},"text":"111 Stat. 1666","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tX/s1084"},"text":"Pub. L. 114–92, div. A, title X, § 1084","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1004"},"text":"129 Stat. 1004","children":[],"tail":"; renumbered § 8933, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/14"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tX/s1055/c"},"text":"Pub. L. 116–283, div. A, title X, § 1055(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3854"},"text":"134 Stat. 3854","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab55bed3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"referencesInText","id":"idab55bed4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 14 of the Federal Advisory Committee Act, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/463/s14"},"text":"section 14 of Pub. L. 92–463","children":[],"tail":", which was set out in the Appendix to Title 5, Government Organization and Employees, and was repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of Title 5","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(a), 7, "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4204"},"text":"136 Stat. 4204","children":[],"tail":", 4361."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab55bed5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab55bed6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" amended section generally. Prior to amendment, section related to establishment, membership, and responsibilities of Ocean Research Advisory Panel."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7903"},"text":"section 7903 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" struck out subsec. (c). Text read as follows: “The Secretary of the Navy annually shall make funds available to support the activities of the Advisory Panel.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—The Council shall establish an Ocean Research Advisory Panel consisting of not less than 10 and not more than 18 members appointed by the Council from among persons eminent in the fields of marine science or marine policy, or related fields, and who are representative, at a minimum, of the interests of government, academia, and industry."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—The Council shall assign to the Advisory Panel responsibilities that the Council considers appropriate.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab55bed7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab55bed8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab55bed9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" effective as of "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s282"},"text":"section 282 of Pub. L. 104–201","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/s241/d"},"text":"section 241(d) of Pub. L. 105–85","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7902"},"text":"section 7902 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab55beda-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Initial Appointments of Panel Members","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tII/s282/b"},"text":"Pub. L. 104–201, div. A, title II, § 282(b)","children":[],"tail":", formerly § 282(c), "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2473"},"text":"110 Stat. 2473","children":[],"tail":", as renumbered and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tII/s241/b/2"},"text":"Pub. L. 105–85, div. A, title II, § 241(b)(2)","children":[],"tail":", (c)(2), "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1666"},"text":"111 Stat. 1666","children":[],"tail":", provided that the National Ocean Research Leadership Council established by "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8932"},"text":"10 U.S.C. 8932","children":[],"tail":" was to make the appointments required by this section not later than "},{"tag":"date","attrib":{"date":"1998-01-01"},"text":"Jan. 1, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
