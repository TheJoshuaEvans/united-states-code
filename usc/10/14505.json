{"tag":"section","attrib":{"id":"idabb766e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14505"},"text":null,"children":[{"tag":"num","attrib":{"value":"14505"},"text":"§ 14505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of failure of selection for promotion: reserve captains of the Army, Air Force, and Marine Corps and reserve lieutenants of the Navy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Unless retained as provided in section 12646 or 12686 of this title, a captain on the reserve active-status list of the Army, Air Force, or Marine Corps or a lieutenant on the reserve active-status list of the Navy who has failed of selection for promotion to the next higher grade for the second time and whose name is not on a list of officers recommended for promotion to the next higher grade and who has not been selected for continuation on the reserve active-status list under section 14701 or 14701a of this title, shall be separated in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14513"},"text":"section 14513 of this title","children":[],"tail":" not later than the first day of the seventh month after the month in which the Secretary concerned releases the promotion results of the board which considered the officer for the second time to the public."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idabb766e9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2950"},"text":"108 Stat. 2950","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV"},"text":"Pub. L. 118–159, div. A, title V","children":[],"tail":", §§ 505(b)(5), 513(c)(2), "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1870"},"text":"138 Stat. 1870","children":[],"tail":", 1876.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb766ea-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabb766eb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabb766ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s513/c/2"},"text":"Pub. L. 118–159, § 513(c)(2)","children":[],"tail":", inserted “or 14701a” after “14701”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s505/b/5"},"text":"Pub. L. 118–159, § 505(b)(5)","children":[],"tail":", substituted “the Secretary concerned releases the promotion results of the board which considered the officer for the second time to the public” for “the President approves the report of the board which considered the officer for the second time”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabb766ed-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabb766ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691/b/1"},"text":"section 1691(b)(1) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
