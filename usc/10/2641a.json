{"tag":"section","attrib":{"id":"ida9957181-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2641a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2641a"},"text":"§ 2641a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation of American Samoa veterans on Department of Defense aircraft for certain medical care in Hawaii","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9957182-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2641a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may provide transportation on Department of Defense aircraft for the purpose of transporting any veteran specified in subsection (b) between American Samoa and the State of Hawaii if such transportation is required in order to provide hospital care to such veteran as described in that subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9957183-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2641a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Veterans Eligible for Transport","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A veteran eligible for transport under subsection (a) is any veteran who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9957184-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2641a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resides in and is located in American Samoa; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9957185-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2641a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as determined by an official of the Department of Veterans Affairs designated for that purpose by the Secretary of Veterans Affairs, must be transported to the State of Hawaii in order to receive hospital care to which such veteran is entitled under chapter 17 of title 38 in facilities of such Department in the State of Hawaii.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9957186-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2641a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9957187-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2641a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation may be provided to veterans under this section only on a space-available basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9957188-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2641a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A charge may not be imposed on a veteran for transportation provided to the veteran under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9957189-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/262/tVIII/s8121/a"},"text":"Pub. L. 105–262, title VIII, § 8121(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2332"},"text":"112 Stat. 2332","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1066/a/24"},"text":"Pub. L. 106–65, div. A, title X, § 1066(a)(24)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/771"},"text":"113 Stat. 771","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida995718a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida995718b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida995718c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s1066/a/24/A"},"text":"Pub. L. 106–65, § 1066(a)(24)(A)","children":[],"tail":", struck out “, United States Code,” after “title 38”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s1066/a/24/B"},"text":"Pub. L. 106–65, § 1066(a)(24)(B)","children":[],"tail":", struck out heading and text of subsec. (d). Text read as follows: “In this section:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The term ‘veteran’ has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101/2"},"text":"section 101(2) of title 38","children":[],"tail":", United States Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The term ‘hospital care’ has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1701/5"},"text":"section 1701(5) of title 38","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
