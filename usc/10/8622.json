{"tag":"section","attrib":{"id":"idab369e0f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8622"},"text":null,"children":[{"tag":"num","attrib":{"value":"8622"},"text":"§ 8622.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Naval Historical Center Fund: references to Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any reference in a law, regulation, document, paper, or other record of the United States to the Naval Historical Center Fund formerly maintained under this section shall be deemed to refer to the Department of the Navy General Gift Fund maintained under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2601"},"text":"section 2601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab369e10-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/446"},"text":"70A Stat. 446","children":[],"tail":", § 7222; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tX/s1073/b/1"},"text":"Pub. L. 104–201, div. A, title X, § 1073(b)(1)","children":[],"tail":", (2)(A), "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2657"},"text":"110 Stat. 2657","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title IX, § 942(d)(2)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–242; renumbered § 8622, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab369e11-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab369e12-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab369e13-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7222","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s419b"},"text":"5 U.S.C. 419b","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1937-03-04/ch26"},"text":"Mar. 4, 1937, ch. 26","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/50/25"},"text":"50 Stat. 25","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the word “receive” and the words “from individuals or others” and “of the United States” are omitted as surplusage. The title of the “Office of Naval Records and Library, Navy Department” is changed to “Office of Naval Records and History”, in accordance with a directive of the Secretary of the Navy dated ","children":[{"tag":"date","attrib":{"date":"1949-03-10"},"text":"March 10, 1949","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is rewritten for clarity and to conform to a similar statement appearing in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s150s"},"text":"5 U.S.C. 150s","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab369e14-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab369e15-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7222"},"text":"section 7222 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" amended section catchline and text generally. Prior to amendment, section related to acceptance and administration of gifts, bequests, and loans for the benefit of the Naval Historical Center."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1073/b/2/A"},"text":"Pub. L. 104–201, § 1073(b)(2)(A)","children":[],"tail":", substituted “Naval Historical Center Fund” for “Office of Naval Records and History gift fund” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1073/b/1"},"text":"Pub. L. 104–201, § 1073(b)(1)","children":[],"tail":", substituted “Naval Historical Center” for “Office of Naval Records and History” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab369e16-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab369e17-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab369e18-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Merger of Naval Historical Center Fund Into Department of the Navy General Gift Fund","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title IX, § 942(a)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–241, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/398/s1/dA"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy shall transfer all amounts in the Naval Historical Center Fund maintained under section 7222 [now 8622] of title 10, United States Code, to the Department of the Navy General Gift Fund maintained under section 2601 of such title. Upon completing the transfer, the Secretary shall close the Naval Historical Center Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts transferred to the Department of the Navy General Gift Fund under this subsection shall be merged with other amounts in that Fund and shall be available for the purposes for which amounts in that Fund are available.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
