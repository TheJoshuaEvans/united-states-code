{"tag":"section","attrib":{"id":"ida931310f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2156"},"text":null,"children":[{"tag":"num","attrib":{"value":"2156"},"text":"§ 2156.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint Forces Staff College: duration of principal course of instruction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9313110-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2156/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The duration of the principal course of instruction offered at the Joint Forces Staff College may not be less than 10 weeks of resident instruction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9313111-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2156/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “principal course of instruction” means any course of instruction offered at the Joint Forces Staff College as Phase II joint professional military education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9313112-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s532/a/2"},"text":"Pub. L. 108–375, div. A, title V, § 532(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1900"},"text":"118 Stat. 1900","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
