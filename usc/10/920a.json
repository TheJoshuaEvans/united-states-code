{"tag":"section","attrib":{"id":"ida82d5573-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s920a"},"text":null,"children":[{"tag":"num","attrib":{"value":"920a"},"text":"§ 920a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 120a. Mails: deposit of obscene matter","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person subject to this chapter who, wrongfully and knowingly, deposits obscene matter for mailing and delivery shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida82d5574-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLX/s5431"},"text":"Pub. L. 114–328, div. E, title LX, § 5431","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2951"},"text":"130 Stat. 2951","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida82d5575-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida82d5576-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida82d5577-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 920a was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s930"},"text":"section 930 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida82d5578-3a6f-1