{"tag":"section","attrib":{"id":"idaad01473-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6352"},"text":null,"children":[{"tag":"num","attrib":{"value":"6352"},"text":"§ 6352.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Engineering and manufacturing research, development, and demonstration by managers of certain nuclear weapons production facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaad01474-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6352/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority for Programs at Nuclear Weapons Productions Facilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall authorize the head of each nuclear weapons production facility to establish an Engineering and Manufacturing Research, Development, and Demonstration Program under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad01475-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6352/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Projects and Activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The projects and activities carried out through the program at a nuclear weapons production facility under this section shall support innovative or high-risk design and manufacturing concepts and technologies with potentially high payoff for the nuclear security enterprise. Those projects and activities may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad01476-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6352/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" replacement of obsolete or aging design and manufacturing technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad01477-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6352/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of innovative agile manufacturing techniques and processes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad01478-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6352/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training, recruitment, or retention of essential personnel in critical engineering and manufacturing disciplines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad01479-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1454"},"text":"139 Stat. 1454","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaad0147a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaad0147b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaad0147c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2812"},"text":"section 2812 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
