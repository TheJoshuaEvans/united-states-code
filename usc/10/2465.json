{"tag":"section","attrib":{"id":"ida97d7be2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2465"},"text":null,"children":[{"tag":"num","attrib":{"value":"2465"},"text":"§ 2465.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on contracts for performance of firefighting or security-guard functions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida97d7be3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2465/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b), funds appropriated to the Department of Defense may not be obligated or expended for the purpose of entering into a contract for the performance of firefighting or security-guard functions at any military installation or facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida97d7be4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2465/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The prohibition in subsection (a) does not apply to the following contracts:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida97d7be5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2465/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contract to be carried out at a location outside the United States (including its commonwealths, territories, and possessions) at which members of the armed forces would have to be used for the performance of a function described in subsection (a) at the expense of unit readiness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida97d7be6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2465/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contract to be carried out on a Government-owned but privately operated installation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida97d7be7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2465/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contract (or the renewal of a contract) for the performance of a function under contract on ","children":[{"tag":"date","attrib":{"date":"1983-09-24"},"text":"September 24, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida97d7be8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2465/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A contract that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida97d7be9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2465/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a period of one year or less; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida97d7bea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2465/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covers the performance of functions that, in the absence of the contract, would have to be performed by members of the armed forces who are not readily available to perform such functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida97d7beb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tXII/s1222/a/1"},"text":"Pub. L. 99–661, div. A, title XII, § 1222(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3976"},"text":"100 Stat. 3976","children":[],"tail":", § 2693; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tXI/s1112/a"},"text":"Pub. L. 100–180, div. A, title XI, § 1112(a)","children":[],"tail":"–(b)(2), "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1147"},"text":"101 Stat. 1147","children":[],"tail":"; renumbered § 2465, "},{"tag":"ref","attrib":{"href":"/us/pl/100/370/s2/b/1"},"text":"Pub. L. 100–370, § 2(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-07-19"},"text":"July 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/854"},"text":"102 Stat. 854","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1503/a/25"},"text":"Pub. L. 104–106, div. A, title XV, § 1503(a)(25)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/512"},"text":"110 Stat. 512","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tIII/s331"},"text":"Pub. L. 108–136, div. A, title III, § 331","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1442"},"text":"117 Stat. 1442","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tIII/s335"},"text":"Pub. L. 119–60, div. A, title III, § 335","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/818"},"text":"139 Stat. 818","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida97d7bec-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida97d7bed-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida97d7bee-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s335/1"},"text":"Pub. L. 119–60, § 335(1)","children":[],"tail":", substituted “that” for “for the performance of firefighting functions if the contract” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s335/2"},"text":"Pub. L. 119–60, § 335(2)","children":[],"tail":", struck out “only” before “the performance”, “firefighting” before “functions that,”, and “by reason of a deployment” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" substituted “apply to the following contracts:” for “apply—” in introductory provisions, “A” for “to a” at beginning of pars. (1) to (3), period for semicolon at end of par. (1), and period for “; or” at end of par. (2), and added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" substituted “under contract on "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"September 24, 1983","children":[],"tail":"” for “under contract or "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"September 24, 1983","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/370"},"text":"Pub. L. 100–370","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2693"},"text":"section 2693 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180"},"text":"Pub. L. 100–180","children":[],"tail":" inserted “or security-guard” before “functions” in section catchline and subsec. (a), and substituted “a function” for “the function” in subsec. (b)(1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida97d7bef-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida97d7bf0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Temporary Authority To Contract With Local and State Governments for Performance of Security Functions at United States Military Installations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/tX/s1010"},"text":"Pub. L. 107–56, title X, § 1010","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/395"},"text":"115 Stat. 395","children":[],"tail":", which provided authority, during Operation Enduring Freedom and the subsequent 180 days, to use defense funds to contract with local and state governments to perform security functions at military installations, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s812/b/53"},"text":"Pub. L. 115–232, div. A, title VIII, § 812(b)(53)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1850"},"text":"132 Stat. 1850","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida97d7bf1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Performance of Emergency Response Functions at Chemical Weapons Storage Installations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title III, § 355], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–75, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/398/s1/dA"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restriction on Conversion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army may not convert to contractor performance the emergency response functions of any chemical weapons storage installation that, as of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":"], are performed for that installation by employees of the United States until the certification required by subsection (c) has been submitted in accordance with that subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Installations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purposes of this section, a chemical weapons storage installation is any installation of the Department of Defense on which lethal chemical agents or munitions are stored.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Army shall certify in writing to the Committee on Armed Services of the Senate and the Committee on Armed Services of the House of Representatives that, to ensure that there will be no lapse of capability to perform the chemical weapon emergency response mission at a chemical weapons storage installation during any transition to contractor performance of those functions at the installation, the plan for conversion of the performance of those functions—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with the recommendation contained in General Accounting Office [now Government Accountability Office] Report NSIAD–00–88, entitled ‘DoD Competitive Sourcing’, dated March 2000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for a transition to contractor performance of emergency response functions which ensures an adequate transfer of the relevant knowledge and expertise regarding chemical weapon emergency response to the contractor personnel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2465"},"text":"section 2465 of title 10","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
