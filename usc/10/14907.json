{"tag":"section","attrib":{"id":"idabb9d834-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14907"},"text":null,"children":[{"tag":"num","attrib":{"value":"14907"},"text":"§ 14907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Army National Guard of the United States and Air National Guard of the United States: discharge and withdrawal of Federal recognition of officers absent without leave","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabb9d835-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14907/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Withdraw Federal Recognition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an officer of the Army National Guard of the United States or the Air National Guard of the United States has been absent without leave for three months, the Secretary of the Army or the Secretary of the Air Force, as appropriate, may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb9d836-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14907/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminate the reserve appointment of the officer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb9d837-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14907/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withdraw the officer’s Federal recognition as an officer of the National Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb9d838-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14907/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discharge From Reserve Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer of the Army National Guard of the United States or the Air National Guard of the United States whose Federal recognition as an officer of the National Guard is withdrawn under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s323/b"},"text":"section 323(b) of title 32","children":[],"tail":" shall be discharged from the officer’s appointment as a reserve officer of the Army or the Air Force, as the case may be."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabb9d839-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2960"},"text":"108 Stat. 2960","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb9d83a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabb9d83b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idabb9d83c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 3820(a), (b) and 8820 of this title, prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1629/a/2"},"text":"Pub. L. 103–337, § 1629(a)(2)","children":[],"tail":", (c)(2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabb9d83d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabb9d83e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691/b/1"},"text":"section 1691(b)(1) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
