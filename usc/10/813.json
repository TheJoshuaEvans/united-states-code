{"tag":"section","attrib":{"id":"ida81316e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s813"},"text":null,"children":[{"tag":"num","attrib":{"value":"813"},"text":"§ 813.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 13. Punishment prohibited before trial","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No person, while being held for trial, may be subjected to punishment or penalty other than arrest or confinement upon the charges pending against him, nor shall the arrest or confinement imposed upon him be any more rigorous than the circumstances require to insure his presence, but he may be subjected to minor punishment during that period for infractions of discipline.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida81316e8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/41"},"text":"70A Stat. 41","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/81/s3"},"text":"Pub. L. 97–81, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-11-20"},"text":"Nov. 20, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1087"},"text":"95 Stat. 1087","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida81316e9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida81316ea-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida81316eb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":