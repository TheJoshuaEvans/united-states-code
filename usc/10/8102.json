hildren":[{"tag":"html:a","attrib":{"href":"/us/act/1947-08-07/ch512/s430"},"text":"Aug. 7, 1947, ch. 512, § 430","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/61/881"},"text":"61 Stat. 881","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1954-09-03/ch1257/s702/a"},"text":"Sept. 3, 1954, ch. 1257, § 702(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/68/1188"},"text":"68 Stat. 1188","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words “In addition * * * to the number of rear admirals and above authorized by titles I, II, and III and by section 413 of this Act, a total of” are omitted as surplusage. Titles I, II, and III, and section 413 of the Officer Personnel Act of 1947 prescribe the number of officers on the lineal list who may have the grade of rear admiral. Retired officers are excluded from the lineal lists and are not counted for any purpose in the computations under the cited titles and section. The source text does not affect the authorized numbers so computed; it sets up an authorized number for a category of officers not previously covered.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The limitation on reserve flag officers on active duty contained in section 430 of the Officer Personnel Act of 1947 was repealed by section 702(a) of the Reserve Officer Personnel Act of 1954.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab10783c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab10783d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s5450"},"text":"section 5450 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" struck out designation “(a)” before “Except in time of war or national emergency”, substituted “flag officers of the Regular Navy” for “officers of the Regular Navy in the grade of rear admiral and above”, and struck out subsec. (b) which provided that this section did not apply to fleet admirals or to retired officers ordered to temporary duty to serve on boards convened under chapter 543 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab10783e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab10783f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href"