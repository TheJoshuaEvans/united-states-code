{"tag":"section","attrib":{"id":"idab107837-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8102"},"text":null,"children":[{"tag":"num","attrib":{"value":"8102"},"text":"§ 8102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regular Navy: retired flag officers on active duty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except in time of war or national emergency, not more than ten retired flag officers of the Regular Navy may be on active duty.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab107838-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/312"},"text":"70A Stat. 312","children":[],"tail":", § 5450; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s503/21"},"text":"Pub. L. 96–513, title V, § 503(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2912"},"text":"94 Stat. 2912","children":[],"tail":"; renumbered § 8102, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1834"},"text":"132 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab107839-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab10783a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab10783b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","at