{"tag":"section","attrib":{"id":"ida96a69b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2349"},"text":null,"children":[{"tag":"num","attrib":{"value":"2349"},"text":"§ 2349.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overseas Workload Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida96a69b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2349/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A firm of any member nation of the North Atlantic Treaty Organization or of any major non-NATO ally shall be eligible to bid on any contract for the maintenance, repair, or overhaul of equipment of the Department of Defense located outside the United States to be awarded under competitive procedures as part of the program of the Department of Defense known as the Overseas Workload Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida96a69b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2349/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Site of Performance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contract awarded to a firm described in subsection (a) may be performed in the theater in which the equipment is normally located or in the country in which the firm is located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida96a69ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2349/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of a military department may restrict the geographic region in which a contract referred to in subsection (a) may be performed if the Secretary determines that performance of the contract outside that specific region—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida96a69bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2349/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" could adversely affect the military preparedness of the armed forces; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida96a69bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2349/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would violate the terms of an international agreement to which the United States is a party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida96a69bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2349/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “major non-NATO ally” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2350a/i/2"},"text":"section 2350a(i)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida96a69be-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tXIV/s1431/a/1"},"text":"Pub. L. 103–160, div. A, title XIV, § 1431(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1832"},"text":"107 Stat. 1832","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tX/s1084/d/18"},"text":"Pub. L. 108–375, div. A, title X, § 1084(d)(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2062"},"text":"118 Stat. 2062","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida96a69bf-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida96a69c0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida96a69c1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2349, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/323/s2/a"},"text":"Pub. L. 96–323, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-04"},"text":"Aug. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1018"},"text":"94 Stat. 1018","children":[],"tail":", § 2330; renumbered § 2349, "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXIII/s1304/a/3"},"text":"Pub. L. 99–145, title XIII, § 1304(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/741"},"text":"99 Stat. 741","children":[],"tail":"; "},{"tag":"ref","att