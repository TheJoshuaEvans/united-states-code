{"tag":"section","attrib":{"id":"idab42ab89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8716"},"text":null,"children":[{"tag":"num","attrib":{"value":"8716"},"text":"§ 8716.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Naval Observatory: exchange of information with foreign offices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab42ab8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8716/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy may arrange to exchange data with foreign almanac offices to reduce the duplication of work in preparing the different national nautical and astronomical almanacs and make available for publication a larger amount of data useful to navigators and astronomers. Each such arrangement shall be made terminable on one year’s notice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab42ab8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8716/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The work of the Nautical Almanac Office shall be so conducted that in an emergency the part of the work intended for the use of navigators may be computed by the force of the office without foreign cooperation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab42ab8c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/457"},"text":"70A Stat. 457","children":[],"tail":", § 7396; "},{"tag":"ref","attrib":{"href":"/us/pl/95/357"},"text":"Pub. L. 95–357","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-08"},"text":"Sept. 8, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/591"},"text":"92 Stat. 591","children":[],"tail":"; renumbered § 8716, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/4"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab42ab8d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab42ab8e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab42ab8f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attr