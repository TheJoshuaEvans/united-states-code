{"tag":"section","attrib":{"id":"ida8b7938f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1371"},"text":null,"children":[{"tag":"num","attrib":{"value":"1371"},"text":"§ 1371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Warrant officers: general rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Unless entitled to a higher retired grade under some other provision of law, a warrant officer shall be retired in the highest regular or reserve warrant officer grade in which the warrant officer served satisfactorily, as determined by the Secretary concerned.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida8b79390-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/104"},"text":"70A Stat. 104","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tV/s505"},"text":"Pub. L. 114–92, div. A, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/808"},"text":"129 Stat. 808","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8b79391-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8b79392-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida8b79393-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1371","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:600","children":[{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":"(d) (1st sentence)."}],"tail":null},{"tag":"html:p","attrib":{},"text":"10:600","children":[{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":"(f) (1st sentence, as applicable to retired grade)."}],"tail":null},{"tag":"html:p","attrib":{},"text":"34:430(d) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1954-05-29/ch249/s14/d"},"text":"May 29, 1954, ch. 249, § 14(d)","children":[],"tail":" (1st sentence), (f) (1st sentence, as applicable to retired grade), "},{"tag":"html:a","attrib":{"href":"/us/stat/68/163"},"text":"68 Stat. 163","children":[],"tail":", 164."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"34:430(f) (1st sentence, as applicable to retired grade).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The first 13 words are substituted for 10:600","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(f) (1st sentence, as applicable to retired grade) and 34:430 (1st sentence, as applicable to retired grade). The words “for a period of more than 30 days” are substituted for the words “under * * * orders specifying that the period of such duty shall be for a period in excess of thirty days or for an indefinite period”, to conform to the definition of those words in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/23"},"text":"section 101(23) of this title","children":[],"tail":". The words “any full time duty” are omitted, since the duty specified would necessarily be full time duty. The words “under this section” and “competent” are omitted as surplusage."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8b79394-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8b79395-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “Unless entitled to a higher retired grade under some other provision of law, a warrant officer retires, as determined by the Secretary concerned, in the permanent regular or reserve warrant officer grade, if any, that he held on the day before the date of his retirement, or in any higher warrant officer grade in which he served on active duty satisfactorily, as determined by the Secretary, for a period of more than 30 days.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8b79396-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8b79397-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Public Health Service","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Authority vested by this chapter in “military departments”, “the Secretary concerned”, or “the Secretary of Defense” to be exercised, with respect to commissioned officers of Public Health Service, by Secretary of Health and Human Services or his designee, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s213a"},"text":"section 213a of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8b79398-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"National Oceanic and Atmospheric Administration","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Authority vested by this chapter in “military departments”, “the Secretary concerned”, or “the Secretary of Defense” to be exercised, with respect to commissioned officer corps of National Oceanic and Atmospheric Administration, by Secretary of Commerce or Secretary’s designee, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3071"},"text":"section 3071 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
