{"tag":"section","attrib":{"id":"idab403be6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697"},"text":null,"children":[{"tag":"num","attrib":{"value":"8697"},"text":"§ 8697.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Battle force ship employment, maintenance, and manning baseline plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab403be7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 45 days after the date of the delivery of the first ship in a new class of battle force ships, the Secretary of the Navy shall submit to the congressional defense committees a report on the employment, maintenance, and manning baseline plans for the class, including a description of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab403be8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The sustainment and maintenance plans for the class that encompass the number of years the class is expected to be in service, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403be9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the allocation of maintenance tasks among organizational, intermediate, depot, or other activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the planned duration and interval of maintenance for all depot-level maintenance availabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403beb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the planned duration and interval of drydock maintenance periods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403bec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any contractually required integrated logistics support deliverables for the ship, including technical manuals, and an identification of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403bed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deliverables provided to the Government on or before the delivery date; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deliverables not provided to the Government on or before the delivery date and the expected dates those deliverables will be provided to the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403bef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The planned maintenance system for the ship, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403bf0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the elements of the system, including maintenance requirement cards, completed on or before the delivery date;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bf1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the elements of the system not completed on or before the delivery date and the expected completion date of those elements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bf2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plans to complete planned maintenance from the delivery date until all elements of the system have been completed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403bf3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The coordinated shipboard allowance list for the class, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403bf4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the items on the list onboard on or before the delivery date; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bf5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the items on the list not onboard on or before the delivery date and the expected arrival date of those items.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403bf6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The ship manpower document for the class, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403bf7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of officers by grade and designator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bf8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of enlisted personnel by rate and rating.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403bf9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The personnel billets authorized for the ship for the fiscal year in which the ship is delivered and each of the four fiscal years thereafter, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403bfa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of officers by grade and designator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bfb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of enlisted personnel by rate and rating.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403bfc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Programmed funding for manning and end strength on the ship for the fiscal year in which the ship is delivered and each of the four fiscal years thereafter, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403bfd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of officers by grade and designator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bfe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of enlisted personnel by rate and rating.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403bff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Personnel assigned to the ship on the delivery date, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403c00-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of officers by grade and designator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403c01-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of enlisted personnel by rate and rating.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403c02-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For each critical hull, mechanical, electrical, propulsion, and combat system of the class as so designated by the Senior Technical Authority pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8669b/c/2/C"},"text":"section 8669b(c)(2)(C) of this title","children":[],"tail":", the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403c03-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Government-provided training available for personnel assigned to the ship at the time of delivery, including the nature, objectives, duration, and location of the training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403c04-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The contractor-provided training available for personnel assigned to the ship at the time of delivery, including the nature, objectives, duration, and location of the training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403c05-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Plans to adjust how the training described in subparagraphs (A) and (B) will be provided to personnel after delivery, including the nature and timeline of those adjustments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403c06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The notional employment schedule of the ship for each month of the fiscal year in which the ship is delivered and each of the four fiscal years thereafter, including an identification of time spent in the following phases:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403c07-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Basic.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403c08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Integrated or advanced.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403c09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Deployment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403c0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/10/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Maintenance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403c0b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/a/10/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sustainment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403c0c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less than 30 days before implementing a significant change to the baseline plans described in subsection (a) or any subsequent significant change, the Secretary of the Navy shall submit to the congressional defense committees written notification of the change, including for each such change the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab403c0d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An explanation of the change.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403c0e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The desired outcome.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403c0f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rationale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403c10-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The duration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403c11-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The operational effects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403c12-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The budgetary effects, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403c13-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the year in which the change is made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403c14-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" over the five years thereafter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403c15-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" over the expected service life of the relevant class of battle force ships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403c16-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The personnel effects, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403c17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the year in which the change is made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403c18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" over the five years thereafter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403c19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" over the expected service life of the relevant class of battle force ships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403c1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The sustainment and maintenance effects, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403c1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the year in which the change is made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403c1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" over the five years thereafter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403c1d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/b/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" over the expected service life of the relevant class of battle force ships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403c1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8697/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Certain Ships","child