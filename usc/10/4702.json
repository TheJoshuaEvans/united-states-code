{"tag":"section","attrib":{"id":"idaa8af424-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4702"},"text":null,"children":[{"tag":"num","attrib":{"value":"4702"},"text":"§ 4702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentives and consideration for qualified training programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa8af425-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incentives","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall develop workforce development investment incentives for a contractor that implements a qualified training program to develop the workforce of the contractor in a manner consistent with the needs of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa8af426-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration of Qualified Training Programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall revise the Department of Defense Supplement to the Federal Acquisition Regulation to require that the system used by the Federal Government to monitor or record contractor past performance includes an analysis of the availability, quality, and effectiveness of a qualified training program of an offeror as part of the past performance rating of such offeror.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa8af427-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified Training Program Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified training program” means any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa8af428-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4702/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A program eligible to receive funds under the Workforce Innovation and Opportunity Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"29 U.S.C. 3101","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8af429-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4702/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A program eligible to receive funds under the Carl D. Perkins Career and Technical Education Act of 2006 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s2301"},"text":"20 U.S.C. 2301","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8af42a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4702/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A program registered under the Act of ","children":[{"tag":"date","attrib":{"date":"1937-08-16"},"text":"August 16, 1937","children":[],"tail":" (commonly known as the “National Apprenticeship Act”; "},{"tag":"ref","attrib":{"href":"/us/stat/50/664"},"text":"50 Stat. 664","children":[],"tail":"; chapter 663; "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s50"},"text":"29 U.S.C. 50","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa8af42b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4702/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other program determined to be a qualified training program for purposes of this section, and that meets the workforce needs of the Department of Defense, as determined by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa8af42c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVIII/s864/a"},"text":"Pub. L. 116–92, div. A, title VIII, § 864(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1522"},"text":"133 Stat. 1522","children":[],"tail":", § 2409a; renumbered § 4702 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tX/s1081/a/40"},"text":"Pub. L. 116–283, div. A, title X, § 1081(a)(40)","children":[],"tail":", title XVIII, § 1863(b), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3873"},"text":"134 Stat. 3873","children":[],"tail":", 4278.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa8af42d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa8af42e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaa8af42f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","