{"tag":"section","attrib":{"id":"idab6d8c2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9344"},"text":null,"children":[{"tag":"num","attrib":{"value":"9344"},"text":"§ 9344.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Higher grade after 30 years of service: warrant officers and enlisted members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab6d8c2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9344/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each retired member of the Air Force or the Space Force covered by subsection (b) who is retired with less than 30 years of active service is entitled, when his active service plus his service on the retired list totals 30 years, to be advanced on the retired list to the highest grade in which he served on active duty satisfactorily (or, in the case of a member of the National Guard, in which he served on full-time duty satisfactorily), as determined by the Secretary of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab6d8c2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9344/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section applies to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab6d8c2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9344/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" warrant officers of the Air Force or the Space Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab6d8c2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9344/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enlisted members of the Regular Air Force or the Space Force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab6d8c2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9344/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reserve enlisted members of the Air Force or the Space Force who, at the time of retirement, are serving on active duty (or, in the case of members of the National Guard, on full-time duty).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab6d8c30-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/555"},"text":"70A Stat. 555","children":[],"tail":", § 8964; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1"},"text":"Pub. L. 85–861, § 1","children":[],"tail":"(198A), "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1541"},"text":"72 Stat. 1541","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tV/s533/c"},"text":"Pub. L. 98–525, title V, § 533(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2528"},"text":"98 Stat. 2528","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tV/s512/c"},"text":"Pub. L. 100–180, div. A, title V, § 512(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1090"},"text":"101 Stat. 1090","children":[],"tail":"; renumbered § 9344, "},{"tag":"ref","attrib":{"href":"/us/pl/11