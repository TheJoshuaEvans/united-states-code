{"tag":"section","attrib":{"id":"ida9385caa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2193"},"text":null,"children":[{"tag":"num","attrib":{"value":"2193"},"text":"§ 2193.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improvement of education in technical fields: grants for higher education in science and mathematics","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9385cab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2193/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9385cac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2193/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may, in accordance with the provisions of this subsection, carry out a program for awarding grants to students who have been accepted for enrollment in, or who are enrolled in, an institution of higher education as undergraduate or graduate students in scientific and engineering disciplines critical to the national security functions of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9385cad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2193/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grant proceeds shall be disbursed on behalf of students awarded grants under this subsection to the institutions of higher education at which the students are enrolled. No grant proceeds shall be disbursed on behalf of a student until the student is enrolled at an institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9385cae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2193/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of a grant awarded a student under this subsection may not exceed the student’s cost of attendance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9385caf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2193/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of a grant awarded a student under this subsection shall not be reduced on the basis of the student’s receipt of other forms of Federal student financial assistance, but shall be taken into account in determining the eligibility of the student for those other forms of Federal student financial assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9385cb0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2193/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall give priority to awarding grants under this subsection in a manner likely to stimulate the interest of women and members of minority groups in pursuing scientific and engineering careers. The Secretary may consider the financial need of applicants in making awards in accordance with such priority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9385cb1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2193/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9385cb2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2193/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “institution of higher education” has the meaning given such term in section 101 of the Higher Education Act of 1965.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9385cb3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2193/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “cost of attendance” has the meaning given such term in section 472 of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087"},"text":"20 U.S.C. 1087","children":[],"tail":null},{"tag":"i","attrib":{},"text":"ll","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9385cb4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tII/s247/a/1"},"text":"Pub. L. 101–510, div. A, title II, § 247(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1521"},"text":"104 Stat. 1521","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tI/s102/a/2/A"},"text":"Pub. L. 105–244, title I, § 102(a)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1617"},"text":"112 Stat. 1617","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s580/c/2"},"text":"Pub. L. 106–65, div. A, title V, § 580(c)(2)","children":[],"tail":", (3), (d)(2), "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/633"},"text":"113 Stat. 633","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9385cb5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9385cb6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida9385cb7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 101 of the Higher Education Act of 1965, referred to in subsec. (b)(1), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9385cb8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s580/d/2"},"text":"Pub. L. 106–65, § 580(d)(2)","children":[],"tail":", amended section catchline generally. Prior to amendment, catchline read as follows: “Science and mathematics education improvement program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s580/c/3"},"text":"Pub. L. 106–65, § 580(c)(3)","children":[],"tail":", redesignated subsec. (c) as (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s580/c/2"},"text":"Pub. L. 106–65, § 580(c)(2)","children":[],"tail":", redesignated subsec. (b) as "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2193a"},"text":"section 2193a of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s580/c/3"},"text":"Pub. L. 106–65, § 580(c)(3)","children":[],"tail":", redesignated subsec. (c) as (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" substituted “section 101 of the Higher Education Act of 1965” for “section 1201(a) of the Higher Education Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1141/a"},"text":"20 U.S.C. 1141(a)","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9385cb9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9385cba-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
