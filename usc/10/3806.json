II, § 802(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1831"},"text":"111 Stat. 1831","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/391/tIII/s306"},"text":"Pub. L. 106–391, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1592"},"text":"114 Stat. 1592","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa3c5f2f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1834/g/1"},"text":"Pub. L. 116–283, § 1834(g)(1)","children":[],"tail":", (2), (11), transferred subsec. (i) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2307"},"text":"section 2307 of this title","children":[],"tail":" to this section, struck out subsec. (i) designation and heading “Action in Case of Fraud” at beginning, and redesignated par. (10) as subsec. (a), pars. (1) to (7) as subsecs. (b) to (h), respectively, and pars. (9) and (8) as subsecs. (i) and (j), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1834/g/3"},"text":"Pub. L. 116–283, § 1834(g)(3)","children":[],"tail":", inserted heading and substituted “this section” for “this subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1834/g/4"},"text":"Pub. L. 116–283, § 1834(g)(4)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1834/g/5"},"text":"Pub. L. 116–28