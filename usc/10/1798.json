{"tag":"section","attrib":{"id":"ida91962e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1798"},"text":null,"children":[{"tag":"num","attrib":{"value":"1798"},"text":"§ 1798.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child care services and youth program services for dependents: financial assistance for providers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida91962e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1798/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may provide financial assistance to an eligible civilian provider of child care services or youth program services that furnishes such services for members of the armed forces, survivors of members of the armed forces who die in combat-related incidents in the line of duty, and employees of the United States if the Secretary determines that providing such financial assistance—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida91962e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1798/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the best interest of the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida91962e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1798/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enables supplementation or expansion of furnishing of child care services or youth program services for military installations, while not supplanting or replacing such services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida91962e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1798/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures that the eligible provider is able to comply, and does comply, with the regulations, policies, and standards of the Department of Defense that are applicable to the furnishing of such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida91962ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1798/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Providers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A provider of child care services or youth program services is eligible for financial assistance under this section if the provider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida91962eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1798/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is licensed to provide those services under applicable State and local law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida91962ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1798/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has previously provided such services for members of the armed forces or employees of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida91962ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1798/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida91962ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1798/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a family home day care provider; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida91962ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1798/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is a provider of family child care services that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida91962f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1798/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise provides federally funded or sponsored child development services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida91962f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1798/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides the services in a child development center owned and operated by a private, not-for-profit organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida91962f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1798/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides before-school or after-school child care program in a public school facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida91962f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1798/b/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducts an otherwise federally funded or federally sponsored school age child care or youth services program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida91962f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1798/b/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducts a school age child care or youth services program that is owned and operated by a not-for-profit organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida91962f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1798/b/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a provider of another category of child care services or youth services determined by the Secretary of Defense as appropriate for meeting the needs of members of the armed forces or employees of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida91962f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1798/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To provide financial assistance under this subsection, the Secretary of Defense may use any funds appropriated to the Department of Defense for operation and maintenance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida91962f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1798/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Review of Amount of Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall annually review the amount of financial assistance provided under this section, including the maximum amount of financial assistance per month per child that the Secretary authorizes to be provided to eligible providers under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida91962f8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s584/a/1/B"},"text":"Pub. L. 106–65, div. A, title V, § 584(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/634"},"text":"113 Stat. 634","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tX/s1041/a/6"},"text":"Pub. L. 107–314, div. A, title X, § 1041(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2645"},"text":"116 Stat. 2645","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVI/s624"},"text":"Pub. L. 116–92, div. A, title VI, § 624","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1428"},"text":"133 Stat. 1428","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVI/s641"},"text":"Pub. L. 119–60, div. A, title VI, § 641","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/912"},"text":"139 Stat. 912","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida91962f9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida91962fa-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida91962fb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1798 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1800"},"text":"section 1800 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida91962fc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" inserted “, survivors of members of the armed forces who die in combat-related incidents in the line of duty,” after “armed forces” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" struck out heading and text of subsec. (d). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Every two years the Secretary of Defense shall submit to Congress a report on the exercise of authority under this section. The report shall include an evaluation of the effectiveness of that authority for meeting the needs of members of the armed forces or employees of the Department of Defense for child care services and youth program services. The report may include any recommendations for legislation that the Secretary considers appropriate to enhance the capability of the Department of Defense to meet those needs.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) A biennial report under this subsection may be combined with the biennial report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1799/d"},"text":"section 1799(d) of this title","children":[],"tail":" into a single report for submission to Congress.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida91962fd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida91962fe-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pilot Program To Increase Payments for Child Care Services in High-Cost Areas","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tV/s589D"},"text":"Pub. L. 119–60, div. A, title V, § 589D","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/898"},"text":"139 Stat. 898","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tV/s589D"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may establish a pilot program to increase the maximum amount of financial assistance per month per child that the Secretary authorizes to be provided to eligible providers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1798"},"text":"section 1798 of title 10","children":[],"tail":", United States Code, for services provided to children who are two years old or younger in accordance with this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary establishes a pilot program under subsection (a), the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide for an increased maximum amount of financial assistance under the pilot program in each area with high child care services costs, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide for such increased maximum amount of financial assistance in other areas as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than one year after the establishment of the pilot program under this subsection, and annually thereafter until the date of the termination of the pilot program, the Secretary shall submit to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] a report on the pilot program that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of families with respect to whom the Secretary has increased the maximum amount of financial assistance per month per child being provided under the pilot program, disaggregated by location;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methodology for determining the areas that should receive an increased amount of financial assistance per month per child under the pilot program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of areas the Secretary determined should receive such increased amount of financial assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of financial assistance provided under the pilot program with respect to such families, disaggregated by location;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of financial assistance that would have been provided with respect to such families without the increase under the pilot program, disaggregated by location;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the determination of the Secretary as to whether additional funding under the pilot program—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" helped reduce child care costs for applicable military families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increased child care provider participation in the financial assistance available under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increased access to infant and toddler care for military families;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"“(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the determination of the Secretary with respect to the feasibility of expanding the pilot program to all communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"“(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any challenges identified by the Secretary in carrying out the pilot program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"“(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legislation or administrative action that the Secretary determines necessary to make the pilot program permanent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"“(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Final report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date of the termination of the pilot program, the Secretary shall submit to the congressional defense committees a report that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the elements specified in subparagraphs (A) through (J) of paragraph (3) [sic; probably should be “paragraph (1)”]; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recommendation of the Secretary as to whether to make the pilot program permanent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The pilot program established under this subsection shall terminate on the date that is five years after the date on which such program is established.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida91962ff-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Child Care Services and Youth Program Services for Dependents","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s588"},"text":"Pub. L. 118–159, div. A, title V, § 588","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1914"},"text":"138 Stat. 1914","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tV/s588"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the availability of appropriations, the Secretary of Defense shall fully fund requests under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1798"},"text":"section 1798 of title 10","children":[],"tail":", United States Code, for financial assistance to eligible civilian providers of child care services or youth program services, as such terms are used in such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall not be construed to limit the authority of the Secretary, under subsection (a) of such section, to determine whether to provide such financial assistance to an eligible provider for such services.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9196300-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Promotion of Certain Child Care Assistance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tV/s577"},"text":"Pub. L. 117–263, div. A, title V, § 577","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2606"},"text":"136 Stat. 2606","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tV/s577"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Secretary concerned shall promote, to members of the Armed Forces under the jurisdiction of such Secretary concerned, awareness of child care assistance available under—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1798"},"text":"section 1798 of title 10","children":[],"tail":", United States Code; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 589 of the William M. (Mac) Thornberry National Defense Authorization Act for Fiscal Year 2021 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Public Law 116–283","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1791"},"text":"10 U.S.C. 1791","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"], each Secretary concerned shall submit to the Committees on Armed Services of the Senate and House of Representatives a report summarizing activities taken by such Secretary concerned to carry out subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary Concerned Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘Secretary concerned’ has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of title 10","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9196301-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"First Biennial Reports","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s584/b"},"text":"Pub. L. 106–65, div. A, title V, § 584(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/636"},"text":"113 Stat. 636","children":[],"tail":", provided that the first biennial reports under former sections 1798(d) and 1799(d) of this title were to be submitted not later than "},{"tag":"date","attrib":{"date":"2002-03-31"},"text":"Mar. 31, 2002","children":[],"tail":", and were to cover fiscal years 2000 and 2001."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
