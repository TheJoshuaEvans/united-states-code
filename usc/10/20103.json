{"tag":"section","attrib":{"id":"idabc82f35-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20103"},"text":null,"children":[{"tag":"num","attrib":{"value":"20103"},"text":"§ 20103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members not on sustained duty: agreements concerning conditions of service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabc82f36-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Air Force may enter into a written agreement with a member of the Space Force not on sustained duty—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc82f37-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requiring the member to serve on active duty for a definite period of time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f38-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifying the conditions of the member’s service on active duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20103/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a member serving in a space force inactive status, specifying the conditions for the member’s continued service as well as order to active duty with and without the consent of the member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc82f3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions of Service","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agreement under subsection (a) shall specify the conditions of service. The Secretary of the Air Force shall prescribe regulations establishing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc82f3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" what conditions of service may be specified in the agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the obligations of the parties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consequences of failure to comply with the terms of the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc82f3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority for Retention on Active Duty During War or National Emergency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the period of service on active duty of a member under an agreement under subsection (a) expires during a war or during a national emergency declared by Congress or the President, the member concerned may be kept on active duty, without the consent of the member, as otherwise prescribed by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc82f3f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1715"},"text":"Pub. L. 118–31, div. A, title XVII, § 1715","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/628"},"text":"137 Stat. 628","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
