{"tag":"section","attrib":{"id":"ida9eb3244-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2872b"},"text":"§ 2872b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of breach of contract","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9eb3245-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Response to Material Breach","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a material breach of contract under this subchapter by a party to the contract, the Secretary concerned shall use the authorities available to the Secretary, including withholding amounts to be paid under the contract, to encourage the party to cure the breach.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9eb3246-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rescinding of Contract","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a material breach of the contract is not cured in a timely manner, as determined by the Secretary concerned, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9eb3247-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rescind the contract pursuant to the terms of the contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eb3248-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit the offending party from entering into a new contract or undertaking expansions of other existing contracts, or both, with the Secretary under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9eb3249-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dB/tXXX/s3033/a"},"text":"Pub. L. 116–92, div. B, title XXX, § 3033(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1936"},"text":"133 Stat. 1936","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
