{"tag":"section","attrib":{"id":"idaac90fba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6266"},"text":null,"children":[{"tag":"num","attrib":{"value":"6266"},"text":"§ 6266.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of nuclear criticality and non-nuclear incidents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaac90fbb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6266/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy or the Administrator, as the case may be, shall submit to the appropriate congressional committees a notification of a nuclear criticality incident resulting from a covered program that results in an injury or fatality or results in the shutdown, or partial shutdown, of a covered facility by not later than 15 days after the date of such incident.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90fbc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6266/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements of Notification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each notification submitted under subsection (a) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac90fbd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6266/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the incident, including the cause of the incident.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90fbe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6266/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a criticality incident, whether the incident caused a facility, or part of a facility, to be shut down.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90fbf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6266/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The effect, if any, on the mission of the Administration or the Office of Environmental Management of the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90fc0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6266/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any corrective action taken in response to the incident.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90fc1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6266/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Database","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac90fc2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6266/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall maintain a record of incidents described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90fc3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6266/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An incident described in this paragraph is any of the following incidents resulting from a covered program:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac90fc4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6266/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nuclear criticality incident that results in an injury or fatality or results in the shutdown, or partial shutdown, of a covered facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac90fc5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6266/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A non-nuclear incident that results in serious bodily injury or fatality at a covered facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90fc6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6266/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out this section, the Secretary and the Administrator shall ensure that each management and operating contractor of a covered facility cooperates in a timely manner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90fc7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6266/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacb58b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6266/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacb58b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6266/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional defense committees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacb58ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6266/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce of the House of Representatives and the Committee on Energy and Natural Resources of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacb58bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6266/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered facility” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacb58bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6266/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a facility of the nuclear security enterprise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacb58bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6266/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a facility conducting activities for the defense environmental cleanup program of the Office of Environmental Management of the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacb58be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6266/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered program” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacb58bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6266/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs of the Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacb58c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6266/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defense environmental cleanup programs of the Office of Environmental Management of the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaacb58c1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2)(B), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1424"},"text":"139 Stat. 1424","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaacb58c2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaacb58c3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaacb58c4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2736"},"text":"section 2736 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaacb58c5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
