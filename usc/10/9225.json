{"tag":"section","attrib":{"id":"idab68d146-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9225"},"text":null,"children":[{"tag":"num","attrib":{"value":"9225"},"text":"§ 9225.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rank: warrant officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Warrant officers rank next below second lieutenants and rank among themselves within each warrant officer grade under regulations to be prescribed by the Secretary of the Air Force.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab68d147-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/530"},"text":"70A Stat. 530","children":[],"tail":", § 8575; renumbered § 9225, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/b/7"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1832"},"text":"132 Stat. 1832","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab68d148-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab68d149-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab68d14a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n",