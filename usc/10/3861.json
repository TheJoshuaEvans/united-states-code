{"tag":"section","attrib":{"id":"idaa3ea918-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3861"},"text":null,"children":[{"tag":"num","attrib":{"value":"3861"},"text":"§ 3861.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development contracts: indemnification provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa3ea919-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3861/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With the approval of the Secretary of the military department concerned, any contract of a military department for research or development, or both, may provide that the United States will indemnify the contractor against either or both of the following, but only to the extent that they arise out of the direct performance of the contract and to the extent not compensated by insurance or otherwise:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa3ea91a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3861/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Claims (including reasonable expenses of litigation or settlement) by third persons, including employees of the contractor, for death, bodily injury, or loss of or damage to property, from a risk that the contract defines as unusually hazardous.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa3ea91b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3861/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Loss of or damage to property of the contractor from a risk that the contract defines as unusually hazardous.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa3ea91c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3861/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A contract, made under subsection (a), that provides for indemnification must also provide for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa3ea91d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3861/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice to the United States of any claim or suit against the contractor for the death, bodily injury, or loss of or damage to property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa3ea91e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3861/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" control of or assistance in the defense by the United States, at its election, of that suit or claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa3ea91f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3861/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No payment may be made under subsection (a) unless the Secretary of the department concerned, or an officer or official of his department designated by him, certifies that the amount is just and reasonable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa3ea920-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3861/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon approval by the Secretary concerned, payments under subsection (a) may be made from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa3ea921-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3861/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds obligated for the performance of the contract concerned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa3ea922-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3861/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds available for research or development, or both, and not otherwise obligated; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa3ea923-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3861/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds appropriated for those payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa3ea924-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/134"},"text":"70A Stat. 134","children":[],"tail":", § 2354; renumbered § 3861 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1836/b"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1836(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4241"},"text":"134 Stat. 4241","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa3ea925-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa3ea926-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa3ea927-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2354"},"text":"section 2354 of this title","children":[],"tail":" as this section and substituted “Research and development contracts: indemnification provisions” for “Contracts: indemnification provisions” in section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa3ea928-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa3ea929-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
