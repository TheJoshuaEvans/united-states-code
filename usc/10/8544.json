{"tag":"section","attrib":{"id":"idab2f98e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8544"},"text":null,"children":[{"tag":"num","attrib":{"value":"8544"},"text":"§ 8544.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civilian teachers: number; compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Navy may employ as many civilians as he considers necessary to serve at the Naval Postgraduate School under the direction of the President of the school as senior professors, professors, associate professors, assistant professors, and instructors. The Secretary shall prescribe the compensation of those persons.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab2f98e9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/437"},"text":"70A Stat. 437","children":[],"tail":", § 7044; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s557/a/4/A"},"text":"Pub. L. 108–375, div. A, title V, § 557(a)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1915"},"text":"118 Stat. 1915","children":[],"tail":"; renumbered § 8544, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/c/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab2f98ea-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevi