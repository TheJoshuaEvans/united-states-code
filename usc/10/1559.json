{"tag":"section","attrib":{"id":"ida8e4e6a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1559"},"text":null,"children":[{"tag":"num","attrib":{"value":"1559"},"text":"§ 1559.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel limitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8e4e6a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1559/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before ","children":[{"tag":"date","attrib":{"date":"2025-12-31"},"text":"December 31, 2025","children":[],"tail":", the Secretary of a military department may not carry out any reduction in the number of military and civilian personnel assigned to duty with the service review agency for that military department below the baseline number for that agency."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8e4e6a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1559/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Baseline Number","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The baseline number for a service review agency under this section is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8e4e6a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1559/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of the first report with respect to a service review agency under this section, the number of military and civilian personnel assigned to duty with that agency as of ","children":[{"tag":"date","attrib":{"date":"2002-01-01"},"text":"January 1, 2002","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8e4e6a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1559/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of any subsequent report with respect to a service review agency under this section, the number of such personnel specified in the most recent report with respect to that agency under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8e4e6aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1559/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service Review Agency Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “service review agency” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8e4e6ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1559/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the Department of the Army, the Army Review Boards Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8e4e6ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1559/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the Department of the Navy, the Board for Correction of Naval Records; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8e4e6ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1559/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the Department of the Air Force, the Department of the Air Force Review Boards Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8e4e6ae-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tV/s552/a"},"text":"Pub. L. 107–314, div. A, title V, § 552(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2552"},"text":"116 Stat. 2552","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s581"},"text":"Pub. L. 108–375, div. A, title V, § 581","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1928"},"text":"118 Stat. 1928","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title V, § 593, "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4475"},"text":"122 Stat. 4475","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tV/s533/b"},"text":"Pub. L. 111–383, div. A, title V, § 533(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4216"},"text":"124 Stat. 4216","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tV/s520"},"text":"Pub. L. 112–239, div. A, title V, § 520","children":[],"tail":", title X, § 1076(b)(2), "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],