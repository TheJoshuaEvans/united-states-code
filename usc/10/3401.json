{"tag":"section","attrib":{"id":"idaa1fb03e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3401"},"text":null,"children":[{"tag":"num","attrib":{"value":"3401"},"text":"§ 3401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task and delivery order contracts: definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa1fb03f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3401/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delivery order contract","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “delivery order contract” means a contract for property—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa1fb040-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3401/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that does not procure or specify a firm quantity of property (other than a minimum or maximum quantity); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa1fb041-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3401/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that provides for the issuance of orders for the delivery of property during the period of the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa1fb042-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3401/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inli