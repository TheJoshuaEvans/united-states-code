{"tag":"section","attrib":{"id":"idaa949159-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4812"},"text":null,"children":[{"tag":"num","attrib":{"value":"4812"},"text":"§ 4812.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Defense Technology and Industrial Base Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa94915a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4812/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is a National Defense Technology and Industrial Base Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa94915b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4812/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council is composed of the following members:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa94915c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4812/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense, who shall serve as chairman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa94915d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4812/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa94915e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4812/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa94915f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4812/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa949160-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4812/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other officials as may be determined by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa949161-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4812/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall have the responsibility to ensure effective cooperation among departments and agencies of the Federal Government, and to provide advice and recommendations to the President, the Secretary of Defense, the Secretary of Energy, the Secretary of Commerce, and the Secretary of Labor, concerning—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa949162-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4812/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capabilities of the national technology and industrial base to meet the national security objectives set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4811/a"},"text":"section 4811(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa949163-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4812/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs for achieving such national security objectives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa949164-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4812/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changes in acquisition policy that strengthen the national technology and industrial base; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa949165-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4812/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaboration with government officials of member countries of the national technology and industrial base in order to strengthen the national technology and industrial base.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa949166-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4812/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternative Performance of Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsection (c), the President may assign the responsibilities of the Council to another interagency organization of the executive branch that includes among its members the officials specified in paragraphs (1) through (4) of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa949167-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dD/tXLII/s4212/a"},"text":"Pub. L. 102–484, div. D, title XLII, § 4212(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2664"},"text":"106 Stat. 2664","children":[],"tail":", § 2502; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tXIII/s1312/b"},"text":"Pub. L. 103–160, div. A, title XIII, § 1312(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1786"},"text":"107 Stat. 1786","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tX/s1070/a/12"},"text":"Pub. L. 103–337, div. A, title X, § 1070(a)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2856"},"text":"108 Stat. 2856","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tX/s1081/b"},"text":"Pub. L. 104–106, div. A, title X, § 1081(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/452"},"text":"110 Stat. 452","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tVIII/s829/c/2"},"text":"Pub. L. 104–201, div. A, title VIII, § 829(c)(2)","children":[],"tail":", formerly § 829(c)(2), (3), "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2613"},"text":"110 Stat. 2613","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1073/c/7/B"},"text":"Pub. L. 105–85, div. A, title X, § 1073(c)(7)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1904"},"text":"111 Stat. 1904","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1073/c/7/A"},"text":"Pub. L. 105–85, div. A, title X, § 1073(c)(7)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1904"},"text":"111 Stat. 1904","children":[],"tail":"; renumbered § 4812 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVIII/s846/c"},"text":"Pub. L. 116–283, div. A, title VIII, § 846(c)","children":[],"tail":", title XVIII, § 1867(b), (d)(1), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3768"},"text":"134 Stat. 3768","children":[],"tail":", 4281.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa949168-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa949169-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa94916a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1867/b"},"text":"Pub. L. 116–283, § 1867(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2502"},"text":"section 2502 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1867/d/1"},"text":"Pub. L. 116–283, § 1867(d)(1)","children":[],"tail":", substituted “section 4811(a)” for “section 2501(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s846/c"},"text":"Pub. L. 116–283, § 846(c)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s1073/c/7/A"},"text":"Pub. L. 105–85, § 1073(c)(7)(A)","children":[],"tail":", made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s829/c/2"},"text":"Pub. L. 104–201, § 829(c)(2)","children":[],"tail":". See 1996 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s829/c/2"},"text":"Pub. L. 104–201, § 829(c)(2)","children":[],"tail":", formerly § 829(c)(2), (3), as renumbered and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":", substituted “the responsibility to ensure effective cooperation” for “the following responsibilities:”, struck out “(1) To ensure the effective cooperation” before “among departments”, struck out par. (2), redesignated subpars. (A), (B), and (C) as pars. (1), (2), and (3), respectively, and adjusted margins of such pars. Prior to repeal, par. (2) read as follows: “To prepare the periodic assessment and the periodic plan required by sections 2505 and 2506 of this title, respectively.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1081/b/1"},"text":"Pub. L. 104–106, § 1081(b)(1)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “programs for achieving, during a period of reduction in defense expenditures, the defense reinvestment, diversification, and conversion objectives set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2501/b"},"text":"section 2501(b) of this title","children":[],"tail":"; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1081/b/2"},"text":"Pub. L. 104–106, § 1081(b)(2)","children":[],"tail":", (3), redesignated par. (3) as (2) and struck out former par. (2) which read as follows: “To provide overall policy guidance to ensure effective implementation by agencies of the Federal Government of defense reinvestment and conversion activities during a period of reduction in defense expenditures.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" substituted “executive” for “Executive”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa94916b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa94916c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by section 1867(b), (d)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":