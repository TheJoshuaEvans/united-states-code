{"tag":"section","attrib":{"id":"idab070291-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8025"},"text":null,"children":[{"tag":"num","attrib":{"value":"8025"},"text":"§ 8025.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab070292-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8025/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Navy shall provide that the Assistant Secretary of the Navy for Financial Management shall direct and manage financial management activities and operations of the Department of the Navy, including ensuring that financial management systems of the Department of the Navy comply with subsection (b). The authority of the Assistant Secretary for such direction and management shall include the authority to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab070293-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8025/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supervise and direct the preparation of budget estimates of the Department of the Navy and otherwise carry out, with respect to the Department of the Navy, the functions specified for the Under Secretary of Defense (Comptroller) in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s135/c"},"text":"section 135(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab070294-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8025/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve and supervise any project to design or enhance a financial management system for the Department of the Navy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab070295-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8025/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" approve the establishment and supervise the operation of any asset management system of the Department of the Navy, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab070296-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8025/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" systems for cash management, credit management, and debt collection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab070297-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8025/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" systems for the accounting for the quantity, location, and cost of property and inventory.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab070298-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8025/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab070299-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8025/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Financial management systems of the Department of the Navy (including accounting systems, internal control systems, and financial reporting systems) shall be established and maintained in conformance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab07029a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8025/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accounting and financial reporting principles, standards, and requirements established by the Comptroller General under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3511"},"text":"section 3511 of title 31","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab07029b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8025/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the internal control standards established by the Comptroller General under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3512"},"text":"section 3512 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab07029c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8025/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such systems shall provide for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab07029d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8025/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete, reliable, consistent, and timely information which is prepared on a uniform basis and which is responsive to the financial information needs of department management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab07029e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8025/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and reporting of cost information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab07029f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8025/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the integration of accounting and budgeting information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab0702a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8025/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the systematic measurement of performance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0702a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8025/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary shall maintain a five-year plan describing the activities the Department of the Navy proposes to conduct over the next five fiscal years to improve financial management. Such plan shall be revised annually.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0702a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8025/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary of the Navy for Financial Management shall transmit to the Secretary of the Navy a report each year on the activities of the Assistant Secretary during the preceding year. Each such report shall include a description and analysis of the status of Department of the Navy financial management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab0702a3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tVII/s702/b/2"},"text":"Pub. L. 100–456, div. A, title VII, § 702(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1994"},"text":"102 Stat. 1994","children":[],"tail":", § 5025; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tX/s1070/a/15"},"text":"Pub. L. 103–337, div. A, title X, § 1070(a)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2856"},"text":"108 Stat. 2856","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1503/b/1"},"text":"Pub. L. 104–106, div. A, title XV, § 1503(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/512"},"text":"110 Stat. 512","children":[],"tail":"; renumbered § 8025, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/a/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1834"},"text":"132 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab0702a4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab0702a5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab0702a6-3a6f-