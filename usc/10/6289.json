{"tag":"section","attrib":{"id":"idaacb59d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6289"},"text":null,"children":[{"tag":"num","attrib":{"value":"6289"},"text":"§ 6289.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of adequacy of nuclear weapons budget","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaacb59d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6289/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of Adequacy of Administration Budget by Nuclear Weapons Council","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacb59d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6289/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy shall transmit to the Nuclear Weapons Council (in this section referred to as the “Council”) a copy of the proposed budget request of the Administration for each fiscal year before that budget request is submitted to the Director of the Office of Management and Budget in relation to the preparation of the budget of the President to be submitted to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacb59d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6289/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Council shall review each budget request transmitted to the Council under paragraph (1) in accordance with section 179(f).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacb59da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6289/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacb59db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6289/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Council submits to the Secretary of Energy a written description under section 179(f)(2)(B)(i) with respect to the budget request of the Administration for a fiscal year, the Secretary shall include as an appendix to the budget request submitted to the Director of the Office of Management and Budget—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaacb59dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6289/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funding levels and initiatives identified in that description; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaacb59dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6289/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional comments the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacb59de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6289/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy shall transmit to Congress, with the budget justification materials submitted in support of the Department of Energy budget for a fiscal year (as submitted with the budget of the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":"), a copy of the appendix described in subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacb59df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6289/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review and Certification of Department of Energy Budget by Nuclear Weapons Council","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At the time the Secretary of Energy submits the budget request of the Department of Energy for that fiscal year to the Director of the Office of Management and Budget in relation to the preparation of the budget of the President, the Secretary shall transmit a copy of the budget request of the Department to the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaacb59e0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1436"},"text":"139 Stat. 1436","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaacb59e1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaacb59e2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaacb59e3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2757"},"text":"section 2757 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaacb59e4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) to (3) headings which read as follows: “"},{"tag":"inline","attrib":{},"text":"Transmission to council","children":[],"tail":"”, “"},{"tag":"inline","attrib":{},"text":"Review","children":[],"tail":"”, and “"},{"tag":"inline","attrib":{},"text":"Department of energy response","children":[],"tail":"”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out subpars. (A) and (B) headings which read as follows: “"},{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":"” and “"},{"tag":"inline","attrib":{},"text":"Transmission to congress","children":[],"tail":"”, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
