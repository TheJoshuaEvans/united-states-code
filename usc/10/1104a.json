{"tag":"section","attrib":{"id":"ida8916eef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1104a"},"text":"§ 1104a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shared medical facilities with Department of Veterans Affairs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8916ef0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Secretary of Defense may enter into agreements with the Secretary of Veterans Affairs for the planning, design, and construction, or the leasing, of facilities to be operated as shared medical facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8916ef1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Funds by Secretary of Defense","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8916ef2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense may transfer to the Secretary of Veterans Affairs amounts as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8916ef3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the construction of a shared medical facility, amounts not in excess of the amount authorized under subsection (a)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2805"},"text":"section 2805 of this title","children":[],"tail":", if—"}],"tail":null},{"tag":"clause","attrib":{"id":"ida8916ef4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104a/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the share of the Department of Defense for the estimated cost of the project does not exceed the amount authorized under such subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8916ef5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104a/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the other requirements of such section have been met with respect to funds identified for transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8916ef6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the planning, design, and construction, or the leasing, of space for a shared medical facility, amounts appropriated for the Defense Health Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8916ef7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority to transfer funds under this section is in addition to any other authority to transfer funds available to the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8916ef8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2215"},"text":"Section 2215 of this title","children":[],"tail":" does not apply to a transfer of funds under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8916ef9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Funds to Secretary of Defense","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8916efa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount transferred to the Secretary of Defense by the Secretary of Veterans Affairs for necessary expenses for the planning, design, and construction, or the leasing, of a shared medical facility, if the amount of the share of the Department of Defense for the cost of such project does not exceed the amount specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2805/a/2"},"text":"section 2805(a)(2) of this title","children":[],"tail":", may be credited to accounts of the Department of Defense available for the construction of a shared medical facility."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida893defb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount transferred to the Secretary of Defense by the Secretary of Veterans Affairs for the purpose of the planning and design, or the leasing, of space for a shared medical facility may be credited to accounts of the Department of Defense available for such purposes, and may be used for such purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida893defc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Using accounts credited with transfers from the Secretary of Veterans Affairs under paragraph (1), the Secretary of Defense may carry out unspecified minor military construction projects, if the share of the Department of Defense for the cost of such project does not exceed the amount specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2805/a/2"},"text":"section 2805(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida893defd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Merger of Amounts Transferred","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any amount transferred to the Secretary of Veterans Affairs under subsection (b) and any amount transferred to the Secretary of Defense under subsection (c) shall be merged with and available for the same purposes and the same period as the appropriation or fund to which transferred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida893defe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriation in Advance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts may be transferred pursuant to the authority under this section only to the extent and in the amounts provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida893deff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Shared Medical Facility Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “shared medical facility”—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida893df00-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a building or buildings, or a campus, intended to be used by both the Department of Veterans Affairs and the Department of Defense for the provision of health care services, whether under the jurisdiction of the Secretary of Veterans Affairs or the Secretary of Defense, and whether or not located on a military installation or on real property under the jurisdiction of the Secretary of Veterans Affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida893df01-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1104a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any necessary building and auxiliary structure, garage, parking facility, mechanical equipment, abutting and covered sidewalks, and accommodations for attending personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida893df02-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVII/s714/a/1"},"text":"Pub. L. 117–81, div. A, title VII, § 714(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1785"},"text":"135 Stat. 1785","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/168/tVII/s706/a"},"text":"Pub. L. 117–168, title VII, § 706(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-10"},"text":"Aug. 10, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1800"},"text":"136 Stat. 1800","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida893df03-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida893df04-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida893df05-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsecs. (a), (b)(1)(B), (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/s706/a/1"},"text":"Pub. L. 117–168, § 706(a)(1)","children":[],"tail":", inserted “, or the leasing,” after “design, and construction”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/168/s706/a/2"},"text":"Pub. L. 117–168, § 706(a)(2)","children":[],"tail":", inserted “, or the leasing,” after “design”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
