{"tag":"section","attrib":{"id":"idaba4539b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12525"},"text":null,"children":[{"tag":"num","attrib":{"value":"12525"},"text":"§ 12525.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefit amounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaba4539c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12525/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Basic Benefit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The basic benefit for an insured member under the insurance program is $1,000 per month (as adjusted under subsection (d)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba4539d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12525/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reduced and Enhanced Benefits","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the regulations prescribed by the Secretary, a person enrolled for coverage under the insurance program may elect—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba4539e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12525/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reduced coverage benefit equal to one-half the amount of the basic benefit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba4539f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12525/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an enhanced benefit in the amount of $1,500, $2,000, $2,500, $3,000, $3,500, $4,000, $4,500, or $5,000 per month (as adjusted under subsection (d)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba453a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12525/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount for Partial Month","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of insurance payable to an insured member for any period of covered service that is less than one month shall be determined by multiplying ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"30","children":[],"tail":" of the monthly benefit rate for the member by the number of days of the covered service served by the member during such period."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba453a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12525/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adjustment of Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba453a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12525/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall determine annually the effect of inflation on benefits and shall adjust the amounts set forth in subsections (a) and (b)(2) to maintain the constant dollar value of the benefit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba453a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12525/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the amount of a benefit as adjusted under paragraph (1) is not evenly divisible by $10, the amount shall be rounded to the nearest multiple of $10, except that an amount evenly divisible by $5 but not by $10 shall be rounded to the next lower amount that is evenly divisible by $10.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaba453a4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s512/a/1"},"text":"Pub. L. 104–106, div. A, title V, § 512(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/301"},"text":"110 Stat. 301","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
