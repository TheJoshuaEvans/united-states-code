{"tag":"section","attrib":{"id":"ida8ee821f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1562a"},"text":"§ 1562a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complaints of retaliation by victims of sexual assault or sexual harassment and related persons: tracking by Department of Defense","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8ee8220-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Responsible Component.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ee8221-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall designate a component of the Office of the Secretary of Defense to be responsible for documenting and tracking all covered allegations of retaliation and shall ensure that the Secretaries concerned and the Inspector General of the Department of Defense provide to such component the information required to be documented and tracked as described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ee8222-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coast guard","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the department in which the Coast Guard is operating shall designate the Commandant of the Coast Guard to be responsible for carrying out the requirements of this section with respect to members of the Coast Guard when the Coast Guard is not operating as a service in the Navy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ee8223-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tracking of Allegations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of the component designated by the Secretary and the Commandant of the Coast Guard under subsection (a) shall document and track each covered allegation of retaliation, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ee8224-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that such an allegation has been reported and by whom;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ee8225-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ee8226-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of the allegation and the name of the person or persons alleged to have engaged in such retaliation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ee8227-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the component or other entity responsible for the investigation of or inquiry into the allegation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ee8228-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entry of findings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ee8229-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referral of such findings to a decisionmaker for review and action, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ee822a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the outcome of final action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ee822b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other element of information pertaining to the allegation determined appropriate by the Secretary or the head of the component designated by the Secretary or with respect to the Coast Guard, the component designated by the Commandant of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ee822c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Allegation of Retaliation Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered allegation of retaliation” means an allegation of retaliation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ee822d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" made by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8ee822e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an alleged victim of sexual assault or sexual harassment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8ee822f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual charged with providing services or support to an alleged victim of sexual assault or sexual harassment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8ee8230-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a witness or bystander to an alleged sexual assault or sexual harassment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8ee8231-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other person associated with an alleged victim of a sexual assault or sexual harassment; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ee8232-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" without regard to whether the allegation is reported to or investigated or inquired into by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8ee8233-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense Inspector General, the Inspector General of the Department of Homeland Security, or any other inspector general;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8ee8234-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a military criminal investigative organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8ee8235-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commander or other person at the direction of the commander;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8ee8236-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another armed force or civilian law enforcement organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8ee8237-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1562a/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other organization, officer, or employee of the Department of Defense or department in which the Coast Guard is operating when not operating as a service in the Navy for members of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8ee8238-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tV/s544/a"},"text":"Pub. L. 117–81, div. A, title V, § 544(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1710"},"text":"135 Stat. 1710","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXV/s7521"},"text":"Pub. L. 119–60, div. G, title LXXV, § 7521","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1813"},"text":"139 Stat. 1813","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8ee8239-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8ee823a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8ee823b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7521/1"},"text":"Pub. L. 119–60, § 7521(1)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7521/2/A"},"text":"Pub. L. 119–60, § 7521(2)(A)","children":[],"tail":", inserted “and the Commandant of the Coast Guard” after “Secretary” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7521/2/C"},"text":"Pub. L. 119–60, § 7521(2)(C)","children":[],"tail":", struck out “Department of Defense” before “component”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7521/2/B"},"text":"Pub. L. 119–60, § 7521(2)(B)","children":[],"tail":", inserted “or with respect to the Coast Guard, the component designated by the Commandant of the Coast Guard” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7521/3/A"},"text":"Pub. L. 119–60, § 7521(3)(A)","children":[],"tail":", inserted “, the Inspector General of the Department of Homeland Security,” before “or any other inspector general”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7521/3/B"},"text":"Pub. L. 119–60, § 7521(3)(B)","children":[],"tail":", substituted “armed force” for “military”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7521/3/C"},"text":"Pub. L. 119–60, § 7521(3)(C)","children":[],"tail":", inserted “or department in which the Coast Guard is operating when not operating as a service in the Navy for members of the Coast Guard” after “Department of Defense”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
