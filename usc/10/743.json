8034/b"},"text":"section 8034(b) of this title","children":[],"tail":". 5:626c(b) (proviso of last sentence) is omitted as executed, since the incumbents to whom it is applied no longer hold the offices mentioned. The exception as to the Chairman of the Joint Chiefs of Staff is included because of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s142/c"},"text":"section 142(c) of this title","children":[],"tail":". The words “and the Marine Corps” are inserted, since under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s5081"},"text":"section 5081 of this title","children":[],"tail":" the Chief of Naval Operations takes precedence over all other officers of the naval service."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida804bee9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida804beea-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s924/b/20/B"},"text":"Pub. L. 116–283, § 924(b)(20)(B)","children":[],"tail":", amended section catchline generally. Prior to amendment, section catchline read as follows: “Rank: Chief of Staff of the Army; Chief of Naval Operations; Chief of Staff of the Air Force; Commandant of the Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s924/b/20/A"},"text":"Pub. L. 116–283, § 924(b)(20)(A)","children":[],"tail":", substituted “the Commandant of the Marine Corps, and the Chief of Space Operations” for “and the Commandant of the Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s924/b/1/H"},"text":"Pub. L. 116–283, § 924(b)(1)(H)","children":[],"tail":", substituted “Marine Corps, and Space Force” for “and Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/s1314/b/5/A"},"text":"Pub. L. 100–180, § 1314(b)(5)(A)","children":[],"tail":", inserted “; Commandant of the Marine Corps” after “Air Force” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/s1314/a/2"},"text":"Pub. L. 100–180, § 1314(a)(2)","children":[],"tail":", made technical correction in directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/99/433"},"text":"Pub. L. 99–433","children":[],"tail":". See 1986 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433"},"text":"Pub. L. 99–433","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/s1314/a/2"},"text":"Pub. L. 100–180, § 1314(a)(2)","children":[],"tail":", inserted reference to the Commandant of the Marine Corp and the Vice Chairman of the Joint Chiefs of Staff."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “active-duty list” for “active list”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida804beeb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida804beec-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tai