{"tag":"section","attrib":{"id":"ida804bee4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s743"},"text":null,"children":[{"tag":"num","attrib":{"value":"743"},"text":"§ 743.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rank: Chief of Staff of the Army; Chief of Naval Operations; Chief of Staff of the Air Force; Commandant of the Marine Corps; Chief of Space Operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Chief of Staff of the Army, the Chief of Naval Operations, the Chief of Staff of the Air Force, the Commandant of the Marine Corps, and the Chief of Space Operations rank among themselves according to dates of appointment to those offices, and rank above all other officers on the active-duty list of the Army, Navy, Air Force, Marine Corps, and Space Force, except the Chairman and the Vice Chairman of the Joint Chiefs of Staff.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida804bee5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/34"},"text":"70A Stat. 34","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tI/s501/11"},"text":"Pub. L. 96–513, title I, § 501(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2908"},"text":"94 Stat. 2908","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/433/tII/s202/b"},"text":"Pub. L. 99–433, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1010"},"text":"100 Stat. 1010","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tXIII/s1314/a/2"},"text":"Pub. L. 100–180, div. A, title XIII, § 1314(a)(2)","children":[],"tail":", (b)(5)(A), "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1175"},"text":"101 Stat. 1175","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/1/H"},"text":"Pub. L. 116–283, div. A, title IX, § 924(b)(1)(H)","children":[],"tail":", (20)(A), (B), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3820"},"text":"134 Stat. 3820","children":[],"tail":", 3823.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida804bee6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida804bee7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida804bee8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"tex