{"tag":"section","attrib":{"id":"idabb9d7b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14704"},"text":null,"children":[{"tag":"num","attrib":{"value":"14704"},"text":"§ 14704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selective early removal from the reserve active-status list","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabb9d7b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Boards To Recommend Officers for Removal From Reserve Active-Status List","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb9d7b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14704/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever the Secretary of the military department concerned determines that there are in any reserve component under the jurisdiction of the Secretary too many officers in any grade and competitive category who have at least 30 years of service computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14706"},"text":"section 14706 of this title","children":[],"tail":" or at least 20 years of service computed under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12732"},"text":"section 12732 of this title","children":[],"tail":", the Secretary may convene a selection board under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s14101/b"},"text":"section 14101(b) of this title","children":[],"tail":" to consider officers on the reserve active-status list who are in that grade and competitive category, and who have that amount of service, for the purpose of recommending officers by name for removal from that list."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb9d7b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14704/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (3), the list of officers in a reserve component whose names are submitted to a board under paragraph (1) shall include each officer on the reserve active-status list for that reserve component in the same grade and competitive category whose position on the reserve active-status list is between—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabb9d7b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14704/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that of the most junior officer in that grade and competitive category whose name is submitted to the board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabb9d7ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14704/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that of the most senior officer in that grade and competitive category whose name is submitted to the board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb9d7bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14704/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A list submitted to a board under paragraph (1) may not include an officer who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabb9d7bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14704/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been approved for voluntary retirement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabb9d7bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14704/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is to be involuntarily retired under any provision of law during the fiscal year in which the board is convened or during the following fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb9d7be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specification of Number of Officers Who May Be Recommended for Separation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the military department concerned shall specify the number of officers described in subsection (a)(1) that a board may recommend for separation under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb9d7bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Separation of Officers Selected","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of an officer recommended for separation in the report of a board under subsection (a), the Secretary may separate the officer in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14514"},"text":"section 14514 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb9d7c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the military department concerned shall prescribe regulations for the administration of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabb9d7c1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2956"},"text":"108 Stat. 2956","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tV/s503/b"},"text":"Pub. L. 113–66, div. A, title V, § 503(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/750"},"text":"127 Stat. 750","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb9d7c2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabb9d7c3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idabb9d7c4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 3850 and 8850 of this title, prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1629/a/3"},"text":"Pub. L. 103–337, § 1629(a)(3)","children":[],"tail":", (c)(3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabb9d7c5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s503/b/1"},"text":"Pub. L. 113–66, § 503(b)(1)","children":[],"tail":", designated existing provisions as par. (1), substituted “officers on the reserve active-status list” for “all officers on that list” and “that list.” for “the reserve active-status list, in the number specified by the Secretary by each grade and competitive category.” in par. (1), and added pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s503/b/2"},"text":"Pub. L. 113–66, § 503(b)(2)","children":[],"tail":", (3), added subsec. (b) and redesignated former subsecs. (b) and (c) as (c) and (d), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabb9d7c6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabb9d7c7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691/b/1"},"text":"section 1691(b)(1) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
