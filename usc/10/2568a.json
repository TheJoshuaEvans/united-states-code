{"tag":"section","attrib":{"id":"ida98bd445-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2568a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2568a"},"text":"§ 2568a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Damaged personal protective equipment: award to members separating from the Armed Forces and veterans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida98bd446-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2568a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of a military department, acting through a disposition service distribution center of the Defense Logistics Agency, may award to a covered individual the demilitarized PPE of that covered individual. The award of PPE under this section shall be without cost to the covered individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida98bd447-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2568a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida98bd448-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2568a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered individual” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida98bd449-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2568a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a member of the armed forces—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida98bd44a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2568a/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the jurisdiction of the Secretary concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida98bd44b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2568a/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is separating from the armed forces; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida98bd44c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2568a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a veteran who was under the jurisdiction of the Secretary concerned while a member of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida98bd44d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2568a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “PPE” means personal protective equipment that was damaged in combat or otherwise—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida98bd44e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2568a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the deployment of a covered individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida98bd44f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2568a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida98bd450-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVI/s623/a"},"text":"Pub. L. 115–232, div. A, title VI, § 623(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1800"},"text":"132 Stat. 1800","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
