":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab2ab773-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab2ab774-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Degrees for Persons Who Graduated Before Accrediting of Naval Academy","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041/s35"},"text":"Act Aug. 10, 1956, ch. 1041, § 35","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/634"},"text":"70A Stat. 634","children":[],"tail":", provided in part that, under conditions prescribed by the Secretary of the Navy, the Superintendent of the United States Naval Academy “may confer the degree of bachelor of science upon living graduates of [the] Academy who were graduated before the date of accrediting of [the] Academy and who have met the requirements of [the] Academy for that degree.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
