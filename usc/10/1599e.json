{"tag":"section","attrib":{"id":"ida8fcda5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1599e"},"text":"§ 1599e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of retention bonuses to DOD civilian employees in Guam.","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5754"},"text":"section 5754 of title 5","children":[],"tail":", the Secretary of Defense or Secretary of a military department may waive the limit established under subsection (e)(1) of such section and pay an otherwise eligible employee or category of employees in the territory of Guam retention bonuses of up to 50 percent of basic pay, based on a critical agency need."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida8fcda5b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXI/s1109"},"text":"Pub. L. 119–60, div. A, title XI, § 1109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1075"},"text":"139 Stat. 1075","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8fcda5c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8fcda5d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida8fcda5e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1599e, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tXI/s1105/a/1"},"text":"Pub. L. 114–92, div. A, title XI, § 1105(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1023"},"text":"129 Stat. 1023","children":[],"tail":", related to probationary period for employees, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXI/s1106/a/1"},"text":"Pub. L. 117–81, div. A, title XI, § 1106(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1950"},"text":"135 Stat. 1950","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2022-12-31"},"text":"Dec. 31, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8fcda5f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8fcda60-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of Repeal","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXI/s1106/a/1"},"text":"Pub. L. 117–81, div. A, title XI, § 1106(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1950"},"text":"135 Stat. 1950","children":[],"tail":", provided that the repeal of former "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1599e"},"text":"section 1599e of this title","children":[],"tail":" was effective "},{"tag":"date","attrib":{"date":"2022-12-31"},"text":"Dec. 31, 2022","children":[],"tail":". Conforming amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1106"},"text":"section 1106 of Pub. L. 117–81","children":[],"tail":" (amending sections 3321, 3393, 7501, 7511, and 7541 of Title 5, Government Organization and Employees) were executed as if effective at the same time as the repeal, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8fcda61-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXI/s1106/a/2"},"text":"Pub. L. 117–81, div. A, title XI, § 1106(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1950"},"text":"135 Stat. 1950","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dA/tXI/s1106/a/2"},"text":"“The modification of probationary periods for covered employees (as that term is defined in such [former] section 1599e [meaning former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1599e"},"text":"10 U.S.C. 1599e","children":[],"tail":"] as in effect on the date immediately preceding the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":"]) by operation of the amendment made by paragraph (1) [repealing former "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1599e"},"text":"section 1599e of this title","children":[],"tail":"] shall only apply to an individual appointed as such an employee on or after the effective date specified in paragraph (1) [see Effective Date of Repeal note above].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
