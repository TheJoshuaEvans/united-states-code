{"tag":"section","attrib":{"id":"idab155a22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8226"},"text":null,"children":[{"tag":"num","attrib":{"value":"8226"},"text":"§ 8226.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fatality reviews","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab155a23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8226/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of Fatalities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Navy shall conduct a multidisciplinary, impartial review (referred to as a “fatality review”) in the case of each fatality known or suspected to have resulted from domestic violence or child abuse against any of the following.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab155a24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8226/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the naval service on active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab155a25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8226/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A current or former dependent of a member of the naval service on active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab155a26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8226/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A current or former intimate partner who has a child in common or has shared a common domicile with a member of the naval service on active duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab155a27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8226/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matters To Be Included","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report of a fatality review under subsection (a) shall, at a minimum, include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab155a28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8226/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An executive summary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab155a29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8226/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Data setting forth victim demographics, injuries, autopsy findings, homicide or suicide methods, weapons, police information, assailant demographics, and household and family information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab155a2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8226/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Legal disposition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab155a2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8226/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" System intervention and failures, if any, within the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab155a2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8226/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A discussion of significant findings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab155a2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8226/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommendations for systemic changes, if any, within the Department of the Navy and the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab155a2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8226/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" OSD ","children":[{"tag":"inline","attrib":{},"text":"Guidance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe guidance, which shall be uniform for the military departments, for the conduct of reviews by the Secretary under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab155a2f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tV/s576/b/1"},"text":"Pub. L. 108–136, div. A, title V, § 576(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1487"},"text":"117 Stat. 1487","children":[],"tail":", § 6036; renumbered § 8226, "},{"tag":"ref","attrib":{"href"