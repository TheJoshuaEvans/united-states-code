{"tag":"section","attrib":{"id":"idab855a20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9777"},"text":null,"children":[{"tag":"num","attrib":{"value":"9777"},"text":"§ 9777.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permits: military reservations; landing ferries, erecting bridges, driving livestock","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Whenever the Secretary of the Air Force considers that it can be done without injury to the reservation or inconvenience to the military forces stationed there, he may permit—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab855a21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9777/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the landing of ferries at a military reservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab855a22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9777/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the erection of bridges on a military reservation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab855a23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9777/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the driving of livestock across a military reservation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab855a24-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/591"},"text":"70A Stat. 591","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{