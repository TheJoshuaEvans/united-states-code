{"tag":"section","attrib":{"id":"idab534d2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8873"},"text":null,"children":[{"tag":"num","attrib":{"value":"8873"},"text":"§ 8873.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of expenses to marshals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The marshal shall be allowed his actual and necessary expenses for the custody, care, preservation, insurance, and sale or other disposal of the prize property, and for executing any order of the court in the prize cause. Charges of the marshal for expenses or disbursements shall be allowed only upon his oath that they have been necessarily incurred for the purpose stated.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab534d2c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/481"},"text":"70A Stat. 481","children":[],"tail":", § 7673; renumbered § 8873, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/9"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab534d2d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab534d2e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab534d2f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tai