{"tag":"section","attrib":{"id":"idaa39eea9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3793"},"text":null,"children":[{"tag":"num","attrib":{"value":"3793"},"text":"§ 3793.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copyrights, patents, designs, etc.; acquisition","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Funds appropriated for a military department available for making or procuring supplies may be used to acquire any of the following if the acquisition relates to supplies or processes produced or used by or for, or useful to, that department:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa39eeaa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3793/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Copyrights, patents, and applications for patents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa39eeab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3793/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Licenses under copyrights, patents, and applications for patents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa39eeac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3793/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Design and process data, technical data, and computer software.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa39eead-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3793/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Releases for past infringement of patents or copyrights or fo