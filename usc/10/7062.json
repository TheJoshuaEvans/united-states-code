{"tag":"section","attrib":{"id":"idaad9b0cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7062"},"text":null,"children":[{"tag":"num","attrib":{"value":"7062"},"text":"§ 7062.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy; composition; organized peace establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaad9b0d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7062/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It is the intent of Congress to provide an Army that is capable, in conjunction with the other armed forces, of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad9b0d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7062/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserving the peace and security, and providing for the defense, of the United States, the Commonwealths and possessions, and any areas occupied by the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b0d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7062/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the national policies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b0d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7062/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing the national objectives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b0d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7062/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overcoming any nations responsible for aggressive acts that imperil the peace and security of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad9b0d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7062/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In general, the Army, within the Department of the Army, includes land combat and service forces and such aviation and water transport as may be organic therein. It shall be organized, trained, and equipped primarily for prompt and sustained combat incident to operations on land. It is responsible for the preparation of land forces necessary for the effective prosecution of war except as otherwise assigned and, in accordance with integrated joint mobilization plans, for the expansion of the peacetime components of the Army to meet the needs of war.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad9b0d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7062/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Army consists of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad9b0d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7062/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Regular Army, the Army National Guard of the United States, the Army National Guard while in the service of the United States and the Army Reserve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b0d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7062/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all persons appointed or enlisted in, or conscripted into, the Army without component.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad9b0d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7062/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The organized peace establishment of the Army consists of all—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad9b0da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7062/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" military organizations of the Army with their installations and supporting and auxiliary elements, including combat, training, administrative, and logistic elements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b0db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7062/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the Army, including those not assigned to units;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"necessary to form the basis for a complete and immediate mobilization for the national defense in the event of a national emergency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad9b0dc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/166"},"text":"70A Stat. 166","children":[],"tail":", § 3062; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1057/a/6"},"text":"Pub. L. 109–163, div. A, title X, § 1057(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3441"},"text":"119 Stat. 3441","children":[],"tail":"; renumbered § 7062, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1838"},"text":"132 Stat. 1838","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaad9b0dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaad9b0de-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaad9b0df-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3062(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3062(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3062(c)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3062(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:20.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"5:181–1(e).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1b.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:20i.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-07-10/ch454/s2"},"text":"July 10, 1950, ch. 454, § 2","children":[],"tail":", § 101, "},{"tag":"html:a","attrib":{"href":"/us/stat/64/321"},"text":"64 Stat. 321","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1947-07-26/ch343/s205/e"},"text":"July 26, 1947, ch. 343, § 205(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:1021.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-06-28/ch383/s301"},"text":"June 28, 1950, ch. 383, § 301","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/268"},"text":"64 Stat. 268","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608/s807/b"},"text":"July 9, 1952, ch. 608, § 807(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/66/508"},"text":"66 Stat. 508","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608/s301"},"text":"July 9, 1952, ch. 608, § 301","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/66/498"},"text":"66 Stat. 498","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), 10:20 (1st 19 words) is omitted as surplusage. The word “Commonwealth” is inserted to reflect the present status of Puerto Rico. The words “any areas occupied by the United States” are substituted for the words “occupied areas wherever located”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “consists of” are substituted for the word “includes”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “the Army National Guard while in the service of the United States” are substituted for the words “all persons serving in the Army under call * * * under any provision of law, including members of the National Guard of the several States, Territories, and the District of Columbia when in the service of the United States pursuant to call as provided by law”. 10:1b (words between 1st and 3d semicolons) and 50:1021 (last sentence) are omitted, since the components listed include their members.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “or inducted” are omitted as covered by the word “conscripted”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), 10:20i (8th through 38th words) is omitted as surplusage. The words “consists of all” are substituted for the words “shall include all of”. The words “members of the Army” are substituted for the word “personnel”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaad9b0e0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaad9b0e1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3062"},"text":"section 3062 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “Commonwealths and possessions” for “Territories, Commonwealths, and possessions”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaad9b0e2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaad9b0e3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
