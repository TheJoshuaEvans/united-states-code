{"tag":"section","attrib":{"id":"ida82ae5c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s914"},"text":null,"children":[{"tag":"num","attrib":{"value":"914"},"text":"§ 914.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 114. Endangerment offenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida82ae5ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s914/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reckless Endangerment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter who engages in conduct that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82ae5cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s914/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is wrongful and reckless or is wanton; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82ae5cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s914/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is likely to produce death or grievous bodily harm to another person;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82ae5cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s914/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dueling","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82ae5ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s914/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who fights or promotes, or is concerned in or connives at fighting, a duel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82ae5cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s914/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, having knowledge of a challenge sent or about to be sent, fails to report the facts promptly to the proper authority;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82ae5d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s914/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Firearm Discharge, Endangering Human Life","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person subject to this chapter who, willfully and wrongly, discharges a firearm, under circumstances such as to endanger human life shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82ae5d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s914/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Carrying Concealed Weapon","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person subject to this chapter who unlawfully carries a dangerous weapon concealed on or about his person shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida82ae5d2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/72"},"text":"70A Stat. 72","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLX/s5426"},"text":"Pub. L. 114–328, div. E, title LX, § 5426","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2948"},"text":"130 Stat. 2948","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida82ae5d3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida82ae5d4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida82ae5d5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","att