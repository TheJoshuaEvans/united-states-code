{"tag":"section","attrib":{"id":"ida7900472-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s239e"},"text":null,"children":[{"tag":"num","attrib":{"value":"239e"},"text":"§ 239e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nuclear command, control, and communications: major force program and budget assessment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7900473-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s239e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Major Force Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall establish a unified major force program for nuclear command, control, and communications programs pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s222/b"},"text":"section 222(b) of this title","children":[],"tail":" to prioritize such programs in accordance with the requirements of the Department of Defense and national security."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7900474-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s239e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Budget Assessment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7900475-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s239e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall include with the defense budget materials for each of fiscal years 2025 through 2030 a report on the budget for nuclear command, control, and communications programs of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7900476-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s239e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each report on the budget for nuclear command, control, and communications programs of the Department under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7900477-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s239e/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An overview of the budget, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida7900478-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s239e/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comparison between that budget, the previous budget, the most recent and prior future-years defense program submitted to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s221"},"text":"section 221 of this title","children":[],"tail":" (such comparison shall exclude the responsibility for research and development of the continuing improvement of such nuclear command, control, and communications program), and the amounts appropriated for such nuclear command, control, and communications programs during the previous fiscal year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7900479-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s239e/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific identification, as a budgetary line item, for the funding under such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida790047a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s239e/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the budget, including significant changes, priorities, challenges, and risks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida790047b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s239e/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any additional matters the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida790047c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s239e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each report under paragraph (1) shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida790047d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s239e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida790047e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s239e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “budget”, with respect to a fiscal year, means the budget for that fiscal year that is submitted to Congress by the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida790047f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s239e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “defense budget materials”, with respect to a fiscal year, means the materials submitted to Congress by the Secretary of Defense in support of the budget for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7900480-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s239e/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “nuclear command, control, and communications programs” means programs through which presidential authority and operational command and control of nuclear weapons is conducted, including programs that facilitate senior-level decisions on nuclear weapons employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7900481-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVI/s1631"},"text":"Pub. L. 118–31, div. A, title XVI, § 1631","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/591"},"text":"137 Stat. 591","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
