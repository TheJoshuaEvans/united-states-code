{"tag":"section","attrib":{"id":"ida8916e6c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1098"},"text":null,"children":[{"tag":"num","attrib":{"value":"1098"},"text":"§ 1098.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentives for participation in cost-effective health care plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8916e6d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1098/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver of Limitations and Copayments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), the Secretary of Defense, with respect to any plan contracted for under the authority of section 1079 or 1086 of this title, may waive, in whole or in part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8916e6e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1098/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any limitation set out in the second sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1079/a"},"text":"section 1079(a) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8916e6f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1098/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any requirement for payment by the patient under section 1079(b) or 1086(b) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8916e70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1098/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination and Report","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8916e71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1098/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (3), the Secretary may waive a limitation or requirement as authorized by subsection (a) if the Secretary determines that during the period of the waiver such a plan will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8916e72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1098/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be less costly to the Government than a plan subject to such limitations or payment requirements; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8916e73-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1098/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide better services than those provided by a plan subject to such limitations or payment requirements at no additional cost to the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8916e74-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1098/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall submit to the Committee on Armed Services of the Senate and the Committee on Armed Services of the House of Representatives a report with respect to a waiver under paragraph (1), including a comparison of costs of and benefits available under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8916e75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1098/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan with respect to which the limitations and payment requirements are waived; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8916e76-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1098/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan with respect to which there is no such waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8916e77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1098/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A waiver under paragraph (1) may not take effect until the end of the 180-day period beginning on the date on which the Secretary submits the report required by paragraph (2) with respect to such waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8916e78-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tVII/s701/a/1"},"text":"Pub. L. 99–661, div. A, title VII, § 701(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3895"},"text":"100 Stat. 3895","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIV/s1484/h/1"},"text":"Pub. L. 101–510, div. A, title XIV, § 1484(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1717"},"text":"104 Stat. 1717","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1502/a/1"},"text":"Pub. L. 104–106, div. A, title XV, § 1502(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/502"},"text":"110 Stat. 502","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1067/1"},"text":"Pub. L. 106–65, div. A, title X, § 1067(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/774"},"text":"113 Stat. 774","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8916e79-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8916e7a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8916e7b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “and the Committee on Armed Services” for “and the Committee on National Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" substituted “Committee on Armed Services of the Senate and the Committee on National Security of the House of Representatives” for “Committees on Armed Services of the Senate and House of Representatives”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" substituted “subsection (b)” for “subsections (b) and (c)” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
