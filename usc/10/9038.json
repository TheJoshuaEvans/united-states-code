,"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/617"},"text":"113 Stat. 617","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 507(d)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–104; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tV/s501/a"},"text":"Pub. L. 107–314, div. A, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2529"},"text":"116 Stat. 2529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s536/a"},"text":"Pub. L. 108–375, div. A, title V, § 536(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1901"},"text":"118 Stat. 1901","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tV/s502"},"text":"Pub. L. 114–328, div. A, title V, § 502","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"ll","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2106"},"text":"130 Stat. 2106","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1051/a/30"},"text":"Pub. L. 115–91, div. A, title X, § 1051(a)(30)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1562"},"text":"131 Stat. 1562","children":[],"tail":"; renumbered § 9038, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/c"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1833"},"text":"132 Stat. 1833","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab5f34e8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab5f34e9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab5f34ea-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8038"},"text":"section 8038 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" struck out par. (1) designation before “The Chief” and struck out par. (2) which read as follows: “The Secretary of Defense shall transmit the annual report of the Chief of Air Force Reserve under paragraph (1) to Congress, together with such comments on the report as the Secretary considers appropriate. The report shall be transmitted at the same time each year that the annual report of the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s113"},"text":"section 113 of this title","children":[],"tail":" is submitted to Congress.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":", in heading, struck out “; Grade” after “Reappointment”, and in text, struck out par. (1) designation before “The Chief of Air Force Reserve” and struck out par. (2) which read as follows: “The Chief of Air Force Reserve, while so serving, holds the grade of lieutenant general.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2006-12-31"},"text":"December 31, 2006","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2004-12-31"},"text":"December 31, 2004","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2004-12-31"},"text":"December 31, 2004","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2003-10-01"},"text":"October 1, 2003","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “The President, by and with the advice and consent of the Senate, shall appoint the Chief of Air Force Reserve from officers of the Air Force Reserve not on active duty, or on active duty under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10211"},"text":"section 10211 of this title","children":[],"tail":", who—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) have had at least 10 years of commissioned service in the Air Force;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) are in grade of brigadier general and above; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) have been recommended by the Secretary of the Air Force.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “The Chief of Air Force Reserve holds office for four years, but may be removed for cause at any time. He is eligible to succeed himself. If he holds a lower reserve grade, he shall be appointed in the grade of major general for service in the Air Force Reserve. However, if selected in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12505"},"text":"section 12505 of this title","children":[],"tail":", he may be appointed in the grade of lieutenant general.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" inserted at end “However, if selected in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12505"},"text":"section 12505 of this title","children":[],"tail":", he may be appointed in the grade of lieutenant general.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" struck out “(1)” before “The Chief of Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" added subsecs. (d) to (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" substituted “10211” for “265”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/s521/a/2"},"text":"Pub. L. 99–433, § 521(a)(2)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8019"},"text":"section 8019 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/s522/g/3"},"text":"Pub. L. 99–433, § 522(g)(3)","children":[],"tail":", struck out the comma after “Chief of Staff”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab5f34eb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab5f34ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab5f34ed-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment; Applicability to Incumbents","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", with special provision for an officer who is a covered position incumbent who is appointed under that amendment to the grade of lieutenant general or vice admiral, see section 554(g), (h) of "},{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7038"},"text":"section 7038 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab5f34ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691"},"text":"section 1691 of Pub. L. 103–337","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idab5f34ef-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of first calendar month following date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/168"},"text":"Pub. L. 90–168","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1967-12-01"},"text":"Dec. 1, 1967","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/168/s7"},"text":"section 7 of Pub. L. 90–168","children":[],"tail":", set out as an Effective Date of 1967 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s138"},"text":"section 138 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
