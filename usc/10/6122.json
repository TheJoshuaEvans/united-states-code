{"tag":"section","attrib":{"id":"idaabd01ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6122"},"text":null,"children":[{"tag":"num","attrib":{"value":"6122"},"text":"§ 6122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacturing infrastructure for refabrication and certification of nuclear weapons stockpile","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaabd01cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Manufacturing Program","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabd01d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6122/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Energy shall carry out a program for purposes of establishing within the Government a manufacturing infrastructure that has the capabilities of meeting the following objectives:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaabd01d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6122/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide a stockpile surveillance engineering base.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabd01d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6122/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To refabricate and certify weapon components and types in the enduring nuclear weapons stockpile, as necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabd01d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6122/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To fabricate and certify new nuclear warheads, as necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabd01d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6122/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To support nuclear weapons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabd01d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6122/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To supply sufficient tritium in support of nuclear weapons to ensure an upload hedge in the event circumstances require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabd01d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6122/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The purpose of the program carried out under paragraph (1) shall also be to develop manufacturing capabilities and capacities necessary to meet the requirements specified in the annual Nuclear Weapons Stockpile Memorandum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabd01d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Capabilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The manufacturing infrastructure established under the program under subsection (a) shall include the following capabilities (modernized to attain the objectives referred to in that subsection):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabd01d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6122/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The weapons assembly and high explosives manufacturing capabilities of the Pantex Plant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabd01d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6122/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The weapon secondary fabrication capabilities of the Y–12 National Security Complex, Oak Ridge, Tennessee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabd01da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6122/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The capabilities of the Savannah River Site relating to tritium recycling and processing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabd01db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6122/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The fissile material component processing and fabrication capabilities of the Savannah River Plutonium Processing Facility and the Los Alamos National Laboratory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabd01dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6122/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The non-nuclear component capabilities of the Kansas City National Security Campus, Kansas City, Missouri.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaabd01dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2)(B), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1358"},"text":"139 Stat. 1358","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaabd01de-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaabd01df-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaabd01e0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2532"},"text":"section 2532 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaabd01e1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
