{"tag":"section","attrib":{"id":"ida7f8d878-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s663"},"text":null,"children":[{"tag":"num","attrib":{"value":"663"},"text":"§ 663.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint duty assignments after completion of joint professional military education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7f8d879-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s663/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Joint Qualified Officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall ensure that each officer designated as a joint qualified officer who graduates from a school within the National Defense University specified in subsection (c) shall be assigned to a joint duty assignment for that officer’s next duty assignment after such graduation (unless the officer receives a waiver of that requirement by the Secretary in an individual case).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f8d87a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s663/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Officers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7f8d87b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s663/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall ensure that a high proportion (which shall be greater than 50 percent) of the officers graduating from a school within the National Defense University specified in subsection (c) who are not designated as a joint qualified officer shall receive assignments to a joint duty assignment (or, as authorized by the Secretary in an individual case, to a joint assignment other than a joint duty assignment) as their next duty assignment after such graduation or, to the extent authorized in paragraph (2), as their second duty assignment after such graduation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f8d87c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s663/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may, if the Secretary determines that it is necessary to do so for the efficient management of officer personnel, establish procedures to allow up to one-half of the officers subject to the assignment requirement in paragraph (1) to be assigned to such an assignment as their second (rather than first) assignment after such graduation from a school referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f8d87d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s663/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Schools Within the National Defense University","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, a school within the National Defense University specified in this subsection is one of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7f8d87e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s663/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National War College.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f8d87f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s663/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Dwight D. Eisenhower School for National Security and Resource Strategy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f8d880-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s663/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Joint Forces Staff College.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f8d881-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s663/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for Officers Graduating From Other-than-in-residence Programs","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7f8d882-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s663/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) does not apply to an officer graduating from a school within the National Defense University specified in subsection (c) following pursuit of a program on an other-than-in-residence basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f8d883-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s663/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (b) does not apply with respect to any group of officers graduating from a school within the National Defense University specified in subsection (c) following pursuit of a program on an other-than-in-residence basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7f8d884-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tIV/s401/a"},"text":"Pub. L. 99–433, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1027"},"text":"100 Stat. 1027","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXI/s1123/c/1"},"text":"Pub. L. 101–189, div. A, title XI, § 1123(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1557"},"text":"103 Stat. 1557","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tIX/s912/a"},"text":"Pub. L. 102–190, div. A, title IX, § 912(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1452"},"text":"105 Stat. 1452","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tIX/s933/a"},"text":"Pub. L. 103–160, div. A, title IX, § 933(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1735"},"text":"107 Stat. 1735","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/a/6"},"text":"Pub. L. 107–107, div. A, title X, § 1048(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1223"},"text":"115 Stat. 1223","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tX/s1062/a/5"},"text":"Pub. L. 107–314, div. A, title X, § 1062(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2650"},"text":"116 Stat. 2650","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s532/b"},"text":"Pub. L. 108–375, div. A, title V, § 532(b)","children":[],"tail":"–(c)(2)(A), "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1900"},"text":"118 Stat. 1900","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s518"},"text":"Pub. L. 109–364, div. A, title V, § 518","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2190"},"text":"120 Stat. 2190","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title V, § 522(b), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4445"},"text":"122 Stat. 4445","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s503"},"text":"Pub. L. 112–81, div. A, title V, § 503","children":[],"tail":", div. B, title XXVIII, § 2861(c), "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1388"},"text":"125 Stat. 1388","children":[],"tail":", 1701.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7f8d885-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7f8d886-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7f8d887-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s503/a/1"},"text":"Pub. L. 112–81, § 503(a)(1)","children":[],"tail":", inserted “(or, as authorized by the Secretary in an individual case, to a joint assignment other than a joint duty assignment)” after “to a joint duty assignment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s503/a/2"},"text":"Pub. L. 112–81, § 503(a)(2)","children":[],"tail":", substituted “the assignment” for “the joint duty assignment” and “such an assignment” for “a joint duty assignment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s2861/c"},"text":"Pub. L. 112–81, § 2861(c)","children":[],"tail":", substituted “Dwight D. Eisenhower School for National Security and Resource Strategy” for “Industrial College of the Armed Forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s503/b"},"text":"Pub. L. 112–81, § 503(b)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsecs. (a), (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", in subsec. (a), substituted “Qualified” for “Specialty” in heading and “designated as a joint qualified officer” for “with the joint specialty” in text, and, in subsec. (b)(1), substituted “are not designated as a joint qualified officer” for “do not have the joint specialty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsecs. (a), (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s518/a/1"},"text":"Pub. L. 109–364, § 518(a)(1)","children":[],"tail":", (2)(A), substituted “a school within the National Defense University specified in subsection (c)” for “a joint professional military education school”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s518/a/2/B"},"text":"Pub. L. 109–364, § 518(a)(2)(B)","children":[],"tail":", substituted “a school referred to in paragraph (1)” for “a joint professional military education school”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s518/b"},"text":"Pub. L. 109–364, § 518(b)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s532/c/2/A"},"text":"Pub. L. 108–375, § 532(c)(2)(A)","children":[],"tail":", substituted “Joint duty assignments after completion of joint professional military education” for “Education” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s532/c/1/A"},"text":"Pub. L. 108–375, § 532(c)(1)(A)","children":[],"tail":", (B), redesignated subsec. (d)(1) as (a), inserted heading, and struck out heading and text of former subsec. (a) which related to capstone course for new general and flag officers. See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2153"},"text":"section 2153 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s532/c/1/C"},"text":"Pub. L. 108–375, § 532(c)(1)(C)","children":[],"tail":"–(F), redesignated subsec. (d)(2)(A) as (b)(1) and substituted “in paragraph (2)” for “in subparagraph (B)”, redesignated subsec. (d)(2)(B) as (b)(2) and substituted “in paragraph (1)” for “in subparagraph (A)”, and inserted subsec. heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s532/b"},"text":"Pub. L. 108–375, § 532(b)","children":[],"tail":", transferred subsec. (b), relating to joint military education schools, to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2152/b"},"text":"section 2152(b) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s532/b"},"text":"Pub. L. 108–375, § 532(b)","children":[],"tail":", transferred subsec. (c), relating to other professional military education schools, to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2152/c"},"text":"section 2152(c) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s532/c/1/B"},"text":"Pub. L. 108–375, § 532(c)(1)(B)","children":[],"tail":", (C), (E), redesignated par. (1) as subsec. (a), redesignated subpars. (A) and (B) of par. (2) as pars. (1) and (2), respectively, of subsec. (b), and struck out heading “Post-Education Joint Duty Assignments”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s532/c/1/A"},"text":"Pub. L. 108–375, § 532(c)(1)(A)","children":[],"tail":", struck out heading and text of subsec. (e) which related to the duration of the principal course of instruction offered at the Joint Forces Staff College. See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2156"},"text":"section 2156 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" substituted “Joint Forces Staff College” for “Armed Forces Staff College”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" substituted “Joint Forces Staff College” for “Armed Forces Staff College” in subsec. heading and in text of par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":" amended subsec. (d) generally. Prior to amendment, subsec. (d) read as follows: “"},{"tag":"inline","attrib":{},"text":"Post-Education Duty Assignments","children":[],"tail":".—The Secretary of Defense shall ensure that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) unless waived by the Secretary in an individual case, each officer with the joint specialty who graduates from a joint professional military education school shall be assigned to a joint duty assignment for that officer’s next duty assignment; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) a high proportion (which shall be greater than 50 percent) of the other officers graduating from a joint professional military education school also receive assignments to a joint duty assignment as their next duty assignment.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7f8d888-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7f8d889-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tIX/s933/b"},"text":"Pub. L. 103–160, div. A, title IX, § 933(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1736"},"text":"107 Stat. 1736","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/160/dA/tIX/s933/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply with respect to officers graduating from joint professional military education schools after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7f8d88a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tIX/s912/b"},"text":"Pub. L. 102–190, div. A, title IX, § 912(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1452"},"text":"105 Stat. 1452","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tIX/s921"},"text":"Pub. L. 102–484, div. A, title IX, § 921","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2473"},"text":"106 Stat. 2473","children":[],"tail":", provided that the amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/s912/a/2"},"text":"section 912(a)(2) of Pub. L. 102–190","children":[],"tail":" to this section was not to apply with respect to the Armed Forces Staff College until "},{"tag":"date","attrib":{"date":"1994-01-01"},"text":"Jan. 1, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7f8d88b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation of Subsection (e)","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXI/s1123/c/2"},"text":"Pub. L. 101–189, div. A, title XI, § 1123(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1557"},"text":"103 Stat. 1557","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/189/dA/tXI/s1123/c/2"},"text":"“Subsection (e) of such section, as added by paragraph (1), shall be implemented by the Secretary of Defense not later than two years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7f8d88c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Education Requirements; Joint Officer Management Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tIV/s406/d"},"text":"Pub. L. 99–433, title IV, § 406(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1033"},"text":"100 Stat. 1033","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/433/tIV/s406/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Capstone course","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) of section 663 of such title [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s663/a"},"text":"10 U.S.C. 663(a)","children":[],"tail":"] (as added by section 401) shall apply with respect to officers selected in reports of officer selection boards submitted to the Secretary concerned after the end of the 120-day period beginning on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of military education schools","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The first review under subsections (b) and (c) of such section shall be completed not later than 120 days after the date of the enactment of this Act. The Secretary of Defense shall submit to Congress a report on the results of the review at each Department of Defense school not later than 60 days thereafter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such subsections shall be implemented so that the revised curricula take effect with respect to courses beginning after July 1987.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Post-education duty assignments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (d) of such section shall take effect with respect to classes graduating from joint professional military education schools after January 1987.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
