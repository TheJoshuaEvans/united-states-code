{"tag":"section","attrib":{"id":"ida9eda27b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878"},"text":null,"children":[{"tag":"num","attrib":{"value":"2878"},"text":"§ 2878.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conveyance or lease of existing property and facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9eda27c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conveyance or Lease Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may convey or lease property or facilities (including ancillary supporting facilities) to eligible entities for purposes of using the proceeds of such conveyance or lease to carry out activities under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9eda27d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability to Property at Installation Approved for Closure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority of this section does not apply to property or facilities located on or near a military installation approved for closure under a base closure law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9eda27e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Competitive Process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall ensure that the time, method, and terms and conditions of the reconveyance or lease of property or facilities under this section from the eligible entity permit full and free competition consistent with the value and nature of the property or facilities involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9eda27f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms and Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9eda280-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The conveyance or lease of property or facilities under this section shall be for such consideration and upon such terms and conditions as the Secretary concerned considers appropriate for the purposes of this subchapter and to protect the interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eda281-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As part or all of the consideration for a conveyance or lease under this section, the purchaser or lessor (as the case may be) shall enter into an agreement with the Secretary to ensure that a suitable preference will be afforded members of the armed forces and their dependents in the lease or sublease of a reasonable number of the housing units covered by the conveyance or lease, as the case may be, or in the lease of other suitable housing units made available by the purchaser or lessee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9eda282-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of Certain Property Management Laws","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The conveyance or lease of property or facilities under this section shall not be subject to the following provisions of law:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9eda283-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2667"},"text":"Section 2667 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eda284-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subtitle I of title 40 and division C (except sections 3302, 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eda285-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s1302"},"text":"Section 1302 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eda286-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 501 of the McKinney-Vento Homeless Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11411"},"text":"42 U.S.C. 11411","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9eda287-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of Lease Extensions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9eda288-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary concerned shall provide to the congressional defense committees notice in writing and a briefing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9eda289-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 60 days after beginning negotiations with a lessor for the extension of the term of any ground lease of property or facilities under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9eda28a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 90 days before extending the term of any ground lease of property or facilities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eda28b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A notice and briefing required under paragraph (1) shall include each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9eda28c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A description of any material differences between the extended ground lease and the original ground lease, including with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9eda28d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the length of the term of the lease, as extended; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9eda28e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any new provisions that materially affect the rights and responsibilities of the ground lessor or the ground lessee under the original ground lease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9eda28f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The number of housing units or facilities subject to the ground lease that, during the lease extension, are to be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9eda290-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constructed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9eda291-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demolished; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9eda292-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/f/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" renovated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9eda293-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The source of any additional financing the lessor has obtained, or intends to obtain, during the term of the ground lease extension that will be used for the development of the property or facilities subject to the ground lease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9eda294-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following information, displayed annually, for the five-year period preceding the date of the notice and briefing:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9eda295-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/f/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The debt-to-net operating income ratio for the property or facility subject to the ground lease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9eda296-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/f/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The occupancy rates for the housing units subject to the ground lease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9eda297-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/f/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A report on maintenance response times and completion of maintenance requests for the housing units subject to the ground lease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9eda298-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/f/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The occupancy rates and debt-to-net operating income ratios of any other military privatized housing initiative projects managed by a company that controls, or that is under common control with, the ground lessee entering into the lease extension.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9eda299-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2878/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of compliance by the lessor with the Military Housing Privatization Initiative Tenant Bill of Rights developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2890"},"text":"section 2890 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9eda29a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dB/tXXVIII/s2801/a/1"},"text":"Pub. L. 104–106, div. B, title XXVIII, § 2801(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/547"},"text":"110 Stat. 547","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1073/a/60"},"text":"Pub. L. 105–85, div. A, title X, § 1073(a)(60)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1903"},"text":"111 Stat. 1903","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dB/tXXVIII/s2803/g"},"text":"Pub. L. 106–65, div. B, title XXVIII, § 2803(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/849"},"text":"113 Stat. 849","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/d/1"},"text":"Pub. L. 107–107, div. A, title X, § 1048(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1227"},"text":"115 Stat. 1227","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/b/23"},"text":"Pub. L. 107–217, § 3(b)(23)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1297"},"text":"116 Stat. 1297","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/dB/tXXVIII/s2805/d"},"text":"Pub. L. 110–417, div. B, title XXVIII, § 2805(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4723"},"text":"122 Stat. 4723","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/b/50"},"text":"Pub. L. 111–350, § 5(b)(50)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3846"},"text":"124 Stat. 3846","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dB/tXXVIII/s2822"},"text":"Pub. L. 117–263, div. B, title XXVIII, § 2822","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3000"},"text":"136 Stat. 3000","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVIII/s1801/a/24"},"text":"Pub. L. 118–31, div. A, title XVIII, § 1801(a)(24)","children":[],"tail":", div. B, title XXVIII, § 2822(a), "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/684"},"text":"137 Stat. 684","children":[],"tail":", 751.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9eda29b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9eda29c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9eda29d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (f)(2)(D)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1801/a/24"},"text":"Pub. L. 118–31, § 1801(a)(24)","children":[],"tail":", substituted “A report” for “An report”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s2822/a"},"text":"Pub. L. 118–31, § 2822(a)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":", which directed substitution of “division C (except sections 3302, 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41” for “title III of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s251"},"text":"41 U.S.C. 251","children":[],"tail":" et seq.)” in subsec. (d)(2), was executed by making the substitution in subsec. (e)(2) to reflect the probable intent of Congress and the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":". See 2008 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" added subsec. (c) and redesignated former subsecs. (c) and (d) as (d) and (e), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/b/23/A"},"text":"Pub. L. 107–217, § 3(b)(23)(A)","children":[],"tail":", substituted “Subtitle I of title 40 and title III of the” for “The” and “("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s251"},"text":"41 U.S.C. 251","children":[],"tail":" et seq.)” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s471"},"text":"40 U.S.C. 471","children":[],"tail":" et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/b/23/B"},"text":"Pub. L. 107–217, § 3(b)(23)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s1302"},"text":"Section 1302 of title 40","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/act/1932-06-30/s321"},"text":"Section 321 of the Act of June 30, 1932","children":[],"tail":" (commonly known as the Economy Act) ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s303b"},"text":"40 U.S.C. 303b","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" substituted “McKinney-Vento Homeless Assistance Act” for “Stewart B. McKinney Homeless Assistance Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “eligible entities” for “private persons”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" substituted “11411” for “11401”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
