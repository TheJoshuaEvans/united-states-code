{"tag":"section","attrib":{"id":"idab1ecfb9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8328"},"text":null,"children":[{"tag":"num","attrib":{"value":"8328"},"text":"§ 8328.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of years of service: voluntary retirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab1ecfba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8328/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enlisted Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Time required to be made up under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s972/a"},"text":"section 972(a) of this title","children":[],"tail":" after "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"February 10, 1996","children":[],"tail":", may not be counted in computing years of service under this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1ecfbb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8328/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s972/b"},"text":"Section 972(b) of this title","children":[],"tail":" excludes from computation of an officer’s years of service for purposes of this chapter any time identified with respect to that officer under that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1ecfbc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8328/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"t