{"tag":"section","attrib":{"id":"idaae32741-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7325"},"text":null,"children":[{"tag":"num","attrib":{"value":"7325"},"text":"§ 7325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of years of service: voluntary retirement; enlisted members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaae32742-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7325/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of determining whether an enlisted member of the Army may be retired under section 7314 or 7317 of this title, his years of service are computed by adding all active service in the armed forces and service computed under section 3683 ","children":[{"tag":"ref","attrib":{"idref":"fn002155"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002155"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaae32743-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7325/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Time required to be made up under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s972/a"},"text":"section 972(a) of this title","children":[],"tail":" may not be counted in determining years of service under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaae32744-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/228"},"text":"70A Stat. 228","children":