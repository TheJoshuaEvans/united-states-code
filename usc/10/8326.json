ess provisos)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1941-07-24/ch320/s7/a"},"text":"July 24, 1941, ch. 320, § 7(a)","children":[],"tail":" (less provisos), "},{"tag":"html:a","attrib":{"href":"/us/stat/55/604"},"text":"55 Stat. 604","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1942-11-30/ch643"},"text":"Nov. 30, 1942, ch. 643","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/56/1023"},"text":"56 Stat. 1023","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s410m"},"text":"34 U.S.C. 410m","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1947-08-07/ch512/s316/j"},"text":"Aug. 7, 1947, ch. 512, § 316(j)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/61/868"},"text":"61 Stat. 868","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s350i/e"},"text":"34 U.S.C. 350i(e)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1941-07-24/ch320/s10/e"},"text":"July 24, 1941, ch. 320, § 10(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/55/605"},"text":"55 Stat. 605","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1946-02-21/ch34/s8/a"},"text":"Feb. 21, 1946, ch. 34, § 8(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/28"},"text":"60 Stat. 28","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the word “Regular” is inserted before the words “Navy” and “Marine Corps” to reflect the longstanding interpretation that ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s431"},"text":"34 U.S.C. 431","children":[],"tail":" applies only to members of the Regular Navy and Regular Marine Corps. So much of the "},{"tag":"ref","attrib":{"href":"/us/act/1907-03-02/ch2515/s1"},"text":"Act of March 2, 1907, ch. 2515, § 1","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t34/s431"},"text":"34 U.S.C. 431","children":[],"tail":"), as pertains to allowances and rations was expressly repealed by the "},{"tag":"ref","attrib":{"href":"/us/act/1942-06-16/ch413"},"text":"Act of June 16, 1942, ch. 413","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/369"},"text":"56 Stat. 369","children":[],"tail":". The words “active service in the armed forces” are substituted for "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s432"},"text":"34 U.S.C. 432","children":[],"tail":" for brevity. The reference to the former Revenue Cutter Service in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s432"},"text":"34 U.S.C. 432","children":[],"tail":" is omitted as obsolete, inasmuch as that Service was absorbed by the Coast Guard in 1915. If there are any enlisted men not yet retired who served in the Revenue Cutter Service, their right to count that service for the purpose of this section is protected by the saving provisions accompanying this title. The reference to active service in the Civil or Spanish-American War in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s432"},"text":"34 U.S.C. 432","children":[],"tail":" is omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is inserted to cover into the section permanent enlisted members who are temporarily appointed to commissioned or warrant grades.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c) the word “grade” is substituted for the words “rating or rank” and the words “is entitled to retired pay at the rate of 75 percent of the basic pay to which he would be entitled if serving on active duty in the grade in which retired” are substituted for the words “and with 75 per centum of the pay of the said rating or rank” to conform to the terminology of the Career Compensation Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s231"},"text":"37 U.S.C. 231","children":[],"tail":" et seq.)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (d) is substituted for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s350i/e"},"text":"34 U.S.C. 350i(e)","children":[],"tail":" as that section pertains to voluntary retirement of enlisted members with 30 years of active service."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab1c86b0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab1c86b1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s807/b/15"},"text":"Pub. L. 115–232, § 807(b)(15)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6326"},"text":"section 6326 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 8333” for “section 6333”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/348"},"text":"Pub. L. 99–348","children":[],"tail":" substituted provision that retired pay be computed under section 6333 for provision that retired pay, in the case of a person who first became a member of a uniformed service, as defined in section 1407(a)(2), before "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", be at the rate of 75 percent of the basic pay of the pay grade in which he was serving on the day before retirement or, if he served as master chief petty officer of the Navy or as sergeant major of the Marine Corps, 75 percent of the highest basic pay to which he was entitled while so serving, if that rate was higher, or in the case of a person who first became a member of a uniformed service, as defined in section 1407(a)(2), on or after "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", be computed by multiplying the monthly retired pay base computed under section 1407(d) by 75 percent."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"September 8, 1980","children":[],"tail":"” for “the date of the enactment of the Department of Defense Authorization Act, 1981” wherever appearing, and “master chief petty officer” for “senior enlisted advisor”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/342"},"text":"Pub. L. 96–342","children":[],"tail":" designated existing provisions as subpar. (A), inserted provision limiting applicability to persons who became members of the uniformed services before the date of the enactment of the Department of Defense Authorization Act, 1981, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/207"},"text":"Pub. L. 90–207","children":[],"tail":" inserted “, or if he has served as senior enlisted advisor of the Navy or as sergeant major of the Marine Corps, he shall be entitled to retired pay at the rate of 75 percent of the highest basic pay to which he was entitled while so serving, if that rate is higher” after “retirement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/132"},"text":"Pub. L. 88–132","children":[],"tail":" substituted “of” for “to which he would be entitled is serving on active duty in” after “75 percent of the basic pay”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/422"},"text":"Pub. L. 85–422","children":[],"tail":" substituted “pay grade in which he was serving on the day before retirement” for “grade in which retired”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":" repealed subsec. (d) which related to grade of members serving in a grade to which they were appointed under section 5597 or promoted under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s5787"},"text":"section 5787 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab1c86b2-3a6f