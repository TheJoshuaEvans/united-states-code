{"tag":"section","attrib":{"id":"idab1c86a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8326"},"text":null,"children":[{"tag":"num","attrib":{"value":"8326"},"text":"§ 8326.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enlisted members: 30 years","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab1c86a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8326/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each enlisted member of the Regular Navy or the Regular Marine Corps who applies for retirement after completing 30 or more years of active service in the armed forces shall be retired by the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1c86a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8326/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of subsection (a), “enlisted member” includes a member of the Regular Navy or the Regular Marine Corps who holds a permanent enlisted grade and a temporary appointment in a commissioned or warrant officer grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1c86a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8326/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each person retired under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab1c86aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8326/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless otherwise entitled to a higher grade, shall be retired in the grade in which serving at the time of retirement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1c86ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8326/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless otherwise entitled to higher pay, is entitled to retired pay computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8333"},"text":"section 8333 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab1c86ac-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/395"},"text":"70A Stat. 395","children":[],"tail":", § 6326; "},{"tag":"ref","attrib":{"href":"/us/pl/85/422/s6/9"},"text":"Pub. L. 85–422, § 6(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-05-20"},"text":"May 20, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/129"},"text":"72 Stat. 129","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s36B/20"},"text":"Pub. L. 85–861, § 36B(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1571"},"text":"72 Stat. 1571","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/132/s5/h/4"},"text":"Pub. L. 88–132, § 5(h)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-10-02"},"text":"Oct. 2, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/214"},"text":"77 Stat. 214","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/207/s3/3"},"text":"Pub. L. 90–207, § 3(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-16"},"text":"Dec. 16, 1967","children"