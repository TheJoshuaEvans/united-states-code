L. 116–283, § 1867(d)(2)","children":[],"tail":", substituted “section 4816” for “section 2505”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “the Under Secretary of Defense for Research and Engineering and the Under Secretary of Defense for Acquisition and Sustainment” for “the Under Secretary of Defense for Acquisition, Technology, and Logistics” and “the Under Secretaries shall” for “the Under Secretary shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" substituted “Under Secretary of Defense for Acquisition, Technology, and Logistics” for “Under Secretary of Defense for Acquisition”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s829/b/1"},"text":"Pub. L. 104–201, § 829(b)(1)","children":[],"tail":", substituted “The Secretary of Defense” for “(1) The Secretary of Defense, in consultation with the National Defense Technology and Industrial Base Council,” and struck out pars. (2) to (4) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) As determined by the Secretary of Defense, the program shall be administered by one of the following:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) An existing federally funded research and development center.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) A consortium of existing federally funded research and development centers and other nonprofit entities.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) A private sector entity (other than a federally funded research and development center).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) The National Defense University.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) A contract may be awarded under subparagraph (A), (B), or (C) of paragraph (2) only through the use of competitive procedures.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) The Secretary of Defense shall ensure that there is appropriate coordination between the program and the Critical Technologies Institute.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s829/b/2"},"text":"Pub. L. 104–201, § 829(b)(2)","children":[],"tail":", substituted “the Secretary of Defense for” for “the National Defense Technology and Industrial Base Council in” and struck out “and the periodic plans required by "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2506"},"text":"section 2506 of this title","children":[],"tail":"” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2505"},"text":"section 2505 of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa94917d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa94917e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
