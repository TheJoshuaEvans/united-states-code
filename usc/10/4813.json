{"tag":"section","attrib":{"id":"idaa94916e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4813"},"text":null,"children":[{"tag":"num","attrib":{"value":"4813"},"text":"§ 4813.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National defense program for analysis of the technology and industrial base","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa94916f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4813/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall establish a program for analysis of the national technology and industrial base.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa949170-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4813/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supervision of Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall carry out the program through the Under Secretary of Defense for Research and Engineering and the Under Secretary of Defense for Acquisition and Sustainment. In carrying out the program, the Under Secretaries shall consult with the Secretary of Energy, the Secretary of Commerce, and the Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa949171-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4813/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The functions of the program shall include, with respect to the national technology and industrial base, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa949172-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4813/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The assembly of timely and authoritative information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa949173-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4813/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Initiation of studies and analyses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa949174-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4813/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Provision of technical support and assistance to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa949175-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4813/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense for the preparation of the periodic assessments required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4816"},"text":"section 4816 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa949176-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4813/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defense acquisition university structure and its elements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa949177-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4813/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other departments and agencies of the Federal Government in accordance with guidance established by the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa949178-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4813/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Dissemination, through the National Technical Information Service of the Department of Commerce, of unclassified information and assessments for further dissemination within the Federal Government and to the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa949179-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dD/tXLII/s4213/a"},"text":"Pub. L. 102–484, div. D, title XLII, § 4213(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2665"},"text":"106 Stat. 2665","children":[],"tail":", § 2503; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tVIII/s829/b"},"text":"Pub. L. 104–201, div. A, title VIII, § 829(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2612"},"text":"110 Stat. 2612","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/b/4"},"text":"Pub. L. 107–107, div. A, title X, § 1048(b)(4)","children":[],"tail":"