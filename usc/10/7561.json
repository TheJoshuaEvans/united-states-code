ext":"Authority of President under subsec. (a) of this section to prescribe uniform military ration applicable to Army delegated to Secretary of Defense by section 3(a) of Ex. Ord. No. 12781, ","children":[{"tag":"date","attrib":{"date":"1991-11-20"},"text":"Nov. 20, 1991","children":[],"tail":", 56 F.R. 59203, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
