{"tag":"section","attrib":{"id":"ida8406846-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s980"},"text":null,"children":[{"tag":"num","attrib":{"value":"980"},"text":"§ 980.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of humans as experimental subjects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8406847-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s980/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Funds appropriated to the Department of Defense may not be used for research involving a human being as an experimental subject unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8406848-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s980/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the informed consent of the subject is obtained in advance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8406849-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s980/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of research intended to be beneficial to the subject, the informed consent of the subject or a legal representative of the subject is obtained in advance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida840684a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s980/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida840684b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s980/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may waive the prohibition in this section with respect to a specific research project to advance the development of a medical product necessary to the armed forces if the research project may directly benefit the subject and is carried out in accordance with all other applicable laws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida840684c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s980/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may delegate the authority provided by paragraph (1) to the Under Secretary of Defense for Research and Engineering.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida840684d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXIV/s1401/c/1"},"text":"Pub. L. 98–525, title XIV, § 1401(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2615"},"text":"98 Stat. 2615","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tVII/s733"},"text":"Pub. L. 107–107, div. A, title VII, § 733","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1170"},"text":"115 Stat. 1170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tII/s212"},"text":"Pub. L. 118–31, div. A, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/183"},"text":"137 Stat. 183","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"i