{"tag":"section","attrib":{"id":"idab2f991f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8547"},"text":null,"children":[{"tag":"num","attrib":{"value":"8547"},"text":"§ 8547.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Students at institutions of higher education: admission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab2f9920-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8547/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Admission Pursuant to Reciprocal Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy may enter into an agreement with an accredited institution of higher education to permit a student described in subsection (b) enrolled at that institution to receive instruction at the Naval Postgraduate School on a tuition-free basis. In exchange for the admission of the student, the institution of higher education shall be required to permit an officer of the armed forces to attend on a tuition-free basis courses offered by that institution corresponding in length to the instruction provided to the student at the Naval Postgraduate School.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2f9921-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8547/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Students","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A student enrolled at an institution of higher education that is party to an agreement under subsection (a) may be admitted to the Naval Postgraduate School pursuant to that agreement if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab2f9922-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8547/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the student is a citizen of the United States or lawfully admitted for permanent residence in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2f9923-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8547/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Navy determines that the student has a demonstrated ability in a field of study designated by the Secretary as related to naval warfare and national security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab2f9924-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1073/a/2"},"text":"Pub. L. 102–484, div. A, title X, § 1073(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2510"},"text":"106 Stat. 2510","children":[],"tail":", § 7047; renumbered § 8547, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/c/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab2f9925-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab2f9926-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab2f9927-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8547 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9217"},"text":"section 9217 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab2f9928-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7047"},"text":"section 7047 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab2f9929-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab2f992a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
