{"tag":"section","attrib":{"id":"idabca79a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20243"},"text":null,"children":[{"tag":"num","attrib":{"value":"20243"},"text":"§ 20243.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General officers ceasing to occupy positions commensurate with grade","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabca79aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20243/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Officers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 60 days after an officer of the Space Force on the Space Force officer list in a general officer grade ceases to occupy a position commensurate with that grade (or commensurate with a higher grade), the Secretary of the Air Force shall transfer or discharge the officer in accordance with whichever of the following the officer elects:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabca79ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20243/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transfer the officer in grade to the Space Force retired list, if the officer is qualified and applies for the transfer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabca79ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20243/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transfer the officer in grade to a Space Force inactive status, if the officer is qualified.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabca79ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20243/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Discharge the officer from the officer’s appointment and, if the officer is qualified and applies therefor, appoint the officer in the grade held by the officer before the officer’s appointment in a general officer grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabca79ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20243/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Discharge the officer from the officer’s appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabca79af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20243/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Credit for Service in Grade","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who is appointed under subsection (a)(3) shall be credited with an amount of service in the grade in which appointed that is equal to the amount of prior service in an active status in that grade and in any higher grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabca79b0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1716/c"},"text":"Pub. L. 118–31, div. A, title XVII, § 1716(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/649"},"text":"137 Stat. 649","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s521/t"},"text":"Pub. L. 118–159, div. A, title V, § 521(t)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1883"},"text":"138 Stat. 1883","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabca79b1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabca79b2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabca79b3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" struck out “as a” after “held by the officer”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
