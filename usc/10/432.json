{"tag":"section","attrib":{"id":"ida7bd2e9f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s432"},"text":null,"children":[{"tag":"num","attrib":{"value":"432"},"text":"§ 432.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use, disposition, and auditing of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7bd2ea0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s432/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds generated by a commercial activity authorized pursuant to this subchapter may be used to offset necessary and reasonable expenses arising from that activity. Use of such funds for that purpose shall be kept to the minimum necessary to conduct the activity concerned in a secure manner. Any funds generated by the activity in excess of those required for that purpose shall be deposited, as often as may be practicable, into the Treasury as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bd2ea1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s432/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Audits","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bd2ea2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s432/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall assign an organization within the Department of Defense to have auditing responsibility with respect to activities authorized under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bd2ea3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s432/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That organization shall audit the use and disposition of funds generated by any commercial activity authorized under this subchapter not less often than annually. The results of all such audits shall be reported to the congressional defense committees and the congressional intelligence committees (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s437/c"},"text":"section 437(c) of this title","children":[],"tail":") by not later than December 31 of each year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7bd2ea4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/88/tV/s504/a/2"},"text":"Pub. L. 102–88, title V, § 504(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/438"},"text":"105 Stat. 438","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tIX/s921/a"},"text":"Pub. L. 113–66, div. A, title IX, § 921(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/827"},"text":"127 Stat. 827","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tXVI/s1623"},"text":"Pub. L. 115–91, div. A, title XVI, § 1623","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1732"},"text":"131 Stat. 1732","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7bd2ea5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7bd2ea6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7bd2ea7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" struck out “promptly” before “reported” and inserted before period at end “by not later than December 31 of each year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" substituted “the congressional defense committees and the congressional intelligence committees (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s437/c"},"text":"section 437(c) of this title","children":[],"tail":").” for “the intelligence committees (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s437/d"},"text":"section 437(d) of this title","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
