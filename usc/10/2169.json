{"tag":"section","attrib":{"id":"ida93612aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2169"},"text":null,"children":[{"tag":"num","attrib":{"value":"2169"},"text":"§ 2169.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" School of Nursing: establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida93612ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2169/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may establish a School of Nursing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93612ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2169/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Degree Granting Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The School of Nursing may include a program that awards a bachelor of science in nursing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93612ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2169/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Phased Development","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may develop the School of Nursing in phases as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida93612ae-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tV/s525/a/2"},"text":"Pub. L. 111–84, div. A, title V, § 525(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2286"},"text":"123 Stat. 2286","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
