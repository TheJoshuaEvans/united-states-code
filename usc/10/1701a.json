{"tag":"section","attrib":{"id":"ida903df17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1701a"},"text":"§ 1701a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management for acquisition workforce excellence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida903df18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this chapter is to require the Department of Defense to develop and manage a highly skilled professional acquisition workforce—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida903df19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which excellence and contribution to mission is rewarded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida903df1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which has the technical expertise and business skills to ensure the Department receives the best value for the expenditure of public resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida903df1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which serves as a model for performance management of employees of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida903df1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is managed in a manner that complements and reinforces the management of the defense acquisition system pursuant to chapter 205 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida903df1d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance Management","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to achieve the purpose set forth in subsection (a), the Secretary of Defense shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida903df1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the full authorities provided in subsections (a) through (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s9902"},"text":"section 9902 of title 5","children":[],"tail":", including flexibilities related to performance management and hiring and to training of managers;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida903df1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require managers to develop performance plans for individual members of the acquisition workforce in order to give members an understanding of how their performance contributes to their organization’s mission and the success of the defense acquisition system (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida903df20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent appropriate, use the lessons learned from the acquisition demonstration project carried out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1762"},"text":"section 1762 of this title","children":[],"tail":" related to contribution-based compensation and appraisal, and how those lessons may be applied within the General Schedule system;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida903df21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and implement a career path, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1722/a"},"text":"section 1722(a) of this title","children":[],"tail":", for each career field designated by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1721/a"},"text":"section 1721(a) of this title","children":[],"tail":" as an acquisition workforce career field;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida903df22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct continuing education and training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida903df23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize a member of the acquisition workforce to participate in professional associations, consistent with the performance plan of such a member in order to provide the member with the opportunity to gain leadership and management skills;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida903df24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop appropriate procedures for warnings and consequences during performance evaluations for members of the acquisition workforce who consistently fail to meet performance standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida903df25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take full advantage of the Defense Civilian Leadership Program established under section 1112 of the National Defense Authorization Act for Fiscal Year 2010 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Public Law 111–84","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/123/2496"},"text":"123 Stat. 2496","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1580"},"text":"10 U.S.C. 1580","children":[],"tail":" note prec.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida903df26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" use the authorities for highly qualified experts under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s9903"},"text":"section 9903 of title 5","children":[],"tail":", to hire experts who are skilled acquisition professionals to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida903df27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/b/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve in leadership positions within the acquisition workforce to strengthen management and oversight;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida903df28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/b/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide mentors to advise individuals within the acquisition workforce on their career paths and opportunities to advance and excel within the acquisition workforce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida903df29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/b/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist with the design of education and training courses and the training of individuals in the acquisition workforce;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida903df2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the authorities for expedited security clearance processing pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1564"},"text":"section 1564 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida903df2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the participation in the public-private talent exchange program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1599g"},"text":"section 1599g of this title","children":[],"tail":" of up to 250 members of the acquisition workforce in each fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida903df2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Professional Certification","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida903df2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall implement a certification program to provide for a professional certification requirement for all members of the acquisition workforce. Except as provided in paragraph (2), the certification requirement for any acquisition workforce career field shall be based on standards developed by a third-party accredited program based on nationally or internationally recognized standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida903df2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary determines that, for a particular acquisition workforce career field, a third-party accredited program based on nationally or internationally recognized standards does not exist, the Secretary shall establish the certification requirement for that career field that conforms with the practices of national or international accrediting organizations. The Secretary shall determine the best approach for meeting the certification requirement for any such career field, including by implementing such certification requirement through entities outside the Department of Defense, and may design and implement such certification requirement without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1746"},"text":"section 1746 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida903df2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Negotiations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any action taken by the Secretary under this section, or to implement this section, shall be subject to the requirements of chapter 71 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida903df30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1701a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any rules or regulations prescribed pursuant to this section shall be deemed an agency rule or regulation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7117/a/2"},"text":"section 7117(a)(2) of title 5","children":[],"tail":", and shall not be deemed a Government-wide rule or regulation under section 7117(a)(1) of such title."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida903df31-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVIII/s871/a"},"text":"Pub. L. 111–383, div. A, title VIII, § 871(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4299"},"text":"124 Stat. 4299","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVIII/s861/a/1"},"text":"Pub. L. 116–92, div. A, title VIII, § 861(a)(1)","children":[],"tail":"–(3), (e)(1), "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1515"},"text":"133 Stat. 1515","children":[],"tail":", 1517; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tX/s1081/a/31"},"text":"Pub. L. 116–283, div. A, title X, § 1081(a)(31)","children":[],"tail":", title XVIII, §§ 1808(d)(2), 1883(b)(2), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3872"},"text":"134 Stat. 3872","children":[],"tail":", 4160, 4294; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVIII/s831/a"},"text":"Pub. L. 117–263, div. A, title VIII, § 831(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2711"},"text":"136 Stat. 2711","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida903df32-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida903df33-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida903df34-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s831/a/2"},"text":"Pub. L. 117–263, § 831(a)(2)","children":[],"tail":", substituted “as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"” for “as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2545"},"text":"section 2545 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s831/a/1"},"text":"Pub. L. 117–263, § 831(a)(1)","children":[],"tail":", added par. (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1808/d/2"},"text":"Pub. L. 116–283, § 1808(d)(2)","children":[],"tail":", substituted “chapter 205” for “chapter 149”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1883/b/2"},"text":"Pub. L. 116–283, § 1883(b)(2)","children":[],"tail":", which directed that each reference in the text of title 10 to a section that was redesignated by title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", as such section was in effect before the redesignation, be amended by striking such reference and inserting a reference to the appropriate redesignated section, was not executed with respect to “section 2545”, which was redesignated as multiple sections."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1081/a/31/A"},"text":"Pub. L. 116–283, § 1081(a)(31)(A)","children":[],"tail":", substituted a semicolon for the period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1081/a/31/B"},"text":"Pub. L. 116–283, § 1081(a)(31)(B)","children":[],"tail":", struck out par. (1) heading “In General” and par. (2) heading “Requirements for Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s861/e/1"},"text":"Pub. L. 116–92, § 861(e)(1)","children":[],"tail":", amended par. (4) generally. Prior to amendment, par. (4) read as follows: “develop attractive career paths;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s861/a/2/A"},"text":"Pub. L. 116–92, § 861(a)(2)(A)","children":[],"tail":", substituted “direct” for “encourage”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s861/a/3/B"},"text":"Pub. L. 116–92, § 861(a)(3)(B)","children":[],"tail":", added par. (6). Former par. (6) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s861/a/2/B"},"text":"Pub. L. 116–92, § 861(a)(2)(B)","children":[],"tail":", inserted “and consequences” after “warnings”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s861/a/3/A"},"text":"Pub. L. 116–92, § 861(a)(3)(A)","children":[],"tail":", redesignated pars. (6) to (9) as (7) to (10), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s861/a/1"},"text":"Pub. L. 116–92, § 861(a)(1)","children":[],"tail":", added subsec. (c) and redesignated former subsecs. (c) and (d) as (d) and (e), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida903df35-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida903df36-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by sections 1808(d)(2) and 1883(b)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida903df37-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Implementation of Procedures To Institute Certification Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVIII/s861/a/5"},"text":"Pub. L. 116–92, div. A, title VIII, § 861(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1516"},"text":"133 Stat. 1516","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dA/tVIII/s861/a/5"},"text":"“The Secretary of Defense shall implement procedures to institute the program required by subsection (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1701a"},"text":"section 1701a of title 10","children":[],"tail":", United States Code, as added by paragraph (1), not later than 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida903df38-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Implementation of Career Paths","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVIII/s861/e/3"},"text":"Pub. L. 116–92, div. A, title VIII, § 861(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1517"},"text":"133 Stat. 1517","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dA/tVIII/s861/e/3"},"text":"“Not later than the end of the two-year period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"], the Secretary of Defense shall carry out the requirements of paragraph (4) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1701a/b"},"text":"section 1701a(b) of title 10","children":[],"tail":", United States Code (as amended by paragraph (1)).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida903df39-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Flexibility in Contracting Award Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s834"},"text":"Pub. L. 114–328, div. A, title VIII, § 834","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2285"},"text":"130 Stat. 2285","children":[],"tail":", which established an award to recognize acquisition programs and professionals making the best use of flexibilities and authorities granted by Federal Acquisition Regulation and Department of Defense Instruction 5000.02, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVIII/s801/c"},"text":"Pub. L. 117–263, div. A, title VIII, § 801(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2693"},"text":"136 Stat. 2693","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1743"},"text":"section 1743 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida903df3a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Awards for Department of Defense Personnel for Excellence in the Acquisition of Products and Services","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/23/tIII/s301"},"text":"Pub. L. 111–23, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1730"},"text":"123 Stat. 1730","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/23/tIII/s301"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":"], the Secretary of Defense shall commence carrying out a program to recognize excellent performance by individuals and teams of members of the Armed Forces and civilian personnel of the Department of Defense in the acquisition of products and services for the Department of Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program required by subsection (a) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procedures for the nomination by the personnel of the military departments and the Defense Agencies of individuals and teams of members of the Armed Forces and civilian personnel of the Department of Defense for eligibility for recognition under the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procedures for the evaluation of nominations for recognition under the program by one or more panels of individuals from the Government, academia, and the private sector who have such expertise, and are appointed in such manner, as the Secretary shall establish for purposes of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Award of Cash Bonuses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As part of the program required by subsection (a), the Secretary may award to any individual recognized pursuant to the program a cash bonus authorized by any other provision of law to the extent that the performance of such individual so recognized warrants the award of such bonus under such provision of law.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
