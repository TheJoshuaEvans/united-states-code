{"tag":"section","attrib":{"id":"ida978c1dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2453"},"text":null,"children":[{"tag":"num","attrib":{"value":"2453"},"text":"§ 2453.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supply catalog: distribution and use","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense shall distribute the parts of the supply catalog described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2451"},"text":"section 2451 of this title","children":[],"tail":" as they are completed. Existing catalogs shall be replaced according to schedules established by the Secretary. After replacement no other supply catalog may be used within the Department of Defense with respect to the kinds of items covered by that part. All property reports and records shall use the nomenclature, item numbers, and descriptive data of the supply catalog."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida978c1de-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/139"},"text":"70A Stat. 139","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida978c1df-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida978c1e0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida978c1e1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2453","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5:173d.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1952-07-01/ch539/s6"},"text":"July 1, 1952, ch. 539, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/66/320"},"text":"66 Stat. 320","children":[],"tail":"; 1953 Reorg. Plan No. 6, § 1(a) (as applicable to Defense Supply Management Agency), eff. "},{"tag":"html:span","attrib":{},"text":"June 30, 1953","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/638"},"text":"67 Stat. 638","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “and ready for use” and “all departments, bureaus, and services” are omitted as surplusage. The words “After replacement” are substituted for the word “Thereafter”. The words “with respect to the kinds of items covered by that part” are inserted for clarity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
