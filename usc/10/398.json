{"tag":"section","attrib":{"id":"ida7b3b882-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398"},"text":null,"children":[{"tag":"num","attrib":{"value":"398"},"text":"§ 398.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military information support operations in information environment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7b3b883-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Notification Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7b3b884-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 48 hours after the execution of any new military information support operation plan (in this section referred to as a “MISO plan”) approved by the commander of a combatant command, or any change in scope of any existing MISO plan, including any underlying MISO supporting plan, the Secretary of Defense shall promptly submit to the congressional defense committees notice in writing of such approval or execution of change in scope.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b3b885-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A notification under paragraph (1) with respect to a MISO plan shall include each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7b3b886-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the military information support operation program (in this section referred to as a “MISO program”) supported by the MISO plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b3b887-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the objectives of the MISO plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b3b888-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the intended target audience for military information support operation activities under the MISO plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b3b889-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the tactics, techniques, and procedures to be used in executing the MISO plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b3b88a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the personnel engaged in supporting or facilitating the operation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b3b88b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of funding anticipated to be obligated and expended to execute the MISO plan during the current and subsequent fiscal years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b3b88c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The expected duration and desired outcome of the MISO plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b3b88d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other elements the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b3b88e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the maximum extent practicable, the Secretary shall ensure that the congressional defense committees are notified promptly of any unauthorized disclosure of a clandestine military support operation covered by this section. A notification under this subsection may be verbal or written, but in the event of a verbal notification, the Secretary shall provide a written notification by not later than 48 hours after the provision of the verbal notification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b3b88f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the last day of any fiscal year during which the Secretary conducts a MISO plan, the Secretary shall submit to the congressional defense committees a report on all such MISO plans conducted during such fiscal year. Such report shall include each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7b3b890-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A list of each MISO program and the combatant command responsible for the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b3b891-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For each MISO plan—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7b3b892-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the plan and any supporting plans, including the objectives for the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b3b893-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the intended target audience for the activities carried out under the plan and the means of distribution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b3b894-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of executing the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b3b895-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Clandestine Operations Designed to Influence Opinions and Politics in United States","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"None of the funds authorized to be appropriated or otherwise made available for the Department of Defense for any fiscal year may be used to conduct a clandestine military information support operation that is designed to influence—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7b3b896-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any political process taking place in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b3b897-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the opinions of United States persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b3b898-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States policies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b3b899-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" media produced by United States entities for United States persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7b3b89a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tX/s1052/a"},"text":"Pub. L. 117–263, div. A, title X, § 1052(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2776"},"text":"136 Stat. 2776","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7b3b89b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7b3b89c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida7b3b89d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 398 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s398a"},"text":"section 398a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
