{"tag":"section","attrib":{"id":"ida9898acf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563"},"text":null,"children":[{"tag":"num","attrib":{"value":"2563"},"text":"§ 2563.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Articles and services of industrial facilities: sale to persons outside the Department of Defense","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9898ad0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Sell Outside DOD","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9898ad1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may sell in accordance with this section to a person outside the Department of Defense articles and services referred to in paragraph (2) that are not available from any United States commercial source.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9898ad2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9898ad3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (B), articles and services referred to in paragraph (1) are articles and services that are manufactured or performed by any working-capital funded industrial facility of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9898ad4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority in this section does not apply to sales of articles and services by a working-capital funded Army industrial facility (including a Department of the Army arsenal) that manufactures large caliber cannons, gun mounts, recoil mechanisms, ammunition, munitions, or components thereof, which are governed by regulations required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7543"},"text":"section 7543 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9898ad5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Participating Industrial Facilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may designate facilities referred to in subsection (a) as the facilities from which articles and services manufactured or performed by such facilities may be sold under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9898ad6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions for Sales","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9898ad7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A sale of articles or services may be made under this section only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9898ad8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense determines that the articles or services are not available from a commercial source in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9898ad9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchaser agrees to hold harmless and indemnify the United States, except as provided in paragraph (3), from any claim for damages or injury to any person or property arising out of the articles or services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9898ada-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the articles or services can be substantially manufactured or performed by the industrial facility concerned with only incidental subcontracting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9898adb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is in the public interest to manufacture the articles or perform the services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9898adc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the sale of the articles or services will not interfere with the military mission of the industrial facility concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9898add-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale of the goods and services is made on the basis that it will not interfere with performance of work by the industrial facility concerned for the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9898ade-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may waive the condition in paragraph (1)(A) and subsection (a)(1) that an article or service must be not available from a United States commercial source in the case of a particular sale if the Secretary determines that the waiver is necessary for reasons of national security and notifies Congress regarding the reasons for the waiver.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9898adf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1)(B) does not apply in any case of willful misconduct or gross negligence or in the case of a claim by a purchaser of articles or services under this section that damages or injury arose from the failure of the Government to comply with quality, schedule, or cost performance requirements in the contract to provide the articles or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9898ae0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Methods of Sale","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9898ae1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall permit a purchaser of articles or services under this section to use advance incremental funding to pay for the articles or services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9898ae2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the sale of articles and services under this section, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9898ae3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charge the purchaser, at a minimum, the variable costs, capital improvement costs, and equipment depreciation costs that are associated with the articles or services sold;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9898ae4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into a firm, fixed-price contract or, if agreed by the purchaser, a cost reimbursement contract for the sale; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9898ae5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and maintain (from sources other than appropriated funds) working capital to be available for paying design costs, planning costs, procurement costs, and other costs associated with the articles or services sold.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9898ae6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposit of Proceeds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Proceeds from sales of articles and services under this section shall be credited to the funds, including working capital funds and operation and maintenance funds, incurring the costs of manufacture or performance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9898ae7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Arms Export Control Act","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to affect the application of the export controls provided for in section 38 of the Arms Export Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2778"},"text":"22 U.S.C. 2778","children":[],"tail":") to items which incorporate or are produced through the use of an article sold under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9898ae8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9898ae9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “advance incremental funding”, with respect to a sale of articles or services, means a series of partial payments for the articles or services that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9898aea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more partial payments before the commencement of work or the incurring of costs in connection with the manufacture of the articles or the performance of the services, as the case may be; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9898aeb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsequent progress payments that result in full payment being completed as the required work is being completed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9898aec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “not available”, with respect to an article or service proposed to be sold under this section, means that the article or service is unavailable from a commercial source in the required quantity and quality or within the time required.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9898aed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “variable costs”, with respect to sales of articles or services, means the costs that are expected to fluctuate directly with the volume of sales and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9898aee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of articles, the volume of production necessary to satisfy the sales orders; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9898aef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2563/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of services, the extent of the services sold.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9898af0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tIII/s339/a/1"},"text":"Pub. L. 103–337, div. A, title III, § 339(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2718"},"text":"108 Stat. 2718","children":[],"tail":", § 2553; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tIII/s331/a/2"},"text":"Pub. L. 106–65, div. A, title III, § 331(a)(2)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/566"},"text":"113 Stat. 566","children":[],"tail":", 567; renumbered § 2563, "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1033(b)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–260; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tIII/s343/a"},"text":"Pub. L. 107–107, div. A, title III, § 343(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1061"},"text":"115 Stat. 1061","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s809/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 809(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1840"},"text":"132 Stat. 1840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9898af1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9898af2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9898af3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “section 7543” for “section 4543”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s343/a/1"},"text":"Pub. L. 107–107, § 343(a)(1)","children":[],"tail":", substituted “as provided in paragraph (3)” for “in any case of willful misconduct or gross negligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s343/a/2"},"text":"Pub. L. 107–107, § 343(a)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2553"},"text":"section 2553 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s331/a/2"},"text":"Pub. L. 106–65, § 331(a)(2)","children":[],"tail":", designated existing provisions as par. (1), redesignated former pars. (1) to (6) as subpars. (A) to (F), respectively, of par. (1), and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s331/b"},"text":"Pub. L. 106–65, § 331(b)","children":[],"tail":", added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9898af4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9898af5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9898af6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tIII/s339/b"},"text":"Pub. L. 103–337, div. A, title III, § 339(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2720"},"text":"108 Stat. 2720","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/337/dA/tIII/s339/b"},"text":"“Section 2553 [now 2563] of title 10, United States Code, as added by subsection (a), shall take effect on ","children":[{"tag":"date","attrib":{"date":"1995-04-01"},"text":"April 1, 1995","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
