{"tag":"section","attrib":{"id":"ida960f331-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2275a"},"text":"§ 2275a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for protection of satellites","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida960f332-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before a major satellite acquisition program achieves Milestone A approval, or equivalent, the Chief of Staff of the Space Force, in consultation with the Commander of the United States Space Command, shall establish requirements for the defense and resilience of the satellites under that program against the capabilities of adversaries to target, degrade, or destroy the satellites.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida960f333-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida960f334-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “major satellite acquisition program” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2275"},"text":"section 2275 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f335-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Milestone A approval” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4251"},"text":"section 4251 of this title","children":[],"tail":" 10."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida960f336-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tXVI/s1601"},"text":"Pub. L. 117–263, div. A, title XVI, § 1601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2929"},"text":"136 Stat. 2929","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
