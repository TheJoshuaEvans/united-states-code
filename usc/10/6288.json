{"tag":"section","attrib":{"id":"idaacb59c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6288"},"text":null,"children":[{"tag":"num","attrib":{"value":"6288"},"text":"§ 6288.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unfunded priorities of the Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaacb59c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6288/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report or Certification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 10 days after the date on which the budget of the President for a fiscal year is submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", the Administrator shall submit to the Secretary of Energy and the congressional defense committees either—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacb59c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6288/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report on the unfunded priorities of the Administration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacb59c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6288/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Administrator determines that there are no unfunded priorities to include in such a report, a certification and explanation by the Administrator, without delegation, of the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacb59c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6288/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacb59c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6288/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each report under subsection (a)(1) shall specify, for each unfunded priority covered by the report, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacb59c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6288/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary description of that priority, including the objectives to be achieved or the risk to be mitigated if that priority is funded (whether in whole or in part).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacb59c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6288/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The additional amount of funds recommended in connection with the objectives or risk mitigation under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacb59c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6288/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Account information with respect to that priority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacb59ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6288/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each report under subsection (a)(1) shall present the unfunded priorities covered by the report in order of urgency of priority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacb59cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6288/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unfunded Priority Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “unfunded priority”, in the case of a fiscal year, means a program, activity, or mission requirement that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacb59cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6288/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not funded in the budget of the President for that fiscal year as submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacb59cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6288/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary to address a requirement associated with the mission of the Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacb59ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6288/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" would have been recommended for funding through the budget referred to in paragraph (1) by the Administrator—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacb59cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6288/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if additional resources were available for the budget to fund the program, activity, or mission requirement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacb59d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6288/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a program, activity, or mission requirement that emerged after the budget was formulated, if the program, activity, or mission requirement had emerged before the budget was formulated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaacb59d1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI"},"text":"Pub. L. 119–60, div. C, title XXXI","children":[],"tail":", §§ 3111(a), (d)(2), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1435"},"text":"139 Stat. 1435","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaacb59d2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaacb59d3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaacb59d4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2756"},"text":"section 2756 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaacb59d5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) and (2) headings which read as follows: “"},{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":"” and “"},{"tag":"inline","attrib":{},"text":"Prioritization of priorities","children":[],"tail":"”, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
