{"tag":"section","attrib":{"id":"idaa294c10-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3551"},"text":null,"children":[{"tag":"num","attrib":{"value":"3551"},"text":"§ 3551.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiyear procurement authority: purchase of dinitrogen tetroxide, hydrazine, and hydrazine-related products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa294c11-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3551/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ten-Year Contract Period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may enter into a contract for a period of up to 10 years for the purchase of dinitrogen tetroxide, hydrazine, and hydrazine-related products for the support of a United States national security program or a United States space program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa294c12-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3551/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extensions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contract entered into for more than one year under the authority of subsection (a) may be extended for a total of not more than 10 years pursuant to any option or options set forth in the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa294c13-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tVIII/s826/a"},"text":"Pub. L. 107–314, div. A, title VIII, § 826(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2617"},"text":"116 Stat. 2617","children":[],"tail":", § 2410"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"; renumbered § 3551, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1822/e/2"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1822(e)(2)","children":[],"tail":", formerly § 1822(t)(2), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4205"},"text":"134 Stat. 4205","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/k/4"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(k)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2144"},"text":"135 Stat. 2144","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa294c14-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa294c15-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa294c16-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered section 2410"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa294c17-3a6f-11f