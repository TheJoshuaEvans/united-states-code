{"tag":"section","attrib":{"id":"ida908c14f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1725"},"text":null,"children":[{"tag":"num","attrib":{"value":"1725"},"text":"§ 1725.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senior Military Acquisition Advisors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida908c150-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1725/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Position.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida908c151-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1725/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may establish in the acquisition workforce a position to be known as “Senior Military Acquisition Advisor”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida908c152-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1725/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Senior Military Acquisition Advisor shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida908c153-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1725/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope of position","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An officer who is appointed as a Senior Military Acquisition Advisor—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida908c154-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1725/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall serve as an advisor to, and provide senior level acquisition expertise to, the service acquisition executive of that officer’s military department in accordance with this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida908c155-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1725/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be assigned as an adjunct professor at the Defense Acquisition University.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida908c156-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1725/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuation on Active Duty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who is appointed as a Senior Military Acquisition Advisor may continue on active duty while serving in such position without regard to any mandatory retirement date that would otherwise be applicable to that officer by reason of years of service or age. An officer who is continued on active duty pursuant to this section is not eligible for consideration for selection for promotion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida908c157-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1725/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retired Grade","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon retirement, an officer who is a Senior Military Acquisition Advisor may, in the discretion of the President, be retired in the grade of brigadier general or rear admiral (lower half) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida908c158-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1725/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer has served as a Senior Military Acquisition Advisor for a period of not less than three years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida908c159-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1725/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer’s service as a Senior Military Acquisition Advisor has been distinguished.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida908c15a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1725/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection and Tenure.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida908c15b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1725/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Selection of an officer for recommendation for appointment as a Senior Military Acquisition Advisor shall be made competitively, and shall be based upon demonstrated experience and expertise in acquisition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida908c15c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1725/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers eligible","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Officers shall be selected for recommendation for appointment as Senior Military Acquisition Advisors from among officers in the acquisition workforce serving in critical acquisition positions who are serving in the grade of colonel or, in the case of the Navy, captain, and who have at least 12 years of acquisition experience. An officer selected for recommendation for appointment as a Senior Military Acquisition Advisor shall have at least 30 years of active commissioned service at the time of appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida908c15d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1725/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The appointment of an officer as a Senior Military Acquisition Advisor shall be for a term of not longer than five years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida908c15e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1725/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida908c15f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1725/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on number and distribution","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There may not be more than 15 Senior Military Acquisition Advisors at any time, of whom—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida908c160-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1725/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than five may be officers of the Army;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida908c161-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1725/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than five may be officers of the Navy and Marine Corps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida908c162-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1725/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than five may be officers of the Air Force and Space Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida908c163-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1725/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Number in each military department","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (1), the number of Senior Military Acquisition Advisors for each military department shall be as required and identified by the service acquisition executive of such military department and approved by the Under Secretary of Defense for Acquisition and Sustainment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida908c164-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1725/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advice to Service Acquisition Executive","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who is a Senior Military Acquisition Advisor shall have as the officer’s primary duty providing strategic, technical, and programmatic advice to the service acquisition executive of the officer’s military department on matters pertaining to the Defense Acquisition System, including matters pertaining to procurement, research and development, advanced technology, test and evaluation, production, program management, systems engineering, and lifecycle logistics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida908c165-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s866/a/1"},"text":"Pub. L. 114–328, div. A, title VIII, § 866(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2305"},"text":"130 Stat. 2305","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVIII/s861/j/9"},"text":"Pub. L. 116–92, div. A, title VIII, § 861(j)(9)","children":[],"tail":", title IX, § 902(19), "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1520"},"text":"133 Stat. 1520","children":[],"tail":", 1545; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/28"},"text":"Pub. L. 116–283, div. A, title IX, § 924(b)(28)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3825"},"text":"134 Stat. 3825","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida908c166-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida908c167-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida908c168-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1725, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXII/s1202/a"},"text":"Pub. L. 101–510, div. A, title XII, § 1202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1643"},"text":"104 Stat. 1643","children":[],"tail":", which related to Office of Personnel Management approval, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tVIII/s832/a"},"text":"Pub. L. 108–136, div. A, title VIII, § 832(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1550"},"text":"117 Stat. 1550","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tX/s1084/f/1"},"text":"Pub. L. 108–375, div. A, title X, § 1084(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2064"},"text":"118 Stat. 2064","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida908c169-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (e)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" inserted “and Space Force” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s861/j/9/A"},"text":"Pub. L. 116–92, § 861(j)(9)(A)","children":[],"tail":", substituted “acquisition workforce” for “Defense Acquisition Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s861/j/9/B"},"text":"Pub. L. 116–92, § 861(j)(9)(B)","children":[],"tail":", substituted “in the acquisition workforce serving in critical acquisition positions” for “of the Defense Acquisition Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s902/19"},"text":"Pub. L. 116–92, § 902(19)","children":[],"tail":", substituted “Under Secretary of Defense for Acquisition and Sustainment” for “Under Secretary of Defense for Acquisition, Technology, and Logistics”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
