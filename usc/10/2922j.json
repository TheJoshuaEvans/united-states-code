{"tag":"section","attrib":{"id":"ida9fe4506-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922j"},"text":null,"children":[{"tag":"num","attrib":{"value":"2922j"},"text":"§ 2922j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on purchase of drop-in fuel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9fe4507-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less frequently than annually, the Secretary of Defense shall submit to Congress a report that, for the year covered by the report—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9fe4508-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies each instance in which the Secretary purchased drop-in fuel that was not cost-competitive with traditional fuel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fe4509-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each instance identified under paragraph (1), states whether the purchase was based on a military requirement or not.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9fe450a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9fe450b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “drop-in fuel” means a neat or blended liquid hydrocarbon fuel designed as a direct replacement for a traditional fuel with comparable performance characteristics and compatible with existing infrastructure and equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fe450c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “traditional fuel” means a liquid hydrocarbon fuel derived or refined from petroleum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9fe450d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tIII/s315/b"},"text":"Pub. L. 118–159, div. A, title III, § 315(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1852"},"text":"138 Stat. 1852","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
