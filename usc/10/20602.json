{"tag":"section","attrib":{"id":"idabcceaaa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20602"},"text":null,"children":[{"tag":"num","attrib":{"value":"20602"},"text":"§ 20602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers: computation of years of service for voluntary retirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabcceaab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20602/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Years of Active Service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purpose of determining whether an officer of the Space Force may be retired under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20601"},"text":"section 20601 of this title","children":[],"tail":", the officer’s years of service are computed by adding all active service in the armed forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabcceaac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20602/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reference to Section Excluding Service During Certain Periods","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s972/b"},"text":"Section 972(b) of this title","children":[],"tail":" excludes from computation of an officer’s years of service for purposes of this section any time identified with respect to that officer under that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabcceaad-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1719A/a"},"text":"Pub. L. 118–31, div. A, title XVII, § 1719A(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/663"},"text":"137 Stat. 663","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
