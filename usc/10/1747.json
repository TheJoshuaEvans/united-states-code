{"tag":"section","attrib":{"id":"ida90d7c8f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1747"},"text":null,"children":[{"tag":"num","attrib":{"value":"1747"},"text":"§ 1747.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition fellowship program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida90d7c90-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1747/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall establish and carry out an acquisition fellowship program in accordance with this section in order to enhance the ability of the Department of Defense to recruit employees who are highly qualified in fields of acquisition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90d7c91-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1747/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Number of Fellowships","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may designate up to 25 prospective employees of the Department of Defense as acquisition fellows.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90d7c92-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1747/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to be eligible for designation as an acquisition fellow, an employee—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90d7c93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1747/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must complete at least 2 years of Federal Government service as an employee in an acquisition position in the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90d7c94-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1747/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must be serving in an acquisition position in the Department of Defense that involves the performance of duties likely to result in significant restrictions under law on the employment activities of that employee after leaving Government service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90d7c95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1747/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Two-Year Period of Research and Teaching","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under the fellowship program, the Secretary of Defense shall pay designated acquisition fellows to engage in research or teaching for a 2-year period in a field related to Federal Government acquisition policy. Such research or teaching may be conducted in the defense acquisition university structure of the Department of Defense, any other institution of professional education of the Federal Government, or a nonprofit institution of higher education. Each fellow shall be paid at a rate equal to the rate of pay payable for the level of the position in which the fellow served in the Department of Defense before undertaking such research or teaching.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida90d7c96-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tVIII/s841/a"},"text":"Pub. L. 102–484, div. A, title VIII, § 841(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2468"},"text":"106 Stat. 2468","children":[],"tail":", § 2410h; renumbered § 1747, "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tX/s1062/a/10/A"},"text":"Pub. L. 107–314, div. A, title X, § 1062(a)(10)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2650"},"text":"116 Stat. 2650","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida90d7c97-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida90d7c98-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida90d7c99-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2410h"},"text":"section 2410h of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
