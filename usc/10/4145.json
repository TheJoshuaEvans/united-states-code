{"tag":"section","attrib":{"id":"idaa601409-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145"},"text":null,"children":[{"tag":"num","attrib":{"value":"4145"},"text":"§ 4145.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program for the enhancement of the research, development, test, and evaluation centers of the Department of Defense","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa60140a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense and the Secretaries of the military departments shall jointly carry out a program to demonstrate methods for the more effective development of technology and management of functions at eligible centers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa60140b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Centers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of the program, the eligible centers are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa60140c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the science and technology reinvention laboratories, as designated by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4121/b"},"text":"section 4121(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa60140d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the test and evaluation centers which are activities specified as part of the Major Range and Test Facility Base in Department of Defense Directive 3200.11 (or any successor document);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa60140e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Defense Advanced Research Projects Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa60140f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Defense Innovation Unit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa601410-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Strategic Capabilities Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa601411-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Responsible Officials Concerned","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “responsible official concerned” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa601412-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary of the Army for Acquisition, Technology, and Logistics, with respect to matters concerning the Army;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa601413-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary of the Navy for Research, Development, and Acquisition, with respect to matters concerning the Navy and the Marine Corps; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa601414-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary of the Air Force for Acquisition, with respect to matters concerning the Air Force and the Space Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa601415-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Deputy Secretary of Defense, with respect to matters concerning the Defense Advanced Research Projects Agency, the Defense Innovation Unit, and the Strategic Capabilities Office, and any other matters not covered by paragraphs (1), (2), and (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa601416-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participation in Program.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa601417-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), the head of each eligible center shall submit to the responsible official concerned a proposal on, and implement, alternative and innovative methods of effective management and operations of eligible centers, rapid project delivery, support, experimentation, prototyping, and partnership with universities and private sector entities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa601418-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to generate greater value and efficiencies in research and development activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa601419-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to enable more efficient and effective operations of supporting activities, such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa60141a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facility management, construction, and repair;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa60141b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" business operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa60141c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel management policies and practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa60141d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145/d/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intramural and public outreach; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa60141e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enable more rapid deployment of warfighter capabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa60141f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an eligible center shall implement each method proposed under paragraph (1) unless such method is disapproved in writing by the responsible official concerned within 60 days of receiving the proposal from the eligible center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa601420-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4145/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver Authority for Demonstration and Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an eligible center may waive any regulation, restriction, requirement, guidance, policy, procedure, or departmental instruction that would affect the implementation of a method proposed under subsection (d)(1), unless such implementation would be prohibited by a provision of a Federal statute or common law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa601421-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tII/s213/a"},"text":"Pub. L. 119–60, div. A, title II, § 213(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/773"},"text":"139 Stat. 773","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa601422-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa601423-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa601424-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was initially transferred from section 2350","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1844/b"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1844(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4246"},"text":"134 Stat. 4246","children":[],"tail":", to become effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":". Subsequently, "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/u/5/B"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(u)(5)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2154"},"text":"135 Stat. 2154","children":[],"tail":", struck out and added a new "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1844/b"},"text":"section 1844(b) of Pub. L. 116–283","children":[],"tail":", effective as if included therein. The new section 1844(b) did not direct any transfers to section 4145 thereby omitting that section before it took effect. After other amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":", section 2350"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" was not transferred."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
