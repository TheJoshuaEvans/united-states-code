{"tag":"section","attrib":{"id":"ida92549d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2103"},"text":null,"children":[{"tag":"num","attrib":{"value":"2103"},"text":"§ 2103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida92549d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be eligible for membership in the program a person must be a student at an institution where a unit of the Senior Reserve Officers’ Training Corps is established. However, a student at an institution that does not have a unit of the Corps is eligible, if otherwise qualified, to be a member of a unit at another institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92549d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Persons from foreign countries may be enrolled as members of the program when their enrollment is approved by the Secretary of the military department concerned under criteria approved by the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92549d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A medical, dental, pharmacy, veterinary, or sciences allied to medicine, student may be admitted to a unit of the program for a course of training consisting of 90 hours of instruction a year for four academic years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92549da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under such conditions as the Secretary of the military department concerned may prescribe, a medical, dental, pharmacy, veterinary, or sciences allied to medicine, student who is a commissioned officer of a reserve component of an armed force may be admitted to and trained in a unit of the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92549db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2103/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An educational institution at which a unit of the program has been established shall give priority for enrollment in the program to students who are eligible for advanced training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2104"},"text":"section 2104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida92549dc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/647/tII/s201/1"},"text":"Pub. L. 88–647, title II, § 201(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1065"},"text":"78 Stat. 1065","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s551/a/1"},"text":"Pub. L. 104–201, div. A, title V, § 551(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2525"},"text":"110 Stat. 2525","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida92549dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida92549de-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida92549df-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
