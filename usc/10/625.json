{"tag":"section","attrib":{"id":"ida7ef6189-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s625"},"text":null,"children":[{"tag":"num","attrib":{"value":"625"},"text":"§ 625.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to vacate promotions to grades of brigadier general and rear admiral (lower half)","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7ef618a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s625/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may vacate the promotion to the grade of brigadier general or rear admiral (lower half) of an officer who has served less than 18 months in that grade after promotion to that grade under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7ef618b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s625/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer of the Army, Air Force, or Marine Corps whose promotion is vacated under this section holds the regular grade of colonel, if he is a regular officer, or the reserve grade of colonel, if he is a reserve officer. An officer of the Navy whose promotion is vacated under this section holds the regular grade of captain, if he is a regular officer, or the reserve grade of captain, if he is a reserve officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7ef618c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s625/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The position on the active-duty list of an officer whose promotion is vacated under this section is the position he would have held had he not been promoted to the grade of brigadier general or rear admiral (lower half).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7ef618d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tI/s105"},"text":"Pub. L. 96–513, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2858"},"text":"94 Stat. 2858","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/86/tIV/s405/b/1"},"text":"Pub. L. 97–86, title IV, § 405(b)(1)","children":[],"tail":", (4)(A), "},{"tag":"date","attrib":{"date":"1981-12-01"},"text":"Dec. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1105"},"text":"95 Stat. 1105","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tV/s514/b/1"},"text":"Pub. L. 99–145, title V, § 514(b)(1)","children":[],"tail":", (4)(A), "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/628"},"text":"99 Stat. 628","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/3/H"},"text":"Pub. L. 116–283, div. A, title IX, § 924(b)(3)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3821"},"text":"134 Stat. 3821","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1722/b/4"},"text":"Pub. L. 118–31, div. A, title XVII, § 1722(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/668"},"text":"137 Stat. 668","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7ef618e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7ef618f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7ef6190-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" substituted “or Marine Corps” for “Marine Corps, or Space Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Marine Corps, or Space Force” for “or Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" substituted “rear admiral (lower half)” for “commodore” in section catchline and subsecs. (a) and (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/86"},"text":"Pub. L. 97–86","children":[],"tail":" substituted “commodore” for “commodore admiral” in section catchline and subsecs. (a) and (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7ef6191-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7ef6192-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"tex