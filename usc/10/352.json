{"tag":"section","attrib":{"id":"ida7a7d1c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s352"},"text":null,"children":[{"tag":"num","attrib":{"value":"352"},"text":"§ 352.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Naval Small Craft Instruction and Technical Training School","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7a7d1c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s352/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall operate an education and training facility known as the “Naval Small Craft Instruction and Technical Training School” (in this section referred to as the “School”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a7d1c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s352/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Executive Agent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall designate the Secretary of a military department as the Department of Defense executive agent for carrying out the responsibilities of the Secretary of Defense under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a7d1c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s352/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the School shall be to provide to the military and other security forces of one or more friendly foreign countries education and training under any other provision of law related to naval small craft instruction and training and to increase professionalism, readiness, and respect for human rights through formal courses of instruction or mobile training teams for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a7d1c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s352/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operation, employment, maintenance, and logistics of specialized equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a7d1c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s352/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" participation in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a7d1ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s352/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" joint exercises; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a7d1cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s352/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coalition or international military operations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a7d1cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s352/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" improved interoperability between—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a7d1cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s352/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the armed forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a7d1ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s352/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the military and other security forces of the one or more friendly foreign countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a7d1cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s352/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Personnel Eligible To Receive Education and Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may not provide education or training at the School to any personnel of a country that is prohibited from receiving such education or training under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a7d1d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s352/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Costs","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a7d1d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s352/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The fixed costs of the School may be paid from amounts made available for the Navy as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a7d1d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s352/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The costs of operating and maintaining the School may be paid from amounts made available to the Navy for operation and maintenance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a7d1d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s352/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The costs of the equipment requirements of the School may be paid from amounts made available to the Navy for procurement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a7d1d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s352/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The costs of the facilities construction requirements of the School may be paid from amounts made available to the Navy for military construction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a7d1d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s352/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The food procurement and service costs of the School that may be paid from amounts made available to the Navy for operation and maintenance are as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a7d1d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s352/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The costs of providing food services to personnel, visitors, and international students at the School.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a7d1d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s352/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The costs of operating, maintaining, and sustaining a dining facility or contracted food services at the School.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a7d1d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s352/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tuition fees charged for personnel who attend the School may not include any amount for the fixed costs of operating and maintaining the School.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a7d1d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s352/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than March 15 each year, the Secretary of Defense, with the concurrence of the Secretary of State, shall submit to the appropriate congressional committees a detailed report on the activities and operating costs of the School during the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7a7d1da-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXII/s1208/a/1"},"text":"Pub. L. 115–232, div. A, title XII, § 1208(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2021"},"text":"132 Stat. 2021","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXII/s1202/a"},"text":"Pub. L. 118–159, div. A, title XII, § 1202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2093"},"text":"138 Stat. 2093","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXII/s1205"},"text":"Pub. L. 119–60, div. A, title XII, § 1205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1081"},"text":"139 Stat. 1081","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7a7d1db-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7a7d1dc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7a7d1dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1205/1"},"text":"Pub. L. 119–60, § 1205(1)","children":[],"tail":", substituted “shall” for “may”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1205/2"},"text":"Pub. L. 119–60, § 1205(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" amended subsec. (e) generally. Prior to amendment, text read as follows: “The fixed costs of operation and maintenance of the School in a fiscal year may be paid from amounts made available for such fiscal year for operation and maintenance of the Department of Defense.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7a7d1de-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7a7d1df-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Updates Required","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXII/s1202/b"},"text":"Pub. L. 118–159, div. A, title XII, § 1202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2093"},"text":"138 Stat. 2093","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tXII/s1202/b"},"text":"“Not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"], the Secretary of Defense shall update the Security Assistance Management Manual (DSCA 5105.38–M) and volume 15 of the Department of Defense Financial Management Regulation (DoD 7000.14–R) in accordance with the amendment made by this section [amending this section].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7a7d1e0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limitation on Use of Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXII/s1208/c"},"text":"Pub. L. 115–232, div. A, title XII, § 1208(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2022"},"text":"132 Stat. 2022","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/232/dA/tXII/s1208/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s352"},"text":"section 352 of title 10","children":[],"tail":", United States Code (as so added), may be construed as authorizing the use of funds appropriated for the Department of Defense for any purpose described in paragraph (2) unless specifically authorized by an Act of Congress other than that section or this Act [see Tables for classification]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes described in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The operation of a facility other than the Naval Small Craft Instruction and Technical Training School that is in operation as of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":"] for the provision of education and training authorized to be provided by the School."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The construction or expansion of any facility of the School.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
