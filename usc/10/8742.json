{"tag":"section","attrib":{"id":"idab4766c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8742"},"text":null,"children":[{"tag":"num","attrib":{"value":"8742"},"text":"§ 8742.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Physical examination: employees engaged in hazardous occupations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab4766c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8742/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy may provide for physical examination by civilians of employees engaged in hazardous occupations, where the professional services of the Medical Department are not available. The Secretary may compensate these civilians for their services, on a contract or fee basis, at the rates customary in the locality.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab4766c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8742/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, to the extent he considers proper, may delegate the authority conferred by this section to any person in the Department of the Navy, with or without the authority to make successive redelegations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab4766c6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/462"},"text":"70A Stat. 462","children":[],"tail":", § 7472; renumbered § 8742, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/6"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"da