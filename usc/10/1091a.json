{"tag":"section","attrib":{"id":"ida88a42c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1091a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1091a"},"text":"§ 1091a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification in patient medical records of affiliation of certain non-Department of Defense health care providers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida88a42c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1091a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall ensure that medical records of the Department of Defense include the organizational affiliation of any independent health care contractor identified in such medical records.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida88a42c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1091a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Independent Health Care Contractor Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “independent health care contractor” means a health care provider who meets the following criteria:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida88a42c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1091a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The health care provider is a nonpersonal services contractor, or an employee of such a contractor, pursuant to subpart 37.4 of the Federal Acquisition Regulation, or other applicable regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida88a42c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1091a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The health care provider provides health care services under this chapter in any military medical treatment facility (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1073c/j"},"text":"section 1073c(j) of this title","children":[],"tail":") or other location under the jurisdiction of the Secretary of Defense, including an operational clinic."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida88a42ca-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVII/s711"},"text":"Pub. L. 118–159, div. A, title VII, § 711","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1947"},"text":"138 Stat. 1947","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVII/s711/b"},"text":"Pub. L. 119–60, div. A, title VII, § 711(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/919"},"text":"139 Stat. 919","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida88a42cb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida88a42cc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida88a42cd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “section 1073c(j)” for “section 1073c(i)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
