{"tag":"section","attrib":{"id":"idabb9d849-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15102"},"text":null,"children":[{"tag":"num","attrib":{"value":"15102"},"text":"§ 15102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection for promotion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabb9d84a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in this section, the selection for promotion of officers in any competitive category of officers designated for purposes of this chapter shall be governed by the provisions under chapter 1403 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb9d84b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Recommendation for Promotion of Officers Below Promotion Zone","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14301/d"},"text":"Section 14301(d) of this title","children":[],"tail":" shall not apply to the selection for promotion of officers described in subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb9d84c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendation for Officers to Be Excluded From Future Consideration for Promotion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In making recommendations pursuant to chapter 1403 of this title for purposes of the administration of this chapter, a selection board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14101/a"},"text":"section 14101(a) of this title","children":[],"tail":" may recommend that an officer considered by the board be excluded from future consideration for promotion under this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabb9d84d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tV/s514/a"},"text":"Pub. L. 118–31, div. A, title V, § 514(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/246"},"text":"137 Stat. 246","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
