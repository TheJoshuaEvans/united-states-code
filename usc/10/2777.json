{"tag":"section","attrib":{"id":"ida9cea953-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2777"},"text":null,"children":[{"tag":"num","attrib":{"value":"2777"},"text":"§ 2777.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requisitions for advances and removal of charges outstanding in accounts of advances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9cea954-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2777/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of a military department may issue to a disbursing official or agent of the department a requisition for an advance of not more than the total appropriation for the department. The amount advanced shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9cea955-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2777/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under an “account of advances” for the department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cea956-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2777/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a proper voucher;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cea957-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2777/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only for obligations payable under specific appropriations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cea958-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2777/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charged to, and within the limits of, each specific appropriation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cea959-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2777/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" returned to the account of advances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cea95a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2777/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A charge outstanding in an account of advances of a military department shall be removed by crediting the account of advances of the department and deducting the amount of the charge from an appropriation made available for advances to the department when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9cea95b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2777/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relief has been granted or may be granted later to a disbursing official or agent of the department operating under an account of advances and under a law having no provision for removing charges outstanding in an account of advances; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cea95c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2777/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the charge has been—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9cea95d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2777/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outstanding in the account of advances of the department for 2 complete fiscal years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9cea95e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2777/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certified by the head of the department as uncollectable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cea95f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2777/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (b) does not affect the financial liability of a disbursing official or agent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9cea960-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258/s2/b/8/B"},"text":"Pub. L. 97–258, § 2(b)(8)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1055"},"text":"96 Stat. 1055","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXIV/s1405/43"},"text":"Pub. L. 98–525, title XIV, § 1405(43)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2625"},"text":"98 Stat. 2625","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tI/s105/c"},"text":"Pub. L. 104–316, title I, § 105(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3830"},"text":"110 Stat. 3830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9cea961-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida9cea962-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida9cea963-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2777(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:536, 537.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1920-06-05/ch240"},"text":"June 5, 1920, ch. 240","children":[],"tail":" (1st, 2d pars. under heading “Advances to Disbursing Officers”), "},{"tag":"html:a","attrib":{"href":"/us/stat/41/975"},"text":"41 Stat. 975","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:539, 540.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1878-06-19/ch312"},"text":"June 19, 1878, ch. 312","children":[],"tail":", §§ 1, 2, "},{"tag":"html:a","attrib":{"href":"/us/stat/20/167"},"text":"20 Stat. 167","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2777(b), (c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:95b (related to Army, Navy, Air Force).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1954-06-04/ch264/s1"},"text":"June 4, 1954, ch. 264, § 1","children":[],"tail":" (related to Army, Navy, Air Force), "},{"tag":"html:a","attrib":{"href":"/us/stat/68/175"},"text":"68 Stat. 175","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 6, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/92/310/s231/gg"},"text":"Pub. L. 92–310, § 231(gg)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/213"},"text":"86 Stat. 213","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the words “disbursing official” are substituted for “disbursing officers” for consistency with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “Secretary of a military department” are substituted for “Secretary of the Army” in 31:536 and for “Secretary of the Navy” in 31:539 because of 10:101(7). The title of Secretary of War was changed to Secretary of the Army by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/s205/a"},"text":"section 205(a) of the Act of July 26, 1947","children":[],"tail":" (ch. 343, "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":"), and by sections 1 and 53 of the Act of "},{"tag":"date","attrib":{"date":"1956-08-10"},"text":"August 10, 1956","children":[],"tail":" (ch. 1041, "},{"tag":"ref","attrib":{"href":"/us/stat/70A/157"},"text":"70A Stat. 157","children":[],"tail":", 676). The Secretary of the Air Force is included because of sections 205(a) and 207(a) and (f) of the Act of "},{"tag":"date","attrib":{"date":"1947-07-26"},"text":"July 26, 1947","children":[],"tail":" (ch. 343, "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":", 502), and "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/s1"},"text":"section 1 of the Act of August 10, 1956","children":[],"tail":" (ch. 1041, "},{"tag":"ref","attrib":{"href":"/us/stat/70A/488"},"text":"70A Stat. 488","children":[],"tail":"). In clause (1), the word “General” in 31:539 is omitted as surplus. In clause (3), the words “and ‘Pay of the Navy’ shall be used only for its legitimate purpose, as provided by law” are omitted as unnecessary. In clause (5), the words “by pay and counterwarrant” in 31:537 and 540 are omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the word “appropriate” is omitted as surplus. The words “deducting the amount of the charge from” are substituted for “debiting” for clarity. In clause (2)(B), the word “concerned” is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “in any way” and “of the United States” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9cea964-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9cea965-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316"},"text":"Pub. L. 104–316","children":[],"tail":" struck out “to the Comptroller General” after “head of the department”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525"},"text":"Pub. L. 98–525","children":[],"tail":" struck out “of this section” after “Subsection (b)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
