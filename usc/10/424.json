{"tag":"section","attrib":{"id":"ida7b873ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s424"},"text":null,"children":[{"tag":"num","attrib":{"value":"424"},"text":"§ 424.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of organizational and personnel information: exemption for specified intelligence agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7b873ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s424/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemption From Disclosure","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as required by the President or as provided in subsection (c), no provision of law shall be construed to require the disclosure of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7b873ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s424/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the organization or any function of an organization of the Department of Defense named in subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b873af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s424/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of persons employed by or assigned or detailed to any such organization or the name, official title, occupational series, grade, or salary of any such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b873b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s424/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Organizations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies to the following organizations of the Department of Defense:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bae4b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s424/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Defense Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bae4b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s424/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Reconnaissance Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bae4b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s424/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Geospatial-Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bae4b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s424/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of Information to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) does not apply with respect to the provision of information to Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7bae4b5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXI/s1112/d"},"text":"Pub. L. 104–201, div. A, title XI, § 1112(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2683"},"text":"110 Stat. 2683","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tIX/s921/d/5/A"},"text":"Pub. L. 108–136, div. A, title IX, § 921(d)(5)(A)","children":[],"tail":", (B)(i), "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1569"},"text":"117 Stat. 1569","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7bae4b6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7bae4b7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida7bae4b8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 424, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/178/tVI/s603/a"},"text":"Pub. L. 100–178, title VI, § 603(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-02"},"text":"Dec. 2, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1016"},"text":"101 Stat. 1016","children":[],"tail":", § 1607; renumbered § 424 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/453/tVII/s703/a"},"text":"Pub. L. 100–453, title VII, § 703(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1912"},"text":"102 Stat. 1912","children":[],"tail":", related to disclosure of organizational and personnel information with respect to the Defense Intelligence Agency prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXI"},"text":"Pub. L. 104–201, div. A, title XI","children":[],"tail":", §§ 1112(d), 1124, "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2683"},"text":"110 Stat. 2683","children":[],"tail":", 2688, effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7bae4b9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s921/d/5/B/i"},"text":"Pub. L. 108–136, § 921(d)(5)(B)(i)","children":[],"tail":", substituted “Disclosure of organizational and personnel information: exemption for specified intelligence agencies” for “Disclosure of organizational and personnel information: exemption for Defense Intelligence Agency, National Reconnaissance Office, and National Imagery and Mapping Agency” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s921/d/5/A"},"text":"Pub. L. 108–136, § 921(d)(5)(A)","children":[],"tail":", substituted “National Geospatial-Intelligence Agency” for “National Imagery and Mapping Agency”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7bae4ba-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida7bae4bb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1124"},"text":"section 1124 of Pub. L. 104–201","children":[],"tail":", set out as an Effective Date of 1996 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s193"},"text":"section 193 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7bae4bc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Disclosure of Governmental Affiliation by Department of Defense Intelligence Personnel Outside of United States","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/359/tV/s503"},"text":"Pub. L. 103–359, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3430"},"text":"108 Stat. 3430","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/359/tV/s503"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a/e/3"},"text":"section 552a(e)(3) of title 5","children":[],"tail":", United States Code, intelligence personnel of the Department of Defense who are authorized by the Secretary of Defense to collect intelligence from human sources shall not be required, when making an initial assessment contact outside the United States, to give notice of governmental affiliation to potential sources who are United States persons."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Records concerning such contacts shall be maintained by the Department of Defense and made available upon request to the appropriate committees of the Congress in accordance with applicable security procedures. Such records shall include for each such contact an explanation of why notice of government affiliation could not reasonably be provided, the nature of the information obtained from the United States person as a result of the contact, and whether additional contacts resulted with the person concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘United States’ includes the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, and any territory or possession of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘United States person’ means any citizen, national, or permanent resident alien of the United States.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7bae4bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Exemption for National Reconnaissance Office From Any Requirement for Disclosure of Personnel Information","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/496/tIV/s406"},"text":"Pub. L. 102–496, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3186"},"text":"106 Stat. 3186","children":[],"tail":", which provided that, except as required by President and except with respect to provision of information to Congress, nothing in "},{"tag":"ref","attrib":{"href":"/us/pl/102/496"},"text":"Pub. L. 102–496","children":[],"tail":" or any other provision of law was to be construed to require disclosure of name, title, or salary of any person employed by, or assigned or detailed to, National Reconnaissance Office or disclosure of number of such persons, was repealed and restated in former "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s425"},"text":"section 425 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/103/178/tV/s503/a/1"},"text":"Pub. L. 103–178, title V, § 503(a)(1)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1993-12-03"},"text":"Dec. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2038"},"text":"107 Stat. 2038","children":[],"tail":", 2039."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
