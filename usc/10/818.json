{"tag":"section","attrib":{"id":"ida813175a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s818"},"text":null,"children":[{"tag":"num","attrib":{"value":"818"},"text":"§ 818.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 18. Jurisdiction of general courts-martial","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida813175b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s818/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s817"},"text":"section 817 of this title","children":[],"tail":" (article 17), general courts-martial have jurisdiction to try persons subject to this chapter for any offense made punishable by this chapter and may, under such limitations as the President may prescribe, adjudge any punishment not forbidden by this chapter, including the penalty of death when specifically authorized by this chapter. General courts-martial also have jurisdiction to try any person who by the law of war is subject to trial by a military tribunal and may adjudge any punishment permitted by the law of war."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida813175c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s818/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A general court-martial of the kind specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s816/b/3"},"text":"section 816(b)(3) of this title","children":[],"tail":" (article 16(b)(3)) shall not have jurisdiction to try any person for any offense for which the death penalty may be adjudged unless the case has been previously referred to trial as a noncapital case."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida813175d-3a6f-11f1-a58a-d8db54b14ab5",