{"tag":"section","attrib":{"id":"idab5a79d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9020"},"text":null,"children":[{"tag":"num","attrib":{"value":"9020"},"text":"§ 9020.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspector General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab5a79d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9020/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is an Inspector General of the Department of the Air Force who shall be detailed to such position by the Secretary of the Air Force from the general officers of the Air Force or the Space Force. An officer may not be detailed to such position for a tour of duty of more than four years, except that the Secretary may extend such a tour of duty if he makes a special finding that the extension is necessary in the public interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab5a79d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9020/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When directed by the Secretary, the Chief of Staff of the Air Force, or the Chief of Space Operations, the Inspector General shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab5a79d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9020/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inquire into and report upon the discipline, efficiency, and economy of the Department of the Air Force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5a79d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9020/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform any other duties prescribed by the Secretary, the Chief of Staff, or the Chief of Space Operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab5a79da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9020/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Inspector General shall periodically propose programs of inspections to the Secretary of the Air Force and shall recommend additional inspections and investigations as may appear appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab5a79db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9020/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Inspector General shall cooperate fully with the Inspector General of the Department of Defense in connection with the performance of any duty or function by the Inspector General of the Department of Defense under chapter 4 of title 5 regarding the Department of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab5a79dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9020/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Inspector General shall have such deputies and assistants as the Secretary of the Air Force may prescribe. Each such deputy and assistant shall be an officer detailed by the Secretary to that position from the officers of the Air Force or the Space Force for a tour of duty of not more than four years, under a procedure prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab5a79dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s521/a/5"},"text":"Pub. L. 99–433, title V, § 521(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1059"},"text":"100 Stat. 1059","children":[],"tail":", § 8020; renumbered § 9020, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/c"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1833"},"text":"132 Stat. 1833","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s923/b/4"},"text":"Pub. L. 116–283, div. A, title IX, § 923(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3808"},"text":"134 Stat. 3808","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/32"},"text":"Pub. L. 117–286, § 4(b)(32)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4346"},"text":"136 Stat. 4346","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1741/a/7"},"text":"Pub. L. 118–31, div. A, title XVII, § 1741(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/680"},"text":"137 Stat. 680","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab5a79de-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab5a79df-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab5a79e0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" struck out “the general, flag, or equivalent officers of” before “the Space Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 4 of title 5” for “the Inspector General Act of 1978 (5 U.S.C. App. 3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/b/4/A"},"text":"Pub. L. 116–283, § 923(b)(4)(A)","children":[],"tail":", inserted “Department of the” after “Inspector General of the” and “or the general, flag, or equivalent officers of the Space Force” after “general officers of the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/b/4/B/i"},"text":"Pub. L. 116–283, § 923(b)(4)(B)(i)","children":[],"tail":", substituted “, the Chief of Staff of the Air Force, or the Chief of Space Operations” for “or the Chief of Staff”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/b/4/B/ii"},"text":"Pub. L. 116–283, § 923(b)(4)(B)(ii)","children":[],"tail":", inserted “Department of the” before “Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/b/4/B/iii"},"text":"Pub. L. 116–283, § 923(b)(4)(B)(iii)","children":[],"tail":", substituted “, the Chief of Staff, or the Chief of Space Operations” for “or the Chief of Staff”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/b/4/C"},"text":"Pub. L. 116–283, § 923(b)(4)(C)","children":[],"tail":", inserted “or the Space Force” before “for a tour of duty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8020"},"text":"section 8020 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab5a79e1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab5a79e2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab5a79e3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Service of Incumbents in Certain Positions Without Reappointment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s923/f"},"text":"Pub. L. 116–283, div. A, title IX, § 923(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3820"},"text":"134 Stat. 3820","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dA/tIX/s923/f"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The individual serving in a position under a provision of law specified in paragraph (2) as of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"] may continue to serve in such position after that date without further appointment as otherwise provided by such provision of law, notwithstanding the amendment of such provision of law by subsection (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provisions of law","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of law specified in this paragraph are the provisions of title 10, United States Code, as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 9020, relating to the Inspector General of the Department of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 9036. [sic] relating to the Surgeon General of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 9037(a), relating to the Judge Advocate General of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 9037(d), relating to the Deputy Judge Advocate General of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 9039, relating to the Chief of Chaplains for the Air Force and the Space Force.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
