"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6222(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"34 App.:701–4.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6222(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"34 App.:701–5.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “and appropriate” are omitted as covered by the word “necessary”. The words “and ranks” are omitted as covered by the word “grades”. The second sentence of 34 App.:701 is omitted as covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s6224"},"text":"section 6224 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “United States” and “or the United States Marine Corps Reserve” are omitted as unnecessary in view of the definition of “Marine Corps” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s5001/a/2"},"text":"section 5001(a)(2) of this title","children":[],"tail":". The words “as authorized by sections 701 to 701–5 of this title” are omitted as surplusage."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “from the United States . . . as provided by law” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f), the words “a member who holds, or has held” are substituted for the words “Directors and assistant directors of the Marine Band and former directors and assistant directors who have held”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab17a467-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab17a468-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 8287 to 8289 were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tII/s204"},"text":"Pub. L. 96–513, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2880"},"text":"94 Stat. 2880","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 8287, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/508"},"text":"70A Stat. 508","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1957-08-21"},"text":"Aug. 21, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/155/tIII/s301/6"},"text":"Pub. L. 85–155, title III, § 301(6)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/386"},"text":"71 Stat. 386","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/169"},"text":"Pub. L. 85–861, § 1(169)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1517"},"text":"72 Stat. 1517","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1966-09-30"},"text":"Sept. 30, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/609/s1/28"},"text":"Pub. L. 89–609, § 1(28)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/854"},"text":"80 Stat. 854","children":[],"tail":", provided service credit for a person originally appointed in a commissioned grade in Regular Air Force, other than a person appointed as a medical or dental officer, for purpose of determining grade, position on a promotion list, seniority in his grade in Regular Air Force, and eligibility for promotion, with appointment and service credit restrictions on persons who were cadets at the United States Air Force, Military, or Naval Academies but were not graduated, and a disallowance of service credit under this section for persons who graduated from one of these Academies. See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s533"},"text":"section 533 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 8288, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/508"},"text":"70A Stat. 508","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1957-08-02"},"text":"Aug. 2, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/155/tIII/s301/7"},"text":"Pub. L. 85–155, title III, § 301(7)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/387"},"text":"71 Stat. 387","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/170"},"text":"Pub. L. 85–861, § 1(170)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1518"},"text":"72 Stat. 1518","children":[],"tail":", provided for determination of grade of a person originally appointed as a commissioned officer in Regular Air Force, other than persons appointed as medical or dental officers. See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s533"},"text":"section 533 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 8289, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/509"},"text":"70A Stat. 509","children":[],"tail":", provided that no person be originally appointed as a first lieutenant in Regular Air Force with a view to designation as a medical officer until he passes an examination of his professional fitness before an examining board composed of at least three medical officers designated by Secretary of Air Force. See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s532"},"text":"section 532 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab17a469-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6222"},"text":"section 6222 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" amended section catchline and text generally. Prior to amendment, section consisted of subsecs. (a) to (f) relating to composition of the United States Marine Band, designation of its director and assistant directors, grades upon initial appointment, promotion, retirement, and revocation of appointments."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsecs. (e) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" redesignated subsecs. (f) and (g) as (e) and (f), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/197"},"text":"Pub. L. 91–197","children":[],"tail":" struck out provision that the grade of the director be no higher than lieutenant colonel and that the grades of the assistant directors be no higher than captain."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":" repealed subsec. (e) which related to pay and allowances of members who accepted a commission under this section. See sections 207 and 424 of Title 37, Pay and Allowances of the Uniformed Services."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":" substituted “United States Marine Band” for “United States Marine Corps Band”, and “director; assistant director” for “pay and allowances of leader and second leader” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":" authorized one director and two assistant directors instead of one leader and one second leader."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":" substituted provisions relating to designation of director and assistant directors for provisions which prescribed the pay and allowances of the leader and second leader."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":" added subsecs. (c) to (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab1a156a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab1a156b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab1a156c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","att