{"tag":"section","attrib":{"id":"idab17a456-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8287"},"text":null,"children":[{"tag":"num","attrib":{"value":"8287"},"text":"§ 8287.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Marine Band; United States Marine Drum and Bugle Corps: composition; appointment and promotion of members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab17a457-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8287/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"United States Marine Band","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The band of the Marine Corps shall be composed of one director, two assistant directors, and other personnel in such numbers and grades as the Secretary of the Navy determines to be necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab17a458-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8287/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"United States Marine Drum and Bugle Corps","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The drum and bugle corps of the Marine Corps shall be composed of one commanding officer and other personnel in such numbers and grades as the Secretary of the Navy determines to be necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab17a459-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8287/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment and Promotion","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab17a45a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8287/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy shall prescribe regulations for the appointment and promotion of members of the Marine Band and members of the Marine Drum and Bugle Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab17a45b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8287/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may from time to time appoint members of the Marine Band and members of the Marine Drum and Bugle Corps to grades not above the grade of captain. The authority of the President to make appointments under this paragraph may be delegated only to the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab17a45c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8287/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President, by and with the advice and consent of the Senate, may from time to time appoint any member of the Marine Band or of the Marine Drum and Bugle Corps to a grade above the grade of captain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab17a45d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8287/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless otherwise entitled to higher retired grade and retired pay, a member of the Marine Band or Marine Drum and Bugle Corps who holds, or has held, an appointment under this section is entitled, when retired, to be retired in, and with retired pay based on, the highest grade held under this section in which the Secretary of the Navy determines that such member served satisfactorily.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab17a45e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8287/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revocation of Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Navy may revoke any appointment of a member of the Marine Band or Marine Drum and Bugle Corps. When a member’s appointment to a commissioned grade terminates under this subsection, such member is entitled, at the option of such member—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab17a45f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8287/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be discharged from the Marine Corps; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab17a460-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8287/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to revert to the grade and status such member held at the time of appointment under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab17a461-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/388"},"text":"70A Stat. 388","children":[],"tail":", § 6222; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/140"},"text":"Pub. L. 85–861, § 1(140)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1508"},"text":"72 Stat. 1508","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/649/s14c/45"},"text":"Pub. L. 87–649, § 14c(45)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/501"},"text":"76 Stat. 501","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/197"},"text":"Pub. L. 91–197","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-02-24"},"text":"Feb. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/15"},"text":"84 Stat. 15","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s513/18"},"text":"Pub. L. 96–513, title V, § 513(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2932"},"text":"94 Stat. 2932","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s599/a"},"text":"Pub. L. 109–364, div. A, title V, § 599(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2238"},"text":"120 Stat. 2238","children":[],"tail":"; renumbered § 8287, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/12"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","