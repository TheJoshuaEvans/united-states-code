{"tag":"section","attrib":{"id":"idabc82f40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20104"},"text":null,"children":[{"tag":"num","attrib":{"value":"20104"},"text":"§ 20104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Orders to active duty: with consent of member","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabc82f41-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member of the Space Force who is serving in a space force active status and is not on sustained duty, or who is serving in a space force inactive status, may, with the consent of the member, be ordered to active duty, or retained on active duty, under the following sections of chapter 1209 of this title in the same manner as applies to a member of a reserve component ordered to active duty, or retained on active duty, under that section with the consent of the member:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc82f42-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12301(d), relating to orders to active duty at any time with the consent of the member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f43-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12301(h), relating to orders to active duty in connection with medical or health care matters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f44-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20104/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12322, relating to active duty for health care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f45-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20104/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12323, relating to active duty pending line of duty determination required for response to sexual assault.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc82f46-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicable Provisions of Law","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following sections of chapter 1209 of this title pertaining to a member of a reserve component ordered to active duty with the consent of the member apply to a member of the Space Force who is ordered to active duty under this section in the same manner as to such a reserve component member:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc82f47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12308, relating to retention after becoming qualified for retired pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f48-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12309, relating to use of Reserve officers in expansion of armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f49-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20104/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12313, relating to release of reserve members from active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f4a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20104/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12314, relating to kinds of duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f4b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20104/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12315, relating to duty with or without pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f4c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20104/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12316, relating to payment of certain Reserves while on duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f4d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20104/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12318, relating to duties and funding of reserve members on active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f4e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20104/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12320, relating to grade in which ordered to active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20104/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12321, relating to a limitation on number of reserve members assigned to Reserve Officer Training Corps units.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc82f50-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1715"},"text":"Pub. L. 118–31, div. A, title XVII, § 1715","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/628"},"text":"137 Stat. 628","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
