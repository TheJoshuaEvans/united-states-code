{"tag":"section","attrib":{"id":"idaadc224a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7153"},"text":null,"children":[{"tag":"num","attrib":{"value":"7153"},"text":"§ 7153.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioned officers: appointment without specification of branch; transfer between branches","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaadc224b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7153/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appointments in commissioned grades in the Regular Army shall be made without specification of branch except in each of the special branches and as professors or director of admissions of the United States Military Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaadc224c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7153/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Commissioned officers appointed in the Regular Army without specification of branch shall be assigned, and may be transferred and reassigned, by the Secretary of the Army to branches other than the special branches, according to their professional qualifications and the needs of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaadc224d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/181"},"text":"70A Stat. 181","children":[],"tail":", § 3283; "},{"tag":"ref","attrib":{"href":"/us/pl/85/600/s1/4"},"text":"Pub. L. 85–600, § 1(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-06"},"text":"Aug. 6, 1958","children":[],"tail":