{"tag":"section","attrib":{"id":"ida8989a6b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1123"},"text":null,"children":[{"tag":"num","attrib":{"value":"1123"},"text":"§ 1123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to wear badges of military societies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8989a6c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1123/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Army, Navy, Air Force, Marine Corps, or Space Force who is a member of a military society originally composed of men who served in an armed force of the United States during the Revolutionary War, the War of 1812, the Mexican War, the Civil War, the Spanish-American War, the Philippine Insurrection, or the Chinese Relief Expedition of 1900 may wear, on occasions of ceremony, the distinctive badges adopted by that society.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8989a6d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1123/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Army, Navy, Air Force, Marine Corps, or Space Force who is a member of the Army and Navy Union of the United States may wear, on public occasions of ceremony, the distinctive badges adopted by that society.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8989a6e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/88"},"text":"70A Stat. 88","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/3/Q"},"text":"Pub. L. 116–283, div. A, title IX, 