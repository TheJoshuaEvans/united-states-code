"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1901-02-02/ch192/s41"},"text":"Feb. 2, 1901, ch. 192, § 41","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/31/758"},"text":"31 Stat. 758","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Jan. 12, 1903","children":[],"tail":", J. Res. 2, "},{"tag":"html:a","attrib":{"href":"/us/stat/32/1229"},"text":"32 Stat. 1229","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Mar. 2, 1907","children":[],"tail":", J. Res. 18, "},{"tag":"html:a","attrib":{"href":"/us/stat/34/1423"},"text":"34 Stat. 1423","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “an armed force” are substituted for the words “armies and navies”. The words “Revolutionary War”, “Civil War”, and “Philippine Insurrection” are substituted for the words “War of the Revolution”, “War of the Rebellion”, and “incident insurrection in the Philippines”, respectively, to reflect present terminology. The words “originally composed” are substituted for the words “in their own right”, to reflect an opinion of the Attorney General (see 23 Op. Atty. Gen. 454).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b), the word “member” is substituted for the words “officers and enlisted men”. The words “Navy * * * or Marine Corps” are substituted for the word “Navy”, since the word “Navy” in the source statute has, by long-standing administrative interpretation, been construed to include the Marine Corps.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “in their own right” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8989a72-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8989a73-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Marine Corps, or Space Force” for “or Marine Corps” in subsecs. (a) and (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
