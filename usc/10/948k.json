{"tag":"section","attrib":{"id":"ida834818e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948k"},"text":null,"children":[{"tag":"num","attrib":{"value":"948k"},"text":"§ 948k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail of trial counsel and defense counsel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida834818f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Detail of Counsel Generally","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8348190-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Trial counsel and military defense counsel shall be detailed for each military commission under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8348191-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assistant trial counsel and assistant and associate defense counsel may be detailed for a military commission under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8348192-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948k/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Military defense counsel for a military commission under this chapter shall be detailed as soon as practicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8348193-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948k/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall prescribe regulations providing for the manner in which trial counsel and military defense counsel are detailed for military commissions under this chapter and for the persons who are authorized to detail such counsel for such military commissions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8348194-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Trial Counsel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (e), a trial counsel detailed for a military commission under this chapter shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8348195-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948k/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a judge advocate (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":" (article 1 of the Uniform Code of Military Justice)) who is—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8348196-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948k/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a graduate of an accredited law school or a member of the bar of a Federal court or of the highest court of a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8348197-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948k/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certified as competent to perform duties as trial counsel before general courts-martial by the Judge Advocate General of the armed force of which such judge advocate is a member; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8348198-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948k/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a civilian who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8348199-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948k/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the bar of a Federal court or of the highest court of a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida834819a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948k/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise qualified to practice before the military commission pursuant to regulations prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida834819b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defense Counsel","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida834819c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948k/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to subsection (e), a military defense counsel detailed for a military commission under this chapter shall be a judge advocate (as so defined) who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida834819d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948k/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a graduate of an accredited law school or a member of the bar of a Federal court or of the highest court of a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida834819e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948k/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certified as competent to perform duties as defense counsel before general courts-martial by the Judge Advocate General of the armed force of which such judge advocate is a member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida834819f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948k/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall prescribe regulations for the appointment and performance of defense counsel in capital cases under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida83481a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948k/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chief Prosecutor; Chief Defense Counsel","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida83481a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948k/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Prosecutor in a military commission under this chapter shall meet the requirements set forth in subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83481a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948k/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Defense Counsel in a military commission under this chapter shall meet the requirements set forth in subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida83481a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948k/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ineligibility of Certain Individuals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No person who has acted as an investigator, military judge, or member of a military commission under this chapter in any case may act later as trial counsel or military defense counsel in the same case. No person who has acted for the prosecution before a military commission under this chapter may act later in the same case for the defense, nor may any person who has acted for the defense before a military commission under this chapter act later in the same case for the prosecution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida83481a4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tXVIII/s1802"},"text":"Pub. L. 111–84, div. A, title XVIII, § 1802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2577"},"text":"123 Stat. 2577","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida83481a5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida83481a6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida83481a7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 948k, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/366/s3/a/1"},"text":"Pub. L. 109–366, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2604"},"text":"120 Stat. 2604","children":[],"tail":", related to detail of trial counsel and defense counsel, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida83481a8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida83481a9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Grade of Chief Prosecutor and Chief Defense Counsel in Military Commissions Established To Try Individuals Detained at Guantanamo","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tX/s1037"},"text":"Pub. L. 113–66, div. A, title X, § 1037","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/854"},"text":"127 Stat. 854","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/66/dA/tX/s1037"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of any military commission established under chapter 47A of title 10, United States Code, to try an alien unprivileged enemy belligerent (as such terms are defined in section 948a of such title) who is detained at United States Naval Station, Guantanamo Bay, Cuba, the chief defense counsel and the chief prosecutor shall have the same grade (as that term is defined in section 101(b)(7) of such title).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may temporarily waive the requirement specified in subsection (a), if the Secretary determines that compliance with such subsection would—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be infeasible due to a non-availability of qualified officers of the same grade to fill the billets of chief defense counsel and chief prosecutor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cause a significant disruption to proceedings established under chapter 47A of title 10, United States Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the Secretary issues a waiver under paragraph (1), the Secretary shall submit to the Committees on Armed Services of the Senate and the House of Representatives the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A copy of the waiver and the determination of the Secretary to issue the waiver.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement of the basis for the determination, including an explanation of the non-availability of qualified officers or the significant disruption concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notice of the time period during which the waiver is in effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":"], the Secretary of Defense shall issue guidance to ensure that the office of the chief defense counsel and the office of the chief prosecutor receive equitable resources, personnel support, and logistical support for conducting their respective duties in connection with any military commission established under chapter 47A of title 10, United States Code, to try an alien unprivileged enemy belligerent (as such terms are defined in section 948a of such title) who is detained at United States Naval Station, Guantanamo Bay, Cuba.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
