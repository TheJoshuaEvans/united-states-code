},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5:235c.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"5:475h.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"5:628c.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1952-07-16/ch882/s2"},"text":"July 16, 1952, ch. 882, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/66/725"},"text":"66 Stat. 725","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “appointment or” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8f7f8be-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8f7f8bf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" struck out subsec. (a) heading “Waiver of employment restrictions for certain personnel”, designated subsec. (a) as entire section, and struck out subsec. (b) which read as follows: “"},{"tag":"inline","attrib":{},"text":"Notice to Congress of Certain Salary Increases","children":[],"tail":".—The Secretary of Defense shall notify the Committees on Armed Services and the Committees on Appropriations of the Senate and House of Representatives when any salary increase granted to direct and indirect hire foreign national employees of the Department of Defense overseas, stated as a percentage, is greater than the higher of the following percentages:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The percentage pay increase authorized by law for civilian employees of the Department of Defense whose pay is computed under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The percentage increase provided to national government employees of the host nation.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1482/b"},"text":"Pub. L. 101–510, § 1482(b)","children":[],"tail":", substituted “personnel of the Department of Defense” for “any expert, scientist, technician, or professional person whose employment in connection with the research and development activities of a military department is determined to be necessary by the Secretary of that department” in subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1481/d/1"},"text":"Pub. L. 101–510, § 1481(d)(1)","children":[],"tail":", (2), substituted “Employment of non-citizens” for “Laws relating to employment of non-citizens: not applicable to research and development activities” in section catchline, designated existing provisions as subsec. (a) and inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" substituted “pay” for “compensation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8f7f8c0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8f7f8c1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1482/b"},"text":"section 1482(b) of Pub. L. 101–510","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1991-10-01"},"text":"Oct. 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1482/d"},"text":"section 1482(d) of Pub. L. 101–510","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s119"},"text":"section 119 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8f7f8c2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Citizenship Requirement Not Applicable","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/75/dA/tVIII/s8002"},"text":"Pub. L. 119–75, div. A, title VIII, § 8002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-02-03"},"text":"Feb. 3, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/196"},"text":"140 Stat. 196","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/75/dA/tVIII/s8002"},"text":"“During the current fiscal year, provisions of law prohibiting the payment of compensation to, or employment of, any person not a citizen of the United States shall not apply to personnel of the Department of Defense: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That salary increases granted to direct and indirect hire foreign national employees of the Department of Defense funded by this Act [div. A of "},{"tag":"ref","attrib":{"href":"/us/pl/119/75"},"text":"Pub. L. 119–75","children":[],"tail":", see Tables for classification] shall not be at a rate in excess of the percentage increase authorized by law for civilian employees of the Department of Defense whose pay is computed under the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":", United States Code, or at a rate in excess of the percentage increase provided by the appropriate host nation to its own employees, whichever is higher: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That this section shall not apply to Department of Defense foreign service national employees serving at United States diplomatic missions whose pay is set by the Department of State under the Foreign Service Act of 1980 ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"22 U.S.C. 3901","children":[],"tail":" et seq.]: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That the limitations of this provision shall not apply to foreign national employees of the Department of Defense in the Republic of Turkey.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/47/dA/tVIII/s8002"},"text":"Pub. L. 118–47, div. A, title VIII, § 8002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-23"},"text":"Mar. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/481"},"text":"138 Stat. 481","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dC/tVIII/s8002"},"text":"Pub. L. 117–328, div. C, title VIII, § 8002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"t