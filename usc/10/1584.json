{"tag":"section","attrib":{"id":"ida8f7f8b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1584"},"text":null,"children":[{"tag":"num","attrib":{"value":"1584"},"text":"§ 1584.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment of non-citizens","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Laws prohibiting the employment of, or payment of pay or expenses to, a person who is not a citizen of the United States do not apply to personnel of the Department of Defense.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida8f7f8ba-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/118"},"text":"70A Stat. 118","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s1/20/A"},"text":"Pub. L. 97–295, § 1(20)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1290"},"text":"96 Stat. 1290","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIV"},"text":"Pub. L. 101–510, div. A, title XIV","children":[],"tail":", §§ 1481(d)(1), (2), 1482(b), "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1706"},"text":"104 Stat. 1706","children":[],"tail":", 1709; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tX/s1062/b"},"text":"Pub. L. 104–106, div. A, title X, § 1062(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/444"},"text":"110 Stat. 444","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":