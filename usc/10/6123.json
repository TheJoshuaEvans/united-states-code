{"tag":"section","attrib":{"id":"idaabd01e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6123"},"text":null,"children":[{"tag":"num","attrib":{"value":"6123"},"text":"§ 6123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceleration of depleted uranium manufacturing processes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaabd01e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6123/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceleration of Manufacturing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall require the nuclear security enterprise to accelerate the modernization of manufacturing processes for depleted uranium by 2030 so that the nuclear security enterprise—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabd01e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6123/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates bulk cold hearth melting of depleted uranium alloys to augment existing capabilities on an operational basis for war reserve components;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabd01e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6123/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufactures, on a repeatable and ongoing basis, war reserve depleted uranium alloy components using net shape casting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabd01e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6123/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates, if possible, a production facility to conduct routine operations for manufacturing depleted uranium alloy components outside of the current perimeter security fencing of the Y-12 National Security Complex, Oak Ridge, Tennessee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabd01e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6123/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has available high purity depleted uranium for the production of war reserve components.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabd01e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6123/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Briefing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2023-03-31"},"text":"March 31, 2023","children":[],"tail":", and annually thereafter through 2030, the Administrator shall provide to the congressional defense committees a briefing on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabd01e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6123/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" progress made in carrying out subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabd01ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6123/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of activities conducted under such subsection during the preceding fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabd01eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6123/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the nuclear security enterprise to convert depleted uranium fluoride hexafluoride to depleted uranium tetrafluoride.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaabd01ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1359"},"text":"139 Stat. 1359","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaabd01ed-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaabd01ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaabd01ef-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3121"},"text":"section 3121 of Pub. L. 117–263","children":[],"tail":", which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2532"},"text":"section 2532 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/11"},"text":"Pub. L. 119–60, § 3111(b)(11)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
