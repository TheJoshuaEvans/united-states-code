{"tag":"section","attrib":{"id":"idaba45417-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12603"},"text":null,"children":[{"tag":"num","attrib":{"value":"12603"},"text":"§ 12603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attendance at inactive-duty training assemblies: commercial travel at Federal supply schedule rates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaba45418-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Supply Schedule Travel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Commercial travel under Federal supply schedules is authorized for the travel of a Reserve to the location of inactive duty training to be performed by the Reserve and from that location upon completion of the training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba45419-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe in regulations such requirements, conditions, and restrictions for travel under the authority of subsection (a) as the Secretary considers appropriate. The regulations shall include policies and procedures for preventing abuses of that travel authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba4541a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12603/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement Not Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Reserve is not entitled to Government reimbursement for the cost of travel authorized under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba4541b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12603/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Transportation as Use by Military Departments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s501"},"text":"section 501 of title 40","children":[],"tail":", travel authorized under subsection (a) shall be treated as transportation for the use of a military department."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaba4541c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tVI/s635/a"},"text":"Pub. L. 105–261, div. A, title VI, § 635(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2044"},"text":"112 Stat. 2044","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/b/41"},"text":"Pub. L. 107–217, § 3(b)(41)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1298"},"text":"116 Stat. 1298","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaba4541d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaba4541e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaba4541f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s501"},"text":"section 501 of title 40","children":[],"tail":"” for “section 201(a) of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s481/a"},"text":"40 U.S.C. 481(a)","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
