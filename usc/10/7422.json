{"tag":"section","attrib":{"id":"idaaea52ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7422"},"text":null,"children":[{"tag":"num","attrib":{"value":"7422"},"text":"§ 7422.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Degree granting authority for United States Army Armament Graduate School","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaea52f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7422/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under regulations prescribed by the Secretary of the Army, the Chancellor of the United States Army Armament Graduate School may, upon the recommendation of the faculty and provost of the school, confer appropriate degrees upon graduates who meet the degree requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaea52f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7422/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A degree may not be conferred under this section unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaea52f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7422/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Education has recommended approval of the degree in accordance with the Federal Policy Governing Granting of Academic Degrees by Federal Agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaea52f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7422/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Army Armament Graduate School is accredited by the appropriate civilian academic accrediting agency or organization to award the degree, as determined by the Secretary of Education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaea52f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7422/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Notification Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaea52f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7422/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When seeking to establish degree granting authority under this section, the Secretary of Defense shall submit to the Committees on Armed Services of the Senate and the House of Representatives—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaea52f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7422/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the self-assessment questionnaire required by the Federal Policy Governing Granting of Academic Degrees by Federal Agencies, at the time the assessment is submitted to the Department of Education’s National Advisory Committee on Institutional Quality and Integrity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaea52f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7422/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the subsequent recommendations and rationale of the Secretary of Education regarding the establishment of the degree granting authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaea52f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7422/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon any modification or redesignation of existing degree granting authority, the Secretary of Defense shall submit to the Committees on Armed Services of the Senate and House of Representatives a report containing the rationale for the proposed modification or redesignation and any subsequent recommendation of the Secretary of Education on the proposed modification or redesignation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaea52f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7422/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall submit to the Committees on Armed Services of the Senate and House of Representatives a report containing an explanation of any action by the appropriate academic accrediting agency or organization not to accredit the United States Army Armament Graduate School to award any new or existing degree.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaea52fa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tV/s553/a/1"},"text":"Pub. L. 116–92, div. A, title V, § 553(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1386"},"text":"133 Stat. 1386","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaea52fb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaea52fc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaaea52fd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 7422 to 7425 were renumbered sections 8722 to 8725 of this title, respectively.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 7426, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/459"},"text":"70A Stat. 459","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/258/tII/s201/7"},"text":"Pub. L. 94–258, title II, § 201(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-05"},"text":"Apr. 5, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/309"},"text":"90 Stat. 309","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s513/32/A"},"text":"Pub. L. 96–513, title V, § 513(32)(A)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2933"},"text":"94 Stat. 2933","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXIV/s1405/52"},"text":"Pub. L. 98–525, title XIV, § 1405(52)","children":[],"ta