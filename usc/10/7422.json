 or after "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 7427 to 7430 were renumbered sections 8727 to 8730 of this title, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
