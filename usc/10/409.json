{"tag":"section","attrib":{"id":"ida7b87350-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409"},"text":null,"children":[{"tag":"num","attrib":{"value":"409"},"text":"§ 409.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Center for Complex Operations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7b87351-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Center Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may establish a center to be known as the “Center for Complex Operations” (in this section referred to as the “Center”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b87352-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Center established under subsection (a) shall be the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7b87353-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide for effective coordination in the preparation of Department of Defense personnel and other United States Government personnel for complex operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b87354-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To foster unity of effort during complex operations among—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7b87355-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the departments and agencies of the United States Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b87356-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign governments and militaries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b87357-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international organizations and international nongovernmental organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b87358-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" domestic nongovernmental organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b87359-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To conduct research; collect, analyze, and distribute lessons learned; and compile best practices in matters relating to complex operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b8735a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To identify gaps in the education and training of Department of Defense personnel, and other relevant United States Government personnel, relating to complex operations, and to facilitate efforts to fill such gaps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b8735b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Concurrence of the Secretary of State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall seek the concurrence of the Secretary of State to the extent the efforts and activities of the Center involve the entities referred to in subparagraphs (B) and (C) of subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b8735c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support From Other United States Government Departments or Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of any non-Department of Defense department or agency of the United States Government may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7b8735d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the Secretary of Defense services, including personnel support, to support the operations of the Center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b8735e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer funds to the Secretary of Defense to support the operations of the Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b8735f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance of Gifts and Donations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7b87360-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (3), the Secretary of Defense may accept from any source specified in paragraph (2) any gift or donation for purposes of defraying the costs or enhancing the operations of the Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b87361-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The sources specified in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7b87362-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The government of a State or a political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b87363-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The government of a foreign country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b87364-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A foundation or other charitable organization, including a foundation or charitable organization that is organized or operates under the laws of a foreign country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b87365-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any source in the private sector of the United States or a foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b87366-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may not accept a gift or donation under this subsection if acceptance of the gift or donation would compromise or appear to compromise—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7b87367-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the Department of Defense, any employee of the Department, or any member of the armed forces to carry out the responsibility or duty of the Department in a fair and objective manner; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b87368-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the integrity of any program of the Department or of any person involved in such a program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b87369-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide written guidance setting forth the criteria to be used in determining the applicability of paragraph (3) to any proposed gift or donation under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b8736a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Crediting of Funds Transferred or Accepted","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds transferred to or accepted by the Secretary of Defense under this section shall be credited to appropriations available to the Department of Defense for the Center, and shall be available for the same purposes, and subject to the same conditions and limitations, as the appropriations with which merged. Any funds so transferred or accepted shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b8736b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7b8736c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “complex operation” means an operation as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7b8736d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A stability operation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b8736e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A security operation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b8736f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A transition and reconstruction operation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b87370-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/g/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A counterinsurgency operation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b87371-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/g/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An operation consisting of irregular warfare.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b87372-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s409/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “gift or donation” means any gift or donation of funds, materials (including research materials), real or personal property, or services (including lecture services and faculty services).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7b87373-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title X, § 1031(a), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4589"},"text":"122 Stat. 4589","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
