{"tag":"section","attrib":{"id":"idaba6c462-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12644"},"text":null,"children":[{"tag":"num","attrib":{"value":"12644"},"text":"§ 12644.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members physically not qualified for active duty: discharge or transfer to retired status","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided by law, the Secretary concerned may provide for the honorable discharge or the transfer to a retired status of members of the reserve components under his jurisdiction who are found to be not physically qualified for active duty. However, no member of the Army National Guard of the United States or the Air National Guard of the United States may be transferred under this subsection without the consent of the governor or other appropriate authority of the jurisdiction concerned.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idaba6c463-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/79"},"text":"70A Stat. 79","children":[],"tail":", § 1004; "},{"tag":"ref","attrib":{"href":"/us/pl/86/603/s1/1"},"text":"Pub. L. 86–603, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-07"},"text":"July 7, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/357"},"text":"74 Stat. 357","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tV/s519"},"text":"Pub. L. 103–160, div. A, title V, § 519","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1651"},"text":"107 Stat. 1651","children":[],"tail":"; renumbered § 12644 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI"},"text":"Pub. L. 103–337, div. A, title XVI","children":[],"tail":", §§ 1661(a)(4), 1662(h)(2), (4)(B), "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2980"},"text":"108 Stat. 2980","children":[],"tail":", 2996, 2997.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaba6c464-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaba6c465-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaba6c466-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1004(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1004(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1004(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:949.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:950 (last sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:950 (less last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608"},"text":"July 9, 1952, ch. 608","children":[],"tail":", §§ 225, 226, "},{"tag":"html:a","attrib":{"href":"/us/stat/66/488"},"text":"66 Stat. 488","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Each * * * who is not on active duty” are substituted for the words “when not on active duty all”. The words “examined as to his physical fitness” are substituted for the words “given physical examinations”. The words “be required to” are omitted as surplusage. The words “execute and” are inserted for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “under his jurisdiction” are inserted for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaba6c467-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaba6c468-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1662/h/2"},"text":"Pub. L. 103–337, § 1662(h)(2)","children":[],"tail":", (4)(B), renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1004"},"text":"section 1004 of this title","children":[],"tail":" as this section and substituted “Members physically not qualified for active duty: discharge or transfer to retired status” for “Physical examination” as section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1661/a/4"},"text":"Pub. L. 103–337, § 1661(a)(4)","children":[],"tail":", struck out “(c)” before “Except as otherwise provided” and struck out subsecs. (a) and (b) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) Each member of the Ready Reserve who is not on active duty shall—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) be examined as to his physical fitness every five years, or more often as the Secretary concerned considers necessary; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) execute and submit annually a certificate of physical condition.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Each Reserve in an active status, or on an inactive status list, who is not on active duty shall execute and submit annually a certificate of physical condition.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) The kind of duty to which a Reserve ordered to active duty may be assigned shall be considered in determining physical qualifications for active duty.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":" substituted “five years” for “four years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/603"},"text":"Pub. L. 86–603","children":[],"tail":" limited the requirement for a physical examination every four years, and for the annual execution of a certificate of physical condition, to the Ready Reserve, and also required each Reserve in an active status, or on an inactive status list, who is not on active duty to execute and submit annually a certificate of physical condition."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaba6c469-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaba6c46a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691"},"text":"section 1691 of Pub. L. 103–337","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
