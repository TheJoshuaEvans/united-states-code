{"tag":"section","attrib":{"id":"idaa0a2c28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104"},"text":null,"children":[{"tag":"num","attrib":{"value":"3104"},"text":"§ 3104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition-related functions of service chiefs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa0a2c29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance of Certain Acquisition-related Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall ensure that the service chiefs assist the Secretary of the military department concerned, in accordance with the objectives established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3102"},"text":"section 3102 of this title","children":[],"tail":", in the performance of the following acquisition-related functions of such department:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa0a2c2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The development of capability requirement statements for equipping the armed force concerned that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa0a2c2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the operational problem to provide necessary context for the capability requirement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa0a2c2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposes nonprescriptive solutions to operational problems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa0a2c2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures system interoperability, where appropriate, between and among joint military capabilities (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s181"},"text":"section 181 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa0a2c2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Implement strategies to support timely adjustments to capability requirement statements developed in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa0a2c2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advise on trade-offs among life-cycle costs, delivery schedules, performance objectives, technical feasibility, and procurement quantity objectives to maximize best value for the end user.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa0a2c30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In consultation with the Joint Requirements Oversight Council, prioritize—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa0a2c31-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capability needs for investment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa0a2c32-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resource allocation to meet operational readiness requirements (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4324"},"text":"section 4324 of this title","children":[],"tail":") and the materiel readiness objectives established under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s118/c"},"text":"section 118(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa0a2c33-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Make available appropriate personnel to provide end-user feedback for the development of new capabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa0a2c34-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Recommend modification, discontinuation, or termination of the development of capabilities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa0a2c35-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that no longer align with a capability requirement established by the Secretary of Defense; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa0a2c36-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are experiencing significant cost growth, technical or performance deficiencies, or delays in schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa0a2c37-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Build acquisition career paths for officers and personnel (as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1722a"},"text":"section 1722a of this title","children":[],"tail":") to ensure such officers and personnel have the necessary skills and opportunities for career progression to fulfill the objectives established pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3102"},"text":"section 3102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa0a2c38-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adherence to Requirements in Major Defense Acquisition Programs","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa0a2c39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the military department concerned shall ensure that any requirements document for a major defense acquisition program may not be approved until the service chief concerned determines in writing that the requirements in the document are necessary and realistic in relation to the program cost and fielding targets established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4271/a"},"text":"section 4271(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa0a2c3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Consistent with the performance of duties under subsection (a), the service chief concerned, or in the case of a joint program the service chiefs concerned, with respect to major defense acquisition programs, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa0a2c3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concur with the need for a materiel solution as identified in the Materiel Development Decision Review;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa0a2c3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concur with the life-cycle cost, delivery schedule, performance objective, technical feasibility, and procurement quantity trade-offs that have been made with regard to the program before Milestone A approval is granted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4251"},"text":"section 4251 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa0a2c3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concur that appropriate trade-offs among cost, schedule, technical feasibility, and performance objectives have been made to ensure that the program is affordable when considering the per unit cost and the total life-cycle cost before Milestone B approval is granted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4252"},"text":"section 4252 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa0a2c3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concur that the requirements in the program capability document are necessary and realistic in relation to program cost and fielding targets as required by paragraph (1) before Milestone C approval is granted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa0a2c3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to affect the assignment of functions under section 7014(c)(1)(A), section 8014(c)(1)(A), or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9014/c/1/A"},"text":"section 9014(c)(1)(A) of this title","children":[],"tail":", except as explicitly provided in this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa0a2c40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements Document Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “requirements document” means a document that establishes the need for a materiel approach to address an operational problem.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa0a2c41-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVIII/s861/a"},"text":"Pub. L. 111–383, div. A, title VIII, § 861(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4289"},"text":"124 Stat. 4289","children":[],"tail":", § 2547; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tIX/s951/c"},"text":"Pub. L. 112–239, div. A, title IX, § 951(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1891"},"text":"126 Stat. 1891","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVIII/s802/b"},"text":"Pub. L. 114–92, div. A, title VIII, § 802(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/879"},"text":"129 Stat. 879","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s807/c"},"text":"Pub. L. 114–328, div. A, title VIII, § 807(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2261"},"text":"130 Stat. 2261","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVIII/s833"},"text":"Pub. L. 115–91, div. A, title VIII, § 833","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1468"},"text":"131 Stat. 1468","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s809/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 809(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1840"},"text":"132 Stat. 1840","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXVII/s1731/a/52"},"text":"Pub. L. 116–92, div. A, title XVII, § 1731(a)(52)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1815"},"text":"133 Stat. 1815","children":[],"tail":"; renumbered § 3104 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/32"},"text":"Pub. L. 116–283, div. A, title IX, § 924(b)(32)","children":[],"tail":", title XVIII, § 1808(a)(2), (b)(2), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3825"},"text":"134 Stat. 3825","children":[],"tail":", 4159, 4160; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVIII/s1801/c"},"text":"Pub. L. 119–60, div. A, title XVIII, § 1801(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1223"},"text":"139 Stat. 1223","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa0a2c42-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa0a2c43-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa0a2c44-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In addition to being transferred to this section as part of the renumbering of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2547"},"text":"section 2547 of this title","children":[],"tail":", subsec. (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2547"},"text":"section 2547 of this title","children":[],"tail":" had also been directed to be transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4274"},"text":"section 4274 of this title","children":[],"tail":" and redesignated as subsec. (a) of that section by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1847/e/4/B"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1847(e)(4)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4257"},"text":"134 Stat. 4257","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1847/e/4/B"},"text":"Section 1847(e)(4)(B) of Pub. L. 116–283","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/r/1/B"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(r)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2149"},"text":"135 Stat. 2149","children":[],"tail":", effective as if included in title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa0a2c45-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1801/c/1/A"},"text":"Pub. L. 119–60, § 1801(c)(1)(A)","children":[],"tail":", substituted “Acquisition-related functions of service chiefs” for “Acquisition-related functions of chiefs of the armed forces” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1801/c/1/B/i"},"text":"Pub. L. 119–60, § 1801(c)(1)(B)(i)","children":[],"tail":", (ii), in introductory provisions, substituted “service chiefs assist” for “Chief of Staff of the Army, the Chief of Naval Operations, the Chief of Staff of the Air Force, the Commandant of the Marine Corps, and the Chief of Space Operations assist” and inserted “, in accordance with the objectives established pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3102"},"text":"section 3102 of this title","children":[],"tail":",” after “Secretary of the military department concerned”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1801/c/1/B/iii"},"text":"Pub. L. 119–60, § 1801(c)(1)(B)(iii)","children":[],"tail":", amended pars. (1) to (7) generally. Prior to amendment, pars. (1) to (7) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The development of requirements for equipping the armed force concerned (subject, where appropriate, to validation by the Joint Requirements Oversight Council pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s181"},"text":"section 181 of this title","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Decisions regarding the balancing of resources and priorities, and associated trade-offs among cost, schedule, technical feasibility, and performance on major defense acquisition programs.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) The coordination of measures to control requirements creep in the defense acquisition system.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) The recommendation of trade-offs among life-cycle cost, schedule, and performance objectives, and procurement quantity objectives, to ensure acquisition programs deliver best value in meeting the approved military requirements.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) Termination of development or procurement programs for which life-cycle cost, schedule, and performance expectations are no longer consistent with approved military requirements and levels of priority, or which no longer have approved military requirements.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) The development and management of career paths in acquisition for military personnel (as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1722a"},"text":"section 1722a of this title","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(7) The assignment and training of contracting officer representatives when such representatives are required to be members of the armed forces because of the nature of the contract concerned.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1801/c/2/A"},"text":"Pub. L. 119–60, § 1801(c)(2)(A)","children":[],"tail":", substituted “any requirements document” for “the program capability document supporting a Milestone B or subsequent decision” and “service chief concerned” for “chief of the armed force concerned”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1801/c/2/B/i"},"text":"Pub. L. 119–60, § 1801(c)(2)(B)(i)","children":[],"tail":", in introductory provisions, substituted “service chief concerned” for “Chief of the armed force concerned” and “service chiefs concerned” for “chiefs of the armed forces concerned”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1801/c/2/B/ii"},"text":"Pub. L. 119–60, § 1801(c)(2)(B)(ii)","children":[],"tail":", struck out “prior to entry into the Materiel Solution Analysis Phase under Department of Defense Instruction 5000.02” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1801/c/2/B/iii"},"text":"Pub. L. 119–60, § 1801(c)(2)(B)(iii)","children":[],"tail":", substituted “life-cycle cost, delivery schedule, performance objective, technical feasibility, and procurement quantity trade-offs” for “cost, schedule, technical feasibility, and performance trade-offs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1801/c/3"},"text":"Pub. L. 119–60, § 1801(c)(3)","children":[],"tail":", amended subsec. (d) generally. Prior to amendment, subsec. (d) defined the terms “requirements creep”, ‘requirements document”, and “program capability document”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1808/a/2"},"text":"Pub. L. 116–283, § 1808(a)(2)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2547"},"text":"section 2547 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s924/b/32"},"text":"Pub. L. 116–283, § 924(b)(32)","children":[],"tail":", substituted “the Commandant of the Marine Corps, and the Chief of Space Operations” for “and the Commandant of the Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1808/b/2/A"},"text":"Pub. L. 116–283, § 1808(b)(2)(A)","children":[],"tail":", substituted “section 4271(a)” for “section 2448a(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1808/b/2/B"},"text":"Pub. L. 116–283, § 1808(b)(2)(B)","children":[],"tail":", substituted “section 4251” for “section 2366a”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1808/b/2/C"},"text":"Pub. L. 116–283, § 1808(b)(2)(C)","children":[],"tail":", substituted “section 4252” for “section 2366b”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1808/b/2/D"},"text":"Pub. L. 116–283, § 1808(b)(2)(D)","children":[],"tail":", substituted “section 4401(b)(5)” for “section 2446a(b)(5)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “materiel” for “material” and “Materiel” for “Material” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “section 7014(c)(1)(A), section 8014(c)(1)(A), or section 9014(c)(1)(A)” for “section 3014(c)(1)(A), section 5014(c)(1)(A), or section 8014(c)(1)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s807/c/1"},"text":"Pub. L. 114–328, § 807(c)(1)","children":[],"tail":", (2), added subsec. (b) and redesignated former subsec. (b) as (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s807/c/1"},"text":"Pub. L. 114–328, § 807(c)(1)","children":[],"tail":", redesignated subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s807/c/3"},"text":"Pub. L. 114–328, § 807(c)(3)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(2) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s802/b/1"},"text":"Pub. L. 114–92, § 802(b)(1)","children":[],"tail":", (2), added par. (2) and redesignated former pars. (2) to (4) as (3) to (5), respectively. Former par. (5) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s802/b/1"},"text":"Pub. L. 114–92, § 802(b)(1)","children":[],"tail":", (3), redesignated par. (5) as (6) and substituted “The development and management” for “The development”. Former par. (6) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s802/b/1"},"text":"Pub. L. 114–92, § 802(b)(1)","children":[],"tail":", redesignated par. (6) as (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s951/c/1"},"text":"Pub. L. 112–239, § 951(c)(1)","children":[],"tail":", substituted “of requirements for equipping the armed force concerned” for “of requirements relating to the defense acquisition system”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s951/c/2"},"text":"Pub. L. 112–239, § 951(c)(2)","children":[],"tail":", (3), added pars. (3) and (4) and redesignated former pars. (3) and (4) as (5) and (6), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa0a2c46-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa0a2c47-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by section 1808(a)(2), (b)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa0a2c48-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa0a2c49-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVIII/s1801/d"},"text":"Pub. L. 119–60, div. A, title XVIII, § 1801(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1224"},"text":"139 Stat. 1224","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tXVIII/s1801/d"},"text":"“Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"], the Secretary of Defense shall revise Department of Defense Directive 5000.01 and any other relevant instructions, policies, or guidance to carry out the requirements of this section and the amendments made by this section [amending this section and sections 133b, 139, 139a, 3102, and 3103 of this title].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
