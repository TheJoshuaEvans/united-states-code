{"tag":"section","attrib":{"id":"ida82ae4ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s903b"},"text":null,"children":[{"tag":"num","attrib":{"value":"903b"},"text":"§ 903b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 103b. Aiding the enemy","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82ae4f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s903b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aids, or attempts to aid, the enemy with arms, ammunition, supplies, money, or other things; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82ae4f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s903b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without proper authority, knowingly harbors or protects or gives intelligence to, provides military education, military training, or tactical advice to, or communicates or corresponds with or holds any intercourse with the enemy, either directly or indirectly;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall suffer death or such other punishment as a court-martial or military commission may direct. This section does not apply to a military commission established under chapter 47A of this title.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida82ae4f2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/70"},"text":"70A Stat. 70","children":[],"tail":", § 904; "},{"tag":"ref","attrib":{"href":"/us/pl/109/366/s4/a/2"},"text":"Pub. L. 109–366