enerally. Text read as follows: “The Secretary of Defense shall provide for tuition reimbursement and training (including a full-time course of study leading to a degree) under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s4107/b"},"text":"section 4107(b) of title 5","children":[],"tail":" for acquisition personnel in the Department of Defense for the purposes described in that section. For purposes of such section 4107(b), there is deemed to be, until "},{"tag":"date","attrib":{"date":"2001-09-30"},"text":"September 30, 2001","children":[],"tail":", a shortage of qualified personnel to serve in acquisition positions in the Department of Defense.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" substituted “section 4107(b)” for “section 4107(d)” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida90b0b51-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida90b0b52-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tIX/s925/b"},"text":"Pub. L. 106–65, div. A, title IX, § 925(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/726"},"text":"113 Stat. 726","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/65/dA/tIX/s925/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply with respect to charges for tuition or expenses incurred after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
