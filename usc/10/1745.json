{"tag":"section","attrib":{"id":"ida90b0b47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1745"},"text":null,"children":[{"tag":"num","attrib":{"value":"1745"},"text":"§ 1745.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional education and training programs available to acquisition personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida90b0b48-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1745/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tuition Reimbursement and Training","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90b0b49-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1745/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall provide for tuition reimbursement and training (including a full-time course of study leading to a degree) for acquisition personnel in the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90b0b4a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1745/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For civilian personnel, the reimbursement and training shall be provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4107/b"},"text":"section 4107(b) of title 5","children":[],"tail":" for the purposes described in that section. For purposes of such section 4107(b), there is deemed to be, until "},{"tag":"date","attrib":{"date":"2010-09-30"},"text":"September 30, 2010","children":[],"tail":", a shortage of qualified personnel to serve in acquisition positions in the Department of Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90b0b4b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1745/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of members of the armed forces, the limitation in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2007/a"},"text":"section 2007(a) of this title","children":[],"tail":" shall not apply to tuition reimbursement and training provided for under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90b0b4c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1745/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment of Student Loans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may repay all or part of a student loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5379"},"text":"section 5379 of title 5","children":[],"tail":" for an employee of the Department of Defense appointed to an acquisition position."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida90b0b4d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXII/s1202/a"},"text":"Pub. L. 101–510, div. A, title XII, § 1202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1653"},"text":"104 Stat. 1653","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1503/a/15"},"text":"Pub. L. 104–106, div. A, title XV, § 1503(a)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":