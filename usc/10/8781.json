{"tag":"section","attrib":{"id":"idab4c224f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8781"},"text":null,"children":[{"tag":"num","attrib":{"value":"8781"},"text":"§ 8781.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marine Corps post laundries: disposition of receipts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab4c2250-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8781/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Money received for laundry work performed by Marine Corps post laundries shall be used to pay the cost of maintenance and operation of those laundries. Any amount remaining at the end of the fiscal year after the cost has been so paid shall be deposited in the Treasury to the credit of the appropriation from which the cost of operating the laundries is paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab4c2251-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8781/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The receipts and expenditures of Marine Corps post laundries shall be accounted for as public funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab4c2252-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/470"},"text":"70A Stat. 470","children":[],"tail":", § 7581; renumbered § 8781, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/9"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"hre