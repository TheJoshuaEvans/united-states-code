{"tag":"section","attrib":{"id":"idab2f98f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8545"},"text":null,"children":[{"tag":"num","attrib":{"value":"8545"},"text":"§ 8545.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers of the other armed forces; enlisted members: admission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab2f98f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8545/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab2f98f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8545/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy may permit officers of the Army, Air Force, Space Force, and Coast Guard to receive instruction at the Naval Postgraduate School. The numbers and grades of such officers shall be as agreed upon by the Secretary of the Navy with the Secretary of the Army, the Secretary of the Air Force, and the Secretary of Homeland Security, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2f98f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8545/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab2f98f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8545/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may permit an enlisted member of the armed forces to receive instruction at the Naval Postgraduate School through attendance at an executive level seminar.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab2f98f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8545/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may permit an eligible enlisted member of the armed forces to receive instruction at the Postgraduate School in connection with pursuit of a program of education in a cyber discipline as a participant in the Cyber Scholarship program under chapter 112 of this title. To be eligible for instruction under this subparagraph, the enlisted member must have been awarded a baccalaureate degree by an institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab2f98f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8545/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may permit an eligible enlisted member of the armed forces to receive instruction from the Postgraduate School in certificate programs and courses required for the performance of the member’s duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab2f98f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8545/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idab2f98fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8545/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may permit an eligible enlisted member of the armed forces to receive graduate-level instruction at the Naval Postgraduate School in a program leading to a master’s degree in a technical, analytical, or engineering curriculum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab2f98fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8545/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be eligible to be provided instruction under this subparagraph, the enlisted member must have been awarded a baccalaureate degree by an institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab2f98fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8545/a/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Instruction under this subparagraph may be provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab2f98fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8545/a/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An enlisted member who successfully completes a course of instruction under this subparagraph may be awarded a master’s degree under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8548"},"text":"section 8548 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab2f98fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8545/a/2/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Instruction under this subparagraph shall be provided pursuant to regulations prescribed by the Secretary. Such regulations may include criteria for eligibility of enlisted members for instruction under this subparagraph and specification of obligations for further service in the armed forces relating to receipt of such instruction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab2f98ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8545/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to instruction authorized under subparagraphs (A), (B), (C), and (D), the Secretary may, on a space-available basis, permit an enlisted member of the armed forces who is assigned permanently to the staff of the Postgraduate School or to a nearby command to receive instruction at the Postgraduate School.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2f9900-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8545/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab2f9901-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8545/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided under paragraph (3), the Department of the Army, the Department of the Air Force, and the Department of Homeland Security shall bear the cost of the instruction received by members detailed for that instruction by the Secretary of the Army, the Secretary of the Air Force, and the Secretary of Homeland Security, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2f9902-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8545/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an enlisted member permitted under subsection (a)(2)(E) to receive instruction at the Postgraduate School on a space-available basis, the Secretary of the Navy shall charge that member only for such costs and fees as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2f9903-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8545/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The requirements for payment of costs and fees under paragraph (1) shall be subject to such exceptions as the Secretary of Defense may prescribe for members of the armed forces who receive instruction at the Postgraduate School in connection with pursuit of a degree or certification as participants in the Cyber Scholarship program under chapter 112 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2f9904-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8545/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" While receiving instruction at the Postgraduate School, members of the Army, Air Force, Space Force, and Coast Guard are subject to such regulations, as determined appropriate by the Secretary of the Navy, as apply to students who are members of the naval service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2f9905-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8545/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not award a baccalaureate, masters, or doctorate degree to an enlisted member based upon instruction received at the Postgraduate School under subsection (a)(2)(C).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab2f9906-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/437"},"text":"70A Stat. 437","children":[],"tail":", § 7045; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s513/23"},"text":"Pub. L. 96–513, title V, § 513(23)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2932"},"text":"94 Stat. 2932","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tV/s551/a"},"text":"Pub. L. 105–85, div. A, title V, § 551(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1747"},"text":"111 Stat. 1747","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tX/s1069/a/6"},"text":"Pub. L. 105–261, div. A, title X, § 1069(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2136"},"text":"112 Stat. 2136","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/b/5"},"text":"Pub. L. 107–296, title XVII, § 1704(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tV/s532"},"text":"Pub. L. 108–136, div. A, title V, § 532","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1472"},"text":"117 Stat. 1472","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s526/a"},"text":"Pub. L. 109–163, div. A, title V, § 526(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3245"},"text":"119 Stat. 3245","children":[],"tail":", 3246; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s543/a"},"text":"Pub. L. 109–364, div. A, title V, § 543(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2213"},"text":"120 Stat. 2213","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tXVI/s1649/d/3"},"text":"Pub. L. 115–91, div. A, title XVI, § 1649(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1753"},"text":"131 Stat. 1753","children":[],"tail":"; renumbered § 8545 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 807(c)(1), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":", 1840; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tV/s555/a"},"text":"Pub. L. 117–263, div. A, title V, § 555(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2595"},"text":"136 Stat. 2595","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tIX/s915"},"text":"Pub. L. 118–31, div. A, title IX, § 915","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/368"},"text":"137 Stat. 368","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab2f9907-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab2f9908-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab2f9909-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7045","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s1076e"},"text":"34 U.S.C. 1076e","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1947-07-31/ch420/s6"},"text":"July 31, 1947, ch. 420, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/61/706"},"text":"61 Stat. 706","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The section is enlarged to cover officers of the Air Force under authority of § 305(a) of the National Security Act of 1947, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s171e"},"text":"5 U.S.C. 171e","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words “at the request of the Secretary of the Army and the Secretary of the Treasury” are omitted as surplusage. The words “to receive instruction” are inserted after the listing of the services and the words “attendance and” are omitted. The word “grades” is substituted for the word “ranks”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c) the words “rules and” are omitted. The words “who are officers of the naval service” are substituted for the words “of the United States Navy”, since officers of the Marine Corps are occasionally ordered to attend the Postgraduate School on the same basis as officers of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab2f990a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab2f990b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8545, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/528"},"text":"70A Stat. 528","children":[],"tail":", provided that cooking for enlisted members of Air Force should be superintended by officers of organizations to which members belonged, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/90/235/s4/b/1"},"text":"Pub. L. 90–235, § 4(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/760"},"text":"81 Stat. 760","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab2f990c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s915/1"},"text":"Pub. L. 118–31, § 915(1)","children":[],"tail":", substituted “Space Force, and Coast Guard” for “and Coast Guard”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s915/2"},"text":"Pub. L. 118–31, § 915(2)","children":[],"tail":", substituted “Space Force, and Coast Guard” for “and Coast Guard”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(2)(D)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" struck out “only on a space-available basis” after “provided”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s807/c/1"},"text":"Pub. L. 115–232, § 807(c)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7045"},"text":"section 7045 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(D)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 8548” for “section 7048”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" substituted “a cyber discipline” for “information assurance” and “Cyber Scholarship program” for “Information Security Scholarship program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1649/d/3/A"},"text":"Pub. L. 115–91, § 1649(d)(3)(A)","children":[],"tail":", substituted “Cyber Scholarship program” for “Information Security Scholarship program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s543/a"},"text":"Pub. L. 109–364, § 543(a)","children":[],"tail":", substituted “armed forces” for “Navy or Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s526/a/1/B"},"text":"Pub. L. 109–163, § 526(a)(1)(B)","children":[],"tail":", added subpar. (C). Former subpar.(C) redesignated (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s543/b/2"},"text":"Pub. L. 109–364, § 543(b)(2)","children":[],"tail":", added subpar. (D). Former subpar. (D) redesignated (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s526/a/1/A"},"text":"Pub. L. 109–163, § 526(a)(1)(A)","children":[],"tail":", (C), redesignated subpar. (C) as (D) and substituted “subparagraphs (A), (B), and (C)” for “subparagraphs (A) and (B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s543/b/1"},"text":"Pub. L. 109–364, § 543(b)(1)","children":[],"tail":", (c)(1), redesignated subpar. (D) as (E) and substituted “(C), and (D)” for “and (C)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s543/c/2"},"text":"Pub. L. 109–364, § 543(c)(2)","children":[],"tail":", substituted “(a)(2)(E)” for “(a)(2)(D)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s526/a/2"},"text":"Pub. L. 109–163, § 526(a)(2)","children":[],"tail":", substituted “subsection (a)(2)(D)” for “subsection (a)(2)(C)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s526/b"},"text":"Pub. L. 109–163, § 526(b)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s532/a"},"text":"Pub. L. 108–136, § 532(a)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “The Secretary may permit an enlisted member of the armed forces who is assigned to the Naval Postgraduate School or to a nearby command to receive instruction at the Naval Postgraduate School. Admission of enlisted members for instruction under this paragraph shall be on a space-available basis.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s532/b"},"text":"Pub. L. 108–136, § 532(b)","children":[],"tail":", designated first sentence as par. (1) and substituted “Except as provided under paragraph (3), the Department” for “The Department” and “members” for “officers”, designated second sentence as par. (2) and inserted “under subsection (a)(2)(C)” after “permitted” and “on a space-available basis” after “instruction at the Postgraduate School” and struck out “(taking into consideration the admission of enlisted members on a space-available basis)” before period at end, and added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/b/5/A"},"text":"Pub. L. 107–296, § 1704(b)(5)(A)","children":[],"tail":", substituted “Secretary of the Army, the Secretary of the Air Force, and the Secretary of Homeland Security” for “Secretaries of the Army, Air Force, and Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/b/5"},"text":"Pub. L. 107–296, § 1704(b)(5)","children":[],"tail":", substituted “Department of Homeland Security” for “Department of Transportation” and “Secretary of the Army, the Secretary of the Air Force, and the Secretary of Homeland Security” for “Secretaries of the Army, Air Force, and Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":"Pub. L. 105–261","children":[],"tail":" struck out “the” after “are subject to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s551/b/1"},"text":"Pub. L. 105–85, § 551(b)(1)","children":[],"tail":", substituted “Officers of the other armed forces; enlisted members:” for “Officers of Army, Air Force, and Coast Guard:” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s551/a/1"},"text":"Pub. L. 105–85, § 551(a)(1)","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s551/a/2"},"text":"Pub. L. 105–85, § 551(a)(2)","children":[],"tail":", substituted “officers detailed” for “the students detailed” and inserted at end “In the case of an enlisted member permitted to receive instruction at the Postgraduate School, the Secretary of the Navy shall charge that member only for such costs and fees as the Secretary considers appropriate (taking into consideration the admission of enlisted members on a space-available basis).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s551/a/3"},"text":"Pub. L. 105–85, § 551(a)(3)","children":[],"tail":", substituted “members” for “officers” in two places and “such regulations, as determined appropriate by the Secretary of the Navy,” for “same regulations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s513/23"},"text":"Pub. L. 96–513, § 513(23)","children":[],"tail":", substituted references to Transportation Department and Secretary for references to Treasury Department and Secretary, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s513/23/A"},"text":"Pub. L. 96–513, § 513(23)(A)","children":[],"tail":", substituted reference to Transportation Secretary for reference to Treasury Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab2f990d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab2f990e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab2f990f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab2f9910-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/b/3"},"text":"section 701(b)(3) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab2f9911-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pilot Program To Provide Graduate Education Opportunities for Enlisted Members of the Army and Navy","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s559D"},"text":"Pub. L. 118–159, div. A, title V, § 559D","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1900"},"text":"138 Stat. 1900","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tV/s559D"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy and the Secretary of the Army may jointly conduct a pilot program (referred to in this section as the ‘Program’) under which certain enlisted personnel of the covered Armed Forces may enroll in a master’s degree program at the Naval Postgraduate School.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretaries concerned may carry out the Program—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with such regulations as may be prescribed by the Secretary of Defense for purposes of the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner consistent with the Graduate Education Program–Enlisted pilot program of the Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility of Participants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretaries concerned shall establish criteria for determining the eligibility of enlisted members of the covered Armed Forces for participation in the Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection of Participants","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Selection of a member for the Program shall be based on consideration of—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligibility criteria established under subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professional performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotion potential;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retention potential;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic background, capabilities, and accomplishments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the needs of the Navy and Army; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" input from the component within each covered Armed Force with primary responsibility for determining the duty assignments of enlisted members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Post-participation Service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to such terms, conditions, and exceptions as the Secretaries concerned may establish, an enlisted member who receives a master’s degree under the Program shall serve for a period of not less than two years in a duty assignment that is relevant to the degree obtained by the member under the Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Framework for Filling Billets","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conjunction with selecting enlisted members for participation in the Program as described in subsection (d), the Secretaries concerned shall establish a framework for assigning enlisted personnel who are not participating in the Program—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fill the billets of the members participating in the Program while such members are completing a course of study at the Naval Postgraduate School; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fill the billets of members who received a master’s degree under the Program while such members are engaged in post-participation service as described in subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Identification of Degree Programs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretaries concerned shall coordinate with the President of the Naval Postgraduate School to identify specific master’s degree programs offered by the School in which Program participants may enroll. In identifying such programs, the Secretaries shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the needs of the Navy and Army;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capacity of the Naval Postgraduate School; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which enrollment in a specific program is expected to have a positive effect on the career trajectories of participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"“(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information Dissemination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretaries concerned shall take such actions as are necessary to notify and inform enlisted members about the Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before the expiration of the six-year period described in subsection (j), the Secretaries concerned, in coordination with the Secretary of Defense, shall submit to the Committees on Armed Services of the Senate and the House of Representatives a report that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assessment of whether and to what extent the Program has met the needs of the covered Armed Forces and had positive effects on participating enlisted members, including with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" career trajectory, including potential pay increases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruitment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" job performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" merit-based promotions and merit-based promotion reorder; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compatibility with the objectives outlined in the 2022 National Defense Strategy to modernize the Armed Services, spur innovation, and outpace and outthink adversaries of the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recommendations of the Secretaries regarding whether the Program should be extended or made permanent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the funding and capabilities that may be needed to make the Program permanent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other matters the Secretaries determine to be relevant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"“(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Program shall terminate six years after the date on which the Program commences under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"“(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"te