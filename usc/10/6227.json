{"tag":"section","attrib":{"id":"idaac69e09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6227"},"text":null,"children":[{"tag":"num","attrib":{"value":"6227"},"text":"§ 6227.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of certain nuclear facilities and assets from unmanned aircraft","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaac69e0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6227/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any provision of title 18, the Secretary of Energy may take such actions described in subsection (b)(1) that are necessary to mitigate the threat (as defined by the Secretary of Energy, in consultation with the Secretary of Transportation) that an unmanned aircraft system or unmanned aircraft poses to the safety or security of a covered facility or asset.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac69e0b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6227/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions Described","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac69e0c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6227/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The actions described in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac69e0d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6227/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Detect, identify, monitor, and track the unmanned aircraft system or unmanned aircraft, without prior consent, including by means of intercept or other access of a wire, oral, or electronic communication used to control the unmanned aircraft system or unmanned aircraft.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69e0e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6227/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Warn the operator of the unmanned aircraft system or unmanned aircraft, including by passive or active, and direct or indirect physical, electronic, radio, and electromagnetic means.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69e0f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6227/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Disrupt control of the unmanned aircraft system or unmanned aircraft, without prior consent, including by disabling the unmanned aircraft system or unmanned aircraft by intercepting, interfering, or causing interference with wire, oral, electronic, or radio communications used to control the unmanned aircraft system or unmanned aircraft.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69e10-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6227/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Seize or exercise control of the unmanned aircraft system or unmanned aircraft.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69e11-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6227/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Seize or otherwise confiscate the unmanned aircraft system or unmanned aircraft.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69e12-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6227/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Use reasonable force to disable, damage, or destroy the unmanned aircraft system or unmanned aircraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac69e13-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6227/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy shall develop the actions described in paragraph (1) in coordination with the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac69e14-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6227/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Forfeiture","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any unmanned aircraft system or unmanned aircraft described in subsection (a) that is seized by the Secretary of Energy is subject to forfeiture to the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac69e15-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6227/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy and the Secretary of Transportation may prescribe regulations and shall issue guidance in the respective areas of each Secretary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac69e16-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6227/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac69e17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6227/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered facility or asset” means any facility or asset that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac69e18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6227/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identified by the Secretary of Energy for purposes of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69e19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6227/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located in the United States (including the territories and possessions of the United States); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69e1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6227/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaac69e1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6227/e/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned by or contracted to the National Nuclear Security Administration, including any facility that stores or uses special nuclear material; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaac69e1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6227/e/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national security laboratory or nuclear weapons production facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac69e1d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6227/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “unmanned aircraft” and “unmanned aircraft system” have the meanings given those terms in section 331 of the FAA Modernization and Reform Act of 2012 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95"},"text":"Public Law 112–95","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s40101"},"text":"49 U.S.C. 40101","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002143"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002143"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac69e1e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(1)(E), (2)(B), 3114, "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1406"},"text":"139 Stat. 1406","children":[],"tail":", 1462, 1464.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac69e1f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac69e20-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaac69e21-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 331 of the FAA Modernization and Reform Act of 2012, referred to in subsec. (e)(2), which was formerly set out in a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40101"},"text":"section 40101 of Title 49","children":[],"tail":", Transportation, was transferred and is now set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s44802"},"text":"section 44802 of Title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaac69e22-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3114"},"text":"section 3114 of Pub. L. 119–60","children":[],"tail":" directed to "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/s4510"},"text":"section 4510 of Pub. L. 107–314","children":[],"tail":" executed to this section pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/1/E"},"text":"section 3111(d)(1)(E) of Pub. L. 119–60","children":[],"tail":". See Further Technical Amendments note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6114"},"text":"section 6114 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac69e23-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2661"},"text":"section 2661 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaac69e24-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", §§ 3111(d)(1)(E), 3114, amended subpar. (C) generally. Prior to amendment, subpar. (C) read as follows: “owned by the United States or contracted to the United States, to store or use special nuclear material.” See Codification note above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
