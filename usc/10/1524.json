{"tag":"section","attrib":{"id":"ida8e02b8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1524"},"text":null,"children":[{"tag":"num","attrib":{"value":"1524"},"text":"§ 1524.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Posthumous commissions and warrants: determination of date of death","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purposes of sections 1521 and 1522 of this title, in any case where the date of death is established or determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s551–558"},"text":"section 551–558 of title 37","children":[],"tail":", the date of death is the date the Secretary concerned receives evidence that the person is dead, or the date the finding of death is made under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s555"},"text":"section 555 of title 37","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida8e02b8f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/718/s12/a/1"},"text":"Pub. L. 89–718, § 12(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1117"},"text":"80 Stat. 1117","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
