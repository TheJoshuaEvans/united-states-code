{"tag":"section","attrib":{"id":"ida836cc9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949m"},"text":null,"children":[{"tag":"num","attrib":{"value":"949m"},"text":"§ 949m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of votes required","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida836cc9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conviction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No person may be convicted by a military commission under this chapter of any offense, except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s949i/b"},"text":"section 949i(b) of this title","children":[],"tail":" or by concurrence of two-thirds of the primary members present at the time the vote is taken."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida836cc9e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sentences","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida836cc9f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949m/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraphs (2) and (3), sentences shall be determined by a military commission by the concurrence of two-thirds of the primary members present at the time the vote is taken.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida836cca0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949m/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No person may be sentenced to death by a military commission, except insofar as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida836cca1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949m/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the penalty of death has been expressly authorized under this chapter, chapter 47 of this title, or the law of war for an offense of which the accused has been found guilty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida836cca2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949m/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trial counsel expressly sought the penalty of death by filing an appropriate notice in advance of trial;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida836cca3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949m/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accused was convicted of the offense by the concurrence of all the primary members present at the time the vote is taken, or a guilty plea was accepted and not withdrawn prior to announcement of the sentence in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s949i/b"},"text":"section 949i(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida836cca4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949m/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all primary members present at the time the vote was taken on the sentence concurred in the sentence of death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida836cca5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949m/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No person may be sentenced to life imprisonment, or to confinement for more than 10 years, by a military commission under this chapter except by the concurrence of three-fourths of the primary members present at the time the vote is taken.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida836cca6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949m/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The primary members present for a vote on a sentence need not be the same primary members who voted on the conviction if the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s948m/d"},"text":"section 948m(d) of this title","children":[],"tail":" are met."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida836cca7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949m/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Number of Members Required for Penalty of Death","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida836cca8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949m/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), in a case in which the penalty of death is sought, the number of primary members of the military commission under this chapter shall be not less than 12 primary members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida836cca9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949m/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case described in paragraph (1) in which 12 primary members are not reasonably available for a military commission because of physical conditions or military exigencies, the convening authority shall specify a lesser number of primary members for the military commission (but not fewer than 9 primary members), and the military commission may be assembled, and the trial held, with not less than the number of primary members so specified. In any such case, the convening authority shall make a detailed written statement, to be appended to the record, stating why a greater number of primary members were not reasonably available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida836ccaa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tXVIII/s1802"},"text":"Pub. L. 111–84, div. A, title XVIII, § 1802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2589"},"text":"123 Stat. 2589","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tX/s1030/a"},"text":"Pub. L. 112–81, div. A, title X, § 1030(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1570"},"text":"125 Stat. 1570","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tX/s1031/c"},"text":"Pub. L. 113–66, div. A, title X, § 1031(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/850"},"text":"127 Stat. 850","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida836ccab-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida836ccac-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida836ccad-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 949m, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/366/s3/a/1"},"text":"Pub. L. 109–366, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2616"},"text":"120 Stat. 2616","children":[],"tail":", related to number of votes required for conviction and sentences and number of members required on military commission for penalty of death, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida836ccae-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1031/c/1"},"text":"Pub. L. 113–66, § 1031(c)(1)","children":[],"tail":", inserted “primary” before “members” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1031/c/2"},"text":"Pub. L. 113–66, § 1031(c)(2)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s1030/a/1"},"text":"Pub. L. 112–81, § 1030(a)(1)","children":[],"tail":", inserted before semicolon “, or a guilty plea was accepted and not withdrawn prior to announcement of the sentence in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s949i/b"},"text":"section 949i(b) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s1030/a/2"},"text":"Pub. L. 112–81, § 1030(a)(2)","children":[],"tail":", inserted “on the sentence” after “vote was taken”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
