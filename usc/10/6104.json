{"tag":"section","attrib":{"id":"idaabab772-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6104"},"text":null,"children":[{"tag":"num","attrib":{"value":"6104"},"text":"§ 6104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring of industrial base for nuclear weapons components, subsystems, and materials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaabab773-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Official","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2021-03-01"},"text":"March 1, 2021","children":[],"tail":", the Administrator shall designate a senior official within the Administration to be responsible for monitoring the industrial base that supports the nuclear weapons components, subsystems, and materials of the Administration, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabab774-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consistent monitoring of the current status of the industrial base;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab775-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tracking of industrial base issues over time; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab776-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6104/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proactively identifying gaps or risks in specific areas relating to the industrial base.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabab777-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of Resources","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall ensure that the official designated under subsection (a) is provided with resources sufficient to conduct the monitoring required by that subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabab778-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator, acting through the official designated under subsection (a), shall, to the extent practicable and beneficial, in conducting the monitoring required by that subsection, consult with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabab779-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" officials of the Department of Defense who are members of the Nuclear Weapons Council established under section 179;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab77a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" officials of the Department of Defense responsible for the defense industrial base; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab77b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6104/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other components of the Department of Energy that rely on similar components, subsystems, or materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabab77c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefings","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabab77d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6104/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"2021-04-01"},"text":"April 1, 2021","children":[],"tail":", the Administrator shall provide to the Committees on Armed Services of the Senate and the House of Representatives a briefing on the designation of the official required by subsection (a), including on—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaabab77e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6104/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the responsibilities assigned to that official; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabab77f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6104/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan for providing that official with resources sufficient to conduct the monitoring required by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab780-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6104/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"2022-04-01"},"text":"April 1, 2022","children":[],"tail":", and annually thereafter through 2024, the Administrator shall provide to the Committees on Armed Services of the Senate and the House of Representatives a briefing on activities carried out under this section that includes an assessment of the progress made by the official designated under subsection (a) in conducting the monitoring required by that subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabab781-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6104/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator, acting through the official designated under subsection (a), shall submit to the Committees on Armed Services of the Senate and the House of Representatives, contemporaneously with each briefing required by subsection (d)(2), a report—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabab782-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6104/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying actual or potential risks to or specific gaps in any element of the industrial base that supports the nuclear weapons components, subsystems, or materials of the Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab783-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6104/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing the actions the Administration is taking to further assess, characterize, and prioritize such risks and gaps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab784-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6104/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing mitigating actions, if any, the Administration has underway or planned to mitigate any such risks or gaps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab785-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6104/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" setting forth the anticipated timelines and resources needed for such mitigating actions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab786-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6104/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing the nature of any coordination with or burden sharing by other departments or agencies of the Federal Government or the private sector to address such risks and gaps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaabab787-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1341"},"text":"139 Stat. 1341","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaabab788-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaabab789-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaabab78a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3113"},"text":"section 3113 of Pub. L. 116–283","children":[],"tail":", which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2512"},"text":"section 2512 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/8"},"text":"Pub. L. 119–60, § 3111(b)(8)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaabab78b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) and (2) headings which read as follows: “"},{"tag":"inline","attrib":{},"text":"Initial briefing","children":[],"tail":"” and “"},{"tag":"inline","attrib":{},"text":"Subsequent briefings","children":[],"tail":"”, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
