{"tag":"section","attrib":{"id":"ida92c755c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2114a"},"text":"§ 2114a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility of members of foreign militaries to enroll in the University","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida92c755d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida92c755e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense may permit an individual who is a member of the military of a foreign country—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida92c755f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to enroll (including as a full-time student) and receive instruction—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida92c7560-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a medical student of the University; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida92c7561-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a postdoctoral, postgraduate, or certificate program of the University; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92c7562-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to participate in training exercises of the University.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c7563-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Enrollment of an individual under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida92c7564-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be subject to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida92c7565-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the academic capacity of the University described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2112/b"},"text":"section 2112(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida92c7566-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an international agreement or qualifying non-binding instrument (as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t1/s112b"},"text":"section 112b of title 1","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92c7567-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not decrease the number of members of the uniformed services enrolled in the University; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92c7568-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be given priority over the enrollment of a member of the uniformed services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c7569-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The number of individuals simultaneously enrolled under this section may not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida92c756a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10, in the case of medical students of the University; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92c756b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 40, with regards to all postdoctoral, postgraduate, and certificate programs of the University.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92c756c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifications; Selection","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Secretary may select an individual to enroll under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida92c756d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who was nominated for such enrollment by the medical command of the military of a foreign country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c756e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" pursuant to regulations prescribed by the Secretary regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida92c756f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualifications for such enrollment that are comparable to the qualifications required of a United States citizen; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92c7570-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for such selection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92c7571-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida92c7572-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall require the foreign country of an individual enrolled under this section to reimburse the United States for the cost of providing instruction to such individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c7573-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe rates for such reimbursement that equal or exceed the cost to the United States of providing such instruction to a member of the uniformed services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c7574-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may waive, in whole or in part, reimbursement with regards to an individual enrolled under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c7575-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Amounts received by the Secretary under this subsection shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida92c7576-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be used to defray the costs of providing instruction to an individual enrolled under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92c7577-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be credited to appropriations available for the maintenance and operation of the University; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92c7578-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain available for until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c7579-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The source and the disposition of such amounts shall be specifically identified in records of the University.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92c757a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Regulations and Policies","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida92c757b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraphs (2) through (4), and to the determination of the Secretary, an individual enrolled under this section shall be subject to the same regulations and policies that apply to a member of the uniformed services enrolled in the University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c757c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may prescribe regulations regarding access to classified information by an individual enrolled under this section that differ from the regulations that apply to a member of the uniformed services enrolled in the University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c757d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual enrolled under this section shall not be entitled to an appointment in a uniformed service by reason of completing of a program of the University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c757e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2114a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2114"},"text":"Section 2114 of this title","children":[],"tail":" shall not apply to an individual enrolled under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida92c757f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s553"},"text":"Pub. L. 118–159, div. A, title V, § 553","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1894"},"text":"138 Stat. 1894","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
