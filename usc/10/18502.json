{"tag":"section","attrib":{"id":"idabc5beee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18502"},"text":null,"children":[{"tag":"num","attrib":{"value":"18502"},"text":"§ 18502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve components: supplies, services, and facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabc5beef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned shall make available to the reserve components under his jurisdiction the supplies, services, and facilities of the armed forces under his jurisdiction that he considers necessary to support and develop those components.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc5bef0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever he finds it to be in the best interest of the United States, the Secretary concerned may issue supplies of the armed forces under his jurisdiction to the reserve components under his jurisdiction, without charge to the appropriations for those components for the cost or value of the supplies or for any related expense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc5bef1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever he finds it to be in the best interest of the United States, the Secretary of the Army or the Secretary of the Air Force may issue to the Army National Guard or the Air National Guard, as the case may be, supplies of the armed forces under his jurisdiction that are in addition to supplies issued to that National Guard under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s702"},"text":"section 702 of title 32","children":[],"tail":" or charged against its appropriations under section 106 or 107 of title 32, without charge to the appropriations for those components for the cost or value of the supplies or for any related expense."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc5bef2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supplies issued under subsection (b) or (c) may be repossessed or redistributed as prescribed by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc5bef3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1664/c/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1664(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3012"},"text":"108 Stat. 3012","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabc5bef4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabc5bef5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idabc5bef6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2540"},"text":"section 2540 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1664/c/2"},"text":"Pub. L. 103–337, § 1664(c)(2)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabc5bef7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabc5bef8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691"},"text":"section 1691 of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
