{"tag":"section","attrib":{"id":"ida78b2233-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s227"},"text":null,"children":[{"tag":"num","attrib":{"value":"227"},"text":"§ 227.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget justification for covered military unaccompanied housing Facilities Sustainment, Restoration, and Modernization projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida78b2234-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s227/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Along with the budget for each fiscal year submitted by the President pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", United States Code, each Secretary of a military department shall include a consolidated budget justification display for the congressional defense committees that individually identifies—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida78b2235-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s227/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the fiscal year covered by the budget, the total requested expenditure for Facilities Sustainment, Restoration, and Modernization projects for covered military unaccompanied housing compared to the total expenditure required by such projects, disaggregated by military department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b2236-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s227/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the total expenditure for Facilities Sustainment, Restoration, and Modernization projects made during the fiscal year beginning two years before the fiscal year covered by the budget, disaggregated by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida78b2237-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s227/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" military installation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b2238-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s227/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of facility repaired or restored under such repair projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b2239-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s227/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such repair projects that were for sustainment or repair of a facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b223a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s227/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such repair projects that were for restoration or modernization of a facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida78b223b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s227/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida78b223c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s227/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered military unaccompanied housing” has the meaning given in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2856"},"text":"section 2856 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b223d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s227/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “facility” and “military installation” have the meanings given, respectively, in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2801"},"text":"section 2801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b223e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s227/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “repair project” has the meaning given in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2811"},"text":"section 2811 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida78b223f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dB/tXXVIII/s2821"},"text":"Pub. L. 118–159, div. B, title XXVIII, § 2821","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":