{"tag":"section","attrib":{"id":"idaad73f4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7034"},"text":null,"children":[{"tag":"num","attrib":{"value":"7034"},"text":"§ 7034.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vice Chief of Staff","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaad73f50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7034/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is a Vice Chief of Staff of the Army, appointed by the President, by and with the advice and consent of the Senate, from the general officers of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad73f51-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7034/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Vice Chief of Staff of the Army, while so serving, has the grade of general without vacating his permanent grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad73f52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7034/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Vice Chief of Staff has such authority and duties with respect to the Department of the Army as the Chief of Staff, with the approval of the Secretary of the Army, may delegate to or prescribe for him. Orders issued by the Vice Chief of Staff in performing such duties have the same effect as those issued by the Chief of Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad73f53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7034/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When there is a vacancy in the office of Chief of Staff or during the absence or disability of the Chief of Staff—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad73f54-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7034/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Vice Chief of Staff shall perform the duties of the Chief of Staff until a successor is appointed or the absence or disability ceases; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad73f55-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7034/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if there is a vacancy in the office of the Vice Chief of Staff or the Vice Chief of Staff is absent or disabled, unless the President directs otherwise, the most senior officer of the Army in the Army Staff who is not absent or disabled and who is not restricted in performance of duty shall perform the duties of the Chief of Staff until a successor to the Chief of Staff or the Vice Chief of Staff is appointed or until the absence or disability of the Chief of Staff or Vice Chief of Staff ceases, whichever occurs first.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad73f56-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/162"},"text":"70A Stat. 162","children":[],"tail":", § 3035; "},{"tag":"ref","attrib":{"href":"/us/pl/85/599/s6/a"},"text":"Pub. L. 85–599, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-06"},"text":"Aug. 6, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/519"},"text":"72 Stat. 519","children":[],"tail":"; renumbered § 3034 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s502/d"},"text":"Pub. L. 99–433, title V, § 502(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1041"},"text":"100 Stat. 1041","children":[],"tail":"; renumbered § 7034, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1838"},"text":"132 Stat. 1838","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaad73f57-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaad73f58-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaad73f59-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3035(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3035(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:21c (1st sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:21c (less 1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-06-28/ch383/s203"},"text":"June 28, 1950, ch. 383, § 203","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/266"},"text":"64 Stat. 266","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “of the Army” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “If the Chief of Staff is absent or disabled or if that office is vacant” are substituted for 10:21c (1st 18 words of last sentence). The words “the officer who is highest on the following list and” are inserted for clarity. The words “until his successor is appointed” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaad73f5a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaad73f5b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3034"},"text":"section 3034 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/s502/d"},"text":"Pub. L. 99–433, § 502(d)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3035"},"text":"section 3035 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/s502/d/3"},"text":"Pub. L. 99–433, § 502(d)(3)","children":[],"tail":", substituted “Vice Chief of Staff” for “Vice Chief of Staff, Deputy Chiefs of Staff, and Assistant Chiefs of Staff: succession to duties of Chief of Staff” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/s502/d/1"},"text":"Pub. L. 99–433, § 502(d)(1)","children":[],"tail":", amended subsecs. (a) and (b) generally. Prior to amendment, subsecs. (a) and (b) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) The Vice Chief of Staff, the Deputy Chiefs of Staff, and the Assistant Chiefs of Staff shall be general officers detailed to those positions.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) If the Chief of Staff is absent or disabled or if that office is vacant, the officer who is highest on the following list and who is not absent or disabled shall, unless otherwise directed by the President, perform the duties of the Chief of Staff until a successor is appointed or the absence or disability ceases:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The Vice Chief of Staff.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The Deputy Chiefs of Staff in order of seniority.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/s502/d/2"},"text":"Pub. L. 99–433, § 502(d)(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/599"},"text":"Pub. L. 85–599","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaad73f5c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaad73f5d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
