{"tag":"section","attrib":{"id":"ida836cb9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948l"},"text":null,"children":[{"tag":"num","attrib":{"value":"948l"},"text":"§ 948l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail or employment of reporters and interpreters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida836cb9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Court Reporters","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under such regulations as the Secretary of Defense may prescribe, the convening authority of a military commission under this chapter shall detail to or employ for the military commission qualified court reporters, who shall prepare a verbatim record of the proceedings of and testimony taken before the military commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida836cb9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interpreters","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under such regulations as the Secretary of Defense may prescribe, the convening authority of a military commission under this chapter may detail to or employ for the military commission interpreters who shall interpret for the military commission, and, as necessary, for trial counsel and defense counsel for the military commission, and for the accused.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida836cb9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transcript; Record","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The transcript of a military commission under this chapter shall be under the control of the convening authority of the military commission, who shall also be responsible for preparing the record of the proceedings of the military commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida836cb9e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tXVIII/s1802"},"text":"Pub. L. 111–84, div. A, title XVIII, § 1802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2578"},"text":"123 Stat. 2578","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida836cb9f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida836cba0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida836cba1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 948","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":", added "},{"tag":"ref","attrib":{"href":"/us/pl/109/366/s3/a/1"},"text":"Pub. L. 109–366, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2605"},"text":"120 Stat. 2605","children":[],"tail":", related to detail or employment of reporters and interpreters, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
