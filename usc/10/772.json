","attrib":{},"text":"10:1393 (words between 3d and 4th semicolons of 1st proviso of 1st par.).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1028b.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1393 (words between 2d and 3d semicolons of 1st proviso of 1st par.).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-06-03/ch134/s12"},"text":"June 3, 1916, ch. 134, § 12","children":[],"tail":" (words before 4th semicolon, and words after 7th semicolon, of 1st proviso of 1st par.; and last proviso of last par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/39/216"},"text":"39 Stat. 216","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1918-07-09/ch143"},"text":"July 9, 1918, ch. 143","children":[],"tail":", subch. XVII, § 10 (last proviso), "},{"tag":"html:a","attrib":{"href":"/us/stat/40/892"},"text":"40 Stat. 892","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1920-06-04/ch228/s8"},"text":"June 4, 1920, ch. 228, § 8","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/41/836"},"text":"41 Stat. 836","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1942-06-06/ch382"},"text":"June 6, 1942, ch. 382","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/56/328"},"text":"56 Stat. 328","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1949-05-24/ch139/s15/b"},"text":"May 24, 1949, ch. 139, § 15(b)","children":[],"tail":" (last proviso), "},{"tag":"html:a","attrib":{"href":"/us/stat/63/91"},"text":"63 Stat. 91","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1953-07-06/ch180/s1"},"text":"July 6, 1953, ch. 180, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/140"},"text":"67 Stat. 140","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"34:399d.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 1256 (1st sentence).","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"772(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1393 (words between 8th and 9th semicolons of 1st proviso of 1st par.).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 1457 (less 1st and 3d sentences); ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-05-05/ch169/s14/f"},"text":"May 5, 1950, ch. 169, § 14(f)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/147"},"text":"64 Stat. 147","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"772(g)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"772(h)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1393 (last proviso of last par.).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1393 (words between 7th and 8th semicolons of 1st proviso of 1st par.).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1947-04-16/ch38/s207/j"},"text":"Apr. 16, 1947, ch. 38, § 207(j)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/61/50"},"text":"61 Stat. 50","children":[],"tail":"; as redesignated (i); "},{"tag":"html:a","attrib":{"href":"/us/act/1947-08-07/ch512/s434/d"},"text":"Aug. 7, 1947, ch. 512, § 434(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/61/882"},"text":"61 Stat. 882","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"772(i)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"772(j)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1393 (words after 9th semicolon of 1st proviso of 1st par.).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1393 (words between 1st and 2d semicolons of 1st proviso of 1st par., less 15th through 18th words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1930-06-21/ch563/s2"},"text":"June 21, 1930, ch. 563, § 2","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1949-08-04/ch393/s12"},"text":"Aug. 4, 1949, ch. 393, § 12","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/559"},"text":"63 Stat. 559","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1953-07-06/ch180/s2"},"text":"July 6, 1953, ch. 180, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/140"},"text":"67 Stat. 140","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a), (b), (d), (f), (g), (h), (i), and (j), the rules stated in the corresponding clauses of the first proviso of the first paragraph, and the last proviso of the last paragraph, of 10:1393, are restated to make positive the authority of the persons described in those subsections to wear the uniform prescribed for the appropriate organization or activity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “bear the title”, in 34:43g(i), applicable only to retired officers of the Navy Nurse Corps, are made applicable to other retired officers, to make explicit what has heretofore been implicit, that a retired officer may continue to bear the title of his retired grade.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words between the second and third semicolons of the first proviso of the first paragraph of 10:1393 are omitted as superseded by 10:1028b and 34:399d, which authorize the wearing of the uniform by members who are discharged honorably or under honorable conditions. The words “when authorized by regulations prescribed by” are substituted for the words “occasions authorized by regulations of”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f), the words “while portraying a member of the Army, Navy, Air Force, or Marine Corps, an actor in a theatrical or motion-picture production” are substituted for the words “any person from wearing the uniform of the United States Army, Navy, or Marine Corps, in any playhouse or theater or in moving-picture films while actually engaged in representing therein a military or naval character”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (g), the word “resident” is substituted for the word “members”, since the word “members” related to members of the now disbanded National Home for disabled volunteer soldiers to which were admitted “members” of an organization called the “Disabled Volunteer Soldiers”. The words “veterans’ home” are substituted for the words “national home for veterans”, since there are now no “national homes” administered by the Veterans’ Administration.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (h), the words “authorized and” and “for wear during such course of instruction” are omitted as surplusage. The word “naval” is omitted as covered by the word “military”. The words “Army, Navy, Air Force, or Marine Corps” are substituted for the words “military or naval authorities”. The words “that armed force” are substituted for the words “such military or naval authorities”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (i), the words “Air Force school” are substituted for the words “Air Force advanced flying schools or Air Force service schools”. The words “in such manner” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida807303e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"constitutionality","id":"ida807303f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Constitutionality","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For information regarding the constitutionality of certain provisions of this section as enacted by act ","children":[{"tag":"date","attrib":{"date":"1956-08-10"},"text":"Aug. 10, 1956","children":[],"tail":", see the Table of Laws Held Unconstitutional in Whole or in Part by the Supreme Court on the Constitution Annotated website, constitution.congress.gov."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8073040-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1741/b/2/B"},"text":"Pub. L. 118–31, § 1741(b)(2)(B)","children":[],"tail":", substituted “aviation or space badges of the Air Force or Space Force” for “aviation badges of the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1741/b/2/A"},"text":"Pub. L. 118–31, § 1741(b)(2)(A)","children":[],"tail":", which directed amendment of subsec. (i) by substituting “an Air Force or Space Force school” for “an Air Force School”, was executed by making the substitution for “an Air Force school” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Marine Corps, or Space Force” for “or Marine Corps” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" inserted before period at end “if the wear of such uniform is specifically authorized under regulations prescribed by the Secretary of the military department concerned”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" substituted “Department of Veterans Affairs” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" struck out provisions relating to a retired officer of the Navy Nurse Corps."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"ida8073041-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"ida8073042-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No.  10554. Delegation of Authority To Prescribe Regulations","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 10554, ","children":[{"tag":"date","attrib":{"date":"1954-08-18"},"text":"Aug. 18, 1954","children":[],"tail":", 19 F.R. 5295, as amended by Ex. Ord. No. 13286, § 77, "},{"tag":"date","attrib":{"date":"2003-02-28"},"text":"Feb. 28, 2003","children":[],"tail":", 68 F.R. 10631, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The authority vested in the President (1) by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-06-03/s125"},"text":"section 125 of the act of June 3, 1916","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/216"},"text":"39 Stat. 216","children":[],"tail":", as amended by the first section of the act of "},{"tag":"date","attrib":{"date":"1953-07-06"},"text":"July 6, 1953","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/140"},"text":"67 Stat. 140","children":[],"tail":", and (2) by "},{"tag":"ref","attrib":{"href":"/us/act/1930-06-21/s2"},"text":"section 2 of the act of June 21, 1930","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/793"},"text":"46 Stat. 793","children":[],"tail":", as amended by section 2 of said act of "},{"tag":"date","attrib":{"date":"1953-07-06"},"text":"July 6, 1953","children":[],"tail":", to prescribe regulations authorizing occasions upon which the uniform may be worn by persons who have served honorably in the armed forces of the United States in time of war is hereby delegated to the Secretary of Defense so far as it pertains to the uniforms of the Army, Navy, Air Force, and Marine Corps, and to the Secretary of Homeland Security so far as it pertains to the uniform of the Coast Guard."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
