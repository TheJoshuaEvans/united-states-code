{"tag":"section","attrib":{"id":"ida9dcda57-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819"},"text":null,"children":[{"tag":"num","attrib":{"value":"2819"},"text":"§ 2819.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy and assessment with respect to non-operational, underutilized, and other Department of Defense facilities: assessments of historical significance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9dcda58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Strategy for Demolition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Secretary concerned shall develop a strategy to demolish facilities under the respective jurisdiction of each such Secretary that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9dcda59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are in poor or failing condition under the uniform index developed under section 2838 of the National Defense Authorization Act for Fiscal Year 2024 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Public Law 118–31","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9dcda5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not in operational use; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9dcda5b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such Secretary determines are underutilized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9dcda5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment of Certain Maintenance Costs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Secretary concerned shall conduct an assessment to determine the total cost to the United States to maintain facilities that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9dcda5d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not in operational use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9dcda5e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such Secretary determines are underutilized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9dcda5f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Consideration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In determining whether a facility is underutilized pursuant to subsections (a) or (b), each Secretary concerned shall compare the occupancy of such facility to the total square footage of such facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9dcda60-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessments of Historic Significance","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9dcda61-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"2025-12-01"},"text":"December 1, 2025","children":[],"tail":", and on an annual basis thereafter, each Secretary concerned shall conduct an assessment of each facility under the jurisdiction of the Secretary concerned that was constructed at least 25 years prior to the year covered by the assessment to determine whether the facility—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9dcda62-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is historically significant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9dcda63-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be historically significant at the end of the 25-year period beginning on the date of the completion of such assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9dcda64-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For each facility described in paragraph (1) that a Secretary concerned determines is not, or will not be, historically significant pursuant to an assessment under such paragraph, the Secretary concerned shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9dcda65-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an assessment of the condition of such facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9dcda66-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make an initial determination of whether such facility will be modernized or demolished during such 25-year period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9dcda67-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the digital facilities management system of the military department under the jurisdiction of such Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9dcda68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the assessment under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9dcda69-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the initial determination required by subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9dcda6a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If, during the course of any assessment of a facility described in paragraph (1), the Secretary concerned changes a determination with respect to the historic significance of the facility or plans of such Secretary to modernize or demolish the facility, such Secretary shall revise the information submitted to the applicable digital facilities management system pursuant to subparagraph (C) of paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9dcda6b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Briefing","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9dcda6c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Along with the budget for fiscal year 2027 submitted by the President pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", United States Code, and on an annual basis thereafter, each Secretary concerned shall provide to the congressional defense committees a briefing on—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9dcda6d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strategy required by subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9dcda6e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the assessments required by subsections (b) and (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9dcda6f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each such briefing shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9dcda70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the existing authorities of each Secretary concerned to demolish the facilities covered by such strategy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9dcda71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan to implement such strategy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9dcda72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommendations of each such Secretary with respect to reducing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9dcda73-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/e/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the inventory of facilities in poor or failing condition under the uniform index developed under section 2838 of the National Defense Authorization Act for Fiscal Year 2024 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Public Law 118–31","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9dcda74-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2819/e/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total cost to the United States to maintain the facilities covered by the assessment required by subsection (b) of such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9dcda75-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dB/tXXVIII/s2822/a"},"text":"Pub. L. 118–159, div. B, title XXVIII, § 2822(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2254"},"text":"138 Stat. 2254","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVII/s1701/a/19"},"text":"Pub. L. 119–60, div. A, title XVII, § 1701(a)(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1209"},"text":"139 Stat. 1209","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9dcda76-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9dcda77-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida9dcda78-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2838 of the National Defense Authorization Act for Fiscal Year 2024, referred to in subsecs. (a)(1) and (e)(2)(C)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s2838"},"text":"section 2838 of Pub. L. 118–31","children":[],"tail":", which is set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2851"},"text":"section 2851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9dcda79-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" inserted “the” before “congressional defense committees”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
