{"tag":"section","attrib":{"id":"idab1c86b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8327"},"text":null,"children":[{"tag":"num","attrib":{"value":"8327"},"text":"§ 8327.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers and enlisted members of the Navy Reserve and Marine Corps Reserve: 30 years; 20 years; retired pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab1c86b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8327/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member of the Navy Reserve or the Marine Corps Reserve may be transferred to the Retired Reserve upon his request if he has completed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab1c86ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8327/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 30 years of active service in the armed forces, other than active duty for training; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1c86bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8327/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 20 years of active service in the armed forces other than active duty for training, the last 10 of which he served in the 11-year period immediately preceding his transfer to the Retired Reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1c86bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8327/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member who is transferred to the Retired Reserve under subsection (a) is entitled, when not on active duty, to retired pay at the rate of 50 percent of the basic pay of the grade in which retired.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1c86bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8327/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section applies only to persons who were members of the Navy Reserve or the Marine Corps Reserve on ","children":[{"tag":"date","attrib":{"date":"1953-01-01"},"text":"January 1, 1953","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1c86be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8327/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section terminates on ","children":[{"tag":"date","attrib":{"date":"1973-01-01"},"text":"January 1, 1973","children":[],"tail":". However, its termination will not affect any accrued rights to retired pay."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1c86bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8327/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member who is eligible for retirement under this section, and who is also eligible for retirement under another provision or for transfer to the Fleet Reserve or the Fleet Marine Corps Reserve under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8330"},"text":"section 8330 of this title","children":[],"tail":", is entitled to elect which of these benefits he is to receive."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab1c86c0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/395"},"text":"70A Stat. 395","children":[],"tail":", § 6327; "},{"tag":"ref","attrib":{"href":"/us/pl/85/583/s1/1"},"text":"Pub. L. 85–583, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-01"},"text":"Aug. 1, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/480"},"text":"72 Stat. 480","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/132/s5/h/5"},"text":"Pub. L. 88–132, § 5(h)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-10-02"},"text":"Oct. 2, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/214"},"text":"77 Stat. 214","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s515/b/1/I"},"text":"Pub. L. 109–163, div. A, title V, § 515(b)(1)(I)","children":[],"tail":", (3)(B), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3233"},"text":"119 Stat. 3233","children":[],"tail":", 3234; renumbered § 8327 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 807(b)(15), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":", 1840.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab1c86c1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab1c86c2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab1c86c3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6327","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t50/s1052/a"},"text":"50 U.S.C. 1052(a)","children":[],"tail":", (b), (d), (e), (f)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608/s413/a"},"text":"July 9, 1952, ch. 608, § 413(a)","children":[],"tail":", (b), (d), (e), (f), "},{"tag":"html:a","attrib":{"href":"/us/stat/66/499"},"text":"66 Stat. 499","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the word “Federal” is omitted and the words “in the armed forces, other than active duty for training” are inserted. The words “active Federal service” are not defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1052"},"text":"50 U.S.C. 1052","children":[],"tail":". Section 310 of the Naval Reserve Act of 1938, which "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1052"},"text":"50 U.S.C. 1052","children":[],"tail":" replaced, specifies active service in the “Army, Navy, Marine Corps, Coast Guard, Naval Auxiliary Service, Naval Reserve Force, Naval Militia in Federal status, National Naval Volunteers, Naval Reserve, Marine Corps Reserve Force, and Marine Corps Reserve.” "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1052"},"text":"50 U.S.C. 1052","children":[],"tail":" was intended to preserve the rights of persons who, on "},{"tag":"date","attrib":{"date":"1953-01-01"},"text":"January 1, 1953","children":[],"tail":", were members of reserve components, so that they would not be prejudiced by the repeal of § 310 of the Naval Reserve Act of 1938 (U.S. Code Congressional and Administrative News, 1952, p. 3584). To effect that purpose, the service that was creditable under the 1938 Act must be creditable under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1052"},"text":"50 U.S.C. 1052","children":[],"tail":". The words “active service in the armed forces, other than active duty for training” cover all creditable service. The Judge Advocate General of the Navy, in an opinion dated "},{"tag":"date","attrib":{"date":"1954-08-27"},"text":"August 27, 1954","children":[],"tail":" (JAG II:2:WGA:CA:mk), held that active duty for training was not creditable under the 1938 Act and is, therefore, not creditable under the 1952 Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab1c86c4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab1c86c5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s807/b/15"},"text":"Pub. L. 115–232, § 807(b)(15)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6327"},"text":"section 6327 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 8330” for “section 6330”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s515/b/3/B"},"text":"Pub. L. 109–163, § 515(b)(3)(B)","children":[],"tail":", substituted “Navy Reserve” for “Naval Reserve” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s515/b/1/I"},"text":"Pub. L. 109–163, § 515(b)(1)(I)","children":[],"tail":", substituted “Navy Reserve” for “Naval Reserve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/132"},"text":"Pub. L. 88–132","children":[],"tail":" substituted “of the grade in which retired” for “to which he would be entitled if on active duty” after “50 percent of the basic pay”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/583"},"text":"Pub. L. 85–583","children":[],"tail":" entitled eligible members of Naval Reserve or Marine Corps Reserve to elect to transfer to Fleet Reserve or Fleet Marine Corps Reserve."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab1ecfb6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab1ecfb7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab1ecfb8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1963 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/132"},"text":"Pub. L. 88–132","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1963-10-01"},"text":"Oct. 1, 1963","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/88/132/s14"},"text":"section 14 of Pub. L. 88–132","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s201"},"text":"section 201 of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
