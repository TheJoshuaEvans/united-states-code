{"tag":"section","attrib":{"id":"ida8bc7655-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1402a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1402a"},"text":"§ 1402a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recomputation of retired or retainer pay to reflect later active duty of members who first became members after ","children":[{"tag":"date","attrib":{"date":"1980-09-07"},"text":"September 7, 1980","children":[],"tail":null}],"tail":null},{"tag":"subsection","attrib":{"id":"ida8bc7656-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1402a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member of an armed force—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8bc7657-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1402a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who first became a member of a uniformed service after ","children":[{"tag":"date","attrib":{"date":"1980-09-07"},"text":"September 7, 1980","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8bc7658-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1402a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has become entitled to retired pay or retainer pay; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8bc7659-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1402a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who thereafter serves on active duty (other than for training),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is entitled to recompute his retired pay or retainer pay upon release from that duty according to the following table.","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida8bc765a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Column 1","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"Take","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Column 2","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"Multiply by","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Retired pay base or retainer pay base under section 1407 which he would be entitled to use if—","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"The retired pay multiplier or retainer pay multiplier prescribed in section 1409 for the sum of—","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"  (1) he were retiring upon release from that active duty; or","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"  (1) the years of service that may be credited to him in computing retired pay or retainer pay; and","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"  (2) he were transferring to the Fleet Reserve or Fleet Marine Corps Reserve upon that release from active duty.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"  (2) his years of active service after becoming entitled to retired pay or retainer pay.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8bc765b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1402a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"New Disability Incurred During Later Active Duty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of an armed force who first became a member of a uniformed service after ","children":[{"tag":"date","attrib":{"date":"1980-09-07"},"text":"September 7, 1980","children":[],"tail":", who has been retired other than for physical disability and who while on active duty incurs a physical disability of at least 30 percent for which he would otherwise be eligible for retired pay under chapter 61 of this title, is entitled, upon his release from active duty, to retired pay under subsection (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8bc765c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1402a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional or Aggravated Disability Incurred During Later Active Duty","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member of an armed force who first became a member of a uniformed service after ","children":[{"tag":"date","attrib":{"date":"1980-09-07"},"text":"September 7, 1980","children":[],"tail":", and who—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8bc765d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1402a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was retired for physical disability under section 1201 or 1204 of this title or any other law or whose name is on the temporary disability retired list;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8bc765e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1402a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incurs, while on active duty after retirement or after his name was placed on the temporary disability retired list, a physical disability that is in addition to or that aggravates the physical disability for which he was retired or for which his name was placed on that list; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8bc765f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1402a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is qualified under section 1201, 1202, 1204, or 1205 of this title;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is entitled, upon his release from active duty, to retired pay under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8bc7660-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1402a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Computation for Later Disability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of an armed force covered by subsection (b) or (c) may elect to receive either (1) the retired pay to which he became entitled when he retired, increased by any applicable adjustments in that pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1401a"},"text":"section 1401a of this title","children":[],"tail":" after he initially became entitled to that pay, or (2) retired pay computed according to the following table."},{"tag":"html:table","attrib":{"width":"100%","id":"ida8bc7661-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Column 1","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"Take","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Column 2","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"Multiply by","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Column 3","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"Add","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tfoot","attrib":{},"text":null,"children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"name":"TAB_285_0"},"text":null,"children":[],"tail":null},{"tag":"html:sup","attrib":{},"text":"1","children":[],"tail":" Before applying percentage factor, credit each full month of service that is in addition to the number of full years of service creditable to the member as one-twelfth of a year and disregard any remaining fractional part of a month."}],"tail":"\n"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"The retired pay base computed under ","children":[{"tag":"html:a","attrib":{"href":"/us/usc/t10/s1407/b"},"text":"section 1407(b) of this title","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"As member elects—","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"  (1) 2½ percent of years of service credited under ","children":[{"tag":"html:a","attrib":{"href":"/us/usc/t10/s1208"},"text":"section 1208 of this title","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"#TAB_285_0"},"text":null,"children":[{"tag":"html:sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":" or"}],"tail":null},{"tag":"html:p","attrib":{},"text":"  (2) the highest percentage of disability, not to exceed 75 percent, attained while on active duty after retirement or after the date when his name was placed on temporary disability retired list, as the case may be.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Amount necessary to increase product of columns 1 and 2 to 50 percent of pay upon which computation is based, if member is on temporary disability retired list.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8bc7662-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1402a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternative Recomputation to Subsection","children":[],"tail":" (a) "},{"tag":"inline","attrib":{},"text":"Formula","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (a), a member covered by that subsection may elect, upon his release from that active duty, to have his retired pay or retainer pay—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8bc7663-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1402a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" computed according to the formula set forth in subsection (a) but using the monthly retired pay base under which his retired pay or retainer pay was computed when he entered on that active duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8bc7664-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1402a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increased by any applicable adjustments in that pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1401a"},"text":"section 1401a of this title","children":[],"tail":" after he initially became entitled to that pay."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8bc7665-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1402a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional","children":[],"tail":" 10 "},{"tag":"inline","attrib":{},"text":"Percent for Certain Enlisted Members Credited With Extraordinary Heroism","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8bc7666-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1402a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a member who is entitled to recompute retired pay under this section upon release from active duty served after retiring under section 7314 or 9314 of this title, the member’s retired pay as recomputed under another provision of this section shall be increased by 10 percent of the amount so recomputed if the member has been credited by the Secretary concerned with extraordinary heroism in the line of duty during any period of active duty service in the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8bc7667-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1402a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of the retired pay as recomputed under another provision of this section and as increased under paragraph (1) may not exceed the amount equal to 75 percent of the retired pay base upon which the recomputation of such retired pay is based.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8bc7668-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1402a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The determination of the Secretary concerned as to extraordinary heroism is conclusive for all purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8bc7669-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/342/tVIII/s813/b/3/A"},"text":"Pub. L. 96–342, title VIII, § 813(b)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1102"},"text":"94 Stat. 1102","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s511/51/A"},"text":"Pub. L. 96–513, title V, § 511(51)(A)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2924"},"text":"94 Stat. 2924","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/94/tIX"},"text":"Pub. L. 98–94, title IX","children":[],"tail":", §§ 922(a)(5), (6), 923(a)(1), (2)(D), (E), "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/641"},"text":"97 Stat. 641","children":[],"tail":", 642; "},{"tag":"ref","attrib":{"href":"/us/pl/99/348/tII/s201/b/1"},"text":"Pub. L. 99–348, title II, § 201(b)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1986-07-01"},"text":"July 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/693"},"text":"100 Stat. 693","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tVI/s642/b"},"text":"Pub. L. 102–484, div. A, title VI, § 642(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2425"},"text":"106 Stat. 2425","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVI/s631/c"},"text":"Pub. L. 111–383, div. A, title VI, § 631(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4239"},"text":"124 Stat. 4239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s809/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 809(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1840"},"text":"132 Stat. 1840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8bc766a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8bc766b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8bc766c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “section 7314 or 9314” for “section 3914 or 8914”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":", in column 2 of table, inserted “, not to exceed 75%,” after “percentage of disability” and struck out column 4 of table which related to subtraction of excess over 75 percent of retired or retainer pay base upon which computation is based."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/348/s201/b/1"},"text":"Pub. L. 99–348, § 201(b)(1)","children":[],"tail":", amended subsec. (a) generally. Prior to the amendment, subsec. (a) read as follows: “A member of an armed force who first became a member of a uniformed service (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1407/a/2"},"text":"section 1407(a)(2) of this title","children":[],"tail":") after "},{"tag":"date","attrib":{"date":"1980-09-07"},"text":"September 7, 1980","children":[],"tail":", who has become entitled to retired pay or retainer pay, and who thereafter serves on active duty (other than for training), is entitled to recompute his retired pay or retainer pay upon his release from that duty according to the following table. The amount recomputed, if not a multiple of $1, shall be rounded to the next lower multiple of $1.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/348/s201/b/2/A"},"text":"Pub. L. 99–348, § 201(b)(2)(A)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/348/s201/b/2/B"},"text":"Pub. L. 99–348, § 201(b)(2)(B)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/348/s201/b/2/C"},"text":"Pub. L. 99–348, § 201(b)(2)(C)","children":[],"tail":", inserted heading, struck out provision that if the amount recomputed is not a multiple of $1, it be rounded to the next lower multiple of $1, and in column 1 of table struck out “monthly” before “retired pay” and in column 4 of table struck out “monthly” before “retired or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/348/s201/b/2/D"},"text":"Pub. L. 99–348, § 201(b)(2)(D)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/s922/a/5"},"text":"Pub. L. 98–94, § 922(a)(5)","children":[],"tail":", substituted “according to the following table. The amount recomputed, if not a multiple of $1, shall be rounded to the next lower multiple of $1.” for “as follows:”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/s923/a/1"},"text":"Pub. L. 98–94, § 923(a)(1)","children":[],"tail":", (2)(D), in footnote 1 of table, substituted “Before applying percentage factor, credit each full month of service that is in addition to the number of full years of service creditable to the member as one-twelfth of a year and disregard any remaining fractional part of a month” for “Before applying percentage factor, credit a part of a year that is six months or more as a whole year, and disregard a part of a year that is less than six months”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/s922/a/6"},"text":"Pub. L. 98–94, § 922(a)(6)","children":[],"tail":", substituted “according to the following table. The amount computed, if not a multiple of $1, shall be rounded to the next lower multiple of $1.” for “as follows:”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/s923/a/1"},"text":"Pub. L. 98–94, § 923(a)(1)","children":[],"tail":"