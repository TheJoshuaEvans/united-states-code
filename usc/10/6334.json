{"tag":"section","attrib":{"id":"idaacdcb04-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6334"},"text":null,"children":[{"tag":"num","attrib":{"value":"6334"},"text":"§ 6334.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charges to individual program, project, or activity","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":" Of the funds authorized by the Secretary of Energy for laboratory directed research and development, no individual program, project, or activity funded by this or any subsequent Act ","children":[{"tag":"ref","attrib":{"idref":"fn002149"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002149"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" making appropriations for Energy and Water Development for any fiscal year may be charged more than the statutory maximum authorized for such activities: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That this section shall take effect not earlier than "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"October 1, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idaacdcb05-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1449"},"text":"139 Stat. 1449","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaacdcb06-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaacdcb07-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"childr