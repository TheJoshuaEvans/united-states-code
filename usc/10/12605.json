{"tag":"section","attrib":{"id":"idaba4542e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12605"},"text":null,"children":[{"tag":"num","attrib":{"value":"12605"},"text":"§ 12605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presentation of United States flag: members transferred from an active status or discharged after completion of eligibility for retired pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaba4542f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presentation of Flag","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon the transfer from an active status or discharge of a Reserve who has completed the years of service required for eligibility for retired pay under chapter 1223 of this title, the Secretary concerned shall present a United States flag to the member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba45430-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multiple Presentations Not Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member is not eligible for presentation of a flag under subsection (a) if the member has previously been presented a flag under this section or any provision of law providing for the presentation of a United States flag incident to release from active service for retirement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba45431-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12605/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Cost to Recipient","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The presentation of a flag under this section shall be at no cost to the recipient.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaba45432-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s652/a/1"},"text":"Pub. L. 106–65, div. A, title VI, § 652(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/664"},"text":"113 Stat. 664","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaba45433-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaba45434-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaba45435-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s652/d"},"text":"Pub. L. 106–65, div. A, title VI, § 652(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/665"},"text":"113 Stat. 665","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/65/dA/tVI/s652/d"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12605"},"text":"Section 12605 of title 10","children":[],"tail":", United States Code (as added by subsection (a)), section 213 of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s214"},"text":"42 U.S.C. 214","children":[],"tail":"] (as added by subsection (b)), and section 25 of the Coast and Geodetic Survey Commissioned Officers’ Act of 1948 ["},{"tag":"ref","attrib":{"href":"/us/usc/t33/s853v"},"text":"33 U.S.C. 853v","children":[],"tail":"] (as added by subsection (c)) shall apply with respect to releases from service described in those sections on or after "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"October 1, 1999","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
