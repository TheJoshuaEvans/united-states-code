{"tag":"section","attrib":{"id":"idaad9b110-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7065"},"text":null,"children":[{"tag":"num","attrib":{"value":"7065"},"text":"§ 7065.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment and detail: officers assigned or detailed to basic and special branches","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaad9b111-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7065/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Commissioned officers of the Army may be detailed as general staff officers and as inspectors general.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad9b112-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7065/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Army may be detailed to duty in particular fields specified by the Secretary, including intelligence, counter-intelligence, and military government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad9b113-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7065/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Army appointed in or assigned to one branch may be detailed for duty with any other branch.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad9b114-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7065/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Army while not on active duty may be assigned to any basic or special branch, or to such other branches or groups, and to such organizations, as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad9b115-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7065/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No officer of the Army may be assigned to perform technical, scientific, or other professional duties unless he is qualified to perform those duties and meets professional qualifications at least as strict as those in effect on ","children":[{"tag":"date","attrib":{"date":"1950-06-28"},"text":"June 28, 1950","children":[],"tail":". If the duties to which an officer is assigned involve professional work that is the same as or is similar to that usually performed in civil life by a member of a learned profession, such as engineering, law, medicine, or theology, the officer must have the qualifications, by education, training, or experience, equal to or similar to those usually required of members of that profession, unless the exigencies of the situation prevent."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad9b116-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/167"},"text":"70A Stat. 167","children":[],"tail":", § 3065; renumbered § 7065, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1838"},"text":"132 Stat. 1838","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaad9b117-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"top