{"tag":"section","attrib":{"id":"ida8393c2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949s"},"text":null,"children":[{"tag":"num","attrib":{"value":"949s"},"text":"§ 949s.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cruel or unusual punishments prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Punishment by flogging, or by branding, marking, or tattooing on the body, or any other cruel or unusual punishment, may not be adjudged by a military commission under this chapter or inflicted under this chapter upon any person subject to this chapter. The use of irons, single or double, except for the purpose of safe custody, is prohibited under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida8393c2e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tXVIII/s1802"},"text":"Pub. L. 111–84, div. A, title XVIII, § 1802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2598"},"text":"123 Stat. 2598","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8393c2f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8393c30-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida8393c31-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 949s, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/366/s3/a/1"},"text":"Pub. L. 109–366, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2617"},"text":"120 Stat. 2617","children":[],"tail":", prohibited cruel or unusual punishments, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
