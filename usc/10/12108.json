{"tag":"section","attrib":{"id":"idab986d56-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12108"},"text":null,"children":[{"tag":"num","attrib":{"value":"12108"},"text":"§ 12108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enlisted members: discharge or retirement for years of service or for age","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each reserve enlisted member of the Army, Navy, Air Force, or Marine Corps who is in an active status and has reached the maximum years of service or age prescribed by the Secretary concerned shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab986d57-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12108/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be transferred to the Retired Reserve if the member is qualified for such transfer and does not request (in accordance with regulations prescribed by the Secretary concerned) not to be transferred to the Retired Reserve; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab986d58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12108/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be discharged if the member is not qualified for transfer to the Retired Reserve or has requested (in accordance with regulations prescribed by the Secretary concerned) not to be so transferred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab986d59-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s517/f/1"},"text":"Pub. L. 107–107, div. A, title V, § 517(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1095"},"text":"115 Stat. 1095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab986d5a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab986d5b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idab986d5c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first month that begins more than 180 days after ","children":[{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/s517/g"},"text":"section 517(g) of Pub. L. 107–107","children":[],"tail":", set out as an Effective Date of 2001 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10154"},"text":"section 10154 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
