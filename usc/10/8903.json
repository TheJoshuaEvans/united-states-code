{"tag":"section","attrib":{"id":"idab534e1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8903"},"text":null,"children":[{"tag":"num","attrib":{"value":"8903"},"text":"§ 8903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release from Militia duty upon order to active duty in reserve components","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When ordered to active duty, a member of the Navy Reserve or the Marine Corps Reserve who is a member of the Naval Militia is relieved from all service and duty in the Naval Militia from the date of active duty specified in his orders until he is released from active duty.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab534e1d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/486"},"text":"70A Stat. 486","children":[],"tail":", § 7853; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s515/b/1/X"},"text":"Pub. L. 109–163, div. A, title V, § 515(b)(1)(X)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3233"},"text":"119 Stat. 3233","children":[],"tail":"; renumbered § 8903, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/11"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab534e1e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab534e1f-3a