],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida90195dc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Par. (2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" substituted “National Geospatial-Intelligence Agency” for “National Imagery and Mapping Agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" substituted “of the Department of Defense” for “of an intelligence component of the Department of Defense or of a military department”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Par. (3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “Committee on Armed Services” for “Committee on National Security”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida90195dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida90195de-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1635"},"text":"section 1635 of Pub. L. 104–201","children":[],"tail":", set out as an Effective Date of 1996 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1593"},"text":"section 15