{"tag":"section","attrib":{"id":"ida90195ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1614"},"text":null,"children":[{"tag":"num","attrib":{"value":"1614"},"text":"§ 1614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90195cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1614/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “defense intelligence position” means a civilian position as an intelligence officer or intelligence employee of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90195cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1614/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “intelligence component of the Department of Defense” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida90195cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1614/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Security Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90195ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1614/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Defense Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90195cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1614/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Geospatial-Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90195d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1614/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other component of the Department of Defense that performs intelligence functions and is designated by the Secretary of Defense as an intelligence component of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90195d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1614/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any successor to a component specified in, or designated pursuant to, this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90195d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1614/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “congressional oversight committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida90195d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1614/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services and the Select Committee on Intelligence of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90195d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1614/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services and the Permanent Select Committee on Intelligence of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90195d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1614/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “excepted service” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2103"},"text":"section 2103 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90195d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1614/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “preference eligible” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2108/3"},"text":"section 2108(3) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90195d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1614/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Senior Executive Service position” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132/a/2"},"text":"section 3132(a)(2) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90195d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1614/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “collective bargaining agreement” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"hre