tag":"p","attrib":{},"text":"Subsec. (d)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1731/a/12"},"text":"Pub. L. 116–92, § 1731(a)(12)","children":[],"tail":", inserted “had” before “been” prior to the general amendment of subsec. (d). See Amendment note above and Coordination of Amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida78b21a1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida78b21a2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Coordination of Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Amendments to this section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1731"},"text":"section 1731 of Pub. L. 116–92","children":[],"tail":" to be treated as having been enacted immediately before amendments by other provisions of "},{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1731/f"},"text":"section 1731(f) of Pub. L. 116–92","children":[],"tail":", set out as a Coordination of Certain Sections of an Act With Other Provisions of That Act note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida78b21a3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Annual Report on Unfunded Requirements for Laboratory Military Construction Projects","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dB/tXXVIII/s2806"},"text":"Pub. L. 115–91, div. B, title XXVIII, § 2806","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1847"},"text":"131 Stat. 1847","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dB/tXXVIII/s2807"},"text":"Pub. L. 116–92, div. B, title XXVIII, § 2807","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1885"},"text":"133 Stat. 1885","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dB/tXXVIII/s2807"},"text":"“The Under Secretary of Defense for Research and Engineering, in coordination with the Under Secretary of Defense for Acquisition and Sustainment, shall submit to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] each year, at the time the budget of the President for the fiscal year beginning in such year is submitted to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", United States Code, a report listing unfunded requirements on major and minor military construction projects for Department of Defense science and technology laboratories and facilities and test and evaluation facilities, in prioritized order, with specific accounts and program elements identified, and shall include a Department of Defense Form DD1391 for each major and minor military construction project included in the report.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
