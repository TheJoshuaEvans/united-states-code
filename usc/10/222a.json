{"tag":"section","attrib":{"id":"ida78b2170-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a"},"text":null,"children":[{"tag":"num","attrib":{"value":"222a"},"text":"§ 222a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unfunded priorities of the armed forces and combatant commands: annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida78b2171-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 10 days after the date on which the budget of the President for a fiscal year is submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", each officer specified in subsection (b) shall submit to the Secretary of Defense and the Chairman of the Joint Chiefs of Staff, and to the congressional defense committees, a report on the unfunded priorities of the armed force or forces or combatant command under the jurisdiction or command of such officer."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida78b2172-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The officers specified in this subsection are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida78b2173-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Staff of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b2174-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Naval Operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b2175-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Staff of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b2176-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commandant of the Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b2177-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Space Operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b2178-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The commanders of the combatant commands established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s161"},"text":"section 161 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b2179-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of the National Guard Bureau in the role assigned to that position in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s10502/c/1"},"text":"section 10502(c)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida78b217a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida78b217b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under this subsection shall specify, for each unfunded priority covered by such report, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida78b217c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary description of such priority, including the objectives outlined in the national defense strategy required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s113/g"},"text":"section 113(g) of this title","children":[],"tail":" and the National Military Strategy required under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s139/b"},"text":"section 139(b) of this title","children":[],"tail":" to be advanced if such priority is funded (whether in whole or in part)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b217d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The additional amount of funds recommended in connection with the objectives under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b217e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Account information with respect to such priority, including the following (as applicable):","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida78b217f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Line Item Number (LIN) for applicable procurement accounts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida78b2180-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Program Element (PE) number for applicable research, development, test, and evaluation accounts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida78b2181-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sub-activity group (SAG) for applicable operation and maintenance accounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b2182-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed assessment of each specific risk that would be reduced in executing the national defense strategy required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s113/g"},"text":"section 113(g) of this title","children":[],"tail":" and the National Military Strategy required under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s139/b"},"text":"section 139(b) of this title","children":[],"tail":" if such priority is funded (whether in whole or in part)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b2183-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The requirement to be addressed by the unfunded priority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b2184-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The reason why funding for the priority was not included in the budget of the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b2185-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of any funding provided for the requirement for the current and preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b2186-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the effect that providing funding for the priority would have on the future-years defense plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b2187-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prioritization of priorities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report shall present the unfunded priorities covered by such report as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida78b2188-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In overall order of urgency of priority according to the amount of risk reduced.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b2189-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In overall order of urgency of priority among unfunded priorities (other than covered military construction projects).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b218a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In overall order of urgency of priority among covered military construction projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b218b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National guard unfunded priorities.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida78b218c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The officer specified under subsection (b)(7) shall only include in a report submitted under subsection (a) such priorities that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida78b218d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relate to equipping requirements in support of non-federalized National Guard responsibilities for the homeland defense or civil support missions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida78b218e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subparagraph (B), were not included in a report under this section submitted by an officer specified in subsection (b)(1) or (3) for any of five fiscal years preceding the fiscal year for which the report is submitted, on behalf of National Guard forces to address a warfighting requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b218f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The officer specified under subsection (b)(7) may include in a report submitted under subsection (a) an unfunded priority covered by subparagraph (A)(ii) if the Secretary of Defense—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida78b2190-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that the inclusion such unfunded priority reasonably supports the priorities of the Department under the national defense strategy under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s113/g"},"text":"section 113(g) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida78b2191-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits to the congressional defense committees written notice of such determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida78b2192-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prioritization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 10 days after the receipt of all of the reports referred to in subsection (a), the Secretary of Defense, in consultation with the Chairman of the Joint Chiefs of Staff, shall submit to the congressional defense committees a report that prioritizes each specific unfunded priority across all unfunded priorities submitted by officers specified in (b) according to the risk reduced in executing the national defense strategy required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s113/g"},"text":"section 113(g) of this title","children":[],"tail":" and the National Military Strategy required under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s139/b"},"text":"section 139(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida78b2193-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida78b2194-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “unfunded priority”, in the case of a fiscal year, means a program, activity, or mission requirement, including a covered military construction project, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida78b2195-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not funded in the budget of the President for the fiscal year as submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b2196-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary to fulfill a requirement associated with an operational or contingency plan of a combatant command or other validated requirement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b2197-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" would have been recommended for funding through the budget referred to in subparagraph (1) by the officer submitting the report required by subsection (a) in connection with the budget if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida78b2198-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/e/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional resources had been available for the budget to fund the program, activity, or mission requirement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida78b2199-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/e/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program, activity, or mission requirement has emerged since the budget was formulated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b219a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered military construction project”, in connection with a fiscal year, means a military construction project that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida78b219b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is included in any fiscal year of the future-years defense program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s221"},"text":"section 221 of this title","children":[],"tail":" that is submitted in connection with the budget of the President for the fiscal year, and is executable in the fiscal year; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b219c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is considered by the commander of a combatant command referred to in subsection (b)(5) to be an urgent need, and is executable in the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida78b219d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tX/s1064/a/1"},"text":"Pub. L. 114–328, div. A, title X, § 1064(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2408"},"text":"130 Stat. 2408","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tX/s1005"},"text":"Pub. L. 116–92, div. A, title X, §