{"tag":"section","attrib":{"id":"idabb766ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14506"},"text":null,"children":[{"tag":"num","attrib":{"value":"14506"},"text":"§ 14506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of failure of selection for promotion: reserve majors of the Army, Air Force, and Marine Corps and reserve lieutenant commanders of the Navy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Unless retained as provided in section 12646, 12686, 14701, 14701a, or 14702 of this title, each reserve officer of the Army, Navy, Air Force, or Marine Corps who holds the grade of major or lieutenant commander who has failed of selection to the next higher grade for the second time and whose name is not on a list of officers recommended for promotion to the next higher grade shall, if not earlier removed from the reserve active-status list, be removed from that list in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14513"},"text":"section 14513 of this title","children":[],"tail":" on the later of (1) the first day of the month after the month in which the officer completes 20 years of commissioned service, or (2) the first day of the seventh month after the month in which the Secretary concerned releases the promotion results of the board which considered the officer for the second time to the public."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idabb766f0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2951"},"text":"108 Stat. 2951","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1501/b/29"},"text":"Pub. L. 104–106, div. A, title XV, § 1501(b)(29)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/498"},"text":"110 Stat. 498","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s514/a"},"text":"Pub. L. 106–65, div. A, title V, § 514(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/593"},"text":"113 Stat. 593","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV"},"text":"Pub. L. 118–159, div. A, title V","children":[],"tail":", §§ 505(b)(6), 513(c)(3), "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1870"},"text":"138 Stat. 1870","children":[],"tail":", 1876.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb766f1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabb766f2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabb766f3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s513/c/3"},"text":"Pub. L. 118–159, § 513(c)(3)","children":[],"tail":", inserted “14701a,” after “14701,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s505/b/6"},"text":"Pub. L. 118–159, § 505(b)(6)","children":[],"tail":", substituted “the Secretary concerned releases the promotion results of the board which considered the officer for the second time to the public” for “the President approves the report of the board which considered the officer for the second time”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" inserted “the later of (1)” after “in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s14513"},"text":"section 14513 of this title","children":[],"tail":" on” and “, or (2) the first day of the seventh month after the month in which the President approves the report of the board which considered the officer for the second time” before the period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" inserted comma after “Force” in section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabb766f4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idabb766f5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s514/b"},"text":"Pub. L. 106–65, div. A, title V, § 514(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/593"},"text":"113 Stat. 593","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/65/dA