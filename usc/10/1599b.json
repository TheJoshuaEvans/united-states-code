{"tag":"section","attrib":{"id":"ida8fcda2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1599b"},"text":"§ 1599b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees abroad: travel expenses; health care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8fcda2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may provide civilian employees, and members of their families, abroad with benefits that are comparable to certain benefits that are provided by the Secretary of State to members of the Foreign Service and their families abroad as described in subsections (b) and (c). The Secretary may designate the employees and members of families who are eligible to receive the benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcda2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Travel and Related Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may pay travel expenses and related expenses for purposes and in amounts that are comparable to the purposes for which, and the amounts in which, travel and related expenses are paid by the Secretary of State under section 901 of the Foreign Service Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4081"},"text":"22 U.S.C. 4081","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcda30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Health Care Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may establish a health care program that is comparable to the health care program established by the Secretary of State under section 904 of the Foreign Service Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4084"},"text":"22 U.S.C. 4084","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcda31-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may enter into agreements with the heads of other departments and agencies of the Government in order to facilitate the payment of expenses authorized by subsection (b) and to carry out a health care program authorized by subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcda32-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Abroad Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “abroad” means outside—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fcda33-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fcda34-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the territories and possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8fcda35-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVI/s1604/a"},"text":"Pub. L. 104–201, div. A, title XVI, § 1604(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2735"},"text":"110 Stat. 2735","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
