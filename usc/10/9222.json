{"tag":"section","attrib":{"id":"idab68d13d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9222"},"text":null,"children":[{"tag":"num","attrib":{"value":"9222"},"text":"§ 9222.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rank: commissioned officers serving under temporary appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President may, in accordance with the needs of the Air Force or the Space Force, adjust dates of rank of commissioned officers of the Air Force or the Space Force serving in temporary grades.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab68d13e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/529"},"text":"70A Stat. 529","children":[],"tail":", § 8572; renumbered § 9222, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/b/7"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1832"},"text":"132 Stat. 1832","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s923/c/6"},"text":"Pub. L. 116–283, div. A, title IX, § 923(c)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3811"},"text":"134 Stat. 3811","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab68d13f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab68d140-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"w