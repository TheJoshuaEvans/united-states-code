{"tag":"section","attrib":{"id":"ida7fb48a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s665"},"text":null,"children":[{"tag":"num","attrib":{"value":"665"},"text":"§ 665.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for monitoring careers of joint qualified officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7fb48a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s665/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7fb48aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s665/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense, with the advice of the Chairman of the Joint Chiefs of Staff, shall establish procedures for overseeing the careers of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7fb48ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s665/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" officers designated as a joint qualified officer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7fb48ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s665/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other officers who serve in joint duty assignments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7fb48ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s665/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such oversight shall include monitoring of the implementation of the career guidelines established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s661/e"},"text":"section 661(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7fb48ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s665/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Function of Joint Staff","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall take such action as necessary to enhance the capabilities of the Joint Staff so that it can—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7fb48af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s665/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor the promotions and career assignments of officers designated as a joint qualified officer and of other officers who have served in joint duty assignments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7fb48b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s665/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise advise the Chairman on joint personnel matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7fb48b1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tIV/s401/a"},"text":"Pub. L. 99–433, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1028"},"text":"100 Stat. 1028","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title V, § 522(c)(1), (2), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4445"},"text":"122 Stat. 4445","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7fb48b2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7fb48b3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7fb48b4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" in section catchline substituted “joint qualified officers” for “joint officers” and in subsecs. (a)(1)(A) and (b)(1) substituted “designated as a joint qualified officer” for “with the joint specialty”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7fb48b5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7fb48b6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transition to Joint Officer Personnel Policy","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Procedures under subsec. (a) of this section to be established not later than the end of the eight-month period beginning ","children":[{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", and provisions of subsec. (b) of this section to be implemented not later than the end of such period, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/433/s406/c"},"text":"section 406(c) of Pub. L. 99–433","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s661"},"text":"section 661 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
