{"tag":"section","attrib":{"id":"ida8d8fee0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1480"},"text":null,"children":[{"tag":"num","attrib":{"value":"1480"},"text":"§ 1480.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Death gratuity: miscellaneous provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8d8fee1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1480/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A payment may not be made under sections 1475–1477 of this title if the decedent was put to death as lawful punishment for a crime or a military offense, unless he was put to death by a hostile force with which the armed forces of the United States were engaged in armed conflict.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8d8fee2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1480/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A payment may not be made under section 1476 unless the Secretary of Veterans Affairs determines that the decedent was discharged or released, as the case may be, under conditions other than dishonorable from the last period of the duty or training that he performed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8d8fee3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1480/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1475/a/3"},"text":"section 1475(a)(3) of this title","children":[],"tail":", the Secretary concerned shall determine whether the decedent was authorized or required to perform the duty or training and whether or not he died from injury so incurred. For the purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1476"},"text":"section 1476 of this title","children":[],"tail":", the Secretary of Veterans Affairs shall make those determinations. In making those determinations, the Secretary concerned or the Secretary of Veterans Affairs, as the case may be, shall consider—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8d8fee4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1480/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the hour on which the Reserve began to travel directly to or from the duty or training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d8fee5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1480/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the hour at which he was scheduled to arrive for, or at which he ceased performing, that duty or training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d8fee6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1480/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the method of travel used;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d8fee7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1480/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the itinerary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d8fee8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1480/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner in which the travel was performed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d8fee9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1480/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the immediate cause of death.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In cases covered by this subsection, the burden of proof is on the claimant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8d8feea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1480/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payments under sections 1475–1477 of this title shall be made from appropriations available for the payment of members of the armed force concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8d8feeb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1480/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a claim for a death gratuity under this chapter by an individual who is younger than 21 years of age on the date of the death with respect to which the claim is made, the individual shall file the claim with the Secretary of Defense not later than the later of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8d8feec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1480/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is three years after the individual reaches 21 years of age; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d8feed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1480/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is six years after the date of the death with respect to which the claim is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8d8feee-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/32/A"},"text":"Pub. L. 85–861, § 1(32)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1455"},"text":"72 Stat. 1455","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXVI/s1621/a/2"},"text":"Pub. L. 101–189, div. A, title XVI, § 1621(a)(2)","children":[],"tail":", (5), "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1603"},"text":"103 Stat. 1603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVI/s632/a"},"text":"Pub. L. 118–159, div. A, title VI, § 632(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1937"},"text":"138 Stat. 1937","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8d8feef-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8d8fef0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida8d8fef1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1480(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1480(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1480(c)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1480(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"38:1134(a).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"38:1133(e).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"38:1101(6)(B) (less 1st sentence, as applicable to death gratuity).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"38:1134(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-08-01/ch837"},"text":"Aug. 1, 1956, ch. 837","children":[],"tail":", §§ 102(6)(B) (less 1st sentence, as applicable to death gratuity) 303(e), 304(a), (b), "},{"tag":"html:a","attrib":{"href":"/us/stat/70/859"},"text":"70 Stat. 859","children":[],"tail":", 869."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “was put to death” are substituted for the words “suffered death”. The words “or naval” are omitted as covered by the word “military”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “last period * * * that he performed” are substituted for the words “such period”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8d8fef2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8d8fef3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s1621/a/2"},"text":"Pub. L. 101–189, § 1621(a)(2)","children":[],"tail":", substituted “Secretary of Veterans Affairs” for “Administrator of Veterans’ Affairs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s1621/a/2"},"text":"Pub. L. 101–189, § 1621(a)(2)","children":[],"tail":", (5), substituted “Secretary of Veterans Affairs” for “Administrator of Veterans’ Affairs” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1476"},"text":"section 1476 of this title","children":[],"tail":", the” and “the Secretary concerned or the Secretary of Veterans Affairs” for “the Secretary or the Administrator”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8d8fef4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8d8fef5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVI/s632/b"},"text":"Pub. L. 118–159, div. A, title VI, § 632(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1937"},"text":"138 Stat. 1937","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tVI/s632/b"},"text":"“The amendment made by subsection (a) [amending this section] applies to claims filed with respect to deaths occurring on or after on [sic] ","children":[{"tag":"date","attrib":{"date":"2025-01-01"},"text":"January 1, 2025","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
