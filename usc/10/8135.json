{"tag":"section","attrib":{"id":"idab1078b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8135"},"text":null,"children":[{"tag":"num","attrib":{"value":"8135"},"text":"§ 8135.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regular Marine Corps: order of filling vacancies in grade of second lieutenant","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Vacancies on the active-duty list of the Marine Corps in the grade of second lieutenant shall be filled, so far as practicable, first, from members of the graduating class of the Naval Academy; second, from meritorious noncommissioned officers of the Regular Marine Corps; and third, from other persons.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab1078b9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/324"},"text":"70A Stat. 324","children":[],"tail":", § 5585; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s503/29"},"text":"Pub. L. 96–513, title V, § 503(29)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2913"},"text":"94 Stat. 2913","children":[],"tail":"; renumbered § 8135, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/4"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1834"},"text":"132 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab1078ba-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id