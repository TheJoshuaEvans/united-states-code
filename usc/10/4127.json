{"tag":"section","attrib":{"id":"idaa5b5927-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127"},"text":null,"children":[{"tag":"num","attrib":{"value":"4127"},"text":"§ 4127.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defense Innovation Unit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa5b5928-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established in the Department of Defense a Defense Innovation Unit (referred to in this section as the “Unit”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa5b5929-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director and Deputy Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is a Director of the Unit who shall be appointed by the Secretary of Defense from among persons with substantial experience in innovation and commercial technology, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa5b592a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of Director","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director is the head of the Unit. The Director—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa5b592b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall serve as a principal staff assistant to the Secretary of Defense on matters within the responsibility of the Unit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b592c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall report directly to the Secretary without intervening authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b592d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may communicate views on matters within the responsibility of the Unit directly to the Secretary without obtaining the approval or concurrence of any other official within the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa5b592e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Unit shall have the following responsibilities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa5b592f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Seek out, identify, and support development of and experimentation with commercial technologies that have the potential to be implemented within the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b5930-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Accelerate the adoption or integration of commercial technologies within the Department of Defense to transform military capacity and capabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b5931-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Serve as the principal liaison between the Department of Defense and individuals and entities in the national security innovation base, including entrepreneurs, startups, commercial technology companies, and venture capital sources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b5932-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Carry out programs, projects, and other activities to strengthen the national security innovation base.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b5933-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinate and harmonize the activities of other organizations and elements of the Department of Defense on matters relating to commercial technologies, dual use technologies, and the innovation of such technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b5934-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinate and advise efforts among elements of the Department of Defense on matters relating to the development, procurement, and fielding of nontraditional capabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b5935-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinate with the Joint Staff and the commanders of the combatant commands to identify operational challenges that have the potential to be addressed through the use of nontraditional capabilities, including dual-use technologies, that are being developed and financed in the commercial sector.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b5936-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Using funds made available to the Unit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa5b5937-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/d/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select projects to be carried out by one or more of the service-level innovation organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa5b5938-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/d/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allocate funds to service-level innovation organizations to carry out such projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa5b5939-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/d/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor the execution of such projects by the service-level innovation organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b593a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Serve as the principal liaison between the Department of Defense, nontraditional defense contractors, investors in nontraditional defense companies, and departments and agencies of the Federal Government pursuing nontraditional capabilities similar to those pursued by the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b593b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Lead engagement with industry, academia, and other nongovernment entities to develop—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa5b593c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/d/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" domestic capacity with respect to innovative, commercial, and dual-use technologies and the use of nontraditional defense contractors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa5b593d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/d/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capacity of international allies and partners of the United States with respect to such technologies and the use of such contractors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b593e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/d/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Carry out such other activities as the Secretary of Defense determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa5b593f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support for Multi-stakeholder Partnerships.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa5b5940-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director shall identify and support multi-stakeholder research and innovation partnerships that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa5b5941-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the potential to generate technologies, processes, products, or other solutions that address national defense or security needs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa5b5942-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have as an objective the technology transfer or commercialization of the work product generated by the partnership, which may include work product that incorporates Government-developed intellectual property licensed to the partnership in accordance with paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b5943-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Support provided by the Director to a multi-stakeholder research and innovation partnership under this subsection may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa5b5944-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing funding or other resources to the partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa5b5945-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participating in the partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa5b5946-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical and technological advice and guidance to the partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa5b5947-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suggesting and introducing other participants for inclusion in the partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa5b5948-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing the partnership with insight into desired solutions for defense and security needs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa5b5949-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other forms of support as the Director determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b594a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent the Director determines appropriate, the Director shall seek to actively inform potential participants in multi-stakeholder research and innovation partnerships of the availability of Government-developed intellectual property that may be licensed to the partnership.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b594b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On an annual basis, the Director shall submit to the Secretary of Defense and the congressional defense committees a report on the activities, advances, outcomes, and work product of the multi-stakeholder research and innovation partnerships supported under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa5b594c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regional Outreach Centers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa5b594d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director may establish and maintain regional offices of the Unit at locations within and outside the United States for purposes of conducting outreach to and streamlining interactions between the Unit and the private sector, academia, and other mission partners.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b594e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection criteria and other guidance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the event the Director exercises the authority to establish and maintain regional offices under paragraph (1), the Director shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa5b594f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a strategy and criteria for the selection of locations for such offices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa5b5950-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue any rules, regulations, policies, or guidance necessary for the operation of such offices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa5b5951-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the information described in subparagraphs (A) and (B) available on a publicly accessible website of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa5b5952-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa5b5953-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “multi-stakeholder research and innovation partnership” means a partnership composed of any combination of two or more of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa5b5954-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Universities, colleges, or other institutions of higher education with research and innovation capability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa5b5955-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Non-profit organizations that provide policy, research, outreach, operations, organizational, management, testing, evaluation, technology transfer, legal, financial, or advocacy expertise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa5b5956-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For-profit commercial enterprises that may be publicly or privately owned, early stage or mature, and incorporated or operating by another ownership structure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa5b5957-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/g/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Departments or agencies of the Federal Government with expertise, operations, or resources related to the objectives of the multi-stakeholder research and innovation partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b5958-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “nontraditional capability” means a solution to an operational challenge that can significantly leverage commercial innovation or external capital with minimal dependencies on fielded systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b5959-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4127/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “nontraditional defense contractor” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3014"},"text":"section 3014 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa5b595a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tIX/s913/a/1"},"text":"Pub. L. 118–31, div. A, title IX, § 913(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/365"},"text":"137 Stat. 365","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVII/s1701/a/43"},"text":"Pub. L. 118–159, div. A, title XVII, § 1701(a)(43)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2206"},"text":"138 Stat. 2206","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tIX/s913"},"text":"Pub. L. 119–60, div. A, title IX, § 913","children":[],"tail":", title XVII, § 1701(a)(26), "},{"t