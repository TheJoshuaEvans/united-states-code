{"tag":"section","attrib":{"id":"ida82d5535-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s919b"},"text":null,"children":[{"tag":"num","attrib":{"value":"919b"},"text":"§ 919b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 119b. Child endangerment","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82d5536-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s919b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has a duty for the care of a child under the age of 16 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82d5537-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s919b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, through design or culpable negligence, endangers the child’s mental or physical health, safety, or welfare;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as a court-martial may direct.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida82d5538-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLX/s5429"},"text":"Pub. L. 114–328, div. E, title LX, § 5429","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2949"},"text":"130 Stat. 2949","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida82d5539-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida82d553a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"c