{"tag":"section","attrib":{"id":"idab1ecffc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8332"},"text":null,"children":[{"tag":"num","attrib":{"value":"8332"},"text":"§ 8332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conclusiveness of transfers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"When a member of the naval service is transferred by the Secretary of the Navy—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab1ecffd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8332/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Fleet Reserve;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1ecffe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8332/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Fleet Marine Corps Reserve;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1ecfff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8332/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the Fleet Reserve to the retired list of the Regular Navy or the Retired Reserve; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1ed000-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8332/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the Fleet Marine Corps Reserve to the retired list of the Regular Marine Corps or the Retired Reserve;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the transfer is conclusive for all purposes. Each member so transferred is entitled, when not on active duty, to retainer pay or retired pay from the date of transfer in accordance with his grade and number of years of creditable service as determined by the Secretary. The Secretary may correct any error or omission in his determination as to a member’s grade and years of creditable service. When such a correction is made, the member is entitled, when not on active duty, to retainer pay or retired pay in accordance with his grade and number of years of creditable service, as corrected, from the date of transfer.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab1ed001-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/397"},"text":"70A Stat. 397","children":[],"tail":", § 6332; "},{"tag":"ref","attrib":{"href":"/us/pl/85/583/s1/7"},"text":"Pub. L. 85–583, § 1(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-01"},"text":"Aug. 1, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/480"},"text":"72 Stat. 480","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s33/a/33"},"text":"Pub. L. 85–861, § 33(a)(33)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1566"},"text":"72 Stat. 1566","children":[],"tail":"; renumbered § 8332, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/15"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab1ed002-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab1ed003-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab1ed004-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6332","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s854a"},"text":"34 U.S.C. 854a","children":[],"tail":" (provisos)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1938-06-25/ch690/s202"},"text":"June 25, 1938, ch. 690, § 202","children":[],"tail":" (provisos), "},{"tag":"html:a","attrib":{"href":"/us/stat/52/1178"},"text":"52 Stat. 1178","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s854"},"text":"34 U.S.C. 854","children":[],"tail":" (note)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608/s803"},"text":"July 9, 1952, ch. 608, § 803","children":[],"tail":" (3d sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/66/505"},"text":"66 Stat. 505","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “when not on active duty, to retainer pay or retired pay” are substituted for the words “pay and allowances”. The pay and allowances of a member on active duty are covered by the Career Compensation Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s231"},"text":"37 U.S.C. 231","children":[],"tail":" et seq.). When not on active duty a member of the Fleet Reserve receives retainer pay and a retired member receives retired pay without allowances, the provision for allowances for retired members having been repealed as pointed out in the note on the preceding section. In the last sentence the words “from the date of transfer” are added to make it clear that a correction is retroactive to that date. The Court of Claims has so held ("},{"tag":"i","attrib":{},"text":"Dugan v. United States","children":[],"tail":" (1943), 100 Ct. Cl. 7)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab1ed005-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab1ed006-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6332"},"text":"section 6332 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":" substituted “to retainer pay or retired pay in accordance” for “to retain pay or retired pay in accordance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/583"},"text":"Pub. L. 85–583","children":[],"tail":" inserted “or the Retired Reserve” after “Navy” in cl. (3) and after “Marine Corps” in cl. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab1ed007-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":nul