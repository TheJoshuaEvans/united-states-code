{"tag":"section","attrib":{"id":"idaac69e79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6233"},"text":null,"children":[{"tag":"num","attrib":{"value":"6233"},"text":"§ 6233.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement to plan for declassification of restricted data and formerly restricted data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaac69e7a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6233/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supplement to Plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy and the Archivist of the United States shall, after consultation with the members of the National Security Council and in consultation with the Secretary of Defense and the heads of other appropriate Federal agencies, develop a supplement to the plan required under subsection (a) of section 6232.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac69e7b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6233/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of Supplement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The supplement shall provide for the application of that plan (including in particular the element of the plan required by section 6232(b)(1)) to all records subject to Executive Order No. 12958 that were determined before ","children":[{"tag":"date","attrib":{"date":"1998-10-17"},"text":"October 17, 1998","children":[],"tail":", to be suitable for declassification."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac69e7c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6233/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Declassification of Records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All records referred to in subsection (b) shall be treated, for purposes of subsection (c) of section 6232, in the same manner as records referred to in subsection (a) of such section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac69e7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6233/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of Supplement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy shall submit the supplement required under subsection (a) to the recipients of the plan referred to in subsection (d) of section 6232.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac69e7e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1411"},"text":"139 Stat. 1411","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac69e7f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac69e80-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaac69e81-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order No. 12958, referred to in subsec. (b), is Ex. Ord. No. 12958, ","children":[{"tag":"date","attrib":{"date":"1995-04-17"},"text":"Apr. 17, 1995","children":[],"tail":", 60 F.R. 19825, which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"section 3161 of Title 50","children":[],"tail":", War and National Defense, and was revoked by Ex. Ord. No. 13526, § 6.2(g), "},{"tag":"date","attrib":{"date":"2009-12-29"},"text":"Dec. 29, 2009","children":[],"tail":", 75 F.R. 731."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac69e82-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2673"},"text":"section 2673 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
