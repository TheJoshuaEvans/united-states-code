{"tag":"section","attrib":{"id":"idab4c221f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8776"},"text":null,"children":[{"tag":"num","attrib":{"value":"8776"},"text":"§ 8776.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarters: extension telephones","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab4c2220-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8776/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under regulations prescribed by the Secretary of the Navy appropriated funds may be used to pay the cost of installation and use, other than for personal long distance calls, of extension telephones connecting public quarters occupied by personnel in the following categories with the switchboards of their official stations:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab4c2221-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8776/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the naval service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4c2222-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8776/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Coast Guard when it is operating as a service in the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4c2223-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8776/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the National Oceanic and Atmospheric Administration serving with the Navy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab4c2224-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8776/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, to the extent he considers proper, may delegate the authority conferred by this section, except the authority to prescribe regulations, to any person in the Department of the Navy, with or without the authority to make successive redelegations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab4c2225-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/469"},"text":"70A Stat. 469","children":[],"tail":", § 7576; "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s8/a"},"text":"Pub. L. 89–718, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1117"},"text":"80 Stat. 1117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s513/41"},"text":"Pub. L. 96–513, title V, § 513(41)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2935"},"text":"94 Stat. 2935","children":[],"tail":"; renumbered § 8776, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/9"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab4c2226-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children"