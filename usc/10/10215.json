{"tag":"section","attrib":{"id":"idab8c8733-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10215"},"text":null,"children":[{"tag":"num","attrib":{"value":"10215"},"text":"§ 10215.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers of Army National Guard of the United States and Air National Guard of the United States: authority with respect to Federal status","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab8c8734-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10215/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8c8735-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10215/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Officers of the Army National Guard of the United States who are not on active duty—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab8c8736-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10215/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may order members of the Army National Guard of the United States to active duty for training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12301/d"},"text":"section 12301(d) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8c8737-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10215/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the approval of the Secretary of the Air Force, may order members of the Air National Guard of the United States to active duty for training under that section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c8738-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10215/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Officers of the Air National Guard of the United States who are not on active duty—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab8c8739-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10215/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may order members of the Air National Guard of the United States to active duty for training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12301/d"},"text":"section 12301(d) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8c873a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10215/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the approval of the Secretary of the Army, may order members of the Army National Guard of the United States to active duty for training under that section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c873b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10215/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Officers of the Army National Guard of the United States or the Air National Guard of the United States who are not on active duty—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8c873c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10215/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enlist, reenlist, or extend the enlistments of persons as Reserves of the Army or Reserves of the Air Force for service in the Army National Guard of the United States or the Air National Guard of the United States, as the case may be; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c873d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10215/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to their Federal status, may promote or discharge persons enlisted or reenlisted as Reserves of the Army or Reserves of the Air Force for that service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c873e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10215/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall be carried out under regulations prescribed by the Secretary of the Army, with respect to matters concerning the Army, and by the Secretary of the Air Force, with respect to matters concerning the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab8c873f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1661/a/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1661(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2979"},"text":"108 Stat. 2979","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab8c8740-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab8c8741-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab8c8742-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 3080 and 8080 of this title, prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1661/a/3/A"},"text":"Pub. L. 103–337, § 1661(a)(3)(A)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab8c8743-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idab8c8744-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691"},"text":"section 1691 of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
