{"tag":"section","attrib":{"id":"idab8c86ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10203"},"text":null,"children":[{"tag":"num","attrib":{"value":"10203"},"text":"§ 10203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve affairs: designation of general or flag officer of each armed force","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab8c86ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army may designate a general officer of the Army to be directly responsible for reserve affairs to the Chief of Staff of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c86ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy may designate a flag officer of the Navy to be directly responsible for reserve affairs to the Chief of Naval Operations and a general officer of the Marine Corps to be directly responsible for reserve affairs to the Commandant of the Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c86af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10203/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Air Force may designate a general officer of the Air Force to be directly responsible for reserve affairs to the Chief of Staff of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c86b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10203/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Homeland Security may designate a flag officer of the Coast Guard to be directly responsible for reserve affairs to the Commandant of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c86b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10203/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not affect the functions of the Chief of the National Guard Bureau, the Chief of Army Reserve, or the Chief of Air Force Reserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab8c86b2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1661/a/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1661(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2976"},"text":"108 Stat. 2976","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/b/1"},"text":"Pub. L. 107–296, title XVII, § 1704(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab8c86b3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab8c86b4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorP