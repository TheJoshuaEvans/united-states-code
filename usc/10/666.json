{"tag":"section","attrib":{"id":"ida7fb48b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s666"},"text":null,"children":[{"tag":"num","attrib":{"value":"666"},"text":"§ 666.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve officers not on the active-duty list","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense shall establish personnel policies emphasizing education and experience in joint matters for reserve officers not on the active-duty list. Such policies shall, to the extent practicable for the reserve components, be similar to the policies provided by this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida7fb48b8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tIV/s401/a"},"text":"Pub. L. 99–433, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1028"},"text":"100 Stat. 1028","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7fb48b9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7fb48ba-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7fb48bb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transition to Joint Officer Personnel Policy","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Personnel policies under this section to be established not later than the end of the eight-month period beginning ","children":[{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/433/s406/c"},"text":"section 406(c) of Pub. L. 99–433","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s661"},"text":"section 661 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
