 "},{"tag":"html:a","attrib":{"href":"/us/act/1920-06-04/ch228/s8"},"text":"June 4, 1920, ch. 228, § 8","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/41/836"},"text":"41 Stat. 836","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1951-09-15/ch402"},"text":"Sept. 15, 1951, ch. 402","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/65/323"},"text":"65 Stat. 323","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1953-07-06/ch180/s1"},"text":"July 6, 1953, ch. 180, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/140"},"text":"67 Stat. 140","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “mark” is omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “persons discharged honorably or under honorable conditions from” are substituted for the words “entirely of honorably discharged officers or enlisted men, or both, of”. The words “Regular or Volunteer” are omitted as surplusage. The words “when authorized by regulations prescribed by” are substituted for the words “upon occasions authorized by regulations of”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida807304f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8073050-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Marine Corps, or Space Force” for “or Marine Corps” in subsec. (a) wherever appearing and in subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/355"},"text":"Pub. L. 85–355","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
