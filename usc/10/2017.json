{"tag":"section","attrib":{"id":"ida922fff2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2017"},"text":null,"children":[{"tag":"num","attrib":{"value":"2017"},"text":"§ 2017.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on establishment of postsecondary educational institutions pending notice to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida922fff3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2017/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may not establish a postsecondary educational institution within the Department of Defense until a period of one year has elapsed following the date on which the Secretary notifies the congressional defense committees of the intent of the Secretary to establish the institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida922fff4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2017/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Postsecondary Educational Institution Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “postsecondary educational institution” means a school or other educational institution that is intended to provide students with a course of instruction that is comparable, in length and academic rigor, to a course of instruction for which an associate’s, bachelor’s, or graduate degree may be awarded.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida922fff5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tV/s553/b/1"},"text":"Pub. L. 116–92, div. A, title V, § 553(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1387"},"text":"133 Stat. 1387","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida922fff6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida922fff7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida922fff8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tV/s553/b/3"},"text":"Pub. L. 116–92, div. A, title V, § 553(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1387"},"text":"133 Stat. 1387","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dA/tV/s553/b/3"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2017"},"text":"Section 2017 of title 10","children":[],"tail":", United States Code, as added by paragraph (1), shall apply with respect to postsecondary educational institutions intended to be established by the Secretary of Defense on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
