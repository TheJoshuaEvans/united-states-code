{"tag":"section","attrib":{"id":"ida7d76cf3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s515"},"text":null,"children":[{"tag":"num","attrib":{"value":"515"},"text":"§ 515.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reenlistment after discharge as warrant officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A person who has been discharged from a regular component of an armed force under section 1165 or 1166 of this title may, upon his request and in the discretion of the Secretary concerned, be enlisted in that armed force in the grade prescribed by the Secretary. However, a person discharged under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1165"},"text":"section 1165 of this title","children":[],"tail":" may not be enlisted in a grade lower than the grade that he held immediately before appointment as a warrant officer."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida7d76cf4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/19"},"text":"70A Stat. 19","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7d76cf5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida7d76cf6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida7d76cf7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children