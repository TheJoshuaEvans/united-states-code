{"tag":"section","attrib":{"id":"idab369e9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8634"},"text":null,"children":[{"tag":"num","attrib":{"value":"8634"},"text":"§ 8634.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submarine safety programs: participation of NATO naval personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab369e9e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8634/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance of Assignment of Foreign Naval Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In order to facilitate the development, standardization, and interoperability of submarine vessel safety and rescue systems and procedures, the Secretary of the Navy may conduct a program beginning on or after the date of the enactment of the National Defense Authorization Act for Fiscal Year 2024 under which members of the naval service of any of the member nations of the North Atlantic Treaty Organization may be assigned to United States commands to work on such systems and procedures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab369e9f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8634/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reciprocity Not Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority under subsection (a) is not an exchange program. Reciprocal assignments of members of the Navy to the naval service of a foreign country is not a condition for the exercise of such authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab369ea0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8634/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Costs for Foreign Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab369ea1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8634/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The United States may not pay the following costs for a member of a foreign naval service sent to the United States under the program authorized by this section:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab369ea2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8634/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Salary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab369ea3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8634/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Per diem.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab369ea4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8634/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cost of living.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab369ea5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8634/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Travel costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab369ea6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8634/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cost of language or other training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab369ea7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8634/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369ea8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8634/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) does not apply to the following costs, which may be paid by the United States:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab369ea9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8634/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cost of temporary duty directed by the Secretary of the Navy or an officer of the Navy authorized to do so.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab369eaa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8634/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cost of training programs conducted to familiarize, orient, or certify members of foreign naval services regarding unique aspects of their assignments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab369eab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8634/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs incident to the use of the facilities of the Navy in the performance of assigned duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab369eac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8634/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provisions of this section shall apply in the exercise of any authority of the Secretary of the Navy to enter into an agreement with the government of a foreign country, subject to the concurrence of the Secretary of State, to provide for the assignment of members of the naval service of the foreign country to a Navy submarine safety program. The Secretary of the Navy may prescribe regulations for the application of this section in the exercise of such authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab369ead-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tXII/s1223/a"},"text":"Pub. L. 108–375, div. A, title XII, § 1223(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2089"},"text":"118 Stat. 2089","children":[],"tail":", § 7234; renumbered § 8634, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXII/s1248"},"text":"Pub. L. 118–31, div. A, title XII, § 1248","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/464"},"text":"137 Stat. 464","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab369eae-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab369eaf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idab369eb0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the National Defense Authorization Act for Fiscal Year 2024, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab369eb1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8634, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/532"},"text":"70A Stat. 532","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tIII/s327/c"},"text":"Pub. L. 101–510, div. A, title III, § 327(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1532"},"text":"104 Stat. 1532","children":[],"tail":", generally prohibited Air Force band from being paid for performance outside air base, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tV/s590/b/1"},"text":"Pub. L. 110–181, div. A, title V, § 590(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/138"},"text":"122 Stat. 138","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s974"},"text":"section 974 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab369eb2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1248/b"},"text":"Pub. L. 118–31, § 1248(b)","children":[],"tail":", substituted “the Secretary of the Navy may conduct a program beginning on or after the date of the enactment of the National Defense Authorization Act for Fiscal Year 2024” for “the Secretary of the Navy may conduct a program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1248/a"},"text":"Pub. L. 118–31, § 1248(a)","children":[],"tail":", struck out subsec. (e). Text read as follows: “The Secretary of the Navy may not accept the assignment of a member of the naval service of a foreign country under this section after "},{"tag":"date","attrib":{"date":"2008-09-30"},"text":"September 30, 2008","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p",