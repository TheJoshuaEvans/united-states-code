{"tag":"section","attrib":{"id":"idaa2e074d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3673"},"text":null,"children":[{"tag":"num","attrib":{"value":"3673"},"text":"§ 3673.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on indemnification","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Funds appropriated to the Department of Defense may not be used to indemnify any person under the terms of a contract entered into under this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa2e074e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3673/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any amount paid or due by any person to the United States for any liability arising under the Internal Revenue Code of 1986; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa2e074f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3673/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay any attorneys’ fees in connection with such contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa2e0750-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1825/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1825(a)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4206"},"text":"134 Stat. 4206","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa2e0751-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa2e0752-3a6f-11f1-a58