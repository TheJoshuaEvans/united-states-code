"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1837(a) (as applicable to medical service officers).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8067(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1837(a) (as applicable to nurses).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8067(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1837(a) (as applicable to women medical specialists).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8067(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1837(a) (as applicable to judge advocates).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8067(h)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1837(a) (as applicable to chaplains).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8067(i)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1837(a) (less categories covered by subsections (a)–(h)).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1837(b), (c).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:81–2 (less 1st and last provisos).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The references in clauses (4), (6), and (7) of 10:1837(a) are omitted, since the laws to which reference is made deal with qualifications for appointment as commissioned officers and do not specify professional qualifications prerequisite to designation to duties requiring special training or experience. The reference in clause (8) is omitted as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"10:1837(b) and (c) are omitted, since, except in the case of a reference to a law not presently in effect, their substance is covered by including the laws referred to in various revised sections of this title (see the distribution tables). 10:81–2 (less 1st and last provisos) is omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a)–(d), (g), and (h), the words “commissioned officers” are substituted for the word “members”, in 10:1837(a), since, under the laws to which reference is made, only commissioned officers may be designated to perform these functions.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (e) and (f), the words “female commissioned officers” are substituted for the word “members”, in 10:1837(a), since, under the laws to which reference is made, only female commissioned officers may be designated to perform these functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab61a597-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab61a598-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1958 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (