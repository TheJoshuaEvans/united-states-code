{"tag":"section","attrib":{"id":"idab61a589-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9063"},"text":null,"children":[{"tag":"num","attrib":{"value":"9063"},"text":"§ 9063.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation: officers to perform certain professional functions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab61a58a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9063/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Medical functions in the Air Force and the Space Force shall be performed by commissioned officers of the Air Force who are qualified under regulations prescribed by the Secretary of the Air Force and who are designated as medical officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab61a58b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9063/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Dental functions in the Air Force and the Space Force shall be performed by commissioned officers of the Air Force who are qualified under regulations prescribed by the Secretary and who are designated as dental officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab61a58c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9063/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Veterinary functions in the Air Force and the Space Force shall be performed by commissioned officers of the Air Force who are qualified under regulations prescribed by the Secretary, and who are designated as veterinary officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab61a58d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9063/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Medical service functions in the Air Force and the Space Force shall be performed by commissioned officers of the Air Force who are qualified under regulations prescribed by the Secretary, and who are designated as medical service officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab61a58e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9063/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nursing functions in the Air Force and the Space Force shall be performed by commissioned officers of the Air Force who are qualified under regulations prescribed by the Secretary and who are designated as Air Force nurses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab61a58f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9063/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Biomedical science functions, including physician assistant functions and chiropractic functions, in the Air Force and the Space Force shall be performed by commissioned officers of the Air Force who are qualified under regulations prescribed by the Secretary, and who are designated as biomedical science officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab61a590-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9063/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Judge advocate functions in the Air Force and the Space Force shall be performed by commissioned officers of the Air Force who are qualified under regulations prescribed by the Secretary, and who are designated as judge advocates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab61a591-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9063/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chaplain functions in the Air Force and the Space Force shall be performed by commissioned officers of the Air Force who are qualified under regulations prescribed by the Secretary and who are designated as chaplains.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab61a592-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9063/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other functions in the Air Force and the Space Force requiring special training or experience shall be performed by members of the Air Force or the Space Force who are qualified under regulations prescribed by the Secretary, and who are designated as being in named categories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab61a593-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/494"},"text":"70A Stat. 494","children":[],"tail":", § 8067; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/156"},"text":"Pub. L. 85–861, § 1(156)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1513"},"text":"72 Stat. 1513","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s504/5"},"text":"Pub. L. 96–513, title V, § 504(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12