{"tag":"section","attrib":{"id":"idabb9d86e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15107"},"text":null,"children":[{"tag":"num","attrib":{"value":"15107"},"text":"§ 15107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement: retirement for years of service; selective early retirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabb9d86f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retirement for Years of Service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sections 14507 through 14515 of this title shall apply to the retirement of officers in competitive categories of officers designated for purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb9d870-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selective Early Retirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14101/b"},"text":"Section 14101(b) of this title","children":[],"tail":" shall apply to the retirement of officers described in subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabb9d871-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tV/s514/a"},"text":"Pub. L. 118–31, div. A, title V, § 514(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/2