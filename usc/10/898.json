{"tag":"section","attrib":{"id":"ida82ae49e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s898"},"text":null,"children":[{"tag":"num","attrib":{"value":"898"},"text":"§ 898.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 98. Misconduct as prisoner","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter who, while in the hands of the enemy in time of war—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82ae49f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s898/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purpose of securing favorable treatment by his captors acts without proper authority in a manner contrary to law, custom, or regulation, to the detriment of others of whatever nationality held by the enemy as civilian or military prisoners; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82ae4a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s898/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while in a position of authority over such persons maltreats them without justifiable cause;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as a court-martial may direct.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida82ae4a1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/71"},"text":"70A Stat. 71","children":[],"tail":", § 905; renumbered § 898, "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLX/s5401/6"},"text":"Pub. L. 114–328, div. E, title LX, § 5401(6)","children":[],"tail":", "},{"ta