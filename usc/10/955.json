{"tag":"section","attrib":{"id":"ida83df758-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s955"},"text":null,"children":[{"tag":"num","attrib":{"value":"955"},"text":"§ 955.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prisoners transferred to or from foreign countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida83df759-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s955/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When a treaty is in effect between the United States and a foreign country providing for the transfer of convicted offenders, the Secretary concerned may, with the concurrence of the Attorney General, transfer to such foreign country any offender against chapter 47 of this title. Such transfer shall be effected subject to the terms of such treaty and chapter 306 of title 18.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida83df75a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s955/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever the United States is party to an agreement on the status of forces under which the United States may request that it take custody of a prisoner belonging to its armed forces who is confined by order of a foreign court, the Secretary concerned may provide for the carrying out of the terms of such confinement in a military correctional facility of his department or in any penal or correctional institution under the control of the United States or which the United States may be allowed to use. Except as otherwise specified in such agreement, such person shall be treated as if he were an offender against chapter 47 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida83df75b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/144/s4"},"text":"Pub. L. 95–144, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-28"},"text":"Oct. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1221"},"text":"91 Stat. 1221","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s511/28"},"text":"Pub. L. 96–513, title V, § 511(28)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2922"},"text":"94 Stat. 2922","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida83df75c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida83df75d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida83df75e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “such” for “said” in two places, “Such” for “Said”, and struck out “, United States Code” after “18”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida83df75f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida83df760-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/b/3"},"text":"section 701(b)(3) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
