{"tag":"section","attrib":{"id":"ida7b62a1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s405"},"text":null,"children":[{"tag":"num","attrib":{"value":"405"},"text":"§ 405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Department of Defense funds for United States share of costs of United Nations peacekeeping activities: limitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7b62a1d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s405/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds available to the Department of Defense may not be used to make a financial contribution (directly or through another department or agency of the United States) to the United Nations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7b62a1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s405/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the costs of a United Nations peacekeeping activity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b62a1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s405/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any United States arrearage to the United Nations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b62a20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s405/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The prohibition in subsection (a) applies to voluntary contributions, as well as to contributions pursuant to assessment by the United Nations for the United States share of the costs of a peacekeeping activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7b62a21-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXIII/s1301/a"},"text":"Pub. L. 104–106, div. A, title XIII, § 1301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/473"},"text":"110 Stat. 473","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7b62a22-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7b62a23-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida7b62a24-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 405 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s401/e"},"text":"section 401(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7b62a25-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7b62a26-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Use of Department of Defense Funds for United Nations Forces","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tXII/s1231/b"},"text":"Pub. L. 105–261, div. A, title XII, § 1231(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2155"},"text":"112 Stat. 2155","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/261/dA/tXII/s1231/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“No funds available to the Department of Defense may be used—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a monetary contribution to the United Nations for the establishment of a standing international force under the United Nations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assign or detail any member of the Armed Forces to duty with a United Nations Stand By Force.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
