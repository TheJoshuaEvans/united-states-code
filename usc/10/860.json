{"tag":"section","attrib":{"id":"ida8216e98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860"},"text":null,"children":[{"tag":"num","attrib":{"value":"860"},"text":"§ 860.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 60. Post-trial processing in general and special courts-martial","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8216e99-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statement of Trial Results","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8216e9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The military judge of a general or special court-martial shall enter into the record of trial a document entitled “Statement of Trial Results”, which shall set forth—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8216e9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each plea and finding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8216e9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sentence, if any; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8216e9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the President may prescribe by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8216e9e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Copies of the Statement of Trial Results shall be provided promptly to the convening authority, the accused, and any victim of the offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8216e9f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Post-trial Motions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with regulations prescribed by the President, the military judge in a general or special court-martial shall address all post-trial motions and other post-trial matters that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8216ea0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may affect a plea, a finding, the sentence, the Statement of Trial Results, the record of trial, or any post-trial action by the convening authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8216ea1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are subject to resolution by the military judge before entry of judgment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8216ea2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/57"},"text":"70A Stat. 57","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/209/s5/a/1"},"text":"Pub. L. 98–209, § 5(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-06"},"text":"Dec. 6, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1395"},"text":"97 Stat. 1395","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tVIII/s806/a"},"text":"Pub. L. 99–661, div. A, title VIII, § 806(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3908"},"text":"100 Stat. 3908","children":[],"tail":", 3909; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXI/s1132"},"text":"Pub. L. 104–106, div. A, title XI, § 1132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/464"},"text":"110 Stat. 464","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tXVII"},"text":"Pub. L. 113–66, div. A, title XVII","children":[],"tail":", §§ 1702(b), (c)(1), 1706, "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/955-957"},"text":"127 Stat. 955–957","children":[],"tail":", 960; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tV/s531/a/1"},"text":"Pub. L. 113–291, div. A, title V, § 531(a)(1)","children":[],"tail":"–(3), (5), "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3362"},"text":"128 Stat. 3362","children":[],"tail":", 3363; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLIX/s5321"},"text":"Pub. L. 114–328, div. E, title LIX, § 5321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2924"},"text":"130 Stat. 2924","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8216ea3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8216ea4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida8216ea5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"860","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:647.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-05-05/ch169/s1"},"text":"May 5, 1950, ch. 169, § 1","children":[],"tail":" (Art. 60), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/127"},"text":"64 Stat. 127","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “a” is substituted for the word “every”. The word “by” before the words “any officer” is omitted as surplusage. The word “person” is substituted for the word “officer” before the words “who convened”, since, under sections 823 and 824 of this title (articles 23 and 24), noncommissioned officers who are “officers in charge” may convene special and summary courts-martial.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8216ea6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8216ea7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" amended section generally. Prior to amendment, section related to action by the convening authority."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s531/a/1/A"},"text":"Pub. L. 113–291, § 531(a)(1)(A)","children":[],"tail":", inserted “and may be taken only with respect to a qualifying offense” after “is not required”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s531/a/1/B"},"text":"Pub. L. 113–291, § 531(a)(1)(B)","children":[],"tail":", struck out “, other than a charge or specification for a qualifying offense,” after “specification” and inserted “, but may take such action with respect to a qualifying offense” before semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s531/a/1/C"},"text":"Pub. L. 113–291, § 531(a)(1)(C)","children":[],"tail":", struck out “, other than a charge or specification for a qualifying offense,” after “to a charge or specification” and inserted “, but may take such action with respect to a qualifying offense” before period."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s531/a/2"},"text":"Pub. L. 113–291, § 531(a)(2)","children":[],"tail":", struck out “(other than a qualifying offense)” after “offense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s531/a/5"},"text":"Pub. L. 113–291, § 531(a)(5)","children":[],"tail":", inserted “pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s856/b"},"text":"section 856(b) of this title","children":[],"tail":" (article 56(b))” after “applies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s531/a/3/A/i"},"text":"Pub. L. 113–291, § 531(a)(3)(A)(i)","children":[],"tail":", inserted “, if applicable” before semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s531/a/3/A/ii"},"text":"Pub. L. 113–291, § 531(a)(3)(A)(ii)","children":[],"tail":", struck out “if applicable,” before “the date”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s531/a/3/B"},"text":"Pub. L. 113–291, § 531(a)(3)(B)","children":[],"tail":", substituted “harm” for “loss”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1706/c"},"text":"Pub. L. 113–66, § 1706(c)","children":[],"tail":", substituted “subsection (e)” for “subsection (d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1702/c/1/A"},"text":"Pub. L. 113–66, § 1702(c)(1)(A)","children":[],"tail":", substituted “or another person authorized to act under this section” for “or other person taking action under this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1706/b"},"text":"Pub. L. 113–66, § 1706(b)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1702/b"},"text":"Pub. L. 113–66, § 1702(b)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, text related to the command prerogative of the convening authority to modify the findings and sentence of a court-martial."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1706/a/2"},"text":"Pub. L. 113–66, § 1706(a)(2)","children":[],"tail":", added subsec. (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1702/c/1/B"},"text":"Pub. L. 113–66, § 1702(c)(1)(B)","children":[],"tail":", substituted “or another person authorized to act under this section” for “or other person taking action under this section” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1706/a/1"},"text":"Pub. L. 113–66, § 1706(a)(1)","children":[],"tail":", redesignated subsec. (d) as (e). Former subsec. (e) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1702/c/1/C"},"text":"Pub. L. 113–66, § 1702(c)(1)(C)","children":[],"tail":", substituted “or another person authorized to act under this section” for “or other person taking action under this section, in his sole discretion,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1702/c/1/D"},"text":"Pub. L. 113–66, § 1702(c)(1)(D)","children":[],"tail":", substituted “or another person authorized to act under this section” for “or other person taking action under this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1706/a/1"},"text":"Pub. L. 113–66, § 1706(a)(1)","children":[],"tail":", redesignated subsec. (e) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" inserted after first sentence “Any such submission shall be in writing.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/s806/a/3"},"text":"Pub. L. 99–661, § 806(a)(3)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “Within 30 days after the sentence of a general court-martial or of a special court-martial which has adjudged a bad-conduct discharge has been announced, the accused may submit to the convening authority matters for consideration by the convening authority with respect to the findings and the sentence. In the case of all other special courts-martial, the accused may make such a submission to the convening authority within 20 days after the sentence is announced. In the case of all summary courts-martial the accused may make such a submission to the convening authority within seven days after the sentence is announced. If the accused shows that additional time is required for the accused to submit such matters, the convening authority or other person taking action under this section, for good cause, may extend the period—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) in the case of a general court-martial or a special court-martial which has adjudged a bad-conduct discharge, for not more than an additional 20 days; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) in the case of all other courts-martial, for not more than an additional 10 days.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/s806/a/2"},"text":"Pub. L. 99–661, § 806(a)(2)","children":[],"tail":", (3), added par. (2). Former par. (2) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/s806/a/1"},"text":"Pub. L. 99–661, § 806(a)(1)","children":[],"tail":", (2), redesignated par. (2) as (3), inserted a comma after “case”, and struck out former par. (3) which read as follows: “In no event shall the accused in any general or special court-martial case have less than a seven-day period after the day on which a copy of the authenticated record of trial has been given to him within which to make a submission under paragraph (1). The convening authority or other person taking action on the case, for good cause, may extend this period for up to an additional 10 days.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/s806/b"},"text":"Pub. L. 99–661, § 806(b)","children":[],"tail":", struck out “and, if applicable, under subsection (d),” after “under subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/s806/c"},"text":"Pub. L. 99–661, § 806(c)","children":[],"tail":", substituted “who may submit any matter in response under subsection (b)” for “who shall have five days from the date of receipt in which to submit any matter in response. The convening authority or other person taking action under this section, for good cause, may extend that period for up to an additional 20 days.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/209"},"text":"Pub. L. 98–209","children":[],"tail":" amended section generally, substituting “Action by the convening authority” for “Initial action on the record” as section catchline, and, in text, substituting new provision for provision that after a trial by court-martial the record had to be forwarded to the convening authority, and action thereon could be taken by the person who convened the court, a commissioned officer commanding for the time being, a successor in command, or any officer exercising general court-martial jurisdiction."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8216ea8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8216ea9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. No. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8216eaa-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tXVII/s1702/d/2"},"text":"Pub. L. 113–66, div. A, title XVII, § 1702(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/958"},"text":"127 Stat. 958","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tV/s531/g/2/A"},"text":"Pub. L. 113–291, div. A, title V, § 531(g)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3365"},"text":"128 Stat. 3365","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/291/dA/tV/s531/g/2/A"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (B), the amendments made by subsection (b) and paragraphs (1) and (2) of subsection (c) [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s871"},"text":"section 871 of this title","children":[],"tail":"] shall take effect 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":"] and shall apply with respect to offenses committed under chapter 47 of title 10, United States Code (the Uniform Code of Military Justice), on or after that effective date."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to the findings and sentence of a court-martial that includes both a conviction for an offense committed before the effective date specified in subparagraph (A) and a conviction for an offense committed on or after that effective date, the convening authority shall have the same authority to take action on such findings and sentence as was in effect on the day before such effective date, except with respect to a mandatory minimum sentence under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s856/b"},"text":"section 856(b) of title 10","children":[],"tail":", United States Code (article 56(b) of the Uniform Code of Military Justice).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tV/s531/g/2/B"},"text":"Pub. L. 113–291, div. A, title V, § 531(g)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3366"},"text":"128 Stat. 3366","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/291/dA/tV/s531/g/2/B"},"text":"“The amendments made by subparagraph (A) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1702/d/2"},"text":"section 1702(d)(2) of Pub. L. 113–66","children":[],"tail":", set out above] shall not apply to the findings and sentence of a court-martial with respect to which the convening authority has taken action before the date that is 30 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":"].”"}],"tail":"\n]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8216eab-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tVIII/s806/c"},"text":"Pub. L. 99–661, div. A, title VIII, § 806(c)","children":[],"tail":" [(d)], "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3909"},"text":"100 Stat. 3909","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/661/dA/tVIII/s806/c"},"text":"“The amendments made by this section [amending this section] shall apply in cases in which the sentence is adjudged on or after the effective date of this title.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" effective the earlier of (1) the last day of the 120-day period beginning on "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":"; or (2) the date specified in an Executive order for such amendment to take effect, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/s808"},"text":"section 808 of Pub. L. 99–661","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s802"},"text":"section 802 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8216eac-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/209"},"text":"Pub. L. 98–209","children":[],"tail":" effective first day of eighth calendar month beginning after "},{"tag":"date","attrib":{"date":"1983-12-06"},"text":"Dec. 6, 1983","children":[],"tail":", but not to apply to any case in which the findings and sentence were adjudged by a court-martial before that date, and the proceedings in any such case to be held in the same manner and with the same effect as if such amendments had not been enacted, see section 12(a)(1), (4) of "},{"tag":"ref","attrib":{"href":"/us/pl/98/209"},"text":"Pub. L. 98–209","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
