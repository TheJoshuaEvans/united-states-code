{"tag":"section","attrib":{"id":"idaa353331-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750"},"text":null,"children":[{"tag":"num","attrib":{"value":"3750"},"text":"§ 3750.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proceeding costs not allowable","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa353332-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa353333-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Costs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “costs”, with respect to a proceeding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa353334-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means all costs incurred by a contractor or subcontractor, or personal services contractor, whether before or after the commencement of any such proceeding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa353335-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa353336-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative and clerical expenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa353337-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of legal services, including legal services performed by an employee of the contractor or subcontractor, or personal services contractor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa353338-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of the services of accountants and consultants retained by the contractor or subcontractor, or personal services contractor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa353339-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pay of directors, officers, and employees of the contractor or subcontractor, or personal services contractor for time devoted by such directors, officers, and employees to such proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa35333a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “penalty” does not include restitution, reimbursement, or compensatory damages.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa35333b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proceedings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “proceeding” includes an investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa35333c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this section, costs incurred by a contractor or subcontractor, or personal services contractor in connection with any criminal, civil, or administrative proceeding commenced by the United States, by a State, or by a contractor or subcontractor, or personal services contractor employee submitting a complaint under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4701"},"text":"section 4701 of this title","children":[],"tail":" are not allowable as reimbursable costs under a covered contract, subcontract, or personal services contract if the proceeding—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa35333d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relates to a violation of, or failure to comply with, a Federal or State statute or regulation or to any other activity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4701/a/1"},"text":"section 4701(a)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa35333e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results in a disposition described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa35333f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Dispositions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A disposition referred to in subsection (b)(2) is any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa353340-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a criminal proceeding, a conviction (including a conviction pursuant to a plea of nolo contendere) by reason of the violation or failure referred to in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa353341-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a civil or administrative proceeding involving an allegation of fraud or similar misconduct, a determination of contractor or subcontractor, or personal services contractor liability on the basis of the violation or failure referred to in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa353342-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of any civil or administrative proceeding, the imposition of a monetary penalty or an order to take corrective action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4701"},"text":"section 4701 of this title","children":[],"tail":" by reason of the violation or failure referred to in subsection (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa353343-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A final decision—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa353344-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to debar or suspend the contractor or subcontractor, or personal services contractor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa353345-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to rescind or void the contract, subcontract, or personal services contract; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa353346-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to terminate the contract, subcontract, or personal services contract for default;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"by reason of the violation or failure referred to in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa353347-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A disposition of the proceeding by consent or compromise if such action could have resulted in a disposition described in paragraphs (1), (2), (3), or (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa353348-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Costs Allowed by Settlement Agreement in Proceeding Commenced by United States","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a proceeding referred to in subsection (b) that is commenced by the United States and is resolved by consent or compromise pursuant to an agreement entered into by a contractor or subcontractor, or personal services contractor and the United States, the costs incurred by the contractor or subcontractor, or personal services contractor in connection with such proceeding that are otherwise not allowable as reimbursable costs under such subsection may be allowed to the extent specifically provided in such agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa353349-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Costs Specifically Authorized in Proceeding Commenced by State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a proceeding referred to in subsection (b) that is commenced by a State, the head of the agency or Secretary of the military department concerned that awarded the covered contract, subcontract, or personal services contract involved in the proceeding may allow the costs incurred by the contractor or subcontractor, or personal services contractor in connection with such proceeding as reimbursable costs if the agency head or Secretary determines, in accordance with the Federal Acquisition Regulation, that the costs were incurred as a result of (1) a specific term or condition of the contract, subcontract, or personal services contract, or (2) specific written instructions of the agency or military department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa35334a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Allowable Costs.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa35334b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (3), costs incurred by a contractor or subcontractor, or personal services contractor in connection with a criminal, civil, or administrative proceeding commenced by the United States or a State in connection with a covered contract, subcontract, or personal services contract may be allowed as reimbursable costs under the contract, subcontract, or personal services contract if such costs are not disallowable under subsection (b), but only to the extent provided in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa35334c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of Allowable Costs.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa35334d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum amount allowed","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of the costs allowable under paragraph (1) in any case may not exceed the amount equal to 80 percent of the amount of the costs incurred, to the extent that such costs are determined to be otherwise allowable and allocable under the Federal Acquisition Regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa35334e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content of regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Regulations issued for the purpose of subparagraph (A) shall provide for appropriate consideration of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa35334f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the complexity of procurement litigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa353350-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" generally accepted principles governing the award of legal fees in civil actions involving the United States as a party; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa353351-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/f/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other factors as may be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa353352-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When otherwise allowable costs are not allowable","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a proceeding referred to in paragraph (1), contractor or subcontractor, or personal services contractor costs otherwise allowable as reimbursable costs under this subsection are not allowable if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa353353-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such proceeding involves the same contractor or subcontractor, or personal services contractor misconduct alleged as the basis of another criminal, civil, or administrative proceeding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa353354-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3750/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of such other proceeding are not allowable under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa353355-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1832/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1832(a)","children":[],"tail":", (i), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4218"},"text":"134 Stat. 4218","children":[],"tail":", 4222; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/b/11"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(b)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2134"},"text":"135 Stat. 2134","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa353356-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa353357-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"t