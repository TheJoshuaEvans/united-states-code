{"tag":"section","attrib":{"id":"ida9eb3222-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872"},"text":null,"children":[{"tag":"num","attrib":{"value":"2872"},"text":"§ 2872.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In addition to any other authority provided under this chapter for the acquisition or construction of military family housing or military unaccompanied housing, the Secretary concerned may exercise any authority or any combination of authorities provided under this subchapter in order to provide for the acquisition or construction by eligible entities of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9eb3223-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Family housing units on or near military installations within the United States and its territories and possessions, including such units for civilian employees of the Department of Defense and defense contractors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eb3224-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Military unaccompanied housing units on or near such military installations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9eb3225-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dB/tXXVIII/s2801/a/1"},"text":"Pub. L. 104–106, div. B, title XXVIII, § 2801(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/545"},"text":"110 Stat. 545","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dB/tXXVIII/s2803/b"},"text":"Pub. L. 106–65, div. B, title XXVIII, § 2803(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/849"},"text":"113 Stat. 849","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dB/tXXVIII/s2821/b"},"text":"Pub. L. 119–60, div. B, title XXVIII, § 2821(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1304"},"text":"139 Stat. 1304","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9eb3226-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9eb3227-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9eb3228-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted inserted “, including such units for civilian employees of the Department of Defense and defense contractors” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “eligible entities” for “private persons” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
