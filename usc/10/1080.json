 § 734(a)(1)","children":[],"tail":", inserted “inpatient” before “medical care” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s734/c"},"text":"Pub. L. 104–201, § 734(c)","children":[],"tail":", substituted “Nonavailability-of-Health-Care Statements” for “Nonavailability of Health Care Statements” in heading and “nonavailability-of-health-care statement” for “nonavailability of health care statement” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s734/b/1"},"text":"Pub. L. 104–201, § 734(b)(1)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" substituted reference to administering Secretaries for reference to Secretary of Health and Human Services."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “Secretary of Health and Human Services” for “Secretary of Health, Education, and Welfare”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida88587ac-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida88587ad-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading",