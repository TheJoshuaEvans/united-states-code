{"tag":"section","attrib":{"id":"idab155a57-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8241"},"text":null,"children":[{"tag":"num","attrib":{"value":"8241"},"text":"§ 8241.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Navy ration: persons entitled to","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab155a58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8241/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each enlisted member of the naval service is entitled to a Navy ration for each day that he is on active duty, including each day that he is on leave.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab155a59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8241/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each midshipman is entitled to a Navy ration for each day that he is on active duty, including each day that he is on leave.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab155a5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8241/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy may prescribe regulations stating the conditions under which the ration shall be allowed under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab155a5b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/379"},"text":"70A Stat. 379","children":[],"tail":", § 6081; "},{"tag":"ref","attrib":{"href":"/us/pl/87/649/s5/c"},"text":"Pub. L. 87–649, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/494"},"text":"76 Stat. 494","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVI/s602/b/2"},"text":"Pub. L. 105–85, div. A, title VI, § 602(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1772"},"text":"111 Stat. 1772","children":[],"tail":"; renumbered § 8241, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/8"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1835"},"text":"132 Stat. 1835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab155a5c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab155a5d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab155a5e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6081","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s901a"},"text":"34 U.S.C. 901a","children":[],"tail":" (1st 2 sentences)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-08-02/ch756/s17/a"},"text":"Aug. 2, 1946, ch. 756, § 17(a)","children":[],"tail":" (1st 2 sentences), "},{"tag":"html:a","attrib":{"href":"/us/stat/60/855"},"text":"60 Stat. 855","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s421g"},"text":"5 U.S.C. 421g","children":[],"tail":" (b)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-08-02/ch756/s40/b"},"text":"Aug. 2, 1946, ch. 756, § 40(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/858"},"text":"60 Stat. 858","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"So much of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s901a"},"text":"34 U.S.C. 901a","children":[],"tail":" as authorizes a commuted ration for enlisted members of the naval service under conditions and at rates prescribed by the Secretary of the Navy is superseded by § 301 of the Career Compensation Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t37/s251"},"text":"37 U.S.C. 251","children":[],"tail":"). That section established a basic allowance for subsistence for enlisted members entitled to basic pay who are not subsisting at Government expense and prescribes the conditions under which the basic allowance for subsistence shall be paid and the amount of the allowance. Pursuant to Executive Order No. 10119, "},{"tag":"date","attrib":{"date":"1950-03-30"},"text":"March 30, 1950","children":[],"tail":", 15 F.R. 1757, the Secretary of Defense is authorized to make supplemental regulations to carry out the provisions of § 301. The words “or to a per diem in place of subsistence” are inserted to reflect the subsistence allowance authorized by § 303(a) of the Career Compensation Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t37/s253a"},"text":"37 U.S.C. 253a","children":[],"tail":") to members in travel status."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) reference to the Coast and Geodetic Survey is omitted since there are no enlisted personnel in that service, and reference to the Coast Guard is omitted as covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s478"},"text":"14 U.S.C. 478","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b) the words “or furlough therefrom” are omitted as surplusage, and the words “for each day” are inserted to make clear the fact that a ration is a daily allowance of food and that, in subsection (b), the commuted ration is credited on a daily basis. The words “and cadets” are omitted as there are no cadets in the Navy or Marine Corps entitled to a Navy ration. Aviation cadets are entitled to the basic allowance for subsistence prescribed for officers (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s850c"},"text":"34 U.S.C. 850c","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c) the words “prescribed by law” and “in accordance with law” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab155a5f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab155a60-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6081"},"text":"section 6081 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" substituted “Each enlisted member” for “Except when entitled to a basic allowance for subsistence or to a per diem in place of subsistence, each enlisted member”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":" struck out provisions which permitted payment of the commuted value of the ration in money. See "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s422/b"},"text":"section 422(b) of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":" struck out provisions which permitted the Secretary to prescribe regulations for the allowance of the commuted value of the ration. See "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s422/b"},"text":"section 422(b) of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab155a61-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab155a62-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab155a63-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-01-01"},"text":"Jan. 1, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/s602/g"},"text":"section 602(g) of Pub. L. 105–85","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s402"},"text":"section 402 of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab155a64-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1962 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1962-11-01"},"text":"Nov. 1, 1962","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/87/649/s15"},"text":"section 15 of Pub. L. 87–649","children":[],"tail":", set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s101"},"text":"section 101 of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
