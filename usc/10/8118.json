{"tag":"section","attrib":{"id":"idab10788a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8118"},"text":null,"children":[{"tag":"num","attrib":{"value":"8118"},"text":"§ 8118.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rank of line and staff corps officers of the Navy and officers of the Marine Corps","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except for an officer entitled to a rank higher than his grade, line and staff corps officers of the Navy serving in the same grade and officers of the Marine Corps serving in the corresponding grade rank among themselves according to their respective dates of rank in grade whether or not they are on an active-duty list.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab10788b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/317"},"text":"70A Stat. 317","children":[],"tail":", § 5508; "},{"tag":"ref","attrib":{"href":"/us/pl/90/179/s4"},"text":"Pub. L. 90–179, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-08"},"text":"Dec. 8, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/547"},"text":"81 Stat. 547","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s503/27"},"text":"Pub. L. 96–513, title V, § 503(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2913"},"text":"94 Stat. 2913","children":[],"tail":"; renumbered § 8118, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/2"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1834"},"text":"132 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab10788c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab10788d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab10788e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5508","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s306f/d/2"},"text":"34 U.S.C. 306f(d)(2)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1947-08-07/ch512/s311/d/2"},"text":"Aug. 7, 1947, ch. 512, § 311(d)(2)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/61/852"},"text":"61 Stat. 852","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1949-08-05/ch402/s1/c"},"text":"Aug. 5, 1949, ch. 402, § 1(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/568"},"text":"63 Stat. 568","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “rank” is substituted for the words “take precedence” throughout the section for uniformity of expression.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the first sentence is broadened to include officers of the Marine Corps and officers not on a lineal list. Inclusion of the Marine Corps is possible because the sentence reflects the rule referred to by the Attorney General (25 Op. Atty. Gen. 517) as “an unwritten law of the Army and Navy” as to relative rank between officers in different services. Officers not on a lineal list may properly be included since the statement is consistent with the provisions for assigning lineal position to such officers when they become entitled to be placed on a list.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab10788f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab107890-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s5508"},"text":"section 5508 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" struck out designation “(a)” before “Except for an officer”, substituted “an active-duty list” for “a lineal list”, struck out sentence which had provided that a staff corps officer with the same date of rank as his running mate ranked above all line and staff corps officers junior to his running mate, and struck out subsec. (b) which had provided for a hierarchy of 9 categories of officers of the Navy to be used in ranking officers of the Navy on active duty serving in the same grade and having the same date of rank in that grade."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/179"},"text":"Pub. L. 90–179","children":[],"tail":" added par. (6) and renumbered former pars. (6), (7), and (8) as pars. (7), (8), and (9), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab107891-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab107892-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab107893-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701"},"text":"section 701 of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
