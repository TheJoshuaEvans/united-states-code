{"tag":"section","attrib":{"id":"ida978c205-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2458"},"text":null,"children":[{"tag":"num","attrib":{"value":"2458"},"text":"§ 2458.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventory management policies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida978c206-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2458/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall issue a single, uniform policy on the management of inventory items of the Department of Defense. Such policy shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida978c207-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2458/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish maximum levels for inventory items sufficient to achieve and maintain only those levels for inventory items necessary for the national defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida978c208-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2458/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide guidance to item managers and other appropriate officials on how effectively to eliminate wasteful practices in the acquisition and management of inventory items; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida978c209-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2458/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth a uniform system for the valuation of inventory items by the military departments and Defense Agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida978c20a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2458/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personnel Evaluations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall establish procedures to ensure that, with regard to item managers and other personnel responsible for the acquisition and management of inventory items of the Department of Defense, personnel appraisal systems for such personnel give appropriate consideration to efforts made by such personnel to eliminate wasteful practices and achieve cost savings in the acquisition and management of inventory items.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida978c20b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tIII/s323/a/1"},"text":"Pub. L. 101–510, div. A, title III, § 323(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1530"},"text":"104 Stat. 1530","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tIII/s347/a"},"text":"Pub. L. 102–190, div. A, title III, § 347(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1347"},"text":"105 Stat. 1347","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida978c20c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida978c20d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida978c20e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida978c20f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida978c210-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Secretary of Defense to establish uniform system of valuation described in subsec. (a)(3) of this section not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/s347/c"},"text":"section 347(c) of Pub. L. 102–190","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2721"},"text":"section 2721 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida978c211-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Management of Conventional Ammunition Inventory","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tIII/s352/a"},"text":"Pub. L. 113–291, div. A, title III, § 352(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3347"},"text":"128 Stat. 3347","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/291/dA/tIII/s352/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consolidation of Data","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 240 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":"], the Under Secretary of Defense for Acquisition, Technology, and Logistics shall issue Department-wide guidance designating an authoritative source of data for conventional ammunition. Not later than 10 days after issuing the guidance required by this subsection, the Under Secretary shall notify the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] on what source of data has been designated under this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army shall include in the appropriate annual ammunition inventory reports, as determined by the Secretary, information on all available ammunition for use during the redistribution process, including any ammunition that was unclaimed and categorized for disposal by another military service during a year before the year during which the report is submitted.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida978c212-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Improvement of Inventory Management Practices","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tIII/s328"},"text":"Pub. L. 111–84, div. A, title III, § 328","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2255"},"text":"123 Stat. 2255","children":[],"tail":", which required the Secretary to submit to Congress a comprehensive plan for improving the inventory management systems of the military departments and the Defense Logistics Agency to reduce the acquisition and storage of secondary excess inventory, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s812/b/44"},"text":"Pub. L. 115–232, div. A, title VIII, § 812(b)(44)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1850"},"text":"132 Stat. 1850","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida978c213-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Inventory and Control of Military Equipment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tIII/s363"},"text":"Pub. L. 106–65, div. A, title III, § 363","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/576"},"text":"113 Stat. 576","children":[],"tail":", provided that not later than "},{"tag":"date","attrib":{"date":"2000-08-31"},"text":"Aug. 31, 2000","children":[],"tail":", the Secretary of Defense was to submit to the Committees on Armed Services of the Senate and the House of Representatives a report on the inventory and control of the military equipment of the Department of Defense as of the end of fiscal year 1999, and that not later than "},{"tag":"date","attrib":{"date":"2000-11-30"},"text":"Nov. 30, 2000","children":[],"tail":", the Inspector General of the Department of Defense was to review the report and submit comments to the committees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida978c214-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Best Commercial Inventory Practices for Management of Secondary Supply Items","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tIII/s347"},"text":"Pub. L. 105–261, div. A, title III, § 347","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1980"},"text":"112 Stat. 1980","children":[],"tail":", which related to implementation of the best commercial inventory practices for the acquisition and distribution of secondary supply items, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s812/b/45"},"text":"Pub. L. 115–232, div. A, title VIII, § 812(b)(45)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1850"},"text":"132 Stat. 1850","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida978c215-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inventory Management of In-Transit Items","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tIII/s349"},"text":"Pub. L. 105–261, div. A, title III, § 349","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1981"},"text":"112 Stat. 1981","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title III, § 386], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–88, which required a comprehensive plan to ensure visibility over all in-transit end items and secondary items, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s812/b/46"},"text":"Pub. L. 115–232, div. A, title VIII, § 812(b)(46)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1850"},"text":"132 Stat. 1850","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida978c216-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inventory Management","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tIII/s395"},"text":"Pub. L. 105–85, div. A, title III, § 395","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1718"},"text":"111 Stat. 1718","children":[],"tail":", which required the Director of the Defense Logistics Agency to develop and submit to Congress a schedule for implementing the best commercial inventory practices for the acquisition and distribution of supplies and equipment consistent with military requirements, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s812/b/47"},"text":"Pub. L. 115–232, div. A, title VIII, § 812(b)(47)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1850"},"text":"132 Stat. 1850","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida978c217-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Direct Vendor Delivery System for Consumable Inventory Items of Department of Defense","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tIII/s352"},"text":"Pub. L. 104–106, div. A, title III, § 352","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/266"},"text":"110 Stat. 266","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/106/dA/tIII/s352"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation of Direct Vendor Delivery System","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1997-09-30"},"text":"September 30, 1997","children":[],"tail":", the Secretary of Defense shall, to the maximum extent practicable, implement a system under which consumable inventory items referred to in subsection (b) are delivered to military installations throughout the United States directly by the vendors of those items. The purpose for implementing the system is to reduce the expense and necessity of maintaining extensive warehouses for those items within the Department of Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Items","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The items referred to in subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Food and clothing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Medical and pharmaceutical supplies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Automotive, electrical, fuel, and construction supplies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other consumable inventory items the Secretary considers appropriate.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida978c218-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Date of Issuance of Policy","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tIII/s323/b"},"text":"Pub. L. 101–510, div. A, title III, § 323(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1530"},"text":"104 Stat. 1530","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/510/dA/tIII/s323/b"},"text":"“The policy required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2458/a"},"text":"section 2458(a) of title 10","children":[],"tail":", United States Code (as added by subsection (a)), shall be issued not later than 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
