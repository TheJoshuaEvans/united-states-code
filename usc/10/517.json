,"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1868"},"text":"118 Stat. 1868","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tIV/s406"},"text":"Pub. L. 110–181, div. A, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/89"},"text":"122 Stat. 89","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIV/s403/a"},"text":"Pub. L. 116–283, div. A, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3556"},"text":"134 Stat. 3556","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7d76d08-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida7d76d09-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida7d76d0a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"517","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:232(c) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-10-12/ch681/s201/c"},"text":"Oct. 12, 1949, ch. 681, § 201(c)","children":[],"tail":" (last sentence); added "},{"tag":"html:span","attrib":{},"text":"May 20, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/422/s1/3"},"text":"Pub. L. 85–422, § 1(3)","children":[],"tail":" (last sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/72/124"},"text":"72 Stat. 124","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7d76d0b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7d76d0c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s403/a/1"},"text":"Pub. L. 116–283, § 403(a)(1)","children":[],"tail":", substituted “enlisted end strength” for “daily average” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s403/a/2"},"text":"Pub. L. 116–283, § 403(a)(2)","children":[],"tail":", in first sentence, substituted “end strength for” for “daily average number of”, “as of the last day of a fiscal year” for “in a fiscal year”, and “3.0 percent” for “2.5 percent” and struck out before period at end “on the first day of that fiscal year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s403/a/3"},"text":"Pub. L. 116–283, § 403(a)(3)","children":[],"tail":", struck out subsec. (b) which read as follows: “Whenever the number of members serving in pay grade E–9 is less than the number authorized for that grade under subsection (a), the difference between the two numbers may be applied to increase the number authorized under such subsection for pay grade E–8.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" substituted “1.25 percent” for “1 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" substituted “as authorized under section 115(a)(1)(B) or 115(b) of this title, or excluded from counting for active duty end strengths under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s115/i"},"text":"section 115(i) of this title","children":[],"tail":".” for “(other than for training) in connection with organizing, administering, recruiting, instructing, or training the reserve component of an armed force.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" substituted “2.5 percent” for “2 percent (or, in the case of the Army, 2.5 percent)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/s1069/a/2"},"text":"Pub. L. 105–261, § 1069(a)(2)","children":[],"tail":", substituted “The authorized” for “Except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s307"},"text":"section 307 of title 37","children":[],"tail":", the authorized”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/s407/a"},"text":"Pub. L. 105–261, § 407(a)","children":[],"tail":", substituted “a fiscal year” for “a calendar year” and “the first day of that fiscal year” for “January 1 of that year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s552/a"},"text":"Pub. L. 103–337, § 552(a)","children":[],"tail":", inserted “(or, in the case of the Army, 2.5 percent)” after “may not be more than 2 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1661/a/4/B"},"text":"Pub. L. 103–337, § 1661(a)(4)(B)","children":[],"tail":", redesignated subsec. (c) as (b) and struck out “or whenever the number of members serving in pay grade E–9 for duty described in subsection (b) is less than the number authorized for that grade under subsection (b),” after “under subsection (a),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1662/a/4/A"},"text":"Pub. L. 103–337, § 1662(a)(4)(A)","children":[],"tail":", struck out subsec. (b) which limited the number of enlisted members in pay grades E–8 and E–9 who could be on active duty (other than for training) or on full-time National Guard duty under the authority of "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s502/f"},"text":"section 502(f) of title 32","children":[],"tail":" (other than for training) as of the end of any fiscal year in connection with organizing, administering, recruiting, instructing, or training the reserve components or the National Guard."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1662/a/4/B"},"text":"Pub. L. 103–337, § 1662(a)(4)(B)","children":[],"tail":", redesignated subsec. (c) as (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":", in table, increased fiscal year limitation on number of enlisted men in pay grades E–8 and E–9 on active duty affecting reserve components of the Air Force to 328 and 840 from 279 and 800, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":", in table, increased fiscal year limitation on number of enlisted men in pay grade E–8 on active duty affecting reserve components of the Air Force from 670 to 800, and increased limitation on number of enlisted men in pay grade E–9 on active duty affecting reserve components of the Army from 557 to 569, the Air Force from 231 to 279, and the Marine Corps from 13 to 14."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s413/a/2"},"text":"Pub. L. 101–189, § 413(a)(2)","children":[],"tail":", in table, increased fiscal year limitation on number of enlisted men in pay grades E–8 and E–9 on active duty affecting reserve components of the armed forces: Army, to 557 and 2,585 from 542 and 2,504, respectively; Navy, to 202 and 429 from 200 and 425, respectively; Air Force, to 231 and 670 from 224 and 637, respectively. Marine Corps figures remained unchanged."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s413/a/1"},"text":"Pub. L. 101–189, § 413(a)(1)","children":[],"tail":", in table, increased fiscal year limitation on number of enlisted men in pay grades E–8 and E–9 on active duty affecting reserve components of the armed forces: Army, to 542 and 2,504 from 529 and 2,350, respectively; Navy, to 200 and 425 from 180 and 400, respectively; Air Force, to 224 and 637 from 150 and 425, respectively. Marine Corps figures remained unchanged."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/s413/a/2"},"text":"Pub. L. 100–180, § 413(a)(2)","children":[],"tail":", in table, increased fiscal year limitation on number of enlisted men in pay grades E–8 and E–9 on active duty affecting reserve components of the armed forces: Army, to 529 and 2,350 from 517 and 2,295, respectively; Navy, to 180 and 400 from 175 and 390, respectively; Air Force, to 150 and 425 from 125 and 425, respectively. Marine Corps figures remained unchanged."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/s413/a/1"},"text":"Pub. L. 100–180, § 413(a)(1)","children":[],"tail":", in table, increased fiscal year limitation on number of enlisted men in pay grades E–8 and E–9 on active duty affecting reserve components of the armed forces: Navy, to 175 and 390 from 165 and 381, respectively; Air Force, to 125 and 425 from 80 and 358, respectively; Marine Corps, to 13 and 74 from 9 and 74, respectively. Army figures remained unchanged."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" in table, changed fiscal year limitation on number of enlisted men in pay grades E–8 and E–9 on active duty affecting reserve components of the armed forces: Navy, to 165 and 381 from 156 and 381, respectively; Air Force, to 80 and 358 from 87 and 455, respectively. Army and Marine Corps figures remained unchanged."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s414/a/2"},"text":"Pub. L. 98–525, § 414(a)(2)","children":[],"tail":", inserted “(other than for training) or on full-time National Guard duty under the authority of "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s502/f"},"text":"section 502(f) of title 32","children":[],"tail":" (other than for training)” and substituted “or the National Guard” for “of the armed forces” and “for that grade and armed force” for “prescribed for the grade and the armed force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s413/a"},"text":"Pub. L. 98–525, § 413(a)","children":[],"tail":", in table, increased fiscal year limitation on number of enlisted men in pay grades E–8 and E–9 on active duty affecting reserve components of the armed forces: Army, to 2,295 and 517 from 1,494 and 314; Air Force, to 455 and 87 from 617 and 143; Marine Corps, to 74 and 9 from 56 and 6. Navy figures remained unchanged."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94"},"text":"Pub. L. 98–94","children":[],"tail":" increased fiscal year limitation on number of enlisted men in pay grades E–8 and E–9 on active duty affecting reserve components of the armed forces: Army, to 1,494 and 314 from 1,244 and 265; Navy, to 381 and 156 from 329 and 156; Air Force, to 617 and 143 from 441 and 132; Marine Corps figures remained unchanged."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/252"},"text":"Pub. L. 97–252","children":[],"tail":" increased the numbers in columns from 222, 146, 76, and 4 in the line for E–9 to 265, 156, 132, and 6, respectively, and from 908, 319, 307, and 12 in line for E–8 to 1,244, 329, 441, and 56, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/86/s503/1"},"text":"Pub. L. 97–86, § 503(1)","children":[],"tail":", inserted column for “Marine Corps” in table and increased numbers in existing columns headed “Army”, “Navy”, and “Air Force” from 209, 140, and 71 in line for E–9 to 222, 146, and 76, respectively, and from 823, 302, and 302 in line for E–8 to 908, 319, and 307, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/86/s503/2"},"text":"Pub. L. 97–86, § 503(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/584"},"text":"Pub. L. 96–584","children":[],"tail":" designated existing provisions as subsec. (a), inserted provisions respecting computation of limitations, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7d76d0d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateO