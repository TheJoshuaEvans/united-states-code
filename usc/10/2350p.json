{"tag":"section","attrib":{"id":"ida971952d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p"},"text":null,"children":[{"tag":"num","attrib":{"value":"2350p"},"text":"§ 2350p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reciprocal patient movement agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida971952e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, the Secretary of Defense, with the concurrence of the Secretary of State, may enter into a bilateral or multilateral memorandum of understanding or other formal agreement with one or more governments of partner countries that provides for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida971952f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interchangeable, nonreimbursable use of patient movement personnel, either individually or as members of a patient movement crew or team, and equipment, belonging to one partner country to perform patient movement services aboard the aircraft, vessels, or vehicles of another partner country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9719530-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the reciprocal recognition and acceptance of —","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9719531-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national professional credentials, certifications, and licenses of patient movement personnel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9719532-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national certifications, approvals, and licenses of equipment used in the provision of patient movement services; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9719533-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acceptance of agreed-upon standards for the provision of patient movement services by aircraft, vessel, or vehicle, including, as determined to be beneficial and otherwise permitted by law, the harmonization of patient treatment standards and procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9719534-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9719535-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Before entering into a memorandum of understanding or other formal agreement with the government of a partner country under this section, the Secretary of Defense shall certify in writing that the professional credentials, certifications, licenses, and approvals for patient movement personnel and patient movement equipment of the partner country—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9719536-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet or exceed the equivalent standards of the United States for similar personnel and equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9719537-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will provide for a level of care comparable to, or better than, the level of care provided by the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9719538-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A certification under paragraph (1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9719539-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submitted to the appropriate committees of Congress not later than 15 days after the date on which the Secretary of Defense makes the certification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida971953a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewed and recertified by the Secretary of Defense not less frequently than annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida971953b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Suspension","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary of Defense is unable to recertify a partner country as required by subsection (b)(2)(B), use of the personnel or equipment of the partner country by the Department of Defense under a memorandum of understanding or other formal agreement concluded pursuant to subsection (a) shall be suspended until the date on which the Secretary of Defense is able to recertify the partner country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida971953c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida971953d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate committees of congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida971953e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional defense committees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida971953f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9719540-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Partner country","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “partner country” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9719541-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member country of the North Atlantic Treaty Organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9719542-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Australia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9719543-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Japan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9719544-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" New Zealand.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9719545-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Republic of Korea.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9719546-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other country designated as a partner country by the Secretary of Defense, with the concurrence of the Secretary of State, for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9719547-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350p/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Patient movement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “patient movement” means the act or process of moving wounded, ill, injured, or other persons (including contaminated, contagious, and potentially exposed patients) to obtain medical, surgical, mental health, or dental care or treatment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9719548-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII/s1204/a"},"text":"Pub. L. 116–283, div. A, title XII, § 1204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3911"},"text":"134 Stat. 3911","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
