{"tag":"section","attrib":{"id":"ida8fa6965-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1591"},"text":null,"children":[{"tag":"num","attrib":{"value":"1591"},"text":"§ 1591.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement for travel and transportation expenses when accompanying Members of Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8fa6966-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1591/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (b), the Secretary concerned may authorize reimbursement to a civilian employee who is accompanying a Member of Congress or a congressional employee on official travel for actual travel and transportation expenses incurred for such travel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa6967-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1591/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The allowance provided in subsection (a) may be paid—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fa6968-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1591/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a rate that does not exceed the rate approved for official congressional travel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa6969-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1591/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only when the travel of the member is directed or approved by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa696a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1591/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fa696b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1591/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Member of Congress” means a member of the Senate or the House of Representatives, a Delegate to the House of Representatives, and the Resident Commissioner from Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa696c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1591/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “congressional employee” means an employee of a Member of Congress or an employee of Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa696d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1591/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary concerned” includes the Secretary of Defense with respect to civilian employees of the Department of Defense other than a military department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8fa696e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tVI/s617/b/1"},"text":"Pub. L. 100–180, div. A, title VI, § 617(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1097"},"text":"101 Stat. 1097","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8fa696f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8fa6970-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8fa6971-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tVI/s617/c"},"text":"Pub. L. 100–180, div. A, title VI, § 617(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1097"},"text":"101 Stat. 1097","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s631/f/4/B"},"text":"Pub. L. 112–81, div. A, title VI, § 631(f)(4)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1465"},"text":"125 Stat. 1465","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/a/9"},"text":"Pub. L. 112–239, div. A, title X, § 1076(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1948"},"text":"126 Stat. 1948","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/239/dA/tX/s1076/a/9"},"text":"“Subsection (h) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s474"},"text":"section 474 of title 37","children":[],"tail":", United States Code (as added by subsection (a)), and "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1591"},"text":"section 1591 of title 10","children":[],"tail":", United States Code (as added by subsection (b)), shall apply with respect to travel performed after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
