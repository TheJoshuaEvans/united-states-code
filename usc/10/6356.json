{"tag":"section","attrib":{"id":"idaad014ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356"},"text":null,"children":[{"tag":"num","attrib":{"value":"6356"},"text":"§ 6356.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to use passenger carriers for contractor commuting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaad014ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If and to the extent that the Administrator deems it appropriate to further mission activities under section 3211 of the National Nuclear Security Administration Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2401"},"text":"50 U.S.C. 2401","children":[],"tail":"), a passenger carrier may be used to provide transportation services to contractor employees between the covered facility of the contractor employee and a mass transit facility in accordance with any applicable transportation plan adopted by the Administrator pursuant to this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad014af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan Requests and Approval","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad014b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaad014b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaad014b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide Management and Operating contractors at covered facilities the opportunity to, on a voluntary basis, submit, through the cognizant contracting officer of the applicable covered facility, a plan to provide transportation services described in subsection (a) for contractor employees at the covered facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaad014b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review each such plan submitted in accordance with clause (i); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad014b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may approve each such plan if the requirements described in clauses (i) through (iv) of paragraph (2)(B) are satisfied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad014b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each plan submitted pursuant to paragraph (1)(A)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaad014b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include proposals for parking facilities, road improvements, real property acquisition, passenger carrier services, and commuting cost deferment payments to contractor employees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad014b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaad014b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the use of passenger carriers will facilitate the mission of the covered facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaad014b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the plan will be economical and advantageous to the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaad014ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the benefits that will be provided under the plan and how costs will be monitored; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaad014bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the plan will alleviate traffic congestion, reduce commuting times, and improve recruitment and retention of contractor employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad014bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator may delegate to the Senior Procurement Executive of the Administration the approval of any plan submitted under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad014bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administration may reimburse a contractor for the costs of transportation services incurred pursuant to a plan approved under subsection (b) using funds appropriated to the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad014be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out a plan approved under subsection (b), the Administrator, to the maximum extent practicable and consistent with sound budget policy, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad014bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the use of alternative fuel vehicles to provide transportation services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad014c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure funds spent for this plan further the mission activities of the Administration under section 3211 of the National Nuclear Security Administration Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2401"},"text":"50 U.S.C. 2401","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad014c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the time during which a contractor employee uses transportation services shall not be included for purposes of calculating the hours of work for such contractor employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad014c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad014c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “contractor employee” means an employee of a Management and Operating contractor or subcontractor employee at any tier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad014c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered facility” means any facility of the Administration that directly supports the mission of the Administration under section 3211 of the National Nuclear Security Administration Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2401"},"text":"50 U.S.C. 2401","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad014c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Management and Operating contractor” means a management and operating contractor that manages a covered facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad014c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6356/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “passenger carrier” means a passenger motor vehicle, aircraft, boat, ship, train, or other similar means of transportation that is owned, leased, or provided pursuant to contract or subcontract by the Federal Government or through a contractor of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad014c7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2)(B), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1456"},"text":"139 Stat. 1456","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaad014c8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaad014c9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaad014ca-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2815"},"text":"section 2815 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaad014cb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
