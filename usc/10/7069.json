}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3069","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:81–1 (5th through 8th words of last sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:166(a) (words of last sentence before proviso).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:166(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-06-28/ch383/s307"},"text":"June 28, 1950, ch. 383, § 307","children":[],"tail":" (5th through 8th words of last sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/270"},"text":"64 Stat. 270","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1947-04-16/ch38"},"text":"Apr. 16, 1947, ch. 38","children":[],"tail":" §§ 101(a) (words of last sentence before proviso), 101(b), "},{"tag":"html:a","attrib":{"href":"/us/stat/61/41"},"text":"61 Stat. 41","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “officers of the Regular Army in that corps” are substituted for the words “officers permanently commissioned in such Army Nurse Corps”. The words “but not for more than” are substituted for the words “for a term not to exceed”, in 10:166(a). The words “vacating her regular grade” are substituted for the words “vacation of her permanent grade”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaad9b14d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaad9b14e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3069"},"text":"section 3069 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" struck out second sentence which read as follows: “An appointee who holds a lower regular grade shall be appointed in the regular grade of major general.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" substituted “major general” for “brigadier general”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s502/a/3"},"text":"Pub. L. 104–201, § 502(a)(3)","children":[],"tail":", inserted “; grade” at end of section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s502/a/1"},"text":"Pub. L. 104–201, § 502(a)(1)","children":[],"tail":", substituted “lieutenant colonel” for “major” in first sentence, inserted “An appointee who holds a lower regular grade shall be appointed in the regular grade of brigadier general.” after first sentence, and inserted “to the same position” before period at end of last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s502/a/2"},"text":"Pub. L. 104–201, § 502(a)(2)","children":[],"tail":", substituted “lieutenant colonel” for “major”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/130"},"text":"Pub. L. 90–130","children":[],"tail":" divided existing provisions into subsecs. (a), (b), and (c), made minor changes in phraseology, inserted provision for the appointment and service of an assistant chief, struck out limitation restricting membership in the Corps to grades of second lieutenant through colonel, and struck out provision entitling the Chief to the temporary grade of colonel while serving as Chief."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/609"},"text":"Pub. L. 89–609","children":[],"tail":" combined third and fourth sentences, substituting “, and” for period at end of third sentence and introductory word “She” to fourth sentence, and substituted “the regular grade held, the Chief” for “her regular grade, she” in fifth sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":" struck out provisions which authorized the pay and allowances of a colonel for Chief of the Army Nurse Corps."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1957—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/155"},"text":"Pub. L. 85–155","children":[],"tail":" substituted “second lieutenant through colonel” for “second lieutenant through lieutenant colonel”, “major” for “captain”, and “entitled to the temporary grade and the pay and allowances of a colonel while so serving and ranks above all other colonels in that corps” for “entitled to the rank, pay and allowances of a colonel so serving”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaad9b14f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaad9b150-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaad9b151-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1962 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1962-11-01"},"text":"Nov. 1, 1962","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/87/649/s15"},"text":"section 15 of Pub. L. 87–649","children":[],"tail":", set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s101"},"text":"section 101 of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idaad9b152-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/155/tI/s105"},"text":"Pub. L. 85–155, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-21"},"text":"Aug. 21, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/381"},"text":"71 Stat. 381","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/85/155/tI/s105"},"text":"“This title [amending this section and sections 3070, 3206, 3207, 3288, 3291, 3296 to 3299, 3304, 3305, 3888, 3915, 3916, 3927, and 3991 of this title] may be cited as the ‘Army Nurse and Medical Specialist Act of 1957’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idaad9b153-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/155/tI/s104"},"text":"Pub. L. 85–155, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-21"},"text":"Aug. 21, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/380"},"text":"71 Stat. 380","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/85/155/tI/s104"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This Act [amending this section and sections 3070, 3206, 3207, 3288, 3291, 3296 to 3299, 3304, 3305, 3888, 3915, 3916, 3927, 3991, 5140, 5444, 5449, 5702, 5707, 5708, 5753, 5762, 5773, 5775, 5776, 5782, 6377 to 6379, 6381, 6388, 6395, 6396, 8206, 8207, 8212, 8285 to 8288, 8297, 8298 to 8301, 8303, 8305, 8888, 8915, 8927 and 8991 of this title, and repealing sections 3881, 3882, 3887, 3912, 3928, 8291, 8304, 8881, 8882, 8887, 8912 and 8928 of this title] does not affect the appointment of an officer of the Army Nurse Corps, Regular Army, or the Army Medical Specialist Corps, Regular Army, on the active list on the effective date of this Act [","children":[{"tag":"date","attrib":{"date":"1957-08-21"},"text":"Aug. 21, 1957","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This Act does not affect the retired status or retired pay of a person retired under section 108, Army-Navy Nurses Act of 1947, as amended, or any other law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer of the Army Nurse Corps, Regular Army, or the Army Medical Specialist Corps, Regular Army, on the active list on the effective date of this Act [","children":[{"tag":"date","attrib":{"date":"1957-08-21"},"text":"Aug. 21, 1957","children":[],"tail":"] does not lose any years of service creditable to her on that date for promotion, computation of basic pay, or other purposes, by the enactment of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, an officer of the Army Nurse Corps, Regular Army, or the Army Medical Specialist Corps, Regular Army, who is on a recommended list for promotion to a higher regular grade on the effective date of this Act [","children":[{"tag":"date","attrib":{"date":"1957-08-21"},"text":"Aug. 21, 1957","children":[],"tail":"] may, if nominated by the President and confirmed by the Senate, be promoted to that grade."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, an officer of the Army Nurse Corps, Regular Army, or the Army Medical Specialist Corps, Regular Army, who, on the effective date of this Act [","children":[{"tag":"date","attrib":{"date":"1957-08-21"},"text":"Aug. 21, 1957","children":[],"tail":"], has been nominated by the President and confirmed by the Senate for appointment to any regular grade, may be appointed in that grade.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
