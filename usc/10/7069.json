{"tag":"section","attrib":{"id":"idaad9b145-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7069"},"text":null,"children":[{"tag":"num","attrib":{"value":"7069"},"text":"§ 7069.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Army Nurse Corps: composition; Chief and assistant chief; appointment; grade","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaad9b146-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7069/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Army Nurse Corps consists of the Chief and assistant chief of that corps and other officers in grades prescribed by the Secretary of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad9b147-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7069/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army shall appoint the Chief from the officers of the Regular Army in that corps whose regular grade is above lieutenant colonel and who are recommended by the Surgeon General. The Chief serves during the pleasure of the Secretary, but not for more than four years, and may not be reappointed to the same position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad9b148-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7069/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Surgeon General shall appoint the assistant chief from the officers of the Regular Army in that corps whose regular grade is above lieutenant colonel. The assistant chief serves during the pleasure of the Surgeon General, but not for more than four years and may not be reappointed to the same position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad9b149-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/168"},"text":"70A Stat. 168","children":[],"tail":", § 3069; "},{"tag":"ref","attrib":{"href":"/us/pl/85/155/tI/s101/1"},"text":"Pub. L. 85–155, title I, § 101(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-21"},"text":"Aug. 21, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/375"},"text":"71 Stat. 375","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/649/s6/b/1"},"text":"Pub. L. 87–649, § 6(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/494"},"text":"76 Stat. 494","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/609/s1/1"},"text":"Pub. L. 89–609, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-30"},"text":"Sept. 30, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/852"},"text":"80 Stat. 852","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/130/s1/8/A"},"text":"Pub. L. 90–130, § 1(8)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-11-08"},"text":"Nov. 8, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/374"},"text":"81 Stat. 374","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s502/a"},"text":"Pub. L. 104–201, div. A, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2511"},"text":"110 Stat. 2511","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tV/s504/a/1"},"tex