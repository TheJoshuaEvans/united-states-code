{"tag":"section","attrib":{"id":"idaab11ab1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4982"},"text":null,"children":[{"tag":"num","attrib":{"value":"4982"},"text":"§ 4982.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees charged and collected","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaab11ab2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4982/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fee Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall assess a fee for providing a loan guarantee under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab11ab3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4982/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of Fee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of the fee shall be not less than 75 percent of the amount incurred by the Secretary to provide the loan guarantee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab11ab4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4982/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Account","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab11ab5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4982/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such fees shall be credited to a special account in the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab11ab6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4982/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts in the special account shall be available, to the extent and in amounts provided in appropriations Acts, for paying the costs of administrative expenses of the Department of Defense that are attributable to the loan guarantee program under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab11ab7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4982/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaab11ab8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4982/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If for any fiscal year amounts in the special account established under paragraph (1) are not available (or are not anticipated to be available) in a sufficient amount for administrative expenses of the Department of Defense for that fiscal year that are directly attributable to the administration of the program under this subchapter, the Secretary may use amounts currently available for operations and maintenance for Defense-wide activities, not to exceed $500,000 in any fiscal year, for those expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab11ab9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4982/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, from funds in the special account established under paragraph (1), replenish operations and maintenance accounts for amounts expended under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaab11aba-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1033(a)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–259, § 2541a; renumbered § 4982, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1873/b"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1873(b)","children":[],"tail":", (c)(2), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4290"},"text":"134 Stat. 4290","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaab11abb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaab11abc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaab11abd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2541a"},"text":"section 2541a of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaab11abe-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaab11abf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
