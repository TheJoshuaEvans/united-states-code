{"tag":"section","attrib":{"id":"ida903df52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1702"},"text":null,"children":[{"tag":"num","attrib":{"value":"1702"},"text":"§ 1702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary of Defense for Acquisition and Sustainment: authorities and responsibilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to the authority, direction, and control of the Secretary of Defense, the Under Secretary of Defense for Acquisition and Sustainment shall carry out all powers, functions, and duties of the Secretary of Defense with respect to the acquisition workforce in the Department of Defense. The Under Secretary shall ensure that the policies of the Secretary of Defense established in accordance with this chapter are implemented throughout the Department of Defense. The Under Secretary shall prescribe policies and requirements for the educational programs of the defense acquisition university structure established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1746"},"text":"section 1746 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida903df53-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXII/s1202/a"},"text":"Pub. L. 101–510, div. A, title XII, § 1202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1638"},"text":"104 Stat. 1638","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tIX/s904/d/1"},"text":"Pub. L. 103–160, div. A, title IX, § 904(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1728"},"text":"107 Stat. 1728","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tVIII/s815"},"text":"Pub. L. 105–261, div. A, title VIII, § 815","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2088"},"text":"112 Stat. 2088","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/b/2"},"text":"Pub. L. 107–107, div. A, title X, § 1048(b)(2)","children":[],"tail":", (3)(A), "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1225"},"text":"115 Stat. 1225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s902/11"},"text":"Pub. L. 116–92, div. A, title IX, § 902(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1544"},"text":"133 Stat. 1544","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida903df54-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida903df55-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida903df56-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “Under Secretary of Defense for Acquisition and Sustainment” for “Under Secretary of Defense for Acquisition, Technology, and Logistics” in section catchline and in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" substituted “Under Secretary of Defense for Acquisition, Technology, and Logistics” for “Under Secretary of Defense for Acquisition and Technology” in section catchline and in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":"Pub. L. 105–261","children":[],"tail":" inserted at end “The Under Secretary shall prescribe policies and requirements for the educational programs of the defense acquisition university structure established under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1746"},"text":"section 1746 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":" substituted “Under Secretary of Defense for Acquisition and Technology” for “Under Secretary of Defense for Acquisition” in section catchline and in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida903df57-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida903df58-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Quick-Reaction Special Projects Acquisition Team","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tVIII/s807"},"text":"Pub. L. 107–314, div. A, title VIII, § 807","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2608"},"text":"116 Stat. 2608","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s902/12"},"text":"Pub. L. 116–92, div. A, title IX, § 902(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1544"},"text":"133 Stat. 1544","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dA/tIX/s902/12"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Under Secretary of Defense for Acquisition and Sustainment shall establish a team of highly qualified acquisition professionals who shall be available to advise the Under Secretary on actions that can be taken to expedite the acquisition of urgently needed systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The issues on which the team may provide advice shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Industrial base issues, including the limited availability of suppliers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Technology development and technology transition issues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Issues of acquisition policy, including the length of the acquisition cycle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Issues of testing policy and ensuring that weapon systems perform properly in combat situations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Issues of procurement policy, including the impact of socio-economic requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Issues relating to compliance with environmental requirements.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
