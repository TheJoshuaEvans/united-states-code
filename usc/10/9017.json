{"tag":"section","attrib":{"id":"idab5a79b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9017"},"text":null,"children":[{"tag":"num","attrib":{"value":"9017"},"text":"§ 9017.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of the Air Force: successors to duties","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If the Secretary of the Air Force dies, resigns, is removed from office, is absent, or is disabled, the person who is highest on the following list, and who is not absent or disabled, shall perform the duties of the Secretary until the President, under section 3347 ","children":[{"tag":"ref","attrib":{"idref":"fn002167"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002167"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 5, directs another person to perform those duties or until the absence or disability ceases:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab5a79b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9017/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5a79b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9017/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretaries of the Air Force, in the order prescribed by the Secretary of the Air Force and approved by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5a79b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9017/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tai