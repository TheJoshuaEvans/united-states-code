{"tag":"section","attrib":{"id":"ida7bf9efc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s442"},"text":null,"children":[{"tag":"num","attrib":{"value":"442"},"text":"§ 442.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Missions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7bf9efd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s442/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Security Missions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bf9efe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s442/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The National Geospatial-Intelligence Agency shall, in support of the national security objectives of the United States, provide geospatial intelligence consisting of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7bf9eff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s442/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Imagery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bf9f00-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s442/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Imagery intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bf9f01-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s442/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Geospatial information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bf9f02-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s442/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7bf9f03-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s442/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As directed by the Director of National Intelligence, the National Geospatial-Intelligence Agency shall develop a system to facilitate the analysis, dissemination, and incorporation of likenesses, videos, and presentations produced by ground-based platforms, including handheld or clandestine photography taken by or on behalf of human intelligence collection organizations or available as open-source information, into the National System for Geospatial Intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bf9f04-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s442/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority provided by this paragraph does not include authority for the National Geospatial-Intelligence Agency to manage tasking of handheld or clandestine photography taken by or on behalf of human intelligence collection organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bf9f05-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s442/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Geospatial intelligence provided in carrying out paragraphs (1) and (2) shall be timely, relevant, and accurate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bf9f06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s442/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Navigation Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Geospatial-Intelligence Agency shall improve the means for safe navigation by providing, under the authority of the Secretary of Defense, accurate geospatial information for use by the departments and agencies of the United States, the merchant marine, and navigators generally.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bf9f07-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s442/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maps, Charts, Etc","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Geospatial-Intelligence Agency shall acquire, prepare, and distribute maps, safe-for-navigation charts and datasets, books, and geomatics products as authorized under subchapter II of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bf9f08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s442/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Missions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Geospatial-Intelligence Agency also has national missions as specified in section 110(a) of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3045/a"},"text":"50 U.S.C. 3045(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bf9f09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s442/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Systems","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Geospatial-Intelligence Agency may, in furtherance of a mission of the Agency, design, develop, deploy, operate, and maintain systems related to the processing and dissemination of imagery intelligence and geospatial information that may be transferred to, accepted or used by, or used on behalf of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bf9f0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s442/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the armed forces, including any combatant command, component of a combatant command, joint task force, or tactical unit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bf9f0b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s442/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other department or agency of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bf9f0c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s442/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Validation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Geospatial-Intelligence Agency shall assist the Joint Chiefs of Staff, combatant commands, and the military departments in establishing, coordinating, consolidating, and validating mapping, charting, geomatics data, and safety of navigation capability requirements through a formal process governed by the Joint Staff. Consistent with validated requirements, the National Geospatial-Intelligence Agency shall provide aeronautical and nautical charts that are safe for navigation, maps, books, datasets, models, and geomatics products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7bf9f0d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXI/s1112/a/2"},"text":"Pub. L. 104–201, div. A, title XI, § 1112(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2678"},"text":"110 Stat. 2678","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tIX/s921/c/1"},"text":"Pub. L. 108–136, div. A, title IX, § 921(c)(1)","children":[],"tail":", (d)(2)(A), (f), "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1568"},"text":"117 Stat. 1568","children":[],"tail":", 1570; "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIV/s432"},"text":"Pub. L. 111–259, title IV, § 432","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2732"},"text":"124 Stat. 2732","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1071/c/6"},"text":"Pub. L. 113–291, div. A, title X, § 1071(c)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3509"},"text":"128 Stat. 3509","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVI/s1621/a"},"text":"Pub. L. 116–283, div. A, title XVI, § 1621(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4052"},"text":"134 Stat. 4052","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7bf9f0e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7bf9f0f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7bf9f10-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1621/a/1"},"text":"Pub. L. 116–283, § 1621(a)(1)","children":[],"tail":", substituted “the means for safe navigation” for “means of navigating vessels of the Navy and the merchant marine” and “geospatial information for use by the departments and agencies of the United States, the merchant marine, and navigators generally.” for “and inexpensive nautical charts, sailing directions, books on navigation, and manuals of instructions for the use of all vessels of the United States and of navigators generally.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1621/a/2"},"text":"Pub. L. 116–283, § 1621(a)(2)","children":[],"tail":", substituted “shall acquire, prepare, and” for “shall prepare and”, “safe-for-navigation charts and datasets” for “charts”, and “geomatics” for “geodetic”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1621/a/3"},"text":"Pub. L. 116–283, § 1621(a)(3)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3045/a"},"text":"50 U.S.C. 3045(a)","children":[],"tail":")” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s404e/a"},"text":"50 U.S.C. 404e(a)","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s432/2"},"text":"Pub. L. 111–259, § 432(2)","children":[],"tail":", added par. (2). Former par. (2) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s432/1"},"text":"Pub. L. 111–259, § 432(1)","children":[],"tail":", (3), redesignated par. (2) as (3) and substituted “paragraphs (1) and (2)” for “paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s921/c/1/A"},"text":"Pub. L. 108–136, § 921(c)(1)(A)","children":[],"tail":", (d)(2)(A), in introductory provisions, substituted “National Geospatial-Intelligence Agency” for “National Imagery and Mapping Agency” and inserted “geospatial intelligence consisting of” after “provide”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s921/c/1/B"},"text":"Pub. L. 108–136, § 921(c)(1)(B)","children":[],"tail":", substituted “Geospatial intelligence” for “Imagery, intelligence, and information”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s921/d/2/A"},"text":"Pub. L. 108–136, § 921(d)(2)(A)","children":[],"tail":", substituted “National Geospatial-Intelligence Agency” for “National Imagery and Mapping Agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s921/d/2/A"},"text":"Pub. L. 108–136, § 921(d)(2)(A)","children":[],"tail":", (f), substituted “National Geospatial-Intelligence Agency” for “National Imagery and Mapping Agency” and “section 110(a) of the National Security Act of 1947 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s404e/a"},"text":"50 U.S.C. 404e(a)","children":[],"tail":")” for “section 120(a) of the National Security Act of 1947”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s921/d/2/A"},"text":"Pub. L. 108–136, § 921(d)(2)(A)","children":[],"tail":", substituted “National Geospatial-Intelligence Agency” for “National Imagery and Mapping Agency” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7bf9f11-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida7bf9f12-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1124"},"text":"section 1124 of Pub. L. 104–201","children":[],"tail":", set out as an Effective Date of 1996 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s193"},"text":"section 193 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
