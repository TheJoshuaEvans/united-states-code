{"tag":"section","attrib":{"id":"ida8a96393-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1170"},"text":null,"children":[{"tag":"num","attrib":{"value":"1170"},"text":"§ 1170.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regular enlisted members: minority discharge","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Upon application by the parents or guardian of a regular enlisted member of an armed force to the Secretary concerned within 90 days after the member’s enlistment, the member shall be discharged for his own convenience, with the pay and form of discharge certificate to which his service entitles him, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8a96394-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1170/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is evidence satisfactory to the Secretary concerned that the member is under eighteen years of age; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8a96395-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1170/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the member enlisted without the written consent of his parent or guardian.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8a96396-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/235/s3/a/1/A"},"text":"Pub. L. 90–235, § 3(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/757"},"text":"81 Stat. 757","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
