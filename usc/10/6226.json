{"tag":"section","attrib":{"id":"idaac69df2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6226"},"text":null,"children":[{"tag":"num","attrib":{"value":"6226"},"text":"§ 6226.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual ","children":[{"tag":"ref","attrib":{"idref":"fn002142"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002142"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Biennial”."}],"tail":" report and certification on status of security of atomic energy defense facilities"}],"tail":null},{"tag":"subsection","attrib":{"id":"idaac69df3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6226/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report and Certification on Nuclear Security Enterprise","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac69df4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6226/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than September 30 of each even-numbered year, the Administrator shall submit to the Secretary of Energy—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac69df5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6226/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report detailing the status of security at facilities holding Category I and II quantities of special nuclear material that are administered by the Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69df6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6226/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" written certification that such facilities are secure and that the security measures at such facilities meet the security standards and requirements of the Administration and the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac69df7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6226/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Administrator is unable to make the certification described in paragraph (1)(B) with respect to a facility, the Administrator shall submit to the Secretary with the matters required by paragraph (1) a corrective action plan for the facility describing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac69df8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6226/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deficiency that resulted in the Administrator being unable to make the certification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69df9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6226/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actions to be taken to correct the deficiency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69dfa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6226/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" timelines for taking such actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac69dfb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6226/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than December 1 of each even-numbered year, the Secretary shall submit to the congressional defense committees the unaltered report, certification, and any corrective action plans submitted by the Administrator under paragraphs (1) and (2) together with any comments of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac69dfc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6226/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report and Certification on Atomic Energy Defense Facilities Not Administered by the Administration","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac69dfd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6226/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than December 1 of each even-numbered year, the Secretary shall submit to the congressional defense committees—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac69dfe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6226/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report detailing the status of the security of atomic energy defense facilities holding Category I and II quantities of special nuclear material that are not administered by the Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69dff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6226/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" written certification that such facilities are secure and that the security measures at such facilities meet the security standards and requirements of the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac69e00-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6226/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Secretary is unable to make the certification described in paragraph (1)(B) with respect to a facility, the Secretary shall submit to the congressional defense committees, together with the matters required by paragraph (1), a corrective action plan describing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac69e01-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6226/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deficiency that resulted in the Secretary being unable to make the certification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69e02-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6226/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actions to be taken to correct the deficiency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69e03-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6226/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" timelines for taking such actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac69e04-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2)(B), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1405"},"text":"139 Stat. 1405","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac69e05-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac69e06-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac69e07-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2657"},"text":"section 2657 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaac69e08-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","chi