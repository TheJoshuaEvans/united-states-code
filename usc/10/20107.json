{"tag":"section","attrib":{"id":"idabc82f75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20107"},"text":null,"children":[{"tag":"num","attrib":{"value":"20107"},"text":"§ 20107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer to inactive status: initial service obligation not complete","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabc82f76-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the Space Force who has not completed the required minimum service obligation referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20003"},"text":"section 20003 of this title","children":[],"tail":" shall, if terminating space force active status, be transferred to a space force inactive status and, unless otherwise designated an Individual Ready Guardian under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s20102"},"text":"section 20102 of this title","children":[],"tail":", shall remain subject to order to active duty without the member’s consent under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s20106"},"text":"section 20106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc82f77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) does not apply to a member who is separated from the Space Force by the Secretary of the Air Force under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20503"},"text":"section 20503 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc82f78-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1715"},"text":"Pub. L. 118–31, div. A, title XVII, § 1715","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/630"},"text":"137 Stat. 630","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
