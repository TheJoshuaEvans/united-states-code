{"tag":"section","attrib":{"id":"idaad9b190-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7075"},"text":null,"children":[{"tag":"num","attrib":{"value":"7075"},"text":"§ 7075.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regular Army: composition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaad9b191-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7075/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Regular Army is the component of the Army that consists of persons whose continuous service on active duty in both peace and war is contemplated by law, and of retired members of the Regular Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad9b192-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7075/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Regular Army includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad9b193-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7075/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officers and enlisted members of the Regular Army;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b194-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7075/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the professors, director of admissions, and cadets of the United States Military Academy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b195-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7075/b/3"},"text":null,"children":[{"tag":"num","attrib":{"