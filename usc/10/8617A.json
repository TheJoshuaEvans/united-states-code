{"tag":"section","attrib":{"id":"idab3454d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A"},"text":null,"children":[{"tag":"num","attrib":{"value":"8617A"},"text":"§ 8617A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Navy Museum System","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab3454d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Navy shall support a system of official Navy museums, which shall collectively be known as the “United States Navy Museum System”. Such system shall include the following museums:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab3454d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Museum of the United States Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab3454d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Naval Academy Museum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab3454d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Naval War College Museum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369dca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Submarine Force Museum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369dcb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Naval Aviation Museum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369dcc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The USS Constitution Naval History and Heritage Command, Detachment Boston.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369dcd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Navy Seabee Museum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369dce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Puget Sound Navy Museum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369dcf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Naval Undersea Museum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369dd0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Museum of the American Sailor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369dd1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Hampton Roads Naval Museum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369dd2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other museums as may be designated by the Secretary of the Navy that meet criteria established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab369dd3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria for Designation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Navy shall establish criteria for designating museums other than museums identified in paragraphs (1) through (11) of subsection (a) for inclusion in the United States Navy Museum System. Such criteria shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab369dd4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" historical significance to naval operations, technology, or personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369dd5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public accessibility and educational outreach programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369dd6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alignment with the mission of the Navy to preserve its heritage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab369dd7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria for Closure","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Navy shall establish criteria for the closure of museums within the United States Navy Museum System. No museum within such system may be closed until—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab369dd8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary of the Navy submits to the Committees on Armed Services of the House of Representatives and the Senate notice that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab369dd9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for the preservation, storage, or alternate display of historical collections contained in the museum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab369dda-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how any issues relating to museum personnel will be resolved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab369ddb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of any efforts to maintain museum operations through public-private partnerships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab369ddc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the cost to transport, consolidate, and preserve the historical collections contained in the museum; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369ddd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 90 days has elapsed after the date on which such notice is received by such committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab369dde-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8617A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding and Support","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Consistent with applicable law, the Secretary of the Navy may enter into partnerships, including with nonprofit organizations, to enhance the financial sustainability and public engagement of the museums in the United States Museum System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab369ddf-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tIII/s375"},"text":"Pub. L. 119–60, div. A, title III, § 375","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/839"},"text":"139 Stat. 839","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
