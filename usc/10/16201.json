{"tag":"section","attrib":{"id":"idabc10344-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201"},"text":null,"children":[{"tag":"num","attrib":{"value":"16201"},"text":"§ 16201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance: health-care professionals in reserve components","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabc10345-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purpose of obtaining adequate numbers of commissioned officers in the reserve components who are qualified in health professions, the Secretary of each military department may establish and maintain a program to provide financial assistance under this chapter to persons engaged in training that leads to a degree in medicine or dentistry or training in a health professions specialty that is critically needed in wartime. Under such a program, the Secretary concerned may agree to pay a financial stipend to persons engaged in health care education and training in return for a commitment to subsequent service in the Selected Reserve of the Ready Reserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc10346-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Medical and Dental School Students","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc10347-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under the stipend program under this chapter, the Secretary of the military department concerned may enter into an agreement with a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabc10348-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible to be appointed as an officer in a reserve component;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc10349-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is enrolled or has been accepted for enrollment in an institution in a course of study that results in a degree in medicine or dentistry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc1034a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" signs an agreement that, unless sooner separated, the person will—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idabc1034b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete the educational phase of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idabc1034c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept a reappointment or redesignation within the person’s reserve component, if tendered, based upon the person’s health profession, following satisfactory completion of the educational and intern programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idabc1034d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in a residency program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc1034e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if required by regulations prescribed by the Secretary of Defense, agrees to apply for, if eligible, and accept, if offered, residency training in a health profession skill which has been designated by the Secretary of Defense as a critically needed wartime skill.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc1034f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under the agreement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabc10350-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the military department concerned shall agree to pay the participant a stipend, in the amount determined under subsection (g), for the period or the remainder of the period that the student is satisfactorily progressing toward a degree in medicine or dentistry while enrolled in an accredited medical or dental school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc10351-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participant shall not be eligible to receive such stipend before appointment, designation, or assignment as an officer for service in the Ready Reserve;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc10352-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participant shall be subject to such active duty requirements as may be specified in the agreement and to active duty in time of war or national emergency as provided by law for members of the Ready Reserve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc10353-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participant shall agree to serve in the Selected Reserve, upon successful completion of the program, for the period of service applicable under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc10354-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabc10355-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subparagraph (B), the period for which a participant is required to serve in the Selected Reserve under the agreement pursuant to paragraph (2)(D) shall be one year for each period of six months, or part thereof, for which the participant is provided a stipend pursuant to the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc10356-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a participant who enters into a subsequent agreement under subsection (c) and successfully completes residency training in a specialty designated by the Secretary of Defense as a specialty critically needed by the military department in wartime, the requirement to serve in the Selected Reserve may be reduced to one year for each year, or part thereof, for which the stipend was provided while enrolled in medical or dental school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc10357-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Physicians and Dentists in Critical Wartime Specialties","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc10358-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under the stipend program under this chapter, the Secretary of the military department concerned may enter into an agreement with a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabc10359-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a graduate of a medical school or dental school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc1035a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible for appointment, designation, or assignment as a medical officer or dental officer in the Reserve of the armed force concerned or has been appointed as a medical or dental officer in the Reserve of the armed force concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc1035b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is enrolled or has been accepted for enrollment in a residency program for physicians or dentists in a medical or dental specialty designated by the Secretary concerned as a specialty critically needed by that military department in wartime.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc1035c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under the agreement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabc1035d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall agree to pay the participant a stipend, in an amount determined under subsection (g), for the period or the remainder of the period of the residency program in which the participant enrolls or is enrolled;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc1035e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participant shall not be eligible to receive such stipend before appointment, designation, or assignment as a medical officer or dental officer for service in the Ready Reserve;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc1035f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participant shall be subject to such active duty requirements as may be specified in the agreement and to active duty in time of war or national emergency as provided by law for members of the Ready Reserve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc10360-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participant shall agree to serve, upon successful completion of the program, one year in the Selected Reserve for each six months, or part thereof, for which the stipend is provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc10361-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Registered Nurses in Critical Specialties","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc10362-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under the stipend program under this chapter, the Secretary of the military department concerned may enter into an agreement with a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabc10363-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a registered nurse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc10364-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible for appointment as a Reserve officer for service in a reserve component in a Nurse Corps or as a nurse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc10365-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is enrolled or has been accepted for enrollment in an accredited program in nursing in a specialty designated by the Secretary concerned as a specialty critically needed by that military department in wartime.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc10366-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under the agreement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabc10367-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall agree to pay the participant a stipend, in an amount determined under subsection (g), for the period or the remainder of the period of the nursing program in which the participant enrolls or is enrolled;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc10368-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participant shall not be eligible to receive such stipend before being appointed as a Reserve officer for service in the Ready Reserve in a Nurse Corps or as a nurse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc10369-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participant shall be subject to such active duty requirements as may be specified in the agreement and to active duty in time of war or national emergency as provided by law for members of the Ready Reserve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc1036a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participant shall agree to serve, upon successful completion of the program, one year in the Selected Reserve for each six months, or part thereof, for which the stipend is provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc1036b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Baccalaureate Students in Nursing or Other Health Professions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc1036c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under the stipend program under this chapter, the Secretary of the military department concerned may enter into an agreement with a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabc1036d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will, upon completion of the program, be eligible to be appointed, designated, or assigned as a Reserve officer for duty as a nurse or other health professional; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc1036e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is enrolled, or has been accepted for enrollment in the third or fourth year of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idabc1036f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an accredited baccalaureate nursing program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idabc10370-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other accredited baccalaureate program leading to a degree in a health-care profession designated by the Secretary concerned as a profession critically needed by that military department in wartime.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc10371-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under the agreement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabc10372-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall agree to pay the participant a monthly stipend in an amount not to exceed the stipend rate in effect under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2121/d"},"text":"section 2121(d) of this title","children":[],"tail":" for the period or the remainder of the period of the baccalaureate program in which the participant enrolls or is enrolled;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc10373-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participant shall not be eligible to receive such stipend before enlistment in the Ready Reserve;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc10374-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participant shall be subject to such active duty requirements as may be specified in the agreement and to active duty in time of war or national emergency as provided by law for members of the Ready Reserve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc10375-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participant shall agree to serve, upon graduation from the baccalaureate program, one year in the Selected Reserve for each year, or part thereof, for which the stipend is paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc10376-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mental Health Professionals in Critical Wartime Specialties","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc10377-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under the stipend program under this chapter, the Secretary of the military department concerned may enter into an agreement with a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabc10378-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible to be appointed as an officer in a reserve component;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc10379-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is enrolled or has been accepted for enrollment in an institution in a course of study that results in a degree in clinical psychology or social work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc1037a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" signs an agreement that, unless sooner separated, the person will—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idabc1037b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/f/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete the educational phase of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idabc1037c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/f/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept a reappointment or redesignation within the person’s reserve component, if tendered, based upon the person’s health profession, following satisfactory completion of the educational and intern programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idabc1037d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/f/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in a residency program if required for clinical licensure in a mental health profession skill; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc1037e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if required by regulations prescribed by the Secretary of Defense, agrees to apply for, if eligible, and accept, if offered, residency training in a mental health profession skill that has been designated by the Secretary as a critically needed wartime skill.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc1037f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under the agreement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabc10380-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the military department concerned shall agree to pay the participant a stipend, in the amount determined under subsection (g), for the period or the remainder of the period that the student is satisfactorily progressing toward a degree in clinical psychology or social work while enrolled in a school accredited in the designated mental health discipline;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc10381-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participant shall not be eligible to receive such stipend before appointment, designation, or assignment as an officer for service in the Selected Reserve;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc10382-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participant shall be subject to such active duty requirements as may be specified in the agreement and to active duty in time of war or national emergency as provided by law for members of the Selected Reserve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc10383-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participant shall agree to serve, upon successful completion of the program, one year in the Selected Reserve for each six months, or part thereof, for which the stipend is provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc10384-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16201/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of Stipend","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of a stipend under an agreement under subsection (b), (c), (d), or (f) shall be the stipend rate in effect for participants in the Armed Forces Health Professions Scholarship Program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2121/d"},"text":"section 2121(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc10385-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tVII/s711/a/3"},"text":"Pub. L. 100–180, div. A, title VII, § 711(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1108"},"text":"101 Stat. 1108","children":[],"tail":", § 2128; renumbered § 16201 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1663/c/2"},"text":"Pub. L. 103–337, div. A, title XVI, § 1663(c)(2)","children":[],"tail":", (5), "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3007"},"text":"108 Stat. 3007","children":[],"tail":", 3008; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tVII/s736"},"text":"Pub. L. 104–106, div. A, title VII, § 736","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/383"},"text":"110 Stat. 383","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s539"},"text":"Pub. L. 107–107, div. A, title V, § 539","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1108"},"text":"115 Stat. 1108","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s515/b/1/WW"},"text":"Pub. L. 109–163, div. A, title V, § 515(b)(1)(WW)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3234"},"text":"119 Stat. 3234","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VI, § 616(c), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4486"},"text":"122 Stat. 4486","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tX/s1073/c/3"},"text":"Pub. L. 111–84, div. A, title X, § 1073(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2474"},"text":"123 Stat. 2474","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s556"},"text":"Pub. L. 112–81, div. A, title V, § 556","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1416"},"text":"125 Stat. 1416","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tVI/s618"},"text":"Pub. L. 113–66, div. A, title VI, § 618","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/782"},"text":"127 Stat. 782","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabc10386-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabc10387-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabc10388-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s618/b/1"},"text":"Pub. L. 113–66, § 618(b)(1)","children":[],"tail":", substituted “the Selected Reserve of the Ready Reserve” for “the Ready Reserve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s618/b/2"},"text":"Pub. L. 113–66, § 618(b)(2)","children":[],"tail":", added subpar. (D) and struck out former subpar. (D) which read as follows: “the participant shall agree to serve, upon successful completion of the program, one year in the Ready Reserve for each six months, or part thereof, for which the stipend is provided, to be served in the Selected Reserve or in the Individual Ready Reserve as specified in the agreement.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s618/a/1"},"text":"Pub. L. 113–66, § 618(a)(1)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “is eligible for appointment as—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) a Reserve officer for service in the Army Reserve in the Army Nurse Corps;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) a Reserve officer for service in the Navy Reserve in the Navy Nurse Corps; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iii) a Reserve officer for service in the Air Force Reserve with a view to designation as an Air Force nurse under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8067/e"},"text":"section 8067(e) of this title","children":[],"tail":"; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s618/a/2"},"text":"Pub. L. 113–66, § 618(a)(2)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “the participant shall not be eligible to receive such stipend before being appointed as a Reserve officer for service in the Ready Reserve—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) in the Nurse Corps of the Army or Navy; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) as an Air Force nurse of the Air Force;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s618/b/3"},"text":"Pub. L. 113–66, § 618(b)(3)","children":[],"tail":", added subpar. (D) and struck out former subpar. (D) which read as follows: “the participant shall agree to serve, upon successful completion of the program, one year in the Ready Reserve for each six months, or part thereof, for which the stipend is provided, to be served in the Selected Reserve or in the Individual Ready Reserve as specified in the agreement.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s618/b/4"},"text":"Pub. L. 113–66, § 618(b)(4)","children":[],"tail":", substituted “the Selected Reserve” for “the Ready Reserve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s618/c"},"text":"Pub. L. 113–66, § 618(c)","children":[],"tail":", amended subsec. (g) generally. Prior to amendment, text read as follows: “The amount of a stipend under an agreement under subsection (b), (c), or (f) shall be—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the stipend rate in effect for participants in the Armed Forces Health Professions Scholarship Program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2121/d"},"text":"section 2121(d) of this title","children":[],"tail":", if the participant has agreed to serve in the Selected Reserve; or"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) one-half of that rate, if the participant has agreed to serve in the Individual Ready Reserve.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsecs. (b)(2)(A), (c)(2)(A), (d)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s556/b/1"},"text":"Pub. L. 112–81, § 556(b)(1)","children":[],"tail":", substituted “subsection (g)” for “subsection (f)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s556/a/2"},"text":"Pub. L. 112–81, § 556(a)(2)","children":[],"tail":", added subsec. (f). Former subsec. (f) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s556/a/1"},"text":"Pub. L. 112–81, § 556(a)(1)","children":[],"tail":", (b)(2), redesignated subsec. (f) as (g) and substituted “subsection (b), (c), or (f)” for “subsection (b) or (c)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (e)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/s616/c"},"text":"Pub. L. 110–417, § 616(c)","children":[],"tail":". See 2008 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (e)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s616/c"},"text":"Pub. L. 110–417, § 616(c)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":", substituted “monthly stipend in an amount not to exceed the stipend rate in effect under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2121/d"},"text":"section 2121(d) of this title","children":[],"tail":"” for “stipend of $100 per month”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (d)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “Navy Reserve” for “Naval Reserve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s539/a"},"text":"Pub. L. 107–107, § 539(a)","children":[],"tail":", struck out “specialties critically needed in wartime” after “qualified in health professions” and substituted “training that leads to a degree in medicine or dentistry or training in a health professions specialty that is critically needed in wartime” for “training in such specialties” and “health care education and training” for “training in certain health care specialties”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s539/b/2"},"text":"Pub. L. 107–107, § 539(b)(2)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s539/b/1"},"text":"Pub. L. 107–107, § 539(b)(1)","children":[],"tail":", (c)(1), redesignated subsec. (b) as (c) and inserted “Wartime” after “Critical” in heading. Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s539/c/2"},"text":"Pub. L. 107–107, § 539(c)(2)","children":[],"tail":", inserted “or has been appointed as a medical or dental officer in the Reserve of the armed force concerned” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s539/e"},"text":"Pub. L. 107–107, § 539(e)","children":[],"tail":", substituted “subsection (f)” for “subsection (e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s539/d"},"text":"Pub. L. 107–107, § 539(d)","children":[],"tail":", substituted “one year in the Ready Reserve for each six months” for