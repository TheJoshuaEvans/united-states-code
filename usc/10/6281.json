{"tag":"section","attrib":{"id":"idaacb5942-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6281"},"text":null,"children":[{"tag":"num","attrib":{"value":"6281"},"text":"§ 6281.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of defense environmental cleanup funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaacb5943-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6281/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer Authority for Defense Environmental Cleanup Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy shall provide the manager of each field office of the Department of Energy with the authority to transfer defense environmental cleanup funds from a program or project under the jurisdiction of that office to another such program or project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacb5944-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6281/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacb5945-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6281/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than one transfer may be made to or from any program or project under subsection (a) in a fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacb5946-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6281/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount transferred to or from a program or project in any one transfer under subsection (a) may not exceed $5,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacb5947-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6281/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A transfer may not be carried out by a manager of a field office under subsection (a) unless the manager determines that the transfer is necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacb5948-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6281/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address a risk to health, safety, or the environment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacb5949-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6281/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assure the most efficient use of defense environmental cleanup funds at the field office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacb594a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6281/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds transferred pursuant to subsection (a) may not be used for an item for which Congress has specifically denied funds or for a new program or project that has not been authorized by Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacb594b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6281/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemption From Reprogramming Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirements of section 6272 shall not apply to transfers of funds pursuant to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacb594c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6281/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, acting through the Assistant Secretary of Energy for Environmental Management, shall notify Congress of any transfer of funds pursuant to subsection (a) not later than 30 days after such transfer occurs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacb594d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6281/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacb594e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6281/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “program or project” means, with respect to a field office of the Department of Energy, a program or project that is for defense environmental cleanup activities necessary for national security programs of the Department, that is being carried out by that office, and for which defense environmental cleanup funds have been authorized and appropriated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacb594f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6281/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “defense environmental cleanup funds” means funds appropriated to the Department of Energy pursuant to an authorization for carrying out defense environmental cleanup activities necessary for national security programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaacb5950-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1430"},"text":"139 Stat. 1430","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaacb5951-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaacb5952-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaacb5953-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2750"},"text":"section 2750 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaacb5954-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) to (4) headings which read as follows: “"},{"tag":"inline","attrib":{},"text":"Number of transfers","children":[],"tail":"”, “"},{"tag":"inline","attrib":{},"text":"Amounts transferred","children":[],"tail":"”, “"},{"tag":"inline","attrib":{},"text":"Determination required","children":[],"tail":"”, and “"},{"tag":"inline","attrib":{},"text":"Impermissible uses","children":[],"tail":"”, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
