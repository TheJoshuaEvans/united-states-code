{"tag":"section","attrib":{"id":"ida8fa69af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596"},"text":null,"children":[{"tag":"num","attrib":{"value":"1596"},"text":"§ 1596.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign language proficiency: special pay for proficiency beneficial for intelligence interests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8fa69b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense may pay special pay under this section to a civilian officer or employee of the Department of Defense who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fa69b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been certified as being proficient in a foreign language identified by the Secretary of Defense as being a language in which proficiency by civilian personnel of the Department is important for the effective collection, production, or dissemination of foreign intelligence information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa69b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is serving in a position, or is subject to assignment to a position, in which proficiency in that language facilitates performance of officially assigned intelligence or intelligence-related duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa69b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The annual rate of special pay under subsection (a) shall be determined by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa69b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Special pay under this section may be paid in addition to any compensation authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1602"},"text":"section 1602 of this title","children":[],"tail":" for which an officer or employee is eligible."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8fa69b5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/193/tV/s501/a/1"},"text":"Pub. L. 101–193, title V, § 501(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1707"},"text":"103 Stat. 1707","children":[],"tail":", § 1592; renumbered § 1596, "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIV/s1484/a"},"text":"Pub. L. 101–510, div. A, title XIV, § 1484(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1715"},"text":"104 Stat. 1715","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVI/s1633/e/2"},"text":"Pub. L. 104–201, div. A, title XVI, § 1633(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2752"},"text":"110 Stat. 2752","children":[],"tail":"; "},{"tag":"ref","attrib"