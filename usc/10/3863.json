{"tag":"section","attrib":{"id":"idaa3ea940-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3863"},"text":null,"children":[{"tag":"num","attrib":{"value":"3863"},"text":"§ 3863.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of amounts collected from contractor during the pendency of contract dispute","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa3ea941-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3863/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding sections 1552(a) and 3302(b) of title 31, any amount, including interest, collected from a contractor as a result of a claim made by a military department or Defense Agency under chapter 71 of title 41, shall remain available in accordance with this section to pay—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa3ea942-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3863/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any settlement of the claim by the parties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa3ea943-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3863/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any judgment rendered in the contractor’s favor on an appeal of the decision on that claim to the Armed Services Board of Contract Appeals under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s7104/a"},"text":"section 7104(a) of title 41","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa3ea944-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3863/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any judgment rendered in the contractor’s favor in an action on that claim in a court of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa3ea945-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3863/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of Availability","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa3ea946-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3863/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The period of availability of an amount under subsection (a), in connection with a claim—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa3ea947-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3863/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" expires 180 days after the expiration of the period for bringing an action on that claim in the United States Court of Federal Claims under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s7104/b"},"text":"section 7104(b) of title 41","children":[],"tail":" if, within that 180-day period—"}],"tail":null},{"tag":"clause","attrib":{"id":"idaa3ea948-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3863/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no appeal on the claim is commenced at the Armed Services Board of Contract Appeals under section 7104(a) of such title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa3ea949-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3863/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no action on the claim is commenced in a court of the United States; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa3ea94a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3863/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if not expiring under subparagraph (A), expires—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa3ea94b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3863/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a settlement of the claim, 180 days after the date of the settlement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa3ea94c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3863/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a judgment rendered on the claim in an appeal to the Armed Services Board of Contract Appeals under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s7104/a"},"text":"section 7104(a) of title 41","children":[],"tail":" or an action in a court of the United States, 180 days after the date on which the judgment becomes final and not appealable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa3ea94d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3863/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" While available under this section, an amount may be obligated or expended only for a purpose described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa3ea94e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3863/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon the expiration of the period of availability of an amount under paragraph (1), the amount shall be covered into the Treasury as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa3ea94f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVIII/s831/a"},"text":"Pub. L. 105–85, div. A, title VIII, § 831(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1841"},"text":"111 Stat. 1841","children":[],"tail":", § 2410m; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tX/s1031/a/21"},"text":"Pub. L. 108–136, div. A, title X, § 1031(a)(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1598"},"text":"117 Stat. 1598","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/b/32"},"text":"Pub. L. 111–350, § 5(b)(32)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3845"},"text":"124 Stat. 3845","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tX/s1061/15"},"text":"Pub. L. 112–81, div. A, title X, § 1061(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1583"},"text":"125 Stat. 1583","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1071/a/8"},"text":"Pub. L. 113–291, div. A, title X, § 1071(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3504"},"text":"128 Stat. 3504","children":[],"tail":"; renumbered § 3863, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1836/b"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1836(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4241"},"text":"134 Stat. 4241","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa3ea950-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa3ea951-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa3ea952-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2410m"},"text":"section 2410m of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(1)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1071/a/8/A"},"text":"Pub. L. 113–291, § 1071(a)(8)(A)","children":[],"tail":", substituted “section 7104(a) of such title” for “section 7 of such Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1071/a/8/B"},"text":"Pub. L. 113–291, § 1071(a)(8)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t41/s7104/a"},"text":"section 7104(a) of title 41","children":[],"tail":"” for “section 7 of the Contract Disputes Act of 1978”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/b/32/A"},"text":"Pub. L. 111–350, § 5(b)(32)(A)","children":[],"tail":", substituted “chapter 71 of title 41” for “the Contract Disputes Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s601"},"text":"41 U.S.C. 601","children":[],"tail":" et seq.)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/b/32/B"},"text":"Pub. L. 111–350, § 5(b)(32)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t41/s7104/a"},"text":"section 7104(a) of title 41","children":[],"tail":"” for “section 7 of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s606"},"text":"41 U.S.C. 606","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/b/32/C"},"text":"Pub. L. 111–350, § 5(b)(32)(C)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t41/s7104/b"},"text":"section 7104(b) of title 41","children":[],"tail":"” for “section 10(a) of the Contract Disputes Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s609/a"},"text":"41 U.S.C. 609(a)","children":[],"tail":")” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" struck out subsec. (c), which required submission of annual report on amounts available for obligation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1031/a/21/A"},"text":"Pub. L. 108–136, § 1031(a)(21)(A)","children":[],"tail":", substituted “Annual Report” for “Reporting Requirement” in heading and “Not later than 60 days after the end of each fiscal year” for “Each year” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1031/a/21/B"},"text":"Pub. L. 108–136, § 1031(a)(21)(B)","children":[],"tail":", inserted “at the end of such fiscal year” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1031/a/21/C"},"text":"Pub. L. 108–136, § 1031(a)(21)(C)","children":[],"tail":", substituted “under this section during that fiscal year” for “during the year preceding the year in which the report is submitted”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1031/a/21/D"},"text":"Pub. L. 108–136, § 1031(a)(21)(D)","children":[],"tail":", substituted “under this section during that fiscal year” for “in such preceding year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1031/a/21/E"},"text":"Pub. L. 108–136, § 1031(a)(21)(E)","children":[],"tail":", substituted “under this section during that fiscal year” for “in such preceding year”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa3ea953-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa3ea954-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
