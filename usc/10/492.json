" inserted “, and the ability to meet operational availability requirements for,” after “military effectiveness of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s490a"},"text":"section 490a of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7c6cbd6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7c6cbd7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Initial Assessment and Reports","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tX/s1041/b"},"text":"Pub. L. 112–81, div. A, title X, § 1041(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1574"},"text":"125 Stat. 1574","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1031/b/4"},"text":"Pub. L. 112–239, div. A, title X, § 1031(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1919"},"text":"126 Stat. 1919","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tX/s1091/b/6"},"text":"Pub. L. 113–66, div. A, title X, § 1091(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/876"},"text":"127 Stat. 876","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/66/dA/tX/s1091/b/6"},"text":"“Not later than 30 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":"], each covered official, as such term is defined in subsection (d) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s492"},"text":"section 492 of title 10","children":[],"tail":", United States Code, shall conduct an initial assessment as described by subsection (a) of such section and submit an initial report as described by subsection (b) of such section. The requirements of subsection (c) of such section shall apply with respect to the report submitted under this subsection.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tX/s1091/b"},"text":"Pub. L. 113–66, div. A, title X, § 1091(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/876"},"text":"127 Stat. 876","children":[],"tail":", provided in part that the amendment made by section 1091(b)(6) is effective as of "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" as enacted.]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
