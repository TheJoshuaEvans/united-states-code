{"tag":"section","attrib":{"id":"ida7c6cbb7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492"},"text":null,"children":[{"tag":"num","attrib":{"value":"492"},"text":"§ 492.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial assessment and report on the delivery platforms for nuclear weapons and the nuclear command and control system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7c6cbb8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Biennial Assessments","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7c6cbb9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each even-numbered year, each covered official shall assess the safety, security, reliability, sustainability, performance, and military effectiveness of, and the ability to meet operational availability requirements for, the systems described in paragraph (2) for which such official has responsibility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c6cbba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The systems described in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7c6cbbb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each type of delivery platform for nuclear weapons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7c6cbbc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The nuclear command and control system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7c6cbbd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Biennial Report","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7c6cbbe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than December 1 of each even-numbered year, each covered official shall submit to the Secretary of Defense and the Nuclear Weapons Council established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s179"},"text":"section 179 of this title","children":[],"tail":" a report on the assessments conducted under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c6cbbf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each report under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7c6cbc0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The results of the assessment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7c6cbc1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An identification and discussion of any capability gaps or shortfalls with respect to the systems described in subsection (a)(2) covered under the assessment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7c6cbc2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An identification and discussion of any risks with respect to meeting mission or capability requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7c6cbc3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an assessment by the Commander of the United States Strategic Command, if the Commander identifies any deficiency with respect to a nuclear weapons delivery platform covered under the assessment, a discussion of the relative merits of any other nuclear weapons delivery platform type or compensatory measure that would accomplish the mission of such nuclear weapons delivery platform.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7c6cbc4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An identification and discussion of any matter having an adverse effect on the capability of the covered official to accurately determine the matters covered by the assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7c6cbc5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to President and Congress","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7c6cbc6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than March 1 of each year following a year for which a report under subsection (b) is submitted, the Secretary of Defense shall submit to the President a report containing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7c6cbc7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each report under subsection (b) submitted during the previous year, as originally submitted to the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7c6cbc8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any comments that the Secretary considers appropriate with respect to each such report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7c6cbc9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any conclusions that the Secretary considers appropriate with respect to the safety, security, reliability, sustainability, performance, or military effectiveness of the systems described in subsection (a)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7c6cbca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information that the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c6cbcb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than March 15 of each year during which a report under paragraph (1) is submitted, the President shall transmit to the congressional defense committees the report submitted to the President under paragraph (1), including any comments the President considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c6cbcc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each report under this subsection may be in classified form if the Secretary of Defense determines it necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7c6cbcd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Official Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered official” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7c6cbce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commander of the United States Strategic Command;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c6cbcf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Strategic Systems Program of the Navy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c6cbd0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commander of the Global Strike Command of the Air Force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c6cbd1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s492/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commander of the United States Air Forces in Europe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7c6cbd2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tX/s1041/a"},"text":"Pub. L. 112–81, div. A, title X, § 1041(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1573"},"text":"125 Stat. 1573","children":[],"tail":", § 490a; renumbered § 492, "},{"ta