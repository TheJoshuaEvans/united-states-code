{"tag":"section","attrib":{"id":"ida93ace98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h"},"text":null,"children":[{"tag":"num","attrib":{"value":"2200h"},"text":"§ 2200h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program elements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida93ace99-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing the program, the Secretary of Defense shall determine the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93ace9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A methodology to identify and target critical skills gaps in Department of Defense occupations relating to acquisition, science, engineering, or other civilian occupations determined by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93ace9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A mechanism to track and report the success of the program in eliminating any critical skills gaps identified under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93ace9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Criteria for an accredited civilian educational institution to participate in the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93ace9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The eligibility of a student to become a member of the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93ace9e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Criteria required for a member of the program to receive financial assistance from the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93ace9f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term of service as an employee of the Department of Defense required for a member of the program to receive such financial assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93acea0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Criteria required for a member of the program to be released from a term of service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93acea1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The method by which a successful graduate of the program may gain immediate employment in the Department of Defense, in accordance with subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93acea2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Resources required for implementation of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93acea3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hiring Authority.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93acea4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an element of the Department of Defense that partners with an institution participating in the program may, without regard to the provisions of subchapter I of chapter 33 of title 5, appoint a member of the program to a position in such element for a term of one year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93acea5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Graduates.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida93acea6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of an element described in paragraph (1) may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida93acea7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" renew the appointment ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" a successful graduate of the program serving a one-year term under such paragraph until such graduate is appointed to a permanent position in such element, except that the appointment may not be renewed for more than a total of four one-year terms; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida93acea8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without regard to the provisions of subchapter I of chapter 33 of title 5, appoint a graduate holding a position under an appointment renewed under clause (i) to a vacant position in the civil service (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2101"},"text":"section 2101 of title 5","children":[],"tail":", United States Code) in the Department."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida93acea9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Level","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The position of a graduate in a term or permanent position described in subparagraph (A) shall be classified at the level of GS–9 under the General Schedule under subchapter III of chapter 53 of title 5, or an equivalent level for which the participant is qualified, without regard to any minimum time-in-grade or time-based experience requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida93aceaa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority under this section may not be used for more than 60 graduates of the program in any calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93aceab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida93aceac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The basic pay of an individual appointed under this subsection shall be paid from amounts available in the Department of Defense Acquisition Workforce Development Account established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1705"},"text":"section 1705 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida93acead-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Payment under subparagraph (A) may be made only during the term of the appointment of such an individual and may not exceed a total of four years of payments for any one individual, including renewals under paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida93aceae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relation to other authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this paragraph shall be construed to affect the authority of the Secretary of Defense to pay compensation from other available appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93aceaf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200h/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority under this subsection shall terminate on ","children":[{"tag":"date","attrib":{"date":"2029-12-31"},"text":"December 31, 2029","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida93aceb0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVIII/s860/a"},"text":"Pub. L. 116–92, div. A, title VIII, § 860(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1514"},"text":"133 Stat. 1514","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tX/s1081/a/4/A"},"text":"Pub. L. 116–283, div. A, title X, § 1081(a)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3870"},"text":"134 Stat. 3870","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVIII/s823/a"},"text":"Pub. L. 119–60, div. A, title VIII, § 823(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/954"},"text":"139 Stat. 954","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida93aceb1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida93aceb2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida93aceb3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s823/a/1"},"text":"Pub. L. 119–60, § 823(a)(1)","children":[],"tail":", (2), inserted “, in accordance with subsection (b)” before period at end of par. (8), designated existing provisions as subsec. (a), and inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s823/a/3"},"text":"Pub. L. 119–60, § 823(a)(3)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “§” for “SEC.” in section designation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
