{"tag":"section","attrib":{"id":"idab8ef6c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10219"},"text":null,"children":[{"tag":"num","attrib":{"value":"10219"},"text":"§ 10219.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suicide prevention and resilience program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab8ef6ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10219/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall establish and carry out a program to provide members of the National Guard and Reserves and their families with training in suicide prevention, resilience, and community healing and response to suicide, including provision of such training at Yellow Ribbon Reintegration Program events and activities authorized under section 582 of the National Defense Authorization Act for Fiscal Year 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s10101"},"text":"10 U.S.C. 10101","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8ef6cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10219/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Suicide Prevention Training","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the program, the Secretary shall provide members of the National Guard and Reserves with training in suicide prevention. Such training may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8ef6cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10219/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing the warning signs for suicide and teaching effective strategies for prevention and intervention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef6cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10219/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examining the influence of military culture on risk and protective factors for suicide; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef6ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10219/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaging in interactive case scenarios and role plays to practice effective intervention strategies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8ef6cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10219/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Community Response Training","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the program, the Secretary shall provide the families and communities of members of the National Guard and Reserves with training in responses to suicide that promote individual and community healing. Such training may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8ef6d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10219/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing collaboration among community members and local service providers to create an integrated, coordinated community response to suicide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef6d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10219/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communicating best practices for preventing suicide, including safe messaging, appropriate memorial services, and media guidelines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef6d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10219/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addressing the impact of suicide on the military and the larger community, and the increased risk that can result; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef6d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10219/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" managing resources to assist key community and military service providers in helping the families, friends, and fellow servicemembers of a suicide victim through the processes of grieving and healing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8ef6d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10219/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Community Training Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The program shall include the provision of assistance with such training to the local communities of those servicemembers and families, to be provided in coordination with local community programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8ef6d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10219/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Collaboration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out the program, the Secretary shall collect and analyze “lessons learned” and suggestions from State National Guard and Reserve organizations with existing or developing suicide prevention and community response programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8ef6d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10219/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Outreach for Certain Members of the Reserve Components","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8ef6d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10219/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon the request of an adjutant general of a State, the Secretary may share with the adjutant general the contact information of members described in paragraph (2) who reside in such State in order for the adjutant general to include such members in suicide prevention efforts conducted under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef6d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10219/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Members described in this paragraph are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab8ef6d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10219/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the Individual Ready Reserve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab8ef6da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10219/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of a reserve component who are individual mobilization augmentees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8ef6db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10219/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Triennial Evaluation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall evaluate the program every third year beginning in 2022 until the program terminates to determine whether the program effectively—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8ef6dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10219/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides training and assistance under subsections (b), (c), and (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8ef6dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10219/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implements subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab8ef6de-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tV/s581/a/1"},"text":"Pub. L. 112–239, div. A, title V, § 581(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1764"},"text":"126 Stat. 1764","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tV/s511/a"},"text":"Pub. L. 113–66, div. A, title V, § 511(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/751"},"text":"127 Stat. 751","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tV/s565"},"text":"Pub. L. 114–328, div. A, title V, § 565","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2138"},"text":"130 Stat. 2138","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tV/s544"},"text":"Pub. L. 115–91, div. A, title V, § 544","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1396"},"text":"131 Stat. 1396","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tV/s515"},"text":"Pub. L. 116–92, div. A, title V, § 515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1349"},"text":"133 Stat. 1349","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tV/s514"},"text":"Pub. L. 116–283, div. A, title V, § 514","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3588"},"text":"134 Stat. 3588","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab8ef6df-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab8ef6e0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idab8ef6e1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 582 of the National Defense Authorization Act for Fiscal Year 2008, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s582"},"text":"section 582 of Pub. L. 110–181","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10101"},"text":"section 10101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab8ef6e2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" struck out subsec. (h). Text read as follows: “The program under this section shall terminate on "},{"tag":"date","attrib":{"date":"2025-10-01"},"text":"October 1, 2025","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" added subsec. (g). Former subsec. (g) redesignated (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s515/1"},"text":"Pub. L. 116–92, § 515(1)","children":[],"tail":", (2), redesignated subsec. (g) as (h) and substituted “2025” for “2020”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2020-10-01"},"text":"October 1, 2020","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2018-10-01"},"text":"October 1, 2018","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2018-10-01"},"text":"October 1, 2018","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2017-10-01"},"text":"October 1, 2017","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" added subsec. (f) and redesignated former subsec. (f) as (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab8ef6e3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab8ef6e4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"National Guard Suicide Prevention Pilot Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVII/s739"},"text":"Pub. L. 116–92, div. A, title VII, § 739","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1464"},"text":"133 Stat. 1464","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dA/tVII/s739"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pilot Program Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief of the National Guard Bureau may carry out a pilot program to expand suicide prevention and intervention efforts at the community level through the use of a mobile application that provides the capability for a member of the National Guard to receive prompt support, including access to a behavioral health professional, on a smartphone, tablet computer, or other handheld mobile device.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The pilot program shall include, subject to such conditions as the Secretary may prescribe—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use by members of the National Guard of an existing mobile application that provides the capability described in subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and use of a new mobile application that provides such capability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility and Participation Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief of the National Guard Bureau shall establish requirements with respect to eligibility and participation in the pilot program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment Prior to Pilot Program Commencement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Prior to commencement of the pilot program, the Chief of the National Guard Bureau shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an assessment of existing prevention and intervention efforts of the National Guard in each State that include the use of mobile applications that provide the capability described in subsection (a) to determine best practices for providing immediate and localized care through the use of such mobile applications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the feasibility of expanding existing programs on a national scale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities of Entities Participating in Pilot Program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each entity that participates in the pilot program shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" share best practices with other entities participating in the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annually assess outcomes with respect to members of the National Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The pilot program shall terminate on the date that is three years after the date on which the pilot program commenced.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Chief of the National Guard Bureau commences the pilot program authorized under subsection (a), not later than 180 days after the date of the commencement of such program, the Chief shall submit to the Committees on Armed Services of the Senate and the House of Representatives a report containing a description of the pilot program and such other matters as the Chief considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Final report.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the termination of the pilot program, the Chief of the National Guard Bureau shall submit to the Committees on Armed Services of the Senate and the House of Representatives a report on such pilot program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matters included","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under subparagraph (A) shall include the following:","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the pilot program, including any partnerships entered into by the Chief of the National Guard Bureau under the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the effectiveness of the pilot program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of costs associated with the implementation of the pilot program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"“(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The estimated costs of making the pilot program permanent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"“(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A recommendation as to whether the pilot program should be extended or made permanent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"“(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other recommendations for legislative or administrative action as the Chief of the National Guard Bureau considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"“(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘State’ means each of the several States, the District of Columbia, the Commonwealth of Puerto Rico, American Samoa, Guam, the United States Virgin Islands, and the Commonwealth of the Northern Mariana Islands.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
