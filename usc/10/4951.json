{"tag":"section","attrib":{"id":"idaaaecfc5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4951"},"text":null,"children":[{"tag":"num","attrib":{"value":"4951"},"text":"§ 4951.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaaecfc6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4951/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “eligible entity” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaaecfc7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4951/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaaecfc8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4951/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A local government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaaecfc9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4951/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nonprofit organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaaecfca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4951/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A tribal organization, as defined in section 4(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of the Indian Self-Determination and Education Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"25 U.S.C. 5304","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")), or an economic enterprise, as defined in section 3(e) of the Indian Financing Act of 1974 ("},{"tag":"ref","attrib":{"href":"/us/pl/93/262"},"text":"Public Law 93–262","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1452/e"},"text":"25 U.S.C. 1452(e)","children":[],"tail":"), whether or not such economic enterprise is organized for profit purposes or nonprofit purposes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaaecfcb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4951/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “distressed area” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaaecfcc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4951/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the area of a unit of local government (or such area excluding the area of any defined political jurisdiction within the area of such unit of local government) that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaaaecfcd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4951/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a per capita income of 80 percent or less of the State average; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaaaecfce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4951/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","