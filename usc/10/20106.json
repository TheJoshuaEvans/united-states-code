{"tag":"section","attrib":{"id":"idabc82f59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106"},"text":null,"children":[{"tag":"num","attrib":{"value":"20106"},"text":"§ 20106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Orders to active duty: without consent of member","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabc82f5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members in a Space Force Active Status.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc82f5b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Space Force in a space force active status who is not on sustained duty, may, without the consent of the member, be ordered to active duty or inactive duty in the same manner as a member of a reserve component ordered to active duty or inactive duty under the provisions of chapter 1209 of this title and any other provision of law authorizing the order to active duty of a member of a reserve component in an active status without the consent of the member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of chapter 1209 of this title, or other applicable provisions of law, pertaining to a member of the Ready Reserve when ordered to active duty shall apply to a member of the Space Force who is in a space force active status when ordered to active duty under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f5d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12304"},"text":"section 12304 of this title","children":[],"tail":" pertaining to members in the Individual Ready Reserve mobilization category shall apply to a member of the Space Force who is designated an Individual Ready Guardian when ordered to active duty who meets the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s20102/b"},"text":"section 20102(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc82f5e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members in a Space Force Inactive Status.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc82f5f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member of the Space Force in a space force inactive status may be ordered to active duty under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabc82f60-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of chapter 1209 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc82f61-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other provision of law authorizing the order to active duty of a member of a reserve component in an inactive status; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc82f62-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms of any agreement entered into by the member under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20103"},"text":"section 20103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f63-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of chapter 1209 of this title, or other applicable provisions of law, pertaining to the Standby Reserve shall apply to a member of the Space Force who is in a space force inactive service when ordered to active duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc82f64-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members in a Space Force Retired Status.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc82f65-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapters 39 and 1209 of this title include provisions authorizing the order to active duty of a member of the Space Force in a space force retired status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f66-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of sections 688, 688a, and 12407 of this title pertaining to a retired member or a member of the Retired Reserve shall apply to a member of the Space Force in a space force retired status when ordered to active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f67-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s689"},"text":"section 689 of this title","children":[],"tail":" pertaining to a retired member ordered to active duty shall apply to a member of the Space Force in a space force retired status who is ordered to active duty."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc82f68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Applicable Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following provisions of chapter 1209 of this title shall apply to a member of the Space Force ordered to active duty in the same manner as to a Reserve or member of the Retired Reserve ordered to active duty:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc82f69-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12305, relating to the authority of the President to suspend certain laws relating to promotion, retirement, and separation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f6a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12308, relating to retention after becoming qualified for retired pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f6b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12313, relating to release from active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f6c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12314, relating to kinds of duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f6d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12315, relating to duty with or without pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f6e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12316, relating to payment of certain Reserves while on duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f6f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12317, relating to theological students; limitations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20106/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12320, relating to grade in which ordered to active duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc82f71-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1715"},"text":"Pub. L. 118–31, div. A, title XVII, § 1715","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/629"},"text":"137 Stat. 629","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s521/m"},"text":"Pub. L. 118–159, div. A, title V, § 521(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1882"},"text":"138 Stat. 1882","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabc82f72-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabc82f73-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabc82f74-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" struck out “pertaining” before “shall apply” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
