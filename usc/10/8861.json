{"tag":"section","attrib":{"id":"idab50dc97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8861"},"text":null,"children":[{"tag":"num","attrib":{"value":"8861"},"text":"§ 8861.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interrogation of witnesses by prize commissioners","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Witnesses before the prize commissioners shall be questioned separately, on interrogatories prescribed by the court, in the manner usual in prize courts. Without special authority from the court, the witnesses may not see the interrogatories, documents, or papers, or consult with counsel or with other persons interested in the cause. Witnesses who have the rights of neutrals shall be discharged as soon as practicable.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab50dc98-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/477"},"text":"70A Stat. 477","children":[],"tail":", § 7661; renumbered § 8861, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/9"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab50dc99-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab50dc9a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab50dc9b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children"