{"tag":"section","attrib":{"id":"ida9d0f3c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2785"},"text":null,"children":[{"tag":"num","attrib":{"value":"2785"},"text":"§ 2785.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remittance addresses: regulation of alterations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense, acting through the Under Secretary of Defense (Comptroller), shall prescribe regulations setting forth controls on alteration of remittance addresses. Those regulations shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9d0f3c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2785/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a remittance address for a disbursement that is provided by an officer or employee of the Department of Defense authorizing or requesting the disbursement is not altered by any officer or employee of the department authorized to prepare the disbursement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d0f3c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2785/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a remittance address for a disbursement is altered only if the alteration—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9d0f3c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2785/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is requested by the person to whom the disbursement is authorized to be remitted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9d0f3ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2785/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is made by an officer or employee authorized to do so who is not an officer or employee referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9d0f3cb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tIX/s933/a/1"},"text":"Pub. L. 106–65, div. A, title IX, § 933(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/729"},"text":"113 Stat. 729","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9d0f3cc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9d0f3cd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9d0f3ce-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tIX/s933/b/2"},"text":"Pub. L. 106–65, div. A, title IX, § 933(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/730"},"text":"113 Stat. 730","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/65/dA/tIX/s933/b/2"},"text":"“Regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2785"},"text":"section 2785 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall be prescribed not later than 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
