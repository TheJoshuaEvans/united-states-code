{"tag":"section","attrib":{"id":"ida7d040e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s502"},"text":null,"children":[{"tag":"num","attrib":{"value":"502"},"text":"§ 502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enlistment oath: who may administer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7d040e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enlistment Oath","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each person enlisting in an armed force shall take the following oath:","children":[{"tag":"p","attrib":{},"text":"“I, __________, do solemnly swear (or affirm) that I will support and defend the Constitution of the United States against all enemies, foreign and domestic; that I will bear true faith and allegiance to the same; and that I will obey the orders of the President of the United States and the orders of the officers appointed over me, according to regulations and the Uniform Code of Military Justice. So help me God.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7d040e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Who May Administer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The oath may be taken before the President, the Vice-President, the Secretary of Defense, any commissioned officer, or any other person designated under regulations prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7d040e6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/17"},"text":"70A Stat. 17","children":[],"tail":", § 501; "},{"tag":"ref","attrib":{"href":"/us/pl/87/751/s1"},"text":"Pub. L. 87–751, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-05"},"text":"Oct. 5, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/748"},"text":"76 Stat. 748","children":[],"tail":"; renumbered § 502, "},{"tag":"ref","attrib":{"href":"/us/pl/90/235/s2/a/1/A"},"text":"Pub. L. 90–235, § 2(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/753"},"text":"81 Stat. 753","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVI/s653/a/1"},"text":"Pub. L. 101–189, div. A, title VI, § 653(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1462"},"text":"103 Stat. 1462","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s595/a"},"text":"Pub. L. 109–364, div. A, title V, § 595(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2235"},"text":"120 Stat. 2235","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7d040e7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida7d040e8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida7d040e9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","childre