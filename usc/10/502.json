":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/146"},"text":"64 Stat. 146","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “or affirmation” are omitted as covered by the definition of the word “oath” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t1/s1"},"text":"section 1 of title 1","children":[],"tail":". The words “of any armed force” are inserted in the last sentence, since they are necessarily implied by their use in the source statute."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7d040ea-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida7d040eb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Uniform Code of Military Justice, referred to in the oath, is classified to chapter 47 (§ 801 et seq.) of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida7d040ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 502 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s500b"},"text":"section 500b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7d040ed-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, struck out concluding provisions which read as follows: “This oath may be taken before any commissioned officer of any armed force.”, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" struck out “or affirmation” after “This oath”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/751"},"text":"Pub. L. 87–751","children":[],"tail":" substituted “support and defend the Constitution of the United States against all enemies, foreign and domestic; that I will bear true faith and allegiance to the same” for “bear true faith and allegiance to the United States of America; that I will serve them honestly and faithfully against all their enemies whomsoever” and inserted “So help me God” in the oath, and “or affirmation” in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7d040ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7d040ef-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1962 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/751/s3"},"text":"Pub. L. 87–751, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-05"},"text":"Oct. 5, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/748"},"text":"76 Stat. 748","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/87/751/s3"},"text":"“This Act [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s304"},"text":"section 304 of Title 32","children":[],"tail":", National Guard] does not affect any oath taken before one year after its enactment ["},{"tag":"date","attrib":{"date":"1962-10-05"},"text":"Oct. 5, 1962","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
