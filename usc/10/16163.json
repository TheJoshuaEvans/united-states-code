{"tag":"section","attrib":{"id":"idabbe92cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163"},"text":null,"children":[{"tag":"num","attrib":{"value":"16163"},"text":"§ 16163.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for educational assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabbe92ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On or after ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":", a member of a reserve component is entitled to educational assistance under this chapter if the member—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabbe92cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served on active duty in support of a contingency operation for 90 consecutive days or more; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbe92d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a member of the Army National Guard of the United States or Air National Guard of the United States, performed full time National Guard duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s502/f"},"text":"section 502(f) of title 32","children":[],"tail":" for 90 consecutive days or more when authorized by the President or Secretary of Defense for the purpose of responding to a national emergency declared by the President and supported by Federal funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabbe92d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disabled Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding the eligibility requirements in subsection (a), a member who was ordered to active service as prescribed under subsection (a)(1) or (a)(2) but is released from duty before completing 90 consecutive days because of an injury, illness or disease incurred or aggravated in the line of duty shall be entitled to educational assistance under this chapter at the rate prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s16162/c/4/A"},"text":"section 16162(c)(4)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabbe92d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Written Notification","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabbe92d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member who becomes entitled to educational assistance under subsection (a) shall be given a statement in writing prior to release from active service that summarizes the provisions of this chapter and stating clearly and prominently the substance of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s16165"},"text":"section 16165 of this title","children":[],"tail":" as such section may apply to the member."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbe92d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the request of the Secretary of Veterans Affairs, the Secretary concerned shall transmit a notice of entitlement for each such member to that Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabbe92d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bar From Dual Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member who qualifies for educational assistance under this chapter may not receive credit for such service under both the program established by chapter 30 of title 38 and the program established by this chapter but shall make an irrevocable election (in such form and manner as the Secretary of Veterans Affairs may prescribe) as to the program to which such service is to be credited.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabbe92d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bar From Duplication of Educational Assistance Allowance","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabbe92d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), an individual entitled to educational assistance under this chapter who is also eligible for educational assistance under chapter 1606 of this title, chapter 30, 31, 32, 33, or 35 of title 38, or under the Hostage Relief Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/449"},"text":"Public Law 96–449","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5561"},"text":"5 U.S.C. 5561","children":[],"tail":" note) may not receive assistance under more than one such program and shall elect (in such form and manner as the Secretary of Veterans Affairs may prescribe) under which program the member elects to receive educational assistance."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbe92d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The restriction on duplication of educational assistance under paragraph (1) does not apply to the entitlement of educational assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s16131/i"},"text":"section 16131(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabbe92d9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s527/a"},"text":"Pub. L. 108–375, div. A, title V, § 527(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1892"},"text":"118 Stat. 1892","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s540/a"},"text":"Pub. L. 109–163, div. A, title V, § 540(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3251"},"text":"119 Stat. 3251","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/252/tV/s5003/b/1/C"},"text":"Pub. L. 110–252, title V, § 5003(b)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2375"},"text":"122 Stat. 2375","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tX/s1073/a/36"},"text":"Pub. L. 111–84, div. A, title X, § 1073(a)(36)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2474"},"text":"123 Stat. 2474","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabbe92da-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabbe92db-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idabbe92dc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Hostage Relief Act of 1980, referred to in subsec. (e)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/449"},"text":"Pub. L. 96–449","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1967"},"text":"94 Stat. 1967","children":[],"tail":", as amended, which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5561"},"text":"section 5561 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabbe92dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" substituted “such program” for “such programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252"},"text":"Pub. L. 110–252","children":[],"tail":" inserted “33,” after “32,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “Secretary of Veterans Affairs” for “Secretary concerned”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabbe92de-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idabbe92df-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252/tV/s5003/d"},"text":"Pub. L. 110–252, title V, § 5003(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2378"},"text":"122 Stat. 2378","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/252/tV/s5003/d"},"text":"“This section [enacting chapter 33 of Title 38, Veterans’ Benefits, amending this section and sections 3033, 3485, 3688 to 3690, 3692, 3695, 3697, and 3697A of Title 38, and enacting provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3301"},"text":"section 3301 of Title 38","children":[],"tail":"] and the amendments made by this section shall take effect on "},{"tag":"date","attrib":{"date":"2009-08-01"},"text":"August 1, 2009","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
