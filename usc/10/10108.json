{"tag":"section","attrib":{"id":"idab8a1579-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10108"},"text":null,"children":[{"tag":"num","attrib":{"value":"10108"},"text":"§ 10108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Navy Reserve: administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab8a157a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Navy Reserve is the reserve component of the Navy. It shall be organized, administered, trained, and supplied under the direction of the Chief of Naval Operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8a157b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The bureaus and offices of the executive part of the Department of the Navy have the same relation and responsibility to the Navy Reserve as they do to the Regular Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab8a157c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1661/a/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1661(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2971"},"text":"108 Stat. 2971","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s515/b/1/AA"},"text":"Pub. L. 109–163, div. A, title V, § 515(b)(1)(AA)","children":[],"tail":", (3)(F), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/323