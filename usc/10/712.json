{"tag":"section","attrib":{"id":"ida8027520-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s712"},"text":null,"children":[{"tag":"num","attrib":{"value":"712"},"text":"§ 712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign governments: detail to assist","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8027521-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s712/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon the application of the country concerned, the President, whenever he considers it in the public interest, may detail members of the Army, Navy, Air Force, Marine Corps, and Space Force to assist in military matters—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8027522-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s712/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any republic in North America, Central America, or South America;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8027523-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s712/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Republic of Cuba, Haiti, or Santo Domingo; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8027524-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s712/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during a war or a declared national emergency, any other country that he considers it advisable to assist in the interest of national defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8027525-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s712/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the prior approval of the Secretary of the military department concerned, a member detailed under this section may accept any office from the country to which he is detailed. He is entitled to credit for all service while so detailed, as if serving with the armed forces of the United States. Arrangements may be made by the President, with countries to which such members are detailed to perform functions under this section, for reimbursement to the United States or other sharing of the cost of performing such functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8027526-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/32"},"text":"70A Stat. 32","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/477"},"text":"Pub. L. 85–477","children":[],"tail":", ch. V, § 502(k), "},{"tag":"date","attrib":{"date":"1958-06-30"},"text":"June 30, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/275"},"text":"72 Stat. 275","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/1/E"},"text":"Pub. L. 116–283, div. A, title IX, § 924(b)(1)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3820"},"text":"134 Stat. 3820","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8027527-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8027528-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida8027529-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"712(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"712(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:540 (less provisos).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"34:441a (less provisos).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:540 (provisos).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"34:441a (provisos).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1926-05-19/ch334"},"text":"May 19, 1926, ch. 334","children":[],"tail":", 44 Stat, 565; "},{"tag":"html:a","attrib":{"href":"/us/act/1935-05-14/ch109"},"text":"May 14, 1935, ch. 109","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/49/218"},"text":"49 Stat. 218","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1942-10-01/ch571"},"text":"Oct. 1, 1942, ch. 571","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/56/763"},"text":"56 Stat. 763","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “and the Commonwealth of the Philippine Islands”, in the ","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-19/ch334"},"text":"Act of May 19, 1926, ch. 334","children":[],"tail":", added by the "},{"tag":"ref","attrib":{"href":"/us/act/1935-05-14/ch109"},"text":"Act of May 14, 1935, ch. 109","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/218"},"text":"49 Stat. 218","children":[],"tail":", are not contained in 10:540 or 34:441a. They are also omitted from the revised section, since Proclamation No. 2695, effective "},{"tag":"date","attrib":{"date":"1946-07-04"},"text":"July 4, 1946","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/1352"},"text":"60 Stat. 1352","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1240"},"text":"48 U.S.C. 1240","children":[],"tail":" (note)), proclaimed the independence of the Philippine Islands. Similar provisions relating to the Philippines are now contained in "},{"tag":"ref","attrib":{"href":"/us/act/1946-06-26/ch500/s5"},"text":"section 5 of the Act of June 26, 1946, ch. 500","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/315"},"text":"60 Stat. 315","children":[],"tail":". The word “members” is substituted for the words “officers and enlisted men”, in 10:540 and 34:441a."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “entitled to credit for all service” are substituted for the words “and shall be allowed the same credit for longevity, retirement, and for all other purposes”, in 10:540 and 34:441a.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida802752a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida802752b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Marine Corps, and Space Force” for “and Marine Corps” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/477"},"text":"Pub. L. 85–477","children":[],"tail":" struck out provisions which authorized members of the armed forces to accept compensation or emoluments from countries to which they are detailed, and inserted provisions permitting arrangements for reimbursement or other sharing of cost."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida802752c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida802752d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/477"},"text":"Pub. L. 85–477","children":[],"tail":", ch. V, § 502(k), "},{"tag":"date","attrib":{"date":"1958-06-30"},"text":"June 30, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/275"},"text":"72 Stat. 275","children":[],"tail":", provided that the amendment made by that section is effective nine months after "},{"tag":"date","attrib":{"date":"1958-06-30"},"text":"June 30, 1958","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
