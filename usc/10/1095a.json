{"tag":"section","attrib":{"id":"ida88cb36b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1095a"},"text":"§ 1095a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical care: members held as captives and their dependents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida88cb36c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under regulations prescribed by the President, the Secretary concerned shall pay (by advancement or reimbursement) any person who is a former captive, and any dependent of that person or of a person who is in a captive status, for health care and other expenses related to such care, to the extent that such care—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida88cb36d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is incident to the captive status; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida88cb36e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is not covered—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida88cb36f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by any other Government medical or health program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida88cb370-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida88cb371-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of any person who is eligible for medical care under section 1074 or 1076 of this title, such regulations shall require that, whenever practicable, such care be provided in a facility of the uniformed services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida88cb372-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida88cb373-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “captive status” and “former captive” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s559"},"text":"section 559 of title 37","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida88cb374-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “dependent” has the meaning given that term in section 551 of that title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida88cb375-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tVIII/s806/c/1"},"text":"Pub. L. 99–399, title VIII, § 806(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/886"},"text":"100 Stat. 886","children":[],"tail":", § 1095; renumbered § 1095a, "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s7/e/2"},"text":"Pub. L. 100–26, § 7(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/281"},"text":"101 Stat. 281","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/526/tI/s106/b/1"},"text":"Pub. L. 100–526, title I, § 106(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-24"},"text":"Oct. 24, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2625"},"text":"102 Stat. 2625","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida88cb376-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida88cb377-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida88cb378-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/526"},"text":"Pub. L. 100–526","children":[],"tail":" substituted “The terms ‘captive status’ ” for “ ‘Captive status’ ” in par. (1), and “The term ‘dependent’ ” for “ ‘Dependent’ ” in par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida88cb379-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida88cb37a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date; Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tVIII/s806/c/3"},"text":"Pub. L. 99–399, title VIII, § 806(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/886"},"text":"100 Stat. 886","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/399/tVIII/s806/c/3"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 1095 [now 1095a] of title 10, United States Code, as added by paragraph (1), shall apply with respect to any person whose captive status begins after ","children":[{"tag":"date","attrib":{"date":"1981-01-21"},"text":"January 21, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall prescribe specific regulations regarding the carrying out of such section with respect to persons whose captive status begins during the period beginning on ","children":[{"tag":"date","attrib":{"date":"1981-01-21"},"text":"January 21, 1981","children":[],"tail":", and ending on the effective date of that section ["},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"ida88cb37b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"ida88cb37c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under this section delegated to Secretary of Defense, see section 3 of Ex. Ord. No. 12598, ","children":[{"tag":"date","attrib":{"date":"1987-06-17"},"text":"June 17, 1987","children":[],"tail":", 52 F.R. 23421, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5569"},"text":"section 5569 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
