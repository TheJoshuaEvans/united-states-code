{"tag":"section","attrib":{"id":"idaaa9ee97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4875"},"text":null,"children":[{"tag":"num","attrib":{"value":"4875"},"text":"§ 4875.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on acquisition of personal protective equipment and certain other items from non-allied foreign nations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaa9ee98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4875/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (c), the Secretary of Defense may not procure any covered item from any covered nation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaa9ee99-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4875/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall apply to prime contracts and subcontracts at any tier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaa9ee9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4875/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaa9ee9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4875/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply under the following circumstances:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaa9ee9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4875/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary of Defense determines that covered materials of satisfactory quality and quantity, in the required form, cannot be procured as and when needed from nations other than covered nations to meet requirements at a reasonable price.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa9ee9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4875/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The procurement of a covered item for use outside of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa9ee9e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4875/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Purchases for amounts not greater than $150,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaa9ee9f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4875/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A proposed procurement in an amount greater than $150,000 may not be divided into several purchases or contracts for lesser amounts in order to qualify for this exception.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaa9eea0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4875/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaa9eea1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4875/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered item","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered item” means an article or item of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaa9eea2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4875/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal protective equipment for use in preventing spread of disease, such as by exposure to infected individuals or contamination or infection by infectious material (including nitrile and vinyl gloves, surgical masks, respirator masks and powered air purifying respirators and required filters, face shields and protective eyewear, surgical and isolation gowns, and head and foot coverings) or clothing, and the materials and components thereof, other than sensors, electronics, or other items added to and not normally associated with such personal protective equipment or clothing; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa9eea3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4875/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sanitizing and disinfecting wipes, testing swabs, gauze, and bandages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaa9eea4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4875/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered nation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered nation” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaa9eea5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4875/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Democratic People’s Republic of North Korea;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa9eea6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4875/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the People’s Republic of China;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa9eea7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4875/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Russian Federation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa9eea8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4875/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Islamic Republic of Iran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaa9eea9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVIII/s802/a/1"},"text":"Pub. L. 117–81, div. A, title VIII, § 802(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1812"},"text":"135 Stat. 1812","children":[],"tail":", § 2533e; renumbered § 4875, "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVIII/s802/b/1"},"text":"Pub. L. 117–81, div. A, title VIII, § 802(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1813"},"text":"135 Stat. 1813","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaa9eeaa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaa9eeab-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaaa9eeac-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2533e"},"text":"section 2533e of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaaa9eead-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaaa9eeae-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":", which renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2533e"},"text":"section 2533e of this title","children":[],"tail":" as this section, deemed to have taken effect immediately before "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1881"},"text":"section 1881 of Pub. L. 116–283","children":[],"tail":", subsec. (a) of which had repealed chapter 148 of this title, where section 2533c was located. See "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s881/a"},"text":"section 881(a) of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4027"},"text":"section 4027 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVIII/s802/b/3"},"text":"Pub. L. 117–81, div. A, title VIII, § 802(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1814"},"text":"135 Stat. 1814","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dA/tVIII/s802/b/3"},"text":"“The transfer, redesignation, and amendments made by this subsection [renumbering ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2533e"},"text":"section 2533e of this title","children":[],"tail":" as this section] shall take effect immediately after the amendments made by title XVIII of the William M. (Mac) Thornberry National Defense Authorization Act for Fiscal Year 2021 ["},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":"] take effect ["},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":"].”"}],"tail":"\n See note above."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaaa9eeaf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References; Savings Provision; Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVIII/s802/b/4"},"text":"Pub. L. 117–81, div. A, title VIII, § 802(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1814"},"text":"135 Stat. 1814","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dA/tVIII/s802/b/4"},"text":"“Sections 1883 through 1885 of the William M. (Mac) Thornberry National Defense Authorization Act for Fiscal Year 2021 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Public Law 116–283","children":[],"tail":") [set out as notes preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"] shall apply with respect to the transfers, redesignations, and amendments made under this subsection [see Effective Date of 2021 Amendment note above] as if such transfers, redesignations, and amendments were made under title XVIII of such Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
