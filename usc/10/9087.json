{"tag":"section","attrib":{"id":"idab63ef44-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087"},"text":null,"children":[{"tag":"num","attrib":{"value":"9087"},"text":"§ 9087.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Space Development Agency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab63ef45-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab63ef46-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is a Space Development Agency of the Department of Defense (in this section referred to as the “Agency”). The Director of the Space Development Agency shall be the head of the Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63ef47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Effective on ","children":[{"tag":"date","attrib":{"date":"2022-10-01"},"text":"October 1, 2022","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab63ef48-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Agency shall be an element of the Space Force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab63ef49-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Director shall report—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idab63ef4a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9016/b/6/B/iv/III"},"text":"section 9016(b)(6)(B)(iv)(III) of this title","children":[],"tail":", to the Assistant Secretary of the Air Force for Space Acquisition and Integration with respect to acquisition decisions; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab63ef4b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly to the Chief of Space Operations with respect to requirements decisions, personnel decisions, and any other matter not covered by clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab63ef4c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development and Integration Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall lead—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab63ef4d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and demonstration of a resilient military space-based sensing, tracking, and data transport architecture that uses proliferated low-Earth orbit systems and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63ef4e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the integration of next-generation space capabilities, such as novel sensors (including with respect to alternate navigation, and autonomous battle management features), and sensor and tracking components (including a hypersonic and ballistic missile tracking space sensor payload pursuant to section 1645 of the William M. (Mac) Thornberry National Defense Authorization Act for Fiscal Year 2021), into the architecture specified in paragraph (1) to address the requirements and needs of the armed forces and combatant commands for such capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63ef4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the procurement of commercial capabilities and services, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab63ef50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" options for integrating payloads on commercial buses and spacecraft into existing commercial architectures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab63ef51-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" innovative commercial capabilities and services, such as on-orbit servicing or in-space transportation systems, that could extend the life of space systems, rapidly respond to threats, or contribute to resilience; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63ef52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rapid introduction, acquisition, and iteration of cost-effective, resilient solutions that leverage planned and existing commercial low-Earth orbit capabilities or innovative capabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab63ef53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Budget Materials and Program Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning not later than with respect to fiscal year 2023 and each fiscal year thereafter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab63ef54-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the budget justification materials submitted to Congress in support of the Department of Defense budget for a fiscal year (as submitted with the budget of the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":"), the amount requested for the activities of the Agency shall be separate from the other activities of the Space Force; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63ef55-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense shall ensure that the programs of the Agency are assigned program elements different from other program elements of the Space Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab63ef56-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delegation of Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab63ef57-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to tranche 0 capabilities and tranche 1 capabilities, to the extent practicable, the Secretary of the Air Force, acting through the Service Acquisition Executive for Space Systems and Programs, shall ensure the delegation to the Agency of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab63ef58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" head of contracting authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab63ef59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" milestone decision authority for the middle tier of acquisition programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63ef5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab63ef5b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Service Acquisition Executive for Space Systems and Programs may rescind the delegation of authority under paragraph (1) for cause or on a case-by-case basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab63ef5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 30 days after the date of a rescission under subparagraph (A), the Secretary of the Air Force shall notify the congressional defense committees of such rescission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63ef5d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab63ef5e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “tranche 0 capabilities” means capabilities relating to transport, battle management, tracking, custody, navigation, deterrence, and support, that are intended to be achieved by ","children":[{"tag":"date","attrib":{"date":"2022-09-30"},"text":"September 30, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab63ef5f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9087/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “tranche 1 capabilities” means capabilities relating to transport, battle management, tracking, custody, navigation, deterrence, and support, that are intended to be achieved by ","children":[{"tag":"date","attrib":{"date":"2024-09-30"},"text":"September 30, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab63ef60-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVI/s1601/a"},"text":"Pub. L. 116–283, div. A, title XVI, § 1601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4041"},"text":"134 Stat. 4041","children":[],"tail":", § 9084; renumbered § 9086 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tX/s1081/a/33"},"text":"Pub. L. 117–81, div. A, title X, § 1081(a)(33)","children":[],"tail":", title XVI, § 1603, "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1921"},"text":"135 Stat. 1921","children":[],"tail":", 2077; renumbered § 9087, "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s509C/a/1"},"text":"Pub. L. 118–159, div. A, title V, § 509C(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1873"},"text":"138 Stat. 1873","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab63ef61-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab63ef62-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idab63ef63-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1645 of the William M. (Mac) Thornberry National Defense Authorization Act for Fiscal Year 2021, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1645"},"text":"section 1645 of Pub. L. 116–283","children":[],"tail":", div. A, title XVI, "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4064"},"text":"134 Stat. 4064","children":[],"tail":". Subsec. (g) of section 1645 amended provisions formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2431"},"text":"section 2431 of this title","children":[],"tail":". Subsecs. (a) to (f) of section 1645 are not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab63ef64-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9086"},"text":"section 9086 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1081/a/33"},"text":"Pub. L. 117–81, § 1081(a)(33)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9084"},"text":"section 9084 of this title","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1601/a"},"text":"section 1601(a) of Pub. L. 116–283","children":[],"tail":", as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1603"},"text":"Pub. L. 117–81, § 1603","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab63ef65-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab63ef66-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transition","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVI/s1601/d"},"text":"Pub. L. 116–283, div. A, title XVI, § 1601(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4042"},"text":"134 Stat. 4042","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dA/tXVI/s1601/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Effective on ","children":[{"tag":"date","attrib":{"date":"2022-10-01"},"text":"October 1, 2022","children":[],"tail":", the Secretary of Defense shall transfer the Space Development Agency from the Office of the Secretary of Defense to the Space Force."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding, duties, responsibilities, and personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9084"},"text":"section 9084 of title 10","children":[],"tail":", United States Code [now "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9085"},"text":"10 U.S.C. 9085","children":[],"tail":"], the transfer under paragraph (1) of the Space Development Agency from the Office of the Secretary of Defense to the Space Force shall include the transfer of the funding, duties, responsibilities, and personnel of the Agency as of the day before the date of the transfer.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab63ef67-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Review of Space Development Agency Exemption From Joint Capabilities Integration and Development System","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tXVI/s1608"},"text":"Pub. L. 117–263, div. A, title XVI, § 1608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2932"},"text":"136 Stat. 2932","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tXVI/s1608"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2023-03-31"},"text":"March 31, 2023","children":[],"tail":", the Secretary of Defense shall complete a review regarding whether the Space Development Agency should be exempt from the Joint Capabilities Integration and Development System."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the date on which the review under subsection (a) is completed, the Secretary of Defense shall submit to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] a recommendation as to whether the exemption described in such subsection should apply to the Space Development Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after the date on which the recommendation is submitted under subsection (b), the Secretary of the Air Force and the Director of the Space Development Agency shall implement the recommendation.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
