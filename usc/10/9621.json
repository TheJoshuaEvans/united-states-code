:" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1911-03-03/ch209"},"text":"Mar. 3, 1911, ch. 209","children":[],"tail":" (last par. under “Subsistence Department”), "},{"tag":"html:a","attrib":{"href":"/us/stat/36/1047"},"text":"36 Stat. 1047","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1953-08-08/ch390/s1"},"text":"Aug. 8, 1953, ch. 390, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/499"},"text":"67 Stat. 499","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1875-03-03/ch131"},"text":"Mar. 3, 1875, ch. 131","children":[],"tail":" (proviso of 1st sentence of 1st par. under “War Department”), "},{"tag":"html:a","attrib":{"href":"/us/stat/18/410"},"text":"18 Stat. 410","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “members” is substituted for the words “officers and enlisted men”, in 10:1237. Clause (2) is substituted for 10:904. Reference to the Secretary of the Air Force is substituted for reference to branch, office, or officers of the Army, in 10:1237, since the functions which, for the Army are assigned to subordinate officers, are, for the Air Force assigned to the Secretary of the Air Force. 32:156 is omitted as covered by 10:904, since the words “officers of the Air Force” necessarily cover all persons named in 32:156. The words “Except for articles and items acquired through the use of working capital funds under sections 172–172j of title 5” are inserted to reflect Title IV of the National Security Act of 1947, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/stat/63/585"},"text":"63 Stat. 585","children":[],"tail":"), which authorized the Secretary of Defense to prescribe regulations governing the use and sale of certain inventories at cost, including applicable administrative expenses. (See opinion of the Assistant General Counsel (Fiscal Matters) of the Office of the Secretary of Defense, "},{"tag":"date","attrib":{"date":"1955-01-04"},"text":"January 4, 1955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the first sentence states expressly the rule which is implicit in 10:1238. The word “members” is substituted for the words “officers and enlisted men”. The words “shall be understood, in all cases of such sales” are omitted as surplusage. The last sentence is inserted to reflect Title IV of the National Security Act of 1947, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/stat/63/585"},"text":"63 Stat. 585","children":[],"tail":"), which authorized the Secretary of Defense to prescribe regulations governing the use and sale of certain inventories at cost, including applicable administrative expenses. (See opinion of the Deputy General Counsel of the Office of the Secretary of Defense, "},{"tag":"date","attrib":{"date":"1956-03-28"},"text":"March 28, 1956","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “members” is substituted for the words “officers and enlisted men”. The words “prices at which like property is sold to” are substituted for the words “same price as is charged the”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (c) and (d), the words “other armed forces” are substituted for the words “Navy and Marine Corps”, since such sales are authorized to members of the Coast Guard by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s144/b"},"text":"section 144(b) of Title 14","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “other than subsistence supplies” are inserted, since the sale of subsistence supplies is covered by subsection (c).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “a person who has been discharged” are substituted for the words “discharged officers and enlisted men”. The words “Navy * * * or Marine Corps”, omitted from the 1952 edition of the United States Code, are inserted to conform to the source statute. The words “may buy” are substituted for the words “shall * * * be permitted to purchase”. The words “at the prices at which like property is sold” are substituted for the words “at the same price as charged”. The word “member” is substituted for the words “officers and enlisted men”. The words “while undergoing such care and treatment” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f), the words “person who has been discharged” are substituted for the words “former members * * * who have been separated therefrom”. The words “at the prices at which like articles are sold to members” are inserted to conform to the last sentence of subsection (a) and subsection (e).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (g), the words “regulations to be prescribed by the Secretary” are substituted for the words “Army Regulations”. The words “of the Government” are omitted as surplusage. 10:1253 (last 22 words of 1st sentence) is omitted as surplusage. The words “or to another executive department of the Government” are omitted as superseded by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-05-21/ch194/s7"},"text":"section 7 of the act of May 21, 1920, ch. 194","children":[],"tail":", as amended ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s686"},"text":"31 U.S.C. 686","children":[],"tail":"). The provisions of 10:1253 relating to the computation of cost are omitted to reflect Title IV of the National Security Act of 1947, as amended ("},{"tag":"ref","attrib":{"href":"/us/stat/63/585"},"text":"63 Stat. 585","children":[],"tail":"), which authorized the Secretary of Defense to prescribe regulations governing the use and sale of certain inventories at cost, including applicable administrative expenses. (See opinion of the Assistant General Counsel (Fiscal Matters) of the Office of the Secretary of Defense, "},{"tag":"date","attrib":{"date":"1955-01-04"},"text":"January 4, 1955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (h), the word “outside” is substituted for the words “beyond the continental limitations”. The words “or in Alaska” are omitted, since, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/1"},"text":"section 101(1) of this title","children":[],"tail":", the words “United States” are defined to include only the States and the District of Columbia. The word “continental”, after the words “within the”, is omitted for the same reason. The last sentence is substituted for 10:1241 (proviso)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (i), 10:1196 (last 30 words) is omitted as superseded by the ","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-04-27/ch72"},"text":"Act of April 27, 1914, ch. 72","children":[],"tail":" (last proviso under “Subsistence of the Army”), "},{"tag":"ref","attrib":{"href":"/us/stat/38/361"},"text":"38 Stat. 361","children":[],"tail":". The words “So much of the” and “as may be necessary” are omitted as surplusage. The words “members * * * on active duty, for the use of themselves and their families” are substituted for the words “officers for the use of themselves and their families, and to commanders of companies or other organizations, for the use of the enlisted men of their companies or organizations”, to conform to 10:1237 and 1238. Those sections provide the basic authority for procurement and sale of subsistence supplies to all members. This interpretation conforms to established administrative practice under those sections. The word “supplies” is substituted for the word “stores”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab80a008-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1962 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"The change corrects an internal reference.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab80a009-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab80a00a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/9/A/i"},"text":"Pub. L. 116–283, § 923(e)(9)(A)(i)","children":[],"tail":", inserted “and members of the Space Force” after “the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/9/A/ii"},"text":"Pub. L. 116–283, § 923(e)(9)(A)(ii)","children":[],"tail":", inserted “and officers of the Space Force” after “the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/9/B"},"text":"Pub. L. 116–283, § 923(e)(9)(B)","children":[],"tail":", inserted “or the Space Force” after “the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/9/C"},"text":"Pub. L. 116–283, § 923(e)(9)(C)","children":[],"tail":", inserted “or the Space Force” after “the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/9/D"},"text":"Pub. L. 116–283, § 923(e)(9)(D)","children":[],"tail":", substituted “Marine Corps, or Space Force” for “or Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/9/E"},"text":"Pub. L. 116–283, § 923(e)(9)(E)","children":[],"tail":", inserted “or the Space Force” after “from the Air Force” and “or the Space Force, respectively” after “of the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/9/F"},"text":"Pub. L. 116–283, § 923(e)(9)(F)","children":[],"tail":", inserted “or the Space Force” after “the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/9/G"},"text":"Pub. L. 116–283, § 923(e)(9)(G)","children":[],"tail":", inserted “or the Space Force” after “subsistence of the Air Force” and “or members of the Space Force” after “members of the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s375/b/2/A"},"text":"Pub. L. 104–106, § 375(b)(2)(A)","children":[],"tail":", substituted “The Secretary shall” for “The Air Force shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s375/b/2/B"},"text":"Pub. L. 104–106, § 375(b)(2)(B)","children":[],"tail":", inserted “or by commercial credit” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" substituted “Department of Veterans Affairs” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsecs. (b) to (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180"},"text":"Pub. L. 100–180","children":[],"tail":" redesignated subsecs. (c) to (i) as (b) to (h), respectively, and struck out former subsec. (b) which read as follows: “Subsistence supplies may be sold to members of the Air Force. The selling price of each article sold under this subsection is the invoice price of the last lot of that article that the officer making the sale received before the first day of the month in which the sale is made. Activities conducted under this subsection shall be consistent with "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2208"},"text":"section 2208 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/22"},"text":"Pub. L. 97–22","children":[],"tail":" struck out a comma after “section 772”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" struck out reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8612"},"text":"section 8612 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/651"},"text":"Pub. L. 87–651","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2208"},"text":"section 2208 of this title","children":[],"tail":"” for “sections 172–172j of title 5”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab80a00b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab80a00c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/b/3"},"text":"section 701(b)(3) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
