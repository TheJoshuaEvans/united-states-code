{"tag":"section","attrib":{"id":"ida91bd44f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2002"},"text":null,"children":[{"tag":"num","attrib":{"value":"2002"},"text":"§ 2002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dependents of members of armed forces: language training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida91bd450-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2002/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding section 701(b) of the Foreign Service Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4021/b"},"text":"22 U.S.C. 4021(b)","children":[],"tail":") or any other provision of law, and under regulations to be prescribed by the Secretary of Defense or, with respect to the Coast Guard when it is not operating as a service in the Navy, the Secretary of Homeland Security, language training may be provided in—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida91bd451-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2002/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a facility of the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida91bd452-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2002/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a facility of the George P. Shultz National Foreign Affairs Training Center established under section 701(a) of the Foreign Service Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4021/a"},"text":"22 U.S.C. 4021(a)","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida91bd453-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2002/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a civilian educational institution;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to a dependent of a member of the armed forces in anticipation of the member’s assignment to permanent duty outside the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida91bd454-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2002/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section, the term “dependent” has the same meaning that it has under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s401"},"text":"section 401 of title 37","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida91bd455-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/160/s1/1"},"text":"Pub. L. 89–160, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-01"},"text":"Sept. 1, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/615"},"text":"79 Stat. 615","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/278/s2/1"},"text":"Pub. L. 91–278, § 2(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1970-06-12"},"text":"June 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/306"},"text":"84 Stat. 306","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/tII/s2206/c/1"},"text":"Pub. L. 96–465, title II, § 2206(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2162"},"text":"94 Stat. 2162","children"