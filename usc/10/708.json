{"tag":"section","attrib":{"id":"ida8000481-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s708"},"text":null,"children":[{"tag":"num","attrib":{"value":"708"},"text":"§ 708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational leave of absence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8000482-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under such regulations as the Secretary of Defense may prescribe after consultation with the Secretary of Homeland Security and subject to subsection (b), the Secretary concerned may grant to any eligible member (as defined in subsection (e)) a leave of absence for the purpose of permitting the member to pursue a program of education. The period of a leave of absence granted under this section may not exceed two years, except that the period may exceed two years but may not exceed three years in the case of an eligible member pursuing a program of education in a health care profession.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8000483-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8000484-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s708/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member may not be granted a leave of absence under this section unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8000485-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s708/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an enlisted member, the member agrees in writing to extend his current enlistment after completion (or other termination) of the program of education for which the leave of absence was granted for a period of two months for each month of the period of the leave of absence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8000486-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s708/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an officer, the member agrees to serve on active duty after completion (or other termination) of the program of education for which the leave of absence was granted for a period (in addition to any other period of obligated service on active duty) of two months for each month of the period of the leave of absence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8000487-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s708/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member may not be granted a leave of absence under this section until he has completed any extension of enlistment or reenlistment, or any period of obligated service, incurred by reason of any previous leave of absence granted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8000488-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s708/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8000489-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s708/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" While on a leave of absence under this section, a member shall be paid basic pay but may not receive basic allowance for housing under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s403"},"text":"section 403 of title 37","children":[],"tail":", basic allowance for subsistence under section 402 of such title, or any other pay and allowances to which he would otherwise be entitled for such period."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida800048a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s708/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A period during which a member is on a leave of absence under this section shall be counted for the purposes of computing the amount of the member’s basic pay, for the purpose of determining the member’s eligibility for retired pay, and for the purpose of determining the member’s time in grade for promotion purposes, but may not be counted for the purposes of completion of the term of enlistment of the member (in the case of an enlisted member) or for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3021"},"text":"section 3021 of title 38","children":[],"tail":", relating to entitlement to supplemental educational assistance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida800048b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s708/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida800048c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s708/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In time of war, or of national emergency declared by the President or the Congress after ","children":[{"tag":"date","attrib":{"date":"1984-10-19"},"text":"October 19, 1984","children":[],"tail":", the Secretary concerned may cancel any leave of absence granted under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida800048d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s708/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may cancel a leave of absence granted to a member under this section if the Secretary determines that the member is not satisfactorily pursuing the program of education for which the leave was granted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida800048e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s708/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section, the term “eligible member” means a member of the armed forces on active duty who is eligible for basic educational assistance under chapter 30 of title 38 and who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida800048f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s708/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an enlisted member, has completed at least one term of enlistment and has reenlisted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8000490-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s708/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an officer, has completed the officer’s initial period of obligated service on active duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8000491-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tVII/s707/a/1"},"text":"Pub. L. 98–525, title VII, § 707(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2571"},"text":"98 Stat. 2571","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s7/i/2"},"text":"Pub. L. 100–26, § 7(i)(2)","children":[],"tail":", (k)(3), "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/282"},"text":"101 Stat. 282","children":[],"tail":", 284; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tX/s1070/e/2"},"text":"Pub. L. 103–337, div. A, title X, § 1070(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2859"},"text":"108 Stat. 2859","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVI/s603/d/2/A"},"text":"Pub. L. 105–85, div. A, title VI, § 603(d)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1782"},"text":"111 Stat. 1782","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/b/1"},"text":"Pub. L. 107–296, title XVII, § 1704(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s554"},"text":"Pub. L. 108–375, div. A, title V, § 554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1913"},"text":"118 Stat. 1913","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tX/s1071/g/3"},"text":"Pub. L. 109–364, div. A, title X, § 1071(g)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2402"},"text":"120 Stat. 2402","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8000492-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8000493-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8000494-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/s554/1"},"text":"Pub. L. 108–375, § 554(1)","children":[],"tail":". See 2004 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s554/2"},"text":"Pub. L. 108–375, § 554(2)","children":[],"tail":", inserted at end “The period of a leave of absence granted under this section may not exceed two years, except that the period may exceed two years but may not exceed three years in the case of an eligible member pursuing a program of education in a health care profession.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s554/1"},"text":"Pub. L. 108–375, § 554(1)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":", struck out “for a period of not to exceed two years” after “leave of absence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" substituted “basic allowance for housing under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s403"},"text":"section 403 of title 37","children":[],"tail":", basic allowance for subsistence under section 402 of such title,” for “basic allowance for quarters or basic allowance for subsistence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3021"},"text":"section 3021 of title 38","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1421"},"text":"section 1421 of title 38","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/26/s7/i/2"},"text":"Pub. L. 100–26, § 7(i)(2)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"October 19, 1984","children":[],"tail":"” for “the date of the enactment of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/26/s7/k/3"},"text":"Pub. L. 100–26, § 7(k)(3)","children":[],"tail":", inserted “the term” after “In this section,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8027495-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8027496-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tX/s1071/g"},"text":"Pub. L. 109–364, div. A, title X, § 1071(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2402"},"text":"120 Stat. 2402","children":[],"tail":", provided that the amendment made by section 1071(g)(3) is effective as of "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8027497-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8027498-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-01-01"},"text":"Jan. 1, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/s603/e"},"text":"section 603(e) of Pub. L. 105–85","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5561"},"text":"section 5561 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8027499-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tVII/s707/b"},"text":"Pub. L. 98–525, title VII, § 707(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2572"},"text":"98 Stat. 2572","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/525/tVII/s707/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s708"},"text":"Section 708 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall take effect on "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"October 1, 1985","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
