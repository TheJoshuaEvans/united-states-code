{"tag":"section","attrib":{"id":"idaa2e0758-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3674"},"text":null,"children":[{"tag":"num","attrib":{"value":"3674"},"text":"§ 3674.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-term lease or charter defined; substantial termination liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa2e0759-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3674/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Long-term Lease or Charter.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa2e075a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3674/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General rule.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa2e075b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3674/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this chapter, the term “long-term lease or charter” (except as provided in paragraph (2)) means a lease, charter, service contract, or conditional sale agreement—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa2e075c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3674/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term of which is for a period of five years or longer or more than one-half the useful life of the vessel, aircraft, or combat vehicle; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa2e075d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3674/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the initial term of which is for a period of less than five years but which contains an option to renew or extend the agreement for a period which, when added to the initial term (or any previous renewal or extension), is five years or longer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa2e075e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3674/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such term includes the extension or renewal of a lease or charter agreement if the term of the extension or renewal thereof is for a period of five years or longer or if the term of the lease or charter agreement being extended or renewed was for a period of five years or longer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa2e075f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3674/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa2e0760-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3674/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of an agreement under which the lessor first places the property in service under the agreement or the property has been in service for less than one year and there is allowable to the lessor or charterer an investment tax credit or depreciation for the property leased, chartered, or otherwise provided under the agreement under section 168 of the Internal Revenue Code of 1986 (unless the lessor or charterer has elected depreciation on a straightline method for such property), the term “long-term lease or charter” means a lease, charter, service contract, or conditional sale agreement—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa2e0761-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3674/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term of which is for a period of three years or longer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa2e0762-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3674/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the initial term of which is for a period of less than three years but which contains an option to renew or extend the agreement for a period which, when added to the initial term (or any previous renewal or extension), is three years or longer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa2e0763-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3674/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such term includes the extension or renewal of a lease or charter agreement if the term of the extension or renewal thereof is for a period of three years or longer or if the term of the lease or charter agreement being extended or renewed was for a period of three years or longer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa2e0764-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3674/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Substantial Termination Liability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter, the United States shall be considered to have a substantial termination liability under a contract—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa2e0765-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3674/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if there is an agreement by the United States under the contract to pay an amount not less than the amount equal to 25 percent of the value of the vessel, aircraft, or combat vehicle under lease or charter, calculated on the basis of the present value of the termination liability of the United States under such charter or lease (as determined under regulations prescribed by the Secretary of Defense); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa2e0766-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3674/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if (as determined under regulations prescribed by the Secretary of Defense) the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa2e0767-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3674/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the present value of the amount of the termination liability of the United States under the contract as of the end of the term of the contract (exclusive of any option to extend the contract); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa2e0768-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3674/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the present value of the total of the payments to be made by the United States under the contract (excluding any option to extend the contract) attributable to capital-hire,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is more than one-half the price of the vessel, aircraft, or combat vehicle involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa2e0769-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1825/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1825(a)","children":[],"tail":", (f), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4206"},"text":"134 Stat. 4206","children":[],"tail":", 4207.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa2e076a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa2e076b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaa2e076c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 168 of the Internal Revenue Code of 1986, referred to in subsec. (a)(2)(A), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s168"},"text":"section 168 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa2e076d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2401"},"text":"section 2401 of this title","children":[],"tail":", which was transferred to this section and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1825/f"},"text":"Pub. L. 116–283, § 1825(f)","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/pl/98/94/tXII/s1202/a/1"},"text":"Pub. L. 98–94, title XII, § 1202(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/679"},"text":"97 Stat. 679","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s7/h/1"},"text":"Pub. L. 100–26, § 7(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/282"},"text":"101 Stat. 282","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVIII/s815/a/1"},"text":"Pub. L. 109–163, div. A, title VIII, § 815(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3381"},"text":"119 Stat. 3381","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa2e076e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1825/f/1"},"text":"Pub. L. 116–283, § 1825(f)(1)","children":[],"tail":", transferred subsec. (d) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2401"},"text":"section 2401 of this title","children":[],"tail":" to this section, struck out subsec. (d) designation at beginning, and redesignated pars. (1) and (2) of such former subsec. (d) as subsecs. (a) and (b), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1825/f/2/A"},"text":"Pub. L. 116–283, § 1825(f)(2)(A)","children":[],"tail":", (C), (D), (E), after redesignation of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2401/d/1"},"text":"section 2401(d)(1) of this title","children":[],"tail":" as subsec. (a) of this section, inserted subsec. heading, redesignated subpar. (A)(i) and (ii) and its concluding provisions as par. (1)(A)(i) and (ii) and (B), respectively, redesignated subpar. (B)(i) and (ii) and its concluding provisions as par. (2)(A)(i) and (ii) and (B), respectively, and inserted par. headings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1825/f/2/A"},"text":"Pub. L. 116–283, § 1825(f)(2)(A)","children":[],"tail":", (B), substituted “In this chapter” for “In this section” and “paragraph (2)” for “subparagraph (B)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1825/f/3"},"text":"Pub. L. 116–283, § 1825(f)(3)","children":[],"tail":", after redesignation of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2401/d/2"},"text":"section 2401(d)(2) of this title","children":[],"tail":" as subsec. (b) of this section, inserted heading, substituted “this chapter” for “this section” in introductory provisions, and redesignated subpar. (A) as par. (1) and subpar. (B) and its cls. (i) and (ii) as par. (2) and subpars. (A) and (B), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa2e076f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa2e0770-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as an Effective Date of 2021 Amendment note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
