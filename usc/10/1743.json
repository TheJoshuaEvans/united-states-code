{"tag":"section","attrib":{"id":"ida90b0b27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743"},"text":null,"children":[{"tag":"num","attrib":{"value":"1743"},"text":"§ 1743.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards to recognize members of the acquisition workforce","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida90b0b28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President of the Defense Acquisition University shall establish two programs to provide awards to recognize members of the acquisition workforce as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90b0b29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An award of not more than $5,000 to such members who use an iterative writing process to document a first-hand account of using independent judgment to overcome an obstacle the member faced while working within the defense acquisition system (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90b0b2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An award of not more than $5,000 to such members who make the best use of the flexibilities and authorities granted by the Federal Acquisition Regulation and Department of Defense Instruction 5000.02 (Operation of the Defense Acquisition System).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90b0b2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Number of Awards.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90b0b2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President of the Defense Acquisition University may make not more than five awards under subsection (a)(1) and one award under subsection (a)(2) each year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90b0b2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the acquisition workforce may receive one award each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90b0b2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for Writing Award.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90b0b2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member of the acquisition workforce desiring an award under subsection (a)(1) shall submit to the President of the Defense Acquisition University the first-hand account described in such subsection. Such first-hand account shall demonstrate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida90b0b30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an original and engaging idea documenting the use of independent judgment to overcome an obstacle the recipient faced while working within the defense acquisition system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90b0b31-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the use of an iterative writing process, including evidence of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida90b0b32-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" critical thinking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida90b0b33-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporation of feedback from diverse perspectives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida90b0b34-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" editing to achieve plain writing (as defined in section 3 of the Plain Writing Act of 2010 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s301"},"text":"5 U.S.C. 301","children":[],"tail":" note))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90b0b35-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Website","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President of the Defense Acquisition University shall establish and maintain a website to serve as a repository for submissions made under paragraph (1). Such website shall allow for public comments and discussion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90b0b36-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for Flexibility Award","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member of the acquisition workforce desiring an award under subsection (a)(2) shall submit to the President of the Defense Acquisition University documentation that such member uses approaches to program management that emphasize innovation and local adaptation, including the use of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90b0b37-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" simplified acquisition procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90b0b38-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inherent flexibilities within the Federal Acquisition Regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90b0b39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercial contracting approaches;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90b0b3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public-private partnership agreements and practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90b0b3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cost-sharing arrangements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90b0b3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" innovative contractor incentive practices; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90b0b3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other innovative implementations of acquisition flexibilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90b0b3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1743/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall use funds from the Defense Acquisition Workforce Development Account to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida90b0b3f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVIII/s801/a"},"text":"Pub. L. 117–263, div. A, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2692"},"text":"136 Stat. 2692","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida90b0b40-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida90b0b41-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida90b0b42-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3 of the Plain Writing Act of 2010, referred to in subsec. (c)(1)(B)(iii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/274/s3"},"text":"section 3 of Pub. L. 111–274","children":[],"tail":", which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s301"},"text":"section 301 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida90b0b43-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1743, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXII/s1202/a"},"text":"Pub. L. 101–510, div. A, title XII, § 1202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1651"},"text":"104 Stat. 1651","children":[],"tail":", related to cooperative education program, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tVIII/s834/b"},"text":"Pub. L. 108–136, div. A, title VIII, § 834(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1551"},"text":"117 Stat. 1551","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
