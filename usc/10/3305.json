":"1967-11-08"},"text":"Nov. 8, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/375"},"text":"81 Stat. 375","children":[],"tail":", related to promotion of officers in regular grade of lieutenant colonel to grade of colonel, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tII/s204"},"text":"Pub. L. 96–513, title II, § 204","children":[],"tail":", title VII, § 701, "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2880"},"text":"94 Stat. 2880","children":[],"tail":", 2955, effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":". See section 619 et seq. of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa1d3e4d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1816/c/7/A"},"text":"Pub. L. 116–283, § 1816(c)(7)(A)","children":[],"tail":", transferred subsec. (b)(6) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2305"},"text":"section 2305 of this title","children":[],"tail":" to this section and struck out par. (6) designation at beginning."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1816/c/7/C"},"text":"Pub. L. 116–283, § 1816(c)(7)(C)","children":[],"tail":", (E), redesignated subpar. (A) of former "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2305/b/6"},"text":"section 2305(b)(6) of this title","children":[],"tail":" as subsec. (a) of this section and inserted heading. Former second sentence of subsec. (a) designated subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1816/c/7/D"},"text":"Pub. L. 116–283, § 1816(c)(7)(D)","children":[],"tail":", (F), designated second sentence of subsec. (a) as subsec. (b) of this section and inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1816/c/7/B"},"text":"Pub. L. 116–283, § 1816(c)(7)(B)","children":[],"tail":", (G), redesignated subpar. (B) of former "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2305/b/6"},"text":"section 2305(b)(6) of this title","children":[],"tail":" as subsec. (c) of this section, inserted heading, and substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3304"},"text":"section 3304 of this title","children":[],"tail":"” for “paragraph (5)” and “subsections (a) and (b)” for “subparagraph (A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1816/c/7/B"},"text":"Pub. L. 116–283, § 1816(c)(7)(B)","children":[],"tail":", (H), redesignated subpar. (C) of former "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2305/b/6"},"text":"section 2305(b)(6) of this title","children":[],"tail":" and its cls. (i) to (iii) as subsec. (d) of this section and pars. (1) to (3), respectively, inserted heading, and substituted “subsections (a) and (b)” for “subparagraph (A)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1816/c/7/B"},"text":"Pub. L. 116–283, § 1816(c)(7)(B)","children":[],"tail":", (I), redesignated subpar. (D) of former "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2305/b/6"},"text":"section 2305(b)(6) of this title","children":[],"tail":" as subsec. (e) of this section, inserted heading, and substituted “subsections (a) and (b)” for “subparagraph (A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1816/c/7/B"},"text":"Pub. L. 116–283, § 1816(c)(7)(B)","children":[],"tail":", (J), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/b/6/B"},"text":"Pub. L. 117–81, § 1701(b)(6)(B)","children":[],"tail":", redesignated subsec. (b)(7) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2305"},"text":"section 2305 of this title","children":[],"tail":" as subsec. (f) of this section, inserted heading, and substituted “under this section” for “under paragraph (5) or (6)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa1d3e4e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa1d3e4f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" applicable as if included in the enactment of title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" as enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/a/2"},"text":"section 1701(a)(2) of Pub. L. 117–81","children":[],"tail":", set out in a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":" and Effective Date note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa1d3e50-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as an Effective Date of 2021 Amendment note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
