,"children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Army and Air Force, exclusive of the above","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"184","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"150","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Total","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"201","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"156","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"After the enactment of the Officer Personnel Act of 1947, section 308 of the Army Organization Act of 1950 (10:61–1) provided for an Assistant Judge Advocate General and three brigadier generals in the Judge Advocate General’s Corps of the Army. The creation of these four general officer spaces served to increase the mentioned authorized strength figure from 357 to 361, and the figure 201 to 205. The opinion of the Judge Advocate General of the Army (JAGA 1948/5806, 2 Sept. 1948) is in accord with that conclusion.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The revised section reflects the authorized strength of the Regular Air Force in general officers on the active list resulting from the mentioned allocation to the Air Force.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"That allocation, and those mentioned in the explanation of subsection (c) below, have had the force of law since ","children":[{"tag":"date","attrib":{"date":"1950-07-26"},"text":"July 26, 1950","children":[],"tail":", when the period for transfers, including the administrative authority to change these allocations, expired."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “regular” is substituted for the word “permanent” throughout the revised subsection.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), 10:506a(a) (1st proviso) is omitted, since there is no authority to appoint to a regular grade above major general. 10:506a(a) (last 65 words of 2d proviso) is omitted as executed by the declaration of a national emergency on ","children":[{"tag":"date","attrib":{"date":"1950-12-16"},"text":"December 16, 1950","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the figures “4” and “2” result from the allocation of the original figures “16” and “8”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the figure “1” results from the allocation of the original figures “4” and “2”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(3), the figure “1” results from the allocation of the original figures “2” and “1”. (The major general was allocated to the Army, the brigadier general to the Air Force.)","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(4), the figures “150” and “75” result from the allocation of the original figures “334” and “167”. That allocation corresponds to the allotment made by the Secretary of War between the Air Corps and the Army exclusive of the Air Corps, the Medical Department, and the Chaplains, under 10: 506a(a) (3d proviso). That proviso is omitted as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “by law to hold any civil office under the United States” are substituted for the words “by Acts of Congress to hold appointments in the Diplomatic or Consular Service of the Government or to hold any civil office under the Government”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab666094-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab666095-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1958 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[