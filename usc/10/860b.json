{"tag":"section","attrib":{"id":"ida8216ed8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860b"},"text":null,"children":[{"tag":"num","attrib":{"value":"860b"},"text":"§ 860b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 60b. Post-trial actions in summary courts-martial and certain general and special courts-martial","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8216ed9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8216eda-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In a court-martial not specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s860a/a/2"},"text":"section 860a(a)(2) of this title","children":[],"tail":" (article 60a(a)(2)), the convening authority may—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8216edb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dismiss any charge or specification by setting aside the finding of guilty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8216edc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" change a finding of guilty to a charge or specification to a finding of guilty to a lesser included offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8216edd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860b/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disapprove the findings and the sentence and dismiss the charges and specifications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8216ede-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860b/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disapprove the findings and the sentence and order a rehearing as to the findings and the sentence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8216edf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860b/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disapprove, commute, or suspend the sentence, in whole or in part; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8216ee0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860b/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disapprove the sentence and order a rehearing as to the sentence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8216ee1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In a summary court-martial, the convening authority shall approve the sentence or take other action on the sentence under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8216ee2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (4), the convening authority may act under this section only before entry of judgment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8216ee3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The convening authority may act under this section after entry of judgment in a general or special court-martial in the same manner as the convening authority may act under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s860a/d/2"},"text":"section 860a(d)(2) of this title","children":[],"tail":" (article 60a(d)(2)). Such action shall be forwarded to the chief trial judge, who shall ensure appropriate modification to the entry of judgment and shall transmit the entry of judgment to the Judge Advocate General for appropriate action."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8216ee4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860b/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed by the Secretary concerned, a commissioned officer commanding for the time being, a successor in command, or any person exercising general court-martial jurisdiction may act under this section in place of the convening authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8216ee5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations on Rehearings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The convening authority may not order a rehearing under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8216ee6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as to the findings, if there is insufficient evidence in the record to support the findings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8216ee7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reconsider a finding of not guilty of any specification or a ruling which amounts to a finding of not guilty; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8216ee8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reconsider a finding of not guilty of any charge, unless there has been a finding of guilty under a specification laid under that charge, which sufficiently alleges a violation of some article of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8216ee9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submissions by Accused and Victim","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In accordance with rules prescribed by the President, in determining whether to act under this section, the convening authority shall consider matters submitted in writing by the accused or any victim of the offense. Such rules shall include the matter required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s860a/e"},"text":"section 860a(e) of this title","children":[],"tail":" (article 60a(e))."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8216eea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Decision of Convening Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8216eeb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In a general or special court-martial, the decision of the convening authority under this section shall be forwarded to the military judge, with copies provided to the accused and to any victim of the offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8216eec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the convening authority acts on the findings or the sentence under subsection (a)(1), the decision of the convening authority shall include a written explanation of the reasons for such action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8216eed-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLIX/s5323"},"text":"Pub. L. 114–328, div. E, title LIX, § 5323","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2926"},"text":"130 Stat. 2926","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8216eee-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8216eef-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8216ef0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on ","children":[{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
