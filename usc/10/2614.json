{"tag":"section","attrib":{"id":"ida9930076-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2614"},"text":null,"children":[{"tag":"num","attrib":{"value":"2614"},"text":"§ 2614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency communications equipment: acceptance from local public safety agencies for temporary use related to disasters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9930077-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2614/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Accept Equipment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9930078-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2614/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (c), the Secretary concerned—","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9930079-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2614/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may accept communications equipment for use in coordinating joint response and recovery operations with public safety agencies in the event of a disaster; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida993007a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2614/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may accept services related to the operation and maintenance of such equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida993007b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2614/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority under subsection (a) shall be exercised under regulations prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida993007c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2614/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida993007d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2614/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Equipment may be accepted under subsection (a)(1) only to the extent that communications equipment under the control of the Secretary concerned at the potential disaster response site is inadequate to meet military requirements for communicating with public safety agencies during the period of response to the disaster.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida993007e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2614/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Services may be accepted under subsection (a)(2) related to the operation and maintenance of communications equipment only to the extent that the necessary capabilities are not available to the military commander having custody of the equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida993007f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2614/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person providing services accepted under this section may not be considered, by reason of the provision of such services, to be an officer, employee, or agent of the United States for any purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9930080-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tX/s1051/a"},"text":"Pub. L. 108–375, div. A, title X, § 1051(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2053"},"text":"118 Stat. 2053","children":[],"tail":", § 2613; renumbered § 2614 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tX/s1071/a/19/A"},"text":"Pub. L. 109–364, div. A, title X, § 1071(a)(19)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2399"},"text":"120 Stat. 2399","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9930081-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9930082-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9930083-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2613"},"text":"section 2613 of this title","children":[],"tail":" as this section and redesignated the second subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
