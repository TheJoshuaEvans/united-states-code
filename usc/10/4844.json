{"tag":"section","attrib":{"id":"idaa9e0764-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4844"},"text":null,"children":[{"tag":"num","attrib":{"value":"4844"},"text":"§ 4844.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacturing experts in the classroom","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa9e0765-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4844/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense, in consultation with the Secretary of Education and the Secretary of Commerce, shall conduct a program to support the following activities of one or more manufacturing experts at institutions of higher education:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa9e0766-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4844/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identifying the education and training requirements of United States manufacturing firms located in the same geographic region as an institution participating in the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e0767-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4844/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assisting in the development of teaching curricula for classroom and in-factory education and training classes at such an institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e0768-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4844/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Teaching such classes and overseeing the teaching of such classes by others.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e0769-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4844/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improving the knowledge and expertise of permanent faculty and staff of such an institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e076a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4844/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Marketing the programs and facilities of such an institution to firms referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e076b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4844/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinating the activities described in the other provisions of this subsection with other programs conducted by the Federal Government, any State, any local government, or any private, nonprofit organization to modernize United States manufacturing firms, especially the regional centers for the transfer of manufacturing technology and programs receiving financial assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4843"},"text":"section 4843 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa9e076c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4844/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Merit Competition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Applications for assistance under this section shall be evaluated on the basis of merit pursuant to competitive procedures prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa9e076d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4844/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall select institutions for the award of financial assistance under this section from among institutions submitting applications for such assistance that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa9e076e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4844/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate that the proposed activities are of an appropriate scale and a sufficient quality to ensure long term improvement in the applicant’s capability to serve the education and training needs of United States manufacturing firms in the same region as the applicant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e076f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4844/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate a significant level of industry involvement and support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e0770-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4844/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate attention to the needs of any United States industries that supply manufactured products to the Department of Defense or to a contractor of the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e0771-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4844/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet such other criteria as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa9e0772-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4844/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Support","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of financial assistance furnished to an institution under this section may not exceed 50 percent of the estimated cost of carrying out the activities proposed to be supported in part with such financial assistance for the period for which the assistance is to be provided. In no event may the amount of the financial assistance provided to an institution exceed $250,000 per year. The period for which financial assistance is provided an institution under this section shall be at least two years unless such assistance is earlier terminated for cause determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa9e0773-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4844/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Manufacturing Expert Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “manufacturing expert” means manufacturing managers and workers having experience in the organization of production and education and training needs and other experts in manufacturing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa9e0774-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVIII/s825/a/1"},"text":"Pub. L. 102–190, div. A, title VIII, § 825(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1440"},"text":"105 Stat. 1440","children":[],"tail":", § 2197; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dD/tXLII/s4238/a"},"text":"Pub. L. 102–484, div. D, title XLII, § 4238(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2694"},"text":"106 Stat. 2694","children":[],"tail":"; renumbered § 4844 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1869/d"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1869(d)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/p/1"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(p)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2148"},"text":"135 Stat. 2148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa9e0775-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"ro