{"tag":"section","attrib":{"id":"ida9cea8ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2771"},"text":null,"children":[{"tag":"num","attrib":{"value":"2771"},"text":"§ 2771.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final settlement of accounts: deceased members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9cea8cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2771/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the settlement of the accounts of a deceased member of the armed forces, an amount due from the armed force of which he was a member shall be paid to the person highest on the following list living on the date of death:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9cea8d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2771/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Beneficiary designated by him in writing to receive such an amount, if the designation is received, before the deceased member’s death, at the place named in regulations to be prescribed by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cea8d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2771/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Surviving spouse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cea8d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2771/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Children and their descendants, by representation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cea8d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2771/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Father and mother in equal parts or, if either is dead, the survivor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cea8d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2771/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Legal representative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cea8d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2771/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Person entitled under the law of the dom­icile of the deceased member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cea8d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2771/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Designations and changes of designation of beneficiaries under subsection (a)(1) are subject to regulations to be prescribed by the Secretary concerned. So far as practicable, these regulations shall be uniform for the uniformed services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cea8d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2771/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payments under subsection (a) shall be made by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cea8d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2771/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A payment under this section bars recovery by any other person of the amount paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9cea8d9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/155"},"text":"70A Stat. 155","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/56"},"text":"Pub. L. 85–861, § 1(56)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1461"},"text":"72 Stat. 1461","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/641"},"text":"Pub. L. 86–641","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/473"},"text":"74 Stat. 473","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s8/a"},"text":"Pub. L. 89–718, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1117"},"text":"80 Stat. 1117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s511/97"},"text":"Pub. L. 96–513, title V, § 511(97)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2928"},"text":"94 Stat. 2928","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tXI/s1182/a/11"},"text":"Pub. L. 103–160, div. A, title XI, § 1182(a)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1771"},"text":"107 Stat. 1771","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tII/s202/f"},"text":"Pub. L. 104–316, title II, § 202(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3842"},"text":"110 Stat. 3842","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9cea8da-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida9cea8db-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida9cea8dc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1956 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2771(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2771(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:868 (less proviso).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"34:941a (less proviso).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:868 (proviso).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"34:941a (proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1906-06-30/ch3914/s1"},"text":"June 30, 1906, ch. 3914, § 1","children":[],"tail":" (last par. under “State or Territorial Homes for Disabled Soldiers and Sailors”); restated "},{"tag":"html:a","attrib":{"href":"/us/act/1944-12-07/ch519"},"text":"Dec. 7, 1944, ch. 519","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1946-02-25/ch35/s4"},"text":"Feb. 25, 1946, ch. 35, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/30"},"text":"60 Stat. 30","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-02-25/ch35/s1"},"text":"Feb. 25, 1946, ch. 35, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/30"},"text":"60 Stat. 30","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1949-08-04/ch393/s18"},"text":"Aug. 4, 1949, ch. 393, § 18","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/560"},"text":"63 Stat. 560","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b), the words “General Accounting Office” are substituted for the words “accounting officers”, for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “member” is substituted for the words “officers or enlisted persons”, in 10:868 and 34:941a. The words “his legal representative” are substituted for the words “a duly appointed legal representative of the estate”, since an estate, being property and not an entity, has no representative. The words “duly appointed” are omitted as surplusage. The words “highest on the following list” are substituted for the words “following order of precedence”, in 10:868 and 34:941a. Clauses (1)–(4) are substituted for the words between the first and second colons of 10:868 and 34:941a. The words “Surviving spouse” are substituted for the words “widow or widower” after the words “First, to”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “That this section shall not be so construed as to prevent”, “or persons”, and “actually”, in 10:868 and 34:941a, are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida9cea8dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida9cea8de-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1958 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2771(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2771(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:361.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"37:362.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"37:365.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"37:364 (less proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1955-07-12/ch328"},"text":"July 12, 1955, ch. 328","children":[],"tail":", §§ 1–3, 4 (less proviso), 5 (first sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/69/295"},"text":"69 Stat. 295","children":[],"tail":", 296."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2771(c)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2771(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:363 (less last sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"37:363 (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the definition of the term “Department”, in 37:361, is omitted as unnecessary, since the particular departments referred to are spelled out in the revised text. The definition of the term “uniformed services”, in 37:361, is omitted as covered by the word “member” in this revised section and by sections 3 and 4 of the Act enacting this revised section. Clauses (1)–(6) are substituted for the last 5 clauses of 37:362. The words “regulations to be prescribed by the Secretary concerned” are substituted for the words “regulations of the Department concerned”, since the “Department”, as such, cannot issue regulations.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “surviving spouse” are substituted for the words “widow or widower”. As defined in section 101(32), “spouse” includes a widower.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “are subject to” are substituted for the words “shall be made under”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “Under” is substituted for the words “Subject to”. The words “rules and” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9cea8df-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9cea8e0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316"},"text":"Pub. L. 104–316","children":[],"tail":" amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “Under such regulations as the Comptroller General may prescribe, payments under subsection (a) shall be made by the military department concerned or the Department of Transportation, as the case may be. Payment under clause (6) of subsection (a) shall be made—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) upon settlement by the General Accounting Office; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) as otherwise authorized by the Comptroller General.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s1182/a/11/A"},"text":"Pub. L. 103–160, § 1182(a)(11)(A)","children":[],"tail":", struck out “who dies after "},{"tag":"date","attrib":{"date":"1955-12-31"},"text":"December 31, 1955","children":[],"tail":"” after “armed forces” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s1182/a/11/B"},"text":"Pub. L. 103–160, § 1182(a)(11)(B)","children":[],"tail":", substituted “for the uniformed services” for “for the armed forces, the National Oceanic and Atmospheric Administration, and the Public Health Service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s511/97/A"},"text":"Pub. L. 96–513, § 511(97)(A)","children":[],"tail":", substituted “National Oceanic and Atmospheric Administration” for “Environmental Science Services Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s511/97/B"},"text":"Pub. L. 96–513, § 511(97)(B)","children":[],"tail":", substituted “Department of Transportation” for “Department of the Treasury”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/718"},"text":"Pub. L. 89–718","children":[],"tail":" substituted “Environmental Science Services Administration” for “Coast and Geodetic Survey”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/641"},"text":"Pub. L. 86–641","children":[],"tail":" substituted provisions requiring payment under clause (6) of subsection (a) to be made upon settlement by the General Accounting Office or as otherwise authorized by the Comptroller General for provisions which permitted payments under clauses (2) to (6) of subsection (a) to be made only after settlement by the General Accounting Office."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":" amended subsec. (a) generally to restrict application of section to members of the armed forces who die after "},{"tag":"date","attrib":{"date":"1955-12-31"},"text":"Dec. 31, 1955","children":[],"tail":", and to permit payment to the designated beneficiaries, surviving spouse, children and their descendants, and to parents before payment to the legal representative."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":" substituted provisions relating to designations and changes of designation of beneficiaries for provisions which authorized reimbursement of funeral expenses."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":" added subsecs. (c) and (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9cea8e1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9cea8e2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/b/3"},"text":"section 701(b)(3) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"repeals","id":"ida9cea8e3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeals","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The directory language of, but not the amendment made by, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/718/s8/a"},"text":"Pub. L. 89–718, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1117"},"text":"80 Stat. 1117","children":[],"tail":", cited as a credit to this section, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s6/b"},"text":"Pub. L. 97–295, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1314"},"text":"96 Stat. 1314","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9cea8e4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Final Settlement of Accounts of Members Who Died Before ","children":[{"tag":"date","attrib":{"date":"1960-01-01"},"text":"January 1, 1960","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s29"},"text":"Pub. L. 85–861, § 29","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1563"},"text":"72 Stat. 1563","children":[],"tail":", authorized the General Accounting Office, in the settlement of the accounts of a member of the Army, Navy, Air Force, or Marine Corps who died before "},{"tag":"date","attrib":{"date":"1956-01-01"},"text":"Jan. 1, 1956","children":[],"tail":", to allow any amount due to the person highest on a list of persons living on the date of settlement and to provide reimbursement for funeral expenses from the amount due the decedent’s estate."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9cea8e5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Designation of Beneficiary Made Before January 1, 1956","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s31"},"text":"Pub. L. 85–861, § 31","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1563"},"text":"72 Stat. 1563","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/85/861/s31"},"text":"“The designation of a beneficiary made for the purposes of any six months’ death gratuity, including the designation of a person whose right to the gratuity does not depend upon that designation, and received in the military department concerned, the Department of the Treasury, the Department of Commerce, or the Department of Health, Education, and Welfare, as the case may be, before ","children":[{"tag":"date","attrib":{"date":"1956-01-01"},"text":"January 1, 1956","children":[],"tail":", is considered as the designation of a beneficiary for the purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2771"},"text":"section 2771 of title 10","children":[],"tail":", United States Code [this section], "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s714"},"text":"section 714 of title 32","children":[],"tail":", United States Code, and sections 3 and 4 of this Act [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s857a"},"text":"section 857a of Title 33","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s213a"},"text":"section 213a of Title 42","children":[],"tail":"], in the absence of a designation under one of those sections, unless the member making the designation was missing, missing in action, in the hands of a hostile force, or interned in a foreign country any time after "},{"tag":"date","attrib":{"date":"1955-07-11"},"text":"July 11, 1955","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1956-01-01"},"text":"January 1, 1956","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"ida9cea8e6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"ida9cea8e7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of Public Health Service, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s802"},"text":"section 802 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
