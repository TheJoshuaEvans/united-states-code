{"tag":"section","attrib":{"id":"idabadf0b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12738"},"text":null,"children":[{"tag":"num","attrib":{"value":"12738"},"text":"§ 12738.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on revocation of retired pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabadf0ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12738/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After a person is granted retired pay under this chapter, or is notified in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12731/d"},"text":"section 12731(d) of this title","children":[],"tail":" that the person has completed the years of service required for eligibility for retired pay under this chapter, the person’s eligibility for retired pay may not be denied or revoked on the basis of any error, miscalculation, misinformation, or administrative determination of years of service performed as required by "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12731/a/2"},"text":"section 12731(a)(2) of this title","children":[],"tail":", unless it resulted directly from the fraud or misrepresentation of the person."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabadf0bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12738/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of years of creditable service upon which retired pay is computed may be adjusted to correct any error, miscalculation, misinformation, or administrative determination and when such a correction is made the person is entitled to retired pay in accordance with the number of years of creditable service, as corrected, from the date the person is granted retired pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabadf0bc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/652/s2/1"},"text":"Pub. L. 89–652, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-14"},"text":"Oct. 14, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/902"},"text":"80 Stat. 902","children":[],"tail":", § 1406; renumbered § 1338 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/348/tI/s104/a"},"text":"Pub. L. 99–348, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-07-01"},"text":"July 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/686"},"text":"100 Stat. 686","children":[],"tail":"; renumbered § 12738 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1662/j/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1662(j)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2998"},"text":"108 Stat. 2998","children":[],"tail":", 3003.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabadf0bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabadf0be-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabadf0bf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1338"},"text":"section 1338 of this title","children":[],"tail":" as this section and amended text generally, making changes in style and references to other sections."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/348"},"text":"Pub. L. 99–348","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1406"},"text":"section 1406 of this title","children":[],"tail":" as this section, designated first sentence as subsec. (a) and substituted “this chapter” for “chapter 67 of this title” in two places, and designated second sentence as subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabadf0c0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idabadf0c1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691"},"text":"section 1691 of Pub. L. 103–337","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idabadf0c2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Entitlement to Retirement Pay After ","children":[{"tag":"date","attrib":{"date":"1966-10-14"},"text":"October 14, 1966","children":[],"tail":"; Conclusiveness"}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/652/s3"},"text":"Pub. L. 89–652, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-14"},"text":"Oct. 14, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/902"},"text":"80 Stat. 902","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/652/s3"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Notwithstanding section 1406 [now 12738] of title 10, United States Code, as added by this Act—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the granting of retired pay to a person under chapter 67 [now 1223] of that title is conclusive as to that person’s entitlement to such pay only if the payment of that retired pay is begun after the effective date of this Act [","children":[{"tag":"date","attrib":{"date":"1966-10-14"},"text":"Oct. 14, 1966","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a notification that a person has completed the years of service required for eligibility for retired pay under chapter 67 [now 1223] of that title is conclusive as to the person’s subsequent entitlement to such pay only if the notification is made after the effective date of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
