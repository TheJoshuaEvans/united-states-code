{"tag":"section","attrib":{"id":"idaab5fcf5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5536"},"text":null,"children":[{"tag":"num","attrib":{"value":"5536"},"text":"§ 5536.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testing and assessment of missile defense systems prior to production and deployment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaab5fcf6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5536/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Successful Testing Required Prior to Final Production or Operational Deployment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may not make a final production decision for, or operationally deploy, a covered system unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab5fcf7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5536/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary ensures that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaab5fcf8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5536/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sufficient and operationally realistic testing of the covered system is conducted to assess the performance of the covered system in order to inform a final production decision or an operational deployment decision; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab5fcf9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5536/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the results of such testing have demonstrated a high probability that the covered system—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaab5fcfa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5536/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will work in an operationally effective manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaab5fcfb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5536/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the ability to accomplish the intended mission of the covered system; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab5fcfc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5536/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of Operational Test and Evaluation has carried out subsection (b) with respect to such covered system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab5fcfd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5536/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment by Director of Operational Test and Evaluation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of Operational Test and Evaluation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab5fcfe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5536/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the Secretary the assessment of the Director, based on the available test data, of the sufficiency, adequacy, and results of the testing of each covered system, including an assessment of whether the covered system will be sufficiently effective, suitable, and survivable when needed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab5fcff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5536/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the congressional defense committees a written summary of such assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab5fd00-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5536/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to alter, modify, or otherwise affect a determination of the Secretary with respect to the participation of the Missile Defense Agency in the Joint Capabilities Integration Development System or the acquisition reporting process under the Department of Defense Directive 5000 series, or to diminish the authority of the Secretary of Defense to deploy a missile defense system at the date on which the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab5fd01-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5536/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered System","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “covered system” means a new or substantially upgraded interceptor or weapon system of the ballistic missile defense system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaab5fd02-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1649/a"},"text":"Pub. L. 118–159, div. A, title XVI, § 1649(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2197"},"text":"138 Stat. 2197","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaab5fd03-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaab5fd04-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaab5fd05-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5536, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/319"},"text":"70A Stat. 319","children":[],"tail":", related to extension of service by reason of time lost through misconduct or unauthorized absence, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s36B/13"},"text":"Pub. L. 85–861, § 36B(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1571"},"text":"72 Stat. 1571","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s972/a"},"text":"section 972(a) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tXVI/s1662"},"text":"Pub. L. 113–291, div. A, title XVI, § 1662","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3657"},"text":"128 Stat. 3657","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tXVI/s1677/b"},"text":"Pub. L. 115–91, div. A, title XVI, § 1677(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1774"},"text":"131 Stat. 1774","children":[],"tail":", which was set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4205"},"text":"section 4205 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1649/b/9"},"text":"Pub. L. 118–159, div. A, title XVI, § 1649(b)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2199"},"text":"138 Stat. 2199","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
