{"tag":"section","attrib":{"id":"ida92c7585-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2116"},"text":null,"children":[{"tag":"num","attrib":{"value":"2116"},"text":"§ 2116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military nursing research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida92c7586-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida92c7587-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2116/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “military nursing research” means research on the furnishing of care and services by nurses in the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c7588-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2116/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “TriService Nursing Research Program” means the program of military nursing research authorized under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92c7589-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may establish at the University a program of military nursing research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92c758a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2116/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"TriService Research Group","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The TriService Nursing Research Program shall be administered by a TriService Nursing Research Group composed of Army, Navy, and Air Force nurses who are involved in military nursing research and are designated by the Secretary concerned to serve as members of the group.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92c758b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2116/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties of Group","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The TriService Nursing Research Group shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida92c758c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2116/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop for the Department of Defense recommended guidelines for requesting, reviewing, and funding proposed military nursing research projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c758d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2116/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make available to Army, Navy, and Air Force nurses and Department of Defense officials concerned with military nursing research—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida92c758e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2116/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information about nursing research projects that are being developed or carried out in the Army, Navy, and Air Force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92c758f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2116/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expertise and information beneficial to the encouragement of meaningful nursing research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92c7590-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2116/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Research Topics","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, military nursing research includes research on the following issues:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida92c7591-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2116/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Issues regarding how to improve the results of nursing care and services provided in the armed forces in time of peace.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c7592-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2116/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Issues regarding how to improve the results of nursing care and services provided in the armed forces in time of war.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c7593-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2116/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Issues regarding how to prevent complications associated with battle injuries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c7594-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2116/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Issues regarding how to prevent complications associated with the transporting of patients in the military medical evacuation system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c7595-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2116/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Issues regarding how to improve methods of training nursing personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c7596-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2116/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Clinical nursing issues, including such issues as prevention and treatment of child abuse and spouse abuse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c7597-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2116/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Women’s health issues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c7598-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2116/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Wellness issues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c7599-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2116/e/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Preventive medicine issues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c759a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2116/e/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Home care management issues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c759b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2116/e/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Case management issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida92c759c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tVII/s741/a"},"text":"Pub. L. 104–106, div. A, title VII, § 741(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/384"},"text":"110 Stat. 384","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida92c759d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida92c759e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida92c759f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2116, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/426/s2/a"},"text":"Pub. L. 92–426, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-21"},"text":"Sept. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/716"},"text":"86 Stat. 716","children":[],"tail":", directed Secretary of Defense to report periodically to Committees on Armed Services of the Senate and House of Representatives on feasibility of establishing educational institutions similar or identical to University at any other locations he deemed appropriate, with last such report to be submitted by "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/98/94/tXII/s1268/12/A"},"text":"Pub. L. 98–94, title XII, § 1268(12)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/706"},"text":"97 Stat. 706","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
