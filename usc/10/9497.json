{"tag":"section","attrib":{"id":"idab7be49f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497"},"text":null,"children":[{"tag":"num","attrib":{"value":"9497"},"text":"§ 9497.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Governors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab7be4a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Governing Body","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board of Governors of the Civil Air Patrol is the governing body of the Civil Air Patrol.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7be4a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board of Governors is composed of 11 members as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab7be4a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Four members appointed by the Secretary of the Air Force, who may be active or retired officers of the Air Force (including reserve components of the Air Force), employees of the United States, or private citizens.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be4a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Four members of the Civil Air Patrol, selected in accordance with the constitution and bylaws of the Civil Air Patrol.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be4a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members appointed or selected as provided in subsection (c) from among personnel of any Federal Government agencies, public corporations, nonprofit associations, and other organizations that have an interest and expertise in civil aviation and the Civil Air Patrol mission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7be4a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointments From Interested Organizations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab7be4a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), the members of the Board of Governors referred to in subsection (b)(3) shall be appointed jointly by the Secretary of the Air Force and the National Commander of the Civil Air Patrol.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be4a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vacancy in the position of a member referred to in paragraph (1) that is not filled under that paragraph within 90 days shall be filled by majority vote of the other members of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7be4a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairman","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chairman of the Board of Governors shall be chosen by the members of the Board of Governors from among the members of the Board referred to in paragraphs (1) and (2) of subsection (b) and shall serve for a term of two years. The position of Chairman shall be held on a rotating basis between members of the Board appointed by the Secretary of the Air Force under paragraph (1) of subsection (b) and members of the Board selected under paragraph (2) of that subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7be4a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Powers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab7be4aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board of Governors shall, subject to paragraphs (2) and (3), exercise the powers granted to the Civil Air Patrol under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s40304"},"text":"section 40304 of title 36","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be4ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any exercise by the Board of the power to amend the constitution or bylaws of the Civil Air Patrol or to adopt a new constitution or bylaws shall be subject to approval by a majority of the members of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be4ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Neither the Board of Governors nor any other component of the Civil Air Patrol may modify or terminate any requirement or authority set forth in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7be4ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personal Liability for Breach of a Fiduciary Duty","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab7be4ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), the Board of Governors may take such action as is necessary to limit the personal liability of a member of the Board of Governors to the Civil Air Patrol, or to any of its members, for monetary damages for a breach of fiduciary duty while serving as a member of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be4af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Board may not limit the liability of a member of the Board of Governors to the Civil Air Patrol, or to any of its members, for monetary damages for any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab7be4b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A breach of the member’s duty of loyalty to the Civil Air Patrol or its members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab7be4b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any act or omission that is not in good faith or that involves intentional misconduct or a knowing violation of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab7be4b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Participation in any transaction from which the member directly or indirectly derives an improper personal benefit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be4b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this subsection shall be construed as rendering section 207 or 208 of title 18 inapplicable in any respect to a member of the Board of Governors who is a member of the Air Force on active duty, an officer on a retired list of the Air Force, or an employee of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7be4b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personal Liability for Breach of a Fiduciary Duty","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab7be4b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), no member of the Board of Governors or officer of the Civil Air Patrol shall be personally liable for damages for any injury or death or loss or damage of property resulting from a tortious act or omission of an employee or member of the Civil Air Patrol.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be4b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) does not apply to a member of the Board of Governors or officer of the Civil Air Patrol for a tortious act or omission in which the member or officer, as the case may be, was personally involved, whether in breach of a civil duty or in commission of a criminal offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be4b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this subsection shall be construed to restrict the applicability of common law protections and rights that a member of the Board of Governors or officer of the Civil Air Patrol may have.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be4b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9497/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The protections provided under this subsection are in addition to the protections provided under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab7be4b9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1090(a)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–298, § 9447; renumbered § 9497, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/a/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1832"},"text":"132 Stat. 1832","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab7be4ba-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab7be4bb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab7be4bc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s806/a/1"},"text":"Pub. L. 115–232, § 806(a)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9447"},"text":"section 9447 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab7be4bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab7be4be-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idab7be4bf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 120 days after ","children":[{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", see section 1 [[div. A], title X, § 1090(c)] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9491"},"text":"section 9491 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
