{"tag":"section","attrib":{"id":"idaaecc381-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7438"},"text":null,"children":[{"tag":"num","attrib":{"value":"7438"},"text":"§ 7438.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civilian faculty: number; compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaecc382-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7438/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army may employ as many civilians as professors, instructors, and lecturers at the Academy as the Secretary considers necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaecc383-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7438/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The compensation of persons employed under this section is as prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaecc384-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7438/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Army may, notwithstanding the provisions of subchapter V of chapter 55 of title 5 or section 6101 of such title, prescribe for persons employed under this section the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaecc385-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7438/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The work schedule, including hours of work and tours of duty, set forth with such specificity and other characteristics as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaecc386-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7438/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any premium pay or compensatory time off for hours of work or tours of duty in excess of the regularly scheduled hours or tours of duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaecc387-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tV/s533/a/1"},"text":"Pub. L. 103–160, div. A, title V, § 533(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1658"},"text":"107 Stat. 1658","children":[],"tail":", § 4338; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tXI/s1107/a"},"text":"Pub. L. 106–65, div. A, title XI, § 1107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/778"},"text":"113 Stat. 778","children":[],"tail":"; renumbered § 7438, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/c/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaecc388-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaecc389-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"c