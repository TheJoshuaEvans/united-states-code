{"tag":"section","attrib":{"id":"idab6d8bda-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9326"},"text":null,"children":[{"tag":"num","attrib":{"value":"9326"},"text":"§ 9326.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of years of service: voluntary retirement; regular and reserve commissioned officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab6d8bdb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9326/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of determining whether an officer of the Air Force or the Space Force may be retired under section 9311, 9318, or 9324 of this title, the officer’s years of service are computed by adding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab6d8bdc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9326/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all active service performed as a member of the Army, the Air Force, or the Space Force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab6d8bdd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9326/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all service in the Navy or Marine Corps that may be included in determining the eligibility of an officer of the Navy or Marine Corps for retirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab6d8bde-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9326/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of determining whether a medical officer of the Regular Air Force may be retired under section 9311, 9318, or 9324 of this title, the officer’s years of service are computed by adding to the officer’s service under subsection (a) all service performed as a contract surgeon, acting assistant surgeon, or contract physician, under a contract to serve full time and to take and change station as ordered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab6d8bdf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9326/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of determining whether a dental officer of the Regular Air Force may be retired under section 9311, 9318, or 9324 of this title, the officer’s years of service are computed by adding to the officer’s service under subsection (a) all service as a contract dental surgeon or acting dental surgeon.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab6d8be0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9326/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s972/b"},"text":"Section 972(b) of this title","children":[],"tail":" excludes from computation of an officer’s years of service for purposes of this section any time identified with respect to that officer under that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab6d8be1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/552"},"text":"70A Stat. 552","children":[],"tail":", § 8926; "},{"tag":"ref","attrib":{"href":"/us/pl/86/197/s1/8"},"text":"Pub. L. 86–197, § 1(8)","chil