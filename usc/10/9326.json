tail":" that occurs after that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/s561/e"},"text":"section 561(e) of Pub. L. 104–106","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s972"},"text":"section 972 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
