 Stat. 2445","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/tI/s1002"},"text":"Pub. L. 103–355, title I, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3249"},"text":"108 Stat. 3249","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s812/a/2/C/v"},"text":"Pub. L. 115–232, div. A, title VIII, § 812(a)(2)(C)(v)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1847"},"text":"132 Stat. 1847","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa1157d0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3203, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/173"},"text":"70A Stat. 173","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/64"},"text":"Pub. L. 85–861, § 1(64)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1463"},"text":"72 Stat. 1463","children":[],"tail":", prescribed authorized strength of Regular Army in members on active duty, exclusive of officers candidates, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tII/s202"},"text":"Pub. L. 96–513, title II, § 202","children":[],"tail":", title VII, § 701, "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2878"},"text":"94 Stat. 2878","children":[],