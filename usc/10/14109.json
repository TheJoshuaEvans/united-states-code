{"tag":"section","attrib":{"id":"idabb03ae0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14109"},"text":null,"children":[{"tag":"num","attrib":{"value":"14109"},"text":"§ 14109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports of promotion boards: in general","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabb03ae1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report of Officers Recommended for Promotion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each promotion board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14101/a"},"text":"section 14101(a) of this title","children":[],"tail":" shall submit to the Secretary of the military department concerned a report in writing containing a list of the names of the officers recommended by the board for promotion. The report shall be signed by each member of the board."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb03ae2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subsection (a) shall include a certification—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb03ae3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14109/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the board has carefully considered the record of each officer whose name was furnished to the board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb03ae4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14109/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that, in the case of a promotion board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14101/a"},"text":"section 14101(a) of this title","children":[],"tail":", in the opinion of a majority of the members of the board, the officers recommended for promotion by the board are best qualified for promotion to meet the needs of the armed force concerned (as noted in the guidelines or information furnished the board under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s14107"},"text":"section 14107 of this title","children":[],"tail":") among those officers whose names were furnished to the selection board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb03ae5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14109/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Show-Cause Recommendations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb03ae6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14109/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A promotion board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14101/a"},"text":"section 14101(a) of this title","children":[],"tail":" shall include in its report to the Secretary concerned the name of any reserve officer before it for consideration for promotion whose record, in the opinion of a majority of the members of the board, indicates that the officer should be required to show cause for retention in an active status."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb03ae7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14109/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If such a report names an officer as having a record which indicates that the officer should be required to show cause for retention, the Secretary concerned may provide for the review of the record of that officer as provided under regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14902"},"text":"section 14902 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb03ae8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14109/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report of Officers Recommended for Higher Placement on Promotion List","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A promotion board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14101/a"},"text":"section 14101(a) of this title","children":[],"tail":" shall, when authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s14108/f"},"text":"section 14108(f) of this title","children":[],"tail":", include in its report to the Secretary concerned—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb03ae9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14109/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the names of those officers the promotion board recommends be placed higher on the promotion list; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb03aea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14109/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the order in which the promotion board recommends those officers should be placed on the promotion list.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabb03aeb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2928"},"text":"108 Stat. 2928","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tV/s510/b"},"text":"Pub. L. 116–92, div. A, title V, § 510(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1347"},"text":"133 Stat. 1347","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb03aec-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabb03aed-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idabb03aee-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in subsecs. (a) and (b) of this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s5897"},"text":"section 5897 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1629/b/2"},"text":"Pub. L. 103–337, § 1629(b)(2)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabb03aef-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabb03af0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabb03af1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691/b/1"},"text":"section 1691(b)(1) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
