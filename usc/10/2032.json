{"tag":"section","attrib":{"id":"ida923006a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2032"},"text":null,"children":[{"tag":"num","attrib":{"value":"2032"},"text":"§ 2032.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility of the Secretaries of the military departments to maximize enrollment and enhance efficiency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida923006b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2032/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of each military department, in establishing, maintaining, transferring, and terminating Junior Reserve Officers’ Training Corps units under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2031"},"text":"section 2031 of this title","children":[],"tail":", shall do so in a coordinated manner that is designed to maximize enrollment in the Corps and to enhance administrative efficiency in the management of the Corps."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida923006c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2032/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration of New School Openings and Consolidations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Secretary of a military department shall take into consideration—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida923006d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2032/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" openings of new schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida923006e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2032/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consolidations of schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida923006f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2032/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the desirability of continuing the opportunity for participation in the Corps by participants whose continued participation would otherwise be adversely affected by new school openings and consolidations of schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9230070-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tV/s546/a"},"text":"Pub. L. 105–85, div. A, title V, § 546(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1746"},"text":"111 Stat. 1746","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
