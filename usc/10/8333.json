{"tag":"section","attrib":{"id":"idab1ed00a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8333"},"text":null,"children":[{"tag":"num","attrib":{"value":"8333"},"text":"§ 8333.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of retired and retainer pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab1ed00b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8333/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The monthly retired pay or retainer pay of a member entitled to such pay under this chapter or under section 8470 or 8372 of this title is computed in accordance with the following table.","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab1ed00c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Formula","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"For","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"sections","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Column 1","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"Take","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Column 2","