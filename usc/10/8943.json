{"tag":"section","attrib":{"id":"idab55beed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8943"},"text":null,"children":[{"tag":"num","attrib":{"value":"8943"},"text":"§ 8943.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplies: military instruction camps","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Under such conditions as he may prescribe, the Secretary of the Navy may issue, to any educational institution at which an officer of the naval service is detailed as professor of naval science, such supplies as are necessary to establish and maintain a camp for the military instruction of its students. The Secretary shall require a bond in the value of the property issued under this section, for the care and safekeeping of that property and except for property properly expended, for its return when required.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab55beee-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tIII/s377/a"},"text":"Pub. L. 110–181, div. A, title III, § 377(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/85"},"text":"122 Stat. 85","children":[],"tail":", § 7913; renumbered § 8943, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/15"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab55beef-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab55bef0-3a6f-