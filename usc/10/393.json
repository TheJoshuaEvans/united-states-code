{"tag":"section","attrib":{"id":"ida7aefdfd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393"},"text":null,"children":[{"tag":"num","attrib":{"value":"393"},"text":"§ 393.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting on penetrations of networks and information systems of certain contractors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7aefdfe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures for Reporting Penetrations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall establish procedures that require each cleared defense contractor to report to a component of the Department of Defense designated by the Secretary for purposes of such procedures when a network or information system of such contractor that meets the criteria established pursuant to subsection (b) is successfully penetrated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7aefdff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Networks and Information Systems Subject to Reporting","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7aefe00-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall designate a senior official to, in consultation with the officials specified in paragraph (2), establish criteria for covered networks to be subject to the procedures for reporting system penetrations under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7aefe01-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officials","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The officials specified in this subsection are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7aefe02-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense for Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aefe03-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense for Acquisition and Sustainment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aefe04-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary of Defense for Research and Engineering.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aefe05-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense for Intelligence and Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aefe06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Information Officer of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aefe07-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commander of the United States Cyber Command.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7aefe08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedure Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7aefe09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rapid reporting","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The procedures established pursuant to subsection (a) shall require each cleared defense contractor to rapidly report to a component of the Department of Defense designated pursuant to subsection (a) of each successful penetration of the network or information systems of such contractor that meet the criteria established pursuant to subsection (b). Each such report shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7aefe0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the technique or method used in such penetration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aefe0b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A sample of the malicious software, if discovered and isolated by the contractor, involved in such penetration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aefe0c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary of information created by or for the Department in connection with any Department program that has been potentially compromised due to such penetration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7aefe0d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access to equipment and information by department of defense personnel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The procedures established pursuant to subsection (a) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7aefe0e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include mechanisms for Department of Defense personnel to, upon request, obtain access to equipment or information of a cleared defense contractor necessary to conduct forensic analysis in addition to any analysis conducted by such contractor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aefe0f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that a cleared defense contractor is only required to provide access to equipment or information as described in subparagraph (A) to determine whether information created by or for the Department in connection with any Department program was successfully exfiltrated from a network or information system of such contractor and, if so, what information was exfiltrated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aefe10-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the reasonable protection of trade secrets, commercial or financial information, and information that can be used to identify a specific person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7aefe11-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dissemination of information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The procedures established pursuant to subsection (a) shall limit the dissemination of information obtained or derived through such procedures to entities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7aefe12-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with missions that may be affected by such information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aefe13-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that may be called upon to assist in the diagnosis, detection, or mitigation of cyber incidents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aefe14-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that conduct counterintelligence or law enforcement investigations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aefe15-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for national security purposes, including cyber situational awareness and defense purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7aefe16-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protection From Liability of Cleared Defense Contractors","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7aefe17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No cause of action shall lie or be maintained in any court against any cleared defense contractor, and such action shall be promptly dismissed, for compliance with this section that is conducted in accordance with the procedures established pursuant to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7aefe18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7aefe19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing in this section shall be construed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida7aefe1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require dismissal of a cause of action against a cleared defense contractor that has engaged in willful misconduct in the course of complying with the procedures established pursuant to subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7aefe1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to undermine or limit the availability of otherwise applicable common law or statutory defenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aefe1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any action claiming that paragraph (1) does not apply due to willful misconduct described in subparagraph (A), the plaintiff shall have the burden of proving by clear and convincing evidence the willful misconduct by each cleared defense contractor subject to such claim and that such willful misconduct proximately caused injury to the plaintiff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aefe1d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection, the term “willful misconduct” means an act or omission that is taken—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida7aefe1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intentionally to achieve a wrongful purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7aefe1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly without legal or factual justification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7aefe20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/d/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in disregard of a known or obvious risk that is so great as to make it highly probable that the harm will outweigh the benefit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7aefe21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7aefe22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cleared defense contractor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “cleared defense contractor” means a private entity granted clearance by the Department of Defense to access, receive, or store classified information for the purpose of bidding for a contract or conducting activities in support of any program of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7aefe23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s393/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered network","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “covered network” means a network or information system of a cleared defense contractor that contains or processes information created by or for the Department of Defense with respect to which such contractor is required to apply enhanced protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7aefe24-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tXVI/s1641/a"},"text":"Pub. L. 114–92, div. A, title XVI, § 1641(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1114"},"text":"129 Stat. 1114","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s902/8"},"text":"Pub. L. 116–92, div. A, title IX, § 902(8)","children":[],"tail":", title XVI, § 1621(e)(1)(A)(vi), "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1543"},"text":"133 Stat. 1543","children":[],"tail":", 1733; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tX/s1081/a/15"},"text":"Pub. L. 116–283, div. A, title X, § 1081(a)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3871"},"text":"134 Stat. 3871","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tX/s1081/a/9"},"text":"Pub. L. 117–81, div. A, title X, § 1081(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1920"},"text":"135 Stat. 1920","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7aefe25-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7aefe26-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida7aefe27-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section, as added and amended by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":", is based on "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tIX/s941"},"text":"Pub. L. 112–239, div. A, title IX, § 941","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1889"},"text":"126 Stat. 1889","children":[],"tail":", which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2224"},"text":"section 2224 of this title","children":[],"tail":" before being transferred to this chapter and renumbered as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7aefe28-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" inserted period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “of Defense for Intelligence and Security” for “of Defense for Intelligence.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s902/8/A"},"text":"Pub. L. 116–92, § 902(8)(A)","children":[],"tail":", substituted “Under Secretary of Defense for Acquisition and Sustainment” for “Under Secretary of Defense for Acquisition, Technology, and Logistics”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1621/e/1/A/vi"},"text":"Pub. L. 116–92, § 1621(e)(1)(A)(vi)","children":[],"tail":", which directed amendment of subpar. (C) by substituting “Under Secretary of Defense for Intelligence and Security” for “Under Secretary of Defense for Intelligence”, could not be executed because the words “Under Secretary of Defense for Intelligence” did not appear. Similar amendment was subsequently directed to subpar. (D) by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", see 2021 Amendment note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s902/8/B"},"text":"Pub. L. 116–92, § 902(8)(B)","children":[],"tail":", added subpar. (C). Former subpar. (C) redesignated (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(D) to (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s902/8/C"},"text":"Pub. L. 116–92, § 902(8)(C)","children":[],"tail":", redesignated subpars. (C) to (E) as (D) to (F), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s1641/a/1"},"text":"Pub. L. 114–92, § 1641(a)(1)","children":[],"tail":", substituted “Reporting on penetrations of networks and information systems of certain contractors” for “Reports to Department of Defense on penetrations of networks and information systems of certain contractors” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s1641/a"},"text":"Pub. L. 114–92, § 1641(a)","children":[],"tail":", transferred "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/s941"},"text":"section 941 of Pub. L. 112–239","children":[],"tail":" to this chapter and renumbered it as this section. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s1641/a/2"},"text":"Pub. L. 114–92, § 1641(a)(2)","children":[],"tail":", added par. (3) and struck out former par. (3). Prior to amendment, text read as follows: “The procedures established pursuant to subsection (a) shall prohibit the dissemination outside the Department of Defense of information obtained or derived through such procedures that is not created by or for the Department except with the approval of the contractor providing such information.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s1641/a/3"},"text":"Pub. L. 114–92, § 1641(a)(3)","children":[],"tail":", added subsec. (d) and struck out former subsec. (d). Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—Not later than 90 days after the date of the enactment of this Act—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the Secretary of Defense shall establish the procedures required under subsection (a); and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the senior official designated under subsection (b)(1) shall establish the criteria required under such subsection.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Applicability date","children":[],"tail":".—The requirements of this section shall apply on the date on which the Secretary of Defense establishes the procedures required under this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
