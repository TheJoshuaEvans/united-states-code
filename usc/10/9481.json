{"tag":"section","attrib":{"id":"idab7be3f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9481"},"text":null,"children":[{"tag":"num","attrib":{"value":"9481"},"text":"§ 9481.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment: purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Air Force may maintain schools and camps for the military instruction and training of persons selected, upon their application, from warrant officers and enlisted members of the Air Force, the Space Force, and civilians, to qualify them for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab7be3f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9481/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appointment as reserve officers, or enlistment as reserve noncommissioned officers, for service in the Air Force Reserve; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be3f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9481/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appointment as officers, or enlistment as noncommissioned officers, for service in the Space Force in a space force active status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab7be3fa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/571"},"text":"70A Stat. 571","children":[],"tail":", § 9411; renumbered § 9481, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/a/2"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"