{"tag":"section","attrib":{"id":"ida8ff24d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599i"},"text":null,"children":[{"tag":"num","attrib":{"value":"1599i"},"text":"§ 1599i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recruitment incentives for placement at remote locations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8ff24d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recruitment Incentive.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ff24d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual appointed to a position in the Department of Defense at a covered location may be paid a recruitment incentive in connection with such appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ff24d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a recruitment incentive payable to an individual under this subsection may not exceed the amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8ff24da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599i/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent of the annual rate of basic pay of the employee for the position concerned as of the date on which the service period in such position agreed to by the individual under paragraph (3) commences; multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8ff24db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599i/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of years (including fractions of a year) of such service period (not to exceed four years).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ff24dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599i/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To receive a recruitment incentive under this subsection, an individual appointed to a position under paragraph (1) shall enter into an agreement with the Secretary of Defense to complete a period of service at the covered location. The period of obligated service of the individual at such location under the agreement may not exceed four years. The agreement shall include such repayment or alternative employment obligations as the Secretary considers appropriate for failure of the individual to complete the period of obligated service specified in the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ff24dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599i/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered locations defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, a covered location is a location for which the Secretary of Defense has determined that critical hiring needs are not being met due to the geographic remoteness or isolation or extreme climate conditions of the location.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ff24de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Effective on ","children":[{"tag":"date","attrib":{"date":"2022-09-30"},"text":"September 30, 2022","children":[],"tail":", the authority provided under subsection (a) shall expire."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8ff24df-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXI/s1120/a"},"text":"Pub. L. 116–283, div. A, title XI, § 1120(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3898"},"text":"134 Stat. 3898","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8ff24e0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8ff24e1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8ff24e2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Outcome Measurements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXI/s1120/b"},"text":"Pub. L. 116–283, div. A, title XI, § 1120(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3899"},"text":"134 Stat. 3899","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dA/tXI/s1120/b"},"text":"“The Secretary of Defense shall develop outcome measurements to evaluate the effect of the authority provided under subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1599i"},"text":"section 1599i of title 10","children":[],"tail":", United States Code, as added by subsection (a), and any relocation incentives provided under subsection (b) of such section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
