tail":", the Federal Employees Pay Act of 1946, "},{"tag":"ref","attrib":{"href":"/us/stat/60/216"},"text":"60 Stat. 216","children":[],"tail":", the Postal Rate Revision and Federal Employees Salary Act of 1948, "},{"tag":"ref","attrib":{"href":"/us/stat/62/1260"},"text":"62 Stat. 1260","children":[],"tail":", and the Classification Act of 1949, "},{"tag":"ref","attrib":{"href":"/us/stat/63/954"},"text":"63 Stat. 954","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaaecc378-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1962 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"The change reflects the opinion of the Assistant General Counsel, Civil Service Commission (GC: JHF:fz, ","children":[{"tag":"date","attrib":{"date":"1959-05-04"},"text":"May 4, 1959","children":[],"tail":"), that those parts of section 4337 and 9337 of title 10 that relate to the salaries of the chaplains at the United States Military Academy and the United States Air Force Academy were superseded by the Classification Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1071"},"text":"5 U.S.C. 1071","children":[],"tail":" et seq.). While the positions of chaplain at those Academies are not specifically covered by the Act, the Act has been determined to apply to those positions in accordance with section 203 thereof ("},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1083"},"text":"5 U.S.C. 1083","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaecc379-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaaecc3