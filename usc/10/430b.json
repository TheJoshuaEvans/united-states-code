{"tag":"section","attrib":{"id":"ida7bae55a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430b"},"text":null,"children":[{"tag":"num","attrib":{"value":"430b"},"text":"§ 430b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive agent for open-source intelligence tools","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7bae55b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2016-04-01"},"text":"April 1, 2016","children":[],"tail":", the Secretary of Defense shall designate a senior official of the Department of Defense to serve as the executive agent for the Department for open-source intelligence tools."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bae55c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Roles, Responsibilities, and Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bae55d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":" (1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"2016-07-01"},"text":"July 1, 2016","children":[],"tail":", in accordance with Directive 5101.1, the Secretary shall prescribe the roles, responsibilities, and authorities of the executive agent designated under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bae55e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The roles and responsibilities of the executive agent designated under subsection (a) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7bae55f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing and maintaining a comprehensive list of open-source intelligence tools and technical standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bae560-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing priorities for the development, acquisition, and integration of open-source intelligence tools into the intelligence enterprise, and other command and control systems as needed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bae561-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430b/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Certifying all open-source intelligence tools with respect to compliance with the standards required by the framework and guidance for the Intelligence Community Information Technology Enterprise, the Defense Intelligence Information Enterprise, and the Joint Information Environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bae562-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430b/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assessing and making recommendations regarding the protection of privacy in the acquisition, analysis, and dissemination of open-source information available around the world.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bae563-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430b/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Performing such other assessments or analyses as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bae564-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support Within Department of Defense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In accordance with Directive 5101.1, the Secretary shall ensure that the military departments, the Defense Agencies, and other elements of the Department of Defense provide the executive agent designated under subsection (a) with the appropriate support and resources needed to perform the roles, responsibilities, and authorities of the executive agent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bae565-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bae566-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Directive 5101.1” means Department of Defense Directive 5101.1, or any successor directive relating to the responsibilities of an executive agent of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bd2e57-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “executive agent” has the meaning given the term “DoD Executive Agent” in Directive 5101.1.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bd2e58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “open-source intelligence tools” means tools for the systematic collection, processing, and analysis of publicly available information for known or anticipated intelligence requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7bd2e59-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tXVI/s1631/a"},"text":"Pub. L. 114–92, div. A, title XVI, § 1631(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1110"},"text":"129 Stat. 1110","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
