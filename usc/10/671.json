{"tag":"section","attrib":{"id":"ida7fb48e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s671"},"text":null,"children":[{"tag":"num","attrib":{"value":"671"},"text":"§ 671.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members not to be assigned outside United States before completing training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7fb48e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s671/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the armed forces may not be assigned to active duty on land outside the United States and its territories and possessions until the member has completed the basic training requirements of the armed force of which he is a member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7fb48ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s671/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In time of war or a national emergency declared by Congress or the President, the period of required basic training (or its equivalent) may not (except as provided in subsection (c)) be less than 12 weeks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7fb48eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s671/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7fb48ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s671/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A period of basic training (or equivalent training) shorter than 12 weeks may be established by the Secretary concerned for members of the armed forces who have been credentialed in a medical profession or occupation and are serving in a health-care occupational specialty, as determined under regulations prescribed under paragraph (2). Any such period shall be established under regulations prescribed under paragraph (2) and may be established notwithstanding section 4(a) of the Military Selective Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3803/a"},"text":"50 U.S.C. 3803(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7fb48ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s671/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense, and the Secretary of Homeland Security with respect to the Coast Guard when it is not operating as a service in the Navy, shall prescribe regulations for the purposes of paragraph (1). The regulations prescribed by the Secretary of Defense shall apply uniformly to the military departments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7fb48ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/27"},"text":"70A Stat. 27","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/106/tVIII/s802/b"},"text":"Pub. L. 94–106, title VIII, § 802(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-10-07"},"text":"Oct. 7, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/537"},"text":"89 Stat. 537","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tV/s501"},"text":"Pub. L. 99–661, div. A, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3863"},"text":"100 Stat. 3863","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tV/s511"},"text":"Pub. L. 103–160, div. A, title V, § 511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1648"},"text":"107 Stat. 1648","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/b/1"},"text":"Pub. L. 107–296, title XVII, § 1704(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tX/s1081/b/1/A/v"},"text":"Pub. L. 114–328, div. A, title X, § 1081(b)(1)(A)(v)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2418"},"text":"130 Stat. 2418","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7fb48ef-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida7fb48f0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida7fb48f1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"671","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50 App.:454(a) (words between semicolon and proviso of 6th par.).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1948-06-24/ch625/s4/a"},"text":"June 24, 1948, ch. 625, § 4(a)","children":[],"tail":" (words between semicolon and proviso of 6th par.); restated "},{"tag":"html:a","attrib":{"href":"/us/act/1951-06-19/ch144/s1/d"},"text":"June 19, 1951, ch. 144, § 1(d)","children":[],"tail":" (words between semicolon and proviso of 6th par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/65/78"},"text":"65 Stat. 78","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “four months of basic training or its equivalent” are substituted for the words “the equivalent of at least four months of basic training”. The words “who is enlisted, inducted, appointed, or ordered to active duty after the date of enactment of the 1951 Amendments to the Universal Military Training and Service Act [","children":[{"tag":"date","attrib":{"date":"1951-06-19"},"text":"June 19, 1951","children":[],"tail":"]” and “at any installation located” are omitted as surplusage."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7fb48f2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7fb48f3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3803/a"},"text":"50 U.S.C. 3803(a)","children":[],"tail":")” for “(50 U.S.C. App. 454(a))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s511/1"},"text":"Pub. L. 103–160, § 511(1)","children":[],"tail":", inserted “(except as provided in subsection (c))” after “may not”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s511/2"},"text":"Pub. L. 103–160, § 511(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “No member of an armed force may be assigned to active duty on land outside the United States and its Territories and possessions, until he has had twelve weeks of basic training or its equivalent.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/106"},"text":"Pub. L. 94–106","children":[],"tail":" reduced minimum period of basic training from four months to twelve weeks."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7fb48f4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7fb48f5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
