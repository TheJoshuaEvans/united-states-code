{"tag":"section","attrib":{"id":"ida93f88a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2216a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2216a"},"text":"§ 2216a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rapidly meeting urgent needs: Joint Urgent Operational Needs Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida93f88a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2216a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established in the Treasury an account to be known as the “Joint Urgent Operational Needs Fund” (in this section referred to as the “Fund”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93f88a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2216a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Fund shall consist of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93f88a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2216a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts appropriated to the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93f88a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2216a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts transferred to the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93f88aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2216a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other amounts made available to the Fund by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93f88ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2216a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93f88ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2216a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts in the Fund shall be available to the Secretary of Defense for capabilities that are determined by the Secretary, pursuant to the review process required by Department of Defense Instruction 5000.81 (or any successor instruction), dated ","children":[{"tag":"date","attrib":{"date":"2019-12-31"},"text":"December 31, 2019","children":[],"tail":", and titled “Urgent Capability Acquisition”, to be suitable for rapid fielding in response to urgent operational needs."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93f88ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2216a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish a merit-based process for identifying equipment, supplies, services, training, and facilities suitable for funding through the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93f88ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2216a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall be interpreted to require or enable any official of the Department of Defense to provide funding under this section pursuant to a congressional earmark, as defined in clause 9 of Rule XXI of the Rules of the House of Representatives, or a congressionally directed spending item, as defined in paragraph 5 of Rule XLIV of the Standing Rules of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93f88af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2216a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93f88b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2216a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Amounts in the Fund may be transferred by the Secretary of Defense from the Fund to any of the following accounts of the Department of Defense to accomplish the purpose stated in subsection (c):","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida93f88b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2216a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operation and maintenance accounts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida93f88b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2216a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procurement accounts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida93f88b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2216a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Research, development, test, and evaluation accounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93f88b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2216a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon determination by the Secretary that all or part of the amounts transferred from the Fund under paragraph (1) are not necessary for the purpose for which transferred, such amounts may be transferred back to the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93f88b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2216a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The transfer of an amount to an account under the authority in paragraph (1) shall be deemed to increase the amount authorized for such account by an amount equal to the amount so transferred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93f88b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2216a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The transfer authority provided by paragraphs (1) and (2) is in addition to any other transfer authority available to the Department of Defense by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93f88b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2216a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority to make expenditures or transfers from the Fund shall expire on ","children":[{"tag":"date","attrib":{"date":"2018-09-30"},"text":"September 30, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida93f88b8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVIII/s846/a/1"},"text":"Pub. L. 112–81, div. A, title VIII, § 846(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1516"},"text":"125 Stat. 1516","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/e/2"},"text":"Pub. L. 112–239, div. A, title X, § 1076(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1951"},"text":"126 Stat. 1951","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tVIII/s860"},"text":"Pub. L. 113–291, div. A, title VIII, § 860","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3461"},"text":"128 Stat. 3461","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVIII/s804/d/1"},"text":"Pub. L. 117–263, div. A, title VIII, § 804(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2701"},"text":"136 Stat. 2701","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida93f88b9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida93f88ba-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida93f88bb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2216a, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tIII/s371/a/1"},"text":"Pub. L. 104–106, div. A, title III, § 371(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/277"},"text":"110 Stat. 277","children":[],"tail":", § 2216; renumbered § 2216a and amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tIII"},"text":"Pub. L. 104–201, div. A, title III","children":[],"tail":", §§ 363(c), 364, title X, § 1074(a)(10), "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2493"},"text":"110 Stat. 2493","children":[],"tail":", 2494, 2659, related to Defense Business Operations Fund, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tX/s1008/b"},"text":"Pub. L. 105–261, div. A, title X, § 1008(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2117"},"text":"112 Stat. 2117","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida93f88bc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “Department of Defense Instruction 5000.81 (or any successor instruction), dated "},{"tag":"date","attrib":{"date":"2019-12-31"},"text":"December 31, 2019","children":[],"tail":", and titled ‘Urgent Capability Acquisition’ ” for “section 804(b) of the Ike Skelton National Defense Authorization Act for Fiscal Year 2011 ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2302"},"text":"10 U.S.C. 2302","children":[],"tail":" note)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2018-09-30"},"text":"September 30, 2018","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2015-09-30"},"text":"September 30, 2015","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" substituted “on "},{"tag":"date","attrib":{"date":"2015-09-30"},"text":"September 30, 2015","children":[],"tail":".” for “on the last day of the third fiscal year that begins after the date of the enactment of the National Defense Authorization Act for Fiscal Year 2012.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida93f88bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida93f88be-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limitation on Commencement of Expenditures From Fund","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVIII/s846/b"},"text":"Pub. L. 112–81, div. A, title VIII, § 846(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1517"},"text":"125 Stat. 1517","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/81/dA/tVIII/s846/b"},"text":"“No expenditure may be made from the Joint Urgent Operational Needs Fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2216a"},"text":"section 2216a of title 10","children":[],"tail":", United States Code (as added by subsection (a)), until the Secretary of Defense certifies to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] that the Secretary has developed and implemented an expedited review process in compliance with the requirements of section 804 of the Ike Skelton National Defense Authorization Act for Fiscal Year 2011 ("},{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Public Law 111–383","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/124/4256"},"text":"124 Stat. 4256","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2302"},"text":"10 U.S.C. 2302","children":[],"tail":" note).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
