of provisions of this type. The reference to time of examination is omitted as being included within the Secretary’s authority to prescribe regulations, which is stated in the subsection. The words “Academic Board” are substituted for the words “board of examiners”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b) the words “domiciled in” are substituted for the words “actual resident of” since this term has been so interpreted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab2ab6e1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab2ab6e2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s807/c/1"},"text":"Pub. L. 115–232, § 807(c)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6958"},"text":"section 6958 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “clauses (3) through (9) of section 8454(a)” for “clauses (3) through (9) of section 6954(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “clause (2) or (3) of section 8454(b)” for “clause (2) or (3) of section 6954(b)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" substituted “twenty-third birthday” for “twenty-second birthday”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (c)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" redesignated pars. (3) and (4) as (2) and (3), respectively, and struck out former par. (2) which required candidates to have served at least one year as enlisted members on date of entrance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" substituted “clauses (3) through (9)” for “clauses (3)–(7), (9) and (10)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/171"},"text":"Pub. L. 93–171","children":[],"tail":" substituted “, (9) and (10) of section 6954(a)” for “and (9) of section 6954(a)” and struck out “or Territory”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/663"},"text":"Pub. L. 87–663","children":[],"tail":" inserted references to American Samoa, Guam, and the Virgin Islands, and substituted “clauses (3)–(7) and (9)” for “clauses (3)–(7)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab2ab6e3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab2ab6e4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab2ab6e5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1973 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/171"},"text":"Pub. L. 93–171","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/171/s4"},"text":"section 4 of Pub. L. 93–171","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7442"},"text":"section 7442 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab2ab6e6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authority To Waive Maximum Age Limitation on Admission to Service Academies for Certain Enlisted Members Who Served During Persian Gulf War","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For authority to waive maximum age limitation in subsec. (a)(1) of this section on basis of service on active duty in connection with Operation Desert Storm, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/s514"},"text":"section 514 of Pub. L. 102–190","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7446"},"text":"section 7446 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
