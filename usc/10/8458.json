{"tag":"section","attrib":{"id":"idab286ce3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8458"},"text":null,"children":[{"tag":"num","attrib":{"value":"8458"},"text":"§ 8458.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Midshipmen: qualifications for admission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab286ce4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8458/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each candidate for admission to the Naval Academy—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab286ce5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8458/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must be at least 17 years of age and must not have passed his twenty-third birthday on July 1 of the calendar year in which he enters the Academy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab286ce6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8458/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be examined according to such regulations as the Secretary of the Navy prescribes, and if rejected at one examination may not be examined again for admission to the same class unless recommended by the Academic Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab286ce7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8458/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each candidate for admission nominated under clauses (3) through (9) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8454/a"},"text":"section 8454(a) of this title","children":[],"tail":" must be domiciled in the State, or in the congressional district, from which he is nominated, or in the District of Columbia, Puerto Rico, American Samoa, Guam, or the Virgin Islands, if nominated from one of those places."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab286ce8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8458/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each candidate nominated under clause (2) or (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8454/b"},"text":"section 8454(b) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab286ce9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8458/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must be a citizen of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab286cea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8458/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must have passed the required physical examination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab286ceb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8458/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be appointed in the order of merit from candidates who have, in competition with each other, passed the required mental examination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2ab6dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8458/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be admitted to the Naval Academy, an appointee must take and subscribe to an oath prescribed by the Secretary of the Navy. If a candidate for admission refuses to take and subscribe to the prescribed oath, the candidate’s appointment is terminated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab2ab6dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/431"},"text":"70A Stat. 431","children":[],"tail":", § 6958; "},{"tag":"ref","attrib":{"href":"/us/pl/87/663/s1/4"},"text":"Pub. L. 87–663, § 1(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-14"},"text":"Sept. 14, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/547"},"text":"76 Stat. 547","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/171/s2/5"},"text":"Pub. L. 93–171, § 2(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-11-29"},"text":"Nov. 29, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/690"},"text":"87 Stat. 690","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tV/s532/b/3"},"text":"Pub. L. 101–510, div. A, title V, § 532(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1563"},"text":"104 Stat. 1563","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tV/s512"},"text":"Pub. L. 102–190, div. A, title V, § 512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1360"},"text":"105 Stat. 1360","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s555/c"},"text":"Pub. L. 104–201, div. A, title V, § 555(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2527"},"text":"110 Stat. 2527","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tV/s541/a"},"text":"Pub. L. 105–85, div. A, title V, § 541(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1740"},"text":"111 Stat. 1740","children":[],"tail":"; renumbered § 8458 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 807(c)(1), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":", 1840.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab2ab6de-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab2ab6df-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab2ab6e0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"