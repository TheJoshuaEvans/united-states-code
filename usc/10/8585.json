{"tag":"section","attrib":{"id":"idab31e2a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8585"},"text":null,"children":[{"tag":"num","attrib":{"value":"8585"},"text":"§ 8585.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of life annuity","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each civilian member who retires under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8584"},"text":"section 8584 of this title","children":[],"tail":" is entitled to a life annuity computed by multiplying his average annual compensation during any five consecutive years of allowable service, at his option, by his number of years of service, not exceeding 35, and dividing the product by 70. The retirement annuity payable to a retired civilian member under a policy required by "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8582"},"text":"section 8582 of this title","children":[],"tail":" is counted as part of the retirement annuity provided in this section. Any difference between the amount received by the retired civilian member under his annuity policy and the total annual amount to which he is entitled under this section shall be paid to him by the Secretary of the Navy from appropriations made for this purpose."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab31e2a5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/439"},"text":"70A Stat. 439","children":[],"tail":", § 7085; renumbered § 8585 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 807(c)(1), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":", 1840.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab31e2a6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab31e2a7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab31e2a8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7085","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s1073c–1"},"text":"34 U.S.C. 1073c–1","children":[],"tail":" (less 2d proviso)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-01-16/ch3/s4A"},"text":"Jan. 16, 1936, ch. 3, § 4A","children":[],"tail":" (less 2d proviso); added "},{"tag":"html:a","attrib":{"href":"/us/act/1943-11-28/ch331/s1"},"text":"Nov. 28, 1943, ch. 331, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/57/594"},"text":"57 Stat. 594","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “terminable on his death at the rate of the following total annual amount” are omitted as surplusage, since they are covered by the words “life annuity”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “basic salary, pay, or” are omitted as surplusage, since they are covered by the word “compensation”. The first proviso is omitted as unnecessary, since all existing rights and benefits of persons affected by this title are protected by a general saving provision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab31e2a9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab31e2aa-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 8584” for “section 7084” and “section 8582” for “section 7082”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s807/c/1"},"text":"Pub. L. 115–232, § 807(c)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7085"},"text":"section 7085 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab31e2ab-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab31e2ac-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab31e2ad-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Increase in Annuities of Civilian Members Who Retired Before ","children":[{"tag":"date","attrib":{"date":"1948-04-01"},"text":"April 1, 1948","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s30"},"text":"Pub. L. 85–861, § 30","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1563"},"text":"72 Stat. 1563","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/85/861/s30"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A retired civilian member of the teaching staff of the United States Naval Academy or the United States Naval Postgraduate School who retired before ","children":[{"tag":"date","attrib":{"date":"1948-04-01"},"text":"April 1, 1948","children":[],"tail":", is entitled to be paid, out of applicable current appropriations, $300 a year in addition to the annuity to which he is entitled under section 7085 [now 8585] of title 10."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A retired civilian member whose annuity, when increased by $300 under subsection (a), is less than $1,860 is entitled to be paid an additional $300 a year out of applicable current appropriations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Additions to the annuities of retired civilian members under subsection (b) do not increase the annuities payable to the survivors of those members.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab31e2ae-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Increase of Annuities—1957","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/40"},"text":"Pub. L. 85–40","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-05-31"},"text":"May 31, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/42"},"text":"71 Stat. 42","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/85/40"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“That the annuities, payable under chapter 607 [now 857] of title 10, United States Code, to civilian members of the teaching staff of the United States Naval Academy or the United States Naval Postgraduate School are increased as follows: That portion of an annuity which is not in excess of $1,500 is increased by 12 per centum, and that portion of an annuity which is in excess of $1,500 is increased by 8 per centum. These increases shall not exceed the sum necessary to increase the annuity to $4,104, and are in addition to the increases authorized by Public Law 371, Eighty-fourth Congress. The monthly installments of each annuity shall be fixed at the nearest dollar.","children":[],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“Sec. 2.","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The increases provided by section 1, when added to the annuities of retired civilian members of the teaching staff of the United States Naval Academy or the United States Naval Postgraduate School, do not increase the annuities of their survivors. The annuity of any such survivor, however, who is entitled to or becomes entitled to an annuity under chapter 607 [now 857] of title 10, United States Code, shall be increased in accordance with the following schedule:","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab31e2af-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"“If annuity commences between—","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Portion of annuity not in excess of $1,500 shall be increased by—","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Portion of annuity in excess of $1,500 shall be increased by—","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"per centum","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"per centum","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Jan. 16, 1936","children":[],"tail":", and "},{"tag":"html:span","attrib":{},"text":"June 30, 1955","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"12","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"8","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 1, 1955","children":[],"tail":", and "},{"tag":"html:span","attrib":{},"text":"Dec. 31, 1955","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"7","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Jan. 1, 1956","children":[],"tail":", and "},{"tag":"html:span","attrib":{},"text":"June 30, 1956","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"8","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"6","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 1, 1956","children":[],"tail":", and "},{"tag":"html:span","attrib":{},"text":"Dec. 31, 1956","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"6","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"4","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Jan. 1, 1957","children":[],"tail":", and "},{"tag":"html:span","attrib":{},"text":"June 30, 1957","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"4","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"2","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 1, 1957","children":[],"tail":", and "},{"tag":"html:span","attrib":{},"text":"Dec. 31, 1957","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"2","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"1","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“Sec. 3.","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any provision of law, enacted after the effective date of this Act [","children":[{"tag":"date","attrib":{"date":"1957-05-31"},"text":"May 31, 1957","children":[],"tail":"], which increases the annuities of retired employees and their survivors who are entitled to annuities under the Civil Service Retirement Act of "},{"tag":"date","attrib":{"date":"1930-05-29"},"text":"May 29, 1930","children":[],"tail":", as amended ("},{"tag":"ref","attrib":{"href":"/us/usc/t5/s691"},"text":"5 U.S.C. 691","children":[],"tail":" et seq.) [now covered by section 8331 et seq. 30 of Title 5], shall be applicable in like manner and to the same extent to civilian members of the teaching staff of the United States Naval Academy and of the United States Naval Postgraduate School and their survivors who are entitled to annuities under chapter 607 [now 857] of title 10, United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
