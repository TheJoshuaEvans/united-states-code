tml:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s32"},"text":"34 U.S.C. 32","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-08-29/ch417"},"text":"Aug. 29, 1916, ch. 417","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/39/573"},"text":"39 Stat. 573","children":[],"tail":" (30th through 44th words of 6th par. under “Hospital Corps”)."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s51"},"text":"34 U.S.C. 51","children":[],"tail":" (26th through 37th words)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-08-29/ch417"},"text":"Aug. 29, 1916, ch. 417","children":[],"tail":" (1st par. under “Naval Dental Corps”, 75th word to end of 1st sentence); added "},{"tag":"html:a","attrib":{"href":"/us/act/1918-07-01/ch114"},"text":"July 1, 1918, ch. 114","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/40/708"},"text":"40 Stat. 708","children":[],"tail":" (4th par.)."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"There is no provision of law specifically stating that the Medical Corps is in the Medical Department. It was the first corps to have duties relating to medical and sanitary matters and so long as it was the only corps having such duties there was no need for the departmental concept. The subsequent establishment of other corps with related duties “in the Medical Department” indicates clearly that the Medical Corps is in that Department.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “effective ","children":[{"tag":"date","attrib":{"date":"1947-08-04"},"text":"August 4, 1947","children":[],"tail":"” and the words “establishing the Medical Service Corps” in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s30a"},"text":"34 U.S.C. 30a","children":[],"tail":" are omitted as executed. The words “is created and established as a Staff Corps of the United States Navy” in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s43"},"text":"34 U.S.C. 43","children":[],"tail":" are omitted as executed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab1559ea-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab1559eb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8219, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/164/A"},"text":"Pub. L. 85–861, § 1(164)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1515"},"text":"72 Stat. 1515","children":[],"tail":", related to authorized strength of Air Force in reserve commissioned officers in grades below brigadier general in active status, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tX