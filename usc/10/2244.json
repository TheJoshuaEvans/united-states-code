{"tag":"section","attrib":{"id":"ida959c78d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2244"},"text":null,"children":[{"tag":"num","attrib":{"value":"2244"},"text":"§ 2244.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security investigations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida959c78e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2244/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Funds appropriated to the Department of Defense may not be used for the conduct of an investigation by the Department of Defense, or by any other Federal department or agency, for purposes of determining whether to grant a security clearance to an individual or a facility unless the Secretary of Defense determines both of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida959c78f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2244/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That a current, complete investigation file is not available from any other department or agency of the Federal Government with respect to that individual or facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c790-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2244/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That no other department or agency of the Federal Government is conducting an investigation with respect to that individual or facility that could be used as the basis for determining whether to grant the security clearance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida959c791-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2244/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of subsection (a)(1), a current investigation file is a file on an investigation that has been conducted within the past five years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida959c792-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tIX/s904/a"},"text":"Pub. L. 101–510, div. A, title IX, § 904(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1621"},"text":"104 Stat. 1621","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tX/s1061/a/11"},"text":"Pub. L. 102–190, div. A, title X, § 1061(a)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1473"},"text":"105 Stat. 1473","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida959c793-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida959c794-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida959c795-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" substituted “Government” for “government”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
