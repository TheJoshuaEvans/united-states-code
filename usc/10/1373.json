-10-12/ch681"},"text":"Oct. 12, 1949, ch. 681","children":[],"tail":", §§ 402(d) (last proviso, as applicable to retired grade), 409 (as applicable to § 402(d) (last proviso)), "},{"tag":"html:a","attrib":{"href":"/us/stat/63/819"},"text":"63 Stat. 819","children":[],"tail":", 823."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The applicability of the rule stated in 37:279 to all members whose retired pay is computed under 37:272(d) (last proviso) is based on an opinion of the Judge Advocate General of the Army (JAGA 1953/3305, 24 Apr. 1953).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8b793a9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8b793aa-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/342"},"text":"Pub. L. 96–342","children":[],"tail":" inserted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1402a/d"},"text":"section 1402a(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
