{"tag":"section","attrib":{"id":"ida9361331-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2183"},"text":null,"children":[{"tag":"num","attrib":{"value":"2183"},"text":"§ 2183.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational assistance: former captives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9361332-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2183/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In order to respond to special circumstances, the Secretary concerned may pay (by advancement or reimbursement) a person who is a former captive for expenses incurred, while attending an educational or training institution, for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9361333-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2183/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsistence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361334-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2183/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tuition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361335-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2183/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361336-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2183/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supplies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361337-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2183/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" books;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361338-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2183/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361339-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2183/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other educational expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida936133a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2183/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2184"},"text":"section 2184 of this title","children":[],"tail":", payments shall be available under this section for a person who is a former captive for education or training that occurs—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida936133b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2183/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the termination of the status of that person as a captive; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida936133c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2183/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on or before—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida936133d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2183/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the end of any semester or quarter (as appropriate) that begins before the end of the 10-year period beginning on the date on which the status of that person as a captive terminates; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida936133e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2183/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the educational or training institution is not operated on a semester or quarter system, the earlier of the end of any course that began before such date or the end of the 16-week period following that date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida936133f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2183/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payments shall be available under this section only to the extent that such payments are not otherwise authorized by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9361340-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tVIII/s806/d/1"},"text":"Pub. L. 99–399, title VIII, § 806(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/888"},"text":"100 Stat. 888","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9361341-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9361342-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9361343-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to persons whose captive status begins after ","children":[{"tag":"date","attrib":{"date":"1981-01-21"},"text":"Jan. 21, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/399/s806/d/3"},"text":"section 806(d)(3) of Pub. L. 99–399","children":[],"tail":", set out as a note under 2181 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
