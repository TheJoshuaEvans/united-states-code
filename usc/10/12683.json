{"tag":"section","attrib":{"id":"idaba6c4c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12683"},"text":null,"children":[{"tag":"num","attrib":{"value":"12683"},"text":"§ 12683.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve officers: limitation on involuntary separation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaba6c4c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12683/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An officer of a reserve component who has at least five years of service as a commissioned officer may not be separated from that component without his consent except—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba6c4c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12683/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under an approved recommendation of a board of officers convened by an authority designated by the Secretary concerned; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba6c4c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12683/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the approved sentence of a court-martial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba6c4c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12683/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a) does not apply to any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba6c4c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12683/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A separation under section 12684, 14901, or 14907 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba6c4c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12683/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A dismissal under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1161/a"},"text":"section 1161(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba6c4c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12683/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A transfer under section 12213, 12214, 14514, or 14515 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba6c4c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12683/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A separation of an officer who is in an inactive status in the Standby Reserve and who is not qualified for transfer to the Retired Reserve or is qualified for transfer to the Retired Reserve and does not apply for such a transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaba6c4ca-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1662/i/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1662(i)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2997"},"text":"108 St