{"tag":"section","attrib":{"id":"idaa2220d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3452"},"text":null,"children":[{"tag":"num","attrib":{"value":"3452"},"text":"§ 3452.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship of other provisions of law to procurement of commercial products and commercial services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa2220d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3452/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Government-wide Statutes","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa2220d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3452/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No contract for the procurement of a commercial product or commercial service entered into by the head of an agency shall be subject to any law properly listed in the Federal Acquisition Regulation pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1906/b"},"text":"section 1906(b) of title 41","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa2220da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3452/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No subcontract under a contract for the procurement of a commercial product or commercial service entered into by the head of an agency shall be subject to any law properly listed in the Federal Acquisition Regulation pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1906/c"},"text":"section 1906(c) of title 41","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa2220db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3452/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No contract for the procurement of a commercially available off-the-shelf item entered into by the head of an agency shall be subject to any law properly listed in the Federal Acquisition Regulation pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1907"},"text":"section 1907 of title 41","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa2220dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3452/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Defense-unique Statutes to Contracts for Commercial Products and Commercial Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Department of Defense Supplement to the Federal Acquisition Regulation shall include a list of defense-unique contract clause requirements based on laws, executive orders, or acquisition policies that may be applied to contracts for the procurement of commercial products and commercial services entered into by the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa2220dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3452/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Defense-unique Statutes to Subcontracts for Commercial Products and Commercial Services","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa2220de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3452/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Defense Supplement to the Federal Acquisition Regulation shall include a list of defense-unique contract clause requirements based on laws, executive orders, or acquisition policies that may be applied to subcontracts for the procurement of commercial products and commercial services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa2220df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3452/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection, the term “subcontract”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa2220e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3452/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a transfer of commercial products and commercial services between divisions, subsidiaries, or affiliates of a contractor or subcontractor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa2220e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3452/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include any agreement entered into by a contractor or subcontractor for the supply of products or services that are intended for use in the performance of multiple contracts with the Department of Defense or with other parties, and that are not identifiable to any particular contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa2220e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3452/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection does not authorize the waiver of the applicability of any provision of law or contract clause requirement with respect to any first-tier subcontract under a contract with a prime contractor reselling or distributing commercial products and commercial services of another contractor without adding value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa2220e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3452/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Defense-unique Statutes to Contracts or Subcontracts for Commercially Available, Off-the-shelf Items","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Department of Defense Supplement to the Federal Acquisition Regulation shall include a list of defense-unique contract clause requirements based on laws, executive orders, or acquisition policies that are applicable to contracts or subcontracts for the procurement of commercially available off-the-shelf items entered into by the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa2469d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3452/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicable Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall ensure that the lists required by subsections (b) and (c)(1) shall include any contract clause to implement the requirements of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa2469d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3452/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 385 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa2469d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3452/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 5949 of the National Defense Authorization Act for Fiscal Year 2023 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Public Law 117–263","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s4713"},"text":"41 U.S.C. 4713","children":[],"tail":" note);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa2469d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3452/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 805 of the National Defense Authorization Act for Fiscal Year 2024 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Public Law 118–31","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa2469d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3452/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statute that specifically refers to this section and provides that, notwithstanding this section, such statute shall be applicable to contracts for the procurement of commercial products and commercial services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa2469d9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355/tVIII/s8102"},"text":"Pub. L. 103–355, title VIII, § 8102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3390"},"text":"108 Stat. 3390","children":[],"tail":", § 2375; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1073/a/51"},"text":"Pub. L. 105–85, div. A, title X, § 1073(a)(51)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1903"},"text":"111 Stat. 1903","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/a/18"},"text":"Pub. L. 107–107, div. A, title X, § 1048(a)(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1223"},"text":"115 Stat. 1223","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/b/21"},"text":"Pub. L. 111–350, § 5(b)(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3844"},"text":"124 Stat. 3844","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s874/a"},"text":"Pub. L. 114–328, div. A, title VIII, § 874(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2308"},"text":"130 Stat. 2308","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 836(d)(1), (8)(B), 837(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1866"},"text":"132 Stat. 1866","children":[],"tail":", 1868, 1875; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s902/57"},"text":"Pub. L. 116–92, div. A, title IX, § 902(57)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1549"},"text":"133 Stat. 1549","children":[],"tail":"; renumbered § 3452 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII"},"text":"Pub. L. 116–283, div. A, title XVIII","children":[],"tail":", §§ 1821(a)(2), (b)(2), 1870(c)(6)(A), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4195"},"text":"134 Stat. 4195","children":[],"tail":", 4285; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVIII/s1821"},"text":"Pub. L. 119–60, div. A, title XVIII, § 1821","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1245"},"text":"139 Stat. 1245","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa2469da-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa2469db-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaa2469dc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 805 of the National Defense Authorization Act for Fiscal Year 2024, referred to in subsec. (e)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s805"},"text":"section 805 of Pub. L. 118–31","children":[],"tail":", which is set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4651"},"text":"section 4651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa2469dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3452, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/81/E"},"text":"Pub. L. 85–861, § 1(81)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1480"},"text":"72 Stat. 1480","children":[],"tail":", provided that, notwithstanding any other provision of law, an officer of Medical Corps or Dental Corps may be promoted to temporary grade of captain at any time after first anniversary of date upon which he graduated from a medical, osteopathic, or dental school, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tII/s207"},"text":"Pub. L. 96–513, title II, § 207","children":[],"tail":", title VII, § 701, "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2884"},"text":"94 Stat. 2884","children":[],"tail":", 2955, effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa2469de-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsecs. (b) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" added subsecs. (b) to (e) and struck out former subsecs. (b) to (e) which related to applicability of defense-unique statutes to contracts for commercial products and commercial services, applicability of defense-unique statutes to subcontracts for commercial products and commercial services, applicability of defense-unique statutes to contracts for commercially available, off-the-shelf items, and covered provision of law or contract clause requirement, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1821/a/2"},"text":"Pub. L. 116–283, § 1821(a)(2)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2375"},"text":"section 2375 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", §§ 1821(b)(2), 1870(c)(6)(A), made identical amendments, substituting “section 4862” for “section 2533a” and “section 4863” for “section 2533b”. Section 1870(c)(6)(A) amended former section 2375 while section 1821(b)(2) amended this section. See Amendment note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsecs. (b)(2), (c)(2), (d)(2), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “Under Secretary of Defense for Acquisition and Sustainment” for “Under Secretary of Defense for Acquisition, Technology, and Logistics”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s836/d/8/B"},"text":"Pub. L. 115–232, § 836(d)(8)(B)","children":[],"tail":", substituted “Relationship of other provisions of law to procurement of commercial products and commercial services” for “Relationship of commercial item provisions to other provisions of law” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s836/d/1/A"},"text":"Pub. L. 115–232, § 836(d)(1)(A)","children":[],"tail":", substituted “commercial product or commercial service” for “commercial item”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s836/d/1/B"},"text":"Pub. L. 115–232, § 836(d)(1)(B)","children":[],"tail":", in heading, substituted “Commercial Products and Commercial Services” for “Commercial Items” and, in text, substituted “commercial products and commercial services” for “commercial items” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s837/a"},"text":"Pub. L. 115–232, § 837(a)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"October 13, 1994","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2015-01-01"},"text":"January 1, 2015","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s836/d/1/B"},"text":"Pub. L. 115–232, § 836(d)(1)(B)","children":[],"tail":", in heading, substituted “Commercial Products and Commercial Services” for “Commercial Items” and, in text, substituted “commercial products and commercial services” for “commercial items” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s836/d/1/C"},"text":"Pub. L. 115–232, § 836(d)(1)(C)","children":[],"tail":", substituted “commercial products and commercial services” for “commercial items”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" amended section generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Title","children":[],"tail":".—Unless otherwise specifically provided, nothing in this chapter shall be construed as providing that any other provision of this title relating to procurement is inapplicable to the procurement of commercial items."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"List of Laws Inapplicable to Contracts for the Acquisition of Commercial Items","children":[],"tail":".—No contract for the procurement of a commercial item entered into by the head of an agency shall be subject to any law properly listed in the Federal Acquisition Regulation (pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s1906"},"text":"section 1906 of title 41","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) ","children":[{"tag":"inline","attrib":{},"text":"Cross Reference to Exception to Cost or Pricing Data Requirements for Commercial Items","children":[],"tail":".—For a provision relating to an exception for requirements for cost or pricing data for contracts for the procurement of commercial items, see "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2306a/b"},"text":"section 2306a(b) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t41/s1906"},"text":"section 1906 of title 41","children":[],"tail":"” for “section 34 of the Office of Federal Procurement Policy Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s430"},"text":"41 U.S.C. 430","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" inserted “("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s430"},"text":"41 U.S.C. 430","children":[],"tail":")” after “section 34 of the Office of Federal Procurement Policy Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" substituted “a provision relating to an exception” for “provisions relating to exceptions” and “section 2306a(b)” for “section 2306a(d)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa2469df-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa2469e0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa2469e1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by section 836(d)(1), (8)(B) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2020-01-01"},"text":"Jan. 1, 2020","children":[],"tail":", subject to a savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s836/h"},"text":"section 836(h) of Pub. L. 115–232","children":[],"tail":", set out as an Effective Date of 2018 Amendment; Savings Provision note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s453b"},"text":"section 453b of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa2469e2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date and applicability of chapter, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355/s10001"},"text":"section 10001 of Pub. L. 103–355","children":[],"tail":" set out as an Effective Date of 1994 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8752"},"text":"section 8752 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa2469e3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Changes to Defense Federal Acquisition Regulation Supplement","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s874/b"},"text":"Pub. L. 114–328, div. A, title VIII, § 874(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2310"},"text":"130 Stat. 2310","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s902/58"},"text":"Pub. L. 116–92, div. A, title IX, § 902(58)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1549"},"text":"133 Stat. 1549","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dA/tIX/s902/58"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, the Under Secretary of Defense for Acquisition and Sustainment shall ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Defense Federal Acquisition Regulation Supplement does not require the inclusion of contract clauses in contracts for the procurement of commercial items or contracts for the procurement of commercially available off-the-shelf items, unless such clauses are—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required to implement provisions of law or executive orders applicable to such contracts; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined to be consistent with standard commercial practice; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the flow-down of contract clauses to subcontracts under contracts for the procurement of commercial items or commercially available off-the-shelf items is prohibited unless such flow-down is required to implement provisions of law or executive orders applicable to such subcontracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subcontracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term ‘subcontract’ includes a transfer of commercial items between divisions, subsidiaries, or affiliates of a contractor or subcontractor. The term does not include agreements entered into by a contractor for the supply of commodities that are intended for use in the performance of multiple contracts with the Department of Defense and other parties and are not identifiable to any particular contract.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa2469e4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Provisions Not Affected by Title VIII of Pub. L. 103–355","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355/tVIII/s8304"},"text":"Pub. L. 103–355, title VIII, § 8304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3398"},"text":"108 Stat. 3398","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s812/a/2/C/iii"},"text":"Pub. L. 115–232, div. A, title VIII, § 812(a)(2)(C)(iii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1847"},"text":"132 Stat. 1847","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/232/dA/tVIII/s812/a/2/C/iii"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Nothing in this title [see Tables for classification] shall be construed as modifying or superseding, or as intended to impair or restrict, authorities or responsibilities under—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 7102 of the Federal Acquisition Streamlining Act of 1994 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355"},"text":"Pub. L. 103–355","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s644"},"text":"15 U.S.C. 644","children":[],"tail":" note];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Brooks Automatic Data Processing Act (section 111 of the Federal Property and Administrative Services Act of 1949 ([former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s759"},"text":"40 U.S.C. 759","children":[],"tail":"));"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Brooks Architect-Engineers Act (title IX of the Federal Property and Administrative Services Act of 1949 ([former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s541"},"text":"40 U.S.C. 541","children":[],"tail":" et seq.) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s1101–110"},"text":"40 U.S.C. 1101–110","children":[],"tail":"4]);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsections (a) and (d) of section 8 of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/a"},"text":"15 U.S.C. 637(a)","children":[],"tail":" and (d)); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Javits-Wagner-O’Day Act ([former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s46–48c"},"text":"41 U.S.C. 46–48c","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s8501"},"text":"41 U.S.C. 8501","children":[],"tail":" et seq.].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
