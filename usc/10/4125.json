{"tag":"section","attrib":{"id":"idaa5b5900-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4125"},"text":null,"children":[{"tag":"num","attrib":{"value":"4125"},"text":"§ 4125.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Defense research facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa5b5901-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4125/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions of Defense Research Facilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall ensure, to the maximum extent practicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa5b5902-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4125/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that Defense research facilities are assigned broad mission requirements rather than specific hardware needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b5903-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4125/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that appropriate personnel of such facilities are assigned to serve as consultants on component and support system standardization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b5904-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4125/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the managers of such facilities have broad latitude to choose research and development projects based on awareness of activities throughout the technology domain, including within the Federal Government, the Department of Defense, public and private research institutions and universities, and the global commercial marketplace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b5905-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4125/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that technology position and issue papers prepared by Defense research facilities are readily available to all components of the Department of Defense and to contractors who submit bids or proposals for Department of Defense contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b5906-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4125/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that, in order to promote increased consideration of technological issues early in the development process, any technological assessment made by a Defense research facility shall be provided to the Defense Technical Information Center repository to support acquisition decisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b5907-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4125/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that, in light of Defense research facilities being funded by the public, Defense research facilities are broadly authorized and encouraged to support national technological development goals and support technological missions of other departments and agencies of the Federal Government, when such support is determined by the Secretary of Defense to be in the best interests of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa5b5908-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4125/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “Defense research facility” means a Department of Defense facility which performs or contracts for the performance of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa5b5909-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4125/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basic research; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5b590a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4125/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applied research known as exploratory development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa5b590b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1843/b/2"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1843(b)(2)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/u/4/A"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(u)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2153"},"text":"135 Stat. 2153","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa5b590c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"codification","id":"idaa5b590d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsecs. (b) and (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2364"},"text":"section 2364 of this title","children":[],"tail":", which were transferred to this section and redesignated as subsecs. (a) and (b), respectively, by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1843/b/2"},"text":"Pub. L. 116–283, § 1843(b)(2)","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tII/s234/c/1"},"text":"Pub. L. 99–661, div. A, title II, § 234(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3848"},"text":"100 Stat. 3848","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/26"},"text":"Pub. L. 100–26","children":[],"tail":", §§ 3(1)(A), 7(a)(9), "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/273"},"text":"101 Stat. 273","children":[],"tail":", 278; "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tXII/s1231/10/A"},"text":"Pub. L. 100–180, div. A, title XII, § 1231(10)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1160"},"text":"101 Stat. 1160","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tVIII/s805"},"text":"Pub. L. 104–106, div. A, title VIII, § 805","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/390"},"text":"110 Stat. 390","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tII/s213"},"text":"Pub. L. 113–291, div. A, title II, § 213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3325"},"text":"128 Stat. 3325","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tII/s214/a/2"},"text":"Pub. L. 114–92, div. A, title II, § 214(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/768"},"text":"129 Stat. 768","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1844/d"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1844(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4246"},"text":"134 Stat. 4246","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/u/5/B"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(u)(5)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2154"},"text":"135 Stat. 2154","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa5b590e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1843/b/2"},"text":"Pub. L. 116–283, § 1843(b)(2)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/u/4/A"},"text":"Pub. L. 117–81, § 1701(u)(4)(A)","children":[],"tail":", transferred subsecs. (b) and (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2364"},"text":"section 2364 of this title","children":[],"tail":" to this section and redesignated them as subsecs. (a) and (b), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa5b590f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa5b5910-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" applicable as if included in the enactment of title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" as enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/a/2"},"text":"section 1701(a)(2) of Pub. L. 117–81","children":[],"tail":", set out in a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":" and Effective Date note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa5b5911-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as an Effective Date of 2021 Amendment note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa5b5912-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Specification of Certain Duties of the Defense Technical Information Center","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tIX/s905"},"text":"Pub. L. 115–232, div. A, title IX, § 905","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1922"},"text":"132 Stat. 1922","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1842/c/2"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1842(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4244"},"text":"134 Stat. 4244","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dA/tXVIII/s1842/c/2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to any other duties specified for the Defense Technical Information Center by law, regulation, or Department of Defense directive or instruction, the duties of the Center shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To execute the Global Research Watch Program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4066"},"text":"section 4066 of title 10","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To develop and maintain datasets and other data repositories on research and engineering activities being conducted within the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Action Plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":"], the Secretary of Defense shall submit to the Committees on Armed Services of the Senate and the House of Representatives a plan of action for the commencement by the Defense Technical Information Center of the duties specified in subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa5b5913-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Coordination of High-Temperature Superconductivity Research and Development","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tII/s218/b/2"},"text":"Pub. L. 100–180, div. A, title II, § 218(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1053"},"text":"101 Stat. 1053","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5115/c"},"text":"Pub. L. 100–418, title V, § 5115(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1433"},"text":"102 Stat. 1433","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tIX/s904/f"},"text":"Pub. L. 103–160, div. A, title IX, § 904(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1729"},"text":"107 Stat. 1729","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tIX/s911/a/1"},"text":"Pub. L. 106–65, div. A, title IX, § 911(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/717"},"text":"113 Stat. 717","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/65/dA/tIX/s911/a/1"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Secretary of Defense, acting through the Under Secretary of Defense for Acquisition, Technology, and Logistics, shall—","children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the research and development activities of the Department of Defense relating to high-temperature superconductivity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that such research and development—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is carried out in coordination with the high-temperature superconductivity research and development activities of the Department of Energy (including the national laboratories of the Department of Energy), the National Science Foundation, the National Institute of Standards and Technology, and the National Aeronautics and Space Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complements rather than duplicates such activities.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
