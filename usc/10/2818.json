{"tag":"section","attrib":{"id":"ida9dcda4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2818"},"text":null,"children":[{"tag":"num","attrib":{"value":"2818"},"text":"§ 2818.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts for design and construction of facilities of Department of Defense","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9dcda50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2818/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an element of the Department of Defense (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s111/b"},"text":"section 111(b) of this title","children":[],"tail":") may award a contract to any other such element for the design and construction of facilities of the Department of Defense, including facility maintenance and repair projects and unspecified minor military construction projects under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2805"},"text":"section 2805 of this title","children":[],"tail":", on a reimbursable basis."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9dcda51-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2818/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration as an Obligation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contract awarded under subsection (a) by such head shall be considered to be an obligation of such head in the same manner as a similar order or contract placed by such head with a private entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9dcda52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2818/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An awardee of a contract under subsection (a) may include an amount equal to not more than 10 percent of the proposed value of the contract for contingency expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9dcda53-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dB/tXXVIII/s2843"},"text":"Pub. L. 118–159, div. B, title XXVIII, § 2843","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2263"},"text":"138 Stat. 2263","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVII/s1701/a/18"},"text":"Pub. L. 119–60, div. A, title XVII, § 1701(a)(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1209"},"text":"139 Stat. 1209","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9dcda54-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9dcda55-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9dcda56-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “contract” for “contact”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
