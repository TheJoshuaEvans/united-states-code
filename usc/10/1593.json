{"tag":"section","attrib":{"id":"ida8fa697b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1593"},"text":null,"children":[{"tag":"num","attrib":{"value":"1593"},"text":"§ 1593.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform allowance: civilian employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8fa697c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1593/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allowance Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fa697d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1593/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may pay an allowance to each civilian employee of the Department of Defense who is required by law or regulation to wear a prescribed uniform in the performance of official duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa697e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1593/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In lieu of providing an allowance under paragraph (1), the Secretary may provide a uniform to a civilian employee referred to in such paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa697f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1593/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection shall not apply with respect to a civilian employee of the Defense Intelligence Agency who is entitled to an allowance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1622"},"text":"section 1622 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa6980-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1593/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of Allowance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5901/a"},"text":"section 5901(a) of title 5","children":[],"tail":", the amount of an allowance paid, and the cost of uniforms provided, under subsection (a) to a civilian employee may not exceed $400 per year (or such higher maximum amount as the Secretary of Defense may by regulation prescribe)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa6981-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1593/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Allowance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An allowance paid, or uniform provided, under subsection (a) shall be treated in the same manner as is provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5901/c"},"text":"section 5901(c) of title 5","children":[],"tail":" for an allowance paid under that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa6982-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1593/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Appropriated Funds for Allowance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts appropriated annually to the Department of Defense for the pay of civilian employees may be used for uniforms, or for allowance for uniforms, as authorized by this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5901"},"text":"section 5901 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8fa6983-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tIII/s336/a/1"},"text":"Pub. L. 101–189, div. A, title III, § 336(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1419"},"text":"103 Stat. 1419","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIV/s1481/d/3"},"text":"Pub. L. 101–510, div. A, title XIV, § 1481(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1706"},"text":"104 Stat. 1706","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVI/s1633/e/1"},"text":"Pub. L. 104–201, div. A, title XVI, § 1633(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2752"},"text":"110 Stat. 2752","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tXI/s1113"},"text":"Pub. L. 110–181, div. A, title XI, § 1113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/360"},"text":"122 Stat. 360","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8fa6984-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8fa6985-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida8fa6986-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in subsec. (d) of this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/165/tIX/s9010"},"text":"Pub. L. 101–165, title IX, § 9010","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1131"},"text":"103 Stat. 1131","children":[],"tail":", which was set out as a note below, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1481/d/4/B"},"text":"Pub. L. 101–510, § 1481(d)(4)(B)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8fa6987-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" substituted “$400 per year (or such higher maximum amount as the Secretary of Defense may by regulation prescribe).” for “$400 per year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" substituted “section 1622” for “section 1606”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8fa6988-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8fa6989-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVI/s1635"},"text":"Pub. L. 104–201, div. A, title XVI, § 1635","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2752"},"text":"110 Stat. 2752","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/201/dA/tXVI/s1635"},"text":"“This subtitle [subtitle B (§§ 1631–1635) of title XVI of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":", enacting sections 1601 to 1603, 1606 to 1610, and 1612 to 1614 of this title, amending this section, sections 1596, 1605, 1611, and 1621 of this title, and sections 7103 and 7511 of Title 5, Government Organization and Employees, renumbering sections 1599, 1602, 1606, and 1608 of this title as sections 1611, 1621, 1622, and 1623 of this title, respectively, repealing sections 1590, 1601, 1603, and 1604 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s833"},"text":"section 833 of Title 50","children":[],"tail":", War and National Defense, enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1601"},"text":"section 1601 of this title","children":[],"tail":", and repealing provisions formerly set out in a National Security Agency Act of 1959 note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s402"},"text":"section 402 of Title 50","children":[],"tail":"] and the amendments made by this subtitle shall take effect on "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"October 1, 1996","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8fa698a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tIII/s336/c"},"text":"Pub. L. 101–189, div. A, title III, § 336(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1419"},"text":"103 Stat. 1419","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/189/dA/tIII/s336/c"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1606"},"text":"section 1606 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"1990-01-01"},"text":"January 1, 1990","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8fa698b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Availability of Funds for Pay of Civilian Employees for Uniforms","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/165/tIX/s9010"},"text":"Pub. L. 101–165, title IX, § 9010","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1131"},"text":"103 Stat. 1131","children":[],"tail":", which made appropriations available to Department of Defense for pay of civilian employees for uniforms, or allowances therefor, as authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5901"},"text":"section 5901 of title 5","children":[],"tail":", was repealed and restated in subsec. (d) of this section by "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1481/d/3"},"text":"Pub. L. 101–510, § 1481(d)(3)","children":[],"tail":", (4)(B)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
