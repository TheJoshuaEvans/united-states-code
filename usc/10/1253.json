{"tag":"section","attrib":{"id":"ida8b2d9d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1253"},"text":null,"children":[{"tag":"num","attrib":{"value":"1253"},"text":"§ 1253.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Age 64: regular commissioned officers in general and flag officer grades; exceptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8b2d9d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1253/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless retired or separated earlier, each regular commissioned officer of the Army, Navy, Air Force, Marine Corps, or Space Force serving in a general or flag officer grade shall be retired on the first day of the month following the month in which the officer becomes 64 years of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8b2d9d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1253/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for Officers Serving in O–","children":[],"tail":"9"},{"tag":"inline","attrib":{},"text":" and O–","children":[],"tail":"10"},{"tag":"inline","attrib":{},"text":" Positions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an officer serving in a position that carries a grade above major general or rear admiral, the retirement under subsection (a) of that officer may be deferred—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8b549d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1253/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the President, but such a deferment may not extend beyond the first day of the month following the month in which the officer becomes 68 years of age; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8b549d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1253/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Secretary of Defense, but such a deferment may not extend beyond the first day of the month following the month in which the officer becomes 66 years of age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8b549da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1253/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deferred Retirement of Chaplains","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8b549db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1253/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the military department concerned may defer the retirement under subsection (a) of an officer serving in a general or flag officer grade who is the Chief of Chaplains or Deputy Chief of Chaplains of that officer’s armed force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8b549dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1253/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A deferment of the retirement of an officer referred to in paragraph (1) may not extend beyond the first day of the month following the month in which the officer becomes 68 years of age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8b549dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s502/a"},"text":"Pub. L. 109–364, div. A, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2176"},"text":"120 Stat. 2176","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tV/s504/a"},"text":"Pub. L. 114–92, div. A, title V, § 504(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/807"},"text":"129 Stat. 807","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tV/s508"},"text":"Pub. L. 116–92, div. A, title V, § 508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1346"},"text":"133 Stat. 1346","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/3/V"},"text":"Pub. L. 116–283, div. A, title IX, § 924(b)(3)(V)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3821"},"text":"134 Stat. 3821","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8b549de-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8b549df-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8b549e0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Marine Corps, or Space Force” for “or Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" struck out par. (3) which read as follows: “The authority to defer the retirement of an officer referred to in paragraph (1) expires "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":". Subject to paragraph (2), a deferment granted before that date may continue on and after that date.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s504/b/1"},"text":"Pub. L. 114–92, § 504(b)(1)","children":[],"tail":", substituted “Age 64: regular commissioned officers in general and flag officer grades; exceptions” for “Age 64: regular commissioned officers in general and flag officer grades; exception” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s504/a"},"text":"Pub. L. 114–92, § 504(a)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
