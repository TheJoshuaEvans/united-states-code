{"tag":"section","attrib":{"id":"idaa2e0771-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3675"},"text":null,"children":[{"tag":"num","attrib":{"value":"3675"},"text":"§ 3675.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital lease or lease-purchase treated as an acquisition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa2e0772-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3675/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a lease or charter covered by this chapter is a capital lease or a lease-purchase—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa2e0773-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3675/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lease or charter shall be treated as an acquisition and shall be subject to all applicable statutory and regulatory requirements for the acquisition of aircraft, naval vessels, or combat vehicles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa2e0774-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3675/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds appropriated to the Department of Defense for operation and maintenance may not be obligated or expended for the lease or charter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa2e0775-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3675/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"ta