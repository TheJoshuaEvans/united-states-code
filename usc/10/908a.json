{"tag":"section","attrib":{"id":"ida82ae561-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s908a"},"text":null,"children":[{"tag":"num","attrib":{"value":"908a"},"text":"§ 908a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 108a. Captured or abandoned property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida82ae562-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s908a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All persons subject to this chapter shall secure all public property taken from the enemy for the service of the United States, and shall give notice and turn over to the proper authority without delay all captured or abandoned property in their possession, custody, or control.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82ae563-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s908a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any person subject to this chapter who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82ae564-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s908a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to carry out the duties prescribed in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82ae565-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s908a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" buys, sells, trades, or in any way deals in or disposes of captured or abandoned property, whereby he receives or expects any profit, benefit, or advantage to himself or another directly or indirectly connected with himself; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82ae566-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s908a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engages in looting or pillaging;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida82ae567-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/70"},"text":"70A Stat. 70","children":[],"tail":", § 903; renumbered § 908a, "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLX/s5401/4"},"text":"Pub. L. 114–328, div. E, title LX, § 5401(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2938"},"text":"130 Stat. 2938","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida82ae568-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida82ae569-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida82ae56a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"ht