{"tag":"section","attrib":{"id":"ida9cea91d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2774"},"text":null,"children":[{"tag":"num","attrib":{"value":"2774"},"text":"§ 2774.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claims for overpayment of pay and allowances and of travel and transportation allowances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9cea91e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2774/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A claim of the United States against a person arising out of an erroneous payment of any pay or allowances made before, on, or after ","children":[{"tag":"date","attrib":{"date":"1972-10-02"},"text":"October 2, 1972","children":[],"tail":", or arising out of an erroneous payment of travel and transportation allowances, to or on behalf of a member or former member of the uniformed services, the collection of which would be against equity and good conscience and not in the best interest of the United States, may be waived in whole or in part by—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9cea91f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2774/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Office of Management and Budget; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cea920-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2774/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary concerned, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s101/5"},"text":"section 101(5) of title 37","children":[],"tail":", when—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9cea921-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2774/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claim is in an amount aggregating not more than $10,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9cea922-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2774/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the waiver is made in accordance with standards which the Director of the Office of Management and Budget shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cea923-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2774/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director of the Office of Management and Budget or the Secretary concerned, as the case may be, may not exercise his authority under this section to waive any claim—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9cea924-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2774/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if, in his opinion, there exists, in connection with the claim, an indication of fraud, misrepresentation, fault, or lack of good faith on the part of the member or any other person having an interest in obtaining a waiver of the claim; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cea925-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2774/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if application for waiver is received in his office after the expiration of five years immediately following the date on which the erroneous payment was discovered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cea926-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2774/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who has repaid to the United States all or part of the amount of a claim, with respect to which a waiver is granted under this section, is entitled, to the extent of the waiver, to refund, by the department concerned at the time of the erroneous payment, of the amount repaid to the United States, if he applies to that department for that refund within two years following the effective date of the waiver. The Secretary concerned shall pay from current applicable appropriations that refund in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cea927-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2774/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the audit and settlement of accounts of any accountable officer or official, full credit shall be given for any amounts with respect to which collection by the United States is waived under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cea928-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2774/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An erroneous payment, the collection of which is waived under this section, is considered a valid payment for all purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cea929-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2774/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not affect any authority under any other law to litigate, settle, compromise, or waive any claim of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9cea92a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/453/s1/1"},"text":"Pub. L. 92–453, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-02"},"text":"Oct. 2, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/758"},"text":"86 Stat. 758","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s511/98"},"text":"Pub. L. 96–513, title V, § 511(98)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2928"},"text":"94 Stat. 2928","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/224/s2/a"},"text":"Pub. L. 99–224, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-28"},"text":"Dec. 28, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1741"},"text":"99 Stat. 1741","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s7/j/7/A"},"text":"Pub. L. 100–26, § 7(j)(7)(A)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/283"},"text":"101 Stat. 283","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVI/s657/b"},"text":"Pub. L. 102–190, div. A, title VI, § 657(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1393"},"text":"105 Stat. 1393","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tI/s105/b"},"text":"Pub. L. 104–316, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3830"},"text":"110 Stat. 3830","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tVI/s671/a"},"text":"Pub. L. 109–364, div. A, title VI, § 671(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2270"},"text":"120 Stat. 2270","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9cea92b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9cea92c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9cea92d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s671/a/1"},"text":"Pub. L. 109–364, § 671(a)(1)","children":[],"tail":", substituted “$10,000” for “$1,500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s671/a/2"},"text":"Pub. L. 109–364, § 671(a)(2)","children":[],"tail":", substituted “five years” for “three years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316/s105/b/1"},"text":"Pub. L. 104–316, § 105(b)(1)","children":[],"tail":", substituted “Director of the Office of Management and Budget” for “Comptroller General” in par. (1), and in par. (2) inserted “and” at end of subpar. (A), redesignated subpar. (C) as (B) and substituted “Director of the Office of Management and Budget” for “Comptroller General”, and struck out former subpar. (B) which read as follows “the claim is not the subject of an exception made by the Comptroller General in the account of any accountable officer or official; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316/s105/b/2"},"text":"Pub. L. 104–316, § 105(b)(2)","children":[],"tail":", substituted “Director of the Office of Management and Budget” for “Comptroller General”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" substituted “$1,500” for “$500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/26/s7/j/7/A"},"text":"Pub. L. 100–26, § 7(j)(7)(A)","children":[],"tail":", substituted “allowances and of” for “allowances, and” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/26/s7/j/7/B"},"text":"Pub. L. 100–26, § 7(j)(7)(B)","children":[],"tail":", struck out “as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s101/3"},"text":"section 101(3) of title 37","children":[],"tail":",” after “uniformed services,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/224/s2/a/1"},"text":"Pub. L. 99–224, § 2(a)(1)","children":[],"tail":", substituted “and” for “other than” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/224/s2/a/2"},"text":"Pub. L. 99–224, § 2(a)(2)","children":[],"tail":", substituted “made before, on, or after "},{"tag":"date","attrib":{"date":"1972-10-02"},"text":"October 2, 1972","children":[],"tail":", or arising out of an erroneous payment of travel and transportation allowances” for “, other than travel and transportation allowances, made before or after "},{"tag":"date","attrib":{"date":"1972-10-02"},"text":"October 2, 1972","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/224/s2/a/3"},"text":"Pub. L. 99–224, § 2(a)(3)","children":[],"tail":", struck out “of pay or allowances, other than travel and transportation allowances,” after “payment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1972-10-02"},"text":"October 2, 1972","children":[],"tail":"” for “the effective date of this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9cea92e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9cea92f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tVI/s671/c"},"text":"Pub. L. 109–364, div. A, title VI, § 671(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2270"},"text":"120 Stat. 2270","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/364/dA/tVI/s671/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s716"},"text":"section 716 of Title 32","children":[],"tail":", National Guard] shall take effect on "},{"tag":"date","attrib":{"date":"2007-03-01"},"text":"March 1, 2007","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9cea930-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316"},"text":"Pub. L. 104–316","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/s101/e"},"text":"section 101(e) of Pub. L. 104–316","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4593"},"text":"section 4593 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9cea931-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/224"},"text":"Pub. L. 99–224","children":[],"tail":" applicable to any claim arising out of an erroneous payment of travel and transportation allowances made on or after "},{"tag":"date","attrib":{"date":"1985-12-28"},"text":"Dec. 28, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/224/s4"},"text":"section 4 of Pub. L. 99–224","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5584"},"text":"section 5584 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9cea932-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/b/3"},"text":"section 701(b)(3) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9cea933-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Cancellation of Debts Up To $2,500 of Uniformed Service Members Incurred in Connection With Operation Desert Shield/Storm","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/61/tVIII/s8052"},"text":"Pub. L. 104–61, title VIII, § 8052","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-01"},"text":"Dec. 1, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/662"},"text":"109 Stat. 662","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/61/tVIII/s8052"},"text":"“Notwithstanding any other provision of law, the Secretary of Defense may, when he considers it in the best interest of the United States, cancel any part of an indebtedness, up to $2,500, that is or was owed to the United States by a member or former member of a uniformed service if such indebtedness, as determined by the Secretary, was incurred in connection with Operation Desert Shield/Storm: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the amount of an indebtedness previously paid by a member or former member and cancelled under this section shall be refunded to the member.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/335/tVIII/s8060"},"text":"Pub. L. 103–335, title VIII, § 8060","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-30"},"text":"Sept. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2633"},"text":"108 Stat. 2633","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/139/tVIII/s8071"},"text":"Pub. L. 103–139, title VIII, § 8071","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-11"},"text":"Nov. 11, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1457"},"text":"107 Stat. 1457","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/396/tIX/s9100"},"text":"Pub. L. 102–396, title IX, § 9100","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1926"},"text":"106 Stat. 1926","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/172/tVIII/s8138"},"text":"Pub. L. 102–172, title VIII, § 8138","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-26"},"text":"Nov. 26, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1212"},"text":"105 Stat. 1212","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
