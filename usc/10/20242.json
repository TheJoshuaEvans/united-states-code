{"tag":"section","attrib":{"id":"idabca79a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20242"},"text":null,"children":[{"tag":"num","attrib":{"value":"20242"},"text":"§ 20242.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to vacate promotions to grade of brigadier general","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabca79a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20242/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President may vacate the appointment of a Space Force officer to the grade of brigadier general if the period of time during which the officer has served in that grade after promotion to that grade is less than 18 months.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabca79a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20242/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Promotion Being Vacated","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer whose promotion to the grade of brigadier general is vacated under this section holds the grade of colonel. Upon assuming the grade of colonel under this section, the officer shall have the same position on the Space Force officer list as the officer would have had if the officer had not served in the higher grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabca79a8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1716/c"},"text":"Pub. L. 118–31, div. A, title XVII, § 1716(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/648"},"text":"137 Stat. 648","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
