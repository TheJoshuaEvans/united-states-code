{"tag":"section","attrib":{"id":"idaafd658b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7689"},"text":null,"children":[{"tag":"num","attrib":{"value":"7689"},"text":"§ 7689.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of material and equipment to the Architect of the Capitol","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Army is authorized to transfer, without payment, to the Architect of the Capitol, such material and equipment, not required by the Department of the Army, as the Architect may request for use at the Capitol power plant, the Capitol, and the Senate and House Office Buildings.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idaafd658c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s2/1"},"text":"Pub. L. 107–217, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1294"},"text":"116 Stat. 1294","children":[],"tail":", § 4689; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tX/s1084/d/29"},"text":"Pub. L. 108–375, div. A, title X, § 1084(d)(29)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2063"},"text":"118 Stat. 2063","children":[],"tail":"; renumbered § 7689, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/d"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaafd658d-3a6f-11f1-a58a-