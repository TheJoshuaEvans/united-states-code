{"tag":"section","attrib":{"id":"ida9208f8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2013"},"text":null,"children":[{"tag":"num","attrib":{"value":"2013"},"text":"§ 2013.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training at non-Government facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9208f8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2013/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Enter Into Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9208f8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2013/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned, without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":", may make agreements or other arrangements for the training of members of the uniformed services under the jurisdiction of that Secretary by, in, or through non-Government facilities."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9208f8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2013/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section, the term “non-Government facility” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9208f8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2013/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The government of a State or of a territory or possession of the United States, including the Commonwealth of Puerto Rico, an interstate governmental organization, and a unit, subdivision, or instrumentality of any of the foregoing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9208f8f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2013/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A foreign government or international organization, or instrumentality of either, which is designated by the President as eligible to provide training under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9208f90-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2013/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A medical, scientific, technical, educational, research, or professional institution, foundation, or organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9208f91-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2013/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A business, commercial, or industrial firm, corporation, partnership, proprietorship, or other organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9208f92-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2013/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individuals other than civilian or military personnel of the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9208f93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2013/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The services and property of any of the foregoing providing the training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9208f94-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2013/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned, from appropriations or other funds available to the Secretary, may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9208f95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2013/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay all or a part of the pay of a member of a uniformed service who is selected and assigned for training under this section, for the period of training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9208f96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2013/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" pay, or reimburse the member of a uniformed service for, all or a part of the necessary expenses of the training (without regard to subsections (a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3324"},"text":"section 3324 of title 31","children":[],"tail":"), including among those expenses the necessary costs of the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9208f97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2013/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Travel and per diem instead of subsistence under sections 405 and 452 of title 37 and the Joint Travel Regulations for the Uniformed Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9208f98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2013/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation of immediate family, household goods and personal effects, packing, crating, temporarily storing, draying, and unpacking under sections 452 and 453(c) of title 37 and the Joint Travel Regulations for the Uniformed Services when the estimated costs of transportation and related services are less than the estimated aggregate per diem payments for the period of training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9208f99-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2013/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tuition and matriculation fees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9208f9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2013/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Library and laboratory services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9208f9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2013/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Purchase or rental of books, materials, and supplies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9208f9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2013/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other services or facilities directly related to the training of the member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9208f9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2013/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain Expenses Excluded","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The expenses of training do not include membership fees except to the extent that the fee is a necessary cost directly related to the training itself or that payment of the fee is a condition precedent to undergoing the training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9208f9e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tIII/s362/a/1"},"text":"Pub. L. 104–201, div. A, title III, § 362(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2491"},"text":"110 Stat. 2491","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/b/2"},"text":"Pub. L. 111–350, § 5(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3842"},"text":"124 Stat. 3842","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s631/f/4/A"},"text":"Pub. L. 112–81, div. A, title VI, § 631(f)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1465"},"text":"125 Stat. 1465","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/a/9"},"text":"Pub. L. 112–239, div. A, title X, § 1076(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1948"},"text":"126 Stat. 1948","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1071/a/1"},"text":"Pub. L. 113–291, div. A, title X, § 1071(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3504"},"text":"128 Stat. 3504","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVI/s626/c/6"},"text":"Pub. L. 117–263, div. A, title VI, § 626(c)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2628"},"text":"136 Stat. 2628","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9208f9f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9208fa0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9208fa1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s626/c/6/A"},"text":"Pub. L. 117–263, § 626(c)(6)(A)","children":[],"tail":", substituted “sections 405 and 452” for “sections 474 and 475”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s626/c/6/B"},"text":"Pub. L. 117–263, § 626(c)(6)(B)","children":[],"tail":", substituted “sections 452 and 453(c)” for “sections 476 and 479”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":"” for “section 6101(b)–(d) of title 41”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(2)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1076/a/9"},"text":"Pub. L. 112–239, § 1076(a)(9)","children":[],"tail":", made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/s631/f/4/A"},"text":"Pub. L. 112–81, § 631(f)(4)(A)","children":[],"tail":". See 2011 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":" substituted “section 6101(b)–(d) of title 41” for “section 3709 of the Revised Statutes ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s5"},"text":"41 U.S.C. 5","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s631/f/4/A"},"text":"Pub. L. 112–81, § 631(f)(4)(A)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1076/a/9"},"text":"Pub. L. 112–239, § 1076(a)(9)","children":[],"tail":", substituted “474” for “404” and “475” for “405” in subpar. (A), and “476” for “406” and “479” for “409” in subpar. (B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9208fa2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9208fa3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/a"},"text":"Pub. L. 112–239, div. A, title X, § 1076(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1947"},"text":"126 Stat. 1947","children":[],"tail":", provided that the amendment made by section 1076(a)(9) is effective "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9208fa4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tIII/s362/b"},"text":"Pub. L. 104–201, div. A, title III, § 362(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2493"},"text":"110 Stat. 2493","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/201/dA/tIII/s362/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2013"},"text":"Section 2013 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall take effect on "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"October 1, 1996","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
