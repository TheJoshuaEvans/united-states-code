{"tag":"section","attrib":{"id":"idaadc2210-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7138"},"text":null,"children":[{"tag":"num","attrib":{"value":"7138"},"text":"§ 7138.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regular Army: reenlistment after service as an officer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaadc2211-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7138/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any former enlisted member of the Regular Army who has served on active duty as an officer of the Army, or who was discharged as an enlisted member to accept an appointment as an officer of the Army, is entitled to be reenlisted in the Regular Army in the enlisted grade that he held before his service as an officer, without loss of seniority or credit for service, regardless of the existence of a vacancy in his grade or of a physical disability incurred or having its inception in line of duty, if (1) his service as an officer is terminated by an honorable discharge or he is relieved from active duty for a purpose other than to await appellate review of a sentence that includes dismissal or dishonorable discharge, and (2) he applies for reenlistment within six months (or such other period as the Secretary of the Army prescribes for exceptional circumstances) after termination of that service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaadc2212-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7138/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person is not entitled to be reenlisted under this section if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaadc2213-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7138/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the person was discharged or released from active duty as an officer on the basis of a determination of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaadc2214-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7138/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" misconduct;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaadc2215-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7138/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" moral or professional dereliction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaadc2216-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7138/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" duty performance below prescribed standards for the grade held; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaadc2217-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7138/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retention being inconsistent with the interests of national security; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaadc2218-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7138/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person’s former enlisted status and grade was based solely on the participation by that person in a precommissioning program that resulted in the commission held by that person during the active duty from which the person was released or discharged.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaadc2219-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/179"},"text":"70A Stat. 179","children":[],"tail":", § 3258; "},{"tag":"ref","attrib":{"href":"/us/pl/85/603/s1/1"},"text":"Pub. L. 85–603, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-08"},"text":"Aug. 8, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/526"},"text":"72 Stat. 526","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tV/s520/a"},"text":"Pub. L. 102–484, div. A, title V, § 520(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2408"},"text":"106 Stat. 2408","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tV/s506/a"},"text":"Pub. L. 110–181, div. A, title V, § 506(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/96"},"text":"122 Stat. 96","children":[],"tail":"; renumbered § 7138, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/b/2"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1838"},"text":"132 Stat. 1838","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaadc221a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaadc221b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaadc221c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3258","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:631a (less last proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1939-07-14/ch267/s1"},"text":"July 14, 1939, ch. 267, § 1","children":[],"tail":" (less last proviso); restated "},{"tag":"html:a","attrib":{"href":"/us/act/1954-05-29/ch249/s19/b"},"text":"May 29, 1954, ch. 249, § 19(b)","children":[],"tail":" (less last proviso), "},{"tag":"html:a","attrib":{"href":"/us/stat/68/166"},"text":"68 Stat. 166","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “former” and “as an enlisted member” are inserted for clarity. The words “credit for service” are substituted for the words “of service”. The words “in his grade” are substituted for the words “in the appropriate enlisted grade”. The words “he applies” are substituted for the words “application * * * shall be made”. The words “Hereafter” and “while on active duty” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaadc221d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaadc221e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3258"},"text":"section 3258 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s506/a/1"},"text":"Pub. L. 110–181, § 506(a)(1)","children":[],"tail":", substituted “an officer” for “a Reserve officer” and “an appointment” for “a temporary appointment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s506/a/2/A"},"text":"Pub. L. 110–181, § 506(a)(2)(A)","children":[],"tail":", substituted “an officer” for “a Reserve officer” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s506/a/2/B"},"text":"Pub. L. 110–181, § 506(a)(2)(B)","children":[],"tail":", substituted “the commission” for “the Reserve commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":" designated existing provisions as subsec. (a), added subsec. (b), and struck out at end of subsec. (a) “However, if his service as an officer terminated by a general discharge, he may, under regulations to be prescribed by the Secretary of the Army, be so reenlisted.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/603"},"text":"Pub. L. 85–603","children":[],"tail":" limited entitlement to be reenlisted in enlisted grade to those officers whose service terminated by an honorable discharge and those relieved from active duty for a purpose other than to await appellate review of a sentence that includes dismissal or dishonorable discharge, and provided that persons whose service terminated by a general discharge, may, under regulations to be prescribed by the Secretary of the Army, be so reenlisted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaadc221f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaadc2220-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaadc2221-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tV/s520/c"},"text":"Pub. L. 102–484, div. A, title V, § 520(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2409"},"text":"106 Stat. 2409","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/484/dA/tV/s520/c"},"text":"“The amendments made by subsections (a) and (b) [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8258"},"text":"section 8258 of this title","children":[],"tail":"] shall apply to persons discharged or released from active duty as commissioned officers in the Army Reserve or the Air Force Reserve, respectively, after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
