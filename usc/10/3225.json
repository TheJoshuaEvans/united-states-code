{"tag":"section","attrib":{"id":"idaa13c8e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3225"},"text":null,"children":[{"tag":"num","attrib":{"value":"3225"},"text":"§ 3225.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discussion of risk in cost estimates","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Director of Cost Assessment and Program Evaluation, and the Secretary of the military department concerned or the head of the Defense Agency concerned (as applicable), shall each—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa13c8e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3225/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue guidance requiring a discussion of risk, the potential impacts of risk on program costs, and approaches to mitigate risk in cost estimates for major defense acquisition programs and major subprograms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa13c8ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3225/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that cost estimates are developed, to the extent practicable, based on historical actual cost information that is based on demonstrated contractor and Government performance and that such estimates provide a high degree of confidence that the program or subprogram can be completed without the need for significant adjustment to program budgets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa13c8eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3225/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include the information required in the guidance under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa13c8ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3225/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any decision documentation approving a cost estimate within the baseline description or any other cost estimate for use at any event specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3221/b/6"},"text":"section 3221(b)(6) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa13c8ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3225/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the next Selected Acquisition Report pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4351"},"text":"section 4351 of this title","children":[],"tail":" in the case of a major defense acquisition program or major subprogram."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa13c8ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1812/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1812(a)","children":[],"tail":", (f), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4174"},"text":"134 Stat. 4174","children":[],"tail":", 4176; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(6)(A)(ii), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat