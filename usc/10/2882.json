{"tag":"section","attrib":{"id":"ida9eda2c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2882"},"text":null,"children":[{"tag":"num","attrib":{"value":"2882"},"text":"§ 2882.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of assignment of members to housing units acquired or constructed under alternative authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9eda2c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2882/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment as Quarters of the United States","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), housing units acquired or constructed under this subchapter shall be considered as quarters of the United States or a housing facility under the jurisdiction of a uniformed service for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s403"},"text":"section 403 of title 37","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9eda2c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2882/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Basic Allowance for Housing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the armed forces who is assigned to a housing unit acquired or constructed under this subchapter that is not owned or leased by the United States shall be entitled to a basic allowance for housing under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s403"},"text":"section 403 of title 37","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9eda2c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2882/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lease Payments Through Pay Allotments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may require members of the armed forces who lease housing in housing units acquired or constructed under this subchapter to make lease payments for such housing pursuant to allotments of the pay of such members under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s701"},"text":"section 701 of title 37","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9eda2c9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dB/tXXVIII/s2801/a/1"},"text":"Pub. L. 104–106, div. B, title XXVIII, § 2801(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/548"},"text":"110 Stat. 548","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVI/s603/d/2/C"},"text":"Pub. L. 105–85, div. A, title VI, § 603(d)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1783"},"text":"111 Stat. 1783","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/dB/tXXVIII/s2805/e/1"},"text":"Pub. L. 110–417, div. B, title XXVIII, § 2805(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4723"},"text":"122 Stat. 4723","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9eda2ca-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9eda2cb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9eda2cc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" amended section generally. Prior to amendment, section related to assignment of members of the armed forces to housing units by the Secretary concerned, treatment of such housing as quarters of the United States, entitlement to a basic allowance for housing, and making of lease payments through pay allotments."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s603/d/2/C/i"},"text":"Pub. L. 105–85, § 603(d)(2)(C)(i)","children":[],"tail":", substituted “section 403” for “section 403(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s603/d/2/C/ii"},"text":"Pub. L. 105–85, § 603(d)(2)(C)(ii)","children":[],"tail":", substituted “basic allowance for housing under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s403"},"text":"section 403 of title 37","children":[],"tail":"” for “basic allowance for quarters under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s403"},"text":"section 403 of title 37","children":[],"tail":" and, if in a high housing cost area, a variable housing allowance under section 403a of that title”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9eda2cd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9eda2ce-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-01-01"},"text":"Jan. 1, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/s603/e"},"text":"section 603(e) of Pub. L. 105–85","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5561"},"text":"section 5561 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
