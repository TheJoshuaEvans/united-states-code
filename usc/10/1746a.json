{"tag":"section","attrib":{"id":"ida90d7c75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1746a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1746a"},"text":"§ 1746a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition workforce educational partnerships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida90d7c76-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1746a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense, acting through the Under Secretary of Defense for Acquisition and Sustainment, shall establish a program within Defense Acquisition University to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90d7c77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1746a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the engagement of relevant experts, including with the acquisition research activities established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4142"},"text":"section 4142 of this title","children":[],"tail":", with the faculty of the Defense Acquisition University to assess and modify the curriculum of the Defense Acquisition University, as appropriate, to enhance the capabilities of the Defense Acquisition University to support educational, training, and research activities in support of acquisition missions of the Department of Defense;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90d7c78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1746a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a cross-discipline, peer mentoring program for academic advising and to address critical retention concerns with respect to the acquisition workforce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90d7c79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1746a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partner with extramural institutions and military department functional leadership to offer training and on-the-job learning support to all members of the acquisition workforce addressing operational challenges that affect procurement decisionmaking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90d7c7a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1746a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the partnerships between the Department of Defense and extramural institutions with missions relating to the training and continuous development of members of the acquisition workforce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90d7c7b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1746a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accelerate the adoption, appropriate design and customization, and use of flexible acquisition practices by the acquisition workforce by expanding the availability of training and on-the-job learning and guidance on such practices and incorporating such training into the curriculum of the Defense Acquisition University; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90d7c7c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1746a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support and enhance the capabilities of the faculty of the Defense Acquisition University, and the currency and applicability of the knowledge possessed by such faculty, by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida90d7c7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1746a/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building partnerships between the faculty of the Defense Acquisition University and the director of, and individuals involved with, the activities established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4142"},"text":"section 4142 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90d7c7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1746a/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the preparation and drafting of the reports required under subsection (f)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90d7c7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1746a/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" instituting a program under which each member of the faculty of the Defense Acquisition University shall be detailed to an operational acquisition position in a military department or Defense Agency, or to an extramural institution, for not less than six months out of every five year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90d7c80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1746a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Senior Official","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the enactment of this section, the President of the Defense Acquisition University shall designate a senior official to execute activities under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90d7c81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1746a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support From Other Department of Defense Organizations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may direct other elements of the Department of Defense to provide personnel, resources, and other support to the program established under this section, as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90d7c82-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1746a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the availability of appropriations, the Under Secretary of Defense for Acquisition and Sustainment may use amounts available in the Defense Acquisition Workforce and Development Account (as established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1705"},"text":"section 1705 of this title","children":[],"tail":") to carry out the requirements of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90d7c83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1746a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2022-09-30"},"text":"September 30, 2022","children":[],"tail":", and annually thereafter, the President of the Defense Acquisition University shall submit to the Secretary of Defense and the congressional defense committees a report describing the activities conducted under this section during the one-year period ending on the date on which such report is submitted."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90d7c84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1746a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemption to Report Termination Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 1080(a) of the National Defense Authorization Act for Fiscal Year 2016 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Public Law 114–92","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/129/1000"},"text":"129 Stat. 1000","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s111"},"text":"10 U.S.C. 111","children":[],"tail":" note), as amended by section 1061(j) of the National Defense Authorization Act for Fiscal Year 2017 ("},{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Public Law 114–328","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/130/2405"},"text":"130 Stat. 2405","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s111"},"text":"10 U.S.C. 111","children":[],"tail":" note), does not apply with respect to the reports required to be submitted to Congress under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90d7c85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1746a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90d7c86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1746a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition workforce","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “acquisition workforce” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1705/g"},"text":"section 1705(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90d7c87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1746a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extramural institutions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “extramural institutions” means participants in an activity established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4142"},"text":"section 4142 of this title","children":[],"tail":", public sector organizations, and nonprofit credentialing organizations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida90d7c88-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVIII/s801/a"},"text":"Pub. L. 117–81, div. A, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1811"},"text":"135 Stat. 1811","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1883/b/2"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1883(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4294"},"text":"134 Stat. 4294","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida90d7c89-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida90d7c8a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida90d7c8b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The enactment of this section, referred to in subsec. (b), probably means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida90d7c8c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsecs. (a)(1), (6)(A), (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “section 4142” for “section 2361a”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida90d7c8d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida90d7c8e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
