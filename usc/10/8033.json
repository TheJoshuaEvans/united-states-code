{"tag":"section","attrib":{"id":"idab070311-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8033"},"text":null,"children":[{"tag":"num","attrib":{"value":"8033"},"text":"§ 8033.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief of Naval Operations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab070312-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8033/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab070313-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8033/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is a Chief of Naval Operations, appointed by the President, by and with the advice and consent of the Senate. The Chief of Naval Operations shall be appointed for a term of four years, from the flag officers of the Navy. He serves at the pleasure of the President. In time of war or during a national emergency declared by Congress, he may be reappointed for a term of not more than four years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab070314-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8033/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President may appoint an officer as the Chief of Naval Operations only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab070315-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8033/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer has had significant experience in joint duty assignments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab070316-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8033/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such experience includes at least one full tour of duty in a joint duty assignment (as defined in section 664(f) ","children":[{"tag":"ref","attrib":{"idref":"fn002159"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002159"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title) as a flag officer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab070317-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8033/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may waive paragraph (2) in the case of an officer if the President determines such action is necessary in the national interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab070318-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8033/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Naval Operations, while so serving, has the grade of admiral without vacating his permanent grade. In the performance of his duties within the Department of the Navy, the Chief of Naval Operations takes precedence above all other officers of the naval service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab070319-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8033/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise prescribed by law and subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8013/f"},"text":"section 8013(f) of this title","children":[],"tail":", the Chief of Naval Operations performs his duties under the authority, direction, and control of the Secretary of the Navy and is directly responsible to the Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab07031a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8033/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to the authority, direction, and control of the Secretary of the Navy, the Chief of Naval Operations shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab07031b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8033/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preside over the Office of the Chief of Naval Operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab07031c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8033/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmit the plans and recommendations of the Office of the Chief of Naval Operations to the Secretary and advise the Secretary with regard to such plans and recommendations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab07031d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8033/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after approval of the plans or recommendations of the Office of the Chief of Naval Operations by the Secretary, act as the agent of the Secretary in carrying them into effect;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab07031e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8033/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise supervision, consistent with the authority assigned to commanders of unified or specified combatant commands under chapter 6 of this title, over such of the members and organizations of the Navy and the Marine Corps as the Secretary determines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab07031f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8033/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform the duties prescribed for him by sections 171 and 3104 of this title and other provisions of law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab070320-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8033/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other military duties, not otherwise assigned by law, as are assigned to him by the President, the Secretary of Defense, or the Secretary of the Navy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab070321-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8033/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab070322-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8033/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Naval Operations shall also perform the duties prescribed for him as a member of the Joint Chiefs of Staff under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s151"},"text":"section 151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab070323-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8033/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent that such action does not impair the independence of the Chief of Naval Operations in the performance of his duties as a member of the Joint Chiefs of Staff, the Chief of Naval Operations shall inform the Secretary regarding military advice rendered by members of the Joint Chiefs of Staff on matters affecting the Department of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab070324-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8033/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the authority, direction, and control of the Secretary of Defense, the Chief of Naval Operations shall keep the Secretary of the Navy fully informed of significant military operations affecting the duties and responsibilities of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab070325-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s512/b"},"text":"Pub. L. 99–433, title V, § 512(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1049"},"text":"100 Stat. 1049","children":[],"tail":", § 5033; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tV/s519/a/3"},"text":"Pub. L. 100–456, div. A, title V, § 519(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"19