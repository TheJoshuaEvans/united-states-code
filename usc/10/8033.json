{"tag":"ref","attrib":{"href":"/us/stat/134/4257"},"text":"134 Stat. 4257","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/r/1/B"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(r)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2149"},"text":"135 Stat. 2149","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab070326-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab070327-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idab070328-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s664/f"},"text":"Section 664(f) of this title","children":[],"tail":", referred to in subsec. (a)(2)(B), was redesignated as "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s664/d"},"text":"section 664(d) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tV/s510/g/1"},"text":"Pub. L. 114–328, div. A, title V, § 510(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2111"},"text":"130 Stat. 2111","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab070329-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 5081 and 5082 of this title prior to enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433"},"text":"Pub. L. 99–433","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 8033 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9033"},"text":"section 9033 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 8033 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s10305"},"text":"section 10305 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 8034 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9034"},"text":"section 9034 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 8034 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8033"},"text":"section 8033 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab07032a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1847/e/6/B"},"text":"Pub. L. 116–283, § 1847(e)(6)(B)","children":[],"tail":", which directed substitution of “, 3103, and 4274” for “and 2547”, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/r/1/B"},"text":"Pub. L. 117–81, § 1701(r)(1)(B)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1808/d/3"},"text":"Pub. L. 116–283, § 1808(d)(3)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/r/2"},"text":"Pub. L. 117–81, § 1701(r)(2)","children":[],"tail":", substituted “and 3104” for “and 2547”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s807/a/1"},"text":"Pub. L. 115–232, § 807(a)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s5033"},"text":"section 5033 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 8013(f)” for “section 5013(f)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" substituted “sections 171 and 2547” for “section 171”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" substituted “from the flag officers of the Navy” for “from officers on the active-duty list in the line of the Navy who are eligible to command at sea and who hold the grade of rear admiral or above”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" substituted “full tour of duty in a joint duty assignment (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s664/f"},"text":"section 664(f) of this title","children":[],"tail":")” for “joint duty assignment”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab07032b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab07032c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" applicable as if included in the enactment of title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" as enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/a/2"},"text":"section 1701(a)(2) of Pub. L. 117–81","children":[],"tail":", set out in a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":" and note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab07032d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab07032e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reappointment of Incumbent Chief of Naval Operations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tV/s508"},"text":"Pub. L. 108–136, div. A, title V, § 508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1458"},"text":"117 Stat. 1458","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/136/dA/tV/s508"},"text":"“Notwithstanding the provisions of section 5033(a)(1) [now 8033(a)(1)] of title 10, United States Code, the President, by and with the advice and consent of the Senate, may reappoint the officer serving as Chief of Naval Operations on ","children":[{"tag":"date","attrib":{"date":"2003-10-01"},"text":"October 1, 2003","children":[],"tail":", for an additional term as Chief of Naval Operations. Such a reappointment shall be for a term of not more than two years.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab07032f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Waiver of Qualifications for Appointment as Service Chief","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions giving President temporary authority to waive requirements in subsec. (a)(2) of this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/s532/c"},"text":"section 532(c) of Pub. L. 99–433","children":[],"tail":", title V, "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1063"},"text":"100 Stat. 1063","children":[],"tail":", which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3033"},"text":"section 3033 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
