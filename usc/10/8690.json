{"tag":"section","attrib":{"id":"idab403b30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8690"},"text":null,"children":[{"tag":"num","attrib":{"value":"8690"},"text":"§ 8690.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on length of overseas forward deployment of naval vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab403b31-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8690/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy shall ensure that no naval vessel specified in subsection (b) that is listed in the Naval Vessel Register is forward deployed overseas for a period in excess of ten years. At the end of a period of overseas forward deployment, the vessel shall be assigned a homeport in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403b32-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8690/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessels Specified","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A naval vessel specified in this subsection is any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab403b33-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8690/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Aircraft carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403b34-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8690/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amphibious ship.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403b35-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8690/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cruiser.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403b36-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8690/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Destroyer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403b37-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8690/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Frigate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403b38-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8690/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Littoral Combat Ship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403b39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8690/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Navy may waive the limitation under subsection (a) with respect to a naval vessel if the Secretary submits to the congressional defense committees notice in writing of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab403b3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8690/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the waiver of such limitation with respect to the vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403b3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8690/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the period of overseas forward deployment of the vessel is expected to end; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403b3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8690/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the factors used by the Secretary to determine that a longer period of deployment would promote the national defense or be in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab403b3d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added § 7320 and renumbered § 8690, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tIII/s323/a/1"},"text":"Pub. L. 115–232, div. A, title III, § 323(a)(1)","children":[],"tail":", title VIII, § 807(d)(2), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1719"},"text":"132 Stat. 1719","children":[],"tail":", 1836.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab403b3e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab403b3f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab403b40-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8690, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/538"},"text":"70A Stat. 538","children":[],"tail":", exempted enlisted members of Air Force, while on active duty, from arrest for any debt, unless it was contracted before enlistment and amounted to at least $20 when first contracted, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/90/235/s7/b/1"},"text":"Pub. L. 90–235, § 7(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/763"},"text":"81 Stat. 763","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab403b41-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s807/d/2"},"text":"Pub. L. 115–232, § 807(d)(2)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7320"},"text":"section 7320 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab403b42-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab403b43-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s807/d/2"},"text":"section 807(d)(2) of Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab403b44-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Treatment of Currently Deployed Vessels; Extension of Limitation for U.S.S. Shiloh","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tIII/s323/b"},"text":"Pub. L. 115–232, div. A, title III, § 323(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1720"},"text":"132 Stat. 1720","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIII/s353/2"},"text":"Pub. L. 116–92, div. A, title III, § 353(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1321"},"text":"133 Stat. 1321","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIII/s344"},"text":"Pub. L. 116–283, div. A, title III, § 344","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3538"},"text":"134 Stat. 3538","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dA/tIII/s344"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Currently Deployed Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of any aircraft carrier, amphibious ship, cruiser, destroyer, frigate, or littoral combat ship that has been forward deployed overseas for a period in excess of ten years as of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":"], the Secretary of the Navy shall ensure that such vessel is assigned a homeport in the United States by not later than three years after the date of the enactment of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extension of Limitation on Length of Overseas Forward Deployment for U.S.S. Shiloh (CG–","children":[],"tail":"67).—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsection (b), the Secretary of the Navy shall ensure that the U.S.S. Shiloh (CG–67) is assigned a homeport in the United States by not later than ","children":[{"tag":"date","attrib":{"date":"2023-09-30"},"text":"September 30, 2023","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
