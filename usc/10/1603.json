{"tag":"section","attrib":{"id":"ida8ff251c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603"},"text":null,"children":[{"tag":"num","attrib":{"value":"1603"},"text":"§ 1603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional compensation, incentives, and allowances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8ff251d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Compensation Based on Title ","children":[],"tail":"5 "},{"tag":"inline","attrib":{},"text":"Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may provide employees in defense intelligence positions compensation (in addition to basic pay), including benefits, incentives, and allowances, consistent with, and not in excess of the level authorized for, comparable positions authorized by title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ff251e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allowances Based on Living Costs and Environment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ff251f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to basic pay, employees in defense intelligence positions who are citizens or nationals of the United States and are stationed outside the continental United States or in Alaska may be paid an allowance, in accordance with regulations prescribed by the Secretary of Defense, while they are so stationed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ff2520-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An allowance under this subsection shall be based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8ff2521-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" living costs substantially higher than in the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8ff2522-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conditions of environment which (i) differ substantially from conditions of environment in the continental United States, and (ii) warrant an allowance as a recruitment incentive; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8ff2523-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" both of the factors specified in subparagraphs (A) and (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ff2524-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An allowance under this subsection may not exceed the allowance authorized to be paid by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5941/a"},"text":"section 5941(a) of title 5","children":[],"tail":" for employees whose rates of basic pay are fixed by statute."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ff2525-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Allowances and Benefits for Certain Employees of the Defense Clandestine Service","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ff2526-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Beginning on the date on which the Secretary of Defense submits the report under paragraph (3)(A), in addition to the authority to provide compensation under subsection (a), the Secretary may provide a covered employee allowances and benefits under paragraph (1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s9904"},"text":"section 9904 of title 5","children":[],"tail":" without regard to the limitations in that section—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8ff2527-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the employee be assigned to activities outside the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8ff2528-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the activities to which the employee is assigned be in support of Department of Defense activities abroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ff2529-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not provide allowances and benefits under paragraph (1) to more than 125 covered employees per year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ff252a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8ff252b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall submit to the appropriate congressional committees a report containing a strategy addressing the mission of the Defense Clandestine Service during the period covered by the most recent future-years defense program submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s221"},"text":"section 221 of this title","children":[],"tail":", including—"}],"tail":null},{"tag":"clause","attrib":{"id":"ida8ff252c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how such mission will evolve during such period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8ff252d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the authority provided by paragraph (1) will assist the Secretary in carrying out such mission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8ff252e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an implementation plan for carrying out paragraph (1), including a projection of how much the amount of the allowances and benefits provided under such paragraph compare with the amount of the allowances and benefits provided before the date of the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8ff252f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":", and each year thereafter, the Secretary shall submit to the appropriate congressional committees a report, with respect to the fiscal year preceding the date on which the report is submitted—"}],"tail":null},{"tag":"clause","attrib":{"id":"ida8ff2530-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying the number of covered employees for whom the Secretary provided allowances and benefits under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8ff2531-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating the efficacy of such allowances and benefits in enabling the execution of the objectives of the Defense Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8ff2532-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The reports under subparagraphs (A) and (B) may be submitted in classified form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ff2533-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8ff2534-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8ff2535-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional defense committees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8ff2536-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Permanent Select Committee on Intelligence of the House of Representatives and the Select Committee on Intelligence of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8ff2537-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1603/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered employee” means an employee in a defense intelligence position who is assigned to the Defense Clandestine Service at a location in the United States that the Secretary determines has living costs equal to or higher than the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8ff2538-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVI/s1632/a/3"},"text":"Pub. L. 104–201, div. A, title XVI, § 1632(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2746"},"text":"110 Stat. 2746","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXI/s1108"},"text":"Pub. L. 116–92, div. A, title XI, § 1108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1597"},"text":"133 Stat. 1597","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8ff2539-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8ff253a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida8ff253b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1603, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/89/tVII/s701/a/1"},"text":"Pub. L. 97–89, title VII, § 701(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-04"},"text":"Dec. 4, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1160"},"text":"95 Stat. 1160","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXIII/s1302/a/3"},"text":"Pub. L. 99–145, title XIII, § 1302(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/738"},"text":"99 Stat. 738","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tXIII/s1343/a/9"},"text":"Pub. L. 99–661, div. A, title XIII, § 1343(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3992"},"text":"100 Stat. 3992","children":[],"tail":", related to limits on pay to members of the Defense Intelligence Senior Executive Service, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVI"},"text":"Pub. L. 104–201, div. A, title XVI","children":[],"tail":", §§ 1632(a)(3), 1635, "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2745"},"text":"110 Stat. 2745","children":[],"tail":", 2752, effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 1590(d) and 1604(b)(2), (d) of this title prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":", §§ 1632(a)(3), 1633(a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8ff253c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8ff253d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8ff253e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1635"},"text":"section 1635 of Pub. L. 104–201","children":[],"tail":", set out as an Effective Date of 1996 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1593"},"text":"section 1593 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
