{"tag":"section","attrib":{"id":"idaa1fafcd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3344"},"text":null,"children":[{"tag":"num","attrib":{"value":"3344"},"text":"§ 3344.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of identity of contractor","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense may disclose the identity or location of a person awarded a contract by the Department of Defense to any individual, including a Member of Congress, only after the Secretary makes a public announcement identifying the contractor. When the identity of a contractor is to be made public, the Secretary shall announce publicly that the contract has been awarded and the identity of the contractor.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idaa1fafce-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295/s1/26/A"},"text":"Pub. L. 97–295, § 1(26)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1291"},"text":"96 Stat. 1291","children":[],"tail":", § 2316; renumbered § 3344, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1818/b"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1818(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4188"},"text":"134 Stat. 4188","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/b/7"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2133"},"text":"135 Stat. 2133","children":[],