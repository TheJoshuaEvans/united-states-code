to retirement of Coast Guard personnel.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dD/tXLIV/s4403"},"text":"Pub. L. 102–484, div. D, title XLIV, § 4403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2702"},"text":"106 Stat. 2702","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tV/s561/a"},"text":"Pub. L. 103–160, div. A, title V, § 561(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1667"},"text":"107 Stat. 1667","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1504/c/3"},"text":"Pub. L. 104–106, div. A, title XV, § 1504(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/514"},"text":"110 Stat. 514","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tV/s561/a"},"text":"Pub. L. 105–261, div. A, title V, § 561(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2025"},"text":"112 Stat. 2025","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 571(a)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–134; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tV/s554"},"text":"Pub. L. 107–314, div. A, title V, § 554","children":[],"tail":", "},{"tag":"date","attrib":{"d