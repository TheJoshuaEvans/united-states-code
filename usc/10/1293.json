,"attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of this section is to provide the Secretary of Defense a temporary additional force management tool with which to effect the drawdown of military forces during the active force drawdown period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retirement for","children":[],"tail":" 15 "},{"tag":"inline","attrib":{},"text":"to","children":[],"tail":" 20 "},{"tag":"inline","attrib":{},"text":"Years of Service","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" During the active force drawdown period, the Secretary of the Army may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7311"},"text":"section 7311 of title 10","children":[],"tail":", United States Code, to a regular or reserve commissioned officer with at least 15 but less than 20 years of service by substituting ‘at least 15 years’ for ‘at least 20 years’ in subsection (a) of that section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply the provisions of section 7314 of such title to an enlisted member with at least 15 but less than 20 years of service by substituting ‘at least 15’ for ‘at least 20’; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply the provisions of section 1293 of such title to a warrant officer with at least 15 but less than 20 years of service by substituting ‘at least 15 years’ for ‘at least 20 years’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" During the active force drawdown period, the Secretary of the Navy may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8323"},"text":"section 8323 of title 10","children":[],"tail":", United States Code, to an officer with at least 15 but less than 20 years of service by substituting ‘at least 15 years’ for ‘at least 20 years’ in subsection (a) of that section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply the provisions of section 8330 of such title to an enlisted member of the Navy or Marine Corps with at least 15 but less than 20 years of service by substituting ‘15 or more years’ for ‘20 or more years’ in the first sentence of subsection (a)[(b)], in the case of an enlisted member of the Navy, and in the second sentence of subsection (b), in the case of an enlisted member of the Marine Corps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply the provisions of section 1293 of such title to a warrant officer with at least 15 but less than 20 years of service by substituting ‘at least 15 years’ for ‘at least 20 years’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" During the active force drawdown period, the Secretary of the Air Force may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9311"},"text":"section 9311 of title 10","children":[],"tail":", United States Code, to a regular or reserve commissioned officer with at least 15 but less than 20 years of service by substituting ‘at least 15 years’ for ‘at least 20 years’ in subsection (a) of that section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply the provisions of section 9314 of such title to an enlisted member with at least 15 but less than 20 years of service by substituting ‘at least 15’ for ‘at least 20’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of Certain Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the period specified in subsection (i)(2), this section does not apply as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To members of the Coast Guard, notwithstanding section 542(d) of the National Defense Authorization Act for Fiscal Year 1995 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Public Law 103–337","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1293"},"text":"10 U.S.C. 1293","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To members of the commissioned corps of the National Oceanic and Atmospheric Administration, notwithstanding section 566(c) of the National Defense Authorization Act for Fiscal Year 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Public Law 104–106","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1293"},"text":"10 U.S.C. 1293","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of each military department may prescribe regulations and policies regarding the criteria for eligibility for early retirement by reason of eligibility pursuant to this section and for the approval of applications for such retirement. Such criteria may include factors such as grade, years of service, and skill.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Computation of Retired Pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Retired or retainer pay of a member retired (or transferred to the Fleet Reserve or Fleet Marine Corps Reserve) under a provision of title 10, United States Code, by reason of eligibility pursuant to subsection (b) shall be reduced by ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"12","children":[],"tail":"th of 1 percent for each full month by which the number of months of active service of the member are less than 240 as of the date of the member’s retirement (or transfer to the Fleet Reserve or Fleet Marine Corps Reserve)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1463"},"text":"section 1463 of title 10","children":[],"tail":", United States Code, and subject to the availability of appropriations for this purpose, the Secretary of each military department shall provide in accordance with this section for the payment of retired pay payable during the fiscal years covered by the other provisions of this subsection to members of the Armed Forces under the jurisdiction of that Secretary who are being retired under the authority of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In each fiscal year in which the Secretary of a military department retires a member of the Armed Forces under the authority of this section, the Secretary shall credit to a subaccount (which the Secretary shall establish) within the appropriation account for that fiscal year for pay and allowances of active duty members of the Armed Forces under the jurisdiction of that Secretary such amount as is necessary to pay the retired pay payable to such member for the entire initial period (determined under paragraph (3)) of the entitlement of that member to receive retired pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The initial period applicable under paragraph (2) in the case of a retired member referred to in that paragraph is the number of years (and any fraction of a year) that is equal to the difference between 20 years and the number of years (and any fraction of a year) of service that were completed by the member (as computed under the provision of law used for determining the member’s years of service for eligibility to retirement) before being retired under the authority of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall pay the member’s retired pay for such initial period out of amounts credited to the subaccount under paragraph (2). The amounts so credited with respect to that member shall remain available for payment for that period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer of an enlisted member of the Navy or Marine Corps to the Fleet Reserve or Fleet Marine Corps Reserve shall be treated as a retirement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘retired pay’ shall be treated as including retainer pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination With Other Separation Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Armed Forces retired under the authority of this section is not entitled to benefits under section 1174 or 1175a of title 10, United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8b54a06-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"p","attrib":{},"text":" [Amended section 638a(b)(4)(C) [now 638a(b)(3)(C)] of this title.]","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"“(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members Receiving SSB, VSI, or VSP","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of a military department may retire (or transfer to the Fleet Reserve or Fleet Marine Corps Reserve) pursuant to the authority provided by this section a member of a reserve component who before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":"] was separated from active duty pursuant to an agreement entered into under section 1174a or 1175 of title 10, United States Code or who before "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":", was separated from active duty pursuant to an agreement entered into under section 1175a of such title. The retired or retainer pay of any such member so retired (or transferred) by reason of the authority provided in this section shall be reduced by the amount of any payment to such member before the date of such retirement under the provisions of such agreement."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Active Force Drawdown Period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the active force drawdown period is (1) the period beginning on the date of the enactment of this Act and ending on ","children":[{"tag":"date","attrib":{"date":"2002-09-01"},"text":"September 1, 2002","children":[],"tail":", and (2) the period beginning on "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2030-12-31"},"text":"December 31, 2030","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tV/s554"},"text":"Pub. L. 107–314, div. A, title V, § 554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2553"},"text":"116 Stat. 2553","children":[],"tail":", provided that the amendment made by that section to "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/s4403"},"text":"section 4403 of Pub. L. 102–484","children":[],"tail":", set out above, is effective "},{"tag":"date","attrib":{"date":"2002-01-01"},"text":"Jan. 1, 2002","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
