[{"tag":"ref","attrib":{"href":"/us/pl/112/213/tII/s219"},"text":"Pub. L. 112–213, title II, § 219","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1558"},"text":"126 Stat. 1558","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8213, "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4650"},"text":"134 Stat. 4650","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dG/tLVXXXII"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“For fiscal years 2019 through 2025—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" notwithstanding subsection (c)(1) of section 4403 of the National Defense Authorization Act for Fiscal Year 1993 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":"] ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1293"},"text":"10 U.S.C. 1293","children":[],"tail":" note), such section shall apply to the Coast Guard in the same manner and to the same extent it applies to the Department of Defense, except that—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Homeland Security shall implement such section with respect to the Coast Guard and, for purposes of that implementation, shall apply the applicable provisions of title 14, United States Code, relating to retirement of Coast Guard personnel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of commissioned officers who retire pursuant to this section may not exceed 200, and the total number of enlisted members who retire pursuant to this section may not exceed 300; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only appropriations available for necessary expenses for the operation and maintenance of the Coast Guard shall be expended for the retired pay of personnel who retire pursuant to this section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8b54a05-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Temporary Early Retirement Authority","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/b/tVIII/s8053"},"text":"Pub. L. 104–208, div. A, title I, § 101(b) [title VIII, § 8053]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-71"},"text":"110 Stat. 3009–71","children":[],"tail":", 3009–99, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/208/dA/tI/s101/b/tVIII/s8053"},"text":"“During the current fiscal year and hereafter, appropriations available for the pay and allowances of active duty members of the Armed Forces shall be available to pay the retired pay which is payable pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s4403"},"text":"section 4403 of Public Law 102–484","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1293"},"text":"10 U.S.C. 1293","children":[],"tail":" note) under the terms and conditions provided in section 4403.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/61/tVIII/s8066"},"text":"Pub. L. 104–61, title VIII, § 8066","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-01"},"text":"Dec. 1, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/664"},"text":"109 Stat. 664","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/335/tVIII/s8077"},"text":"Pub. L. 103–335, title VIII, § 8077","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-30"},"text":"Sept. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2636"},"text":"108 Stat. 2636","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/139/tVIII/s8095"},"text":"Pub. L. 103–139, title VIII, § 8095","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-11"},"text":"Nov. 11, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1461"},"text":"107 Stat. 1461","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s566/c"},"text":"Pub. L. 104–106, div. A, title V, § 566(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/328"},"text":"110 Stat. 328","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s272/b"},"text":"Pub. L. 107–372, tit