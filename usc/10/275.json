{"tag":"section","attrib":{"id":"ida794bee6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s275"},"text":null,"children":[{"tag":"num","attrib":{"value":"275"},"text":"§ 275.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on direct participation by military personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense shall prescribe such regulations as may be necessary to ensure that any activity (including the provision of any equipment or facility or the assignment or detail of any personnel) under this chapter does not include or permit direct participation by a member of the Army, Navy, Air Force, or Marine Corps in a search, seizure, arrest, or other similar activity unless participation in such activity by such member is otherwise authorized by law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida794bee7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/86/tIX"},"text":"Pub. L. 97–86, title IX","children":[],"tail":" § 905(a)(1), "},{"tag":"date","attrib":{"date":"1981-12-01"},"text":"Dec. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1116"},"text":"95 Stat. 1116","children":[],"tail":", § 375; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXI/s1104/a"},"text":"Pub. L. 100–456, div. A, title XI, § 1104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2045"},"text":"102 Stat. 2045","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXII/s1211"},"text":"Pub. L. 101–189, div. A, title XII, § 1211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1567"}