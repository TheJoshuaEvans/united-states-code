 for “other items of military equipment not designated as part of the United States Munitions List”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1317/h/1"},"text":"Pub. L. 103–337, § 1317(h)(1)","children":[],"tail":", inserted “(including airlift)” after “transportation”, “calibration services,” after “maintenance services,”, and “Such term includes temporary use of general purpose vehicles and other items of military equipment not designated as part of the United States Munitions List pursuant to section 38(a)(1) of the Arms Export Control Act.” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1317/h/2"},"text":"Pub. L. 103–337, § 1317(h)(2)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" substituted “this subchapter” for “this chapter” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/26"},"text":"Pub. L. 100–26","children":[],"tail":" inserted “The term” after each par. designation and struck out uppercase letter of first word after first quotation marks in pars. (1) and (3) and substituted lowercase letter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2331"},"text":"section 2331 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida96a69d2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida96a69d3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" applicable with regard to any acquisition or transfer of logistic support, supplies, and services under authority of this subchapter that is initiated after "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1317/j"},"text":"section 1317(j) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2341"},"text":"section 2341 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
