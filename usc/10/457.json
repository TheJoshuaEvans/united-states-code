{"tag":"section","attrib":{"id":"ida7bf9f89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s457"},"text":null,"children":[{"tag":"num","attrib":{"value":"457"},"text":"§ 457.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operational files previously maintained by or concerning activities of National Photographic Interpretation Center: authority to withhold from public disclosure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7bf9f8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s457/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may withhold from public disclosure operational files described in subsection (b) to the same extent that operational files may be withheld under section 701 of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3141"},"text":"50 U.S.C. 3141","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bf9f8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s457/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Operational Files","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authority under subsection (a) applies to operational files in the possession of the National Geospatial-Intelligence Agency that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bf9f8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s457/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as of ","children":[{"tag":"date","attrib":{"date":"1996-09-22"},"text":"September 22, 1996","children":[],"tail":", were maintained by the National Photographic Interpretation Center; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bf9f8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s457/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concern the activities of the Agency that, as of such date, were performed by the National Photographic Interpretation Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bf9f8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s457/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operational Files Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “operational files” has the meaning given that term in section 701(b) of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3141/b"},"text":"50 U.S.C. 3141(b)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7bf9f8f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1045/a"},"text":"Pub. L. 106–65, div. A, title X, § 1045(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/762"},"text":"113 Stat. 762","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tIX/s921/d/2/A"},"text":"Pub. L. 108–136, div. A, title IX, § 921(d)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1568"},"text":"117 Stat. 1568","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1071/c/8"},"text":"Pub. L. 113–291, div. A, title X, § 1071(c)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3509"},"text":"128 Stat. 3509","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7bf9f90-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7bf9f91-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7bf9f92-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1071/c/8/A"},"text":"Pub. L. 113–291, § 1071(c)(8)(A)","children":[],"tail":", substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3141"},"text":"50 U.S.C. 3141","children":[],"tail":")” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s431"},"text":"50 U.S.C. 431","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1071/c/8/B"},"text":"Pub. L. 113–291, § 1071(c)(8)(B)","children":[],"tail":", substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3141/b"},"text":"50 U.S.C. 3141(b)","children":[],"tail":")” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s431/b"},"text":"50 U.S.C. 431(b)","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" substituted “National Geospatial-Intelligence Agency” for “National Imagery and Mapping Agency” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
