{"tag":"section","attrib":{"id":"ida91bd45c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2003"},"text":null,"children":[{"tag":"num","attrib":{"value":"2003"},"text":"§ 2003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aeronautical rating as pilot: qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To be eligible to receive an aeronautical rating as a pilot in the Army or Air Force or be designated as a naval aviator, a member of an armed force must successfully complete an undergraduate pilot course of instruction prescribed or approved by the Secretary of his military department.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida91bd45d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/168/s4/1"},"text":"Pub. L. 92–168, § 4(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-11-24"},"text":"Nov. 24, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/489"},"text":"85 Stat. 489","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
