{"tag":"section","attrib":{"id":"ida9e677ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2856b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2856b"},"text":"§ 2856b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered military unaccompanied housing: standards for habitability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9e677cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2856b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of assigning a member of the armed forces to a unit of covered military unaccompanied housing, the Secretary of Defense shall establish uniform minimum standards for covered military unaccompanied housing, that shall include minimum requirements for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9e677cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2856b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" condition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e677cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2856b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" habitability, health, and environmental comfort;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e677ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2856b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safety and security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e677cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2856b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other element the Secretary of Defense determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e677d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2856b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Issuance of Waivers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any waiver of a uniform standard described in subsection (a) may only be issued by a Secretary of a military department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e677d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2856b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall include, in conjunction with the submission of the budget of the President to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", a certification from each Secretary of a military department to the congressional defense committees that the cost for all needed repairs and improvements for each occupied covered military unaccompanied housing facility under the jurisdiction of such Secretary does not exceed 20 percent of the replacement cost of such facility, as mandated by Department of Defense Manual 4165.63 titled “DoD Housing Management” and dated "},{"tag":"date","attrib":{"date":"2010-10-28"},"text":"October 28, 2010","children":[],"tail":" (or a successor document)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9e677d2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dB/tXXVIII"},"text":"Pub. L. 118–31, div. B, title XXVIII","children":[],"tail":", §§ 2832(a), 2834, "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/754"},"text":"137 Stat. 754","children":[],"tail":", 757.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9e677d3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9e677d4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida9e677d5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dB/tXXVIII/s2832/a"},"text":"Pub. L. 118–31, div. B, title XXVIII, § 2832(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/754"},"text":"137 Stat. 754","children":[],"tail":", which directed amendment of “Subchapter III of title 10” by adding this section after "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2856a"},"text":"section 2856a of this title","children":[],"tail":", was executed to subchapter III of chapter 169 of this title, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9e677d6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s2834"},"text":"Pub. L. 118–31, § 2834","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9e677d7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9e677d8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Guidance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dB/tXXVIII/s2832/b"},"text":"Pub. L. 118–31, div. B, title XXVIII, § 2832(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/754"},"text":"137 Stat. 754","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dB/tXXVIII/s2832/b"},"text":"“Not later than 30 days after the date on which the Secretary of Defense develops the uniform standards under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2856b"},"text":"section 2856b of title 10","children":[],"tail":", United States Code (as added by subsection (a)), the Secretary of Defense shall issue to each Secretary of a military department guidance on such uniform standards.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"ida9e677d9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “covered military unaccompanied housing” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2856/c"},"text":"section 2856(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
