{"tag":"section","attrib":{"id":"ida7f68dad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649g"},"text":null,"children":[{"tag":"num","attrib":{"value":"649g"},"text":"§ 649g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement: retirement for years of service; selective early retirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7f68dae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retirement for Years of Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sections 633 through 636 of this title shall apply to the retirement of officers in competitive categories of officers designated for purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f68daf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selective Early Retirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sections 638 and 638a of this title shall apply to the retirement of officers described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7f68db0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tV/s507/a/1"},"text":"Pub. L. 115–232, div. A, title V, § 507(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1747"},"text":"132 Stat. 1747","children":[],"tail":".)"}],"tail":"\n"}],"tail":null