{"tag":"section","attrib":{"id":"ida8fcda49-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1599d"},"text":"§ 1599d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial management positions: authority to prescribe professional certification and credential standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8fcda4a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Prescribe Professional Certification and Credential Standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may prescribe professional certification and credential standards for financial management positions within the Department of Defense, including requirements for formal education and requirements for certifications that individuals have met predetermined qualifications set by an agency of Government or by an industry or professional group. Any such professional certification or credential standard shall be prescribed as a Department regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcda4b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may waive any standard prescribed under subsection (a) whenever the Secretary determines such a waiver to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcda4c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fcda4d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2), the Secretary may, in the Secretary’s discretion—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8fcda4e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599d/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that a standard prescribed under subsection (a) apply immediately to all personnel holding financial management positions designated by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fcda4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599d/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delay the imposition of such a standard for a reasonable period to permit persons holding financial management positions so designated time to comply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fcda50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A formal education requirement prescribed under subsection (a) shall not apply to any person employed by the Department in a financial management position before the standard is prescribed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcda51-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discharge of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe any professional certification or credential standards under subsection (a) through the Under Secretary of Defense (Comptroller), in consultation with the Under Secretary of Defense for Personnel and Readiness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcda52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after the effective date of any regulations prescribed under subsection (a), or any significant modification of such regulations, the Secretary shall, in conjunction with the Director of the Office of Personnel Management, submit to Congress a report setting forth the plans of the Secretary to provide training to appropriate Department personnel to meet any new professional certification or credential standard under such regulations or modification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcda53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Financial Management Position Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “financial management position” means a position or group of positions (including civilian and military positions), as designated by the Secretary for purposes of this section, that perform, supervise, or manage work of a fiscal, financial management, accounting, auditing, cost, or budgetary nature, or that require the performance of financial management-related work.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8fcda54-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tXI/s1104/a/1"},"text":"Pub. L. 107–314, div. A, title XI, § 1104(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2661"},"text":"116 Stat. 2661","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title XI, § 1110, "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4619"},"text":"122 Stat. 4619","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tX/s1051/a"},"text":"Pub. L. 112–81, div. A, title X, § 1051(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1581"},"text":"125 Stat. 1581","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8fcda55-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8fcda56-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8fcda57-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" amended section generally. Prior to amendment, section related to the authority to prescribe certification and credential standards for professional accounting positions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" substituted “0505, 0510, 0511, or equivalent” for “GS–510, GS–511, and GS–505”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8fcda58-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8fcda59-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tXI/s1104/b"},"text":"Pub. L. 107–314, div. A, title XI, § 1104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2661"},"text":"116 Stat. 2661","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/314/dA/tXI/s1104/b"},"text":"“Standards established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1599d"},"text":"section 1599d of title 10","children":[],"tail":", United States Code, as added by subsection (a), may take effect no sooner than 120 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
