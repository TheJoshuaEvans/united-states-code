text":"Pub. L. 96–513, title V, § 511(76)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2926"},"text":"94 Stat. 2926","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s1/24/B"},"text":"Pub. L. 97–295, § 1(24)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1291"},"text":"96 Stat. 1291","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dB/tVII"},"text":"Pub. L. 98–369, div. B, title VII","children":[],"tail":", §§ 2723(a)(1)(B), 2727(b), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1187"},"text":"98 Stat. 1187","children":[],"tail":", 1194; "},{"tag":"ref","attrib":{"href":"/us/pl/98/577/tV/s504/b/2"},"text":"Pub. L. 98–577, title V, § 504(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3086"},"text":"98 Stat. 3086","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dD/tXLIII/s4321/b/5"},"text":"Pub. L. 104–106, div. D, title XLIII, § 4321(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/672"},"text":"110 Stat. 672","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/b/3"},"text":"Pub. L. 107–217, § 3(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1295"},"text":"116 Stat. 1295","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/b/12/E"},"text":"Pub. L. 111