{"tag":"section","attrib":{"id":"ida87c116d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1076c"},"text":"§ 1076c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dental insurance plan: certain retirees and their surviving spouses and other dependents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida87c116e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for Plan","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida87c116f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall establish a dental insurance plan for retirees of the uniformed services, certain unremarried surviving spouses, and dependents in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida87c1170-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may satisfy the requirement under paragraph (1) by entering into an agreement with the Director of the Office of Personnel Management to allow persons described in subsection (b) to enroll in an insurance plan under chapter 89A of title 5 that provides benefits similar to those benefits required to be provided under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida87c1171-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Persons Eligible for Plan","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following persons are eligible to enroll in the dental insurance plan established under subsection (a):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida87c1172-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the uniformed services who are entitled to retired pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida87c1173-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Retired Reserve who would be entitled to retired pay under chapter 1223 of this title but for being under 60 years of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida87c1174-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Eligible dependents of a member described in paragraph (1) or (2) who are covered by the enrollment of the member in the plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida87c1175-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Eligible dependents of a member described in paragraph (1) or (2) who is not enrolled in the plan and who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida87c1176-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is enrolled under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1705"},"text":"section 1705 of title 38","children":[],"tail":" to receive dental care from the Secretary of Veterans Affairs;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida87c1177-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is enrolled in a dental plan that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida87c1178-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is available to the member as a result of employment by the member that is separate from the military service of the member; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida87c1179-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not available to dependents of the member as a result of such separate employment by the member; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida87c117a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is prevented by a medical or dental condition from being able to obtain benefits under the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida87c117b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The unremarried surviving spouse and eligible child dependents of a deceased member—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida87c117c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who died while in a status described in paragraph (1) or (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida87c117d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1448/d/1"},"text":"section 1448(d)(1) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida87c117e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who died while on active duty for a period of more than 30 days and whose eligible dependents are not eligible, or no longer eligible, for dental benefits under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1076a"},"text":"section 1076a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida87c117f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Premiums","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida87c1180-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member enrolled in the dental insurance plan established under subsection (a) shall pay the premiums charged for the insurance coverage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida87c1181-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall establish procedures for the collection of the premiums charged for coverage by the dental insurance plan. To the maximum extent practicable, the premiums payable by a member entitled to retired pay shall be deducted and withheld from the retired pay of the member (if pay is available to the member).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida87c1182-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Benefits Available Under the Plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The dental insurance plan established under subsection (a) shall provide benefits for dental care and treatment which may be comparable to the benefits authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1076a"},"text":"section 1076a of this title","children":[],"tail":" for plans established under that section and shall include diagnostic services, preventative services, endodontics and other basic restorative services, surgical services, and emergency services."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida87c1183-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coverage","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida87c1184-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe a minimum required period for enrollment by a member or surviving spouse in the dental insurance plan established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida87c1185-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The dental insurance plan shall provide for voluntary enrollment of participants and shall authorize a member or eligible unremarried surviving spouse to enroll for self only or for self and eligible dependents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida87c1186-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Terminations of Enrollment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall terminate the enrollment of any enrollee, and any eligible dependents of the enrollee covered by the enrollment, in the dental insurance plan established under subsection (a) upon the occurrence of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida87c1187-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an enrollment under subsection (b)(1), termination of the member’s entitlement to retired pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida87c1188-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an enrollment under subsection (b)(2), termination of the member’s status as a member of the Retired Reserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida87c1189-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an enrollment under subsection (b)(5), remarriage of the surviving spouse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida87c118a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuation of Dependents’ Enrollment Upon Death of Enrollee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Coverage of a dependent in the dental insurance plan established under subsection (a) under an enrollment of a member or a surviving spouse who dies during the period of enrollment shall continue until the end of that period and may be renewed by (or for) the dependent, so long as the premium paid is sufficient to cover continuation of the dependent’s enrollment. The Secretary may terminate coverage of the dependent when the premiums paid are no longer sufficient to cover continuation of the enrollment. The Secretary shall prescribe in regulations under subsection (h) the parties responsible for paying the remaining premiums due on the enrollment and the manner for collection of the premiums.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida87c118b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The dental insurance plan established under subsection (a) shall be administered under regulations prescribed by the Secretary of Defense, in consultation with the other administering Secretaries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida87c118c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voluntary Disenrollment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida87c118d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to enrollment in the dental insurance plan established under subsection (a), the Secretary of Defense—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida87c118e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall allow for a period of up to 30 days at the beginning of the prescribed minimum enrollment period during which an enrollee may disenroll; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida87c118f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide for limited circumstances under which disenrollment shall be permitted during the prescribed enrollment period, without jeopardizing the fiscal integrity of the dental program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida87c1190-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The circumstances described in paragraph (1)(B) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida87c1191-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a case in which a retired member, surviving spouse, or dependent of a retired member who is also a Federal employee is assigned to a location outside the jurisdiction of the dental insurance plan established under subsection (a) that prevents utilization of dental benefits under the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida87c1192-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a case in which a retired member, surviving spouse, or dependent of a retired member is prevented by a serious medical condition from being able to obtain benefits under the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida87c1193-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/i/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a case in which severe financial hardship would result; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida87c1194-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/i/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other circumstances which the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida87c1195-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish procedures for timely decisions on requests for disenrollment under this section and for appeal to the TRICARE Management Activity of adverse decisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida87c1196-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida87c1197-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “eligible dependent” means a dependent described in subparagraph (A), (D), or (I) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072/2"},"text":"section 1072(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida87c1198-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “eligible child dependent” means a dependent described in subparagraph (D) or (I) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072/2"},"text":"section 1072(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida87c1199-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1076c/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “retired pay” includes retainer pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida87c119a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tVII/s703/a/1"},"text":"Pub. L. 104–201, div. A, title VII, § 703(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2588"},"text":"110 Stat. 2588","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVII"},"text":"Pub. L. 105–85, div. A, title VII","children":[],"tail":", §§ 701, 733(b), 734, "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1807"},"text":"111 Stat. 1807","children":[],"tail":", 1812, 1813; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tVII/s702"},"text":"Pub. L. 105–261, div. A, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2056"},"text":"112 Stat. 2056","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVII/s704"},"text":"Pub. L. 106–65, div. A, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/683"},"text":"113 Stat. 683","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VII, § 726, title X, § 1087(a)(6)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–187, 1654A–290; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVII/s715/b/3"},"text":"Pub. L. 114–328, div. A, title VII, § 715(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2222"},"text":"130 Stat. 2222","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida87c119b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida87c119c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida87c119d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, text read as follows: “The Secretary of Defense, in consultation with the other administering Secretaries, shall establish a dental insurance plan for retirees of the uniformed services, certain unremarried surviving spouses, and dependents in accordance with this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(5)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1087(a)(6)], struck out “pursuant to subsection (i)(2) of such section” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1076a"},"text":"section 1076a of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VII, § 726(b)], substituted “Required Terminations” for “Termination” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (i), (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VII, § 726(a)], added subsec. (i) and redesignated former subsec. (i) as (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" amended heading and text of subsec. (d) generally. Text read as follows: “The dental insurance plan established under subsection (a) shall provide benefits for basic dental care and treatment, including diagnostic services, preventative services, basic restorative services (including endodontics), surgical services, and emergency services.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/s702/a"},"text":"Pub. L. 105–261, § 702(a)","children":[],"tail":", added par. (4) and redesignated former par. (4) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/s702/b"},"text":"Pub. L. 105–261, § 702(b)","children":[],"tail":", substituted “(b)(5)” for “(b)(4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s734/a/1"},"text":"Pub. L. 105–85, § 734(a)(1)","children":[],"tail":", (b)(1), substituted “The Secretary of Defense, in consultation with the other administering Secretaries, shall establish a dental insurance plan for retirees of the uniformed services” for “The Secretary of Defense shall establish a dental insurance plan for military retirees”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s734/a/2"},"text":"Pub. L. 105–85, § 734(a)(2)","children":[],"tail":", substituted “uniformed services” for “Armed Forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s701/1/A"},"text":"Pub. L. 105–85, § 701(1)(A)","children":[],"tail":", substituted “died” for “dies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s701/1/B"},"text":"Pub. L. 105–85, § 701(1)(B)","children":[],"tail":", (2), (3), added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s733/b"},"text":"Pub. L. 105–85, § 733(b)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “The amount of the premiums payable by a member entitled to retired pay shall be deducted and withheld from the retired pay and shall be disbursed to pay the premiums. The regulations prescribed under subsection (h) shall specify the procedures for payment of the premiums by other enrolled members and by enrolled surviving spouses.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s734/b/2"},"text":"Pub. L. 105–85, § 734(b)(2)","children":[],"tail":", substituted “other administering Secretaries” for “Secretary of Transportation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida87c119e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida87c119f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" applicable with respect to the first contract year for chapter 89A or 89B of Title 5, Government Organization and Employees, as applicable, that begins on or after "},{"tag":"date","attrib":{"date":"2018-01-01"},"text":"Jan. 1, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s715/c"},"text":"section 715(c) of Pub. L. 114–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8951"},"text":"section 8951 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida87c11a0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limitation on Implementation of Alternative Collection Procedures","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVII/s733/d"},"text":"Pub. L. 105–85, div. A, title VII, § 733(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1813"},"text":"111 Stat. 1813","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/85/dA/tVII/s733/d"},"text":"“The Secretary of Defense may not implement procedures for collecting premiums under [former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1076b/b/3"},"text":"section 1076b(b)(3) of title 10","children":[],"tail":", United States Code, or section 1076c(c)(2) of such title other than by deductions and withholding from pay until 120 days after the date that the Secretary submits a report to Congress describing the justifications for implementing such alternative procedures.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida87c11a1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation of Dental Plan","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tVII/s703/b"},"text":"Pub. L. 104–201, div. A, title VII, § 703(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2590"},"text":"110 Stat. 2590","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVII/s733/e"},"text":"Pub. L. 105–85, div. A, title VII, § 733(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1813"},"text":"111 Stat. 1813","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/85/dA/tVII/s733/e"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Beginning not later than ","children":[{"tag":"date","attrib":{"date":"1998-04-01"},"text":"April 1, 1998","children":[],"tail":", the Secretary of Defense shall—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer members of the Armed Forces and other persons described in subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1076c"},"text":"section 1076c of title 10","children":[],"tail":", United States Code (as added by subsection (a)(1) of this section), the opportunity to enroll in the dental insurance plan required under that section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" begin to provide benefits under the plan.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
