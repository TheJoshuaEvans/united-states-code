{"tag":"section","attrib":{"id":"ida9930094-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631"},"text":null,"children":[{"tag":"num","attrib":{"value":"2631"},"text":"§ 2631.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference for United States vessels in transporting supplies by sea","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9930095-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Supplies bought for the Army, Navy, Air Force, Marine Corps, or Space Force, or for a Defense Agency, or otherwise transported by the Department of Defense, may only be transported by sea in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9930096-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel belonging to the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9930097-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel of the United States (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s116"},"text":"section 116 of title 46","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9930098-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver and Notification","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9930099-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense may waive the requirement under subsection (a) if such a vessel is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida993009a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not available at a fair and reasonable rate for commercial vessels of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida993009b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise not available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida993009c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least once each fiscal year, the Secretary of Defense shall submit, in writing, to the appropriate congressional committees a notice of any waiver granted under this subsection and the reasons for such waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida993009d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for Reflagging or Repair Work","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida993009e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In each request for proposals to enter into a time-charter contract for the use of a vessel for the transportation of supplies under this section, the Secretary of Defense shall require that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida993009f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reflagging or repair work on a vessel for which a proposal is submitted in response to the request for proposals be performed in the United States (including any territory of the United States); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida99300a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any corrective and preventive maintenance or repair work on a vessel under contract pursuant to this section relevant to the purpose of such contract be performed in the United States (including any territory of the United States) for the duration of the contract, to the greatest extent practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida99300a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may waive a requirement under paragraph (1) if the Secretary determines that such waiver is critical to the national security of the United States. The Secretary shall immediately submit, in writing, to the appropriate congressional committees a notice of any waiver granted under this paragraph and the reasons for such waiver.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida99300a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida99300a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “reflagging or repair work” means work performed on a vessel—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida99300a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enable the vessel to meet applicable standards to become a vessel of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida99300a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to convert the vessel to a more useful military configuration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida99300a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “corrective and preventive maintenance or repair” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida99300a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintenance or repair actions performed as a result of a failure in order to return or restore equipment to acceptable performance levels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida99300a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scheduled maintenance or repair actions to prevent or discover functional failures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida99300a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall ensure that contracting officers of the Department of Defense award contracts under this section to responsible offerors and monitor and ensure compliance with the requirements of this section. The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida99300aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that timely, accurate, and complete information on contractor performance under this section is included in any contractor past performance database used by an executive agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida99300ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" exercise appropriate contractual rights and remedies against contractors who fail to comply with this section, or subchapter I of chapter 553 of title 46, as determined by the Secretary of Transportation under such subchapter, including by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida99300ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining that a contractor is ineligible for an award of such a contract; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida99300ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminating such a contract or suspension or debarment of the contractor for such contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida99300ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate Congressional Committees Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida99300af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on Armed Services of the Senate and the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida99300b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Transportation and Infrastructure of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida99300b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2631/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida99300b2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/146"},"text":"70A Stat. 146","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tIII/s315/a"},"text":"Pub. L. 103–160, div. A, title III, § 315(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1619"},"text":"107 Stat. 1619","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tX/s1033"},"text":"Pub. L. 116–92, div. A, title X, § 1033","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1580"},"text":"133 Stat. 1580","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/3/GG"},"text":"Pub. L. 116–283, div. A, title IX, § 924(b)(3)(GG)","children":[],"tail":", title X, § 1024(a)(1), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3822"},"text":"134 Stat. 3822","children":[],"tail":", 3841.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida99300b3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida99300b4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida99300b5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2631","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1365.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"34:528.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1904-04-28/ch1766"},"text":"Apr. 28, 1904, ch. 1766","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/33/518"},"text":"33 Stat. 518","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “supplies” is substituted for the words “coal, provisions, fodder, or supplies of any description”, in 10:1365 and 34:528. The words “pursuant to law” and “the use of”, in 10:1365 and 34:528, are omitted as surplusage. The words “as otherwise provided by law”, in 10:1365 and 34:528, are used rather than the words “under the law as it now exists”, in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1904-04-28/ch1766/s1"},"text":"section 1 of the Act of April 28, 1904, ch. 1766","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/33/518"},"text":"33 Stat. 518","children":[],"tail":". The word “may” is substituted for the word “shall”. The words “However, if” are substituted for the words “unless * * * in which case”. The words “private persons” are substituted for the words “private parties or companies”, in 10:1365 and 34:528. The last sentence is substituted for the proviso of 10:1365 and 34:528."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida99300b6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida99300b7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1024/a/1"},"text":"Pub. L. 116–283, § 1024(a)(1)","children":[],"tail":", amended section generally. Prior to amendment, section related to preference to United States vessels for transportation by sea of supplies."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s924/b/3/GG"},"text":"Pub. L. 116–283, § 924(b)(3)(GG)","children":[],"tail":", which directed amendment of subsec. (a) by substituting “Marine Corps, or Space Force” for “or Marine Corps”, was executed by making the substitution in subsec. (a) as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1024/a/1"},"text":"section 1024(a)(1) of Pub. L. 116–283","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1033/1"},"text":"Pub. L. 116–92, § 1033(1)","children":[],"tail":", inserted “or for a Defense Agency” after “Marine Corps” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1033/2"},"text":"Pub. L. 116–92, § 1033(2)","children":[],"tail":", added par. (2), redesignated former pars. (2) and (3) as (3) and (4), respectively, and in par. (4), substituted “a requirement under paragraph (1) or (2)” for “the requirement described in paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida99300b8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida99300b9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tIII/s315/b"},"text":"Pub. L. 103–160, div. A, title III, § 315(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1619"},"text":"107 Stat. 1619","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/160/dA/tIII/s315/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to a vessel for which reflagging or repair work is necessary to be performed after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida99300ba-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Obtaining Carriage by Vessel: Criterion Regarding Overhaul, Repair, and Maintenance of Vessels in the United States","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tX/s1017"},"text":"Pub. L. 109–364, div. A, title X, § 1017","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2379"},"text":"120 Stat. 2379","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tX/s1063/c/9"},"text":"Pub. L. 110–181, div. A, title X, § 1063(c)(9)","children":[],"tail":", div. C, title XXXV, § 3526(a), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/323"},"text":"122 Stat. 323","children":[],"tail":", 601, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/181/dA/tX/s1063/c/9"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition Policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In order to maintain the national defense industrial base, the Secretary of Defense shall issue an acquisition policy that establishes, as a criterion required to be considered in obtaining carriage by vessel of cargo for the Department of Defense, the extent to which an offeror of such carriage had overhaul, repair, and maintenance work for covered vessels of the offeror performed in shipyards located in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel is a covered vessel of an offeror under this section if the vessel is—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned, operated, or controlled by the offeror; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualified to engage in the carriage of cargo in the coastwise or non-contiguous trade under sections 12112 and 50501 and chapter 551 of title 46, United States Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of Policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The acquisition policy shall include rules providing for application of the policy to covered vessels as expeditiously as is practicable based on the nature of carriage obtained, and by no later than ","children":[{"tag":"date","attrib":{"date":"2007-06-01"},"text":"June 1, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe regulations as necessary to carry out the acquisition policy and submit such regulations to the Committees on Armed Services of the Senate and the House of Representatives, by not later than ","children":[{"tag":"date","attrib":{"date":"2007-06-01"},"text":"June 1, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interim regulations.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may prescribe interim regulations as necessary to carry out the acquisition policy. For this purpose, the Secretary is excepted from compliance with the notice and comment requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon the issuance of interim regulations under this paragraph, the Secretary shall submit to the Committees on Armed Services of the Senate and the House of Representatives the interim regulations and a description of the acquisition policy developed (or being developed) under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expiration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All interim regulations prescribed under the authority of this paragraph that are not earlier superseded by final regulations shall expire no later than ","children":[{"tag":"date","attrib":{"date":"2007-06-01"},"text":"June 1, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, acting through the United States Transportation Command, shall annually submit to the Committees on Armed Services of the Senate and the House of Representatives a report regarding overhaul, repair, and maintenance performed on covered vessels of each offeror of carriage to which the acquisition policy applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign shipyard","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘foreign shipyard’ means a shipyard that is not located in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"United states","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘United States’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Guam.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3526/a"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3526(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/601"},"text":"122 Stat. 601","children":[],"tail":", which directed amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/s1017/b/2"},"text":"section 1017(b)(2) of Pub. L. 109–364","children":[],"tail":", set out above, by substituting “sections 12112, 50501, and 55102 of title 46, United States Code” for “section 27 of the Merchant Marine Act, 1920 ("},{"tag":"ref","attrib":{"href":"/us/usc/t46/s883"},"text":"46 U.S.C. 883","children":[],"tail":"), "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s12106"},"text":"section 12106 of title 46","children":[],"tail":", United States Code, and section 2 of the Shipping Act, 1916 (46 U.S.C. App. 802)”, could not be executed because those words did not appear subsequent to amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1063/c/9"},"text":"section 1063(c)(9) of Pub. L. 110–181","children":[],"tail":", which was effective as of "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" as enacted. See Effective Date of 2008 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s624"},"text":"section 624 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"ida99300bb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida99300bc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Authority Under the Cargo Preference Act","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of the President of the United States, ","children":[{"tag":"date","attrib":{"date":"1985-08-07"},"text":"Aug. 7, 1985","children":[],"tail":", 50 F.R. 36565, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Honorable Caspar W. Weinberger, the Secretary of Defense","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By virtue of the authority vested in me as President by the Constitution and statutes of the United States of America, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"Section 301 of Title 3","children":[],"tail":" of the United States Code, I hereby delegate to the Secretary of Defense all the functions vested in me by the Cargo preference Act of 1904, "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2631"},"text":"10 U.S.C. 2631","children":[],"tail":". This authority may be redelegated."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This memorandum shall be published in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Ronald Reagan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
