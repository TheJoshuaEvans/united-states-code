{"tag":"section","attrib":{"id":"idaadc21dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7102"},"text":null,"children":[{"tag":"num","attrib":{"value":"7102"},"text":"§ 7102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notification of significant Army force structure changes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaadc21de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (c), the Secretary of the Army shall submit to the congressional defense committees written notification of any decision to make a significant change to Army force structure prior to implementing or announcing such change.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaadc21df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A notification required under subsection (a) shall include each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaadc21e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The justification for the planned change.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaadc21e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the details of the planned change and timing for implementation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaadc21e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7102/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the operational implications of the planned change.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaadc21e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7102/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The estimated costs of such change.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaadc21e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The notification requirement under subsection (a) shall not apply if the Secretary of Defense certifies to the congressional defense committees in advance that the planned Army force structure change must be implemented immediately for reasons of military urgency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaadc21e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Significant Change to Army Force Structure","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “significant change to Army force structure” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaadc21e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7102/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a change in the number, type, or component of brigade-level organizations or higher-echelon headquarters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaadc21e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7102/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a change in the number or component of theater-level capabilities, such as a multi-domain task force, Terminal High Altitude Area Defense, long range fires unit, or headquarters; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaadc21e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7102/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a permanent or temporary activation or inactivation of an experimental unit or brigade-size or higher task force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaadc21e9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tX/s1044/a/1"},"text":"Pub. L. 117–81, div. A, title X, § 1044(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1904"},"text":"135 Stat. 1904","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaadc21ea-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaadc21eb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaadc21ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 7102 to 7104 were renumbered sections 8592 to 8594 of this title, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
