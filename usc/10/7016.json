hildren":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s911/a"},"text":"Pub. L. 116–92, § 911(a)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3016"},"text":"section 3016 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s921/a"},"text":"Pub. L. 115–91, § 921(a)","children":[],"tail":", designated first sentence as subpar. (A), designated second and third sentences as subpar. (C) and, in subpar. (C), substituted “The principal responsibility of the Assistant Secretary shall be” for “The Assistant Secretary shall have as his principal responsibility”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s505"},"text":"Pub. L. 115–91, § 505","children":[],"tail":", substituted “an officer” for “a lieutenant general”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" inserted at end “In the event of a vacancy in the position of Assistant Secretary of the Army for Acquisition, Logistics, and Technology, the Principal Military Deputy may serve as Acting Assistant Secretary for a period of not more than one year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaad4f5a0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaad4f5a1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaad4f5a2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tIX/s921/d"},"text":"Pub. L. 115–91, div. A, title IX, § 921(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1524"},"text":"131 Stat. 1524","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/91/dA/tIX/s921/d"},"text":"“The appointment qualifications imposed by the amendments made by this section [amending this section and sections 5016 and 8016 of this title] shall apply with respect to an appointment as an Assistant Secretary of a military department for financial management that is made on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaad4f5a3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tVII/s702/e/1"},"text":"Pub. L. 100–456, div. A, title VII, § 702(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1996"},"text":"102 Stat. 1996","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/456/dA/tVII/s702/e/1"},"text":"“The amendments made by subsections (a) and (b) [enacting sections 3022 and 5025 of this title and amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s5016"},"text":"section 5016 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"1989-01-20"},"text":"January 20, 1989","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
