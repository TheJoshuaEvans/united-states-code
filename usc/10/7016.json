{"tag":"section","attrib":{"id":"idaad4f58b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7016"},"text":null,"children":[{"tag":"num","attrib":{"value":"7016"},"text":"§ 7016.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Secretaries of the Army","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaad4f58c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7016/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are five Assistant Secretaries of the Army. They shall be appointed from civilian life by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad4f58d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7016/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad4f58e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7016/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretaries shall perform such duties and exercise such powers as the Secretary of the Army may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f58f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7016/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One of the Assistant Secretaries shall be the Assistant Secretary of the Army for Manpower and Reserve Affairs. He shall have as his principal duty the overall supervision of manpower and reserve component affairs of the Department of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f590-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7016/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One of the Assistant Secretaries shall be the Assistant Secretary of the Army for Civil Works. He shall have as his principal duty the overall supervision of the functions of the Department of the Army relating to programs for conservation and development of the national water resources, including flood control, navigation, shore protection, and related purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f591-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7016/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaad4f592-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7016/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One of the Assistant Secretaries shall be the Assistant Secretary of the Army for Financial Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad4f593-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7016/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary shall be appointed from among persons who have significant budget, financial management, or audit experience in complex organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad4f594-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7016/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The principal responsibility of the Assistant Secretary shall be the exercise of the comptroller functions of the Department of the Army, including financial management functions. The Assistant Secretary shall be responsible for all financial management activities and operations of the Department of the Army and shall advise the Secretary of the Army on financial management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f595-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7016/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaad4f596-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7016/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One of the Assistant Secretaries shall be the Assistant Secretary of the Army for Acquisition, Logistics, and Technology. The principal duty of the Assistant Secretary shall be the overall supervision of acquisition, technology, and logistics matters of the Department of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad4f597-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7016/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary shall have a Principal Military Deputy, who shall be an officer of the Army on active duty. The Principal Military Deputy shall be appointed from among officers who have significant experience in the areas of acquisition and program management. The position of Principal Military Deputy shall be designated as a critical acquisition position under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1731"},"text":"section 1731 of this title","children":[],"tail":". In the event of a vacancy in the position of Assistant Secretary of the Army for Acquisition, Logistics, and Technology, the Principal Military Deputy may serve as Acting Assistant Secretary for a period of not more than one year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f598-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7016/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaad4f599-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7016/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One of the Assistant Secretaries shall be the Assistant Secretary for Energy, Installations, and Environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad4f59a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7016/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The principal duty of the Assistant Secretary for Energy, Installations, and Environment shall be the overall supervision of energy, installation, and environment matters for the Department of the Army.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad4f59b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s501/a/5"},"text":"Pub. L. 99–433, title V, § 501(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1038"},"text":"100 Stat. 1038","children":[],"tail":", § 3016; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tVII/s702/a/1"},"text":"Pub. L. 100–456, div. A, title VII, § 702(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","childr