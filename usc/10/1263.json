{"tag":"section","attrib":{"id":"ida8b549e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1263"},"text":null,"children":[{"tag":"num","attrib":{"value":"1263"},"text":"§ 1263.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Age 62: warrant officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8b549e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1263/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Unless retired under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1305"},"text":"section 1305 of this title","children":[],"tail":", a permanent regular warrant officer who has at least 20 years of active service that could be credited to him under section 511 of the Career Compensation Act of 1949, as amended ("},{"tag":"ref","attrib":{"href":"/us/stat/70/114"},"text":"70 Stat. 114","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s580"},"text":"10 U.S.C. 580","children":[],"tail":" note), and who is at least 62 years of age, shall be retired 60 days after he becomes that age, except as provided by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8301"},"text":"section 8301 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8b549e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1263/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may defer, for not more than four months, the retirement under subsection (a) of any warrant officer if, because of unavoidable circumstances, evaluation of his physical condition and determination of his entitlement to retirement or separation for physical disability require hospitalization or medical observation that cannot be completed before the date when he would otherwise be required to retire under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8b549e7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"date","attrib":{"date":"1956-08-10"},"text":"Aug. 10, 1956","children":[],"tail":" ch. 1041, "},{"tag":"ref","attrib":{"href":"/us/stat/70A/101"},"text":"70A Stat. 101","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s3"},"text":"Pub. L. 89–718, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1115"},"text":"80 Stat. 1115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/130/s1/6"},"text":"Pub. L. 90–130, § 1(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-11-08"},"text":"Nov. 8, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/374"},"text":"81 Stat. 374","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s511/46"},"text":"Pub. L. 96–513, title V, § 511(46)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2924"},"text":"94 Stat. 2924","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1052/17"},"text":"Pub. L. 102–484, div. A, title X, § 1052(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2500"},"text":"106 Stat. 2500","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8b549e8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8b549e9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida8b549ea-3a6f-11f1-a58a-d8db54b14ab5"},"text"