{"tag":"section","attrib":{"id":"idaab5fc8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5515"},"text":null,"children":[{"tag":"num","attrib":{"value":"5515"},"text":"§ 5515.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Missile defense and defeat programs: major force program and budget assessment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaab5fc8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5515/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Major Force Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall establish a unified major force program for missile defense and defeat programs pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s222/b"},"text":"section 222(b) of this title","children":[],"tail":" to prioritize missile defense and defeat programs in accordance with the requirements of the Department of Defense and national security."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab5fc8f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5515/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Budget Assessment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab5fc90-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5515/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall include with the defense budget materials for each of fiscal years 2019 through 2030 a report on the budget for missile defense and defeat programs of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab5fc91-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5515/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each report on the budget for missile defense and defeat programs of the Department under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaab5fc92-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5515/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An overview of the budget, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaab5fc93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5515/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comparison between that budget, the previous budget, the most recent and prior future-years defense program submitted to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s221"},"text":"section 221 of this title","children":[],"tail":" (such comparison shall exclude the responsibility for research and development of the continuing improvement of such missile defense and defeat program), and the amounts appropriated for such missile defense and defeat programs during the previous fiscal year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaab5fc94-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5515/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific identification, as a budgetary line item, for the funding under such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab5fc95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5515/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the budget, including significant changes, priorities, challenges, and risks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab5fc96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5515/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any additional matters the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab5fc97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5515/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each report under paragraph (1) shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab5fc98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5515/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab5fc99-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5515/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “budget”, with respect to a fiscal year, means the budget for that fiscal year that is submitted to Congress by the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab5fc9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5515/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “defense budget materials”, with respect to a fiscal year, means the materials submitted to Congress by the Secretary of Defense in support of the budget for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab5fc9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5515/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “missile defense and defeat programs” means active and passive ballistic missile defense programs, cruise missile defense programs for the homeland, and missile defeat programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaab5fc9c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1649/a"},"text":"Pub. L. 118–159, div. A, title XVI, § 1649(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2193"},"text":"138 Stat. 2193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaab5fc9d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaab5fc9e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaab5fc9f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s239a"},"text":"section 239a of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1649/b/1"},"text":"Pub. L. 118–159, div. A, title XVI, § 1649(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2199"},"text":"138 Stat. 2199","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
