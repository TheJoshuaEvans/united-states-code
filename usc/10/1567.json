{"tag":"section","attrib":{"id":"ida8f33e65-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1567"},"text":null,"children":[{"tag":"num","attrib":{"value":"1567"},"text":"§ 1567.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of military protective orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A military protective order issued by a military commander shall remain in effect until such time as the military commander terminates the order or issues a replacement order.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida8f33e66-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title V, § 561(a), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4470"},"text":"122 Stat. 4470","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tX/s1073/a/16"},"text":"Pub. L. 111–84, div. A, title X, § 1073(a)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2473"},"text":"123 Stat. 2473","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8f33e67-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8f33e68-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8f33e69-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","ch