{"tag":"section","attrib":{"id":"ida908c16f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1731"},"text":null,"children":[{"tag":"num","attrib":{"value":"1731"},"text":"§ 1731.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical acquisition positions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida908c170-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1731/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Critical Acquisition Positions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida908c171-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1731/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense shall designate the acquisition positions in the Department of Defense that are critical acquisition positions. Such positions shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida908c172-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1731/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any acquisition position which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida908c173-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1731/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of employees, is required to be filled by an employee in a senior position in the National Security Personnel System, as determined in accordance with guidelines prescribed by the Secretary, or in the Senior Executive Service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida908c174-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1731/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of members of the armed forces, is required to be filled by a commissioned officer of the Army, Navy, Air Force, Marine Corps, or Space Force who is serving in the grade of lieutenant colonel, or, in the case of the Navy, commander, or a higher grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida908c175-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1731/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Other selected acquisition positions not covered by subparagraph (A), including the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida908c176-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1731/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Portfolio acquisition executive.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida908c177-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1731/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Program manager of a major defense acquisition program (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4201"},"text":"section 4201 of this title","children":[],"tail":") or of a significant nonmajor defense acquisition program (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1737/a/3"},"text":"section 1737(a)(3) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida908c178-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1731/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Deputy program manager of a major defense acquisition program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida908c179-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1731/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Product support manager.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida908c17a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1731/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other acquisition position of significant responsibility in which the primary duties are supervisory or management duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida908c17b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1731/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall periodically publish a list of the positions designated under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida908c17c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1731/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Promotion Rate for Officers in the Acquisition Workforce","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall ensure that the qualifications of commissioned officers in the acquisition workforce are such that those officers are expected, as a group, to be promoted at a rate not less than the rate for all line (or the equivalent) officers of the same armed force (both in the zone and below the zone) in the same grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida908c17d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1731/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mobility Statements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida908c17e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1731/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense is authorized to require civilians in critical acquisition positions to sign mobility statements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida908c17f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1731/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall identify which categories of civilians in critical acquisition positions, as a condition of employment, shall be required to sign mobility statements. The Secretary shall make available published information on such identification of categories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida908c180-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXII/s1202/a"},"text":"Pub. L. 101–510, div. A, title XII, § 1202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1646"},"text":"104 Stat. 1646","children":[],"tail":", § 1733; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1052/22"},"text":"Pub. L. 102–484, div. A, title X, § 1052(22)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2500"},"text":"106 Stat. 2500","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/89/s3/b/3/C"},"text":"Pub. L. 103–89, § 3(b)(3)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-30"},"text":"Sept. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/983"},"text":"107 Stat. 983","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tX/s1074/a/9/C"},"text":"Pub. L. 104–201, div. A, title X, § 1074(a)(9)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2659"},"text":"110 Stat. 2659","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tVIII/s833/2"},"text":"Pub. L. 108–136, div. A, title VIII, § 833(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1550"},"text":"117 Stat. 1550","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVIII/s812/a/2"},"text":"Pub. L. 108–375, div. A, title VIII, § 812(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2013"},"text":"118 Stat. 2013","children":[],"tail":"; renumbered § 1731 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVIII/s861/j/2"},"text":"Pub. L. 116–92, div. A, title VIII, § 861(j)(2)","children":[],"tail":"–(4), (6)(A), "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1519"},"text":"133 Stat. 1519","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/3/AA"},"text":"Pub. L. 116–283, div. A, title IX, § 924(b)(3)(AA)","children":[],"tail":", title XVIII, § 1846(i)(4), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3821"},"text":"134 Stat. 3821","children":[],"tail":", 4252; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVIII"},"text":"Pub. L. 119–60, div. A, title XVIII","children":[],"tail":", §§ 1802(b)(1)(B), 1803(a)(3), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1227"},"text":"139 Stat. 1227","children":[],"tail":", 1229.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida908c181-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida908c182-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida908c183-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1731/b"},"text":"section 1731(b) of this title","children":[],"tail":", which was transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1733/b"},"text":"section 1733(b) of this title","children":[],"tail":" and then to subsec. (b) of this section by "},{"tag":"ref","att