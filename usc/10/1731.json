],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida908c184-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1731, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXII/s1202/a"},"text":"Pub. L. 101–510, div. A, title XII, § 1202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1644"},"text":"104 Stat. 1644","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tVIII"},"text":"Pub. L. 108–136, div. A, title VIII","children":[],"tail":", §§ 832(b)(1), 833(1), "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1550"},"text":"117 Stat. 1550","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVIII/s861/j/3"},"text":"Pub. L. 116–92, div. A, title VIII, § 861(j)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1519"},"text":"133 Stat. 1519","children":[],"tail":", related to establishment of the Acquisition Corps, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVIII/s861/j/5"},"text":"Pub. L. 116–92, div. A, title VIII, § 861(j)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1519"},"text":"133 Stat. 1519","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida908c185-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1802/b/1/B"},"text":"Pub. L. 119–60, § 1802(b)(1)(B)","children":[],"tail":", substituted “Portfolio acquisition executive” for “Program executive officer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1803/a/3"},"text":"Pub. L. 119–60, § 1803(a)(3)","children":[],"tail":", added cl. (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s924/b/3/AA"},"text":"Pub. L. 116–283, § 924(b)(3)(AA)","children":[],"tail":", substituted “Marine Corps, or Space Force” for “or Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1846/i/4"},"text":"Pub. L. 116–283, § 1846(i)(4)","children":[],"tail":", which directed amendment of subsec. (b)(1)(B)(ii) of this section by substituting “section 4201” for “section 2430”, was executed to subsec. (a)(1)(B)(ii) of this section, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s861/j/6/A"},"text":"Pub. L. 116–92, § 861(j)(6)(A)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1733"},"text":"section 1733 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s861/j/2"},"text":"Pub. L. 116–92, § 861(j)(2)","children":[],"tail":", in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1733"},"text":"section 1733 of this title","children":[],"tail":" prior to renumbering as this section, redesignated subsec. (b) as (a) and struck out former subsec. (a). Prior to amendment, text of subsec. (a) of section 1733 read as follows: “A critical acquisition position may be filled only by a member of the Acquisition Corps.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s861/j/3"},"text":"Pub. L. 116–92, § 861(j)(3)","children":[],"tail":", prior to repeal of former section 1731, transferred subsec. (b) of that section to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1733"},"text":"section 1733 of this title","children":[],"tail":" and substituted “the Acquisition Workforce” for “Acquisition Corps” in heading and “in the acquisition workforce” for “selected for the Acquisition Corps” in text. See Codification note above. Section 1733 was subsequently renumbered as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s861/j/4"},"text":"Pub. L. 116–92, § 861(j)(4)","children":[],"tail":", prior to repeal of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1732"},"text":"section 1732 of this title","children":[],"tail":", transferred subsec. (e) of that section to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1733"},"text":"section 1733 of this title","children":[],"tail":", redesignated it as (c), and substituted “in critical acquisition positions” for “in the Acquisition Corps” in pars. (1) and (2) and “employment” for “serving in the Corps” in par. (2). See Codification note above. Section 1733 was subsequently renumbered as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(1)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" substituted “in a senior position in the National Security Personnel System, as determined in accordance with guidelines prescribed by the Secretary,” for “in a position within grade GS–14 or above of the General Schedule,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" substituted “the Acquisition Corps” for “an Acquisition Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" substituted “A critical” for “On and after "},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"October 1, 1993","children":[],"tail":", a critical”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(1)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/89"},"text":"Pub. L. 103–89","children":[],"tail":" substituted “Schedule” for “Schedule (including an employee covered by chapter 54 of title 5)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":" substituted “1737(a)(3)” for “1736(a)(3)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida908c186-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida908c187-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1846/i/4"},"text":"section 1846(i)(4) of Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida908c188-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/89"},"text":"Pub. L. 103–89","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-11-01"},"text":"Nov. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/89/s3/c"},"text":"section 3(c) of Pub. L. 103–89","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3372"},"text":"section 3372 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida908c189-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date for Requirement for Corps Members To Fill Critical Acquisition Positions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXII/s1209/f"},"text":"Pub. L. 101–510, div. A, title XII, § 1209(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1666"},"text":"104 Stat. 1666","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/25/tVII/s704/b/3/C"},"text":"Pub. L. 102–25, title VII, § 704(b)(3)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-04-06"},"text":"Apr. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/119"},"text":"105 Stat. 119","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tIX/s904/f"},"text":"Pub. L. 103–160, div. A, title IX, § 904(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1729"},"text":"107 Stat. 1729","children":[],"tail":", provided that the Secretaries of the military departments were to make every effort to fill critical acquisition positions by Acquisition Corps members as soon as possible after "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", and that for each of the first three years after "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", the report of the Under Secretary of Defense for Acquisition and Technology to the Secretary of Defense under former "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1762"},"text":"section 1762 of this title","children":[],"tail":" was to include the number of critical acquisition positions filled by Acquisition Corps members."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida908c18a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Defense Acquisition Corps","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVIII/s861/j/1"},"text":"Pub. L. 116–92, div. A, title VIII, § 861(j)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1519"},"text":"133 Stat. 1519","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dA/tVIII/s861/j/1"},"text":"“The Acquisition Corps for the Department of Defense referred to in [former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1731/a"},"text":"section 1731(a) of title 10","children":[],"tail":", United States Code, is terminated.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida908c18b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Tenure and Accountability of Program Managers for Program Definition Periods","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVIII/s826"},"text":"Pub. L. 114–92, div. A, title VIII, § 826","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/908"},"text":"129 Stat. 908","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s862/a"},"text":"Pub. L. 114–328, div. A, title VIII, § 862(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2302"},"text":"130 Stat. 2302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s902/64"},"text":"Pub. L. 116–92, div. A, title IX, § 902(64)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1550"},"text":"133 Stat. 1550","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dA/tIX/s902/64"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revised Guidance Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":"], the Secretary of Defense shall revise Department of Defense guidance for major defense acquisition programs to address the tenure and accountability of program managers for the program definition period of major defense acquisition programs."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Definition Period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purposes of this section, the term ‘program definition period’, with respect to a major defense acquisition program, means the period beginning with initiation of the program and ending with Milestone B approval (or Key Decision Point B approval in the case of a space program).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The revised guidance required by subsection (a) shall provide that the program manager for the program definition period of a major defense acquisition program is responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bringing technologies to maturity and identifying the manufacturing processes that will be needed to carry out the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring continuing focus during program development on meeting stated mission requirements and other requirements of the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommending trade-offs between program cost, schedule, and performance for the life-cycle of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing a business case for the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that appropriate information is available to the milestone decision authority to make a decision on Milestone B approval (or Key Decision Point B approval in the case of a space program), including information necessary to make the certification required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2366a"},"text":"section 2366a of title 10","children":[],"tail":", United States Code [now "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4251"},"text":"10 U.S.C. 4251","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifications, Resources, and Tenure","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall ensure that each program manager for the program definition period of a major defense acquisition program—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the appropriate management, engineering, technical, and financial expertise needed to meet the responsibilities assigned pursuant to subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is provided the resources and support (including systems engineering expertise, cost-estimating expertise, and software development expertise) needed to meet such responsibilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is assigned to the program manager position for such program until such time as such program receives Milestone B approval (or Key Decision Point B approval in the case of a space program), unless removed for cause or due to exceptional circumstances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The service acquisition executive, in the case of a major defense acquisition program of a military department, or the Under Secretary of Defense for Acquisition and Sustainment, in the case of a Defense-wide or Defense Agency major defense acquisition program, may waive the requirement in paragraph (3) of subsection (d) upon a determination that the program definition period will take so long that it would not be appropriate for a single individual to serve as program manager for the entire period covered by such paragraph.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida908c18c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Tenure and Accountability of Program Managers for Program Execution Periods","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVIII/s827"},"text":"Pub. L. 114–92, div. A, title VIII, § 827","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/909"},"text":"129 Stat. 909","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s862/b"},"text":"Pub. L. 114–328, div. A, title VIII, § 862(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2302"},"text":"130 Stat. 2302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s902/65"},"text":"Pub. L. 116–92, div. A, title IX, § 902(65)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1550"},"text":"133 Stat. 1550","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dA/tIX/s902/65"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revised Guidance Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":"], the Secretary of Defense shall revise Department of Defense guidance for major defense acquisition programs to address the tenure and accountability of program managers for the program execution period of major defense acquisition programs."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Execution Period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term ‘program execution period’, with respect to a major defense acquisition program, means the period beginning with Milestone B approval (or Key Decision Point B approval in the case of a space program) and ending with declaration of initial operational capability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The revised guidance required by subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require the program manager for the program execution period of a major defense acquisition program to enter into a performance agreement with the manager’s immediate supervisor for such program within six months of assignment, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes expected parameters for the cost, schedule, and performance of the program consistent with the business case for the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides the commitment of the supervisor to provide the level of funding and resources required to meet such parameters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides the assurance of the program manager that such parameters are achievable and that the program manager will be accountable for meeting such parameters; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide the program manager with the authority to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult on the addition of new program requirements that would be inconsistent with the parameters established in the performance agreement entered into pursuant to paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend trade-offs between cost, schedule, and performance, provided that such trade-offs are consistent with the parameters established in the performance agreement entered into pursuant to paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop such interim goals and milestones as may be required to achieve the parameters established in the performance agreement entered into pursuant to paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifications, Resources, and Tenure","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that each program manager for the program execution period of a defense acquisition program—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the appropriate management, engineering, technical, and financial expertise needed to meet the responsibilities assigned pursuant to subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is provided the resources and support (including systems engineering expertise, cost estimating expertise, and software development expertise) needed to meet such responsibilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is assigned to the program manager position for such program during the program execution period, unless removed for cause or due to exceptional circumstances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The service acquisition executive, in the case of a major defense acquisition program of a military department, or the Under Secretary of Defense for Acquisition and Sustainment, in the case of a Defense-wide or Defense Agency major defense acquisition program, may waive the requirement in paragraph (3) of subsection (d) upon a determination that the program execution period will take so long that it would not be appropriate for a single individual to serve as program manager for the entire program execution period.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
