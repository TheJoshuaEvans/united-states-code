te","attrib":{"date":"1943-12-06"},"text":"Dec. 6, 1943","children":[],"tail":", 8 F.R. 16351; New Zealand, Proc. No. 2582, "},{"tag":"date","attrib":{"date":"1943-04-02"},"text":"Apr. 2, 1943","children":[],"tail":", 8 F.R. 4275; United Kingdom, Proc. No. 2575, "},{"tag":"date","attrib":{"date":"1944-02-02"},"text":"Feb. 2, 1944","children":[],"tail":", 8 F.R. 1429."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
