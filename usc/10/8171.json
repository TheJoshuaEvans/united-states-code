{"tag":"section","attrib":{"id":"idab12e957-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8171"},"text":null,"children":[{"tag":"num","attrib":{"value":"8171"},"text":"§ 8171.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of authority after loss of vessel or aircraft","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If the crew of any naval vessel or naval aircraft are separated from their vessel or aircraft because of its wreck, loss, or destruction, all the command and authority given to the officers of the vessel or aircraft remain in full force until the crew are discharged or reassigned.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab12e958-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/372"},"text":"70A Stat. 372","children":[],"tail":", § 5951; renumbered § 8171, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/5"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1834"},"text":"132 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab12e959-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab12e95a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab12e95b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tai