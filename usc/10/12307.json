{"tag":"section","attrib":{"id":"idab9f992f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12307"},"text":null,"children":[{"tag":"num","attrib":{"value":"12307"},"text":"§ 12307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retired Reserve","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A member in the Retired Reserve may, if qualified, be ordered to active duty without his consent, but only as provided in section 688 or 12301(a) of this title. A member of the Retired Reserve (other than a member transferred to the Retired Reserve under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12641/b"},"text":"section 12641(b) of this title","children":[],"tail":") who is ordered to active duty or other appropriate duty in a retired status may be credited under chapter 1223 of this title with service performed pursuant to such order. A member in a retired status is not eligible for promotion (or for consideration for promotion) as a Reserve."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab9f9930-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/29"},"text":"70A Stat. 29","children":[],"tail":", § 675; "},{"tag":"ref","attrib":{"href":"/us/pl/98/94/tX/s1017/a"},"text":"Pub. L. 98–94, title X, § 1017(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/669"},"text":"97 Stat. 669","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVI/s651/d"},"text":"Pub. L. 101–189, div. A, title VI, § 651(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us