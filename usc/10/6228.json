{"tag":"section","attrib":{"id":"idaac69e25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228"},"text":null,"children":[{"tag":"num","attrib":{"value":"6228"},"text":"§ 6228.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting on penetrations of networks of contractors and subcontractors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaac69e26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures for Reporting Penetrations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall establish procedures that require each contractor and subcontractor to report to the Chief Information Officer when a covered network of the contractor or subcontractor that meets the criteria established pursuant to subsection (b) is successfully penetrated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac69e27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Criteria for Covered Networks","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac69e28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator shall, in consultation with the officials specified in paragraph (2), establish criteria for covered networks to be subject to the procedures for reporting penetrations under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac69e29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The officials specified in this paragraph are the following officials of the Administration:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac69e2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Deputy Administrator for Defense Programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69e2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Associate Administrator for Acquisition and Project Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69e2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Information Officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69e2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other official of the Administration the Administrator considers necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac69e2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedure Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac69e2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac69e30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The procedures established pursuant to subsection (a) shall require each contractor or subcontractor to submit to the Chief Information Officer a report on each successful penetration of a covered network of the contractor or subcontractor that meets the criteria established pursuant to subsection (b) not later than 60 days after the discovery of the successful penetration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69e31-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to subparagraph (C), each report required by subparagraph (A) with respect to a successful penetration of a covered network of a contractor or subcontractor shall include the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaac69e32-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the technique or method used in such penetration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaac69e33-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A sample of the malicious software, if discovered and isolated by the contractor or subcontractor, involved in such penetration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaac69e34-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary of information created by or for the Administration in connection with any program of the Administration that has been potentially compromised as a result of such penetration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69e35-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If a contractor or subcontractor is not able to obtain all of the information required by subparagraph (B) to be included in a report required by subparagraph (A) by the date that is 60 days after the discovery of a successful penetration of a covered network of the contractor or subcontractor, the contractor or subcontractor shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaac69e36-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in the report all information available as of that date; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaac69e37-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the Chief Information Officer the additional information required by subparagraph (B) as the information becomes available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac69e38-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Concurrent with the establishment of the procedures pursuant to subsection (a), the Administrator shall establish procedures to be used if information owned by the Administration was in use during or at risk as a result of the successful penetration of a covered network—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac69e39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in order to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaac69e3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a penetration of a covered network of a management and operating contractor, enhance the access of personnel of the Administration to Government-owned equipment and information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaac69e3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a penetration of a covered network of a contractor or subcontractor that is not a management and operating contractor, facilitate the access of personnel of the Administration to the equipment and information of the contractor or subcontractor; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69e3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaac69e3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include mechanisms for personnel of the Administration to, upon request, obtain access to equipment or information of a contractor or subcontractor necessary to conduct forensic analysis in addition to any analysis conducted by the contractor or subcontractor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaac69e3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that a contractor or subcontractor is only required to provide access to equipment or information as described in clause (i) to determine whether information created by or for the Administration in connection with any program of the Administration was successfully exfiltrated from a network of the contractor or subcontractor and, if so, what information was exfiltrated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaac69e3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the reasonable protection of trade secrets, commercial or financial information, and information that can be used to identify a specific person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac69e40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The procedures established pursuant to subsection (a) shall allow for limiting the dissemination of information obtained or derived through such procedures so that such information may be disseminated only to entities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac69e41-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with missions that may be affected by such information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69e42-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that may be called upon to assist in the diagnosis, detection, or mitigation of cyber incidents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69e43-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that conduct counterintelligence or law enforcement investigations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69e44-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for national security purposes, including cyber situational awareness and defense purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac69e45-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac69e46-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Chief Information Officer” means the Associate Administrator for Information Management and Chief Information Officer of the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac69e47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “contractor” means a private entity that has entered into a contract or contractual action of any kind with the Administration to furnish supplies, equipment, materials, or services of any kind.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac69e48-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered network” includes any network or information system that accesses, receives, or stores—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac69e49-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" classified information; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69e4a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sensitive unclassified information germane to any program of the Administration, as determined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac69e4b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6228/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “subcontractor” means a private entity that has entered into a contract or contractual action with a contractor or another subcontractor to furnish supplies, equipment, materials, or services of any kind in connection with another contract in support of any program of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac69e4c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1407"},"text":"139 Stat. 1407","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac69e4d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac69e4e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac69e4f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2662"},"text":"section 2662 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaac69e50-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) and (2) headings which read as follows: “"},{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":"” and “"},{"tag":"inline","attrib":{},"text":"Officials specified","children":[],"tail":"”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out headings for par. (1) “"},{"tag":"inline","attrib":{},"text":"Rapid reporting","children":[],"tail":"” and subpars. (A) to (C) “"},{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":"”, “"},{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":"”, and “"},{"tag":"inline","attrib":{},"text":"Avoidance of delays in reporting","children":[],"tail":"”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (2) and (3) headings which read as follows: “"},{"tag":"inline","attrib":{},"text":"Access to equipment and information by administration personnel","children":[],"tail":"” and “"},{"tag":"inline","attrib":{},"text":"Dissemination of information","children":[],"tail":"”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) to (4) headings which corresponded to the defined term in each par."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
