{"tag":"section","attrib":{"id":"idabb76721-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14510"},"text":null,"children":[{"tag":"num","attrib":{"value":"14510"},"text":"§ 14510.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separation at age 62: brigadier generals and rear admirals (lower half)","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Unless retired, transferred to the Retired Reserve, or discharged at an earlier date, each reserve officer of the Army, Air Force, or Marine Corps in the grade of brigadier general who has not been recommended for promotion to the grade of major general, and each reserve rear admiral (lower half) of the Navy who has not been recommended for promotion to the grade of rear admiral, except an officer covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14512"},"text":"section 14512 of this title","children":[],"tail":", shall be separated in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s14515"},"text":"section 14515 of this title","children":[],"tail":" on the last day of the month in which the officer becomes 62 years of age."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idabb76722-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2952"},"text":"108 Stat. 2952","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s503/b"},"text":"Pub. L. 109–364, div. A, title V, § 503(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2178"},"text":"120 Stat. 2178","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb76723-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabb76724-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idabb76725-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 3843(a) and 8843 of this title, prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1629/a/3"},"text":"Pub. L. 103–337, § 1629(a)(3)","children":[],"tail":", (c)(3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabb76726-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" substituted “age 62: brigadier generals” for “age 60: reserve brigadier generals” in section catchline and “62” for “60” in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabb76727-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabb76728-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},