{"tag":"section","attrib":{"id":"ida8a6f25a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1164"},"text":null,"children":[{"tag":"num","attrib":{"value":"1164"},"text":"§ 1164.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Warrant officers: separation for age","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8a6f25b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1164/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Unless retired or separated on or before the expiration of that period, each warrant officer shall be retired or separated from his armed force not later than 60 days after the date when he becomes 62 years of age, except as provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8301"},"text":"section 8301 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8a6f25c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1164/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may defer, for not more than four months, the separation under subsection (a) of any warrant officer if, because of unavoidable circumstances, evaluation of his physical condition and determination of his entitlement to retirement or separation for physical disability require hospitalization or medical observation that cannot be completed before the date when he would otherwise be required to be retired or separated under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8a6f25d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/90"},"text":"70A Stat. 90","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s3"},"text":"Pub. L. 89–718, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1115"},"text":"80 Stat. 1115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/130/s1/5"},"text":"Pub. L. 90–130, § 1(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-11-08"},"text":"Nov. 8, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/374"},"text":"81 Stat. 374","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s511/41"},"text":"Pub. L. 96–513, title V, § 511(41)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2923"},"text":"94 Stat. 2923","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s1/16"},"text":"Pub. L. 97–295, § 1(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1290"},"text":"96 Stat. 1290","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8a6f25e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8a6f25f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida8a6f260-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"