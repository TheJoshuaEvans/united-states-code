trib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:600","children":[{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":"(e) (as applicable to 10:600"},{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":"(c))."}],"tail":null},{"tag":"html:p","attrib":{},"text":"34:430(e) (as applicable to 34:430(c)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b), the words “Except as provided in clause (3) of subsection (b) of this section and in subsection (g) of this section” are omitted as covered by section 46 of the bill and section 14(g) of the source statute. The words “Unless retired or separated on or before the expiration of that period” are inserted for clarity. The words “becomes 62[55] years of age” are substituted for the words “attains the age of sixty-two * * * or the age of fifty-five”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “The Secretary concerned may defer” are substituted for the words “may, in the discretion of the Secretary, be deferred”. The words “not more than” are substituted for the words “a period not to exceed”. The words “determination of his” are inserted for clarity. The words “he would otherwise be required to be separated under this section” are substituted for the words “separation would otherwise be required”. The words “proper”, “which is required”, “possible”, and “a period of” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8a6f261-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8a6f262-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295/s1/16"},"text":"Pub. L. 97–295, § 1(16)","children":[],"tail":", substituted a colon for a semicolon after “officers” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" redesignated former subsec. (c) as (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" redesignated former subsec. (c) as (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/130"},"text":"Pub. L. 90–130","children":[],"tail":" struck out “male” before “warrant officer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/130"},"text":"Pub. L. 90–130","children":[],"tail":" struck out subsec. (b) which made special provisions for female warrant officers."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/130"},"text":"Pub. L. 90–130","children":[],"tail":" struck out reference to subsec. (b) of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/718"},"text":"Pub. L. 89–718","children":[],"tail":" substituted “8301” for “47a” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8a6f263-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8a6f264-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/b/3"},"text":"section 701(b)(3) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8a6f265-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deferment of Separation With Completion of 20 Years of Service or at Age 60","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041/s46"},"text":"Act Aug. 10, 1956, ch. 1041, § 46","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/638"},"text":"70A Stat. 638","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/act/1956-08-10/ch1041/s46"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The separation of any person who, on ","children":[{"tag":"date","attrib":{"date":"1954-11-01"},"text":"November 1, 1954","children":[],"tail":", was a male permanent warrant officer of a regular component of an armed force, and who upon attaining the age of 62 has completed less than 20 years of active service that could be credited to him under section 511 of the Career Compensation Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t37/s311"},"text":"37 U.S.C. 311","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/act/1949-10-12/ch681/tV/s511"},"text":"act Oct. 12, 1949, ch. 681, title V, § 511","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/829"},"text":"63 Stat. 829","children":[],"tail":", formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s580"},"text":"section 580 of this title","children":[],"tail":"] may be deferred by the Secretary concerned until he completes 20 years of that service, but not later than that date which is 60 days after the date on which he attains the age of 64."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The separation of any person who, on ","children":[{"tag":"date","attrib":{"date":"1954-11-01"},"text":"November 1, 1954","children":[],"tail":", was a female permanent warrant officer of a regular component of an armed force, and who upon attaining the age of 55 has completed less than 20 years of active service that could be credited to her under section 511 of the Career Compensation Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t37/s311"},"text":"37 U.S.C. 311","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/act/1949-10-12/ch681/tV/s511"},"text":"act Oct. 12, 1949, ch. 681, title V, § 511","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/829"},"text":"63 Stat. 829","children":[],"tail":", formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s580"},"text":"section 580 of this title","children":[],"tail":"] may be deferred by the Secretary concerned until she completes 20 years of that service, but not later than that date which is 60 days after the date on which she attains the age of 60.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
