":"34 U.S.C. 625h(a)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1948-06-12/ch449/s213/a"},"text":"June 12, 1948, ch. 449, § 213(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/62/369"},"text":"62 Stat. 369","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s993c"},"text":"34 U.S.C. 993c","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1948-06-19/ch540/s3"},"text":"June 19, 1948, ch. 540, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/62/505"},"text":"62 Stat. 505","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsections (b) and (c) are worded to conform to the terminology of the Career Compensation Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s231"},"text":"37 U.S.C. 231","children":[],"tail":" et seq.). The second and third provisos in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s410c/a"},"text":"34 U.S.C. 410c(a)","children":[],"tail":", relating to the computation of retired pay for officers whose pay on the active list was not based on years of service, are omitted as obsolete, since under the Career Compensation Act of 1949, the active-duty pay of all officers is based on years of service."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d) the words “A retired member who is advanced * * * from the grade of warrant officer, W–1, or from an enlisted grade” are substituted for the words “Enlisted men and warrant officers * * * advanced” and the words “as a warrant officer, W–1, or an enlisted member” are substituted for the words “to be enlisted or warrant officer personnel” because the Warrant Officer Act of 1954 established the grade of warrant officer, W–1, in lieu of the old warrant officer (as distinguished from commissioned warrant officer) grades. The words “rank or” are omitted as unnecessary. The words “within three months of the date of the approval of this Act” and “whichever is the later” are omitted as executed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab17a3c1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab17a3c2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1958 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6151(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"34 App.:350i(b)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-05-31/ch348/s3"},"text":"May 31, 1956, ch. 348, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/70/222"},"text":"70 Stat. 222","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to the provisions of law under which temporary appointments in officer grades were made is omitted as unnecessary, since the provisions cited comprise all existing authority for such appointments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab17a3c3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab17a3c4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8262, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/506"},"text":"70A Stat. 506","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/166/A"},"text":"Pub. L. 85–861, § 1(166)(A)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1516"},"text":"72 Stat. 1516","children":[],"tail":", provided for extension of enlistment of members of the Air Force needing medical care or hospitalization, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/90/235/s2/a/4/B"},"text":"Pub. L. 90–235, § 2(a)(4)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/756"},"text":"81 Stat. 756","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab17a3c5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “section 689, and section 1370 or 1370a (as applicable),” for “sections 689 and 1370”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6151"},"text":"section 6151 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" substituted “sections 689” for “sections 688”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/348"},"text":"Pub. L. 99–348","children":[],"tail":" amended subsec. (b) generally, substituting provision that retired pay be determined in accordance with the table for provision that retired pay, in the case of a member who first became a member of a uniformed service, as defined in section 1407(a)(2), before "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", be at the rate of 2½ percent of the basic pay of the grade to which advanced or, in the case of a member who first became a member of a uniformed service, as defined in section 1407(a)(2), on or after "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", be at a rate of 2½ percent of the monthly retired pay base computed under section 1407(d), which rates were to be multiplied by the number of years of service credited under section 1405, but such retired pay was not to be more than 75 percent of the basic pay or monthly retired pay base upon which the computation of retired pay was based and, in determining the number of years to be used as a multiplier, each additional full month of service was to be counted as one-twelfth of a year and any remaining fractional part of a month was to be disregarded."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/348"},"text":"Pub. L. 99–348","children":[],"tail":" amended subsec. (c) generally, substituting provision that retired pay of a former member be determined in accordance with the table for provision that retired pay, in the case of a former member who first became a member of a uniformed service, as defined in section 1407(a)(2), before "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", be at a rate of 2½ percent of the basic pay of the grade to which advanced, determined by the same period of service used to determine the basic pay of the grade upon which his retainer pay was based, multiplied by the number of years of creditable service for his retainer pay at the time of retirement, but such retired pay was not to be more than 75 percent of the basic pay upon the computation of retired pay was based, or in the case of a former member who first became a member of a uniformed service, as defined in section 1407(a)(2), on or after "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", that retired pay be at a rate of 2½ percent of the monthly retired pay base computed under section 1407(d), multiplied by the number of years of creditable service for his retainer pay at the time of retirement, but such retired pay was not to be more than 75 percent of the monthly retired pay base upon which the computation of retired pay was based."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/s923/c/1"},"text":"Pub. L. 98–94, § 923(c)(1)","children":[],"tail":", substituted “each full month of service that is in addition to the number of full years of service creditable to a member is counted as one-twelfth of a year and any remaining fractional part of a month is disregarded” for “a part of a year that is six months or more is counted as a whole year and a part of a year that is less than six months is disregarded”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/s922/a/9"},"text":"Pub. L. 98–94, § 922(a)(9)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s503/45"},"text":"Pub. L. 96–513, § 503(45)","children":[],"tail":", inserted “and subject to sections 688 and 1370 of this title” after “retired grade”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s513/17"},"text":"Pub. L. 96–513, § 513(17)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"September 8, 1980","children":[],"tail":"” for “the date of the enactment of the Department of Defense Authorization Act, 1981” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/342"},"text":"Pub. L. 96–342","children":[],"tail":" amended subsec. (b) generally, designating existing provisions as pars. (1) and (2) and, as so amended, in par. (1) designated existing provisions as subpar. (A), as so designated, inserted provision limiting applicability to members who became members of the uniformed services before the date of the enactment of the Department of Defense Authorization Act, 1981, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s513/17"},"text":"Pub. L. 96–513, § 513(17)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"September 8, 1980","children":[],"tail":"” for “the date of the enactment of the Department of Defense Authorization Act, 1981” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/342"},"text":"Pub. L. 96–342","children":[],"tail":" designated existing provisions as par. (1), inserted provision limiting applicability to members who became members of the uniformed services before the date of the enactment of the Department of Defense Authorization Act, 1981, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/132"},"text":"Pub. L. 88–132","children":[],"tail":" substituted “of” for “to which he would be 