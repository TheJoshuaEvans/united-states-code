{"tag":"section","attrib":{"id":"idab17a3b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8262"},"text":null,"children":[{"tag":"num","attrib":{"value":"8262"},"text":"§ 8262.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Higher retired grade and pay for members who serve satisfactorily under temporary appointments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab17a3b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8262/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Unless otherwise entitled to a higher retired grade and subject to section 689, and section 1370 or 1370a (as applicable), of this title, each member, other than a retired member, of the Navy or the Marine Corps shall, when retired, be advanced on the retired list to the highest officer grade in which he served satisfactorily under a temporary appointment as determined by the Secretary of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab17a3b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8262/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member (other than a former member of the Fleet Reserve or the Fleet Marine Corps Reserve) who is advanced on the retired list under this section is (unless otherwise entitled to higher retired pay) entitled to retired pay determined in accordance with the following table. References in the table are to sections of this title.","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab17a3b8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Column 1","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"Take","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Column 2","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"Multiply by","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Retired pay base computed under section 1406(d) or 1407","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Retired pay multiplier prescribed under section 1409 for the years of service that may be credited to him under section 1405.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab17a3b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8262/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each former member of the Fleet Reserve or the Fleet Marine Corps Reserve who is advanced on the retired list under this section is entitled to retired pay determined in accordance with the following table. References in the table are to sections of this title.","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab17a3ba-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Column 1","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"Take","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Column 2","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"Multiply by","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Retired pay base computed under section 1406(d) or 1407","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Retired pay multiplier prescribed under section 1409 for the number of years of service creditable for his retainer pay at the time of retirement.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab17a3bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8262/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member who is advanced on the retired list under this section from the grade of warrant officer, W–1, or from an enlisted grade to a commissioned grade, and who applies to the Secretary within three months after his advancement, shall, if the Secretary approves, be restored on the retired list to his former warrant officer or enlisted grade, as the case may be. A member who is restored to his former grade under this subsection is thereafter considered for all purposes as a warrant officer, W–1, or an enlisted member, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab17a3bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8262/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Retired pay computed under subsection (b) or (c), if not a multiple of $1, shall be rounded to the next lower multiple of $1.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab17a3bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/385"},"text":"70A Stat. 385","children":[],"tail":", § 6151; "},{"tag":"ref","attrib":{"href":"/us/pl/85/422/s11/a/6/A"},"text":"Pub. L. 85–422, § 11(a)(6)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-05-20"},"text":"May 20, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/131"},"text":"72 Stat. 131","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/138"},"text":"Pub. L. 85–861, § 1(138)","children":[],"tail":", (139)(A), "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1507"},"text":"72 Stat. 1507","children":[],"tail":", 1508; "},{"tag":"ref","attrib":{"href":"/us/pl/88/132/s5/h/4"},"text":"Pub. L. 88–132, § 5(h)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-10-02"},"text":"Oct. 2, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/214"},"text":"77 Stat. 214","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/342/tVIII/s813/d/13"},"text":"Pub. L. 96–342, title VIII, § 813(d)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "