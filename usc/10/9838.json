{"tag":"section","attrib":{"id":"idab87caed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9838"},"text":null,"children":[{"tag":"num","attrib":{"value":"9838"},"text":"§ 9838.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Settlement of accounts: affidavit of squadron commander","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In the settlement of the accounts of the commanding officer of a squadron for clothing and other military supplies, his affidavit may be received to show—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab87caee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9838/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that vouchers or squadron books were lost;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab87caef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9838/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" anything tending to prove that any apparent deficiency of those articles was caused by unavoidable accident, or by loss in actual service without his fault; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab87caf0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9838/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that all or part of the clothing and supplies was properly used.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The affidavit may be used as evidence of the facts set forth, with or without other evidence, as determined by the Secretary of the Air Force to be just and proper under the circumstances.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab87caf1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/595"},"text":"70A Stat. 595","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab87caf2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab87caf3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab87caf4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9838","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1302.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 225 (less 1st sentence); added ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1877-02-27/ch69"},"text":"Feb. 27, 1877, ch. 69","children":[],"tail":" (3d par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/19/241"},"text":"19 Stat. 241","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “anything” is substituted for the words “any matter or circumstance”. The words “properly used” are substituted for the words “legally used and appropriated”. The words “of the case” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
