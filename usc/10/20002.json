{"tag":"section","attrib":{"id":"idabc82f18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20002"},"text":null,"children":[{"tag":"num","attrib":{"value":"20002"},"text":"§ 20002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members: duty status","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed by the Secretary of the Air Force, each member of the Space Force shall be placed in one of the following duty statuses:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc82f19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20002/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Space Force active status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20002/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Space Force inactive status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20002/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Space Force retired status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc82f1c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1714"},"text":"Pub. L. 118–31, div. A, title XVII, § 1714","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/626"},"text":"137 Stat. 626","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
