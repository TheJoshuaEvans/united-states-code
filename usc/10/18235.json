{"tag":"section","attrib":{"id":"idabc5be78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18235"},"text":null,"children":[{"tag":"num","attrib":{"value":"18235"},"text":"§ 18235.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration; other use permitted by Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabc5be79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18235/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense, after consulting the Committee on Armed Services of the Senate and the Committee on Armed Services of the House of Representatives on matters of policy, may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc5be7a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18235/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer, operate, maintain, and equip facilities constructed, expanded, rehabilitated, or converted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s18233"},"text":"section 18233 of this title","children":[],"tail":" or otherwise acquired and used for the purposes of this chapter;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc5be7b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18235/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit persons or organizations other than members and units of the armed forces to use those facilities under such leases or other agreements as he considers appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc5be7c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18235/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cover the payments received under those leases or agreements into the Treasury to the credit of the appropriation from which the cost of maintaining the facility, including its utilities and services, is paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc5be7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18235/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may not permit any use or disposition to be made of a facility covered by subsection (a) that would interfere with its use—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc5be7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18235/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for administering and training the reserve components of the armed forces; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc5be7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18235/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in time of war or national emergency, by other units of the armed forces or by the United States for any other purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc5be80-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/122"},"text":"70A Stat. 122","children":[],"tail":", § 2235; renumbered § 18235 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1664/b/2"},"text":"Pub. L. 103–337, div. A, title XVI, § 1664(b)(2)","children":[],"tail":", (7), "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3010"},"text":"108 Stat. 3010","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1502/a/2"},"text":"Pub. L. 104–106, div. A, title XV, § 1502(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/502"},"text":"110 Stat. 502","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1067/1"},"text":"Pub. L. 106–65, div. A, title X, § 1067(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/774"},"text":"113 Stat. 774","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabc5be81-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idabc5be82-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idabc5be83-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html: