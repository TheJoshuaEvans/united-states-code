{"tag":"section","attrib":{"id":"ida8bebf74-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1405"},"text":null,"children":[{"tag":"num","attrib":{"value":"1405"},"text":"§ 1405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Years of service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8bebf75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1405/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of the computation of the years of service of a member of the armed forces under a provision of this title providing for such computation to be made under this section, the years of service of the member are computed by adding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8bebf76-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1405/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" his years of active service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8bebf77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1405/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the years of service, not included in clause (1), with which he was entitled to be credited on ","children":[{"tag":"date","attrib":{"date":"1958-05-31"},"text":"May 31, 1958","children":[],"tail":", in computing his basic pay; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8bebf78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1405/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the years of service, not included in clause (1) or (2), with which he would be entitled to be credited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12733"},"text":"section 12733 of this title","children":[],"tail":" if he were entitled to retired pay under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12731"},"text":"section 12731 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8bebf79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1405/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fractional Years of Service","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining a member’s years of service under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8bebf7a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1405/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each full month of service that is in addition to the number of full years of service creditable to the member shall be credited as ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"12","children":[],"tail":" of a year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8bebf7b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1405/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any remaining fractional part of a month shall be disregarded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8bebf7c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1405/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion of Time Required To Be Made Up or Excluded","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8bebf7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1405/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Time required to be made up by an enlisted member of the Army, Air Force, or Space Force under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s972/a"},"text":"section 972(a) of this title","children":[],"tail":", or required to be made up by an enlisted member of the Navy, Marine Corps, or Coast Guard under that section with respect to a period of time after "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"October 5, 1994","children":[],"tail":", may not be counted in determining years of service under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8bebf7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1405/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s972/b"},"text":"Section 972(b) of this title","children":[],"tail":" excludes from computation of an officer’s years of service for purposes of this section any time identified with respect to that officer under that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8bebf7f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/422/s11/a/1/A"},"text":"Pub. L. 85–422, § 11(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-05-20"},"text":"May