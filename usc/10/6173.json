{"tag":"section","attrib":{"id":"idaac42d3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6173"},"text":null,"children":[{"tag":"num","attrib":{"value":"6173"},"text":"§ 6173.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to develop future use plans for defense environmental cleanup","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaac42d3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6173/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Develop Future Use Plans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy may develop future use plans for any defense nuclear facility at which defense environmental cleanup activities are occurring.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac42d40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6173/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement to Develop Future Use Plans","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall develop a future use plan for each of the following defense nuclear facilities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac42d41-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6173/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hanford Site, Richland, Washington.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d42-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6173/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Savannah River Site, Aiken, South Carolina.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d43-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6173/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Idaho National Engineering Laboratory, Idaho.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac42d44-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6173/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Citizen Advisory Board","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac42d45-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6173/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At each defense nuclear facility for which the Secretary of Energy intends or is required to develop a future use plan under this section and for which no citizen advisory board has been established, the Secretary shall establish a citizen advisory board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d46-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6173/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may authorize the manager of a defense nuclear facility for which a future use plan is developed under this section (or, if there is no such manager, an appropriate official of the Department of Energy designated by the Secretary) to pay routine administrative expenses of a citizen advisory board established for that facility. Such payments shall be made from funds available to the Secretary for defense environmental cleanup activities necessary for national security programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac42d47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6173/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement to Consult With Citizen Advisory Board","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In developing a future use plan under this section with respect to a defense nuclear facility, the Secretary of Energy shall consult with a citizen advisory board established pursuant to subsection (c) or a similar advisory board already in existence as of ","children":[{"tag":"date","attrib":{"date":"1996-09-23"},"text":"September 23, 1996","children":[],"tail":", for such facility, affected local governments (including any local future use redevelopment authorities), and other appropriate State agencies."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac42d48-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6173/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 50","children":[{"tag":"inline","attrib":{},"text":"-year Planning Period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A future use plan developed under this section shall cover a period of at least 50 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac42d49-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6173/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after completing development of a final plan for a site listed in subsection (b), the Secretary of Energy shall submit to Congress a report on the plan. The report shall describe the plan and contain such findings and recommendations with respect to the site as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac42d4a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6173/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac42d4b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6173/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section, or in a future use plan developed under this section with respect to a defense nuclear facility, shall be construed as requiring any modification to a future use plan with respect to a defense nuclear facility that was developed before ","children":[{"tag":"date","attrib":{"date":"1996-09-23"},"text":"September 23, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d4c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6173/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section may be construed to affect statutory requirements for a defense environmental cleanup activity or project or to modify or otherwise affect applicable statutory or regulatory defense environmental cleanup requirements, including substantive standards intended to protect public health and the environment, nor shall anything in this section be construed to preempt or impair any local land use planning or zoning authority or State authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac42d4d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2)(B), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1386"},"text":"139 Stat. 1386","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac42d4e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac42d4f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac42d50-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2582"},"text":"section 2582 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaac42d51-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
