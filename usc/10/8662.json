{"tag":"section","attrib":{"id":"idab390eee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8662"},"text":null,"children":[{"tag":"num","attrib":{"value":"8662"},"text":"§ 8662.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Naming","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab390eef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8662/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than one vessel of the Navy may have the same name.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab390ef0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8662/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy may change the name of any vessel bought for the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab390ef1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/448"},"text":"70A Stat. 448","children":[],"tail":", § 7292; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1018/b"},"text":"Pub. L. 112–239, div. A, title X, § 1018(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1910"},"text":"126 Stat. 1910","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1071/f/27"},"text":"Pub. L. 113–291, div. A, title X, § 1071(f)(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3511"},"text":"128 Stat. 3511","