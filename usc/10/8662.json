ail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1898-05-04/ch234"},"text":"May 4, 1898, ch. 234","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/30/390"},"text":"30 Stat. 390","children":[],"tail":" (2d sentence under “Armor and Armament”); "},{"tag":"html:a","attrib":{"href":"/us/act/1908-05-13/ch166"},"text":"May 13, 1908, ch. 166","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/35/159"},"text":"35 Stat. 159","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1949-06-29/ch278"},"text":"June 29, 1949, ch. 278","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/300"},"text":"63 Stat. 300","children":[],"tail":" (6th par.)."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7292(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s463"},"text":"34 U.S.C. 463","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 1533.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words “care shall be taken that” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b) the words “first class” are omitted as obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c) the words “by authority of law” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab390ef5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab390ef6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8662, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/533"},"text":"70A Stat. 533","children":[],"tail":", provided for military training, organization, and equipping of prisoners who have been sent to United States Disciplinary Barracks, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/90/377/s6/3"},"text":"Pub. L. 90–377, § 6(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-05"},"text":"July 5, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/288"},"text":"82 Stat. 288","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab390ef7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" redesignated subsec. (c) as (b) and struck out former subsec. (b) which read as follows: “Each battleship shall be named for a State. However, if the names of all the States are in use, a battleship may be named for a city, place, or person.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7292"},"text":"section 7292 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" struck out subsec. (d) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The Secretary of the Navy may not announce or implement any proposal to name a vessel of the Navy until 30 days after the date on which the Secretary submits to the Committees on Armed Services of the Senate and the House of Representatives a report setting forth such proposal.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Each report under this subsection shall describe the justification for the proposal covered by such report in accordance with the standards referred to in section 1018(a) of the National Defense Authorization Act for Fiscal Year 2013.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" substituted “section 1018(a)” for “section 1024(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab390ef8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab390ef9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab390efa-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1018/c"},"text":"Pub. L. 112–239, div. A, title X, § 1018(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1911"},"text":"126 Stat. 1911","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/239/dA/tX/s1018/c"},"text":"“This section [amending this section and enacting provisions set out as a note under this section] and the amendment made by this section shall go into effect on the date that is 30 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab390efb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1018/a"},"text":"Pub. L. 112–239, div. A, title X, § 1018(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1910"},"text":"126 Stat. 1910","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/239/dA/tX/s1018/a"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress makes the following findings:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Navy traces its ancestry to ","children":[{"tag":"date","attrib":{"date":"1775-10-13"},"text":"October 13, 1775","children":[],"tail":", when an Act of the Continental Congress authorized the first vessel of a navy for the United Colonies. Vessels of the Continental Navy were named for early patriots and military heroes, Federal institutions, colonial cities, and positive character traits representative of naval and military virtues."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Act of Congress on ","children":[{"tag":"date","attrib":{"date":"1819-03-03"},"text":"March 3, 1819","children":[],"tail":", made the Secretary of the Navy responsible for assigning names to vessels of the Navy. Traditional sources for vessel names customarily encompassed such categories as geographic locations in the United States; historic sites, battles, and ships; naval and military heroes and leaders; and noted individuals who made distinguished contributions to United States national security."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" These customs and traditions provide appropriate and necessary standards for the naming of vessels of the Navy.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
