{"tag":"section","attrib":{"id":"idab50dc70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8859"},"text":null,"children":[{"tag":"num","attrib":{"value":"8859"},"text":"§ 8859.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Libel and proceedings by United States attorney","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab50dc71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8859/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon receiving the report of the prize master directed by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8858"},"text":"section 8858 of this title","children":[],"tail":", the United States attorney for the district shall promptly—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab50dc72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8859/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" file a libel against the prize property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc73-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8859/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain a warrant from the court directing the marshal to take custody of the prize property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc74-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8859/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proceed to obtain a condemnation of the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab50dc75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8859/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In connection with the condemnation proceedings the United States attorney shall insure that the prize commissioners—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab50dc76-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8859/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take proper preparatory evidence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8859/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take depositions de bene esse of the prize crew and of other transient persons who know any facts bearing on condemnation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab50dc78-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/477"},"text":"70A Stat. 477","children":[],"tail":", § 7659; renumbered § 8859 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 807(d)(9), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":", 1840.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab50dc79-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab50dc7a-3a6f-11f1-a5