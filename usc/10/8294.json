{"tag":"section","attrib":{"id":"idab1a159d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8294"},"text":null,"children":[{"tag":"num","attrib":{"value":"8294"},"text":"§ 8294.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Silver star medal","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President may award a silver star medal of appropriate design, with ribbons and appurtenances, to a person who, while serving in any capacity with the Navy or Marine Corps, is cited for gallantry in action that does not warrant a medal of honor or Navy cross—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab1a159e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8294/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while engaged in an action against an enemy of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1a159f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8294/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while engaged in military operations involving conflict with an opposing foreign force; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1a15a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8294/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while serving with friendly foreign forces engaged in an armed conflict against an opposing armed force in which the United States is not a belligerent party.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab1a15a1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/389"},"text":"70A Stat. 389","children":[],"tail":", § 6244; "},{"tag":"ref","attrib":{"href":"/us/pl/88/77/s2/3"},"text":"Pub. L. 88–77, § 2(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-07-25"},"text":"July 25, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/94"},"text":"77 Stat. 94","children":[],"tail":"; renumbered § 8294, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/13"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab1a15a2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab1a15a3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab1a15a4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html: