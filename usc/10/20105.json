{"tag":"section","attrib":{"id":"idabc82f51-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20105"},"text":null,"children":[{"tag":"num","attrib":{"value":"20105"},"text":"§ 20105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sustained duty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabc82f52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enlisted Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An authority designated by the Secretary of the Air Force may order an enlisted member of the Space Force in a space force active status to sustained duty, or retain an enlisted member on sustained duty, with the consent of that member, as specified in the terms of the member’s enlistment or reenlistment agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc82f53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc82f54-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An authority designated by the Secretary of the Air Force may order a Space Force officer in a space force active status to sustained duty—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabc82f55-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20105/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the consent of the officer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc82f56-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20105/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fulfill the terms of an active-duty service commitment incurred by the officer under any provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f57-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer ordered to sustained duty under paragraph (1) may not be released from sustained duty without the officer’s consent except as provided in chapter 2009 or 2011 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc82f58-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1715"},"text":"Pub. L. 118–31, div. A, title XVII, § 1715","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/629"},"text":"137 Stat. 629","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
