{"tag":"section","attrib":{"id":"idab097348-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8037"},"text":null,"children":[{"tag":"num","attrib":{"value":"8037"},"text":"§ 8037.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Chiefs of Naval Operations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab097349-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8037/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are Assistant Chiefs of Naval Operations in the Office of the Chief of Naval Operations, detailed by the Secretary of the Navy from officers on the active-duty list of the Navy and officers on the active-duty list of the Marine Corps. The Secretary of the Navy shall prescribe the number of Assistant Chiefs of Naval Operations in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8036/a"},"text":"section 8036(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab09734a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8037/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Chiefs of Naval Operations shall perform such duties as the Secretary of the Navy prescribes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab09734b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s512/b"},"text":"Pub. L. 99–433, title V, § 512(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1051"},"text":"100 Stat. 1051","children":[],"tail":", § 5037; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s502/b"},"text":"Pub.