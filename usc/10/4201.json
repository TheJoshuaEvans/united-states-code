il":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa64cf13-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1804/d/1"},"text":"Pub. L. 119–60, § 1804(d)(1)","children":[],"tail":", substituted “$1,000,000,000 (based on fiscal year 2024 constant dollars)” for “$300,000,000 (based on fiscal year 1990 constant dollars)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1804/d/2"},"text":"Pub. L. 119–60, § 1804(d)(2)","children":[],"tail":", substituted “$4,500,000,000 (based on fiscal year 2024 constant dollars)” for “$1,800,000,000 (based on fiscal year 1990 constant dollars)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s812/a/9"},"text":"Pub. L. 119–60, § 812(a)(9)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":", which directed substitution of “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3602"},"text":"section 3602 of this title","children":[],"tail":"” for “section 804 of the National Defense Authorization Act for Fiscal Year 2016 ("},{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Public Law 114–92","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3201"},"text":"10 U.S.C. 3201","children":[],"tail":" note prec.)”, was executed by making the substitution for “section 804 of the National Defense Authorization Act for Fiscal Year 2016 ("},{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Public Law 114–92","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2302"},"text":"10 U.S.C. 2302","children":[],"tail":" note)” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1846/c/1"},"text":"Pub. L. 116–283, § 1846(c)(1)","children":[],"tail":", transferred subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2430"},"text":"section 2430 of this title","children":[],"tail":" to this section, struck out par. (1) designation, inserted subsec. (a) heading, substituted “under subsection (b), in this part” for “under paragraph (2), in this chapter”, redesignated par. (2) as subsec. (b) and subpars. (A) and (B) of subsecs. (a) and (b) as pars. (1) and (2) of subsecs. (a) and (b), respectively, inserted subsec. (b) heading, and substituted “In this part” for “In this chapter” in introductory provisions of subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1846/c/2"},"text":"Pub. L. 116–283, § 1846(c)(2)","children":[],"tail":", substituted “to require—” for “to require”, inserted subpar. (A) designation before “an eventual total expenditure for research” and subpar. (B) designation before “an eventual total expenditure for procurement” and substituted “dollars); or” for “dollars) or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1846/c/3"},"text":"Pub. L. 116–283, § 1846(c)(3)","children":[],"tail":", in introductory provisions, substituted “include the following:” for “include—”, in par. (1), substituted “An” for “an” and period at end for “; or” and in par. (2), substituted “An” for “an”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa64cf14-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","childr