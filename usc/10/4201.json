{"tag":"section","attrib":{"id":"idaa64cf04-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4201"},"text":null,"children":[{"tag":"num","attrib":{"value":"4201"},"text":"§ 4201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major defense acquisition programs: definition; exceptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa64cf05-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided under subsection (b), in this part, the term “major defense acquisition program” means a Department of Defense acquisition program that is not a highly sensitive classified program (as determined by the Secretary of Defense) and—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa64cf06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4201/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is designated by the Secretary of Defense as a major defense acquisition program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa64cf07-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4201/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a program that is not a program for the acquisition of an automated information system (either a product or a service), that is estimated by the Secretary of Defense to require—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa64cf08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4201/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an eventual total expenditure for research, development, test, and evaluation of more than $1,000,000,000 (based on fiscal year 2024 constant dollars); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa64cf09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4201/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an eventual total expenditure for procurement, including all planned increments or spirals, of more than $4,500,000,000 (based on fiscal year 2024 constant dollars).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa64cf0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this part, the term “major defense acquisition program” does not include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa64cf0b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4201/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An acquisition program or project that is carried out using the rapid fielding or rapid prototyping acquisition pathway under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3602"},"text":"section 3602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa64cf0c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4201/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An acquisition program for a defense business system (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2222/i/1"},"text":"section 2222(i)(1) of this title","children":[],"tail":") carried out using the acquisition guidance issued pursuant to section 883(e) of the National Defense Authorization Act for Fiscal Year 2016 ("},{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Public Law 114–92","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2223a"},"text":"10 U.S.C. 2223a","children":[],"tail":" note)."},{"tag":"ref","attrib":{"idref":"fn002117"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002117"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa64cf0d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4201/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An acquisition program for software and covered hardware as described by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3603"},"text":"section 3603 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa64cf0e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1846/b"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1846(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4248"},"text":"134 Stat. 4248","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVIII/s804/c/2"},"text":"Pub. 