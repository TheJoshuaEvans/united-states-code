{"tag":"section","attrib":{"id":"ida9898b16-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2564a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2564a"},"text":"§ 2564a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of assistance for adaptive sports programs: members of the armed forces; certain veterans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9898b17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2564a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9898b18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2564a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense may establish a military adaptive sports program to support the provision of adaptive sports programming for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9898b19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2564a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any member of the armed forces who is eligible to participate in adaptive sports because of an injury, illness, or wound incurred in the line of duty in the armed forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9898b1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2564a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any veteran (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of title 38","children":[],"tail":"), during the one-year period following the veteran’s date of separation, who—"}],"tail":null},{"tag":"clause","attrib":{"id":"ida9898b1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2564a/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is on the Temporary Disability Retirement List or Permanently Disabled Retirement List;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9898b1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2564a/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible to participate in adaptive sports because of an injury, illness, or wound incurred in the line of duty in the armed forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9898b1d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2564a/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was enrolled in the program authorized under this section prior to the veteran’s date of separation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9898b1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2564a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In establishing the military adaptive sports program, the Secretary of Defense shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9898b1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2564a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Secretary of Veterans Affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9898b20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2564a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" avoid duplicating programs conducted by the Secretary of Veterans Affairs under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s521A"},"text":"section 521A of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9898b21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2564a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of Assistance; Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9898b22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2564a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under such criteria as the Secretary of Defense may establish under the military adaptive sports program, the Secretary may award grants to, or enter into contracts and cooperative agreements with, entities for the purpose of planning, developing, managing, and implementing adaptive sports programming for members and veterans described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9898b23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2564a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall use competitive procedures to award any grant or to enter into any contract or cooperative agreement under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9898b24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2564a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assistance provided under the military adaptive sports program shall be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9898b25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2564a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purposes specified in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9898b26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2564a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for such related activities and expenses as the Secretary of Defense may authorize.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9898b27-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s589/a"},"text":"Pub. L. 112–81, div. A, title V, § 589(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1437"},"text":"125 Stat. 1437","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tV/s592/a"},"text":"Pub. L. 116–92, div. A, title V, § 592(a)","children":[],"tail":"–(c)(1), "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1414"},"text":"133 Stat. 1414","children":[],"tail":", 1415.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9898b28-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9898b29-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9898b2a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s592/c/1"},"text":"Pub. L. 116–92, § 592(c)(1)","children":[],"tail":", amended section catchline generally. Prior to amendment, catchline read as follows: “Provision of assistance for adaptive sports programs for members of the armed forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s592/a"},"text":"Pub. L. 116–92, § 592(a)","children":[],"tail":", substituted “for—” and subpars. (A) and (B) for “for members of the armed forces who are eligible to participate in adaptive sports because of an injury or wound incurred in the line of duty in the armed forces.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s592/b"},"text":"Pub. L. 116–92, § 592(b)","children":[],"tail":", inserted “and veterans” after “members”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
