{"tag":"section","attrib":{"id":"ida8d4439b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455"},"text":null,"children":[{"tag":"num","attrib":{"value":"1455"},"text":"§ 1455.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8d4439c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall prescribe regulations to carry out this subchapter. Those regulations shall, so far as practicable, be uniform for the uniformed services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8d4439d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of Elections","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Regulations prescribed under this section shall provide that before the date on which a member becomes entitled to retired pay—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8d4439e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the member is married, the member and the member’s spouse shall be informed of the elections available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1448/a"},"text":"section 1448(a) of this title","children":[],"tail":" and the effects of such elections; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d4439f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the notification referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1448/a/3/E"},"text":"section 1448(a)(3)(E) of this title","children":[],"tail":" is required, any former spouse of the member shall be informed of the elections available and the effects of such elections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8d443a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedure for Depositing Certain Receipts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Regulations prescribed under this section shall establish procedures for depositing the amounts referred to in sections 1448(g), 1450(k)(2), and 1452(d) of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8d443a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payments to Guardians, Fiduciaries, and Special Needs Trusts.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8d443a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Regulations prescribed under this section shall provide procedures for the payment of an annuity under this subchapter in the case of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8d443a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person for whom a guardian or other fiduciary has been appointed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8d443a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a minor, mentally incompetent, or otherwise legally disabled person for whom a guardian or other fiduciary has not been appointed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8d443a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dependent child incapable of self-support because of mental or physical incapacity for whom a supplemental or special needs trust has been established under subparagraph (A) or (C) of section 1917(d)(4) of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396p/d/4"},"text":"42 U.S.C. 1396p(d)(4)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d443a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized procedures","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations under paragraph (1) may include provisions for the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8d443a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an annuitant referred to in paragraph (1)(A), payment of the annuity to the appointed guardian or other fiduciary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8d443a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an annuitant referred to in paragraph (1)(B), payment of the annuity to any person who, in the judgment of the Secretary concerned, is responsible for the care of the annuitant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8d443a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an annuitant referred to in paragraph (1)(C), payment of the annuity to the supplemental or special needs trust established for the annuitant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8d443aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subparagraphs (E) and (F), a requirement for the payee of an annuity to spend or invest the amounts paid on behalf of the annuitant solely for benefit of the annuitant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8d443ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Authority for the Secretary concerned to permit the payee to withhold from the annuity payment such amount, not in excess of 4 percent of the annuity, as the Secretary concerned considers a reasonable fee for the fiduciary services of the payee when a court appointment order provides for payment of such a fee to the payee for such services or the Secretary concerned determines that payment of a fee to such payee is necessary in order to obtain the fiduciary services of the payee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8d443ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Authority for the Secretary concerned to require the payee to provide a surety bond in an amount sufficient to protect the interests of the annuitant and to pay for such bond out of the annuity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8d443ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A requirement for the payee of an annuity to maintain and, upon request, to provide to the Secretary concerned an accounting of expenditures and investments of amounts paid to the payee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8d443ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/d/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of an annuitant referred to in paragraph (1)(B) or (1)(C)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8d443af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/d/2/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for determining incompetency and for selecting a payee to represent the annuitant for the purposes of this section, including provisions for notifying the annuitant of the actions being taken to make such a determination and to select a representative payee, an opportunity for the annuitant to review the evidence being considered, and an opportunity for the annuitant to submit additional evidence before the determination is made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8d443b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/d/2/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards for determining incompetency, including standards for determining the sufficiency of medical evidence and other evidence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8d443b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/d/2/H/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for determining when annuity payments to a supplemental or special needs trust shall end based on the death or marriage of the dependent child for which the trust was established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8d443b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/d/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provisions for any other matter that the President considers appropriate in connection with the payment of an annuity in the case of a person referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d443b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1455/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Legal effect of payment to guardian, fiduciary, or trust","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An annuity paid to a person on behalf of an annuitant in accordance with the regulations prescribed pursuant to paragraph (1) discharges the obligation of the United States for payment to the annuitant of the amount of the annuity so paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8d443b4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/425/s1/3"},"text":"Pub. L. 92–425, § 1(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-21"},"text":"Sept. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/711"},"text":"86 Stat. 711","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tVII/s724"},"text":"Pub. L. 99–145, title VII, § 724","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/678"},"text":"99 Stat. 678","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVI/s654/a"},"text":"Pub. L. 102–190, div. A, title VI, § 654(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1389"},"text":"105 Stat. 1389","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tVI/s634"},"text":"Pub. L. 104–201, div. A, title VI, § 634","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2577"},"text":"110 Stat. 2577","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tVI/s624/b"},"text":"Pub. L. 113–291, div. A, title VI, § 624(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3404"},"text":"128 Stat. 3404","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8d443b5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8d443b6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8d443b7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s624/b/1"},"text":"Pub. L. 113–291, § 624(b)(1)","children":[],"tail":", substituted “"},{"tag":"inline","attrib":{},"text":", Fiduciaries, and Special Needs Trusts","children":[],"tail":"” for “"},{"tag":"inline","attrib":{},"text":"and Fiduciaries","children":[],"tail":"” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s624/b/2"},"text":"Pub. L. 113–291, § 624(b)(2)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s624/b/3/B"},"text":"Pub. L. 113–291, § 624(b)(3)(B)","children":[],"tail":", added subpar. (C). Former subpar. (C) redesignated (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s624/b/3/A"},"text":"Pub. L. 113–291, § 624(b)(3)(A)","children":[],"tail":", (C), redesignated subpar. (C) as (D) and substituted “subparagraphs (E) and (F)” for “subparagraphs (D) and (E)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(E) to (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s624/b/3/A"},"text":"Pub. L. 113–291, § 624(b)(3)(A)","children":[],"tail":", redesignated subpars. (D) to (F) as (E) to (G), respectively. Former subpar. (G) redesignated (H)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s624/b/3/A"},"text":"Pub. L. 113–291, § 624(b)(3)(A)","children":[],"tail":", (D), redesignated subpar. (G) as (H), inserted “or (1)(C)” after “(1)(B)” in introductory provisions, and added cl. (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s624/b/3/A"},"text":"Pub. L. 113–291, § 624(b)(3)(A)","children":[],"tail":", redesignated subpar. (H) as (I)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s624/b/4"},"text":"Pub. L. 113–291, § 624(b)(4)","children":[],"tail":", substituted “"},{"tag":"inline","attrib":{},"text":", fiduciary, or trust","children":[],"tail":"” for “"},{"tag":"inline","attrib":{},"text":"or fiduciary","children":[],"tail":"” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" amended section generally, revising and restating provisions relating to regulations to carry out this subchapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsecs. (a) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" designated existing provisions as subsec. (a) and added subsecs. (b) to (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Pars. (1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" amended pars. (1) and (2) generally. Prior to amendment, pars. (1) and (2) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) provide that, when the notification referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1448/a"},"text":"section 1448(a) of this title","children":[],"tail":" is required, the member and his spouse shall, before the date the member becomes entitled to retired or retainer pay, be informed of the elections available and the effects of such elections; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) establish procedures for depositing the amounts referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1452/d"},"text":"section 1452(d) of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8d443b8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8d443b9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by title VII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1986-03-01"},"text":"Mar. 1, 1986","children":[],"tail":", with prohibition against accrual of benefits to any person by reason of the enactment of such title VII for any period before "},{"tag":"date","attrib":{"date":"1986-03-01"},"text":"Mar. 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/s731"},"text":"section 731 of Pub. L. 99–145","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1447"},"text":"section 1447 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
