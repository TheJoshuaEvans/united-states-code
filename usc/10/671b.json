{"tag":"section","attrib":{"id":"ida7fb48f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s671b"},"text":null,"children":[{"tag":"num","attrib":{"value":"671b"},"text":"§ 671b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members: service extension when Congress is not in session","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7fb48f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s671b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, when the President determines that the national interest so requires, he may, if Congress is not in session, having adjourned sine die, authorize the Secretary of Defense to extend for not more than six months enlistments, appointments, periods of active duty, periods of active duty for training, periods of obligated service, or other military status, in any component of the armed forces, that expire before the thirtieth day after Congress next convenes or reconvenes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7fb48fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s671b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An extension under this section continues until the sixtieth day after Congress next convenes or reconvenes or until the expiration of the period of extension specified by the Secretary of Defense, whichever occurs earlier, unless sooner terminated by law or Executive order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7fb48fb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/235/s1/a/1/A"},"text":"Pub. L. 90–235, § 1(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/753"},"text":"81 Stat. 753","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVI/s653/a/3"},"text":"Pub. L. 101–189, div. A, title VI, § 653(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1462"},"text":"103 Stat. 1462","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7fb48fc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7fb48fd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7fb48fe-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" substituted “armed forces” for “Armed Forces of the United States”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
