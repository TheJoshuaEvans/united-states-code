{"tag":"section","attrib":{"id":"ida8216ef1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860c"},"text":null,"children":[{"tag":"num","attrib":{"value":"860c"},"text":"§ 860c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 60c. Entry of judgment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8216ef2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Entry of Judgment of General or Special Court-martial","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8216ef3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In accordance with rules prescribed by the President, in a general or special court-martial, the military judge shall enter into the record of trial the judgment of the court. The judgment of the court shall consist of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8216ef4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Statement of Trial Results under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s860"},"text":"section 860 of this title","children":[],"tail":" (article 60)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8216ef5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any modifications of, or supplements to, the Statement of Trial Results by reason of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8216ef6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860c/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any post-trial action by the convening authority; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8216ef7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860c/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any ruling, order, or other determination of the military judge that affects a plea, a finding, or the sentence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8216ef8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under rules prescribed by the President, the judgment under paragraph (1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8216ef9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided to the accused and to any victim of the offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8216efa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8216efb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s860c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Summary Court-martial Judgment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The findings and sentence of a summary court-martial, as modified by any post-trial action by the convening authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s860b"},"text":"section 860b of this title","children":[],"tail":" (article 60b), constitutes the judgment of the court-martial and shall be recorded and distributed under rules prescribed by the President."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8216efc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLIX/s5324"},"text":"Pub. L. 114–328, div. E, title LIX, § 5324","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2927"},"text":"130 Stat. 2927","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8216efd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8216efe-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8216eff-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on ","children":[{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
