{"tag":"section","attrib":{"id":"ida9a3a1c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2670"},"text":null,"children":[{"tag":"num","attrib":{"value":"2670"},"text":"§ 2670.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of facilities by private organizations; use as polling places","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9a3a1ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2670/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use by Red Cross","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under such conditions as he may prescribe, the Secretary of any military department may issue a revocable license to the American National Red Cross to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9a3a1cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2670/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" erect and maintain, on any military installation under his jurisdiction, buildings for the storage of supplies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a3a1cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2670/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use, for the storage of supplies, buildings erected by the United States.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Supplies stored in buildings erected or used under this subsection are available to aid the civilian population in a serious national disaster.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9a3a1cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2670/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Certain Facilities as Polling Places","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9a3a1ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2670/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding chapter 29 of title 18 (including sections 592 and 593 of such title) or any other provision of law, the Secretary of Defense or Secretary of a military department may not (except as provided in paragraph (3)) prohibit the designation or use of a qualifying facility under the jurisdiction of the Secretary as an official polling place for local, State, or Federal elections.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a3a1cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2670/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A Department of Defense facility is a qualifying facility for purposes of this subsection if as of ","children":[{"tag":"date","attrib":{"date":"2000-12-31"},"text":"December 31, 2000","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9a3a1d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2670/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the facility is designated as an official polling place by a State or local election official; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9a3a1d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2670/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the facility has been used as such an official polling place since ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a3a1d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2670/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The limitation in paragraph (1) may be waived by the Secretary of Defense or Secretary of the military department concerned with respect to a particular Department of Defense facility if the Secretary of Defense or Secretary concerned determines that local security conditions require prohibition of the designation or use of that facility as an official polling place for any election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9a3a1d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2670/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Space and Equipment by Veterans Service Organizations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9a3a1d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2670/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon certification to the Secretary concerned by the Secretary of Veterans Affairs, the Secretary concerned shall allow accredited, paid, full-time representatives of the organizations named in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s5902"},"text":"section 5902 of title 38","children":[],"tail":", or of other organizations recognized by the Secretary of Veterans Affairs, to function on military installations under the jurisdiction of the Secretary concerned that are on land and from which persons are discharged or released from active duty."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a3a1d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2670/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The commanding officer of a military installation allowing representatives to function on the installation under paragraph (1) shall allow the representatives to use available space and equipment at the installation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a3a1d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2670/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection does not authorize the violation of measures of military security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9a3a1d7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/151"},"text":"70A Stat. 151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXVI/s1607/a"},"text":"Pub. L. 107–107, div. A, title XVI, § 1607(a)","children":[],"tail":"–(b)(2), "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1279"},"text":"115 Stat. 1279","children":[],"tail":", 1280; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dB/tXXVIII/s2821/c/1"},"text":"Pub. L. 108–375, div. B, title XXVIII, § 2821(c)(1)","children":[],"tail":", (e)(2), "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2129"},"text":"118 Stat. 2129","children":[],"tail":", 2130.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9a3a1d8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida9a3a1d9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida9a3a1da-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2670","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:12.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-06-03/ch134/s127a"},"text":"June 3, 1916, ch. 134, § 127a","children":[],"tail":" (5th par.); added "},{"tag":"html:a","attrib":{"href":"/us/act/1920-06-04/ch227"},"text":"June 4, 1920, ch. 227","children":[],"tail":", subch. I, § 51 (5th par.); restated "},{"tag":"html:a","attrib":{"href":"/us/act/1953-07-17/ch222/s3"},"text":"July 17, 1953, ch. 222, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/178"},"text":"67 Stat. 178","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “issue” is substituted for the words “grant permission”. The word “use” is substituted for the words “occupy for that purpose”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9a3a1db-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9a3a1dc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s2821/e/2"},"text":"Pub. L. 108–375, § 2821(e)(2)","children":[],"tail":", substituted “Use of facilities by private organizations; use as polling places” for “Military installations: use by American National Red Cross; use as polling places” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s2821/c/1"},"text":"Pub. L. 108–375, § 2821(c)(1)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" substituted “Military installations: use by American National Red Cross; use as polling places” for “Licenses: military installations; erection and use of buildings; American National Red Cross” in section catchline, designated existing provisions as subsec. (a), inserted heading, substituted “this subsection” for “this section” in concluding provisions, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9a3a1dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9a3a1de-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dB/tXXVIII/s2821/c/3"},"text":"Pub. L. 108–375, div. B, title XXVIII, § 2821(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2129"},"text":"118 Stat. 2129","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/375/dB/tXXVIII/s2821/c/3"},"text":"“The regulations prescribed to carry out [former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2679"},"text":"section 2679 of title 10","children":[],"tail":", United States Code, as in effect on the day before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":"], shall remain in effect with regard to section 2670(c) of such title, as added by paragraph (1), until changed by joint action of the Secretary concerned (as defined in section 101(9) of such title [now "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a/9"},"text":"10 U.S.C. 101(a)(9)","children":[],"tail":"]) and the Secretary of Veterans Affairs.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
