{"tag":"section","attrib":{"id":"ida978c1e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2454"},"text":null,"children":[{"tag":"num","attrib":{"value":"2454"},"text":"§ 2454.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supply catalog: new or obsolete items","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida978c1e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2454/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After any part of the supply catalog described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2451"},"text":"section 2451 of this title","children":[],"tail":" is distributed, and with respect to the kinds of items covered by that part, only the items listed in it may be procured for recurrent use in the Department of Defense. However, a military department may acquire any new item that is necessary to carry out its mission. As soon as such an item is acquired, it shall be submitted to the Secretary for inclusion in the catalog and the standardization program."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida978c1e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2454/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Obsolete items may be deleted from the catalog at any time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida978c1e5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/140"},"text":"70A Stat. 140","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida978c1e6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib