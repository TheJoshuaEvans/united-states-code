{"tag":"section","attrib":{"id":"ida82ae574-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s909a"},"text":null,"children":[{"tag":"num","attrib":{"value":"909a"},"text":"§ 909a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 109a. Mail matter: wrongful taking, opening, etc.","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida82ae575-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s909a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Taking","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person subject to this chapter who, with the intent to obstruct the correspondence of, or to pry into the business or secrets of, any person or organization, wrongfully takes mail matter before the mail matter is delivered to or received by the addressee shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82ae576-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s909a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Opening, Secreting, Destroying, Stealing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person subject to this chapter who wrongfully opens, secretes, destroys, or steals mail matter before the mail matter is delivered to or received by the addressee shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida82ae577-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLX/s5421"},"text":"Pub. L. 114–328, div. E, title LX, § 5421","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2946"},"text":"130 Stat. 2946","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida82ae578-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida82ae579-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida82ae57a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on ","children":[{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. No. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
