{"tag":"section","attrib":{"id":"ida9575678-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2242"},"text":null,"children":[{"tag":"num","attrib":{"value":"2242"},"text":"§ 2242.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to use appropriated funds for certain investigations and security services","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense and the Secretary of each military department may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9575679-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2242/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay in advance for the expenses of conducting investigations in foreign countries incident to matters relating to the Department of Defense, to the extent such expenses are determined by the investigating officer to be necessary and in accord with local custom;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida957567a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2242/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay expenses incurred in connection with the administration of occupied areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c77b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2242/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay expenses of military courts, boards, and commissions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c77c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2242/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimburse the Administrator of General Services for security guard services furnished by the Administrator to the Department of Defense for the protection of confidential files.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida959c77d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/370/s1/e/1"},"text":"Pub. L. 100–370, § 1(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-07-19"},"text":"July 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/844"},"text":"102 Stat. 844","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida959c77e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida959c77f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Paragraphs (1) and (4) of this section and sections 2241(b) and 2253(a)(1) of this title are based on ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/212/tVII/s705"},"text":"Pub. L. 98–212, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-08"},"text":"Dec. 8, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1437"},"text":"97 Stat. 1437","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Paragraphs (2) and (3) are based on ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/190/s101/b/tVIII/s8005/a"},"text":"Pub. L. 99–190, § 101(b) [title VIII, §§ 8005(a), 8006(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-19"},"text":"Dec. 19, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1185"},"text":"99 Stat. 1185","children":[],"tail":", 1202, 1203."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
