{"tag":"section","attrib":{"id":"idaacdcb12-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6336"},"text":null,"children":[{"tag":"num","attrib":{"value":"6336"},"text":"§ 6336.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on use of funds for certain research and development purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaacdcb13-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6336/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than February 1 each year, the Secretary of Energy shall submit to the congressional defense committees a report on the funds expended during the preceding fiscal year on activities under the Department of Energy Laboratory Directed Research and Development Program. The purpose of the report is to permit an assessment of the extent to which such activities support the national security mission of the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdcb14-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6336/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plant-directed Research and Development","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacdcb15-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6336/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The report required by subsection (a) shall include, with respect to plant-directed research and development, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacdcb16-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6336/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A financial accounting of expenditures for such research and development, disaggregated by nuclear weapons production facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdcb17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6336/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A breakdown of the percentage of research and development conducted by each such facility that is plant-directed research and development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdcb18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6336/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An explanation of how each such facility plans to increase the availability and utilization of funds for plant-directed research and development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdcb19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6336/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the term “plant-directed research and development” means research and development selected by the director of a nuclear weapons production facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdcb1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6336/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preparation of Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each report shall be prepared by the officials responsible for Federal oversight of the funds expended on activities under the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdcb1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6336/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria Used in Preparation of Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each report shall set forth the criteria utilized by the officials preparing the report in determining whether or not the activities reviewed by such officials support the national security mission of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaacdcb1c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1449"},"text":"139 Stat. 1449","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaacdcb1d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaacdcb1e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaacdcb1f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6336 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8336"},"text":"section 8336 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2793"},"text":"section 2793 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaacdcb20-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) and (2) headings which read as follows: "},{"tag":"inline","attrib":{},"text":"“In general”","children":[],"tail":" and "},{"tag":"inline","attrib":{},"text":"“Plant-directed research and development defined”","children":[],"tail":", respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
