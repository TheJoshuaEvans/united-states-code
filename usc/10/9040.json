{"tag":"section","attrib":{"id":"idab5f3500-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9040"},"text":null,"children":[{"tag":"num","attrib":{"value":"9040"},"text":"§ 9040.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight of nuclear deterrence mission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab5f3501-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9040/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Oversight of Nuclear Deterrence Mission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the authority, direction, and control of the Secretary of the Air Force, the Chief of Staff of the Air Force shall be responsible for overseeing the safety, security, reliability, effectiveness, and credibility of the nuclear deterrence mission of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab5f3502-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9040/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deputy Chief of Staff","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2016-03-01"},"text":"March 1, 2016","children":[],"tail":", the Chief of Staff shall designate a Deputy Chief of Staff to carry out the following duties in coordination with the Commander of Air Force Global Strike Command:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab5f3503-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9040/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide direction, guidance, integration, and advocacy regarding the nuclear deterrence mission of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5f3504-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9040/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinate with and support the activities of Air Force Global Strike Command, the Air Force Nuclear Systems Center, and any other applicable Air Force organization in the sustainment and modernization of weapon systems associated with the nuclear deterrence mission of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5f3505-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9040/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conduct monitoring and oversight activities regarding the safety, security, reliability, effectiveness, and credibility of the nuclear deterrence mission of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5f3506-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9040/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conduct periodic comprehensive assessments of all aspects of the nuclear deterrence mission of the Air Force and provide such assessments to the Secretary of the Air Force ","children":[{"tag":"ref","attrib":{"idref":"fn002169"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002169"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" the Chief of Staff of the Air Force, and the Commander of Air Force Global Strike Command."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5f3507-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9040/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Represent Air Force nuclear deterrence mission equities on behalf of the Chief of Staff of the Air Force and the Commander of Air Force Global Strike Command within the Nuclear Weapons Council processes and other Department of Defense fora, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab5f3508-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tXVI/s1652/a/1"},"text":"Pub. L. 114–92, div. A, title XVI, § 1652(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1121"},"text":"129 Stat. 1121","children":[],"tail":", § 8040; renumbered § 9040, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/c"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1833"},"text":"132 Stat. 1833","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVI/s1642/b"},"text":"Pub. L. 119–60, div. A, title XVI, § 1642(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1192"},"text":"139 Stat. 1192","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab5f3509-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab5f350a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab5f350b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1642/b/1"},"text":"Pub. L. 119–60, § 1642(b)(1)","children":[],"tail":", inserted “in coordination with the Commander of Air Force Global Strike Command” after “duties” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1642/b/2"},"text":"Pub. L. 119–60, § 1642(b)(2)","children":[],"tail":"–(4), added par. (2), redesignated former pars. (2) and (3) as (3) and (4), respectively, and in par. (4), substituted “the Chief of Staff of the Air Force, and the Commander of Air Force Global Strike Command” for “and the Chief of Staff of the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1642/b/5"},"text":"Pub. L. 119–60, § 1642(b)(5)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8040"},"text":"section 8040 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab5f350c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab5f350d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
