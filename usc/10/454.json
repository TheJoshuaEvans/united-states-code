{"tag":"section","attrib":{"id":"ida7bf9f64-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s454"},"text":null,"children":[{"tag":"num","attrib":{"value":"454"},"text":"§ 454.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange of mapping, charting, and geomatics data with foreign countries, international organizations, nongovernmental organizations, and academic institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7bf9f65-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s454/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign Countries and International Organizations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may authorize the National Geospatial-Intelligence Agency to exchange or furnish mapping, charting, and geomatics data, supplies and services to a foreign country or international organization pursuant to an agreement for the production or exchange of such data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bf9f66-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s454/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nongovernmental Organizations and Academic Institutions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may authorize the National Geospatial-Intelligence Agency to exchange or furnish mapping, charting, and geomatics data, supplies, and services relating to areas outside of the United States to a nongovernmental organization or an academic institution engaged in geospatial information research or production of such areas pursuant to an agreement for the production or exchange of such data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7bf9f67-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/569/tVI/s601/a"},"text":"Pub. L. 99–569, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3202"},"text":"100 Stat. 3202","children":[],"tail":", § 2795; renumbered § 454 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXI/s1112/b"},"text":"Pub. L. 104–201, div. A, title XI, § 1112(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2682"},"text":"110 Stat. 2682","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tIX/s921/d/2/A"},"text":"Pub. L. 108–136, div. A, title IX, § 921(d)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1568"},"text":"117 Stat. 1568","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tIX/s923/a"},"text":"Pub. L. 112–81, div. A, title IX, § 923(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1539"},"text":"125 Stat. 1539","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVI/s1621/c/1"},"text":"Pub. L. 116–283, div. A, title XVI, § 1621(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4053"},"text":"134 Stat. 4053","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7bf9f68-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7bf9f69-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7bf9f6a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “geomatics” for “geodetic” in section catchline and in two places in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s923/b/1"},"text":"Pub. L. 112–81, § 923(b)(1)","children":[],"tail":", amended section catchline generally, substituting “Exchange of mapping, charting, and geodetic data with foreign countries, international organizations, nongovernmental organizations, and academic institutions” for “Exchange of mapping, charting, and geodetic data with foreign countries and international organizations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s923/a"},"text":"Pub. L. 112–81, § 923(a)","children":[],"tail":", designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" substituted “National Geospatial-Intelligence Agency” for “National Imagery and Mapping Agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" renumbered "},{"tag":"ref","at