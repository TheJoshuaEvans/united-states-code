{"tag":"section","attrib":{"id":"ida7f1ac1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s630"},"text":null,"children":[{"tag":"num","attrib":{"value":"630"},"text":"§ 630.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discharge of commissioned officers with less than six years of active commissioned service or found not qualified for promotion for first lieutenant or lieutenant (junior grade)","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of the military department concerned, under regulations prescribed by the Secretary of Defense—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7f1ac20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s630/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may discharge any officer on the active-duty list who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7f1ac21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s630/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has less than six years of active commissioned service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7f1ac22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s630/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is serving in the grade of second lieutenant or ensign and has been found not qualified for promotion to the grade of first lieutenant or lieutenant (junior grade); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f1ac23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s630/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, unless the officer has been promoted, discharge any officer described in paragraph (1)(B) at the end of the 18-month period beginning on the date on which the officer is first found not qualified for promotion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7f1ac24-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tI/s105"},"text":"Pub. L. 96–513, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2861"},"text":"94 Stat. 2861","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXIV/s1405/11"},"text":"Pub. L. 98–525, title XIV, § 1405(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2622"},"text":"98 Stat. 2622","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s505/d/2"},"text":"Pub. L. 107–107, div. A, title V, § 505(d)(2)","children":[],"tail":", (4)(A), "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1088"},"text":"115 Stat. 1088","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tV/s505/b"},"text":"Pub. L. 108–136, div. A, title V, § 505(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1457"},"text":"117 Stat. 1457","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tV/s503/a/1"},"text":"Pub. L. 110–181, div. A, title V, § 503(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"ta