{"tag":"section","attrib":{"id":"idab403b88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695"},"text":null,"children":[{"tag":"num","attrib":{"value":"8695"},"text":"§ 8695.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Navy battle force ship assessment and requirement reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab403b89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date on which a covered event occurs, the Chief of Naval Operations shall submit to the congressional defense committees a battle force ship assessment and requirement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403b8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each assessment required by subsection (a) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab403b8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A review of the strategic guidance of the Federal Government, the Department of Defense, and the Navy for identifying priorities, missions, objectives, and principles, in effect as of the date on which the assessment is submitted, that the force structure of the Navy must follow.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403b8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An identification of the steady-state demand for maritime security and security force assistance activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403b8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An identification of the force options that can satisfy the steady-state demands for activities required by theater campaign plans of combatant commanders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403b8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A force optimization analysis that produces a day-to-day global posture required to accomplish peacetime and steady-state tasks assigned by combatant commanders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403b8f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A modeling of the ability of the force to fight and win scenarios approved by the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403b90-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A calculation of the number and global posture of each force element required to meet steady-state presence demands and warfighting response timelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403b91-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab403b92-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each requirement required by subsection (a) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403b93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be based on the assessment required by subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403b94-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify, for each of the fiscal years that are five, 10, 15, 20, 25, and 30 years from the date of the covered event—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idab403b95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of battle force ships required;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab403b96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of battle force ships required in each of the categories described in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab403b97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the classes of battle force ships included in each of the categories described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab403b98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of battle force ships required in each class.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403b99-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The categories described in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403b9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Aircraft carriers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403b9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Large surface combatants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403b9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Small surface combatants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403b9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amphibious warfare ships.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403b9e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Attack submarines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403b9f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ballistic missile submarines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403ba0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Combat logistics force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403ba1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Expeditionary fast transport.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403ba2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/c/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Expeditionary support base.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403ba3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/c/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Command and support.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403ba4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/c/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403ba5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab403ba6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “battle force ship” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403ba7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A commissioned United States Ship warship capable of contributing to combat operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403ba8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A United States Naval Ship that contributes directly to Navy warfighting or support missions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403ba9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered event” means a significant change to any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403baa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Strategic guidance that results in changes to theater campaign plans or warfighting scenarios.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Strategic laydown of vessels or aircraft that affects sustainable peacetime presence or warfighting response timelines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operating concepts, including employment cycles, crewing constructs, or operational tempo limits, that affect peacetime presence or warfighting response timelines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403bad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assigned missions that affect the type or quantity of force elements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403bae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8695/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities of Commandant of Marine Corps","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In preparing each assessment and requirement under subsection (a), the Commandant of the Marine Corps shall be specifically responsible for developing the requirements relating to amphibious warfare ships and for naval vessels with the primary mission of transporting Marines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab403baf-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tX/s1017/a"},"text":"Pub. L. 117–81, div. A, title X, § 1017(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1896"},"text":"135 Stat. 1896","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tX/s1025"},"text":"Pub. L. 117–263, div. A, title X, § 1025","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2764"},"text":"136 Stat. 2764","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tX/s1019"},"text":"Pub. L. 118–31, div. A, title X, § 1019","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/384"},"text":"137 Stat. 384","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab403bb0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab403bb1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab403bb2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" substituted “Responsibilities of Commandant of Marine Corps” for “Amphibious Warfare Ships” in heading and inserted “and for naval vessels with the primary mission of transporting Marines” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab403bb3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab403bb4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Baseline Assessment and Requirement Required","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tX/s1017/c"},"text":"Pub. L. 117–81, div. A, title X, § 1017(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1897"},"text":"135 Stat. 1897","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dA/tX/s1017/c"},"text":"“The date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":"] is deemed to be a covered event for the purposes of establishing a baseline battle force ship assessment and requirement under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8695"},"text":"section 8695 of title 10","children":[],"tail":", United States Code, as added by subsection (a) [enacting this section].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
