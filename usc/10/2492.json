{"tag":"section","attrib":{"id":"ida984a8e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2492"},"text":null,"children":[{"tag":"num","attrib":{"value":"2492"},"text":"§ 2492.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonappropriated fund instrumentalities: contracts with other agencies and instrumentalities to provide and obtain goods and services","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An agency or instrumentality of the Department of Defense that supports the operation of the exchange system, or the operation of a morale, welfare, and recreation system, of the Department of Defense may enter into a contract or other agreement with another element of the Department of Defense or with another Federal department, agency, or instrumentality—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida984a8ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2492/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide or obtain goods and services beneficial to the efficient management and operation of the exchange system or that morale, welfare, and recreation system; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida984a8eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2492/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide or obtain food services beneficial to the efficient management and operation of the dining facilities on military installations offering food services to members of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida984a8ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tIII/s341/a/1"},"text":"Pub. L. 104–201, div. A, title III, § 341(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2488"},"text":"110 Stat. 2488","children":[],"tail":", § 2482a; renumbered § 2492, "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVI/s651/c/3"},"text":"Pub. L. 108–375, div. A, title VI, § 651(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1972"},"text":"118 Stat. 1972","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tVI/s632"},"text":"Pub. L. 113–291, div. A, title VI, § 632","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3405"},"text":"128 Stat. 3405","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida984a8ed-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida984a8ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida984a8ef-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2492 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2489"},"text":"section 2489 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida984a8f0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" substituted “Federal department, agency, or instrumentality—” for “Federal department, agency, or instrumentality to provide or obtain goods and services beneficial to the efficient management and operation of the exchange system or that morale, welfare, and recreation system.” and added pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2482a"},"text":"section 2482a of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
