{"tag":"section","attrib":{"id":"idaa0a2cb0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3135"},"text":null,"children":[{"tag":"num","attrib":{"value":"3135"},"text":"§ 3135.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comparable budgeting for common procurement weapon systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa0a2cb1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3135/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matters To Be Included in Annual Defense Budgets","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In preparing the defense budget for any fiscal year, the Secretary of Defense shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa0a2cb2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3135/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifically identify each common procurement weapon system included in the budget;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa0a2cb3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3135/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take all feasible steps to minimize variations in procurement unit costs for any such system as shown in the budget requests of the different armed forces requesting procurement funds for the system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa0a2cb4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3135/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and justify in the budget all such variations in procurement unit costs for common procurement weapon systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa0a2cb5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3135/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comptroller","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall carry out this section through the Under Secretary of Defense (Comptroller).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa0a2cb6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3135/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa0a2cb7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3135/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “defense budget” means the budget of the Department of Defense included in the President’s budget submitted to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":" for a fiscal year."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa0a2cb8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3135/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “common procurement weapon system” means a weapon system for which two or more of the Army, Navy, Air Force, Marine Corps, and Space Force request procurement funds in a defense budget.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa0a2cb9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/370/s1/d/3/A"},"text":"Pub. L. 100–370, § 1(d)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-07-19"},"text":"July 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/843"},"text":"102 Stat. 843","children":[],"tail":", § 2217; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1503/a/20"},"text":"Pub. L. 104–106, div. A, title XV, § 1503(a)(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/512"},"text":"110 Stat. 512","children":[],"tail":"; renumbered § 3135 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/1/N"},"text":"Pub. L. 116–283, div. A, title IX, § 924(b)(1)(N)","children":[],"tail":", title XVIII, § 1809(f)(1), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3820"},"text":"134 Stat. 3820","children":[],"tail":", 4161.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa0a2cba-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaa0a2cbb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section is based on ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/c/tX/s955"},"text":"Pub. L. 99–500, § 101(c) [title X, § 955]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-1