{"tag":"section","attrib":{"id":"idabb9d7d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14706"},"text":null,"children":[{"tag":"num","attrib":{"value":"14706"},"text":"§ 14706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of total years of service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabb9d7d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this chapter and chapter 1407 of this title, a Reserve officer’s years of service include all service of the officer as a commissioned officer of a uniformed service other than the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb9d7d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14706/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Service as a warrant officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb9d7da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14706/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Constructive service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb9d7db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14706/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Service after appointment as a commissioned officer of a reserve component while in a program of advanced education to obtain the first professional degree required for appointment, designation, or assignment to a professional specialty, but only if that service occurs before the officer commences initial service on active duty or initial service in the Ready Reserve in the specialty that results from such a degree.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb9d7dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The exclusion under subsection (a)(3) does not apply to service performed by an officer who previously served on active duty or participated as a member of the Ready Reserve in other than a student status for the period of service preceding the member’s service in a student status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb9d7dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of subsection (a)(3), an officer shall be considered to be in a professional specialty if the officer is appointed or assigned to the Medical Corps, the Dental Corps, the Veterinary Corps, the Medical Service Corps, the Nurse Corps, or the Army Medical Specialists Corps or is designated as a chaplain or judge advocate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabb9d7de-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2957"},"text":"108 Stat. 2957","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s515"},"text":"Pub. L. 106–65, div. A, title V, § 515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/594"},"text":"113 Stat. 594","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb9d7df-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabb9d7e0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idabb9d7e1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 3853 and 8853 of this title, prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1629/a/3"},"text":"Pub. L. 103–337, § 1629(a)(3)","children":[],"tail":", (c)(3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabb9d7e2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" amended text generally. Prior to amendment, text read as follows: “For the purpose of this chapter and chapter 1407 of this title, a reserve officer’s years of service include all service, other than constructive service, of the officer as a commissioned officer of any uniformed service (other than service as a warrant officer).”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabb9d7e3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabb9d7e4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691/b/1"},"text":"section 1691(b)(1) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
