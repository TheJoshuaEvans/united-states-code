{"tag":"section","attrib":{"id":"ida8e02b46-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1512"},"text":null,"children":[{"tag":"num","attrib":{"value":"1512"},"text":"§ 1512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on State law","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8e02b47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1512/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonpreemption of State Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this chapter shall be construed to invalidate or limit the power of any State court or administrative entity, or the power of any court or administrative entity of any political subdivision thereof, to find or declare a person dead for purposes of such State or political subdivision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8e02b48-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1512/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “State” includes the District of Columbia, the Commonwealth of Puerto Rico, and any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8e02b49-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s569/b/1"},"text":"Pub. L. 104–106, div. A, title V, § 569(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/349"},"text":"110 Stat. 349","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
