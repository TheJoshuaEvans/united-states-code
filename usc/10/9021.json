{"tag":"section","attrib":{"id":"idab5a79e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021"},"text":null,"children":[{"tag":"num","attrib":{"value":"9021"},"text":"§ 9021.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Space Acquisition Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab5a79e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is in the Office of the Secretary of the Air Force a council to be known as the “Space Acquisition Council” (in this section referred to as the “Council”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab5a79e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The members of the Council are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab5a79e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5a79e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary of the Air Force for Space Acquisition and Integration, who shall act as chair of the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5a79e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary of Defense for Space Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5a79ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Reconnaissance Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5a79eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Space Operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5a79ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commander of the United States Space Command.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab5a79ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab5a79ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Council shall oversee, direct, and manage acquisition and integration space systems and programs of the armed forces in order to ensure integration across the national security space enterprise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5a79ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab5a79f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Council shall promptly—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idab5cc2e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review any determination made by the Assistant Secretary of the Air Force for Space Acquisition and Integration with respect to architecture for the space systems and programs of the armed forces under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9016/b/6/B/i"},"text":"section 9016(b)(6)(B)(i) of this title","children":[],"tail":", including the requirements for operating such space systems or programs; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab5cc2e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idab5cc2e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021/c/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Council finds such a determination to be warranted, certify the determination; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idab5cc2e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021/c/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Council finds such a determination not to be warranted, decline to certify the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab5cc2e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 10 business days after the date on which the Council makes a finding with respect to a certification under subparagraph (A), the Council shall submit to the congressional defense committees a notification of the finding, including a detailed justification for the finding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab5cc2e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (D), the Assistant Secretary of the Air Force for Space Acquisition and Integration may not take any action to implement a determination referred to in subparagraph (A)(i) until 30 days has elapsed following the date on which the Council submits the notification under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab5cc2e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idab5cc2e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021/c/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may waive subparagraph (C) in the event of an urgent national security requirement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab5cc2e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021/c/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall submit to the congressional defense committees a notification of any waiver granted under clause (i), including a justification for the waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab5cc2ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council shall meet not less frequently than monthly.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab5cc2eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9021/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the end of each calendar year quarter through the first calendar year quarter of 2025, the Council shall submit to the congressional defense committees a report on the activities of the Council during the calendar year quarter preceding the calendar year quarter in which such report is submitted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab5cc2ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s954/a/2"},"text":"Pub. L. 116–92, div. A, title IX, § 954(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1564"},"text":"133 Stat. 1564","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVI/s1602/a/1"},"text":"Pub. L. 117–81, div. A, title XVI, § 1602(a)(1)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2075"},"text":"135 Stat. 2075","children":[],"tail":", 2076.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab5cc2ed-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab5cc2ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab5cc2ef-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 9021 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9021a"},"text":"section 9021a of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 9021 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9371"},"text":"section 9371 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 9021, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/558"},"text":"70A Stat. 558","children":[],"tail":", related to appointments in professional and scientific service, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s36B/30"},"text":"Pub. L. 85–861, § 36B(30)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1571"},"text":"72 Stat. 1571","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab5cc2f0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1602/a/1/A"},"text":"Pub. L. 117–81, § 1602(a)(1)(A)","children":[],"tail":", struck out “Force” before “Acquisition” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1602/a/1/B"},"text":"Pub. L. 117–81, § 1602(a)(1)(B)","children":[],"tail":", substituted “ ‘Space Acquisition Council’ ” for “ ‘Space Force Acquisition Council’ ”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1602/b/1"},"text":"Pub. L. 117–81, § 1602(b)(1)","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1602/a/1/C"},"text":"Pub. L. 117–81, § 1602(a)(1)(C)","children":[],"tail":", substituted “space systems and programs of the armed forces” for “of the Air Force for space systems and programs”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab5cc2f1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab5cc2f2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVI/s1602/a/4"},"text":"Pub. L. 117–81, div. A, title XVI, § 1602(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2076"},"text":"135 Stat. 2076","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dA/tXVI/s1602/a/4"},"text":"“Any reference to the Space Force Acquisition Council in any law, regulation, map, document, record, or other paper of the United States shall be deemed to be a reference to the Space Acquisition Council.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
