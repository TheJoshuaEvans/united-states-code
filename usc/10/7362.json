ull,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3992","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:594 (last 39 words of 1st proviso).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1004 (30 words before proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1941-08-21/ch384/s5"},"text":"Aug. 21, 1941, ch. 384, § 5","children":[],"tail":" (last 39 words of 1st proviso); restated "},{"tag":"html:a","attrib":{"href":"/us/act/1948-06-29/ch708/s203/c"},"text":"June 29, 1948, ch. 708, § 203(c)","children":[],"tail":" (last 39 words of 1st proviso), "},{"tag":"html:a","attrib":{"href":"/us/stat/62/1085"},"text":"62 Stat. 1085","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1954-05-29/ch249/s19/f"},"text":"May 29, 1954, ch. 249, § 19(f)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/68/167"},"text":"68 Stat. 167","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1948-06-29/ch708/s203/e"},"text":"June 29, 1948, ch. 708, § 203(e)","children":[],"tail":" (30 words before proviso), "},{"tag":"html:a","attrib":{"href":"/us/stat/62/1086"},"text":"62 Stat. 1086","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “basic pay * * * as the case may be” are inserted to conform to the terminology of the Career Compensation Act of 1949, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/63/802"},"text":"63 Stat. 802","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t37/s231"},"text":"37 U.S.C. 231","children":[],"tail":" et seq.). The words “at the rate prescribed by law for his length of service”, in 10:1004, are omitted as covered by the words “base and longevity pay”. The words “base and longevity pay” are retained to cover the cases of members retired before the enactment of the Career Compensation Act of 1949, and advanced on the retired list after the enactment of that act. The words “and disregard a part of a year that is less than six months” are inserted to conform to footnote 4 of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3991"},"text":"section 3991 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaae597f7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1982 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 10:3992 to correct an inadvertent error in the codification of title 10 in 1956 relating to retirement pay of warrant officers advanced on the retired list. For further details, see the explanation for amendment of 10:1405 made by section 1(17).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaae597f8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisi