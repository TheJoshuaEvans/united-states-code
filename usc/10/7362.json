hildren":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/455"},"text":"70A Stat. 455","children":[],"tail":", related to advancement of funds by the Secretary of the Navy to private companies for salvage operations, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/tII/s2001/j/1"},"text":"Pub. L. 103–355, title II, § 2001(j)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3303"},"text":"108 Stat. 3303","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3808"},"text":"section 3808 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 7365, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/456"},"text":"70A Stat. 456","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1972-08-29"},"text":"Aug. 29, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/417/s1/4"},"text":"Pub. L. 92–417, § 1(4)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/654"},"text":"86 Stat. 654","children":[],"tail":", related to settlement of claims, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8703"},"text":"section 8703 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 7366, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/456"},"text":"70A Stat. 456","children":[],"tail":", related to limitation on appropriations for naval salvage facilities, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tVIII/s824/a/10"},"text":"Pub. L. 103–160, div. A, title VIII, § 824(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1708"},"text":"107 Stat. 1708","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 7367, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/456"},"text":"70A Stat. 456","children":[],"tail":", related to disposition of receipts, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8704"},"text":"section 8704 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaae597fa-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s808/b/14"},"text":"Pub. L. 115–232, § 808(b)(14)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3992"},"text":"section 3992 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 7344” for “section 3964”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" amended section generally. Prior to amendment, section contained table with two formulas for recomputing retired pay of enlisted members and warrant officers of Army to reflect advancement on retired list."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/348"},"text":"Pub. L. 99–348","children":[],"tail":" revised table generally by striking out provision in column 1 that for a person who first became a member of a uniformed service, as defined in section 1407(a)(2), after "},{"tag":"date","attrib":{"date":"1980-09-07"},"text":"Sept. 7, 1980","children":[],"tail":", one multiplier is the monthly retired pay base as computed under section 1407(c), substituting in formulas A and B provision that the retired pay base as computed under section 1406(c) or 1407 of this title be multiplied by the retired pay multiplier prescribed in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1409"},"text":"section 1409 of this title","children":[],"tail":" for the number of years credited for provisions that the monthly basic pay or base and longevity pay, as the case may be, subject to footnote 1, of the grade to which the member is advanced on the retired list be multiplied by 2½% of years of service credited, subject to footnote 2, and have subtracted from it the excess over 75% of pay upon which the computation is based, struck out footnote 1, which provided that the computation be at the rate applicable on the date of retirement, and redesignated footnote 2 as 1 and substituted “In determining retired pay multiplier” for “Before applying percentage factor” and “1/12” for “one-twelfth”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/s922/a/8"},"text":"Pub. L. 98–94, § 922(a)(8)","children":[],"tail":", inserted “The amount recomputed, if not a multiple of $1, shall be rounded to the next lower multiple of $1.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/s923/a/1"},"text":"Pub. L. 98–94, § 923(a)(1)","children":[],"tail":", (2)(G), in footnote 2 of table, substituted “Before applying percentage factor, credit each full month of service that is in addition to the number of full years of service creditable to the member as one-twelfth of a year and disregard any remaining fractional part of a month” for “Before applying percentage factor, credit a part of a year that is six months or more as a whole year, and disregard a part of a year that is less than six months”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" added formula B, applicable to warrant officers."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" in heading for column 1 of table substituted “after "},{"tag":"date","attrib":{"date":"1980-09-07"},"text":"September 7, 1980","children":[],"tail":"” for “on or after the date of the enactment of the Department of Defense Authorization Act, 1981”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/342"},"text":"Pub. L. 96–342","children":[],"tail":" in heading for column 1 of table inserted provisions respecting applicability to persons becoming members after the date of the enactment of the Department of Defense Authorization Act, 1981."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaae597fb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaae597fc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"t