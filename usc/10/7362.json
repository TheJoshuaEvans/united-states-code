{"tag":"section","attrib":{"id":"idaae597ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7362"},"text":null,"children":[{"tag":"num","attrib":{"value":"7362"},"text":"§ 7362.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recomputation of retired pay to reflect advancement on retired list","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaae597ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7362/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Entitlement to Recomputation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An enlisted member or warrant officer of the Army who is advanced on the retired list under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7344"},"text":"section 7344 of this title","children":[],"tail":" is entitled to recompute his retired pay in accordance with this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaae597ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7362/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Formula","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The monthly retired pay of a member entitled to recompute that pay under this section is computed by multiplying—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaae597f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7362/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the member’s retired pay base (as computed under section 1406(c) or 1407 of this title), by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaae597f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7362/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the retired pay multiplier prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1409"},"text":"section 1409 of this title","children":[],"tail":" for the number of years credited to the member under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1405"},"text":"section 1405 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaae597f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7362/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rounding to Next Lower Dollar","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount computed under subsection (b), if not a multiple of $1, shall be rounded to the next lower multiple of $1.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaae597f3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/233"},"text":"70A Stat. 233","children":[],"tail":", § 3992; "},{"tag":"ref","attrib":{"href":"/us/pl/96/342/tVIII/s813/c"},"text":"Pub. L. 96–342, title VIII, § 813(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1104"},"text":"94 Stat. 1104","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s512/10"},"text":"Pub. L. 96–513, title V, § 512(10)","children":[],"tail":", "},{"tag":"date","attrib":{"dat