{"tag":"section","attrib":{"id":"idab1c8650-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8321"},"text":null,"children":[{"tag":"num","attrib":{"value":"8321"},"text":"§ 8321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers: 40 years","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab1c8651-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each officer of the Regular Navy or the Regular Marine Corps holding a permanent appointment in the grade of warrant officer, W–1, or above who applies for retirement after completing 40 or more years of active service shall be retired by the Secretary of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1c8652-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this section, an officer’s years of active service are computed by adding all his active service in the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab1c8653-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/393"},"text":"70A Stat. 393","children":[],"tail":", § 6321; renumbered § 8321, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/15"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"