n":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s381"},"text":"34 U.S.C. 381","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 1443; ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1948-06-17/ch497/s1/a"},"text":"June 17, 1948, ch. 497, § 1(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/62/477"},"text":"62 Stat. 477","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s879"},"text":"34 U.S.C. 879","children":[],"tail":" (less applicability to enlisted men)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1920-06-04/ch228/s3"},"text":"June 4, 1920, ch. 228, § 3","children":[],"tail":" (3d proviso, less applicability to enlisted men), "},{"tag":"html:a","attrib":{"href":"/us/stat/41/835"},"text":"41 Stat. 835","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s626–1/a"},"text":"34 U.S.C. 626–1(a)","children":[],"tail":" (1st sentence)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1947-08-07/ch512/s314/a"},"text":"Aug. 7, 1947, ch. 512, § 314(a)","children":[],"tail":" (1st sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/61/863"},"text":"61 Stat. 863","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1954-05-05/ch180/s205"},"text":"May 5, 1954, ch. 180, § 205","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/68/68"},"text":"68 Stat. 68","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words “Regular” and “holding a permanent appointment in the grade of warrant officer, W–1, or above” are inserted for clarity. The word “shall” is substituted for the word “may” because the Attorney General has construed R.S. 1443 as conferring a right to retirement upon officers who apply for it after 40 years of service (30 Op. Atty. Gen. 406). The words “from active service” are omitted as surplusage. The words “after completing 40 or more years of active service” are substituted for the words “has been forty years in the service of the United States” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b) the accepted meaning of the words “service of the United States” is spelled out for clarity. They have been consistently interpreted to include active service in the armed forces as defined in this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab1c8657-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab1c8658-3a6f-11f1-a58a-d8db54b14ab5"},"text":