{"tag":"section","attrib":{"id":"ida76c2850-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s143"},"text":null,"children":[{"tag":"num","attrib":{"value":"143"},"text":"§ 143.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of the Secretary of Defense personnel: limitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida76c2851-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s143/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Permanent Limitation on OSD Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The number of OSD personnel may not exceed 4,300.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida76c2852-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s143/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" OSD ","children":[{"tag":"inline","attrib":{},"text":"Personnel Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term “OSD personnel” means military and civilian personnel of the Department of Defense who are assigned to, or employed in, functions in the Office of the Secretary of Defense (including Direct Support Activities of that Office and the Washington Headquarters Services of the Department of Defense).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida76c2853-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s143/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Reassignment of Functions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out reductions in the number of personnel assigned to, or employed in, the Office of the Secretary of Defense in order to comply with this section, the Secretary of Defense may not reassign functions solely in order to evade the requirements contained in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida76c2854-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tIX/s911/d/1"},"text":"Pub. L. 105–85, div. A, title IX, § 911(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1859"},"text":"111 Stat. 1859","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tIX/s921/c"},"text":"Pub. L. 106–65, div. A, title IX, § 921(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/723"},"text":"113 Stat. 723","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tIX/s903/a"},"text":"Pub. L. 114–328, div. A, title IX, § 903(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2344"},"text":"130 Stat. 2344","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s901/a/1"},"text":"Pub. L. 116–92, div. A, title IX, § 901(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1541"},"text":"133 Stat. 1541","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida76c2855-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida76c2856-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida76c2857-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section, as added by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":", consists of text of "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tIX/s903/a"},"text":"Pub. L. 104–201, div. A, title IX, § 903(a)","children":[],"tail":"–(f), "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2617"},"text":"110 Stat. 2617","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s903"},"text":"Section 903 of Pub. L. 104–201","children":[],"tail":", which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s131"},"text":"section 131 of this title","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tIX/s911/d/3"},"text":"Pub. L. 105–85, div. A, title IX, § 911(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1860"},"text":"111 Stat. 1860","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida76c2858-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s901/a/1/A"},"text":"Pub. L. 116–92, § 901(a)(1)(A)","children":[],"tail":", substituted “4,300” for “3,767”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s901/a/1/B"},"text":"Pub. L. 116–92, § 901(a)(1)(B)","children":[],"tail":", substituted “military and civilian personnel” for “military, civilian, and detailed personnel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" substituted “, civilian, and detailed personnel” for “and civilian personnel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s921/c/1"},"text":"Pub. L. 106–65, § 921(c)(1)","children":[],"tail":", substituted “The number” for “Effective "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"October 1, 1999","children":[],"tail":", the number” and “3,767” for “75 percent of the baseline number”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s921/c/2"},"text":"Pub. L. 106–65, § 921(c)(2)","children":[],"tail":", (3), redesignated subsec. (d) as (b) and struck out heading and text of former subsec. (b). Text read as follows: “The number of OSD personnel—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) as of ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"October 1, 1997","children":[],"tail":", may not exceed 85 percent of the baseline number; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) as of ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":", may not exceed 80 percent of the baseline number.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s921/c/2"},"text":"Pub. L. 106–65, § 921(c)(2)","children":[],"tail":", (3), redesignated subsec. (e) as (c) and struck out heading and text of former subsec. (c). Text read as follows: “For purposes of this section, the term ‘baseline number’ means the number of OSD personnel as of "},{"tag":"date","attrib":{"date":"1994-10-01"},"text":"October 1, 1994","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s921/c/3"},"text":"Pub. L. 106–65, § 921(c)(3)","children":[],"tail":", redesignated subsecs. (d) and (e) as (b) and (c), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s921/c/2"},"text":"Pub. L. 106–65, § 921(c)(2)","children":[],"tail":", struck out heading and text of subsec. (f). Text read as follows: “If the Secretary of Defense determines, and certifies to Congress, that the limitation in subsection (b) with respect to any fiscal year would adversely affect United States national security, the Secretary may waive the limitation under that subsection with respect to that fiscal year. If the Secretary of Defense determines, and certifies to Congress, that the limitation in subsection (a) during fiscal year 1999 would adversely affect United States national security, the Secretary may waive the limitation under that subsection with respect to that fiscal year. The authority under this subsection may be used only once, with respect to a single fiscal year.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida76c2859-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida76c285a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tIX/s921/c"},"text":"Pub. L. 106–65, div. A, title IX, § 921(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/723"},"text":"113 Stat. 723","children":[],"tail":", provided that the amendment made by section 921(c) is effective "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida76c285b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Exceptions and Adjustments to Limitations on Personnel","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title XI, § 1111, "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4619"},"text":"122 Stat. 4619","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tXI/s1109/a"},"text":"Pub. L. 111–84, div. A, title XI, § 1109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2492"},"text":"123 Stat. 2492","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/e/17"},"text":"Pub. L. 111–383, div. A, title X, § 1075(e)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4375"},"text":"124 Stat. 4375","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s809/b/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 809(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1840"},"text":"132 Stat. 1840","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/232/dA/tVIII/s809/b/1"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception to Limitations on Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For fiscal year 2009 and fiscal years thereafter, the baseline personnel limitations in sections 143, 194, 7014, 8014, and 9014 of title 10, United States Code (as adjusted pursuant to subsection (b)), shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition personnel hired pursuant to the expedited hiring authority provided in section 1705(h) [now 1705(g)] of title 10, United States Code, as amended by section 833 of this Act, or otherwise hired with funds in the Department of Defense Acquisition Workforce Development Fund established in accordance with section 1705(a) of such title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel hired pursuant to a shortage category designation by the Secretary of Defense or the Director of the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Adjust Limitations on Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For fiscal year 2009 and fiscal years thereafter, the Secretary of Defense or a Secretary of a military department may adjust the baseline personnel limitations in sections 143, 194, 3014, 5014 and 8014 of title 10, United States Code, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fill a gap in the civilian workforce of the Department of Defense identified by the Secretary of Defense in a strategic human capital plan submitted to Congress in accordance with the requirements of [former] section 115b of such title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" accommodate increases in workload or modify the type of personnel required to accomplish work, for any of the following purposes:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Performance of inherently governmental functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Performance of work pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2463"},"text":"section 2463 of title 10","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ability to maintain sufficient organic expertise and technical capability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Performance of work that, while the position may not exercise an inherently governmental function, nevertheless should be performed only by officers or employees of the Federal Government or members of the Armed Forces because of the critical nature of the work.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
