{"tag":"section","attrib":{"id":"idaa863a46-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657"},"text":null,"children":[{"tag":"num","attrib":{"value":"4657"},"text":"§ 4657.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on criminal history inquiries by contractors prior to conditional offer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa863a47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Criminal History Inquiries.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa863a48-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraphs (2) and (3), the head of an agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa863a49-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not require that an individual or sole proprietor who submits a bid for a contract to disclose criminal history record information regarding that individual or sole proprietor before determining the apparent awardee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa863a4a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall require as a condition of receiving a Federal contract and receiving payments under such contract that the contractor may not verbally or through written form request the disclosure of criminal history record information regarding an applicant for a position related to work under such contract before such contractor extends a conditional offer to the applicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa863a4b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Otherwise required by law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The prohibition under paragraph (1) does not apply with respect to a contract if consideration of criminal history record information prior to a conditional offer with respect to the position is otherwise required by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa863a4c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for certain positions.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa863a4d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The prohibition under paragraph (1) does not apply with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa863a4e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contract that requires an individual hired under the contract to access classified information or to have sensitive law enforcement or national security duties; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa863a4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position that the Secretary of Defense identifies under the regulations issued under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa863a50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idaa863a51-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issuance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 16 months after the date of enactment of the Fair Chance to Compete for Jobs Act of 2019, the Secretary of Defense, in consultation with the Administrator of General Services, shall issue regulations identifying additional positions with respect to which the prohibition under paragraph (1) shall not apply, giving due consideration to positions that involve interaction with minors, access to sensitive information, or managing financial transactions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa863a52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance with civil rights laws","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations issued under clause (i) shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idaa863a53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/a/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be consistent with, and in no way supersede, restrict, or limit the application of title VII of the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e"},"text":"42 U.S.C. 2000e","children":[],"tail":" et seq.) or other relevant Federal civil rights laws; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idaa863a54-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/a/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that all hiring activities conducted pursuant to the regulations are conducted in a manner consistent with relevant Federal civil rights laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa863a55-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Complaint Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall establish and publish procedures under which an applicant for a position with a Department of Defense contractor may submit a complaint, or any other information, relating to compliance by the contractor with subsection (a)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa863a56-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Action for Violations of Prohibition on Criminal History Inquiries.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa863a57-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"First violation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary of Defense determines that a contractor has violated subsection (a)(1)(B), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa863a58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the contractor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa863a59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide 30 days after such notification for the contractor to appeal the determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa863a5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue a written warning to the contractor that includes a description of the violation and the additional remedies that may apply for subsequent violations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa863a5b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsequent violations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary of Defense determines that a contractor that was subject to paragraph (1) has committed a subsequent violation of subsection (a)(1)(B), the Secretary shall notify the contractor, shall provide 30 days after such notification for the contractor to appeal the determination, and, in consultation with the relevant Federal agencies, may take actions, depending on the severity of the infraction and the contractor’s history of violations, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa863a5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing written guidance to the contractor that the contractor’s eligibility for contracts requires compliance with this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa863a5d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requiring that the contractor respond within 30 days affirming that the contractor is taking steps to comply with this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa863a5e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspending payment under the contract for which the applicant was being considered until the contractor demonstrates compliance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa863a5f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa863a60-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditional offer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “conditional offer” means an offer of employment for a position related to work under a contract that is conditioned upon the results of a criminal history inquiry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa863a61-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4657/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal history record information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “criminal history record information” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s9201"},"text":"section 9201 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa863a62-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXI/s1123/b/1"},"text":"Pub. L. 116–92, div. A, title XI, § 1123(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1612"},"text":"133 Stat. 1612","children":[],"tail":", § 2339; renumbered § 4657, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1862/b"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1862(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4277"},"text":"134 Stat. 4277","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa863a63-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa863a64-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaa863a65-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Fair Chance to Compete for Jobs Act of 2019, referred to in subsec. (a)(3)(B)(i), is the date of enactment of subtitle B of title XI of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Civil Rights Act of 1964, referred to in subsec. (a)(3)(B)(ii)(I), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352"},"text":"Pub. L. 88–352","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/241"},"text":"78 Stat. 241","children":[],"tail":". Title VII of the Act is classified generally to subchapter VI (§ 2000e et seq.) of chapter 21 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000a"},"text":"section 2000a of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa863a66-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4657 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7657"},"text":"section 7657 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa863a67-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2339"},"text":"section 2339 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa863a68-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa863a69-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa863a6a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXI/s1123/b/2"},"text":"Pub. L. 116–92, div. A, title XI, § 1123(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1614"},"text":"133 Stat. 1614","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1862/c/3/A"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1862(c)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4278"},"text":"134 Stat. 4278","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dA/tXVIII/s1862/c/3/A"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4657/a"},"text":"Section 4657(a) of title 10","children":[],"tail":", United States Code, as added by paragraph (1), shall apply with respect to contracts awarded pursuant to solicitations issued after the effective date described in section 1122(b)(2) of this subtitle [2 years after "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", see Effective Date note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s9202"},"text":"section 9202 of Title 5","children":[],"tail":", Government Organization and Employees].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa863a6b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Revisions to Federal Acquisition Regulation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXI/s1123/c"},"text":"Pub. L. 116–92, div. A, title XI, § 1123(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1614"},"text":"133 Stat. 1614","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1862/c/3/B"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1862(c)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4278"},"text":"134 Stat. 4278","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dA/tXVIII/s1862/c/3/B"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 18 months after the date of enactment of this subtitle [","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"], the Federal Acquisition Regulatory Council shall revise the Federal Acquisition Regulation to implement "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s4714"},"text":"section 4714 of title 41","children":[],"tail":", United States Code, and "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4657"},"text":"section 4657 of title 10","children":[],"tail":", United States Code, as added by this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consistency with office of personnel management regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Acquisition Regulatory Council shall revise the Federal Acquisition Regulation under paragraph (1) to be consistent with the regulations issued by the Director of the Office of Personnel Management under section 1122(b)(1) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s9201"},"text":"5 U.S.C. 9201","children":[],"tail":" note] to the maximum extent practicable. The Council shall include together with such revision an explanation of any substantive modification of the Office of Personnel Management regulations, including an explanation of how such modification will more effectively implement the rights and protections under this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
