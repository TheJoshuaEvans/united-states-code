{"tag":"section","attrib":{"id":"ida81a4279-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s839"},"text":null,"children":[{"tag":"num","attrib":{"value":"839"},"text":"§ 839.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 39. Sessions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida81a427a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s839/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" At any time after the service of charges which have been referred for trial to a court-martial composed of a military judge and members, the military judge may, subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s835"},"text":"section 835 of this title","children":[],"tail":" (article 35), call the court into session without the presence of the members for the purpose of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida81a427b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s839/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hearing and determining motions raising defenses or objections which are capable of determination without trial of the issues raised by a plea of not guilty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81a427c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s839/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hearing and ruling upon any matter which may be ruled upon by the military judge under this chapter, whether or not the matter is appropriate for later consideration or decision by the members of the court;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81a427d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s839/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holding the arraignment and receiving the pleas of the accused;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81a427e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s839/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting a sentencing proceeding and sentencing the accused under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s853/b/1"},"text":"section 853(b)(1) of this title","children":[],"tail":" (article 53(b)(1)); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81a427f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s839/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing any other procedural function which may be performed by the military judge under this chapter or under rules prescribed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s836"},"text":"section 836 of this title","children":[],"tail":" (article 36) and which does not require the presence of the members of the court."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida81a4280-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s839/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Proceedings under subsection (a) shall be conducted in the presence of the accused, the defense counsel, and the trial counsel and shall be made a part of the record. These proceedings may be conducted notwithstanding the number of members of the court and without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s829"},"text":"section 829 of this title","children":[],"tail":" (article 29). If authorized by regulations of the Secretary concerned, and if at least one defense counsel is physically in the presence of the accused, the presence required by this subsection may otherwise be established by audiovisual technology (such as videoteleconferencing technology)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida81a4281-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s839/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the members of a court-martial deliberate or vote, only the members may be present. All other proceedings, including any other consultation of the members of the court with counsel or the military judge, shall be made a part of the record and shall be in the presence of the accused, the defense counsel, the trial counsel, and the military judge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida81a4282-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s839/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The findings, holdings, interpretations, and other precedents of military commissions under chapter 47A of this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida81a4283-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s839/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be introduced or considered in any hearing, trial, or other proceeding of a court-martial under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81a4284-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s839/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not form the basis of any holding, decision, or other determination of a court-martial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida81a4285-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/51"},"text":"70A Stat. 51","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/632/s2/15"},"text":"Pub. L. 90–632, § 2(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-24"},"text":"Oct. 24, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1338"},"text":"82 Stat. 1338","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tV/s541/a"},"text":"Pub. L. 101–510, div. A, title V, § 541(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1565"},"text":"104 Stat. 1565","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s556"},"text":"Pub. L. 109–163, div. A, title V, § 556","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3266"},"text":"119 Stat. 3266","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tXVIII/s1803/a/2"},"text":"Pub. L. 111–84, div. A, title XVIII, § 1803(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2612"},"text":"123 Stat. 2612","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLVII/s5222"},"text":"Pub. L. 114–328, div. E, title LVII, § 5222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2909"},"text":"130 Stat. 2909","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1081/c/1/D"},"text":"Pub. L. 115–91, div. A, title X, § 1081(c)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1598"},"text":"131 Stat. 1598","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida81a4286-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida81a4287-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida81a4288-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"839","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:614.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-05-05/ch169/s1"},"text":"May 5, 1950, ch. 169, § 1","children":[],"tail":" (Art. 39), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/121"},"text":"64 Stat. 121","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “When” is substituted for the word “Whenever”. The words “deliberates or votes” are substituted for the words “is to deliberate or vote”. The word “may” is substituted for the word “shall”. The word “shall” is inserted before the words “be in the presence” for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida81a4289-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida81a428a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" substituted “under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s853/b/1"},"text":"section 853(b)(1) of this title","children":[],"tail":" (article 53(b)(1))” for “in non-capital cases unless the accused requests sentencing by members under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s825"},"text":"section 825 of this title","children":[],"tail":" (article 25)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5222/1/A"},"text":"Pub. L. 114–328, § 5222(1)(A)","children":[],"tail":", struck out “if permitted by regulations of the Secretary concerned,” before “holding” and “and” after “accused;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5222/1/B"},"text":"Pub. L. 114–328, § 5222(1)(B)","children":[],"tail":", (C), added par. (4) and redesignated former par. (4) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5222/2"},"text":"Pub. L. 114–328, § 5222(2)","children":[],"tail":", struck out “, in cases in which a military judge has been detailed to the court,” after “the trial counsel, and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" redesignated concluding provisions of subsec. (a) as subsec. (b), substituted “Proceedings under subsection (a) shall be conducted” for “These proceedings shall be conducted”, inserted at end “If authorized by regulations of the Secretary concerned, and if at least one defense counsel is physically in the presence of the accused, the presence required by this subsection may otherwise be established by audiovisual technology (such as videoteleconferencing technology).”, and redesignated former subsec. (b) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" inserted at end “These proceedings may be conducted notwithstanding the number of members of the court and without regard to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s829"},"text":"section 829 of this title","children":[],"tail":" (article 29).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/632"},"text":"Pub. L. 90–632","children":[],"tail":" added subsec. (a), designated existing provisions as subsec. (b), substituted “military judge” for “law officer”, and struck out provisions authorizing the court after voting on the findings in a general court-martial to request the law officer and the reporter to appear before the court to put the findings in proper form."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida81a428b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida81a428c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" effective immediately after the amendments made by div. E (§§ 5001–5542) of "},{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" take effect as provided for in section 5542 of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"10 U.S.C. 801","children":[],"tail":" note), see "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1081/c/4"},"text":"section 1081(c)(4) of Pub. L. 115–91","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida81a428d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. No. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida81a428e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tV/s541/e"},"text":"Pub. L. 101–510, div. A, title V, § 541(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1565"},"text":"104 Stat. 1565","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/510/dA/tV/s541/e"},"text":"“The amendments made by subsections (a) through (d) [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s841"},"text":"section 841 of this title","children":[],"tail":"] shall apply only to a court-martial convened on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida81a428f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/632"},"text":"Pub. L. 90–632","children":[],"tail":" effective first day of tenth month following October 1968, see "},{"tag":"ref","attrib":{"href":"/us/pl/90/632/s4"},"text":"section 4 of Pub. L. 90–632","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
