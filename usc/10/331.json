{"tag":"section","attrib":{"id":"ida79e347b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331"},"text":null,"children":[{"tag":"num","attrib":{"value":"331"},"text":"§ 331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Friendly foreign countries: authority to provide support for conduct of operations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida79e347c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may provide support to friendly foreign countries in connection with the conduct of operations designated pursuant to subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida79e347d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designated Operations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida79e347e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall designate the operations for which support may be provided under the authority in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida79e347f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall notify the appropriate committees of Congress of the designation of any operation pursuant to this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida79e3480-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual review for continuing designation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall undertake on an annual basis a review of the operations currently designated pursuant to this subsection in order to determine whether each such operation merits continuing designation for purposes of this section for another year. If the Secretary determines that any operation so reviewed merits continuing designation for purposes of this section for another year, the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida79e3481-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may continue the designation of such operation under this subsection for such purposes for another year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida79e3482-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary so continues the designation of such operation, shall notify the appropriate committees of Congress of the continuation of designation of such operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida79e3483-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Types of Support Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The types of support that may be provided under the authority in subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida79e3484-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Logistic support, supplies, and services to security forces of a friendly foreign country participating in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida79e3485-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an operation with the armed forces under the jurisdiction of the Secretary of Defense; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida79e3486-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a military or stability operation that benefits the national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida79e3487-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Logistic support, supplies, and services—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida79e3488-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to military forces of a friendly foreign country solely for the purpose of enhancing the interoperability of the logistical support systems of military forces participating in a combined operation with the United States in order to facilitate such operation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida79e3489-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a nonmilitary logistics, security, or similar agency of a friendly foreign government if such provision would directly benefit the armed forces under the jurisdiction of the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida79e348a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procurement of equipment for the purpose of the loan of such equipment to the military forces of a friendly foreign country participating in a United States-supported coalition or combined operation and the loan of such equipment to those forces to enhance capabilities or to increase interoperability with the armed forces under the jurisdiction of the Secretary of Defense and other coalition partners.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida79e348b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provision of specialized training to personnel of friendly foreign countries in connection with such an operation, including training of such personnel before deployment in connection with such operation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida79e348c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Small-scale construction to support military forces of a friendly foreign country participating in a United States-supported coalition or combined operation when the construction is directly linked to the ability of such forces to participate in such operation effectively and is limited to the geographic area where such operation is taking place. In the case of support provided under this paragraph that results in the provision of small-scale construction above $750,000, the notification pursuant to subsection (b)(2) shall include the location, project title, and cost of each such small-scale construction project that will be carried out, a Department of Defense Form 1391 for each such project, and a masterplan of planned infrastructure investments at the location.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida79e348d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification Required.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida79e348e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operations in which the united states is not participating","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may provide support under subsection (a) to a friendly foreign country with respect to an operation in which the United States is not participating only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida79e348f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary of Defense and the Secretary of State jointly certify to the appropriate committees of Congress that the operation is in the national security interests of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida79e3490-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the expiration of the 15-day period beginning on the date of such certification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida79e3491-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accompanying report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any certification under paragraph (1) shall be accompanied by a report that includes the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida79e3492-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the operation, including the geographic area of the operation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida79e3493-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A list of participating countries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida79e3494-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the type of support and the duration of support to be provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida79e3495-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the national security interests of the United States supported by the operation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida79e3496-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of each entity with which the applicable friendly foreign country is engaged in hostilities and whether each such entity is covered by an authorization for the use of military force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida79e3497-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other matters as the Secretary of Defense and the Secretary of State consider significant to a consideration of such certification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida79e3498-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary of State Concurrence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provision of support under subsection (a) may be made only with the concurrence of the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida79e3499-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support Otherwise Prohibited by Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may not use the authority in subsection (a) to provide any type of support described in subsection (c) that is otherwise prohibited by any provision of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida79e349a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations on Value.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida79e349b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The aggregate value of all logistic support, supplies, and services provided under paragraphs (1), (4), and (5) of subsection (c) in any fiscal year may not exceed $450,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida79e349c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The aggregate value of all logistic support, supplies, and services provided under subsection (c)(2) in any fiscal year may not exceed $5,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida79e349d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s331/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Logistic Support, Supplies, and Services Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “logistic support, supplies, and services” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2350/1"},"text":"section 2350(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida79e349e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tXII/s1201/a"},"text":"Pub. L. 109–364, div. A, title XII, § 1201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2410"},"text":"120 Stat. 2410","children":[],"tail":", § 127c; renumbered § 127d, "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tX/s1063/a/1/A"},"text":"Pub. L. 110–181, div. A, title X, § 1063(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/321"},"text":"122 Stat. 321","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/b/3"},"text":"Pub. L. 111–383, div. A, title X, § 1075(b)(3)","children":[],"tail":", title XII, § 1202, "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4369"},"text":"124 Stat. 4369","children":[],"tail":", 4385; renumbered § 331 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1245/a"},"text":"Pub. L. 114–328, div. A, title XII, § 1245(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2518"},"text":"130 Stat. 2518","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXII/s1203/b"},"text":"Pub. L. 115–232, div. A, title XII, § 1203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2016"},"text":"132 Stat. 2016","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tXII/s1202/a"},"text":"Pub. L. 117–263, div. A, title XII, § 1202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2823"},"text":"136 Stat. 2823","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida79e349f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida79e34a0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida79e34a1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 331 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s251"},"text":"section 251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida79e34a2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d)(2)(E), (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added subpar. (E) and redesignated former subpar. (E) as (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" inserted at end “In the case of support provided under this paragraph that results in the provision of small-scale construction above $750,000, the notification pursuant to subsection (b)(2) shall include the location, project title, and cost of each such small-scale construction project that will be carried out, a Department of Defense Form 1391 for each such project, and a masterplan of planned infrastructure investments at the location.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s127d"},"text":"section 127d of this title","children":[],"tail":" as this section and amended it generally. Prior to amendment, section related to authority to provide logistic support, supplies, and services to allied forces participating in combined operations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1202/a"},"text":"Pub. L. 111–383, § 1202(a)","children":[],"tail":", designated existing provisions as par. (1), inserted “of the United States” after “armed forces”, struck out “Provision of such support, supplies, and services to the forces of an allied nation may be made only with the concurrence of the Secretary of State.” at end, and added pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1202/b/1"},"text":"Pub. L. 111–383, § 1202(b)(1)","children":[],"tail":", substituted “subsection (a)(1)” for “subsection (a)” in par. (1) and in introductory provisions of par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1202/b/2/A"},"text":"Pub. L. 111–383, § 1202(b)(2)(A)","children":[],"tail":", substituted “The” for “Except as provided in paragraph (2), the” and “subsection (a)(1)” for “this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1202/b/2/B"},"text":"Pub. L. 111–383, § 1202(b)(2)(B)","children":[],"tail":", substituted “The value of the logistic support, supplies, and services provided under subsection (a)(2) in any fiscal year may not” for “In addition to any logistic support, supplies, and services provided under subsection (a) that are covered by paragraph (1), the value of logistic support, supplies, and services provided under this section solely for the purposes of enhancing the interoperability of the logistical support systems of military forces participating in combined operation of the United States in order to facilitate such operations may not, in any fiscal year,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1075/b/3"},"text":"Pub. L. 111–383, § 1075(b)(3)","children":[],"tail":", substituted “Committee on Foreign Affairs” for “Committee on International Relations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s127c"},"text":"section 127c of this title","children":[],"tail":", relating to allied forces participating in combined operations, as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida79e34a3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida79e34a4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Support for Execution of Bilateral Agreements Concerning Illicit Transnational Maritime Activity","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVIII/s1808"},"text":"Pub. L. 118–31, div. A, title XVIII, § 1808","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/688"},"text":"137 Stat. 688","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXII/s1201/b"},"text":"Pub. L. 118–159, div. A, title XII, § 1201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2093"},"text":"138 Stat. 2093","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tXII/s1201/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense, in coordination with the Commandant of the Coast Guard, and in consultation with the Secretary of State, may provide assistance to the Coast Guard for the execution of existing maritime law enforcement agreements between the United States and friendly countries that were established to combat transnational organized illegal maritime activity, including illegal, unreported, and unregulated fishing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on Military Training and Readiness","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall ensure that the provision of assistance under this section does not negatively affect military training, operations, readiness, or other military requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary of Defense provides assistance under subsection (a) during any fiscal year, the Secretary shall provide such assistance using amounts available for that fiscal year for the Department of Defense for operation and maintenance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term ‘assistance’ means any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use of surface and air assets as bases of operations and information collection platforms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Communication infrastructure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information sharing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provision of logistic support, supplies, and services (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2350"},"text":"section 2350 of title 10","children":[],"tail":", United States Code).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
