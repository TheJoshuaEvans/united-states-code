{"tag":"section","attrib":{"id":"ida9908f01-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608"},"text":null,"children":[{"tag":"num","attrib":{"value":"2608"},"text":"§ 2608.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of contributions for defense programs, projects, and activities; Defense Cooperation Account","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9908f02-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may accept from any person, foreign government, or international organization any contribution of money or real or personal property made by such person, foreign government, or international organization for use by the Department of Defense and may accept from any foreign government or international organization any contribution of services made by such foreign government or international organization for use by the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9908f03-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Defense Cooperation Account","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9908f04-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established in the Treasury of the United States a special account to be known as the “Defense Cooperation Account”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908f05-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contributions of money and proceeds from the sale of any property accepted by the Secretary of Defense under subsection (a) shall be credited to the Defense Cooperation Account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9908f06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of the Defense Cooperation Account","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9908f07-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds in the Defense Cooperation Account may be appropriated for a function described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s114"},"text":"section 114 of this title","children":[],"tail":" only to the extent that the appropriation of such funds for such purpose is authorized in accordance with that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908f08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds in the Defense Cooperation Account shall not be made available for obligation or expenditure except to the extent and in the manner provided in subsequent appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9908f09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Property","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any contribution of property received under this section may be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9908f0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retained and used by the Department of Defense in the form in which it was donated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908f0b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sold or otherwise disposed of upon such terms and conditions and in accordance with such procedures as the Secretary determines appropriate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908f0c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" converted into a form usable by the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9908f0d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9908f0e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 30 days after the end of the second quarter and the fourth quarter of each fiscal year, the Secretary of Defense shall submit to Congress a report on contributions of property accepted by the Secretary under this section during the preceding two quarters. The Secretary shall include in each such report a description of all property having a value of more than $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida993000f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In computing the value of any property referred to in paragraph (1), the Secretary shall aggregate the value of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9930010-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" similar items of property accepted by the Secretary during the quarter concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9930011-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" components which, if assembled, would comprise all or a substantial part of an item of equipment or a facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9930012-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Use Property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Property accepted under subsection (a) may be used by the Secretary of Defense without specific authorization, except that such property may not be used in connection with any program, project, or activity if the use of such property would result in the violation of any prohibition or limitation otherwise applicable to such program, project, or activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9930013-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Investment of Money","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9930014-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon request by the Secretary of Defense, the Secretary of the Treasury may invest money in the Defense Cooperation Account in securities of the United States or in securities guaranteed as to principal and interest by the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9930015-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any interest or other income that accrues from investment in securities referred to in paragraph (1) shall be deposited to the credit of the Defense Cooperation Account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9930016-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall notify Congress of any condition imposed by the donor on the use of any contribution accepted by the Secretary under the authority of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9930017-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Periodic Audits by","children":[],"tail":" GAO.—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General of the United States shall make periodic audits of money and property accepted under this section, at such intervals as the Comptroller General determines to be warranted. The Comptroller General shall submit to Congress a report on the results of each such audit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9930018-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Items Included as Contributions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “contribution” includes a devise of real property or a bequest of personal property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9930019-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2608/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida993001a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/403/tII/s202/a/1"},"text":"Pub. L. 101–403, title II, § 202(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/872"},"text":"104 Stat. 872","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tX/s1061/a/16"},"text":"Pub. L. 102–190, div. A, title X, § 1061(a)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1473"},"text":"105 Stat. 1473","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tXI/s1105/b/1"},"text":"Pub. L. 103–160, div. A, title XI, § 1105(b)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1750"},"text":"107 Stat. 1750","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tX/s1063"},"text":"Pub. L. 104–201, div. A, title X, § 1063","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2652"},"text":"110 Stat. 2652","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tX/s1064/7"},"text":"Pub. L. 112–81, div. A, title X, § 1064(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1587"},"text":"125 Stat. 1587","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida993001b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida993001c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida993001d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" substituted “the second quarter and the fourth quarter” for “each quarter” and “the preceding two quarters” for “the preceding quarter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" inserted before period at end “and may accept from any foreign government or international organization any contribution of services made by such foreign government or international organization for use by the Department of Defense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s1105/b/2"},"text":"Pub. L. 103–160, § 1105(b)(2)","children":[],"tail":", inserted “; Defense Cooperation Account” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s1105/b/1"},"text":"Pub. L. 103–160, § 1105(b)(1)","children":[],"tail":", substituted “Periodic Audits” for “Annual Audit” in heading and amended text generally. Prior to amendment, text read as follows: “The Comptroller General of the United States shall conduct an annual audit of money and property accepted by the Secretary of Defense under this section and shall submit a copy of the results of each such audit to Congress.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" inserted “(1)” before “Upon request”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
