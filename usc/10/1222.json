{"tag":"section","attrib":{"id":"ida8b2d993-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1222"},"text":null,"children":[{"tag":"num","attrib":{"value":"1222"},"text":"§ 1222.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Physical evaluation boards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8b2d994-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1222/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Response to Applications and Appeals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of each military department shall ensure, in the case of any member of the armed forces appearing before a physical evaluation board under that Secretary’s supervision, that documents announcing a decision of the board in the case convey the findings and conclusions of the board in an orderly and itemized fashion with specific attention to each issue presented by the member in regard to that member’s case. The requirement under the preceding sentence applies to a case both during initial consideration and upon subsequent consideration due to appeal by the member or other circumstance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8b2d995-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1222/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liaison Officer (PEBLO) Requirements and Training","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8b2d996-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1222/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense shall prescribe regulations establishing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8b2d997-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1222/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement for the Secretary of each military department to make available to members of the armed forces appearing before physical evaluation boards operated by that Secretary employees, designated as physical evaluation board liaison officers, to provide advice, counsel, and general information to such members on the operation of physical evaluation boards operated by that Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8b2d998-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1222/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards and guidelines concerning the training of such physical evaluation board liaison officers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8b2d999-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1222/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure compliance by the Secretary of each military department with physical evaluation board liaison officer requirements and training standards and guidelines at least once every three years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8b2d99a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1222/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standardized Staff Training and Operations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8b2d99b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1222/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense shall prescribe regulations on standards and guidelines concerning the physical evaluation board operated by each of the Secretaries of the military departments with regard to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8b2d99c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1222/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assignment and training of staff;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8b2d99d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1222/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operating procedures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8b2d99e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1222/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" timeliness of board decisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8b2d99f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1222/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure compliance with standards and guidelines prescribed under paragraph (1) by each physical evaluation board at least once every three years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8b2d9a0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s597/a/1"},"text":"Pub. L. 109–364, div. A, title V, § 597(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2236"},"text":"120 Stat. 2236","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8b2d9a1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8b2d9a2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8b2d9a3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s597/b"},"text":"Pub. L. 109–364, div. A, title V, § 597(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2237"},"text":"120 Stat. 2237","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/364/dA/tV/s597/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1222"},"text":"Section 1222 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to decisions rendered on cases commenced more than 120 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8b2d9a4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8b2d9a5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Quality Review of Medical Evaluation Boards, Physical Evaluation Boards, and Physical Evaluation Board Liaison Officers","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tV/s524"},"text":"Pub. L. 112–239, div. A, title V, § 524","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1723"},"text":"126 Stat. 1723","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s813/f"},"text":"Pub. L. 115–232, div. A, title VIII, § 813(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1851"},"text":"132 Stat. 1851","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/232/dA/tVIII/s813/f"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall standardize, assess, and monitor the quality assurance programs of the military departments to evaluate the following in the performance of their duties (including duties under chapter 61 of title 10, United States Code):","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Medical Evaluation Boards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Physical Evaluation Boards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Physical Evaluation Board Liaison Officers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Objectives","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The objectives of the quality assurance program shall be as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ensure accuracy and consistency in the determinations and decisions of Medical Evaluation Boards and Physical Evaluation Boards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To otherwise monitor and sustain proper performance of the duties of Medical Evaluation Boards and Physical Evaluation Boards, and of Physical Evaluation Board Liaison Officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other objectives as the Secretary shall specify for purposes of the quality assurance program.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[(c) Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s813/f"},"text":"Pub. L. 115–232, div. A, title VIII, § 813(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1851"},"text":"132 Stat. 1851","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
