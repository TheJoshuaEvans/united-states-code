{"tag":"section","attrib":{"id":"ida9908e62-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601"},"text":null,"children":[{"tag":"num","attrib":{"value":"2601"},"text":"§ 2601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General gift funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9908e63-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority to Accept Gifts","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9908e64-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may accept, hold, administer, and spend any gift, devise, or bequest of real property, personal property, or money made on the condition that the gift, devise, or bequest be used for the benefit, or in connection with, the establishment, operation, or maintenance, of a school, hospital, library, museum, cemetery, or other institution or organization under the jurisdiction of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908e65-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9908e66-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":", the Secretary concerned may accept a gift of services for a military museum program or a professional military education institution from a nonprofit entity established for the purpose of supporting a military museum program or a professional military education institution. Employees or personnel of a nonprofit entity who provide a gift of services under this subparagraph may not be considered to be employees of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9908e67-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the use and benefit of a military museum program, the Secretary concerned may solicit from a bona fide collector a gift of books, manuscripts, works of art, historical artifacts, drawings, plans, models, or condemned or obsolete combat materiel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9908e68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Authority to Accept Gifts to Benefit Certain Members, Dependents, and Civilian Employees","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9908e69-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary concerned may accept, hold, administer, and spend any gift, devise, or bequest of real property, personal property, money, or services made on the condition that the gift, devise, or bequest be used for the benefit of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9908e6a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the armed forces, including members performing full-time National Guard duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s502/f"},"text":"section 502(f) of title 32","children":[],"tail":", who incur a wound, injury, or illness while in the line of duty;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9908e6b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" civilian employees of the Department of Defense who incur a wound, injury, or illness while in the line of duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9908e6c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dependents of such members or employees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9908e6d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" survivors of such members or employees who are killed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908e6e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may not accept a gift of services from a foreign government or international organization under this subsection. A gift of real property, personal property, or money from a foreign government or international organization may be accepted under this subsection only if the gift is not designated for a specific individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908e6f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall prescribe regulations specifying the conditions that may be attached to a gift, devise, or bequest accepted under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9908e70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Gift Funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Gifts and bequests of money, and the proceeds of the sale of property, received under subsection (a) or (b) shall be deposited in the Treasury in the following accounts:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9908e71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of the Army General Gift Fund, in the case of deposits made by the Secretary of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908e72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of the Navy General Gift Fund, in the case of deposits made by the Secretary of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908e73-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of the Air Force General Gift Fund, in the case of deposits made by the Secretary of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908e74-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Coast Guard General Gift Fund, in the case of deposits made by the Secretary of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908e75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Defense General Gift Fund, in the case of deposits made by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9908e76-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Gifts; Prohibitions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9908e77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), property and money accepted under subsection (a) or (b) may be used by the Secretary concerned, and services accepted under such subsections may be performed, without further specific authorization in law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908e78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Property, money, and services may not be accepted under subsection (a) or (b)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9908e79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the use of the property or money or the performance of the services in connection with any program, project, or activity would result in the violation of any prohibition or limitation otherwise applicable to such program, project, or activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9908e7a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the conditions attached to the property, money, or services are inconsistent with applicable law or regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9908e7b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary concerned determines that the use of the property or money or the performance of the services would reflect unfavorably on the ability of the Department of Defense or the Coast Guard, any employee of the Department or Coast Guard, or any member of the armed forces to carry out any responsibility or duty in a fair and objective manner; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9908e7c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary concerned determines that the use of the property or money or the performance of the services would compromise the integrity or appearance of integrity of any program of the Department of Defense or Coast Guard, or any individual involved in such a program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908e7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may disburse funds deposited in a gift fund referred to in subsection (c) for the purposes specified in subsections (a) and (b), subject to the terms of the gift, devise, or bequest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9908e7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance of Property Gifts; Naming Rights","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9908e7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may accept a gift under subsection (a) or (b) consisting of the provision, acquisition, enhancement, or construction of real or personal property offered to an eligible entity even though the gift will be subject to the condition that the real or personal property, or a portion thereof, bear a specified name.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908e80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority conferred by this subsection may be delegated by the Secretary concerned only to a civilian official appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908e81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A gift may not be accepted under paragraph (1) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9908e82-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acceptance of the gift or the imposition of the naming-rights condition would reflect unfavorably upon the United States, as provided in subsection (d)(2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9908e83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the real or personal property to be subject to the condition, or portion thereof, has been named by an act of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908e84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretaries concerned shall issue uniform regulations governing the circumstances under which gifts conditioned on naming rights may be accepted, appropriate naming conventions, and suitable display standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908e85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection, the term “eligible entity” means each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9908e86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Military Academy, the Naval Academy, the Air Force Academy, and the Coast Guard Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9908e87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The professional military education schools listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2162/d"},"text":"section 2162(d) of this title","children":[],"tail":" and the Defense Acquisition University."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9908e88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/e/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A military museum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9908e89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may pay all necessary expenses in connection with the conveyance or transfer of a gift, devise, or bequest accepted under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9908e8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Gifts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purposes of Federal income, estate, and gift taxes, any property, money, or services accepted under subsection (a) or (b) shall be considered as a gift, devise, or bequest to or for the use of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9908e8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Management of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of each gift fund referred to in subsection (c), the Secretary of the Treasury, upon the request of the Secretary concerned, may retain money, securities, and the proceeds of the sale of securities in the gift fund and may invest money and reinvest the proceeds of the sale of securities in the gift fund in securities of the United States or in securities guaranteed as to principal and interest by the United States. The interest and profits accruing from those securities shall be deposited to the credit of the gift fund and may be disbursed as provided in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9908e8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comptroller General Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General shall make periodic audits of gifts, devises, and bequests accepted under subsection (a) or (b) at such intervals as the Comptroller General determines to be warranted. The Comptroller General shall submit to Congress a report on the results of each such audit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9908e8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9908e8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary concerned” includes the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908e8f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2601/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “services” includes activities that benefit the education, morale, welfare, or recreation of members of the armed forces and their dependents or are related or incidental to the conveyance of a gift, devise, or bequest of real property or personal property under subsection (a) or (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9908e90-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/144"},"text":"70A Stat. 144","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s511/86"},"text":"Pub. L. 96–513, title V, § 511(86)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2927"},"text":"94 Stat. 2927","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/b/1"},"text":"Pub. L. 107–296, title XVII, § 1704(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tIII/s374"},"text":"Pub. L. 109–163, div. A, title III, § 374","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3211"},"text":"119 Stat. 3211","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tV