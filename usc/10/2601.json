f deposited in the Treasury pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s150r"},"text":"section 150r of this title","children":[],"tail":"” are omitted as surplusage."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9908e94-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9908e95-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" inserted “or a professional military education institution” after “museum program” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s2821/a/1"},"text":"Pub. L. 116–283, § 2821(a)(1)","children":[],"tail":", struck out “Real” before “Property” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s2821/b/1"},"text":"Pub. L. 116–283, § 2821(b)(1)","children":[],"tail":", substituted “an eligible entity” for “the United States Military Academy, the Naval Academy, the Air Force Academy, or the Coast Guard Academy”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s2821/a/2"},"text":"Pub. L. 116–283, § 2821(a)(2)","children":[],"tail":", inserted “or personal” after “real” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s2821/a/3"},"text":"Pub. L. 116–283, § 2821(a)(3)","children":[],"tail":", inserted “or personal” after “real”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s2821/b/2"},"text":"Pub. L. 116–283, § 2821(b)(2)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsecs. (e) to (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" added subsec. (e) and redesignated former subsecs. (e) to (i) as (f) to (j), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s2852/a/1"},"text":"Pub. L. 112–239, § 2852(a)(1)","children":[],"tail":", designated existing provisions as par. (1), substituted “The” for “Subject to subsection (d)(2), the”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s2852/a/2/A"},"text":"Pub. L. 112–239, § 2852(a)(2)(A)","children":[],"tail":", substituted “The” for “Subject to subsection (d)(2), the” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s2852/a/2/B/i"},"text":"Pub. L. 112–239, § 2852(a)(2)(B)(i)","children":[],"tail":", substituted “such subsections” for “subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s2852/a/2/B/ii"},"text":"Pub. L. 112–239, § 2852(a)(2)(B)(ii)","children":[],"tail":", substituted “, money, and services may not be accepted under subsection (a) or” for “and money may not be accepted under subsection (a) and property, money, and services may not be accepted under subsection” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s2852/a/2/C"},"text":"Pub. L. 112–239, § 2852(a)(2)(C)","children":[],"tail":", substituted “, money, or services accepted under subsection (a) or” for “or money accepted under subsection (a) and any property, money, or services accepted under subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s587/a"},"text":"Pub. L. 112–239, § 587(a)","children":[],"tail":", inserted “education,” before “morale,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" struck out par. (4) which read as follows: “The authority to accept gifts, devises, or bequests under this subsection expires on "},{"tag":"date","attrib":{"date":"2007-12-31"},"text":"December 31, 2007","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" reenacted section catchline without change and amended text generally. Prior to amendment, section consisted of subsecs. (a) to (d) relating to general gift funds."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “Secretary of Homeland Security” for “Secretary of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “Secretary of Transportation” for “Secretary of the Treasury”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9908e96-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9908e97-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9908e98-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/b/3"},"text":"section 701(b)(3) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9908e99-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limitation on Solicitation of Gifts","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tV/s593/b"},"text":"Pub. L. 110–181, div. A, title V, § 593(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/138"},"text":"122 Stat. 138","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/181/dA/tV/s593/b"},"text":"“The Secretary of Defense shall prescribe regulations implementing sections 2601 and 2608 of title 10, United States Code, that prohibit the solicitation of any gift under such sections by any employee of the Department of Defense if the nature or circumstances of such solicitation would compromise the integrity or the appearance of integrity of any program of the Department of Defense or of any individual involved in such program.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
