{"tag":"section","attrib":{"id":"idab7be3ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462"},"text":null,"children":[{"tag":"num","attrib":{"value":"9462"},"text":"§ 9462.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support of athletic programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab7be3cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Corporation for Support Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab7be3d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Air Force may, in accordance with the laws of the State of incorporation, establish a corporation (in this section referred to as the “corporation”) to support the athletic programs of the Academy. All stock of the corporation shall be owned by the United States and held in the name of and voted by the Secretary of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be3d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The corporation shall operate exclusively for charitable, educational, and civic purposes to support the athletic programs of the Academy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7be3d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Corporate Organization","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The corporation shall be organized and operated—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab7be3d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a nonprofit corporation under section 501(c)(3) of the Internal Revenue Code of 1986;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be3d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be3d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to the laws of the State of incorporation, its articles of incorporation, and its bylaws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7be3d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Corporate Board of Directors","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab7be3d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The members of the board of directors of the corporation shall serve without compensation as members of the board, except for reasonable travel and other related expenses for attendance at meetings of the board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be3d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Air Force may authorize military and civilian personnel of the Department of the Air Force under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1033"},"text":"section 1033 of this title","children":[],"tail":" to serve, in their official capacities, as members of the board of directors of the corporation, but such personnel shall not hold more than one-third of the directorships."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7be3d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfers From Nonappropriated Fund Operation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Air Force may, subject to the acceptance of the corporation, transfer to the corporation all title to and ownership of the assets and liabilities of the Air Force nonappropriated fund instrumentality whose functions include providing support for the athletic programs of the Academy, including bank accounts and financial reserves in its accounts, equipment, supplies, and other personal property, but excluding any interest in real property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7be3da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance of Support.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab7be3db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support received from the corporation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":", the Secretary of the Air Force may accept from the corporation funds, supplies, equipment, and services for the support of the athletic programs of the Academy."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be3dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funds received from other sources","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may charge fees for the support of the athletic programs of the Academy. The Secretary may accept and retain fees for services and other benefits provided incident to the operation of its athletic programs, including fees from the National Collegiate Athletic Association, fees from athletic conferences, game guarantees from other educational institutions, fees for ticketing or licensing, and other consideration provided incidental to the execution of the athletic programs of the Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be3dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that contributions accepted under this subsection do not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab7be3de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflect unfavorably on the ability of the Department of the Air Force, any of its employees, or any member of the armed forces to carry out any responsibility or duty in a fair and objective manner; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab7be3df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compromise the integrity or appearance of integrity of any program of the Department of the Air Force, or any individual involved in such a program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7be3e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Leases and Licenses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab7be3e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Air Force may, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2667"},"text":"section 2667 of this title","children":[],"tail":", enter into leases or licenses with the corporation for the purpose of supporting the athletic programs of the Academy. Consideration provided under such a lease or license may be provided in the form of funds, supplies, equipment, and services for the support of the athletic programs of the Academy."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be3e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may provide support services to the corporation without charge while the corporation conducts its support activities at the Academy. In this paragraph, the term “support services” includes utilities, office furnishings and equipment, communications services, records staging and archiving, audio and video support, and security systems in conjunction with the leasing or licensing of property. Any such support services may only be provided without any liability of the United States to the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7be3e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracts and Cooperative Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Air Force may enter into contracts and cooperative agreements with the corporation for the purpose of supporting the athletic programs of the Academy. Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3201/e"},"text":"section 3201(e) of this title","children":[],"tail":", the Secretary may enter such contracts or cooperative agreements on a sole source basis pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3204/a/5"},"text":"section 3204(a)(5) of this title","children":[],"tail":". Notwithstanding chapter 63 of title 31, a cooperative agreement under this section may be used to acquire property, services, or travel for the direct benefit or use of the athletic programs of the Academy."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7be3e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Trademarks and Service Marks.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab7be3e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Licensing, marketing, and sponsorship agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An agreement under subsection (g) may, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2260"},"text":"section 2260 of this title","children":[],"tail":" (other than subsection (d) of such section), authorize the corporation to enter into licensing, marketing, and sponsorship agreements relating to trademarks and service marks identifying the Academy, subject to the approval of the Secretary of the Air Force."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7be3e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No licensing, marketing, or sponsorship agreement may be entered into under paragraph (1) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab7be3e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such agreement would reflect unfavorably on the ability of the Department of the Air Force, any of its employees, or any member of the armed forces to carry out any responsibility or duty in a fair and objective manner; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab7be3e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the use of the trademark or service mark would compromise the integrity or appearance of integrity of any program of the Department of the Air Force, or any individual involved in such a program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7be3e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9462/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention and Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any funds received under this section may be retained for use in support of the athletic programs of the Academy and shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab7be3ea-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tV/s528/a"},"text":"Pub. L. 111–84, div. A, title V, § 528(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2289"},"text":"123 Stat. 2289","children":[],"tail":", § 9362; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tV/s554"},"text":"Pub. L. 113–291, div. A, title V, § 554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3377"},"text":"128 Stat. 3377","children":[],"tail":"; renumbered § 9462, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/a/3"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1832"},"text":"132 Stat. 1832","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s923/d/15"},"text":"Pub. L. 116–283, div. A, title IX, § 923(d)(15)","children":[],"tail":", title XVIII, § 1883(b)(2), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3815"},"text":"134 Stat. 3815","children":[],"tail":", 4294.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab7be3eb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab7be3ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idab7be3ed-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 501(c)(3) of the Internal Revenue Code of 1986, referred to in subsec. (b)(1), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab7be3ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/d/15"},"text":"Pub. L. 116–283, § 923(d)(15)","children":[],"tail":", substituted “personnel of the Department of the Air Force” for “personnel of the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1883/b/2"},"text":"Pub. L. 116–283, § 1883(b)(2)","children":[],"tail":", substituted “section 3201(e)” for “section 2304(k)” and “section 3204(a)(5)” for “section 2304(c)(5)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9362"},"text":"section 9362 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsecs. (e) to (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" added subsecs. (e) to (i) and struck out former subsecs. (e) to (g) which related to acceptance of gifts, leases of real and personal property, and cooperative agreements, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab7be3ef-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab7be3f0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1883/b/2"},"text":"section 1883(b)(2) of Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab7be3f1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
