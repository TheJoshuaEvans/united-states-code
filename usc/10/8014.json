{"tag":"section","attrib":{"id":"idab0490dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014"},"text":null,"children":[{"tag":"num","attrib":{"value":"8014"},"text":"§ 8014.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of the Secretary of the Navy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab0490de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is in the Department of the Navy an Office of the Secretary of the Navy. The function of the Office is to assist the Secretary of the Navy in carrying out his responsibilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0490df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Office of the Secretary of the Navy is composed of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab0490e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0490e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretaries of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0490e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The General Counsel of the Department of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0490e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Judge Advocate General of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0490e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Naval Inspector General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0490e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Legislative Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0490e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Naval Research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0490e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other offices and officials as may be established by law or as the Secretary of the Navy may establish or designate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0490e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab0490e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Office of the Secretary of the Navy shall have sole responsibility within the Office of the Secretary of the Navy, the Office of the Chief of Naval Operations, and the Headquarters, Marine Corps, for the following functions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab0490ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Acquisition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab0490eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Auditing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab0490ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Comptroller (including financial management).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab0490ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab0490ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Inspector General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab0490ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Legislative affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab0490f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Public affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0490f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy shall establish or designate a single office or other entity within the Office of the Secretary of the Navy to conduct each function specified in paragraph (1). No office or other entity may be established or designated within the Office of the Chief of Naval Operations or the Headquarters, Marine Corps, to conduct any of the functions specified in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0490f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab0490f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prescribe the relationship of each office or other entity established or designated under paragraph (2)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idab0490f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Chief of Naval Operations and the Office of the Chief of Naval Operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab0490f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Commandant of the Marine Corps and the Headquarters, Marine Corps; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab0490f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that each such office or entity provides the Chief of Naval Operations and the Commandant of the Marine Corps such staff support as each considers necessary to perform his duties and responsibilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0490f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The vesting in the Office of the Secretary of the Navy of the responsibility for the conduct of a function specified in paragraph (1) does not preclude other elements of the executive part of the Department of the Navy (including the Office of the Chief of Naval Operations and the Headquarters, Marine Corps) from providing advice or assistance to the Chief of Naval Operations and the Commandant of the Marine Corps or otherwise participating in that function within the executive part of the Department under the direction of the office assigned responsibility for that function in the Office of the Secretary of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0490f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab0490f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of the office or other entity established or designated by the Secretary to conduct the auditing function shall have at least five years of professional experience in accounting or auditing. The position shall be considered to be a career reserved position as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132/a/8"},"text":"section 3132(a)(8) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab0490fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The position of regional director within such office or entity, and any other position within such office or entity the primary responsibilities of which are to carry out supervisory functions, may not be held by a member of the armed forces on active duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0490fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab0490fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), the Office of the Secretary of the Navy shall have sole responsibility within the Office of the Secretary of the Navy, the Office of the Chief of Naval Operations, and the Headquarters, Marine Corps, for the function of research and development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0490fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy may assign to the Office of the Chief of Naval Operations and the Headquarters, Marine Corps, responsibility for those aspects of the function of research and development relating to military requirements and test and evaluation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0490fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish or designate a single office or other entity within the Office of the Secretary of the Navy to conduct the function specified in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0490ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab049100-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prescribe the relationship of the office or other entity established or designated under paragraph (3)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idab049101-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Chief of Naval Operations and the Office of the Chief of Naval Operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab049102-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Commandant of the Marine Corps and the Headquarters, Marine Corps; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab049103-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that each such office or entity provides the Chief of Naval Operations and the Commandant of the Marine Corps such staff support as each considers necessary to perform his duties and responsibilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab049104-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy shall ensure that the Office of the Secretary of the Navy, the Office of the Chief of Naval Operations, and the Headquarters, Marine Corps, do not duplicate specific functions for which the Secretary has assigned responsibility to another of such offices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab049105-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab049106-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total number of members of the armed forces and civilian employees of the Department of the Navy assigned or detailed to permanent duty in the Office of the Secretary of the Navy, the Office of Chief of Naval Operations, and the Headquarters, Marine Corps, may not exceed 3,150.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab049107-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than 1,800 officers of the Navy and Marine Corps on the active-duty list may be assigned or detailed to permanent duty in the Office of the Secretary of the Navy, the Office of the Chief of Naval Operations, and the Headquarters, Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab049108-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total number of general and flag officers assigned or detailed to permanent duty in the Office of the Secretary of the Navy, the Office of the Chief of Naval Operations, and the Headquarters, Marine Corps, may not exceed 74.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab049109-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The limitations in paragraphs (1), (2), and (3) do not apply in time of war.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab04910a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8014/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each limitation in paragraphs (1) and (2) may be exceeded by a number equal to 15 percent of such limitation in time of national emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab04910b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s511/c/4"},"text":"Pub. L. 99–433, title V, § 511(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1045"},"text":"100 Stat. 1045","children":[],"tail":", § 5014; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tXIII/s1314/b/7"},"text":"Pub. L. 100–180, div. A, title XIII, § 1314(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1175"},"text":"101 Stat. 1175","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tIII/s325/b"},"text":"Pub. L. 100–456, div. A, title III, § 325(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1955"},"text":"102 Stat. 1955","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVI/s652/a/4"},"text":"Pub. L. 101–189, div. A, title VI, § 652(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1461"},"text":"103 Stat. 1461","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/a/28"},"text":"Pub. L. 107–107, div. A, title X, § 1048(a)(28)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1225"},"text":"115 Stat. 1225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tV/s504/d/2"},"text":"Pub. L. 107–314, div. A, title V, § 504(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2532"},"text":"116 Stat. 2532","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tIX/s903/d"},"text":"Pub. L. 114–328, div. A, title IX, § 903(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2344"},"text":"130 Stat. 2344","children":[],"tail":"; renumbered § 8014, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/a/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1834"},"text":"132 Stat. 1834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s901/a/4"},"text":"Pub. L. 116–92, div. A, title IX, § 901(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"