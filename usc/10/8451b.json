{"tag":"section","attrib":{"id":"idab25fc65-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8451b"},"text":null,"children":[{"tag":"num","attrib":{"value":"8451b"},"text":"§ 8451b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of admissions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab25fc66-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8451b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment and Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is a director of admissions of the Naval Academy. The director of admissions shall be appointed by the President, by and with the advice and consent of the Senate, and shall perform such duties as the Superintendent of the Naval Academy may prescribe with the approval of the Secretary of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab25fc67-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8451b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grade","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab25fc68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8451b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), a person appointed as director of admissions of the Naval Academy has the regular grade of commander in the Navy or lieutenant colonel in the Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab25fc69-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8451b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person serving as director of admissions shall have the regular grade of captain in the Navy or colonel in the Marine Corps upon the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab25fc6a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8451b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which such person completes six years of service as the director of admissions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab25fc6b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8451b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which such person would have been promoted had the person been selected for promotion from among officers in the promotion zone.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab25fc6c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8451b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Detail","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President may detail any officer of the Navy or the Marine Corps in a grade above lieutenant or captain, respectively, to perform the duties of director of admissions without appointing the officer as director of admissions. Such a detail does not affect the position of the officer on the active-duty list.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab25fc6d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tV/s558/a"},"text":"Pub. L. 119–60, div. A, title V, § 558(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/879"},"text":"139 Stat. 879","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab25fc6e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab25fc6f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab25fc70-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continuation of Service of Current Director of Admissions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tV/s558/b"},"text":"Pub. L. 119–60, div. A, title V, § 558(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/879"},"text":"139 Stat. 879","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tV/s558/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Notwithstanding subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8451b"},"text":"section 8451b of title 10","children":[],"tail":", United States Code, as added by subsection (a) of this section, the person serving as the director of admissions of the Naval Academy on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"]—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may serve as the director of admissions of the Naval Academy until the date on which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a director of admissions is appointed by the President, by and with the advice and consent of the Senate, in accordance with subsection (a) of such section 8451b; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President details an officer to perform the duties of the director of admissions in accordance with subsection (c) of such section 8451b; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the regular grade described in subsection (b) of such section 8451b.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
