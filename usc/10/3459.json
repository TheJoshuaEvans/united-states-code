{"tag":"section","attrib":{"id":"idaa26db60-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3459"},"text":null,"children":[{"tag":"num","attrib":{"value":"3459"},"text":"§ 3459.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on required flowdown of contract clauses to subcontractors providing commercial products or commercial services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa26db61-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3459/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may not require that a clause be included in a subcontract for the acquisition of commercial products or commercial services other than a clause that is on the lists required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3452"},"text":"section 3452 of this title","children":[],"tail":" or unless otherwise applicable pursuant to subsection (e) of such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa26db62-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3459/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability to Other Supply Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may not require the application of any contract clauses to other supply agreements unless otherwise applicable pursuant to subsection (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3452"},"text":"section 3452 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa26db63-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3459/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the terms “other supply agreement” and “subcontract” have the meanings given such terms, respectively, in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3452/c/2"},"text":"section 3452(c)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa26db64-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3459/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall apply only with respect to subcontracts entered into after the earliest date on which the lists required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3452"},"text":"section 3452 of this title","children":[],"tail":" are published in the Defense Federal Acquisition Regulation Supplement."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa26db65-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVIII/s1824"},"text":"Pub. L. 119–60, div. A, title XVIII, § 1824","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1248"},"text":"139 Stat. 1248","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
