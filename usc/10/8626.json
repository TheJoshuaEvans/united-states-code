{"tag":"section","attrib":{"id":"idab369e38-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8626"},"text":null,"children":[{"tag":"num","attrib":{"value":"8626"},"text":"§ 8626.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Navy Reserve yacht pennant","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Navy shall prescribe a suitable pennant to be known as the Navy Reserve yacht pennant. This pennant may be flown by a yacht or similar vessel if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab369e39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8626/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is documented under the laws of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369e3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8626/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel has been designated by the Secretary, under such regulations as he prescribes, as suitable for service as a naval auxiliary in time of war; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369e3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8626/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the captain or owner of the vessel is a member of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab369e3c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/447"},"text":"70A Stat. 447","children":[],"ta