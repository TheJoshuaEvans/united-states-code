{"tag":"section","attrib":{"id":"ida997bb25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2651"},"text":null,"children":[{"tag":"num","attrib":{"value":"2651"},"text":"§ 2651.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Passengers and merchandise to Guam: sea transport","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever space is available, passengers, and merchandise produced in the United States, or the Commonwealths and possessions, and consigned to residents and mercantile firms of Guam, may be transported to Guam on vessels operated by the Department of Defense, under regulations and at rates to be prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida997bb26-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/267"},"text":"70A Stat. 267","children":[],"tail":", § 4747; renumbered § 2651 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tX/s1072/a"},"text":"Pub. L. 108–375, div. A, title X, § 1072(a)","children":[],"tail":", (b)(4), "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2057"},"text":"118 Stat. 2057","children":[],"tail":", 2058; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1057/a/6"},"text":"Pub. L. 109–163, div. A, title X, § 1057(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3441"},"text":"119 Stat. 3441","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/h/4/A/ii"},"text":"Pub. L. 111–383, div. A, title X, § 1075(h)(4)(A)(ii)","children":[],"tail"