{"tag":"section","attrib":{"id":"idaadc21af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7083"},"text":null,"children":[{"tag":"num","attrib":{"value":"7083"},"text":"§ 7083.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public Affairs Specialty","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"There is a career field in the Army known as the Public Affairs Specialty. Members of the Army with the Public Affairs Specialty are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaadc21b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7083/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chief of Public Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaadc21b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7083/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commissioned officers of the Army in the grade of major or above who are selected and specifically educated, trained, and experienced to perform as professional public affairs officers for the remainder of their careers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaadc21b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7083/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other members of the Army assigned to public affairs positions by the Secretary of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaadc21b3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tV/s596/a"},"text":"Pub. L. 105–85, div. A, title V, § 596(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date"