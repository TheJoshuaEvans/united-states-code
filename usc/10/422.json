{"tag":"section","attrib":{"id":"ida7b8739d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s422"},"text":null,"children":[{"tag":"num","attrib":{"value":"422"},"text":"§ 422.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds for certain incidental purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7b8739e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s422/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Counterintelligence Official Reception and Representation Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may use funds available to the Department of Defense for counterintelligence programs to pay the expenses of hosting foreign officials in the United States under the auspices of the Department of Defense for consultation on counterintelligence matters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b8739f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s422/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Promotional Items for Recruitment Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may use funds available for an intelligence element of the Department of Defense to purchase promotional items of nominal value for use in the recruitment of individuals for employment by that element.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7b873a0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/569/tIV/s401/c"},"text":"Pub. L. 99–569, title IV, § 401(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3195"},"text":"100 Stat. 3195","children":[],"tail":", § 140a; renumbered § 422, "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s9/a/3"},"text":"Pub. L. 100–26, § 9(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/287"},"text":"101 Stat. 287","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/108/tV/s501/a"},"text":"Pub. L. 107–108, title V, § 501(a)","children":[],"tail":"–(b)(2), "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1404"},"text":"115 Stat. 1404","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7b873a1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7b873a2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7b873a3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/108"},"text":"Pub. L. 107–108","children":[],"tail":" substituted “Use of funds for certain incidental purposes” for “Counterintelligence official reception and representation expenses” in section catchline, designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/10