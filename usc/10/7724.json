{"tag":"section","attrib":{"id":"idaafd660d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7724"},"text":null,"children":[{"tag":"num","attrib":{"value":"7724"},"text":"§ 7724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Director","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaafd660e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7724/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment and Qualifications","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaafd660f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7724/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be an Executive Director of the Army National Military Cemeteries who shall meet such professional qualifications as may be established by the Secretary of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaafd6610-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7724/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Executive Director reports directly to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafd6611-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7724/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Executive Director is responsible for the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaafd6612-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7724/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Exercising authority, direction and control over all aspects of the Cemeteries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaafd6613-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7724/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing and maintaining full accountability for all gravesites and inurnment niches in the Cemeteries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaafd6614-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7724/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Oversight of the construction, operation and maintenance, and repair of the buildings, structures, and utilities of the Cemeteries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaafd6615-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7724/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Acquisition and maintenance of real property and interests in real property for the Cemeteries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaafd6616-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7724/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Planning and conducting private ceremonies at the Cemeteries, including funeral and memorial services for interment and inurnment, and planning and conducting public ceremonies, as directed by the Secretary of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaafd6617-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7724/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Formulating, promulgating, administering, and overseeing policies and addressing proposals for the placement of memorials and monuments in the Cemeteries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaafd6618-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7724/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Formulating and implementing a master plan for Arlington National Cemetery that, at a minimum, addresses interment and inurnment capacity, visitor accommodation, operation and maintenance, capital requirements, preservation of the cemetery’s special features, and other matters the Executive Director considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaafd6619-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7724/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Overseeing the programming, planning, budgeting, and execution of funds authorized and appropriated for the Cemeteries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaafd661a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7724/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing recommendations regarding any request for an exception to interment and inurnment eligibility policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaafd661b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7724/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supervising the superintendents of the Cemeteries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaafd661c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s591/a/1"},"text":"Pub. L. 112–81, div. A, title V, § 591(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1440"},"text":"125 Stat. 1440","children":[],"tail":", § 4724; renumbered § 7724, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/d"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaafd661d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaafd661e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaafd661f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7724 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8894"},"text":"section 8894 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"