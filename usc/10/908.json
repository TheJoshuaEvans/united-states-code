{"tag":"section","attrib":{"id":"ida82ae559-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s908"},"text":null,"children":[{"tag":"num","attrib":{"value":"908"},"text":"§ 908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 108. Military property of United States—Loss, damage, destruction, or wrongful disposition","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter who, without proper authority—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82ae55a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s908/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sells or otherwise disposes of;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82ae55b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s908/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully or through neglect damages, destroys, or loses; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82ae55c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s908/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully or through neglect suffers to be lost, damaged, destroyed, sold, or wrongfully disposed of;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"any military property of the United States, shall be punished as a court-martial may direct.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida82ae55d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/7