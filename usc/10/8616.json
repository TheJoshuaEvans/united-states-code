{"tag":"section","attrib":{"id":"idab3454a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8616"},"text":null,"children":[{"tag":"num","attrib":{"value":"8616"},"text":"§ 8616.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection, preservation, and display of captured flags","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Navy shall collect all flags, standards, and colors taken by the Navy or the Marine Corps from enemies of the United States. These flags, standards, and colors shall be delivered to the President. Under his direction they shall be preserved and displayed in any public place he considers proper.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab3454aa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/445"},"text":"70A Stat. 445","children":[],"tail":", § 7216; renumbered § 8616, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab3454ab-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab3454ac-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab3454ad-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{