{"tag":"section","attrib":{"id":"idaacb59b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6287"},"text":null,"children":[{"tag":"num","attrib":{"value":"6287"},"text":"§ 6287.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters relating to critical decisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaacb59b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6287/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Post-critical Decision","children":[],"tail":" 2 "},{"tag":"inline","attrib":{},"text":"Changes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"After the date on which a plant project specifically authorized by law and carried out under Department of Energy Order 413.3B (relating to program management and project management for the acquisition of capital assets), or a successor order, achieves critical decision 2, the Administrator may not change the requirements for such project if such change increases the cost of such project by more than the lesser of $5,000,000 or 15 percent, unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacb59b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6287/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Administrator submits to the congressional defense committees—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacb59b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6287/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that the Administrator, without delegation, authorizes such proposed change; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacb59b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6287/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a cost-benefit and risk analysis of such proposed change, including with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaacb59b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6287/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effects of such proposed change on the project cost and schedule; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaacb59ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6287/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any mission risks and operational risks from making such change or not making such change; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacb59bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6287/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 15 days elapses following the date of such submission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacb59bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6287/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review and Approval","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall ensure that critical decision packages are timely reviewed and either approved or disapproved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaacb59bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1435"},"text":"139 Stat. 1435","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaacb59be-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaacb59bf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaacb59c0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2755"},"text":"section 2755 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
