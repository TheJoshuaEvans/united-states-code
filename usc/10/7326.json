 Act of Apr. 16, 1949, ch. 38","children":[],"tail":", as amended), "},{"tag":"html:a","attrib":{"href":"/us/stat/20/150"},"text":"20 Stat. 150","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1928-05-29/ch902"},"text":"May 29, 1928, ch. 902","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/45/996"},"text":"45 Stat. 996","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1938-01-29/ch12/s2"},"text":"Jan. 29, 1938, ch. 12, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/52/8"},"text":"52 Stat. 8","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) consolidates the various service computation provisions applicable to voluntary retirement of commissioned officers. Clause (1) is substituted for 10:951. Clause (2) is substituted for 10:951b. The words “pay period and”, in 10:951a, are omitted as superseded by section 202 of the Career Compensation Act of 1949, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/63/807"},"text":"63 Stat. 807","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t37/s233"},"text":"37 U.S.C. 233","children":[],"tail":"). The words “longevity pay and”, in "},{"tag":"ref","attrib":{"href":"/us/act/1878-06-18/ch263/s7"},"text":"section 7 of the act of June 18, 1878, ch. 263","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/20/150"},"text":"20 Stat. 150","children":[],"tail":", are omitted for the same reason. The last sentence of section 7 of that act is omitted, since the distinction between limited and unlimited retired lists was abolished by "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-29/ch708/s201"},"text":"section 201 of the act of June 29, 1948, ch. 708","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/1084"},"text":"62 Stat. 1084","children":[],"tail":". Clause (3) is inserted, since a person entitled to count service under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3683"},"text":"section 3683 of this title","children":[],"tail":" might cease to be a nurse or woman medical specialist and thereafter become entitled to retire under one of the revised sections referred to in subsection (a) of this revised section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “as a member of the Medical Reserve Corps”, in 10:953a, are omitted as covered by subsection (a)(1). The words “are computed by adding to his service under subsection (a)” are substituted for the words “shall be credited to the same extent as service under a Regular Army commission”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c) is substituted for 10:953a (less 1st sentence).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaae32760-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaae32761-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3683"},"text":"Section 3683 of this title","children":[],"tail":", referred to in subsecs. (a)(3) and (d), was repealed (subject to a savings clause) by "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXIII/s1301/b/1/A"},"text":"Pub. L. 99–145, title XIII, § 1301(b)(1)(A)","children":[],"tail":", (C), "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/735"},"text":"99 Stat. 735","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaae32762-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “, the Air Force, or the Space Force” for “or the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s808/b/12"},"text":"Pub. L. 115–232, § 808(b)(12)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3926"},"text":"section 3926 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 7311, 7318, or 7324” for “section 3911, 3918, or 3924” in introductory provisions in subsec. (a) and in subsecs. (b) and (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 7311” for “section 3911”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/197"},"text":"Pub. L. 86–197","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaae32763-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaae32764-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaae32765-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", and applicable to any period of time covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s972"},"text":"section 972 of this title","children":[],"tail":" that occurs after that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/s561/e"},"text":"section 561(e) of Pub. L. 104–106","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s972"},"text":"section 972 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
