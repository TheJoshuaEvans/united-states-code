{"tag":"section","attrib":{"id":"idaae32752-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7326"},"text":null,"children":[{"tag":"num","attrib":{"value":"7326"},"text":"§ 7326.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of years of service: voluntary retirement; regular and reserve commissioned officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaae32753-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7326/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of determining whether an officer of the Army may be retired under section 7311, 7318, or 7324 of this title, his years of service are computed by adding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaae32754-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7326/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all active service performed as a member of the Army, the Air Force, or the Space Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaae32755-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7326/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all service in the Navy or Marine Corps that may be included in determining the eligibility of an officer of the Navy or Marine Corps for retirement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaae32756-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7326/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all service computed under section 3683 ","children":[{"tag":"ref","attrib":{"idref":"fn002156"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002156"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaae32757-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7326/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if an officer of the Regular Army, all active service performed as an officer of the Philippine Constabulary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaae32758-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7326/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of determining whether a commissioned officer of the Regular Army in the Medical Corps may be retired under section 7311, 7318, or 7324 of this title, his years of service are computed by adding to his service under subsection (a) all service performed as a contract surgeon, acting assistant surgeon, or contract physician, under a contract to serve full time and to take and change station as ordered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaae32759-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7326/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of determining whether a commissioned officer of the Regular Army in the Dental Corps may be retired under section 7311, 7318, or 7324 of this title, his years of service are computed by adding to his service under subsection (a) all service as a contract dental surgeon or acting dental surgeon.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaae3275a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7326/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of determining whether a commissioned officer of the Army Nurse Corps or the Army Medical Specialist Corps may be retired under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7311"},"text":"section 7311 of this title","children":[],"tail":", all service computed under section 3683 "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title shall be treated as if it were service as a commissioned officer."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaae3275b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7326/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s972/b"},"text":"Section 972(b) of this title","children":[],"tail":" excludes from computation of an officer’s years of service for purposes of this section any time identified with respect to that officer under that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaae3275c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/228"},"text":"70A Stat. 228","children":[],"tail":", § 3926; "},{"tag":"ref","attrib":{"href":"/us/pl/86/197/s1/5"},"text":"Pub. L. 86–197, § 1(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-08-25"},"text":"Aug. 25, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/426"},"text":"73 Stat. 426","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s561/d/2/B"