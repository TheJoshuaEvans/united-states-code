{"tag":"section","attrib":{"id":"idaba45420-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12604"},"text":null,"children":[{"tag":"num","attrib":{"value":"12604"},"text":"§ 12604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Billeting in Department of Defense facilities: Reserves attending inactive-duty training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaba45421-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12604/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority for Billeting on Same Basis as Active Duty Members Traveling Under Orders","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe regulations authorizing a Reserve traveling to inactive-duty training at a location more than 50 miles from that Reserve’s residence to be eligible for billeting in Department of Defense facilities on the same basis and to the same extent as a member of the armed forces on active duty who is traveling under orders away from the member’s permanent duty station.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba45422-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12604/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proof of Reason for Travel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall include in the regulations the means for confirming a Reserve’s eligibility for billeting under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba45423-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12604/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lodging in Kind","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba45424-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12604/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a member of a reserve component performing active duty for training or inactive-duty training who is not otherwise entitled to travel and transportation allowances in connection with such duty, the Secretary concerned may reimburse the member for housing service charge expenses incurred by the member in occupying transient government housing during the performance of such duty. If transient government housing is unavailable or inadequate, the Secretary concerned may provide the member with lodging in kind.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba45425-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12604/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any payment or other benefit under this subsection shall be provided in accordance with regulations prescribed by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba45426-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12604/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may pay service charge expenses under paragraph (1) and expenses of providing lodging in kind under such paragraph out of funds appropriated for operation and maintenance for the reserve component concerned. Use of a Government charge card is authorized for payment of these expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba45427-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12604/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Decisions regarding the availability or adequacy of government housing at a military installation under paragraph (1) shall be made by the installation commander.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaba45428-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 663(a)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–168; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tVI/s603/a/1"},"text":"Pub. L. 117–81, div. A, title VI, § 603(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1765"},"text":"135 Stat. 1765","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaba45429-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaba4542a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaba4542b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaba4542c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaba4542d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 663(b)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–168, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/398/s1/dA"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12604"},"text":"Section 12604 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to periods of inactive-duty training beginning more than 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
