{"tag":"section","attrib":{"id":"ida89b0c02-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1132"},"text":null,"children":[{"tag":"num","attrib":{"value":"1132"},"text":"§ 1132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presentation of decorations: prohibition on entering correctional facilities for presentation to prisoners convicted of serious violent felonies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida89b0c03-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1132/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the armed forces may not enter a Federal, State, local, or foreign correctional facility to present a decoration to a person who is incarcerated due to conviction of a serious violent felony.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida89b0c04-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1132/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida89b0c05-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1132/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “decoration” means any decoration or award that may be presented or awarded to a member of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida89b0c06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1132/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “serious violent felony” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3559/c/2/F"},"text":"section 3559(c)(2)(F) of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida89b0c07-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tV/s537/a"},"text":"Pub. L. 105–261, div. A, title V, § 537(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2019"},"text":"112 Stat. 2019","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
