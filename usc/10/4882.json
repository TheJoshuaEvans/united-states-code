{"tag":"section","attrib":{"id":"idaaa9eed5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4882"},"text":null,"children":[{"tag":"num","attrib":{"value":"4882"},"text":"§ 4882.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industrial mobilization: orders; priorities; possession of manufacturing plants; violations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaa9eed6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4882/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ordering Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In time of war or when war is imminent, the President, through the head of any department, may order from any person or organized manufacturing industry necessary products or materials of the type usually produced or capable of being produced by that person or industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaa9eed7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4882/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance With Order Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person or industry with whom an order is placed under subsection (a), or the responsible head thereof, shall comply with that order and give it precedence over all orders not placed under that subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaa9eed8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4882/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Seizure of Manufacturing Plants Upon Noncompliance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In time of war or when war is imminent, the President, through the head of any department, may take immediate possession of any plant that is equipped to manufacture, or that in the opinion of the head of that department is capable of being readily transformed into a plant for manufacturing, arms or ammunition, parts thereof, or necessary supplies for the armed forces if the person or industry owning or operating the plant, or the responsible head thereof, refuses—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaa9eed9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4882/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to give precedence to the order as prescribed in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaa9eeda-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4882/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to manufacture the kind, quantity, or quality of arms or ammunition, parts thereof, or necessary supplies, as ordered by the head of such department; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaa9eedb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4882/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to furnish them at a reasonable price as determined by the head of such department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaa9eedc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4882/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Seized Plant","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President, through the head of any department, may manufacture products that are needed in time of war or when war is imminent, in any plant that is seized under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaa9eedd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4882/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each person or industry from whom products or materials are ordered under subsection (a) is entitled to fair and just compensation. Each person or industry whose plant is seized under subsection (c) is entitled to a fair and just rental.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaa9eede-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4882/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever fails to comply with this section shall be imprisoned for not more than three years and fined under title 18.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaa9eedf-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tVIII/s822/a/1"},"text":"Pub. L. 103–160, div. A, title VIII, § 822(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1704"},"text":"107 Stat. 1704","children":[],"tail":", § 2538; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tVIII/s811"},"text":"Pub. L. 103–337, div. A, title VIII, § 811","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2815"},"text":"108 Stat. 2815","children":[],"tail":"; renumbered § 4882, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1870/e/2/A"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1870(e)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4286"},"text":"134 Stat. 4286","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaa9eee0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaa9eee1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaaa9eee2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 4501 and 9501 of this title, prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s822/a/2"},"text":"Pub. L. 103–160, § 822(a)(2)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaaa9eee3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2538"},"text":"section 2538 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s811/1"},"text":"Pub. L. 103–337, § 811(1)","children":[],"tail":", substituted “head of any department” for “Secretary of Defense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s811"},"text":"Pub. L. 103–337, § 811","children":[],"tail":", substituted “through the head of any department” for “through the Secretary of Defense” and “opinion of the head of that department” for “opinion of the Secretary of Defense” in introductory provisions and “head of such department” for “Secretary” in pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s811/1"},"text":"Pub. L. 103–337, § 811(1)","children":[],"tail":", substituted “head of any department” for “Secretary of Defense”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaaa9eee4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaaa9eee5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
