{"tag":"section","attrib":{"id":"idabccea92-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20505"},"text":null,"children":[{"tag":"num","attrib":{"value":"20505"},"text":"§ 20505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officer considered for removal: voluntary retirement or discharge","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabccea93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At any time during proceedings under this chapter with respect to the removal of an officer from a space force active status, the Secretary of the Air Force may grant a request by the officer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabccea94-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20505/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for voluntary retirement, if the officer is qualified for retirement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabccea95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20505/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for discharge in accordance with subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabccea96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retirement or Discharge","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An officer removed from a space force active status under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20503"},"text":"section 20503 of this title","children":[],"tail":" shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabccea97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20505/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if eligible for voluntary retirement under any provision of law on the date of such removal, be retired in the grade and with the retired pay for which the officer would be eligible if retired under such provision; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabccea98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20505/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if ineligible for voluntary retirement under any provision of law on the date of such removal—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabccea99-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20505/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be honorably discharged in the grade then held, in the case of an officer whose case was brought under subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20501"},"text":"section 20501 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabccea9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20505/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be discharged in the grade then held, in the case of an officer whose case was brought under subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20501"},"text":"section 20501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabccea9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Separation Pay for Discharged Officer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who is discharged under subsection (b)(2) is entitled, if eligible therefor, to separation pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1174/a/2"},"text":"section 1174(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabccea9c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1719"},"text":"Pub. L. 118–31, div. A, title XVII, § 1719","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/661"},"text":"137 Stat. 661","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
