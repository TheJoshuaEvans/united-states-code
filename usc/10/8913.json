General” are substituted for “General Accounting Office” for consistency. The words “of the Navy” are omitted because of the restatement. The words “when presented with” are substituted for “upon” for clarity. The words “by whose order such disbursement or disposal was made” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab55be4c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab55be4d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8913, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/549"},"text":"70A Stat. 549","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/86/616/s9"},"text":"Pub. L. 86–616, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/395"},"text":"74 Stat. 395","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s3"},"text":"Pub. L. 89–718, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1115"},"text":"80 Stat. 1115","children":[],"tail":", provided for retirement of deferred officers not recommended for promotion after twenty years or more of service, except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8301"},"text":"section 8301 of Title 5","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tII/s217/a"},"text":"Pub. L. 96–513, title II, § 217(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2886"},"text":"94 Stat. 2886","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":". See section 627 et seq. of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 8914 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9314"},"text":"section 9314 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 8915 and 8916 were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tII/s217/a"},"text":"Pub. L. 96–513, title II, § 217(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2886"},"text":"94 Stat. 2886","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 8915, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/550"},"text":"70A Stat. 550","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1957-08-21"},"text":"Aug. 21, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/155/tIII/s301/18"},"text":"Pub. L. 85–155, title III, § 301(18)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/389"},"text":"71 Stat. 389","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1966-09-30"},"text":"Sept. 30, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/609/s1/31"},"text":"Pub. L. 89–609, § 1(31)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/854"},"text":"80 Stat. 854","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s3"},"text":"Pub. L. 89–718, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1115"},"text":"80 Stat. 1115","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1967-11-08"},"text":"Nov. 8, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/90/130/s1/32/A"},"text":"Pub. L. 90–130, § 1(32)(A)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/382"},"text":"89 Stat. 382","children":[],"tail":", authorized the Secretary of the Air Force to defer the retirement of any Air Force nurse or medical specialist in the regular grade of major until the 30th day after the officer completes 28 years of service. See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s632"},"text":"section 632 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 8916, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/550"},"text":"70A Stat. 550","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1957-08-21"},"text":"Aug. 21, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/155/tIII/s301/19"},"text":"Pub. L. 85–155, title III, § 301(19)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/389"},"text":"71 Stat. 389","children":[],"tail":", provided for retirement of a promotion-list lieutenant colonel, except as provided by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8301"},"text":"section 8301 of title 5","children":[],"tail":", on the 30th day after he completes 28 years of service, with authority for the Secretary of the Air Force to defer retirement in certain cases. See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s633"},"text":"section 633 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 8917 and 8918 were renumbered sections 9317 and 9318 of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 8919, act ","children":[{"tag":"date","attrib":{"date":"1956-08-10"},"text":"Aug. 10, 1956","children":[],"tail":", ch 1041, "},{"tag":"ref","attrib":{"href":"/us/stat/70A/551"},"text":"70A Stat. 551","children":[],"tail":", authorized Secretary of Air Force, when he determined that there were too many commissioned officers on active list of Regular Air Force in any grade who have at least 30 years of service, to convene a board of at least five general officers of the Regular Air Force to make recommendations for retirement and to retire any officer so recommended, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tII/s217/a"},"text":"Pub. L. 96–513, title II, § 217(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2886"},"text":"94 Stat. 2886","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 8920 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9320"},"text":"section 9320 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab55be4e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7863"},"text":"section 7863 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" inserted “were” after “the stores” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s913/c/3/B/i"},"text":"Pub. L. 104–106, § 913(c)(3)(B)(i)","children":[],"tail":", substituted “Disposal of public stores” for “Disbursements” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s913/c/3/A"},"text":"Pub. L. 104–106, § 913(c)(3)(A)","children":[],"tail":", in first sentence, struck out “disbursements of public moneys or” after “Comptroller General shall allow” and “the money was paid or” after “the order was made and that” and, in second sentence, struck out “disbursement or” after “commanding officer is accountable for the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433"},"text":"Pub. L. 99–433","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7862"},"text":"section 7862 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab55be4f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab55be50-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","at