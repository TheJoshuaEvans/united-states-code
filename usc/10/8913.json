{"tag":"section","attrib":{"id":"idab55be47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8913"},"text":null,"children":[{"tag":"num","attrib":{"value":"8913"},"text":"§ 8913.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal of public stores by order of commanding officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When settling an account of a disbursing official, the Comptroller General shall allow disposal of public stores the disbursing official made under an order of a commanding officer when presented with satisfactory evidence that the order was made and that the stores were disposed of as the order provided. The commanding officer is accountable for the disposal.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab55be48-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258/s2/b/12/B"},"text":"Pub. L. 97–258, § 2(b)(12)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1057"},"text":"96 Stat. 1057","children":[],"tail":", § 7862; renumbered § 7863, "},{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s514/b/1"},"text":"Pub. L. 99–433, title V, § 514(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1054"},"text":"100 Stat. 1054","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tIX/s913/c/3/A"},"text":"Pub. L. 104–106, div. A, title IX, § 913(c)(3)(A)","children":[],"tail":", (B)(i), "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/411"},"text":"110 Stat. 411","children":[],"tail":"; "},{"tag":"ref","attrib":{"href"