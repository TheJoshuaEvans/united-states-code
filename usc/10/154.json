{"tag":"section","attrib":{"id":"ida770e2ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s154"},"text":null,"children":[{"tag":"num","attrib":{"value":"154"},"text":"§ 154.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vice Chairman","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida770e2cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s154/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida770e2d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s154/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is a Vice Chairman of the Joint Chiefs of Staff, appointed by the President, by and with the advice and consent of the Senate, from the officers of the regular components of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida770e2d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s154/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman and Vice Chairman may not be members of the same armed force. However, the President may waive the restriction in the preceding sentence for a limited period of time in order to provide for the orderly transition of officers appointed to serve in the positions of Chairman and Vice Chairman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida770e2d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s154/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Vice Chairman serves at the pleasure of the President for a single term of four years, beginning on October 1 of an odd-numbered year, except that the term may not begin in the same year as the term of a Chairman. In time of war, there is no limit on the number of reappointments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida770e2d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s154/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida770e2d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s154/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Vice Chairman shall not be eligible for promotion to the position of Chairman or any other position in the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida770e2d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s154/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may waive subparagraph (A) if the President determines such action is necessary in the national interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida770e2d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s154/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida770e2d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s154/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President may appoint an officer as Vice Chairman of the Joint Chiefs of Staff only if the officer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida770e2d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s154/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the joint specialty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s661"},"text":"section 661 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida770e2d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s154/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed a full tour of duty in a joint duty assignment (as defined in section 664(f) ","children":[{"tag":"ref","attrib":{"idref":"fn002008"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002008"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title) as a general or flag officer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida770e2da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s154/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may waive paragraph (1) in the case of an officer if the President determines such action is necessary in the national interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida770e2db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s154/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Vice Chairman performs the duties prescribed for him as a member of the Joint Chiefs of Staff and such other duties as may be prescribed by the Chairman with the approval of the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida770e2dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s154/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Function as Acting Chairman","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When there is a vacancy in the office of Chairman or in the absence or disability of the Chairman, the Vice Chairman acts as Chairman and performs the duties of the Chairman until a successor is appointed or the absence or disability ceases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida770e2dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s154/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Succession After Chairman and Vice Chairman","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When there is a vacancy in the offices of both Chairman and Vice Chairman or in the absence or disability of both the Chairman and the Vice Chairman, or when there is a vacancy in one such office and in the absence or disability of the officer holding the other, the President shall designate a member of the Joint Chiefs of Staff to act as and perform the duties of the Chairman until a successor to the Chairman or Vice Chairman is appointed or the absence or disability of the Chairman or Vice Chairman ceases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida770e2de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s154/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grade and Rank","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Vice Chairman, while so serving, holds the grade of general or, in the case of an officer of the Navy, admiral and outranks all other officers of the armed forces except the Chairman. The Vice Chairman may not exercise military command over the Joint Chiefs of Staff or any of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida770e2df-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tII/s201"},"text":"Pub. L. 99–433, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1008"},"text":"100 Stat. 1008","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tV/s519/a/1"},"text":"Pub. L. 100–456, div. A, title V, § 519(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1972"},"text":"102 Stat. 1972","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tIX/s911/b/1"},"text":"Pub. L. 102–484, div. A, title IX, § 911(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2473"},"text":"106 Stat. 2473","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tIX/s921/d/1"},"text":"Pub. L. 114–328, div. A, title IX, § 921(d)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2354"},"text":"130 Stat. 2354","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida770e2e0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida770e2e1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida770e2e2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s664/f"},"text":"Section 664(f) of this title","children":[],"tail":", referred to in subsec. (b)(1)(B), was redesignated as "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s664/d"},"text":"section 664(d) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tV/s510/g/1"},"text":"Pub. L. 114–328, div. A, title V, § 510(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2111"},"text":"130 Stat. 2111","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida770e2e3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s921/d/1"},"text":"Pub. L. 114–328, § 921(d)(1)","children":[],"tail":", substituted “for a single term of four years, beginning on October 1 of an odd-numbered year, except that the term may not begin in the same year as the term of a Chairman. In time of war, there is no limit on the number of reappointments.” for “for a term of two years and may be reappointed in the same manner for two additional terms. However, in time of war there is no limit on the number of reappointments.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s921/d/2"},"text":"Pub. L. 114–328, § 921(d)(2)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s911/b/1/A"},"text":"Pub. L. 102–484, § 911(b)(1)(A)","children":[],"tail":", substituted “the duties prescribed for him as a member of the Joint Chiefs of Staff and such other” for “such”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s911/b/1/B"},"text":"Pub. L. 102–484, § 911(b)(1)(B)","children":[],"tail":", (C), redesignated subsec. (g) as (f) and struck out former subsec. (f) which read as follows: “"},{"tag":"inline","attrib":{},"text":"Participation in JCS Meetings","children":[],"tail":".—The Vice Chairman may participate in all meetings of the Joint Chiefs of Staff, but may not vote on a matter before the Joint Chiefs of Staff except when acting as Chairman.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" substituted “completed a full tour of duty in a joint duty assignment (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s664/f"},"text":"section 664(f) of this title","children":[],"tail":")” for “served in at least one joint duty assignment (as defined under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s668/b"},"text":"section 668(b) of this title","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida770e2e4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida770e2e5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tIX/s921/d/3"},"text":"Pub. L. 114–328, div. A, title IX, § 921(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2354"},"text":"130 Stat. 2354","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/328/dA/tIX/s921/d/3"},"text":"“The amendments made by this subsection [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":", and shall apply to individuals appointed as Vice Chairman of the Joint Chiefs of Staff on or after that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida770e2e6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Extension of Term of Office of Vice Chairman of Joint Chiefs of Staff","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/526/tI/s107"},"text":"Pub. L. 100–526, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-24"},"text":"Oct. 24, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2625"},"text":"102 Stat. 2625","children":[],"tail":", authorized President to extend until "},{"tag":"date","attrib":{"date":"1989-06-01"},"text":"June 1, 1989","children":[],"tail":", term of office of officer serving as Vice Chairman of Joint Chiefs of Staff for term which began on "},{"tag":"date","attrib":{"date":"1987-02-06"},"text":"Feb. 6, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida770e2e7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Waiver of Qualifications for Appointment as Vice Chairman of Joint Chiefs of Staff","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tII/s204/c"},"text":"Pub. L. 99–433, title II, § 204(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1011"},"text":"100 Stat. 1011","children":[],"tail":", authorized President, until "},{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", to waive certain requirements otherwise applicable for appointment of an officer as Vice Chairman of Joint Chiefs of Staff."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
