{"tag":"section","attrib":{"id":"idaa163a08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3227"},"text":null,"children":[{"tag":"num","attrib":{"value":"3227"},"text":"§ 3227.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines and collection method for acquisition of cost data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa163a09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3227/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director of Cape to Develop Guidelines and Collection Method","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of Cost Assessment and Program Evaluation shall, in consultation with the Under Secretary of Defense for Acquisition and Sustainment, develop policies, procedures, guidance, and a collection method to ensure that quality acquisition cost data are collected to facilitate cost estimation and comparison across acquisition programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa163a0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3227/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability to Acquisition Programs in Amount Greater Than Specified Threshold","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The program manager and contracting officer for each acquisition program in an amount greater than an amount described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3041/c/1"},"text":"section 3041(c)(1) of this title","children":[],"tail":", in consultation with the cost estimating component of the relevant military department or Defense Agency, shall ensure that cost data are collected in accordance with the requirements of subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa163a0b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3227/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Waiver Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirement under subsection (a) may be waived only by the Director of Cost Assessment and Program Evaluation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa163a0c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1812/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1812(a)","children":[],"tail":", (h), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4174"},"text":"134 Stat. 4174","children":[],"tail":", 4177; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVIII/s801"},"text":"Pub. L. 118–159, div. A, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1965"},"text":"138 Stat. 1965","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa163a0d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa163a0e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa163a0f-3a6f-11f1-a