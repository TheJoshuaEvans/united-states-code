{"tag":"section","attrib":{"id":"ida83480e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946"},"text":null,"children":[{"tag":"num","attrib":{"value":"946"},"text":"§ 946.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 146. Military Justice Review Panel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida83480e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall establish a panel to conduct independent periodic reviews and assessments of the operation of this chapter. The panel shall be known as the “Military Justice Review Panel” (in this section referred to as the “Panel”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida83480e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida83480e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Number of members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Panel shall be composed of thirteen members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83480e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment of certain members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each of the following shall appoint one member of the Panel:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida83480e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense (in consultation with the Secretary of the department in which the Coast Guard is operating when it is not operating as a service in the Navy).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida83480e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida83480e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Judge Advocates General of the Army, Navy, Air Force, and Coast Guard, and the Staff Judge Advocate to the Commandant of the Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83480e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment of remaining members by secretary of defense","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall appoint the remaining members of the Panel, taking into consideration recommendations made by each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida83480ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chairman and ranking minority member of the Committee on Armed Services of the Senate and the Committee on Armed Services of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida83480eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Justice of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida83480ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Judge of the United States Court of Appeals for the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83480ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of staggered terms","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (e), members of the Panel appointed to serve on the Panel to fill vacancies that exist due to terms of appointment expiring during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2030-08-01"},"text":"August 1, 2030","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2030-11-30"},"text":"November 30, 2030","children":[],"tail":", shall be appointed to terms as follows:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida83480ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members designated by the Secretary of Defense shall serve a term of two years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida83480ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members designated by the Secretary of Defense shall serve a term of four years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida83480f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members designated by the Secretary of Defense shall serve a term of six years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida83480f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Four members designated by the Secretary of Defense shall serve a term of eight years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida83480f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifications of Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The members of the Panel shall be appointed from among private United States citizens with expertise in criminal law, as well as appropriate and diverse experience in investigation, prosecution, defense, victim representation, or adjudication with respect to courts-martial, Federal civilian courts, or State courts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida83480f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chair","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall select the chair of the Panel from among the members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida83480f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term; Vacancies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida83480f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (b)(4) and paragraphs (2) and (3) of this subsection, each member shall be appointed for a term of eight years, and no member may serve more than one term.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83480f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vacancy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any vacancy in the Panel shall be filled in the same manner as the original appointment. A member appointed to fill a vacancy in the Panel that occurs before the expiration of the term of appointment of the predecessor of such member shall be appointed for the remainder of the term of such predecessor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83480f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of reappointment for certain members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (1), a member of the Panel may be appointed to a single additional term if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida83480f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appointment of the member is to fill a vacancy described in subsection (b)(4); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida83480f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the member was initially appointed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida83480fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a term of four years or less in accordance with subsection (b)(4); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida83480fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fill a vacancy that occurs before the expiration of the term of the predecessor of such member and for which the remainder of the term of such predecessor is four years or less.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida83480fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reviews and Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida83480fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial review of recent amendments to ucmj","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"During fiscal year 2021, the Panel shall conduct an initial review and assessment of the implementation of the amendments made to this chapter during the preceding five years. In conducting the initial review and assessment, the Panel may review such other aspects of the operation of this chapter as the Panel considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83480fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sentencing data collection and report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"During fiscal year 2020, the Panel shall gather and analyze sentencing data collected from each of the armed forces from general and special courts-martial applying offense-based sentencing under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s856"},"text":"section 856 of this title","children":[],"tail":" (article 56). The sentencing data shall include the number of accused who request member sentencing and the number who request sentencing by military judge alone, the offenses which the accused were convicted of, and the resulting sentence for each offense in each case. The Judge Advocates General and the Staff Judge Advocate to the Commandant of the Marine Corps shall provide the sentencing data in the format and for the duration established by the chair of the Panel. The analysis under this paragraph shall be included in the assessment required by paragraph (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83480ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Periodic comprehensive reviews","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"During fiscal year 2024 and every eight years thereafter, the Panel shall conduct a comprehensive review and assessment of the operation of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8348100-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Periodic interim reviews","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"During fiscal year 2028 and every eight years thereafter, the Panel shall conduct an interim review and assessment of such other aspects of the operation of this chapter as the Panel considers appropriate. In addition, at the request of the Secretary of Defense, the Panel may, at any time, review and assess other specific matters relating to the operation of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8348101-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to each review and assessment under this subsection, the Panel shall submit a report to the Committees on Armed Services of the Senate and the House of Representatives. Each report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8348102-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/f/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall set forth the results of the review and assessment concerned, including the findings and recommendations of the Panel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8348103-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/f/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be submitted not later than December 31 of the calendar year in which the review and assessment is concluded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8348104-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hearings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Panel may hold such hearings, sit and act at such times and places, take such testimony, and receive such evidence as the Panel considers appropriate to carry out its duties under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8348105-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information From Federal Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon request of the chair of the Panel, a department or agency of the Federal Government shall provide information that the Panel considers necessary to carry out its duties under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8348106-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Matters.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8348107-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members to serve without pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Members of the Panel shall serve without pay, but shall be allowed travel expenses, including per diem in lieu of subsistence, at rates authorized for employees of agencies under subchapter I of chapter 57 of title 5, while away from their homes or regular places of business in the performance of services for the Panel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8348108-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Staffing and resources","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall provide staffing and resources to support the Panel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8348109-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s946/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chapter ","children":[],"tail":"10"},{"tag":"inline","attrib":{},"text":" of Title ","children":[],"tail":"5.—"}],"tail":null},{"tag":"content","attrib":{},"text":"Chapter 10 of title 5 shall not apply to the Panel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida834810a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXIII/s1301/c"},"text":"Pub. L. 101–189, div. A, title XIII, § 1301(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1574"},"text":"103 Stat. 1574","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tIX/s924/c/1"},"text":"Pub. L. 103–337, div. A, title IX, § 924(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2831"},"text":"108 Stat. 2831","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1502/a/1"},"text":"Pub. L. 104–106, div. A, title XV, § 1502(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/502"},"text":"110 Stat. 502","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1067/1"},"text":"Pub. L. 106–65, div. A, title X, § 1067(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/774"},"text":"113 Stat. 774","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/b/1"},"text":"Pub. L. 107–296, title XVII, § 1704(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tV/s532"},"text":"Pub. L. 112–239, div. A, title V, § 532","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1726"},"text":"126 Stat. 1726","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLXII/s5521"},"text":"Pub. L. 114–328, div. E, title LXII, § 5521","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2962"},"text":"130 Stat. 2962","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tV/s531/k"},"text":"Pub. L. 115–91, div. A, title V, § 531(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1386"},"text":"131 Stat. 1386","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/46"},"text":"Pub. L. 117–286, § 4(a)(46)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4310"},"text":"136 Stat. 4310","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tV/s532"},"text":"Pub. L. 118–31, div. A, title V, § 532","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/260"},"text":"137 Stat. 260","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida834810b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida834810c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida834810d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s532/a"},"text":"Pub. L. 118–31, § 532(a)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s532/b"},"text":"Pub. L. 118–31, § 532(b)","children":[],"tail":", amended subsec. (e) generally. Prior to amendment, text read as follows: “Each member shall be appointed for a term of eight years, and no member may serve more than one term. Any vacancy shall be filled in the same manner as the original appointment.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of Title 5” for “Federal Advisory Committee Act” in heading and “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s531/k/1"},"text":"Pub. L. 115–91, § 531(k)(1)","children":[],"tail":", substituted “fiscal year 2021” for “fiscal year 2020”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s531/k/2"},"text":"Pub. L. 115–91, § 531(k)(2)","children":[],"tail":", substituted “The analysis under this paragraph shall be included in the assessment required by paragraph (1).” for “Not later than "},{"tag":"date","attrib":{"date":"2020-10-31"},"text":"October 31, 2020","children":[],"tail":", the Panel shall submit to the Committees on Armed Services of the Senate and the House of Representatives through the Secretary of Defense a report setting forth the Panel’s findings and recommendations on the need for sentencing reform.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s531/k/3"},"text":"Pub. L. 115–91, § 531(k)(3)","children":[],"tail":", added par. (5) and struck out former par. (5). Prior to amendment, text read as follows: “Not later than December 31 of each year during which the Panel conducts a review and assessment under this subsection, the Panel shall submit to the Committees on Armed Services of the Senate and the House of Representatives a report setting forth the results of such review and assessment, including the Panel’s findings and recommendations.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" amended section generally. Prior to amendment, section related to establishment, membership, and duties of Code committee."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (c)(2)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" added subpar. (B) and redesignated former subpar. (B) as (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “and the Committee on Armed Services” for “and the Committee on National Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" substituted “Committee on Armed Services of the Senate and the Committee on National Security of the House of Representatives” for “Committees on Armed Services of the Senate and House of Representatives”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" substituted “Court of Appeals for the Armed Forces” for “Court of Military Appeals”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida834810e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida834810f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" effective immediately after the amendments made by div. E (§§ 5001–5542) of "},{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" take effect as provided for in section 5542 of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"10 U.S.C. 801","children":[],"tail":" note), see "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/s531/p"},"text":"section 531(p) of Pub. L. 115–91","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8348110-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":"