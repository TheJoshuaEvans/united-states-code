,"attrib":{"topic":"miscellaneous","id":"ida8348113-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Full Functionality of Military Justice Review Panel","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tV/s549E"},"text":"Pub. L. 117–81, div. A, title V, § 549E","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1726"},"text":"135 Stat. 1726","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dA/tV/s549E"},"text":"“Not later than 30 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":"], the Secretary of Defense shall establish or reconstitute, maintain, and ensure the full functionality of the Military Justice Review Panel established pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s946"},"text":"section 946 of title 10","children":[],"tail":", United States Code (article 146 of the Uniform Code of Military Justice)) [sic].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
