{"tag":"section","attrib":{"id":"idaba20a05-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12402"},"text":null,"children":[{"tag":"num","attrib":{"value":"12402"},"text":"§ 12402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Army and Air National Guard of the United States: commissioned officers; duty in National Guard Bureau","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaba20a06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12402/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may, with their consent, order commissioned officers of the Army National Guard of the United States and the Air National Guard of the United States to active duty in the National Guard Bureau.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba20a07-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12402/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba20a08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12402/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of officers of the Army National Guard of the United States in grades below brigadier general who are ordered to active duty in the National Guard Bureau may not be more than 40 percent of the number of officers of the Army authorized for duty in that Bureau and, to the extent practicable, shall not exceed 40 percent of the number of officers of the Army serving in that Bureau in any grade below brigadier general.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba20a09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12402/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of officers of the Air National Guard of the United States in grades below brigadier general who are ordered to active duty in the National Guard Bureau may not be more than 40 percent of the number of officers of the Air Force authorized for duty in that Bureau and, to the extent practicable, shall not exceed 40 percent of the number of officers of the Air Force serving in that Bureau in any grade below brigadier general.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaba20a0a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1662/f/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1662(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2993"},"text":"108 Stat. 2993","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1501/b/18/B"},"text":"Pub. L. 104–106, div. A, title XV, § 1501(b)(18)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/497"},"text":"110 Stat. 497","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaba20a0b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaba20a0c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaba20a0d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"t