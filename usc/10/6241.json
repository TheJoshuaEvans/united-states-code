{"tag":"section","attrib":{"id":"idaac90e9f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6241"},"text":null,"children":[{"tag":"num","attrib":{"value":"6241"},"text":"§ 6241.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for appointment of certain scientific, engineering, and technical personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaac90ea0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6241/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac90ea1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6241/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any provision of title 5 governing appointments in the competitive service and General Schedule classification and pay rates, the Secretary of Energy may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac90ea2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6241/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and set the rates of pay for not more than 200 positions in the Department of Energy for scientific, engineering, and technical personnel whose duties will relate to safety at defense nuclear facilities of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac90ea3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6241/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint persons to such positions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90ea4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6241/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rate of pay for a position established under paragraph (1) may not exceed the rate of pay payable for level III of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90ea5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6241/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the maximum extent practicable, the Secretary shall appoint persons under paragraph (1)(B) to the positions established under paragraph (1)(A) in accordance with the merit system principles set forth in section 2301 of such title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90ea6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6241/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"OPM Review","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac90ea7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6241/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall enter into an agreement with the Director of the Office of Personnel Management under which agreement the Director shall periodically evaluate the use of the authority set forth in subsection (a)(1). The Secretary shall reimburse the Director for evaluations conducted by the Director pursuant to the agreement. Any such reimbursement shall be credited to the revolving fund referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1304/e"},"text":"section 1304(e) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90ea8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6241/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Director determines as a result of such evaluation that the Secretary of Energy is not appointing persons to positions under such authority in a manner consistent with the merit system principles set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2301"},"text":"section 2301 of title 5","children":[],"tail":" or is setting rates of pay at levels that are not appropriate for the qualifications and experience of the persons appointed and the duties of the positions involved, the Director shall notify the Secretary and Congress of that determination."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90ea9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6241/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon receipt of a notification under paragraph (2), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac90eaa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6241/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take appropriate actions to appoint persons to positions under such authority in a manner consistent with such principles or to set rates of pay at levels that are appropriate for the qualifications and experience of the persons appointed and the duties of the positions involved; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac90eab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6241/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cease appointment of persons under such authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90eac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6241/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac90ead-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6241/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority provided under subsection (a)(1) shall terminate on ","children":[{"tag":"date","attrib":{"date":"2036-09-30"},"text":"September 30, 2036","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90eae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6241/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee may not be separated from employment with the Department of Energy or receive a reduction in pay by reason of the termination of authority under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac90eaf-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI"},"text":"Pub. L. 119–60, div. C, title XXXI","children":[],"tail":", §§ 3111(a), (d)(1)(F), (2)(B), 3115, "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1412"},"text":"139 Stat. 1412","children":[],"tail":", 1462, 1464.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac90eb0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac90eb1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaac90eb2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3115"},"text":"section 3115 of Pub. L. 119–60","children":[],"tail":" directed to "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/s4601"},"text":"section 4601 of Pub. L. 107–314","children":[],"tail":" executed to this section pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/1/F"},"text":"section 3111(d)(1)(F) of Pub. L. 119–60","children":[],"tail":". See Further Technical Amendments note set under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6114"},"text":"section 6114 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac90eb3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6241 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8291"},"text":"section 8291 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2701"},"text":"section 2701 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaac90eb4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", §§ 3111(d)(1)(F), 3115, substituted “"},{"tag":"date","attrib":{"date":"2036-09-30"},"text":"September 30, 2036","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":"”. See Codification note above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
