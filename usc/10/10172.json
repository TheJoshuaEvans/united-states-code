{"tag":"section","attrib":{"id":"idab8c866f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10172"},"text":null,"children":[{"tag":"num","attrib":{"value":"10172"},"text":"§ 10172.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Navy Reserve Force","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab8c8670-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10172/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Command","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy, with the advice and assistance of the Chief of Naval Operations, shall establish a Navy Reserve Force. The Navy Reserve Force shall be operated as a separate command of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c8671-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10172/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commander","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief of Navy Reserve shall be the commander of the Navy Reserve Force. The commander of the Navy Reserve Force reports directly to the Chief of Naval Operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c8672-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10172/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assignment of Forces","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Navy—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8c8673-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10172/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall assign to the Navy Reserve Force specified portions of the Navy Reserve other than forces assigned to the unified combatant command for special operations forces established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s167"},"text":"section 167 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c8674-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10172/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as otherwise directed by the Secretary of Defense in the case of forces assigned to carry out functions of the Secretary of the Navy specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8013"},"text":"section 8013 of this title","children":[],"tail":", shall assign to the combatant commands all such forces assigned to the Navy Reserve Force under paragraph (1) in the manner specified by the Secretary of Defense."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab8c8675-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXII/s1211/a/1"},"text":"Pub. L. 104–201, div. A, title XII, § 1211(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2689"},"text":"110 Stat. 2689","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s515/b/1/BB"},"text":"Pub. L. 109–163, div. A, title V, § 515(b)(1)(BB)","children":[],"tail":", (3)(G), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3233"},"text":"119 Stat. 3233","children":[],"tail":", 3234; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s809/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 809(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1840"},"text":"132 Stat. 1840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab8c8676-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab8c8677-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab8c8678-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “section 8013” for “section 5013”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s515/b/3/G"},"text":"Pub. L. 109–163, § 515(b)(3)(G)","children":[],"tail":", substituted “Navy Reserve” for “Naval Reserve” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s515/b/1/BB"},"text":"Pub. L. 109–163, § 515(b)(1)(BB)","children":[],"tail":", substituted “Navy Reserve” for “Naval Reserve” wherever appearing in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab8c8679-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab8c867a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
