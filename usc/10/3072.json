{"tag":"section","attrib":{"id":"idaa0570e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3072"},"text":null,"children":[{"tag":"num","attrib":{"value":"3072"},"text":"§ 3072.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comptroller General assessment of acquisition programs and initiatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa0570e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3072/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General of the United States shall submit to the congressional defense committees an annual assessment of selected acquisition programs and initiatives of the Department of Defense by March 30th of each year from 2020 through 2029.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa0570e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3072/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Analyses To Be Included","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The assessment required under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa0570e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3072/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a macro analysis of how well acquisition programs and initiatives are performing and reasons for that performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa0570e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3072/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific analyses of individual acquisition programs and initiatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa0570e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3072/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other issues as determined appropriate by the Comptroller General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa0570e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3072/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition Programs and Initiatives to Be Considered","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The assessment required under subsection (a) shall consider the following programs and initiatives:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa0570e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3072/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Selected weapon systems, as determined appropriate by the Comptroller General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa0570ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3072/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Selected information technology systems and initiatives, including defense business systems, networks, and software-intensive systems, as determined appropriate by the Comptroller General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa0570eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3072/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Selected prototyping and rapid fielding activities and initiatives, as determined appropriate by the Comptroller General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa0570ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s833/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 833(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1858"},"text":"132 Stat. 1858","children":[],"tail":", § 2229b; renumbered § 3072 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVIII/s813"},"text":"Pub. L. 116–283, div. A, title VIII, § 813","children":[],"tail":", title XVIII, § 1807(g)(1), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3749"},"text":"134 Stat. 3749","children":[],"tail":", 4159; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVIII/s812/a"},"text":"Pub. L. 117–263, div. A, title VIII, § 812(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2706"},"text":"136 Stat. 2706","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVIII/s813/a"},"text":"Pub. L. 118–159, div. A, title VIII, § 813(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/