{"tag":"section","attrib":{"id":"ida93130db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2153"},"text":null,"children":[{"tag":"num","attrib":{"value":"2153"},"text":"§ 2153.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capstone course: newly selected general and flag officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida93130dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2153/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each officer selected for promotion to the grade of brigadier general or, in the case of the Navy or the commissioned officer corps of the National Oceanic and Atmospheric Administration, rear admiral (lower half) shall be required, after such selection, to attend a military education course designed specifically to prepare new general and flag officers to work with the other uniformed services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93130dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2153/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93130de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2153/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (2), the Secretary of Defense or the Secretary of Commerce, as applicable, may waive subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida93130df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2153/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an officer whose immediately previous assignment was in a joint duty assignment and who is thoroughly familiar with joint matters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida93130e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2153/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when necessary for the good of the service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida93130e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2153/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an officer whose proposed selection for promotion is based primarily upon scientific and technical qualifications for which joint requirements do not exist (as determined under regulations prescribed under section 619(e)(4) ","children":[{"tag":"ref","attrib":{"idref":"fn002078"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002078"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida93130e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2153/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a medical officer, dental officer, veterinary officer, medical service officer, nurse, biomedical science officer, or chaplain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93130e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2153/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority of the Secretary of Defense to grant a waiver under paragraph (1) may only be delegated to the Deputy Secretary of Defense, an Under Secretary of Defense, or an Assistant Secretary of Defense. Such a waiver may be granted only on a case-by-case basis in the case of an individual officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida93130e4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s532/a/2"},"text":"Pub. L. 108–375, div. A, title V, § 532(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1897"},"text":"118 Stat. 1897","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/259/tII/s205/b/3"},"text":"Pub. L. 116–259, title II, § 205(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-23"},"text":"Dec. 23, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1167"},"text":"134 Stat. 1167","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida93130e5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida93130e6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida93130e7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s619/e/4"},"text":"Section 619(e)(4) of this title","children":[],"tail":", referred to in subsec. (b)(1)(C), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tIX/s931/b"},"text":"Pub. L. 103–160, div. A, title IX, § 931(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1734"},"text":"107 Stat. 1734","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s619a/f"},"text":"section 619a(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida93130e8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/259/s205/b/3/A"},"text":"Pub. L. 116–259, § 205(b)(3)(A)","children":[],"tail":", inserted “or the commissioned officer corps of the National Oceanic and Atmospheric Administration” after “in the case of the Navy” and substituted “other uniformed services” for “other armed forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/259/s205/b/3/B"},"text":"Pub. L. 116–259, § 205(b)(3)(B)","children":[],"tail":", inserted “or the Secretary of Commerce, as applicable,” after “the Secretary of Defense” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
