{"tag":"section","attrib":{"id":"idab4c21bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8766"},"text":null,"children":[{"tag":"num","attrib":{"value":"8766"},"text":"§ 8766.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan or gift of articles to ships’ sponsors and donors","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Navy, under regulations prescribed by him and without expense to the United States, may lend or give—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab4c21bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8766/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the sponsor of a vessel the name plate or any small article of negligible or sentimental value from that vessel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4c21bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8766/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any State, group, or organization named in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8765"},"text":"section 8765 of this title","children":[],"tail":" any article, material, or equipment, including silver service, given by it."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab4c21be-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/466"},"text":"70A Stat. 466","children":[],"tail":", § 7546; renumbered § 8766 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 807(d)(8), 809(a), "},{"tag":"date","attrib":{"date":