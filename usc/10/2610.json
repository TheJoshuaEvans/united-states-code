{"tag":"section","attrib":{"id":"ida9930021-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2610"},"text":null,"children":[{"tag":"num","attrib":{"value":"2610"},"text":"§ 2610.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitions for excellence: acceptance of monetary awards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9930022-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2610/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may accept a monetary award given to the Department of Defense by a nongovernmental entity as a result of the participation of the Department in a competition carried out to recognize excellence or innovation in providing services or administering programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9930023-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2610/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disposition of Awards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A monetary award accepted under subsection (a) shall be credited to one or more nonappropriated fund accounts supporting morale, welfare, and recreation activities for the command, installation, or other activity that is recognized for the award. Amounts so credited may be expended only for such activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9930024-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2610/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incidental Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to such limitations as may be provided in appropriation Acts, appropriations available to the Department of Defense may be used to pay incidental expenses incurred by the Department to participate in a competition described in subsection (a) or to accept a monetary award under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9930025-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2610/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations and Reporting","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9930026-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2610/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe regulations to determine the disposition of monetary awards accepted under this section and the payment of incidental expenses under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9930027-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2610/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the end of each year, the Secretary shall submit to Congress a report for that year describing the disposition of monetary awards accepted under this section and the payment of incidental expenses under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9930028-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2610/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority of the Secretary under this section shall expire on ","children":[{"tag":"date","attrib":{"date":"1998-02-10"},"text":"February 10, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9930029-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tIII/s377/a"},"text":"Pub. L. 104–106, div. A, title III, § 377(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/283"},"text":"110 Stat. 283","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tX/s1074/a/16"},"text":"Pub. L. 104–201, div. A, title X, § 1074(a)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2659"},"text":"110 Stat. 2659","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida993002a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida993002b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida993002c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" substituted “on "},{"tag":"date","attrib":{"date":"1998-02-10"},"text":"February 10, 1998","children":[],"tail":"” for “two years after the date of the enactment of the National Defense Authorization Act for Fiscal Year 1996”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
