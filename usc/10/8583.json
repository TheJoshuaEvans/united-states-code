{"tag":"section","attrib":{"id":"idab31e291-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8583"},"text":null,"children":[{"tag":"num","attrib":{"value":"8583"},"text":"§ 8583.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annuity premium to be paid by monthly installments; government reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each civilian member shall make a monthly allotment in an amount equal to 10 percent of his monthly basic salary toward the purchase of his deferred annuity policy. For each month the allotment is in force, the pay account of the civilian member shall be credited monthly from appropriations made for this purpose with an additional amount equal to 5 percent of his monthly basic salary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab31e292-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/439"},"text":"70A Stat. 439","children":[],"tail":", § 7083; "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s39"},"text":"Pub. L. 89–718, § 39","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1120"},"text":"80 Stat. 1120","children":[],"tail":"; renumbered § 8583, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/c/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab31e293-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"ta