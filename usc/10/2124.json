{"tag":"section","attrib":{"id":"ida92c75f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2124"},"text":null,"children":[{"tag":"num","attrib":{"value":"2124"},"text":"§ 2124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members of the program: numbers appointed","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida92c75f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2124/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Number of Members of the Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The number of persons who may be designated as members of the program for training in each health profession shall be as prescribed by the Secretary of Defense, except that the total number of persons so designated may not, at any time, exceed 6,300.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92c75f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2124/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mental Health Professionals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of the number of persons designated as members of the program at any time, 300 may be members of the program described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2121/a/1/B"},"text":"section 2121(a)(1)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida92c75fa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/426/s2/a"},"text":"Pub. L. 92–426, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-21"},"text":"Sept. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/718"},"text":"86 Stat. 718","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tVI/s672/i"},"text":"Pub. L. 99–145, title VI, § 672(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/664"},"text":"99 Stat. 664","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tVII"},"text":"Pub. L. 100–180, div. A, title VII","children":[],"tail":", §§ 711(a)(2), 712(b)(1), "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1108"},"text":"101 Stat. 1108","children":[],"tail":", 1112; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVII/s725/g"},"text":"Pub. L. 101–189, div. A, title VII, § 725(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1480"},"text":"103 Stat. 1480","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVII/s717"},"text":"Pub. L. 102–190, div. A, title VII, § 717","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1404"},"text":"105 Stat. 1404","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tV/s524/b"},"text":"Pub. L. 111–84, div. A, title V, § 524(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2285"},"text":"123 Stat. 2285","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida92c75fb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role