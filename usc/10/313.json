{"tag":"section","attrib":{"id":"ida79e342f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s313"},"text":null,"children":[{"tag":"num","attrib":{"value":"313"},"text":"§ 313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bilateral or regional cooperation programs: awards and mementos to recognize superior noncombat achievements or performance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida79e3430-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may present awards and mementos purchased with funds appropriated for operation and maintenance of the armed forces to recognize superior noncombat achievements or performance by members of friendly foreign forces and other foreign nationals that significantly enhance or support the National Security Strategy of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida79e3431-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities That May Be Recognized","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities that may be recognized under subsection (a) include superior achievement or performance that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida79e3432-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s313/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plays a crucial role in shaping the international security environment in ways that protect and promote United States interests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida79e3433-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s313/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supports or enhances United States overseas presence and peacetime engagement activities, including defense cooperation initiatives, security assistance training and programs, and training and exercises with the armed forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida79e3434-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s313/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" helps to deter aggression and coercion, build coalitions, and promote regional stability; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida79e3435-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s313/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves as a role model for appropriate conduct by military forces in emerging democracies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida79e3436-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s313/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Expenditures for the purchase or production of mementos for award under this section may not exceed the minimal value in effect under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7342/a/5"},"text":"section 7342(a)(5) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida79e3437-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tXII/s1222/a"},"text":"Pub. L. 108–136, div. A, title XII, § 1222(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1652"},"text":"117 Stat. 1652","children":[],"tail":", § 1051b; renumbered § 313, "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1241/b"},"text":"Pub. L. 114–328, div. A, title XII, § 1241(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2500"},"text":"130 Stat. 2500","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida79e3438-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida79e3439-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida79e343a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1051b"},"text":"section 1051b of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
