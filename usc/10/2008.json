{"tag":"section","attrib":{"id":"ida9208f38-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2008"},"text":null,"children":[{"tag":"num","attrib":{"value":"2008"},"text":"§ 2008.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to use funds for certain educational purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds appropriated to the Department of Defense may be used to carry out construction, as defined in section 7013(3) of the Elementary and Secondary Education Act of 1965, or to carry out section 7008 of such Act, relating to the provision of assistance to certain school facilities under the impact aid program.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida9208f39-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXIV/s1401/g/1"},"text":"Pub. L. 98–525, title XIV, § 1401(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2618"},"text":"98 Stat. 2618","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dB/tXXVIII/s2891"},"text":"Pub. L. 104–106, div. B, title XXVIII, § 2891","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/590"},"text":"110 Stat. 590","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/uuu/3"},"text":"Pub. L. 114–95, title IX, § 9215(uuu)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2190"},"text":"129 Stat. 2190","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9208f3a-3a6f-11f1-a58a-d8db54b14