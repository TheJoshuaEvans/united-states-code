{"tag":"section","attrib":{"id":"ida9957101-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2636"},"text":null,"children":[{"tag":"num","attrib":{"value":"2636"},"text":"§ 2636.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deductions from amounts due carriers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9957102-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2636/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amounts for Loss or Damage","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An amount deducted from an amount due a carrier shall be credited as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9957103-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2636/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If deducted because of loss of or damage to material in transit for a military department, the amount shall be credited to the proper appropriation, account, or fund from which the same or similar material may be replaced.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9957104-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2636/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If deducted as an administrative offset for an overpayment previously made to the carrier under any Department of Defense contract for transportation services or as liquidated damages due under any such contract, the amount shall be credited to the appropriation or account from which payments for the transportation services were made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9957105-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2636/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Simplified Offset for Collection of Claims Not in Excess of the Simplified Acquisition Threshold","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9957106-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2636/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case in which the total amount of a claim for the recovery of overpayments or liquidated damages under a contract described in subsection (a)(2) does not exceed the simplified acquisition threshold, the Secretary of Defense or the Secretary concerned, in exercising the authority to collect the claim by administrative offset under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3716"},"text":"section 3716 of title 31","children":[],"tail":", may apply paragraphs (2) and (3) of subsection (a) of that section with respect to that collection after (rather than before) the claim is so collected."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9957107-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2636/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Regulations prescribed by the Secretary of Defense under subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3716"},"text":"section 3716 of title 31","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9957108-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2636/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include provisions to carry out paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9957109-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2636/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide the carrier for a claim subject to paragraph (1) with an opportunity to offer an alternative method of repaying the claim (rather than by administrative offset) if the collection of the claim by administrative offset has not already been made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida995710a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2636/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the term “simplified acquisition threshold” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s134"},"text":"section 134 of title 41","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida995710b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258/s2/b/5/B"},"text":"Pub. L. 97–258, § 2(b)(5)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1053"},"text":"96 Stat. 1053","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1009(a)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–250; "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/b/43"},"text":"Pub. L. 111–350, § 5(b)(43)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3846"},"text":"124 Stat. 3846","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida995710c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida995710d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida995710e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2636","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:489a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-06-25/ch442/s1"},"text":"June 25, 1956, ch. 442, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/70/336"},"text":"70 Stat. 336","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “An amount deducted from an amount due” are substituted for “Moneys arising from deductions made from” for clarity. The words “military or naval” and “account of” are omitted as surplus. The words “a military department” are substituted for “the Departments of the Army, Navy, or Air Force” because of 10:101(7). The Department of War was designated the Department of the Army by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/s205/a"},"text":"section 205(a) of the Act of July 26, 1947","children":[],"tail":" (ch. 343, "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":"), and by sections 1 and 53 of the Act of "},{"tag":"date","attrib":{"date":"1956-08-10"},"text":"August 10, 1956","children":[],"tail":" (ch. 1041, "},{"tag":"ref","attrib":{"href":"/us/stat/70A/157"},"text":"70A Stat. 157","children":[],"tail":", 676). The Department of the Air Force is included because of sections 205(a) and 207(a) and (f) of the Act of "},{"tag":"date","attrib":{"date":"1947-07-26"},"text":"July 26, 1947","children":[],"tail":" (ch. 343, "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":", 502), and "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/s1"},"text":"section 1 of the Act of August 10, 1956","children":[],"tail":" (ch. 1041, "},{"tag":"ref","attrib":{"href":"/us/stat/70A/488"},"text":"70A Stat. 488","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida995710f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9957110-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t41/s134"},"text":"section 134 of title 41","children":[],"tail":"” for “section 4(11) of the Office of Federal Procurement Policy Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s403/11"},"text":"41 U.S.C. 403(11)","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows: “An amount deducted from an amount due a carrier because of loss of or damage to material in transit for a military department shall be credited to the proper appropriation, account, or fund from which the same or similar material may be replaced.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9957111-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9957112-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1009(b)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–251, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/398/s1/dA"},"text":"“Subsections (a)(2) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2636"},"text":"section 2636 of title 10","children":[],"tail":", United States Code, as added by subsection (a)(1), shall apply with respect to contracts entered into after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
