{"tag":"section","attrib":{"id":"id746aef14-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1101"},"text":null,"children":[{"tag":"num","attrib":{"value":"1101"},"text":"§ 1101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unauthorized fixation and trafficking in sound recordings and music videos","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id746aef15-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unauthorized Acts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Anyone who, without the consent of the performer or performers involved—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id746aef16-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fixes the sounds or sounds and images of a live musical performance in a copy or phonorecord, or reproduces copies or phonorecords of such a performance from an unauthorized fixation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746aef17-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmits or otherwise communicates to the public the sounds or sounds and images of a live musical performance, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746aef18-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1101/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distributes or offers to distribute, sells or offers to sell, rents or offers to rent, or traffics in any copy or phonorecord fixed as described in paragraph (1), regardless of whether the fixations occurred in the United States,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be subject to the remedies provided in sections 502 through 505, to the same extent as an infringer of copyright.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746aef19-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “traffic” has the same meaning as in section 2320(e) ","children":[{"tag":"ref","attrib":{"idref":"fn002017"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002017"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 18."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746aef1a-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall apply to any act or acts that occur on or after the date of the enactment of the Uruguay Round Agreements Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746aef1b-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1101/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Law Not Preempted","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section may be construed to annul or limit any rights or remedies under the common law or statutes of any State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id746aef1c-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/tV/s512/a"},"text":"Pub. L. 103–465, title V, § 512(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4974"},"text":"108 Stat. 4974","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/181/s2/c/3"},"text":"Pub. L. 109–181, § 2(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-16"},"text":"Mar. 16, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/288"},"text":"120 Stat. 288","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id746aef1d-2930-11f1-b33a-a9dcf95eef0b"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id746aef1e-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id746aef1f-2930-11f1-b33a-a9dcf95eef0b"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2320"},"text":"Section 2320 of title 18","children":[],"tail":", referred to in subsec. (b), was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVIII/s818/h"},"text":"Pub. L. 112–81, div. A, title VIII, § 818(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1497"},"text":"125 Stat. 1497","children":[],"tail":", and, as so amended, provisions similar to those formerly appearing in subsec. (e) are now contained in subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of the Uruguay Round Agreements Act, referred to in subsec. (c), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id746aef20-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/181"},"text":"Pub. L. 109–181","children":[],"tail":" added subsec. (b) and struck out heading and text of former subsec. (b). Text read as follows: “As used in this section, the term ‘traffic in’ means transport, transfer, or otherwise dispose of, to another, as consideration for anything of value, or make or obtain control of with intent to transport, transfer, or dispose of.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
