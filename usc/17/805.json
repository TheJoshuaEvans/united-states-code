{"tag":"section","attrib":{"id":"id746634c3-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s805"},"text":null,"children":[{"tag":"num","attrib":{"value":"805"},"text":"§ 805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule for voluntarily negotiated agreements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any rates or terms under this title that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id746634c4-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s805/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are agreed to by participants to a proceeding under section 803(b)(3),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746634c5-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s805/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are adopted by the Copyright Royalty Judges as part of a determination under this chapter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746634c6-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s805/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are in effect for a period shorter than would otherwise apply under a determination pursuant to this chapter,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall remain in effect for such period of time as would otherwise apply under such determination, except that the Copyright Royalty Judges shall adjust the rates pursuant to the voluntary negotiations to reflect national monetary inflation during the additional period the rates remain in effect.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id746634c7-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/419/s3/a"},"text":"Pub. L. 108–419, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-11-30"},"text":"Nov. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2360"},"text":"118 Stat. 2360","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id746634c8-2930-11f1-b33a-a9dcf95eef0b"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id746634c9-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id746634ca-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 805 to 810 were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/198/s2/e"},"text":"Pub. L. 103–198, § 2(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-17"},"text":"Dec. 17, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2308"},"text":"107 Stat. 2308","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 805, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/553/tI/s101"},"text":"Pub. L. 94–553, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-19"},"text":"Oct. 19, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2598"},"text":"90 Stat. 2598","children":[],"tail":", related to staff of Copyright Royalty Tribunal."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 806, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/553/tI/s101"},"text":"Pub. L. 94–553, title I, § 101","chi