{"tag":"section","attrib":{"id":"id746faa84-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1326"},"text":null,"children":[{"tag":"num","attrib":{"value":"1326"},"text":"§ 1326.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for false marking","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id746faa85-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1326/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever, for the purpose of deceiving the public, marks upon, applies to, or uses in advertising in connection with an article made, used, distributed, or sold, a design which is not protected under this chapter, a design notice specified in section 1306, or any other words or symbols importing that the design is protected under this chapter, knowing that the design is not so protected, shall pay a civil fine of not more than $500 for each such offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746faa86-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1326/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Suit by Private Persons","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person may sue for the penalty established by subsection (a), in which event one-half of the penalty shall be awarded to the person suing and the remainder shall be awarded to the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id746faa87-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/304/tV/s502"},"text":"Pub. L. 105–304, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2915"},"text":"112 Stat. 2915","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
