{"tag":"section","attrib":{"id":"id74663502-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s905"},"text":null,"children":[{"tag":"num","attrib":{"value":"905"},"text":"§ 905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive rights in mask works","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The owner of a mask work provided protection under this chapter has the exclusive rights to do and to authorize any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74663503-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s905/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reproduce the mask work by optical, electronic, or any other means;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74663504-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s905/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to import or distribute a semiconductor chip product in which the mask work is embodied; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74663505-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s905/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to induce or knowingly to cause another person to do any of the acts described in paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74663506-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620/tIII/s302"},"text":"Pub. L. 98–620, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3350"},"text":"98 Stat. 3350","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
