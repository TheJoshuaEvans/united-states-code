{"tag":"section","attrib":{"id":"id746faa55-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1315"},"text":null,"children":[{"tag":"num","attrib":{"value":"1315"},"text":"§ 1315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of announcements and indexes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id746faa56-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1315/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publications of the Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall publish lists and indexes of registered designs and cancellations of designs and may also publish the drawings or other pictorial representations of registered designs for sale or other distribution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746faa57-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1315/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"File of Representatives of Registered Designs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall establish and maintain a file of the drawings or other pictorial representations of registered designs. The file shall be available for use by the public under such conditions as the Administrator may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id746faa58-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/304/tV/s502"},"text":"Pub. L. 105–304, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2912"},"text":"112 Stat. 2912","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
