{"tag":"section","attrib":{"id":"id746d6027-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1308"},"text":null,"children":[{"tag":"num","attrib":{"value":"1308"},"text":"§ 1308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive rights","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The owner of a design protected under this chapter has the exclusive right to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id746d6028-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1308/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make, have made, or import, for sale or for use in trade, any useful article embodying that design; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d6029-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1308/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sell or distribute for sale or for use in trade any useful article embodying that design.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id746d602a-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/304/tV/s502"},"text":"Pub. L. 105–304, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2908"},"text":"112 Stat. 2908","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
