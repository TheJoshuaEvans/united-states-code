{"tag":"section","attrib":{"id":"id746d5fe2-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1204"},"text":null,"children":[{"tag":"num","attrib":{"value":"1204"},"text":"§ 1204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal offenses and penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id746d5fe3-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1204/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who violates section 1201 or 1202 willfully and for purposes of commercial advantage or private financial gain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id746d5fe4-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1204/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be fined not more than $500,000 or imprisoned for not more than 5 years, or both, for the first offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d5fe5-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1204/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be fined not more than $1,000,000 or imprisoned for not more than 10 years, or both, for any subsequent offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746d5fe6-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1204/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation for Nonprofit Library, Archives, Educational Institution, or Public Broadcasting Entity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall not apply to a nonprofit library, archives, educational institution, or public broadcasting entity (as defined under section 118(f)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746d5fe7-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1204/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statute of Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No criminal proceeding shall be brought under this section unless such proceeding is commenced within 5 years after the cause of action arose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id746d5fe8-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/304/tI/s103/a"},"text":"Pub. L. 105–304, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2876"},"text":"112 Stat. 2876","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tV/s5004/b"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title V, § 5004(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–593; "},{"tag":"ref","attrib":{"href":"/us/pl/111/295/s6/f/3"},"text":"Pub. L. 111–295, § 6(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-09"},"text":"Dec. 9, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3181"},"text":"124 Stat. 3181","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id746d5fe9-2930-11f1-b33a-a9dcf95eef0b"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id746d5fea-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id746d5feb-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/295"},"text":"Pub. L. 111–295","children":[],"tail":" substituted “118(f)” for “118(g)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" amended heading and text of subsec. (b) generally. Prior to amendment, text read as follows: “Subsection (a) shall not apply to a nonprofit library, archives, or educational institution.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
