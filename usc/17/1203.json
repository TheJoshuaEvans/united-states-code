{"tag":"section","attrib":{"id":"id746d5fc7-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1203"},"text":null,"children":[{"tag":"num","attrib":{"value":"1203"},"text":"§ 1203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil remedies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id746d5fc8-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person injured by a violation of section 1201 or 1202 may bring a civil action in an appropriate United States district court for such violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746d5fc9-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Powers of the Court","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In an action brought under subsection (a), the court—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id746d5fca-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1203/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may grant temporary and permanent injunctions on such terms as it deems reasonable to prevent or restrain a violation, but in no event shall impose a prior restraint on free speech or the press protected under the 1st amendment to the Constitution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d5fcb-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1203/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at any time while an action is pending, may order the impounding, on such terms as it deems reasonable, of any device or product that is in the custody or control of the alleged violator and that the court has reasonable cause to believe was involved in a violation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d5fcc-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1203/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may award damages under subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d5fcd-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1203/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in its discretion may allow the recovery of costs by or against any party other than the United States or an officer thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d5fce-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1203/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in its discretion may award reasonable attorney’s fees to the prevailing party; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d5fcf-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1203/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, as part of a final judgment or decree finding a violation, order the remedial modification or the destruction of any device or product involved in the violation that is in the custody or control of the violator or has been impounded under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746d5fd0-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1203/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Award of Damages.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id746d5fd1-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1203/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this title, a person committing a violation of section 1201 or 1202 is liable for either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id746d5fd2-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1203/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual damages and any additional profits of the violator, as provided in paragraph (2), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id746d5fd3-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1203/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statutory damages, as provided in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d5fd4-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1203/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actual damages","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The court shall award to the complaining party the actual damages suffered by the party as a result of the violation, and any profits of the violator that are attributable to the violation and are not taken into account in computing the actual damages, if the complaining party elects such damages at any time before final judgment is entered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d5fd5-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1203/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statutory damages","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id746d5fd6-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1203/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At any time before final judgment is entered, a complaining party may elect to recover an award of statutory damages for each violation of section 1201 in the sum of not less than $200 or more than $2,500 per act of circumvention, device, product, component, offer, or performance of service, as the court considers just.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id746d5fd7-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1203/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At any time before final judgment is entered, a complaining party may elect to recover an award of statutory damages for each violation of section 1202 in the sum of not less than $2,500 or more than $25,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d5fd8-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1203/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repeated violations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any case in which the injured party sustains the burden of proving, and the court finds, that a person has violated section 1201 or 1202 within 3 years after a final judgment was entered against the person for another such violation, the court may increase the award of damages up to triple the amount that would otherwise be awarded, as the court considers just.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d5fd9-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1203/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Innocent violations.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id746d5fda-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1203/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The court in its discretion may reduce or remit the total award of damages in any case in which the violator sustains the burden of proving, and the court finds, that the violator was not aware and had no reason to believe that its acts constituted a violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id746d5fdb-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1203/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonprofit library, archives, educational institutions, or public broadcasting entities.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"id746d5fdc-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1203/c/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subparagraph, the term “public broadcasting entity” has the meaning given such term under section 118(f).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id746d5fdd-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1203/c/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a nonprofit library, archives, educational institution, or public broadcasting entity, the court shall remit damages in any case in which the library, archives, educational institution, or public broadcasting entity sustains the burden of proving, and the court finds, that the library, archives, educational institution, or public broadcasting entity was not aware and had no reason to believe that its acts constituted a violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id746d5fde-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/304/tI/s103/a"},"text":"Pub. L. 105–304, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2874"},"text":"112 Stat. 2874","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tV/s5004/a"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title V, § 5004(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–593; "},{"tag":"ref","attrib":{"href":"/us/pl/111/295/s6/f/3"},"text":"Pub. L. 111–295, § 6(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-09"},"text":"Dec. 9, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3181"},"text":"124 Stat. 3181","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id746d5fdf-2930-11f1-b33a-a9dcf95eef0b"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id746d5fe0-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id746d5fe1-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (c)(5)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/295"},"text":"Pub. L. 111–295","children":[],"tail":" substituted “118(f)” for “118(g)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (c)(5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" amended heading and text of subpar. (B) generally. Prior to amendment, text read as follows: “In the case of a nonprofit library, archives, or educational institution, the court shall remit damages in any case in which the library, archives, or educational institution sustains the burden of proving, and the court finds, that the library, archives, or educational institution was not aware and had no reason to believe that its acts constituted a violation.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
