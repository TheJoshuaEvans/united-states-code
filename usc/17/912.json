{"tag":"section","attrib":{"id":"id7468a54b-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s912"},"text":null,"children":[{"tag":"num","attrib":{"value":"912"},"text":"§ 912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7468a54c-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this chapter shall affect any right or remedy held by any person under chapters 1 through 8 or 10 of this title, or under title 35.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7468a54d-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t17/s908/b"},"text":"section 908(b) of this title","children":[],"tail":", references to “this title” or “title 17” in chapters 1 through 8 or 10 of this title shall be deemed not to apply to this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7468a54e-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s912/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of this chapter shall preempt the laws of any State to the extent those laws provide any rights or remedies with respect to a mask work which are equivalent to those rights or remedies provided by this chapter, except that such preemption shall be effective only with respect to actions filed on or after ","children":[{"tag":"date","attrib":{"date":"1986-01-01"},"text":"January 1, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7468a54f-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s912/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subsection (c), nothing in this chapter shall detract from any rights of a mask work owner, whether under Federal law (exclusive of this chapter) or under the common law or the statutes of a State, heretofore or hereafter declared or enacted, with respect to any mask work first commercially exploited before ","children":[{"tag":"date","attrib":{"date":"1983-07-01"},"text":"July 1, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7468a550-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620/tIII/s302"},"text":"Pub. L. 98–620, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3354"},"text":"98 Stat. 3354","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/702/tX/s1020/b"},"text":"Pub. L. 100–702, title X, § 1020(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4672"},"text":"102 Stat. 4672","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/563/s3/c"},"text":"Pub. L. 102–563, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4248"},"text":"106 Stat. 4248","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7468a551-2930-11f1-b33a-a9dcf95eef0b"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7468a552-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7468a553-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/563"},"text":"Pub. L. 102–563","children":[],"tail":" inserted “or 10” after “8”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/702"},"text":"Pub. L. 100–702","children":[],"tail":" redesignated subsec. (e) as (d) and struck out former subsec. (d) which read as follows: “The provisions of sections 1338, 1400(a), and 1498(b) and (c) of title 28 shall apply with respect to exclusive rights in mask works under this chapter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
