{"tag":"section","attrib":{"id":"id7468a5d7-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1006"},"text":null,"children":[{"tag":"num","attrib":{"value":"1006"},"text":"§ 1006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entitlement to royalty payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7468a5d8-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1006/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interested Copyright Parties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The royalty payments deposited pursuant to section 1005 shall, in accordance with the procedures specified in section 1007, be distributed to any interested copyright party—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7468a5d9-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1006/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" whose musical work or sound recording has been—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7468a5da-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1006/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" embodied in a digital musical recording or an analog musical recording lawfully made under this title that has been distributed, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7468a5db-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1006/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distributed in the form of digital musical recordings or analog musical recordings or disseminated to the public in transmissions, during the period to which such payments pertain; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7468a5dc-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1006/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has filed a claim under section 1007.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7468a5dd-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1006/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation of Royalty Payments to Groups","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The royalty payments shall be divided into 2 funds as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7468a5de-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1006/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"The sound recordings fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"66⅔ percent of the royalty payments shall be allocated to the Sound Recordings Fund. 2⅝ percent of the royalty payments allocated to the Sound Recordings Fund shall be placed in an escrow account managed by an independent administrator jointly appointed by the interested copyright parties described in section 1001(7)(A) and the American Federation of Musicians (or any successor entity) to be distributed to nonfeatured musicians (whether or not members of the American Federation of Musicians or any successor entity) who have performed on sound recordings distributed in the United States. 1⅜ percent of the royalty payments allocated to the Sound Recordings Fund shall be placed in an escrow account managed by an independent administrator jointly appointed by the interested copyright parties described in section 1001(7)(A) and the American Federation of Television and Radio Artists (or any successor entity) to be distributed to nonfeatured vocalists (whether or not members of the American Federation of Television and Radio Artists or any successor entity) who have performed on sound recordings distributed in the United States. 40 percent of the remaining royalty payments in the Sound Recordings Fund shall be distributed to the interested copyright parties described in section 1001(7)(C), and 60 percent of such remaining royalty payments shall be distributed to the interested copyright parties described in section 1001(7)(A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7468a5df-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1006/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"The musical works fund.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7468a5e0-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1006/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 33⅓ percent of the royalty payments shall be allocated to the Musical Works Fund for distribution to interested copyright parties described in section 1001(7)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7468a5e1-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1006/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7468a5e2-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1006/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Music publishers shall be entitled to 50 percent of the royalty payments allocated to the Musical Works Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7468a5e3-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1006/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Writers shall be entitled to the other 50 percent of the royalty payments allocated to the Musical Works Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7468a5e4-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1006/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation of Royalty Payments Within Groups","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If all interested copyright parties within a group specified in subsection (b) do not agree on a voluntary proposal for the distribution of the royalty payments within each group, the Copyright Royalty Judges shall, pursuant to the procedures specified under section 1007(c), allocate royalty payments under this section based on the extent to which, during the relevant period—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7468a5e5-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1006/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the Sound Recordings Fund, each sound recording was distributed in the form of digital musical recordings or analog musical recordings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7468a5e6-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1006/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the Musical Works Fund, each musical work was distributed in the form of digital musical recordings or analog musical recordings or disseminated to the public in transmissions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7468a5e7-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/563/s2"},"text":"Pub. L. 102–563, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4242"},"text":"106 Stat. 4242","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/198/s6/b/3"},"text":"Pub. L. 103–198, § 6(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-17"},"text":"Dec. 17, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2312"},"text":"107 Stat. 2312","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/80/s12/a/24"},"text":"Pub. L. 105–80, § 12(a)(24)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-13"},"text":"Nov. 13, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1535"},"text":"111 Stat. 1535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/419/s5/i/2"},"text":"Pub. L. 108–419, § 5(i)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-11-30"},"text":"Nov. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2368"},"text":"118 Stat. 2368","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7468a5e8-2930-11f1-b33a-a9dcf95eef0b"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7468a5e9-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7468a5ea-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/419"},"text":"Pub. L. 108–419","children":[],"tail":" substituted “Copyright Royalty Judges” for “Librarian of Congress shall convene a copyright arbitration royalty panel which” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/80"},"text":"Pub. L. 105–80","children":[],"tail":" substituted “Federation of Television” for “Federation Television” before “and Radio Artists or any successor entity)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/198"},"text":"Pub. L. 103–198","children":[],"tail":" substituted “Librarian of Congress shall convene a copyright arbitration royalty panel which” for “Copyright Royalty Tribunal” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7468a5eb-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7468a5ec-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/419"},"text":"Pub. L. 108–419","children":[],"tail":" effective 6 months after "},{"tag":"date","attrib":{"date":"2004-11-30"},"text":"Nov. 30, 2004","children":[],"tail":", subject to transition provisions, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/419/s6"},"text":"section 6 of Pub. L. 108–419","children":[],"tail":", set out as an Effective Date; Transition Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t17/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
