{"tag":"section","attrib":{"id":"id746aeeed-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009"},"text":null,"children":[{"tag":"num","attrib":{"value":"1009"},"text":"§ 1009.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil remedies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id746aeeee-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any interested copyright party injured by a violation of section 1002 or 1003 may bring a civil action in an appropriate United States district court against any person for such violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746aeeef-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Civil Actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person injured by a violation of this chapter may bring a civil action in an appropriate United States district court for actual damages incurred as a result of such violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746aeef0-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Powers of the Court","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In an action brought under subsection (a), the court—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id746aeef1-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may grant temporary and permanent injunctions on such terms as it deems reasonable to prevent or restrain such violation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746aeef2-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a violation of section 1002, or in the case of an injury resulting from a failure to make royalty payments required by section 1003, shall award damages under subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746aeef3-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in its discretion may allow the recovery of costs by or against any party other than the United States or an officer thereof; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746aeef4-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in its discretion may award a reasonable attorney’s fee to the prevailing party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746aeef5-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Award of Damages.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id746aeef6-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Damages for section 1002 or 1003 violations.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id746aeef7-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actual damages","children":[],"tail":".—"}],"tail":null},{"tag":"clause","attrib":{"id":"id746aeef8-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In an action brought under subsection (a), if the court finds that a violation of section 1002 or 1003 has occurred, the court shall award to the complaining party its actual damages if the complaining party elects such damages at any time before final judgment is entered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id746aeef9-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of section 1003, actual damages shall constitute the royalty payments that should have been paid under section 1004 and deposited under section 1005. In such a case, the court, in its discretion, may award an additional amount of not to exceed 50 percent of the actual damages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id746aeefa-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statutory damages for section 1002 violations.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"id746aeefb-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Device","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A complaining party may recover an award of statutory damages for each violation of section 1002(a) or (c) in the sum of not more than $2,500 per device involved in such violation or per device on which a service prohibited by section 1002(c) has been performed, as the court considers just.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id746aeefc-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Digital musical recording","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A complaining party may recover an award of statutory damages for each violation of section 1002(d) in the sum of not more than $25 per digital musical recording involved in such violation, as the court considers just.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id746aeefd-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transmission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A complaining party may recover an award of damages for each transmission or communication that violates section 1002(e) in the sum of not more than $10,000, as the court considers just.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746aeefe-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repeated violations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any case in which the court finds that a person has violated section 1002 or 1003 within 3 years after a final judgment against that person for another such violation was entered, the court may increase the award of damages to not more than double the amounts that would otherwise be awarded under paragraph (1), as the court considers just.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746aeeff-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Innocent violations of section 1002","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The court in its discretion may reduce the total award of damages against a person violating section 1002 to a sum of not less than $250 in any case in which the court finds that the violator was not aware and had no reason to believe that its acts constituted a violation of section 1002.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746aef00-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of Damages","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any award of damages under subsection (d) shall be deposited with the Register pursuant to section 1005 for distribution to interested copyright parties as though such funds were royalty payments made pursuant to section 1003.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746aef01-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Impounding of Articles","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At any time while an action under subsection (a) is pending, the court may order the impounding, on such terms as it deems reasonable, of any digital audio recording device, digital musical recording, or device specified in section 1002(c) that is in the custody or control of the alleged violator and that the court has reasonable cause to believe does not comply with, or was involved in a violation of, section 1002.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746aef02-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remedial Modification and Destruction of Articles","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In an action brought under subsection (a), the court may, as part of a final judgment or decree finding a violation of section 1002, order the remedial modification or the destruction of any digital audio recording device, digital musical recording, or device specified in section 1002(c) that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id746aef03-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not comply with, or was involved in a violation of, section 1002, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746aef04-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1009/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the custody or control of the violator or has been impounded under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id746aef05-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/563/s2"},"text":"Pub. L. 102–563, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4245"},"text":"106 Stat. 4245","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
