{"tag":"section","attrib":{"id":"id74721b32-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502"},"text":null,"children":[{"tag":"num","attrib":{"value":"1502"},"text":"§ 1502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copyright Claims Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74721b33-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established in the Copyright Office the Copyright Claims Board, which shall serve as an alternative forum in which parties may voluntarily seek to resolve certain copyright claims regarding any category of copyrighted work, as provided in this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74721b34-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers and Staff.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74721b35-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Copyright claims officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Register of Copyrights shall recommend 3 full-time Copyright Claims Officers to serve on the Copyright Claims Board in accordance with paragraph (3)(A). The Officers shall be appointed by the Librarian of Congress to such positions after consultation with the Register of Copyrights.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74721b36-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Copyright claims attorneys","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Register of Copyrights shall hire not fewer than 2 full-time Copyright Claims Attorneys to assist in the administration of the Copyright Claims Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74721b37-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifications.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74721b38-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Copyright claims officers.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"id74721b39-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each Copyright Claims Officer shall be an attorney who has not fewer than 7 years of legal experience.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74721b3a-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Experience","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Two of the Copyright Claims Officers shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id74721b3b-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have substantial experience in the evaluation, litigation, or adjudication of copyright infringement claims; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id74721b3c-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between those 2 Officers, have represented or presided over a diversity of copyright interests, including those of both owners and users of copyrighted works.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74721b3d-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternative dispute resolution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Copyright Claims Officer not described in clause (ii) shall have substantial familiarity with copyright law and experience in the field of alternative dispute resolution, including the resolution of litigation matters through that method of resolution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74721b3e-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Copyright claims attorneys","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each Copyright Claims Attorney shall be an attorney who has not fewer than 3 years of substantial experience in copyright law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74721b3f-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74721b40-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Copyright claims officers.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"id74721b41-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subparagraph, the term “senior level employee of the Federal Government” means an employee, other than an employee in the Senior Executive Service, the position of whom is classified above GS–15 of the General Schedule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74721b42-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pay range","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each Copyright Claims Officer shall be compensated at a rate of pay that is not less than the minimum, and not more than the maximum, rate of pay payable for senior level employees of the Federal Government, including locality pay, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74721b43-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Copyright claims attorneys","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each Copyright Claims Attorney shall be compensated at a rate of pay that is not more than the maximum rate of pay payable for level 10 of GS–15 of the General Schedule, including locality pay, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74721b44-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74721b45-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subparagraph (B), a Copyright Claims Officer shall serve for a renewable term of 6 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74721b46-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial terms","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The terms for the first Copyright Claims Officers appointed under this chapter shall be as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id74721b47-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The first such Copyright Claims Officer appointed shall be appointed for a term of 4 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74721b48-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The second Copyright Claims Officer appointed shall be appointed for a term of 5 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74721b49-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The third Copyright Claims Officer appointed shall be appointed for a term of 6 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74721b4a-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vacancies and incapacity.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74721b4b-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vacancy.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"id74721b4c-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a vacancy occurs in the position of a Copyright Claims Officer, the Librarian of Congress shall, upon the recommendation of, and in consultation with, the Register of Copyrights, act expeditiously to appoint a Copyright Claims Officer for that position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74721b4d-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vacancy before expiration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual appointed to fill a vacancy occurring before the expiration of the term for which the predecessor of the individual was appointed shall be appointed to serve a 6-year term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74721b4e-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incapacity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a Copyright Claims Officer is temporarily unable to perform the duties of the Officer, the Librarian of Congress shall, upon recommendation of, and in consultation with, the Register of Copyrights, act expeditiously to appoint an interim Copyright Claims Officer to perform such duties during the period of such incapacity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74721b4f-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sanction or removal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to section 1503(b), the Librarian of Congress may sanction or remove a Copyright Claims Officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74721b50-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative support","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Register of Copyrights shall provide the Copyright Claims Officers and Copyright Claims Attorneys with necessary administrative support, including technological facilities, to carry out the duties of the Officers and Attorneys under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74721b51-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1502/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Location of copyright claims board","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The offices and facilities of the Copyright Claims Officers and Copyright Claims Attorneys shall be located at the Copyright Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74721b52-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dQ/tII/s212/b"},"text":"Pub. L. 116–260, div. Q, title II, § 212(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2177"},"text":"134 Stat. 2177","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74721b53-2930-11f1-b33a-a9dcf95eef0b"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id74721b54-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id74721b55-2930-11f1-b33a-a9dcf95eef0b"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in subsec. (b)(4), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id74721b56-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id74721b57-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dQ/tII/s212/d"},"text":"Pub. L. 116–260, div. Q, title II, § 212(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2199"},"text":"134 Stat. 2199","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dQ/tII/s212/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":"], the Copyright Claims Board established under "},{"tag":"ref","attrib":{"href":"/us/usc/t17/s1502"},"text":"section 1502 of title 17","children":[],"tail":", United States Code, as added by subsection (b) of this section, shall begin operations."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extension","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Register of Copyrights may, for good cause, extend the deadline under paragraph (1) by not more than 180 days if the Register of Copyrights provides notice of the extension to the public and to Congress.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
