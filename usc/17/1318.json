{"tag":"section","attrib":{"id":"id746faa5d-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1318"},"text":null,"children":[{"tag":"num","attrib":{"value":"1318"},"text":"§ 1318.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copies of records","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon payment of the prescribed fee, any person may obtain a certified copy of any official record of the Office of the Administrator that relates to this chapter. That copy shall be admissible in evidence with the same effect as the original.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id746faa5e-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/304/tV/s502"},"text":"Pub. L. 105–304, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2913"},"text":"112 Stat. 2913","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
