{"tag":"section","attrib":{"id":"id746d5ff0-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1301"},"text":null,"children":[{"tag":"num","attrib":{"value":"1301"},"text":"§ 1301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designs protected","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id746d5ff1-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designs Protected.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id746d5ff2-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The designer or other owner of an original design of a useful article which makes the article attractive or distinctive in appearance to the purchasing or using public may secure the protection provided by this chapter upon complying with and subject to this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d5ff3-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel features","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The design of a vessel hull, deck, or combination of a hull and deck, including a plug or mold, is subject to protection under this chapter, notwithstanding section 1302(4).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d5ff4-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1301/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Department of Defense rights in a registered design under this chapter, including the right to build to such registered design, shall be determined solely by operation of subchapter I of chapter 275 of title 10 or by the instrument under which the design was developed for the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746d5ff5-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this chapter, the following terms have the following meanings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id746d5ff6-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1301/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A design is “original” if it is the result of the designer’s creative endeavor that provides a distinguishable variation over prior work pertaining to similar articles which is more than merely trivial and has not been copied from another source.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d5ff7-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1301/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A “useful article” is a vessel hull or deck, including a plug or mold, which in normal use has an intrinsic utilitarian function that is not merely to portray the appearance of the article or to convey information. An article which normally is part of a useful article shall be deemed to be a useful article.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d5ff8-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1301/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A “vessel” is a craft—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id746d5ff9-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1301/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is designed and capable of independently steering a course on or through water through its own means of propulsion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id746d5ffa-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1301/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is designed and capable of carrying and transporting one or more passengers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d5ffb-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1301/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A “hull” is the exterior frame or body of a vessel, exclusive of the deck, superstructure, masts, sails, yards, rigging, hardware, fixtures, and other attachments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d5ffc-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1301/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A “plug” means a device or model used to make a mold for the purpose of exact duplication, regardless of whether the device or model has an intrinsic utilitarian function that is not only to portray the appearance of the product or to convey information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d5ffd-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1301/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A “mold” means a matrix or form in which a substance for material is used, regardless of whether the matrix or form has an intrinsic utilitarian function that is not only to portray the appearance of the product or to convey information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d5ffe-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1301/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A “deck” is the horizontal surface of a vessel that covers the hull, including exterior cabin and cockpit surfaces, and exclusive of masts, sails, yards, rigging, hardware, fixtures, and other attachments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id746d5fff-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/304/tV/s502"},"text":"Pub. L. 105–304, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2905"},"text":"112 Stat. 2905","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tV/s5005/a/3"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title V, § 5005(a)(3)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–593; "},{"tag":"ref","attrib":{"href":"/us/pl/110/434/s1/b"},"text":"Pub. L. 110–434, § 1(b)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4972"},"text":"122 Stat. 4972","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1702"},"text":"Pub. L. 117–81, div. A, title XVII, § 1702","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2160"},"text":"135 Stat. 2160","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id746d6000-2930-11f1-b33a-a9dcf95eef0b"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id746d6001-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id746d6002-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" substituted “subchapter I of chapter 275” for “section 2320”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/434/s1/b"},"text":"Pub. L. 110–434, § 1(b)","children":[],"tail":", added par. (2) and struck out former par. (2). Prior to amendment, text read as follows: “The design of a vessel hull, including a plug or mold, is subject to protection under this chapter, notwithstanding section 1302(4).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/434/s1/c"},"text":"Pub. L. 110–434, § 1(c)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/434/s1/d/1"},"text":"Pub. L. 110–434, § 1(d)(1)","children":[],"tail":", substituted “vessel hull or deck, including a plug or mold,” for “vessel hull, including a plug or mold,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/434/s1/d/2"},"text":"Pub. L. 110–434, § 1(d)(2)","children":[],"tail":", added par. (4) and struck out former par. (4) which read as follows: “A ‘hull’ is the frame or body of a vessel, including the deck of a vessel, exclusive of masts, sails, yards, and rigging.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/434/s1/d/3"},"text":"Pub. L. 110–434, § 1(d)(3)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" amended par. (3) generally. Prior to amendment, par. (3) read as follows: “A ‘vessel’ is a craft, especially one larger than a rowboat, designed to navigate on water, but does not include any such craft that exceeds 200 feet in length.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id746d6003-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id746d6004-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/304/tV/s505"},"text":"Pub. L. 105–304, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2918"},"text":"112 Stat. 2918","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tV/s5005/a/2"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title V, § 5005(a)(2)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–593, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/113/dB/s1000/a/9/tV/s5005/a/2"},"text":"“The amendments made by sections 502 and 503 [enacting this chapter and amending sections 1338, 1400, and 1498 of Title 28, Judiciary and Judicial Procedure] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id746d6005-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Joint Study of Effect of This Chapter","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/304/tV/s504"},"text":"Pub. L. 105–304, title V, § 504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2917"},"text":"112 Stat. 2917","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/tV/s5005/a/1"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, § 4741(b)(1), title V, § 5005(a)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–586, 1501A–593, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/113/dB/s1000/a/9/tIV/tV/s5005/a/1"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2003-11-01"},"text":"November 1, 2003","children":[],"tail":", the Register of Copyrights and the Under Secretary of Commerce for Intellectual Property and Director of the United States Patent and Trademark Office shall submit to the Committees on the Judiciary of the Senate and the House of Representatives a joint report evaluating the effect of the amendments made by this title [enacting this chapter and amending sections 1338, 1400, and 1498 of Title 28, Judiciary and Judicial Procedure]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements for Consideration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Register of Copyrights and the Under Secretary of Commerce for Intellectual Property and Director of the United States Patent and Trademark Office shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the amendments made by this title has been effective in suppressing infringement of the design of vessel hulls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the registration provided for in chapter 13 of title 17, United States Code, as added by this title, has been utilized;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the creation of new designs of vessel hulls have been encouraged by the amendments made by this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect, if any, of the amendments made by this title on the price of vessels with hulls protected under such amendments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other considerations as the Register and the Under Secretary of Commerce for Intellectual Property and Director of the United States Patent and Trademark Office may deem relevant to accomplish the purposes of the evaluation conducted under subsection (a).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
