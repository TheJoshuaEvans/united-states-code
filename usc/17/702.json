{"tag":"section","attrib":{"id":"id745f0892-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s702"},"text":null,"children":[{"tag":"num","attrib":{"value":"702"},"text":"§ 702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copyright Office regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Register of Copyrights is authorized to establish regulations not inconsistent with law for the administration of the functions and duties made the responsibility of the Register under this title. All regulations established by the Register under this title are subject to the approval of the Librarian of Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id745f0893-2930-11f1-b33a-a9dcf95eef0b"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/553/tI/s101"},"text":"Pub. L. 94–553, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-19"},"text":"Oct. 19, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2591"},"text":"90 Stat. 2591","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
