{"tag":"section","attrib":{"id":"id7449844a-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s120"},"text":null,"children":[{"tag":"num","attrib":{"value":"120"},"text":"§ 120.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of exclusive rights in architectural works","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7449844b-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s120/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pictorial Representations Permitted","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The copyright in an architectural work that has been constructed does not include the right to prevent the making, distributing, or public display of pictures, paintings, photographs, or other pictorial representations of the work, if the building in which the work is embodied is located in or ordinarily visible from a public place.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7449844c-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s120/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alterations to and Destruction of Buildings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding the provisions of section 106(2), the owners of a building embodying an architectural work may, without the consent of the author or copyright owner of the architectural work, make or authorize the making of alterations to such building, and destroy or authorize the destruction of such building.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7449844d-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650/tVII/s704/a"},"text":"Pub. L. 101–650, title VII, § 704(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5133"},"text":"104 Stat. 5133","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7449844e-2930-11f1-b33a-a9dcf95eef0b"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7449844f-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id74498450-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any architectural work created on or after ","children":[{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", and any architectural work, that, on "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", is unconstructed and embodied in unpublished plans or drawings, except that protection for such architectural work under this title terminates on "},{"tag":"date","attrib":{"date":"2002-12-31"},"text":"Dec. 31, 2002","children":[],"tail":", unless the work is constructed by that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/650/s706"},"text":"section 706 of Pub. L. 101–650","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t17/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
