{"tag":"section","attrib":{"id":"id746faa80-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1324"},"text":null,"children":[{"tag":"num","attrib":{"value":"1324"},"text":"§ 1324.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Power of court over registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In any action involving the protection of a design under this chapter, the court, when appropriate, may order registration of a design under this chapter or the cancellation of such a registration. Any such order shall be certified by the court to the Administrator, who shall make an appropriate entry upon the record.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id746faa81-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/304/tV/s502"},"text":"Pub. L. 105–304, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2915"},"text":"112 Stat. 2915","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
