{"tag":"section","attrib":{"id":"id74721b58-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503"},"text":null,"children":[{"tag":"num","attrib":{"value":"1503"},"text":"§ 1503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority and duties of the Copyright Claims Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74721b59-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74721b5a-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Copyright claims officers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the provisions of this chapter and applicable regulations, the functions of the Copyright Claims Officers shall be as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74721b5b-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To render determinations on the civil copyright claims, counterclaims, and defenses that may be brought before the Officers under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74721b5c-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ensure that claims, counterclaims, and defenses are properly asserted and otherwise appropriate for resolution by the Copyright Claims Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74721b5d-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To manage the proceedings before the Officers and render rulings pertaining to the consideration of claims, counterclaims, and defenses, including with respect to scheduling, discovery, evidentiary, and other matters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74721b5e-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To request, from participants and nonparticipants in a proceeding, the production of information and documents relevant to the resolution of a claim, counterclaim, or defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74721b5f-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To conduct hearings and conferences.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74721b60-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To facilitate the settlement by the parties of claims and counterclaims.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74721b61-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id74721b62-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/a/1/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award monetary relief; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74721b63-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/a/1/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in the determinations of the Officers a requirement that certain activities under section 1504(e)(2) cease or be mitigated, if the party to undertake the applicable measure has so agreed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74721b64-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide information to the public concerning the procedures and requirements of the Copyright Claims Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74721b65-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/a/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To maintain records of the proceedings before the Officers, certify official records of such proceedings as needed, and, as provided in section 1506(t), make the records in such proceedings available to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74721b66-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/a/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To carry out such other duties as are set forth in this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74721b67-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/a/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When not engaged in performing the duties of the Officers set forth in this chapter, to perform such other duties as may be assigned by the Register of Copyrights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74721b68-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Copyright claims attorneys","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the provisions of this chapter and applicable regulations, the functions of the Copyright Claims Attorneys shall be as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74721b69-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide assistance to the Copyright Claims Officers in the administration of the duties of those Officers under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74721b6a-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide assistance to members of the public with respect to the procedures and requirements of the Copyright Claims Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74721b6b-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide information to potential claimants contemplating bringing a permissible action before the Copyright Claims Board about obtaining a subpoena under section 512(h) for the sole purpose of identifying a potential respondent in such an action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74721b6c-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When not engaged in performing the duties of the Attorneys set forth in this chapter, to perform such other duties as may be assigned by the Register of Copyrights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74721b6d-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Independence in Determinations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74721b6e-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Copyright Claims Board shall render the determinations of the Board in individual proceedings independently on the basis of the records in the proceedings before it and in accordance with the provisions of this title, judicial precedent, and applicable regulations of the Register of Copyrights.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74721b6f-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Copyright Claims Officers and Copyright Claims Attorneys—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74721b70-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may consult with the Register of Copyrights on general issues of law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74721b71-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subject to section 1506(x), may not consult with the Register of Copyrights with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id74721b72-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the facts of any particular matter pending before the Officers and the Attorneys; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74721b73-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application of law to the facts described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74721b74-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance appraisals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law or any regulation or policy of the Library of Congress or Register of Copyrights, any performance appraisal of a Copyright Claims Officer or Copyright Claims Attorney may not consider the substantive result of any individual determination reached by the Copyright Claims Board as a basis for appraisal except to the extent that the result may relate to any actual or alleged violation of an ethical standard of conduct.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74721b75-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Direction by Register","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (b), the Copyright Claims Officers and Copyright Claims Attorneys shall, in the administration of their duties, be under the general direction of the Register of Copyrights.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74721b76-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inconsistent Duties Barred","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Copyright Claims Officer or Copyright Claims Attorney may not undertake any duty that conflicts with the duties of the Officer or Attorney in connection with the Copyright Claims Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74721b77-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recusal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Copyright Claims Officer or Copyright Claims Attorney shall recuse himself or herself from participation in any proceeding with respect to which the Copyright Claims Officer or Copyright Claims Attorney, as the case may be, has reason to believe that he or she has a conflict of interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74721b78-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ex Parte Communications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as may otherwise be permitted by applicable law, any party to a proceeding before the Copyright Claims Board shall refrain from ex parte communications with the Copyright Claims Officers and the Register of Copyrights concerning the substance of any active or pending proceeding before the Copyright Claims Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74721b79-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1503/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Judicial Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Actions of the Copyright Claims Officers and Register of Copyrights under this chapter in connection with the rendering of any determination are subject to judicial review as provided under section 1508(c) and not under chapter 7 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74721b7a-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dQ/tII/s212/b"},"text":"Pub. L. 116–260, div. Q, title II, § 212(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2179"},"text":"134 Stat. 2179","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
