{"tag":"section","attrib":{"id":"id746d6051-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1312"},"text":null,"children":[{"tag":"num","attrib":{"value":"1312"},"text":"§ 1312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oaths and acknowledgments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id746d6052-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Oaths and acknowledgments required by this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id746d6053-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1312/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may be made—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id746d6054-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1312/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before any person in the United States authorized by law to administer oaths; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id746d6055-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1312/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when made in a foreign country, before any diplomatic or consular officer of the United States authorized to administer oaths, or before any official authorized to administer oaths in the foreign country concerned, whose authority shall be proved by a certificate of a diplomatic or consular officer of the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d6056-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1312/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be valid if they comply with the laws of the State or country where made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746d6057-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Written Declaration in Lieu of Oath","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id746d6058-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1312/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator may by rule prescribe that any document which is to be filed under this chapter in the Office of the Administrator and which is required by any law, rule, or other regulation to be under oath, may be subscribed to by a written declaration in such form as the Administrator may prescribe, and such declaration shall be in lieu of the oath otherwise required.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d6059-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1312/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever a written declaration under paragraph (1) is used, the document containing the declaration shall state that willful false statements are punishable by fine or imprisonment, or both, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1001"},"text":"section 1001 of title 18","children":[],"tail":", and may jeopardize the validity of the application or document or a registration resulting therefrom."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id746d605a-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/304/tV/s502"},"text":"Pub. L. 105–304, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2911"},"text":"112 Stat. 2911","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
