{"tag":"section","attrib":{"id":"id746d6012-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1304"},"text":null,"children":[{"tag":"num","attrib":{"value":"1304"},"text":"§ 1304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The protection provided for a design under this chapter shall commence upon the earlier of the date of publication of the registration under section 1313(a) or the date the design is first made public as defined by section 1310(b).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id746d6013-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/304/tV/s502"},"text":"Pub. L. 105–304, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2907"},"text":"112 Stat. 2907","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
