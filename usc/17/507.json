{"tag":"section","attrib":{"id":"id745c979f-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s507"},"text":null,"children":[{"tag":"num","attrib":{"value":"507"},"text":"§ 507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id745c97a0-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal Proceedings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as expressly provided otherwise in this title, no criminal proceeding shall be maintained under the provisions of this title unless it is commenced within 5 years after the cause of action arose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id745c97a1-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No civil action shall be maintained under the provisions of this title unless it is commenced within three years after the claim accrued.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id745c97a2-2930-11f1-b33a-a9dcf95eef0b"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/553/tI/s101"},"text":"Pub. L. 94–553, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-19"},"text":"Oct. 19, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2586"},"text":"90 Stat. 2586","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/147/s2/c"},"text":"Pub. L. 105–147, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-16"},"text":"Dec. 16, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2678"},"text":"111 Stat. 2678","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/304/tI/s102/e"},"text":"Pub. L. 105–304, title I, § 102(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2863"},"text":"112 Stat. 2863","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id745c97a3-2930-11f1-b33a-a9dcf95eef0b"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id745c97a4-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id745c97a5-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"house report no. 94–1476","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 507, which is substantially identical with section 115 of the present law [section 115 of former title 17], establishes a three-year statute of limitations for both criminal proceedings and civil actions. The language of this section, which was adopted by the act of ","children":[{"tag":"date","attrib":{"date":"1957-09-07"},"text":"September 7, 1957","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/71/633"},"text":"71 Stat. 633","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/pl/85/313/s1"},"text":"Pub. L. 85–313, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-09-07"},"text":"Sept. 7, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/633"},"text":"71 Stat. 633","children":[],"tail":"], represents a reconciliation of views, and has therefore been left unaltered."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id745c97a6-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id745c97a7-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/304"},"text":"Pub. L. 105–304","children":[],"tail":" substituted “Except as expressly provided otherwise in this title, no” for “No”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/147"},"text":"Pub. L. 105–147","children":[],"tail":" substituted “5” for “three”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
