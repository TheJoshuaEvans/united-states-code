{"tag":"section","attrib":{"id":"id746634fd-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s904"},"text":null,"children":[{"tag":"num","attrib":{"value":"904"},"text":"§ 904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id746634fe-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The protection provided for a mask work under this chapter shall commence on the date on which the mask work is registered under section 908, or the date on which the mask work is first commercially exploited anywhere in the world, whichever occurs first.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746634ff-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (c) and the provisions of this chapter, the protection provided under this chapter to a mask work shall end ten years after the date on which such protection commences under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74663500-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All terms of protection provided in this section shall run to the end of the calendar year in which they would otherwise expire.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74663501-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620/tIII/s302"},"text":"Pub. L. 98–620, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3349"},"text":"98 Stat. 3349","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
