{"tag":"section","attrib":{"id":"id746faa94-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1329"},"text":null,"children":[{"tag":"num","attrib":{"value":"1329"},"text":"§ 1329.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to design patent law","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The issuance of a design patent under title 35, United States Code, for an original design for an article of manufacture shall terminate any protection of the original design under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id746faa95-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/304/tV/s502"},"text":"Pub. L. 105–304, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2916"},"text":"112 Stat. 2916","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
