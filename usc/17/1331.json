{"tag":"section","attrib":{"id":"id746faa9a-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1331"},"text":null,"children":[{"tag":"num","attrib":{"value":"1331"},"text":"§ 1331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator; Office of the Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In this chapter, the “Administrator” is the Register of Copyrights, and the “Office of the Administrator” and the “Office” refer to the Copyright Office of the Library of Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id746faa9b-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/304/tV/s502"},"text":"Pub. L. 105–304, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2916"},"text":"112 Stat. 2916","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
