{"tag":"section","attrib":{"id":"id746d6006-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1302"},"text":null,"children":[{"tag":"num","attrib":{"value":"1302"},"text":"§ 1302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designs not subject to protection","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Protection under this chapter shall not be available for a design that is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id746d6007-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1302/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not original;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d6008-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1302/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" staple or commonplace, such as a standard geometric figure, a familiar symbol, an emblem, or a motif, or another shape, pattern, or configuration which has become standard, common, prevalent, or ordinary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d6009-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1302/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" different from a design excluded by paragraph (2) only in insignificant details or in elements which are variants commonly used in the relevant trades;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d600a-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1302/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dictated solely by a utilitarian function of the article that embodies it; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d600b-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1302/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" embodied in a useful article that was made public by the designer or owner in the United States or a foreign country more than 2 years before the date of the application for registration under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id746d600c-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/304/tV/s502"},"text":"Pub. L. 105–304, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2906"},"text":"112 Stat. 2906","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/44/s1/f/1"},"text":"Pub. L. 106–44, § 1(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-08-05"},"text":"Aug. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/222"},"text":"113 Stat. 222","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id746d600d-2930-11f1-b33a-a9dcf95eef0b"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id746d600e-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id746d600f-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/44"},"text":"Pub. L. 106–44","children":[],"tail":" substituted “2 years” for “1 year”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
