{"tag":"section","attrib":{"id":"id74427f6b-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s116"},"text":null,"children":[{"tag":"num","attrib":{"value":"116"},"text":"§ 116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiated licenses for public performances by means of coin-operated phonorecord players","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74427f6c-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Section","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section applies to any nondramatic musical work embodied in a phonorecord.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74427f6d-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Negotiated Licenses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74427f6e-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s116/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority for negotiations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any owners of copyright in works to which this section applies and any operators of coin-operated phonorecord players may negotiate and agree upon the terms and rates of royalty payments for the performance of such works and the proportionate division of fees paid among copyright owners, and may designate common agents to negotiate, agree to, pay, or receive such royalty payments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74427f6f-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s116/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chapter 8 proceeding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Parties not subject to such a negotiation may have the terms and rates and the division of fees described in paragraph (1) determined in a proceeding in accordance with the provisions of chapter 8.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74427f70-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s116/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"License Agreements Superior to Determinations by Copyright Royalty Judges","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"License agreements between one or more copyright owners and one or more operators of coin-operated phonorecord players, which are negotiated in accordance with subsection (b), shall be given effect in lieu of any otherwise applicable determination by the Copyright Royalty Judges.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74427f71-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s116/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section, the following terms mean the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74427f72-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s116/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A “coin-operated phonorecord player” is a machine or device that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74427f73-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s116/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is employed solely for the performance of nondramatic musical works by means of phonorecords upon being activated by the insertion of coins, currency, tokens, or other monetary units or their equivalent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74427f74-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s116/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located in an establishment making no direct or indirect charge for admission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74427f75-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s116/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is accompanied by a list which is comprised of the titles of all the musical works available for performance on it, and is affixed to the phonorecord player or posted in the establishment in a prominent position where it can be readily examined by the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74427f76-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s116/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affords a choice of works available for performance and permits the choice to be made by the patrons of the establishment in which it is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74427f77-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s116/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An “operator” is any person who, alone or jointly with others—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74427f78-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s116/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owns a coin-operated phonorecord player;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74427f79-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s116/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the power to make a coin-operated phonorecord player available for placement in an establishment for purposes of public performance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74427f7a-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s116/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the power to exercise primary control over the selection of the musical works made available for public performance on a coin-operated phonorecord player.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74427f7b-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/568/s4/a/4"},"text":"Pub. L. 100–568, § 4(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2855"},"text":"102 Stat. 2855","children":[],"tail":", § 116A; renumbered § 116 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/198/s3/b/1"},"text":"Pub. L. 103–198, § 3(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-17"},"text":"Dec. 17, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2309"},"text":"107 Stat. 2309","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/80/s5"},"text":"Pub. L. 105–80, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-13"},"text":"Nov. 13, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1531"},"text":"111 Stat. 1531","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/419/s5/e"},"text":"Pub. L. 108–419, § 5(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-11-30"},"text":"Nov. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2365"},"text":"118 Stat. 2365","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74427f7c-2930-11f1-b33a-a9dcf95eef0b"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id74427f7d-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id74427f7e-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 116, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/553/tI/s101"},"text":"Pub. L. 94–553, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-19"},"text":"Oct. 19, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2562"},"text":"90 Stat. 2562","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/568/s4/b/1"},"text":"Pub. L. 100–568, § 4(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2857"},"text":"102 Stat. 2857","children":[],"tail":", related to scope of exclusive rights in nondramatic musical works and compulsory licenses for public performances by means of coin-operated phonorecord players, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/198/s3/a"},"text":"Pub. L. 103–198, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-17"},"text":"Dec. 17, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2309"},"text":"107 Stat. 2309","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id74427f7f-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/419/s5/e/1"},"text":"Pub. L. 108–419, § 5(e)(1)","children":[],"tail":", amended heading and text of par. (2) generally. Prior to amendment, text read as follows: “Parties not subject to such a negotiation may determine, by arbitration in accordance with the provisions of chapter 8, the terms and rates and the division of fees described in paragraph (1).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/419/s5/e/2"},"text":"Pub. L. 108–419, § 5(e)(2)","children":[],"tail":", substituted “Determinations by Copyright Royalty Judges” for “Copyright Arbitration Royalty Panel Determinations” in heading and “the Copyright Royalty Judges” for “a copyright arbitration royalty panel” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/80/s5/1"},"text":"Pub. L. 105–80, § 5(1)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Arbitration","children":[],"tail":".—Parties to such a negotiation, within such time as may be specified by the Librarian of Congress by regulation, may determine the result of the negotiation by arbitration. Such arbitration shall be governed by the provisions of title 9, to the extent such title is not inconsistent with this section. The parties shall give notice to the Librarian of Congress of any determination reached by arbitration and any such determination shall, as between the parties to the arbitration, be dispositive of the issues to which it relates.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/80/s5/2"},"text":"Pub. L. 105–80, § 5(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/198/s3/b/1/A"},"text":"Pub. L. 103–198, § 3(b)(1)(A)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t17/s116A"},"text":"section 116A of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/198/s3/b/1/B"},"text":"Pub. L. 103–198, § 3(b)(1)(B)","children":[],"tail":", (C), redesignated subsec. (c) as (b), substituted “Librarian of Congress” for “Copyright Royalty Tribunal” in two places in par. (2), and struck out former subsec. (b) which related to limitation on exclusive right if licenses not negotiated."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/198/s3/b/1/B"},"text":"Pub. L. 103–198, § 3(b)(1)(B)","children":[],"tail":", (D), redesignated subsec. (d) as (c), in heading substituted “Arbitration Royalty Panel” for “Royalty Tribunal”, and in text substituted “subsection (b)” for “subsection (c)” and “a copyright arbitration royalty panel” for “the Copyright Royalty Tribunal”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/198/s3/b/1/B"},"text":"Pub. L. 103–198, § 3(b)(1)(B)","children":[],"tail":", (E), redesignated subsec. (d) as (c) and struck out subsecs. (e) to (g) which provided, in subsec. (e), for a schedule for negotiation of licenses, in subsec. (f), for a suspension of various ratemaking activities by the Copyright Royalty Tribunal, and in subsec. (g), for transition provisions and retention of Copyright Royalty Tribunal jurisdiction."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id74427f80-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id74427f81-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/419"},"text":"Pub. L. 108–419","children":[],"tail":" effective 6 months after "},{"tag":"date","attrib":{"date":"2004-11-30"},"text":"Nov. 30, 2004","children":[],"tail":", subject to transition provisions, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/419/s6"},"text":"section 6 of Pub. L. 108–419","children":[],"tail":", set out as an Effective Date; Transition Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t17/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id74427f82-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1989-03-01"},"text":"Mar. 1, 1989","children":[],"tail":", with any cause of action arising under this title before such date being governed by provisions as in effect when cause of action arose, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/568/s13"},"text":"section 13 of Pub. L. 100–568","children":[],"tail":", set out as an Effective Date of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t17/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
