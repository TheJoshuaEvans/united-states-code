{"tag":"section","attrib":{"id":"id745f08aa-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s706"},"text":null,"children":[{"tag":"num","attrib":{"value":"706"},"text":"§ 706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copies of Copyright Office records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id745f08ab-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Copies may be made of any public records or indexes of the Copyright Office; additional certificates of copyright registration and copies of any public records or indexes may be furnished upon request and payment of the fees specified by section 708.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id745f08ac-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Copies or reproductions of deposited articles retained under the control of the Copyright Office shall be authorized or furnished only under the conditions specified by the Copyright Office regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id745f08ad-2930-11f1-b33a-a9dcf95eef0b"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/553/tI/s101"},"text":"Pub. L. 94–553, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-19"},"text":"Oct. 19, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2592"},"text":"90 Stat. 2592","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
