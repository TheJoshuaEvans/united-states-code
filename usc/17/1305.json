{"tag":"section","attrib":{"id":"id746d6014-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1305"},"text":null,"children":[{"tag":"num","attrib":{"value":"1305"},"text":"§ 1305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id746d6015-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (b), the protection provided under this chapter for a design shall continue for a term of 10 years beginning on the date of the commencement of protection under section 1304.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746d6016-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expiration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All terms of protection provided in this section shall run to the end of the calendar year in which they would otherwise expire.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746d6017-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Rights","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon expiration or termination of protection in a particular design under this chapter, all rights under this chapter in the design shall terminate, regardless of the number of different articles in which the design may have been used during the term of its protection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id746d6018-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/304/tV/s502"},"text":"Pub. L. 105–304, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2907"},"text":"112 Stat. 2907","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
