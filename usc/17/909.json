{"tag":"section","attrib":{"id":"id7466351e-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s909"},"text":null,"children":[{"tag":"num","attrib":{"value":"909"},"text":"§ 909.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mask work notice","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7466351f-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s909/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The owner of a mask work provided protection under this chapter may affix notice to the mask work, and to masks and semiconductor chip products embodying the mask work, in such manner and location as to give reasonable notice of such protection. The Register of Copyrights shall prescribe by regulation, as examples, specific methods of affixation and positions of notice for purposes of this section, but these specifications shall not be considered exhaustive. The affixation of such notice is not a condition of protection under this chapter, but shall constitute prima facie evidence of notice of protection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74663520-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s909/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The notice referred to in subsection (a) shall consist of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74663521-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s909/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the words “mask work”, the symbol *M*, or the symbol Ⓜ (the letter M in a circle); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74663522-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s909/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the owner or owners of the mask work or an abbreviation by which the name is recognized or is generally known.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74663523-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620/tIII/s302"},"text":"Pub. L. 98–620, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3352"},"text":"98 Stat. 3352","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/80/s12/a/22"},"text":"Pub. L. 105–80, § 12(a)(22)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-13"},"text":"Nov. 13, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1535"},"text":"111 Stat. 1535","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74663524-2930-11f1-b33a-a9dcf95eef0b"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id74663525-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id74663526-2930-11f1-b33a-a9dcf95eef0b"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/80"},"text":"Pub. L. 105–80","children":[],"tail":" substituted “ ‘mask work’, the symbol” for “ ‘mask force’, the sumbol”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
