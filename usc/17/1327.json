{"tag":"section","attrib":{"id":"id746faa88-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1327"},"text":null,"children":[{"tag":"num","attrib":{"value":"1327"},"text":"§ 1327.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for false representation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever knowingly makes a false representation materially affecting the rights obtainable under this chapter for the purpose of obtaining registration of a design under this chapter shall pay a penalty of not less than $500 and not more than $1,000, and any rights or privileges that individual may have in the design under this chapter shall be forfeited.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id746faa89-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/304/tV/s502"},"text":"Pub. L. 105–304, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2915"},"text":"112 Stat. 2915","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
