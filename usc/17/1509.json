{"tag":"section","attrib":{"id":"id74748c50-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1509"},"text":null,"children":[{"tag":"num","attrib":{"value":"1509"},"text":"§ 1509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other district court actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74748c51-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1509/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Stay of District Court Proceedings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to section 1507(b), a district court of the United States shall issue a stay of proceedings or such other relief as the court determines appropriate with respect to any claim brought before the court that is already the subject of a pending or active proceeding before the Copyright Claims Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74748c52-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1509/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternative Dispute Resolution Process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A proceeding before the Copyright Claims Board under this chapter shall qualify as an alternative dispute resolution process under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s651"},"text":"section 651 of title 28","children":[],"tail":" for purposes of referral of eligible cases by district courts of the United States upon the consent of the parties."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74748c53-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dQ/tII/s212/b"},"text":"Pub. L. 116–260, div. Q, title II, § 212(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2198"},"text":"134 Stat. 2198","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
