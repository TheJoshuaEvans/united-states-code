{"tag":"section","attrib":{"id":"id746faa59-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1316"},"text":null,"children":[{"tag":"num","attrib":{"value":"1316"},"text":"§ 1316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator shall by regulation set reasonable fees for the filing of applications to register designs under this chapter and for other services relating to the administration of this chapter, taking into consideration the cost of providing these services and the benefit of a public record.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id746faa5a-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/304/tV/s502"},"text":"Pub. L. 105–304, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2912"},"text":"112 Stat. 2912","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
