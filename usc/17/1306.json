{"tag":"section","attrib":{"id":"id746d6019-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1306"},"text":null,"children":[{"tag":"num","attrib":{"value":"1306"},"text":"§ 1306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Design notice","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id746d601a-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of Design Notice","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id746d601b-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1306/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whenever any design for which protection is sought under this chapter is made public under section 1310(b), the owner of the design shall, subject to the provisions of section 1307, mark it or have it marked legibly with a design notice consisting of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id746d601c-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1306/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the words “Protected Design”, the abbreviation “Prot’d Des.”, or the letter “D” with a circle, or the symbol “*D*”;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id746d601d-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1306/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the year of the date on which protection for the design commenced; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id746d601e-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1306/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the owner, an abbreviation by which the name can be recognized, or a generally accepted alternative designation of the owner.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Any distinctive identification of the owner may be used for purposes of subparagraph (C) if it has been recorded by the Administrator before the design marked with such identification is registered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746d601f-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1306/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After registration, the registration number may be used instead of the elements specified in subparagraphs (B) and (C) of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746d6020-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Location of Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The design notice shall be so located and applied as to give reasonable notice of design protection while the useful article embodying the design is passing through its normal channels of commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746d6021-2930-11f1-b33a-a9dcf95eef0b","identifier":"/us/usc/t17/s1306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsequent Removal of Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the owner of a design has complied with the provisions of this section, protection under this chapter shall not be affected by the removal, destruction, or obliteration by others of the design notice on an article.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id746d6022-2930-11f1-b33a-a9dcf95eef0b"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/304/tV/s502"},"text":"Pub. L. 105–304, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2907"},"text":"112 Stat. 2907","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
