{"tag":"section","attrib":{"id":"idec04a015-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60123"},"text":null,"children":[{"tag":"num","attrib":{"value":"60123"},"text":"§ 60123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative authority of Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec04a016-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60123/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to carry out the responsibilities specified in this subchapter, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec04a017-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60123/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant, condition, or transfer licenses under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec04a018-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60123/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek an order of injunction or similar judicial determination from a district court of the United States with personal jurisdiction over the licensee to terminate, modify, or suspend licenses under this subchapter and to terminate licensed operations on an immediate basis, if the Secretary determines that the licensee has substantially failed to comply with any provisions of this chapter, with any terms, conditions, or restrictions of such license, or with any international obligations or national security concerns of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec04a019-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60123/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide penalties for noncompliance with the requirements of licenses or regulations issued under this subchapter, including civil penalties not to exceed $10,000 (each day of operation in violation of such licenses or regulations constituting a separate violation);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec04a01a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60123/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compromise, modify, or remit any such civil penalty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec04a01b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60123/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue subpoenas for any materials, documents, or records, or for the attendance and testimony of witnesses for the purpose of conducting a hearing under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec04a01c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60123/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seize any object, record, or report pursuant to a warrant from a magistrate based on a showing of probable cause to believe that such object, record, or report was used, is being used, or is likely to be used in violation of this chapter or the requirements of a license or regulation issued thereunder; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec04a01d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60123/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make investigations and inquiries and administer to or take from any person an oath, affirmation, or affidavit concerning any matter relating to the enforcement of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec04a01e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60123/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of Agency Action","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any applicant or licensee that makes a timely request for review of an adverse action pursuant to paragraph (1), (3), (5), or (6) of subsection (a) shall be entitled to adjudication by the Secretary on the record after an opportunity for any agency hearing with respect to such adverse action. Any final action by the Secretary under this subsection shall be subject to judicial review under chapter 7 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec04a01f-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3415"},"text":"124 Stat. 3415","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec04a020-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idec04a021-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idec04a022-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60123","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t15/s5623"},"text":"15 U.S.C. 5623","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/102/555/tII/s203"},"text":"Pub. L. 102–555, title II, § 203","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/4172"},"text":"106 Stat. 4172","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), at the end of paragraph (2), a semicolon is substituted for the period to correct an error in the law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
