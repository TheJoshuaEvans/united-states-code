{"tag":"section","attrib":{"id":"idec06e965-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60141"},"text":null,"children":[{"tag":"num","attrib":{"value":"60141"},"text":"§ 60141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondiscriminatory data availability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec06e966-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60141/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), any unenhanced data generated by the Landsat system or any other land remote sensing system funded and owned by the United States Government shall be made available to all users without preference, bias, or any other special arrangement (except on the basis of national security concerns pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s60146"},"text":"section 60146 of this title","children":[],"tail":") regarding delivery, format, pricing, or technical considerations which would favor one customer or class of customers over another."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec06e967-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60141/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unenhanced data generated by the Landsat system or any other land remote sensing system funded and owned by the United States Government may be made available to the United States Government and its affiliated users at reduced prices, in accordance with this chapter, on the condition that such unenhanced data are used solely for noncommercial purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec06e968-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3419"},"text":"124 Stat. 3419","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec06e969-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idec06e96a-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idec06e96b-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"ta