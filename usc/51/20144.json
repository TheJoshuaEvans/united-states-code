{"tag":"section","attrib":{"id":"idebd74da2-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144"},"text":null,"children":[{"tag":"num","attrib":{"value":"20144"},"text":"§ 20144.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prize authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebd74da3-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administration may carry out a program to competitively award cash prizes to stimulate innovation in basic and applied research, technology development, and prototype demonstration that have the potential for application to the performance of the space and aeronautical activities of the Administration. The Administration may carry out a program to award prizes only in conformity with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd74da4-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Topics","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In selecting topics for prize competitions, the Administrator shall consult widely both within and outside the Federal Government, and may empanel advisory committees. The Administrator shall give consideration to prize goals such as the demonstration of the ability to provide energy to the lunar surface from space-based solar power systems, demonstration of innovative near-Earth object survey and deflection strategies, and innovative approaches to improving the safety and efficiency of aviation systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd74da5-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advertising","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall widely advertise prize competitions to encourage participation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd74da6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements and Registration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For each prize competition, the Administrator shall publish a notice in the Federal Register announcing the subject of the competition, the rules for being eligible to participate in the competition, the amount of the prize, and the basis on which a winner will be selected.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd74da7-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to win a prize under this section, an individual or entity—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd74da8-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have registered to participate in the competition pursuant to any rules promulgated by the Administrator under subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd74da9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have complied with all the requirements under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd74daa-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a private entity, shall be incorporated in and maintain a primary place of business in the United States, and in the case of an individual, whether participating singly or in a group, shall be a citizen or permanent resident of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd74dab-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be a Federal entity or Federal employee acting within the scope of their employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd74dac-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd74dad-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assumption of risk","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Registered participants must agree to assume any and all risks and waive claims against the Federal Government and its related entities, except in the case of willful misconduct, for any injury, death, damage, or loss of property, revenue, or profits, whether direct, indirect, or consequential, arising from their participation in a competition, whether such injury, death, damage, or loss arises through negligence or otherwise. For the purposes of this paragraph, the term “related entity” means a contractor or subcontractor at any tier, and a supplier, user, customer, cooperating party, grantee, investigator, or detailee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd74dae-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability insurance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Participants must obtain liability insurance or demonstrate financial responsibility, in amounts determined by the Administrator, for claims by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebd74daf-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a third party for death, bodily injury, or property damage, or loss resulting from an activity carried out in connection with participation in a competition, with the Federal Government named as an additional insured under the registered participant’s insurance policy and registered participants agreeing to indemnify the Federal Government against third party claims for damages arising from or related to competition activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebd74db0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Government for damage or loss to Government property resulting from such an activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd74db1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Judges","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each competition, the Administration, either directly or through an agreement under subsection (h), shall assemble a panel of qualified judges to select the winner or winners of the prize competition on the basis described pursuant to subsection (d). Judges for each competition shall include individuals from outside the Administration, including from the private sector. A judge may not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd74db2-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have personal or financial interests in, or be an employee, officer, director, or agent of any entity that is a registered participant in a competition; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd74db3-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a familial or financial relationship with an individual who is a registered participant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd74db4-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administering the Competition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may enter into an agreement with a private, nonprofit entity to administer the prize competition, subject to the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd74db5-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd74db6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sources","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Prizes under this section may consist of Federal appropriated funds and funds provided by the private sector for such cash prizes. The Administrator may accept funds from other Federal agencies for such cash prizes. The Administrator may not give any special consideration to any private sector entity in return for a donation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd74db7-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebd74db8-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of provisions known as the anti-deficiency act","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this paragraph, the term “provisions known as the Anti-Deficiency Act” means sections 1341, 1342, 1349(a), 1350, 1351, 1511, 1512, 1513, 1514, 1515, 1516, 1517, 1518, and 1519 of title 31.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebd74db9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, funds appropriated for prize awards under this section shall remain available until expended, and may be transferred, reprogrammed, or expended for other purposes only after the expiration of 10 fiscal years after the fiscal year for which the funds were originally appropriated. No provision in this section permits obligation or payment of funds in violation of the provisions known as the Anti-Deficiency Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd74dba-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriation or commitment of funds required before announcement of prize or increase.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebd74dbb-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No prize may be announced under subsection (d) until all the funds needed to pay out the announced amount of the prize have been appropriated or committed in writing by a private source.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebd74dbc-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Increase","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may increase the amount of a prize after an initial announcement is made under subsection (d) if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idebd74dbd-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/i/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice of the increase is provided in the same manner as the initial notice of the prize; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idebd74dbe-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/i/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funds needed to pay out the announced amount of the increase have been appropriated or committed in writing by a private source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd74dbf-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to committees for prize greater than $50,000,000","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No prize competition under this section may offer a prize in an amount greater than $50,000,000 unless 30 days have elapsed after written notice has been transmitted to the Committee on Science and Technology of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd74dc0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/i/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval of administrator for prize greater than $1,000,000","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No prize competition under this section may result in the award of more than $1,000,000 in cash prizes without the approval of the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd74dc1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Administration Name or Insignia","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A registered participant in a competition under this section may use the Administration’s name, initials, or insignia only after prior review and written approval by the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd74dc2-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20144/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance With Existing Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Government shall not, by virtue of offering or providing a prize under this section, be responsible for compliance by registered participants in a prize competition with Federal law, including licensing, export control, and non-proliferation laws, and related regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebd74dc3-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3350"},"text":"124 Stat. 3350","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/tI/s105/b"},"text":"Pub. L. 111–358, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3993"},"text":"124 Stat. 3993","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebd74dc4-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idebd74dc5-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment Not Shown in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section was derived from ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2459f–1"},"text":"section 2459f–1 of Title 42","children":[],"tail":", The Public Health and Welfare, which was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/tI/s105/b"},"text":"Pub. L. 111–358, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3993"},"text":"124 Stat. 3993","children":[],"tail":". For applicability of this amendment to this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/314/s5/b"},"text":"section 5(b) of Pub. L. 111–314","children":[],"tail":", set out as a Transitional and Savings Provisions note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s10101"},"text":"section 10101 of this title","children":[],"tail":". Former "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2459f–1"},"text":"section 2459f–1 of Title 42","children":[],"tail":" was amended by striking out “The Administration may carry out a program to award prizes only in conformity with this section.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebd74dc6-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebd74dc7-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20144","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s2459f–1"},"text":"42 U.S.C. 2459f–1","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{