{"tag":"section","attrib":{"id":"idec049fdf-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60113"},"text":null,"children":[{"tag":"num","attrib":{"value":"60113"},"text":"§ 60113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data policy for Landsat 7","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec049fe0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Landsat","children":[],"tail":" 7 "},{"tag":"inline","attrib":{},"text":"Data Policy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Landsat Program Management, in consultation with other appropriate United States Government agencies, shall develop a data policy for Landsat 7 which should—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec049fe1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60113/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that unenhanced data are available to all users at the cost of fulfilling user requests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec049fe2-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60113/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure timely and dependable delivery of unenhanced data to the full spectrum of civilian, national security, commercial, and foreign users and the National Satellite Land Remote Sensing Data Archive;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec049fe3-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60113/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the United States retains ownership of all unenhanced data generated by Landsat 7;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec049fe4-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60113/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the development of the commercial market for remote sensing data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec049fe5-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60113/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the provision of commercial value-added services based on remote sensing data remains exclusively the function of the private sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec049fe6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60113/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent possible, ensure that the data distribution system for Landsat 7 is compatible with the Earth Observing System Data and Information System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec049fe7-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Data Policy Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition, the data policy for Landsat 7 may provide for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec049fe8-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60113/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States private sector entities to operate ground receiving stations in the United States for Landsat 7 data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec049fe9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60113/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other means for direct access by private sector entities to unenhanced data from Landsat 7; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec049fea-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60113/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Government to charge a per image fee, license fee, or other such fee to entities operating ground receiving stations or distributing Landsat 7 data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec049feb-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3413"},"text":"124 Stat. 3413","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec049fec-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idec049fed-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","i