"tag":"html:a","attrib":{"href":"/us/usc/t15/s5615/a"},"text":"15 U.S.C. 5615(a)","children":[],"tail":", (b)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/102/555/tI/s105/a"},"text":"Pub. L. 102–555, title I, § 105(a)","children":[],"tail":", (b), "},{"tag":"html:span","attrib":{},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/4170"},"text":"106 Stat. 4170","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
