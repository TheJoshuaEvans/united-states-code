{"tag":"section","attrib":{"id":"idebef1c2a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40301"},"text":null,"children":[{"tag":"num","attrib":{"value":"40301"},"text":"§ 40301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebef1c2b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the understanding, assessment, development, and utilization of space resources by promoting a strong educational base, responsive research and training activities, and broad and prompt dissemination of knowledge and techniques;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1c2c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize the abilities and talents of the universities of the Nation to support and contribute to the exploration and development of the resources and opportunities afforded by the space environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1c2d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" encourage and support, within the university community of the Nation, the existence of interdisciplinary and multidisciplinary programs of space research that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebef1c2e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40301/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in integrated activities of training, research, and public service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebef1c2f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40301/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have cooperative programs with industry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebef1c30-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40301/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are coordinated with the overall program of the Administration;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1c31-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40301/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage and support the existence of consortia, made up of university and industry members, in order to advance the exploration and development of space resources in cases in which national objectives can be better fulfilled through such consortia than through the programs of single universities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1c32-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40301/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage and support Federal funding for graduate fellowships in fields related to space; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1c33-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40301/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support activities in colleges and universities generally for the purpose of creating and operating a network of institutional programs that will enhance achievements resulting from efforts under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebef1c34-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3382"},"text":"124 Stat. 3382","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebef1c35-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebef1c36-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebef1c37-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40301","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s2486a"},"text":"42 U.S.C. 2486a","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/100/147/tII/s203"},"text":"Pub. L. 100–147, title II, § 203","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/101/869"},"text":"101 Stat. 869","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (3), the word “that” is substituted for “, to” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (4), the words “in order to” are substituted for “to”, and the words “through such consortia” are added, for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idebef1c38-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idebef1c39-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Statement of Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/147/tII/s202"},"text":"Pub. L. 100–147, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-10-30"},"text":"Oct. 30, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/869"},"text":"101 Stat. 869","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/147/tII/s202"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vitality of the Nation and the quality of life of the citizens of the Nation depend increasingly on the understanding, assessment, development, and utilization of space resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and development of space science, space technology, and space commercialization will contribute to the quality of life, national security, and the enhancement of commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the understanding and development of the space frontiers require a broad commitment and an intense involvement on the part of the Federal Government in partnership with State and local governments, private industry, universities, organizations, and individuals concerned with the exploration and utilization of space;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Aeronautics and Space Administration, through the national space grant college and fellowship program, offers the most suitable means for such commitment and involvement through the promotion of activities that will result in greater understanding, assessment, development, and utilization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal support of the establishment, development, and operation of programs and projects by space grant colleges, space grant regional consortia, institutions of higher education, institutes, laboratories, and other appropriate public and private entities is the most cost-effective way to promote such activities.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of terms used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/147/s202"},"text":"section 202 of Pub. L. 100–147","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/147/s204"},"text":"section 204 of Pub. L. 100–147","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"1987-10-30"},"text":"Oct. 30, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/870"},"text":"101 Stat. 870","children":[],"tail":", which was classified to former "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2486b"},"text":"section 2486b of Title 42","children":[],"tail":", The Public Health and Welfare, and was repealed and reenacted as "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s40302"},"text":"section 40302 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/111/314"},"text":"Pub. L. 111–314","children":[],"tail":", §§ 3, 6, "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3328"},"text":"124 Stat. 3328","children":[],"tail":", 3444.]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
