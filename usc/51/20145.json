":"20145","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s2459j"},"text":"42 U.S.C. 2459j","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/85/568/tIII/s315"},"text":"Pub. L. 85–568, title III, § 315","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/108/7/dK/tIV/s418"},"text":"Pub. L. 108–7, div. K, title IV, § 418","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/117/525"},"text":"117 Stat. 525","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/110/161/dB/tV/s533/a"},"text":"Pub. L. 110–161, div. B, title V, § 533(a)","children":[],"tail":"–(e), "},{"tag":"html:span","attrib":{},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/121/1931"},"text":"121 Stat. 1931","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/110/422/tXI/s1117/c"},"text":"Pub. L. 110–422, title XI, § 1117(c)","children":[],"tail":", (d), "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 2008","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/122/4814"},"text":"122 Stat. 4814","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f)(2), the word “Administration’s” is substituted for “Agency’s” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (g), the words “10 years after ","children":[{"tag":"date","attrib":{"date":"2007-12-26"},"text":"December 26, 2007","children":[],"tail":"” are substituted for “on the date that is ten years after the date of the enactment of the Commerce, Justice, Science, and Related Agencies Appropriations Act of 2008” for consistency and to reflect the date of enactment of the Commerce, Justice, Science, and Related Agencies Appropriations Act, 2008 ("},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dB"},"text":"Public Law 110–161, div. B","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1884"},"text":"121 Stat. 1884","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idebd74deb-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idebd74dec-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the National Aeronautics and Space Administration Authorization Act of 2022, referred to in subsec. (g), is the date of enactment of title VII of div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idebd74ded-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (f)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10862/b"},"text":"Pub. L. 117–167, § 10862(b)","children":[],"tail":", added pars. (3) to (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10862/c/2"},"text":"Pub. L. 117–167, § 10862(c)(2)","children":[],"tail":", added subsec. (g). Former subsec. (g) redesignated (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10862/a"},"text":"Pub. L. 117–167, § 10862(a)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2032-12-31"},"text":"December 31, 2032","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2022-12-31"},"text":"December 31, 2022","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2022-12-31"},"text":"December 31, 2022","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2021-12-31"},"text":"December 31, 2021","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10862/c/1"},"text":"Pub. L. 117–167, § 10862(c)(1)","children":[],"tail":", redesignated subsec. (g) as (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2021-12-31"},"text":"December 31, 2021","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2019-12-31"},"text":"December 31, 2019","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/403"},"text":"Pub. L. 115–403","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2019-12-31"},"text":"December 31, 2019","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/10"},"text":"Pub. L. 115–10","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"” for “10 years after "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"December 26, 2007","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/55"},"text":"Pub. L. 112–55","children":[],"tail":" designated existing provisions as subpar. (A) and added subpar. (B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idebd9beee-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idebd9beef-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dHH/tII/s202"},"text":"Pub. L. 117–103, div. HH, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1113"},"text":"136 Stat. 1113","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/103/dHH/tII/s202"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds the following:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" NASA uses enhanced-use leasing to enter into agreements with private sector entities, State and local governments, academic institutions, and other Federal agencies for lease of non-excess, underutilized NASA properties and facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" NASA uses enhanced-use leasing authority to support responsible management of its real property, including to improve the use of underutilized property for activities that are compatible with NASA’s mission and to reduce facility operating and maintenance costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In fiscal year 2019, under its enhanced-use lease authority, NASA leased 65 real properties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In fiscal year 2019, NASA’s use of enhanced-use leasing resulted in the collection of $10,843,025.77 in net revenue.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In fiscal year 2019, NASA used a portion of its enhanced-use leasing revenues for repairs of facility control systems such as lighting and heating, ventilation, and air conditioning.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" NASA’s use of enhanced-use leasing authority can contribute to reducing the rate of increase of the Agency’s overall deferred maintenance cost.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idebd9bef0-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deposit of Proceeds","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/6/dB/tIII"},"text":"Pub. L. 113–6, div. B, title III","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-26"},"text":"Mar. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/263"},"text":"127 Stat. 263","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/6/dB/tIII"},"text":"“That hereafter, notwithstanding section 315 of the National Aeronautics and Space Act of 1958 (see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s20145"},"text":"51 U.S.C. 20145","children":[],"tail":"), all proceeds from leases entered into under that section shall be deposited into this account [funds appropriated under the headings ‘"},{"tag":"inline","attrib":{},"text":"National Aeronautics and Space Administration","children":[],"tail":"’ and ‘"},{"tag":"inline","attrib":{},"text":"construction and environmental compliance and restoration","children":[],"tail":"’ of title III of div. B of "},{"tag":"ref","attrib":{"href":"/us/pl/113/6"},"text":"Pub. L. 113–6","children":[],"tail":"]: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That such proceeds shall be available for a period of 5 years to the extent and in amounts as provided in annual appropriations Acts”."}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/74/dA/tIII"},"text":"Pub. L. 119–74, div. A, title III","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-01-23"},"