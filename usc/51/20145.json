{"tag":"section","attrib":{"id":"idebd74dcc-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145"},"text":null,"children":[{"tag":"num","attrib":{"value":"20145"},"text":"§ 20145.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease of non-excess property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebd74dcd-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may enter into a lease under this section with any person or entity (including another department or agency of the Federal Government or an entity of a State or local government) with regard to any non-excess real property and related personal property under the jurisdiction of the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd74dce-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cash Consideration.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd74dcf-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fair market value","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebd74dd0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person or entity entering into a lease under this section shall provide cash consideration for the lease at fair market value as determined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebd74dd1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subparagraph (A), the Administrator may accept in-kind consideration for leases entered into for the purpose of developing renewable energy production facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd74dd2-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Utilization.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebd74dd3-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may utilize amounts of cash consideration received under this subsection for a lease entered into under this section to cover the full costs to the Administration in connection with the lease. These funds shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebd74dd4-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Capital revitalization and improvements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of any amounts of cash consideration received under this subsection that are not utilized in accordance with subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idebd74dd5-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 35 percent shall be deposited in a capital asset account to be established by the Administrator, shall be available for maintenance, capital revitalization, and improvements of the real property assets and related personal property under the jurisdiction of the Administrator, and shall remain available until expended; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idebd74dd6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the remaining 65 percent shall be available to the respective center or facility of the Administration engaged in the lease of nonexcess real property, and shall remain available until expended for maintenance, capital revitalization, and improvements of the real property assets and related personal property at the respective center or facility subject to the concurrence of the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebd74dd7-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No utilization for daily operating costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts utilized under subparagraph (B) may not be utilized for daily operating costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd74dd8-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Terms and Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may require such terms and conditions in connection with a lease under this section as the Administrator considers appropriate to protect the interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd74dd9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Lease Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority under this section to lease property of the Administration is in addition to any other authority to lease property of the Administration under law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd74dda-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lease Restrictions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd74ddb-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No lease back or other contract","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administration is not authorized to lease back property under this section during the term of the out-lease or enter into other contracts with the lessee respecting the property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd74ddc-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification that out-lease will not have negative impact on mission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administration is not authorized to enter into an out-lease under this section unless the Administrator certifies that the out-lease will not have a negative impact on the mission of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd74ddd-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall submit an annual report by January 31st of each year. The report shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd74dde-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Value of arrangements and expenditures of revenues","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Information that identifies and quantifies the value of the arrangements and expenditures of revenues received under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd74ddf-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability and use of funds for operating plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The availability and use of funds received under this section for the Administration’s operating plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd74de0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual and cumulative number of leases","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The annual and cumulative number of leases entered into under this section, by National Aeronautics and Space Administration center and facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd74de1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Estimated cost savings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For each active lease agreement under this section, the estimated cost savings to the Administration resulting from reduced maintenance, operating, and associated costs in the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd74de2-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other quantifiable benefits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Other quantifiable benefits, including additional cost savings not included under paragraph (4), to the Administration resulting from the use of leases under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd74de3-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report on Enhanced-use Leasing Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 270 days after the date of the enactment of the National Aeronautics and Space Administration Authorization Act of 2022, the Administrator shall prepare and submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Science, Space, and Technology of the House of Representatives a report on existing requirements for applicants seeking a lease under this section, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd74de4-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any requirement related to the involvement of foreign entities, foreign entity ownership, and foreign entity investment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd74de5-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the discretion of the Administrator, any other requirement related to the protection and security of Administration missions and facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd74de6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20145/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority to enter into leases under this section shall expire ","children":[{"tag":"date","attrib":{"date":"2032-12-31"},"text":"December 31, 2032","children":[],"tail":". The expiration under this subsection of authority to enter into leases under this section shall not affect the validity or term of leases or the Administration’s retention of proceeds from leases entered into under this section before the expiration of the authority."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebd74de7-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3352"},"text":"124 Stat. 3352","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/55/dB/tIII"},"text":"Pub. L. 112–55, div. B, title III","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-11-18"},"text":"Nov. 18, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/626"},"text":"125 Stat. 626","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/10/tVIII/s832"},"text":"Pub. L. 115–10, title VIII, § 832","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-03-21"},"text":"Mar. 21, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/67"},"text":"131 Stat. 67","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/403/s2"},"text":"Pub. L. 115–403, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5348"},"text":"132 Stat. 5348","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dI/tVI/s602"},"text":"Pub. L. 116–94, div. I, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3028"},"text":"133 Stat. 3028","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dHH/tII/s203"},"text":"Pub. L. 117–103, div. HH, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1113"},"text":"136 Stat. 1113","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVII/s10862"},"text":"Pub. L. 117–167, div. B, title VII, § 10862","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1756"},"text":"136 Stat. 1756","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebd74de8-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"