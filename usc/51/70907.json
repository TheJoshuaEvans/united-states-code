{"tag":"section","attrib":{"id":"idec1086ee-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70907"},"text":null,"children":[{"tag":"num","attrib":{"value":"70907"},"text":"§ 70907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintaining use through at least 2030","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec1086ef-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70907/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall take all necessary steps to ensure that the International Space Station remains a viable and productive facility capable of potential United States utilization through at least ","children":[{"tag":"date","attrib":{"date":"2030-09-30"},"text":"September 30, 2030","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec1086f0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70907/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"NASA Actions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In furtherance of the policy under subsection (a), the Administrator shall ensure, to the extent practicable, that the International Space Station, as a designated national laboratory—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec1086f1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70907/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remains viable as an element of overall exploration and partnership strategies and approaches;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec1086f2-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70907/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is considered for use by all NASA mission directorates, as appropriate, for technically appropriate scientific data gathering or technology risk reduction demonstrations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec1086f3-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70907/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remains an effective, functional vehicle providing research and test bed capabilities for the United States through at least ","children":[{"tag":"date","attrib":{"date":"2030-09-30"},"text":"September 30, 2030","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec1086f4-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3438"},"text":"124 Stat. 3438","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/90/tI/s114/b/4"},"text":"Pub. L. 114–90, title I, § 114(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/716"},"text":"129 Stat. 716","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVII/s10815/d/1"},"text":"Pub. L. 117–167, div. B, title VII, § 10815(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022",