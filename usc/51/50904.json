{"tag":"section","attrib":{"id":"idebfb0244-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50904"},"text":null,"children":[{"tag":"num","attrib":{"value":"50904"},"text":"§ 50904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on launches, operations, and reentries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebfb0245-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A license issued or transferred under this chapter, or a permit, is required for the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebfb0246-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50904/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a person to launch a launch vehicle or to operate a launch site or reentry site, or to reenter a reentry vehicle, in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebfb0247-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50904/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a citizen of the United States (as defined in section 50902(1)(A) or (B) of this title) to launch a launch vehicle or to operate a launch site or reentry site, or to reenter a reentry vehicle, outside the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebfb0248-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50904/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a citizen of the United States (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s50902/1/C"},"text":"section 50902(1)(C) of this title","children":[],"tail":") to launch a launch vehicle or to operate a launch site or reentry site, or to reenter a reentry vehicle, outside the United States and outside the territory of a foreign country unless there is an agreement between the United States Government and the government of the foreign country providing that the government of the foreign country has jurisdiction over the launch or operation or reentry."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebfb0249-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50904/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a citizen of the United States (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s50902/1/C"},"text":"section 50902(1)(C) of this title","children":[],"tail":") to launch a launch vehicle or to operate a launch site or reentry site, or to reenter a reentry vehicle, in the territory of a foreign country if there is an agreement between the United States Government and the government of the foreign country providing that the United States Government has jurisdiction over the launch or operation or reentry."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Notwithstanding this subsection, a permit shall not authorize a person to operate a launch site or reentry site.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebfb024a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance With Payload Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The holder of a license or permit under this chapter may launch or reenter a payload only if the payload complies with all requirements of the laws of the United States related to launching or reentering a payload.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebfb024b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preventing Launches and Reentries","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall establish whether all required licenses, authorizations, and permits required for a payload have been obtained. If no license, authorization, or permit is required, the Secretary may prevent the launch or reentry if the Secretary decides the launch or reentry would jeopardize the public health and safety, safety of property, or national security or foreign policy interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebfb024c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50904/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Single License or Permit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall ensure that only 1 license or permit is required from the Department of Transportation to conduct activities involving crew, government astronauts, or space flight participants, including launch and reentry, for which a license or permit is required under this chapter. The Secretary shall ensure that all Department of Transportation regulations relevant to the licensed or permitted activity are satisfied.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebfb024d-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1332"},"text":"108 Stat. 1332","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s70104"},"text":"§ 70104 of title 49","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/303/tI/s102/a/5"},"text":"Pub. L. 105–303, title I, § 102(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2847"},"text":"112 Stat. 2847","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/492/s2/c/3"},"text":"Pub. L. 108–492, § 2(c)(3)","children":[],"tail":"–(5), "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3976"},"text":"118 Stat. 3976","children":[],"tail":"; renumbered § 70104 then "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s50904"},"text":"§ 50904 of title 51","children":[],"tail":" and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/314/s4/d/2"},"text":"Pub. L. 111–314, § 4(d)(2)","children":[],"tail":", (3)(D), (5)(C)–(E), "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3440"},"text":"124 Stat. 3440","children":[],"tail":", 3441; "},{"tag":"ref","attrib":{"href":"/us/pl/114/90/tI/s112/k"},"text":"Pub. L. 114–90, title I, § 112(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/713"},"text":"129 Stat. 713","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebfb024e-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebfb024f-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebfb0250-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70104(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2605(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/575/s6/a"},"text":"Pub. L. 98–575, § 6(a)","children":[],"tail":", (b), "},{"tag":"html:a","attrib":{"href":"/us/stat/98/3057"},"text":"98 Stat. 3057","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70104(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2605(b)(1) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70104(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2605(b)(1) (last sentence), (2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2)–(4), the cross-reference is to section 70102(1) of the revised title (restating 49 App.:2603(12)) rather than to section 70102(11) (restating 49 App.:2603(11)) to correct a mistake. Section 3(2) of the Commercial Space Launch Act Amendments of 1988 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/657"},"text":"Public Law 100–657","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3900"},"text":"102 Stat. 3900","children":[],"tail":") redesignated 49 App.:2603(11) as 49 App.:2603(12) but did not amend the cross-reference in 49 App.:2605(a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3) and (4), the words “the government of” are added for consistency in the revised title and with other titles of the United States Code. The words “in force” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), the words “at any place which is both” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(4), the text of 49 App.:2605(a)(3)(B)(i) is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “by Federal law”, “which is to be launched”, “by any Federal law”, “take such action under this chapter as the Secretary deems necessary to”, and “of a payload by a holder of a launch license under this chapter” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idebfb0251-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idebfb0252-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/90"},"text":"Pub. L. 114–90","children":[],"tail":" substituted “activities involving crew, government astronauts, or space flight participants” for “activities involving crew or space flight participants”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s4/d/2"},"text":"Pub. L. 111–314, § 4(d)(2)","children":[],"tail":", (3)(D), successively renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s70104"},"text":"section 70104 of title 49","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s70104"},"text":"section 70104 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s4/d/5/C"},"text":"Pub. L. 111–314, § 4(d)(5)(C)","children":[],"tail":", substituted “section 50902(1)(A) or (B)” for “section 70102(1)(A) or (B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s4/d/5/D"},"text":"Pub. L. 111–314, § 4(d)(5)(D)","children":[],"tail":", substituted “section 50902(1)(C)” for “section 70102(1)(C)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s4/d/5/E"},"text":"Pub. L. 111–314, § 4(d)(5)(E)","children":[],"tail":", substituted “section 50902(1)(C)” for “section 70102(1)(C)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/492/s2/c/3"},"text":"Pub. L. 108–492, § 2(c)(3)","children":[],"tail":", substituted “Requirement” for “License Requirement” in heading and “A license issued or transferred under this chapter, or a permit,” for “A license issued or transferred under this chapter” in introductory provisions and inserted concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/492/s2/c/4"},"text":"Pub. L. 108–492, § 2(c)(4)","children":[],"tail":", inserted “or permit” after “holder of a license”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/492/s2/c/5"},"text":"Pub. L. 108–492, § 2(c)(5)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/303/s102/a/5/A"},"text":"Pub. L. 105–303, § 102(a)(5)(A)","children":[],"tail":", substituted “Restrictions on launches, operations, and reentries” for “Restrictions on launches and operations” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/303/s102/a/5/B"},"text":"Pub. L. 105–303, § 102(a)(5)(B)","children":[],"tail":", inserted “or reentry site, or to reenter a reentry vehicle,” after “operate a launch site”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/303/s102/a/5/B"},"text":"Pub. L. 105–303, § 102(a)(5)(B)","children":[],"tail":", (C), inserted “or reentry site, or to reenter a reentry vehicle,” after “operate a launch site” and “or reentry” after “launch or operation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/303/s102/a/5/D"},"text":"Pub. L. 105–303, § 102(a)(5)(D)","children":[],"tail":", struck out “launch” before “license” and inserted “or reenter” after “may launch” and “or reentering” after “related to launching”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/303/s102/a/5/E"},"text":"Pub. L. 105–303, § 102(a)(5)(E)","children":[],"tail":", substituted “Preventing Launches and Reentries” for “Preventing Launches” in heading and inserted “or reentry” after “prevent the launch” and after “decides the launch” in second sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
