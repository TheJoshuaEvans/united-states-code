{"tag":"section","attrib":{"id":"idebef1cee-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40701"},"text":null,"children":[{"tag":"num","attrib":{"value":"40701"},"text":"§ 40701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development initiative","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Administrator may establish an initiative with the objective of developing, and demonstrating in a relevant environment, technologies to enable the following commercial aircraft performance characteristics:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebef1cef-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40701/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Noise levels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Noise levels on takeoff and on airport approach and landing that do not exceed ambient noise levels in the absence of flight operations in the vicinity of airports from which such commercial aircraft would normally operate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1cf0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40701/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Energy consumption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Twenty-five percent reduction in the energy required for medium- to long-range flights, compared to aircraft in commercial service as of ","children":[{"tag":"date","attrib":{"date":"2005-12-30"},"text":"December 30, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1cf1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40701/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Emissions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nitrogen oxides on take-off and landing that are significantly reduced, without adversely affecting hydrocarbons and smoke, relative to aircraft in commercial service as of ","children":[{"tag":"date","attrib":{"date":"2005-12-30"},"text":"December 30, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebef1cf2-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3390"},"text":"124 Stat. 3390","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebef1cf3-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebef1cf4-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebef1cf5-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"ta