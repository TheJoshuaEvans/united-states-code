"42 U.S.C. 17752","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/110/422/tVI/s602"},"text":"Pub. L. 110–422, title VI, § 602","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 2008","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/122/4795"},"text":"122 Stat. 4795","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the date “","children":[{"tag":"date","attrib":{"date":"2008-10-15"},"text":"October 15, 2008","children":[],"tail":"” is substituted for “the date of enactment of this Act” to reflect the date of enactment of the National Aeronautics and Space Administration Authorization Act of 2008 ("},{"tag":"ref","attrib":{"href":"/us/pl/110/422"},"text":"Public Law 110–422","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4779"},"text":"122 Stat. 4779","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idec1086ec-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idec1086ed-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5” for “the Federal Advisory Committee Act”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
