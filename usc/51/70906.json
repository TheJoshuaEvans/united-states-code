{"tag":"section","attrib":{"id":"idec1086df-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70906"},"text":null,"children":[{"tag":"num","attrib":{"value":"70906"},"text":"§ 70906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International Space Station National Laboratory Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec1086e0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2008-10-15"},"text":"October 15, 2008","children":[],"tail":", the Administrator shall establish under chapter 10 of title 5 a committee to be known as the “International Space Station National Laboratory Advisory Committee” (hereafter in this section referred to as the “Committee”)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec1086e1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idec1086e2-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70906/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall be composed of individuals representing organizations that have formal agreements with the Administration to utilize the United States portion of the International Space Station, including allocations within partner elements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec1086e3-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70906/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chair","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall appoint a chair from among the members of the Committee, who shall serve for a 2-year term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec1086e4-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70906/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties of the Committee.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idec1086e5-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70906/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall monitor, assess, and make recommendations regarding effective utilization of the International Space Station as a national laboratory and platform for research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec1086e6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70906/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall submit to the Administrator, on an annual basis or more frequently as considered necessary by a majority of the members of the Committee, a report containing the assessments and recommendations required by paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec1086e7-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70906/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall exist for the life of the International Space Station.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec1086e8-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3438"},"text":"124 Stat. 3438","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/327"},"text":"Pub. L. 117–286, § 4(a)(327)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4342"},"text":"136 Stat. 4342","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec1086e9-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idec1086ea-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idec1086eb-3a70-11f1-9081-fe88c1712d53"},"text":"\n","chi