{"tag":"section","attrib":{"id":"idebef1cd6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40502"},"text":null,"children":[{"tag":"num","attrib":{"value":"40502"},"text":"§ 40502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biomedical research grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebef1cd7-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator and the Director of the National Institutes of Health shall establish a joint program of biomedical research grants in areas described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s40501/a"},"text":"section 40501(a) of this title","children":[],"tail":", where such research requires access to a microgravity environment. Such program shall be consistent with actions taken by the joint working group under "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s40501"},"text":"section 40501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebef1cd8-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Research Opportunity Announcements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The grants program established under subsection (a) shall annually issue joint research opportunity announcements under the sponsorship of the National Institutes of Health and the Administration. Responses to the announcements shall be evaluated by a peer review committee whose members shall be selected by the Director of the National Institutes of Health and the Administrator, and shall include individuals not employed by the Administration or the National Institutes of Health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebef1cd9-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3389"},"text":"124 Stat. 3389","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebef1cda-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebef1cdb-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebef1cdc-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Sec