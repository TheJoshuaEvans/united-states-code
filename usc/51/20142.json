{"tag":"section","attrib":{"id":"idebd74d85-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20142"},"text":null,"children":[{"tag":"num","attrib":{"value":"20142"},"text":"§ 20142.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts regarding expendable launch vehicles","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebd74d86-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20142/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commitments Beyond Available Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may enter into contracts for expendable launch vehicle services that are for periods in excess of the period for which funds are otherwise available for obligation, provide for the payment for contingent liability which may accrue in excess of available appropriations in the event the Federal Government for its convenience terminates such contracts, and provide for advance payments reasonably related to launch vehicle and related equipment, fabrication, and acquisition costs, if any such contract limits the amount of the payments that the Government is allowed to make under such contract to amounts provided in advance in appropriation Acts. Such contracts may be limited to sources within the United States when the Administrator determines that such limitation is in the public interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd74d87-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20142/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination if Funds Not Available","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If funds are not available to continue any such contract, the contract shall be terminated for the convenience of the Government, and the costs of such contract shall be paid from appropriations originally available for performance of the contract, from other unobligated appropriations currently available for the procurement of launch services, or from funds appropriated for such payments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebd74d88-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3348"},"text":"124 Stat. 3348","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebd74d89-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebd74d8a-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebd74d8b-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20142","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s2459c"},"text":"42 U.S.C. 2459c","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/85/568/tIII/s312"},"text":"Pub. L. 85–568, title III, § 312","children":[],"tail":", formerly § 311, as added "},{"tag":"html:a","attrib":{"href":"/us/pl/100/147/tI/s117"},"text":"Pub. L. 100–147, title I, § 117","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/101/867"},"text":"101 Stat. 867","children":[],"tail":"; renumbered § 312, "},{"tag":"html:a","attrib":{"href":"/us/pl/106/391/tIII/s324/a/1"},"text":"Pub. L. 106–391, title III, § 324(a)(1)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/114/1599"},"text":"114 Stat. 1599","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “expendable” is substituted for “expendabe” to correct an error in the law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
