{"tag":"section","attrib":{"id":"idebe5a568-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30301"},"text":null,"children":[{"tag":"num","attrib":{"value":"30301"},"text":"§ 30301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guaranteed customer base","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No amount appropriated to the Administration may be used to fund grants, contracts, or other agreements with an expected duration of more than one year, when a primary effect of the grant, contract, or agreement is to provide a guaranteed customer base for or establish an anchor tenancy in new commercial space hardware or services unless an appropriations Act specifies the new commercial space hardware or services to be developed or used, or the grant, contract, or agreement is otherwise identified in such Act.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idebe5a569-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3363"},"text":"124 Stat. 3363","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebe5a56a-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebe5a56b-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebe5a56c-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail"