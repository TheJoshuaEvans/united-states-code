{"tag":"section","attrib":{"id":"idebd4dd7c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20141"},"text":null,"children":[{"tag":"num","attrib":{"value":"20141"},"text":"§ 20141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Misuse of agency name and initials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebd4dd7d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20141/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person (as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s20135/a"},"text":"section 20135(a) of this title","children":[],"tail":") may knowingly use the words “National Aeronautics and Space Administration” or the letters “NASA”, or any combination, variation, or colorable imitation of those words or letters either alone or in combination with other words or letters—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd4dd7e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20141/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a firm or business name in a manner reasonably calculated to convey the impression that the firm or business has some connection with, endorsement of, or authorization from, the Administration which does not, in fact, exist; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd4dd7f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20141/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with any product or service being offered or made available to the public in a manner reasonably calculated to convey the impression that the product or service has the authorization, support, sponsorship, or endorsement of, or the development, use, or manufacture by or on behalf of the Administration which does not, in fact, exist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd74d80-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20141/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Proceeding To Enjoin","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever it appears to the Attorney General that any person is engaged in an act or practice which constitutes or will constitute conduct prohibited by subsection (a), the Attorney General may initiate a civil proceeding in a district court of the United States to enjoin such act or practice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebd74d81-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3348"},"text":"124 Stat. 3348","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebd74d82-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebd74d83-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebd74d84-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"childre