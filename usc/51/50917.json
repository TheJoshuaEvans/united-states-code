{"tag":"section","attrib":{"id":"idebffe480-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50917"},"text":null,"children":[{"tag":"num","attrib":{"value":"50917"},"text":"§ 50917.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement and penalty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebffe481-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50917/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person may not violate this chapter, a regulation prescribed under this chapter, or any term of a license issued or transferred under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebffe482-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50917/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebffe483-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50917/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out this chapter, the Secretary of Transportation may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebffe484-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50917/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct investigations and inquiries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebffe485-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50917/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer oaths;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebffe486-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50917/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take affidavits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebffe487-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50917/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" under lawful process—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idebffe488-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50917/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter at a reasonable time a launch site, reentry site, production facility, assembly site of a launch vehicle or reentry vehicle, crew or space flight participant training site, or site at which a payload is integrated with a launch vehicle or reentry vehicle to inspect an object to which this chapter applies or a record or report the Secretary requires be made or kept under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idebffe489-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50917/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seize the object, record, or report when there is probable cause to believe the object, record, or report was used, is being used, or likely will be used in violation of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebffe48a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50917/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may delegate a duty or power under this chapter related to enforcement to an officer or employee of another executive agency with the consent of the head of the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebffe48b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50917/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebffe48c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50917/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After notice and an opportunity for a hearing on the record, a person the Secretary finds to have violated subsection (a) of this section is liable to the United States Government for a civil penalty of not more than $100,000. A separate violation occurs for each day the violation continues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebffe48d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50917/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In conducting a hearing under paragraph (1) of this subsection, the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebffe48e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50917/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subpena witnesses and records; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebffe48f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50917/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforce a subpena in an appropriate district court of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebffe490-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50917/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall impose the civil penalty by written notice. The Secretary may compromise or remit a penalty imposed, or that may be imposed, under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebffe491-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50917/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall recover a civil penalty not paid after the penalty is final or after a court enters a final judgment for the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebffe492-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1341"},"text":"108 Stat. 1341","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s70115"},"text":"§ 70115 of title 49","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/303/tI/s102/a/14"},"text":"Pub. L. 105–303, title I, § 102(a)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2850"},"text":"112 Stat. 2850","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/492/s2/c/24"},"text":"Pub. L. 108–492, § 2(c)(24)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3981"},"text":"118 Stat. 3981","children":[],"tail":"; renumbered § 70115 then "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s50917"},"text":"§ 50917 of title 51","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/111/314/s4/d/2"},"text":"Pub. L. 111–314, § 4(d)(2)","children":[],"tail":", (3)(Q), "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3440"},"text":"124 Stat. 3440","children":[],"tail":", 3441.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebffe493-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebffe494-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebffe495-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70115(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2617.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/575"},"text":"Pub. L. 98–575","children":[],"tail":", §§ 17–19, "},{"tag":"html:a","attrib":{"href":"/us/stat/98/3061"},"text":"98 Stat. 3061","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70115(b)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2616(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70115(b)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2616(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70115(c)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2618(a) (1st, 2d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70115(c)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2618(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70115(c)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2618(a) (3d, last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70115(c)(4)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2618(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “a requirement of” are omitted as surplus. The word “prescribed” is substituted for “issued” for consistency in the revised title and with other titles of the United States Code. The words “condition, or restriction” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1)(A)–(C), the words “concerning any matter relating to enforcement of this chapter” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1)(B) and (C), the words “from any person” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1)(B), the word “affirmation” is omitted because of 1:1.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the text of 49 App.:2616(a) (1st sentence) is omitted as surplus because the Secretary of Transportation enforces programs the Secretary carries out unless otherwise provided. The words “the exercise of” are omitted as surplus. The words “duty or power” are substituted for “authority” for consistency in the revised title and with other titles of the Code. The words “to any officer or employee of the Department of Transportation” are omitted as surplus because of 49:322(b).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s554"},"text":"section 554 of title 5","children":[],"tail":"” are omitted for consistency in the revised title and because 5:554 applies to a hearing on the record unless otherwise stated. The words “for each violation” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “relevant papers, books, documents, and other” are omitted as surplus. The words “(3) administer oaths and affirmatives” are omitted as surplus because of subsection (b)(1)(B) of this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(3), the word “impose” is substituted for “assessed” for consistency in the revised title and with other titles of the Code. The words “amount of such” and “modify . . . with or without conditions” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c)(4) is substituted for 49 App.:2618(b) to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idebffe496-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idebffe497-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314"},"text":"Pub. L. 111–314","children":[],"tail":" successively renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s70115"},"text":"section 70115 of title 49","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s70115"},"text":"section 70115 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(1)(D)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/492"},"text":"Pub. L. 108–492","children":[],"tail":" inserted “crew or space flight participant training site,” after “site of a launch vehicle or reentry vehicle,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(1)(D)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/303"},"text":"Pub. L. 105–303","children":[],"tail":" inserted “reentry site,” after “launch site,” and inserted “or reentry vehicle” after “launch vehicle” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
