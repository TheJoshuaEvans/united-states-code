{"tag":"section","attrib":{"id":"idec06e9cc-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60303"},"text":null,"children":[{"tag":"num","attrib":{"value":"60303"},"text":"§ 60303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot projects to encourage public sector applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec06e9cd-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall establish a program of grants for competitively awarded pilot projects to explore the integrated use of sources of remote sensing and other geospatial information to address State, local, regional, and tribal agency needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec06e9ce-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preferred Projects","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this section, the Administrator shall give preference to projects that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec06e9cf-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make use of commercial data sets, including high resolution commercial satellite imagery and derived satellite data products, existing public data sets where commercial data sets are not available or applicable, or the fusion of such data sets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec06e9d0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrate multiple sources of geospatial information, such as geographic information system data, satellite-provided positioning data, and remotely sensed data, in innovative ways;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec06e9d1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60303/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include funds or in-kind contributions from non-Federal sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec06e9d2-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60303/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve the participation of commercial entities that process raw or lightly processed data, often merging that data with other geospatial information, to create data products that have significant value added to the original data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec06e9d3-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60303/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taken together demonstrate as diverse a set of public sector applications as possible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec06e9d4-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Opportunities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Administrator shall seek opportunities to assist—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec06e9d5-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60303/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the development of commercial applications potentially available from the remote sensing industry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec06e9d6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60303/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State, local, regional, and tribal agencies in applying remote sensing and other geospatial information technologies for growth management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec06e9d7-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Assistance for a pilot project under subsection (a) shall be provided for a period not to exceed 3 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec06e9d8-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60303/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each recipient of a grant under subsection (a) shall transmit a report to the Administrator on the results of the pilot project within 180 days of the completion of that project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec06e9d9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60303/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Workshop","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each recipient of a grant under subsection (a) shall, not later than 180 days after the completion of the pilot project, conduct at least one workshop for potential users to disseminate the lessons learned from the pilot project as widely as feasible.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec06e9da-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60303/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall issue regulations establishing application, selection, and implementation procedures for pilot projects, and guidelines for reports and workshops required by this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec06e9db-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3423"},"text":"124 Stat. 3423","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec06e9dc-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idec06e9dd-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idec06e9de-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60303","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s16673"},"text":"42 U.S.C. 16673","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/109/155/tIII/s313"},"text":"Pub. L. 109–155, title III, § 313","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 30, 2005","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/119/2921"},"text":"119 Stat. 2921","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
