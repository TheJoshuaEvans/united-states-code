{"tag":"section","attrib":{"id":"idebea6121-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30703"},"text":null,"children":[{"tag":"num","attrib":{"value":"30703"},"text":"§ 30703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign launch vehicles","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebea6122-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accord With Space Transportation Policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administration shall not launch a payload on a foreign launch vehicle except in accordance with the Space Transportation Policy announced by the President on ","children":[{"tag":"date","attrib":{"date":"2004-12-21"},"text":"December 21, 2004","children":[],"tail":". This subsection shall not be construed to prevent the President from waiving the Space Transportation Policy."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebea6123-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interagency Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administration shall not launch a payload on a foreign launch vehicle unless the Administration commenced the interagency coordination required by the Space Transportation Policy announced by the President on ","children":[{"tag":"date","attrib":{"date":"2004-12-21"},"text":"December 21, 2004","children":[],"tail":", at least 90 days before entering into a development contract for the payload."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attr