{"tag":"section","attrib":{"id":"idebd9bf5c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20161"},"text":null,"children":[{"tag":"num","attrib":{"value":"20161"},"text":"§ 20161.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of purpose and policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebd9bf5d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20161/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of this subchapter is to authorize and direct the Administration to develop and carry out a comprehensive program of research, technology, and monitoring of the phenomena of the upper atmosphere so as to provide for an understanding of and to maintain the chemical and physical integrity of the Earth’s upper atmosphere.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd9bf5e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20161/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Congress declares that it is the policy of the United States to undertake an immediate and appropriate research, technology, and monitoring program that will provide for understanding the physics and chemistry of the Earth’s upper atmosphere.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebd9bf5f-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{