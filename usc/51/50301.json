{"tag":"section","attrib":{"id":"idebf64823-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50301"},"text":null,"children":[{"tag":"num","attrib":{"value":"50301"},"text":"§ 50301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebf64824-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commercial provider","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “commercial provider” means any person or entity providing commercial reusable in-orbit space transportation services or systems, primary control of which is held by persons other than the Federal Government, a State or local government, or a foreign government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf64825-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In-space transportation services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “in-space transportation services” means operations and activities involved in the direct transportation or attempted transportation of a payload or object from one orbit to another by means of an in-space transportation vehicle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf64826-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In-space transportation system","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “in-space transportation system” means the space and ground elements, including in-space transportation vehicles and support space systems, and ground administration and control facilities and associated equipment, necessary for the provision of in-space transportation services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf64827-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50301/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In-space transportation vehicle","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “in-space transportation vehicle” means a vehicle designed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebf64828-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50301/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be based and operated in space;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf64829-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50301/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to transport various payloads or objects from one orbit to another orbit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf6482a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50301/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be reusable and refueled in space.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf6482b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50301/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Secretary” means the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf6482c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50301/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"United states commercial provider","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “United States commercial provider” means any commercial provider organized under the laws of the United States that is more than 50 percent owned by United States nationals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebf6482d-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3401"},"text":"124 Stat. 3401","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebf6482e-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebf6482f-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebf64830-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"50301","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s14753"},"text":"42 U.S.C. 14753","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/107/248/tIX/s904"},"text":"Pub. L. 107–248, title IX, § 904","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 23, 2002","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/116/1576"},"text":"116 Stat. 1576","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idebf64831-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idebf64832-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/248/tIX/s902"},"text":"Pub. L. 107–248, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-23"},"text":"Oct. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1573"},"text":"116 Stat. 1573","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/248/tIX/s902"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress makes the following findings:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is in the national interest to encourage the production of cost-effective, in-space transportation systems, which would be built and operated by the private sector on a commercial basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use of reusable in-space transportation systems will enhance performance levels of in-space operations, enhance efficient and safe disposal of satellites at the end of their useful lives, and increase the capability and reliability of existing ground-to-space launch vehicles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Commercial reusable in-space transportation systems will enhance the economic well-being and national security of the United States by reducing space operations costs for commercial and national space programs and by adding new space capabilities to space operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Commercial reusable in-space transportation systems will provide new cost-effective space capabilities (including orbital transfers from low altitude orbits to high altitude orbits and return, the correction of erroneous satellite orbits, and the recovery, refurbishment, and refueling of satellites) and the provision of upper stage functions to increase ground-to-orbit launch vehicle payloads to geostationary and other high energy orbits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Commercial reusable in-space transportation systems can enhance and enable the space exploration of the United States by providing lower cost trajectory injection from earth orbit, transit trajectory control, and planet arrival deceleration to support potential National Aeronautics and Space Administration missions to Mars, Pluto, and other planets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Satellites stranded in erroneous earth orbit due to deficiencies in their launch represent substantial economic loss to the United States and present substantial concerns for the current backlog of national space assets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Commercial reusable in-space transportation systems can provide new options for alternative planning approaches and risk management to enhance the mission assurance of national space assets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Commercial reusable in-space transportation systems developed by the private sector can provide in-space transportation services to the National Aeronautics and Space Administration, the Department of Defense, the National Reconnaissance Office, and other agencies without the need for the United States to bear the cost of production of such systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"“(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The availability of loan guarantees, with the cost of credit risk to the United States paid by the private-sector, is an effective means by which the United States can help qualifying private-sector companies secure otherwise unattainable private financing for the production of commercial reusable in-space transportation systems, while at the same time minimizing Government commitment and involvement in the development of such systems.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
