{"tag":"section","attrib":{"id":"idebe7efad-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30310"},"text":null,"children":[{"tag":"num","attrib":{"value":"30310"},"text":"§ 30310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception to alternative fuel procurement requirement","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Section 526(a) ","children":[{"tag":"ref","attrib":{"idref":"fn002006"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002006"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Energy Independence and Security Act of 2007 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s17142/a"},"text":"42 U.S.C. 17142(a)","children":[],"tail":") does not prohibit the Administration from entering into a contract to purchase a generally available fuel that is not an alternative or synthetic fuel or predominantly produced from a nonconventional petroleum source, if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebe7efae-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30310/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contract does not specifically require the contractor to provide an alternative or synthetic fuel or fuel from a nonconventional petroleum source;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebe7efaf-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30310/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purpose of the contract is not to obtain an alternative or synthetic fuel or fuel from a nonconventional petroleum source; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebe7efb0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30310/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contract does not provide incentives for a refinery upgrade or expansion to allow a refinery to use or increase its use of fuel from a nonconventional petroleum source.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebe7efb1-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3366"},"text":"124 Stat. 3366","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebe7efb2-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebe7efb3-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebe7efb4-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i",