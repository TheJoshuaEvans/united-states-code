{"tag":"section","attrib":{"id":"idebf8b903-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902"},"text":null,"children":[{"tag":"num","attrib":{"value":"50902"},"text":"§ 50902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebf8b904-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “citizen of the United States” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebf8b905-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who is a citizen of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf8b906-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity organized or existing under the laws of the United States or a State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf8b907-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity organized or existing under the laws of a foreign country if the controlling interest (as defined by the Secretary of Transportation) is held by an individual or entity described in subclause (A) or (B) of this clause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b908-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “crew” means any employee of a licensee or transferee, or of a contractor or subcontractor of a licensee or transferee, who performs activities in the course of that employment directly relating to the launch, reentry, or other operation of or in a launch vehicle or reentry vehicle that carries human beings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b909-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “executive agency” has the same meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b90a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “government astronaut” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebf8b90b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designated by the National Aeronautics and Space Administration under section 20113(n);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf8b90c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is carried within a launch vehicle or reentry vehicle in the course of his or her employment, which may include performance of activities directly relating to the launch, reentry, or other operation of the launch vehicle or reentry vehicle; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf8b90d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idebf8b90e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of the United States Government, including the uniformed services, engaged in the performance of a Federal function under authority of law or an Executive act; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idebf8b90f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an international partner astronaut.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b910-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “international partner astronaut” means an individual designated under Article 11 of the International Space Station Intergovernmental Agreement, by a partner to that agreement other than the United States, as qualified to serve as an International Space Station crew member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b911-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “International Space Station Intergovernmental Agreement” means the Agreement Concerning Cooperation on the International Space Station, signed at Washington ","children":[{"tag":"date","attrib":{"date":"1998-01-29"},"text":"January 29, 1998","children":[],"tail":" (TIAS 12927)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b912-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “launch” means to place or try to place a launch vehicle or reentry vehicle and any payload or human being from Earth—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebf8b913-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a suborbital trajectory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf8b914-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in Earth orbit in outer space; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf8b915-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise in outer space,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"including activities involved in the preparation of a launch vehicle or payload for launch, when those activities take place at a launch site in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b916-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “launch property” means an item built for, or used in, the launch preparation or launch of a launch vehicle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b917-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “launch services” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebf8b918-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities involved in the preparation of a launch vehicle, payload, crew (including crew training), government astronaut, or space flight participant for launch; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf8b919-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct of a launch.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b91a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “launch site” means the location on Earth from which a launch takes place (as defined in a license the Secretary issues or transfers under this chapter) and necessary facilities at that location.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b91b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “launch vehicle” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebf8b91c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vehicle built to operate in, or place a payload or human beings in, outer space; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf8b91d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a suborbital rocket.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b91e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “obtrusive space advertising” means advertising in outer space that is capable of being recognized by a human being on the surface of the Earth without the aid of a telescope or other technological device.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b91f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “payload” means an object that a person undertakes to place in outer space by means of a launch vehicle or reentry vehicle, including components of the vehicle specifically designed or adapted for that object.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b920-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except in section 50904(c), “permit” means an experimental permit issued under section 50906.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b921-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “person” means an individual and an entity organized or existing under the laws of a State or country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b922-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “reenter” and “reentry” mean to return or attempt to return, purposefully, a reentry vehicle and its payload or human beings, if any, from Earth orbit or from outer space to Earth.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b923-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “reentry services” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebf8b924-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/17/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities involved in the preparation of a reentry vehicle and payload, crew (including crew training), government astronaut, or space flight participant, if any, for reentry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf8b925-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/17/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct of a reentry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b926-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “reentry site” means the location on Earth to which a reentry vehicle is intended to return (as defined in a license the Secretary issues or transfers under this chapter).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b927-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “reentry vehicle” means a vehicle designed to return from Earth orbit or outer space to Earth, or a reusable launch vehicle designed to return from Earth orbit or outer space to Earth, substantially intact.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b928-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “space flight participant” means an individual, who is not crew or a government astronaut, carried within a launch vehicle or reentry vehicle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b929-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “space support vehicle flight” means a flight in the air that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebf8b92a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/21/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a launch or reentry; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf8b92b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/21/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is conducted by a space support vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b92c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “space support vehicle” means a vehicle that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebf8b92d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/22/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a launch vehicle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf8b92e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/22/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reentry vehicle; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf8b92f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/22/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a component of a launch or reentry vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b930-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"(23)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means a State of the United States, the District of Columbia, and a territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b931-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/24"},"text":null,"children":[{"tag":"num","attrib":{"value":"24"},"text":"(24)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless and until regulations take effect under section 50922(c)(2), “suborbital rocket” means a vehicle, rocket-propelled in whole or in part, intended for flight on a suborbital trajectory, and the thrust of which is greater than its lift for the majority of the rocket-powered portion of its ascent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b932-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/25"},"text":null,"children":[{"tag":"num","attrib":{"value":"25"},"text":"(25)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “suborbital trajectory” means the intentional flight path of a launch vehicle, reentry vehicle, or any portion thereof, whose vacuum instantaneous impact point does not leave the surface of the Earth.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b933-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/26"},"text":null,"children":[{"tag":"num","attrib":{"value":"26"},"text":"(26)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “third party” means a person except—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebf8b934-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/26/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Government or the Government’s contractors or subcontractors involved in launch services or reentry services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf8b935-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/26/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a licensee or transferee under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf8b936-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/26/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a licensee’s or transferee’s contractors, subcontractors, or customers involved in launch services or reentry services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf8b937-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/26/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the customer’s contractors or subcontractors involved in launch services or reentry services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf8b938-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/26/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" crew, government astronauts, or space flight participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b939-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50902/27"},"text":null,"children":[{"tag":"num","attrib":{"value":"27"},"text":"(27)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States” means the States of the United States, the District of Columbia, and the territories and possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebf8b93a-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1331"},"text":"108 Stat. 1331","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s70102"},"text":"§ 70102 of title 49","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/92"},"text":"Pub. L. 104–287, § 5(92)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3398"},"text":"110 Stat. 3398","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/303/tI/s102/a/3"},"text":"Pub. L. 105–303, title I, § 102(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2846"},"text":"112 Stat. 2846","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/391/tIII/s322/a"},"text":"Pub. L. 106–391, title III, § 322(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1598"},"text":"114 Stat. 1598