uct a launch” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (9), the words “corporation, partnership, joint venture, association, or other” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clauses (10) and (12) are substituted for 49 App.:2603(10) to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (11), before subclause (A), the words “or entity” are omitted as surplus. In subclause (A), the words “its agencies” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebf8b93e-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:70102(6) to correct an error in the codification enacted by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1994-07-05/s1"},"text":"section 1 of the Act of July 5, 1994","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Public Law 103–272","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1331"},"text":"108 Stat. 1331","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idebf8b93f-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idebf8b940-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Pars. (21) to (27). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"tex