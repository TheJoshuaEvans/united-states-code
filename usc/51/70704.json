{"tag":"section","attrib":{"id":"idec0e155b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70704"},"text":null,"children":[{"tag":"num","attrib":{"value":"70704"},"text":"§ 70704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition of Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec0e155c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Number of Commissioners","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Commission established pursuant to this chapter shall consist of 15 members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec0e155d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The members of a Commission shall be chosen in the following manner:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec0e155e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70704/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment by president","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall appoint the members, and shall designate the Chairman and Vice Chairman of the Commission from among its members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec0e155f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70704/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lists provided by leaders of congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The majority leader of the Senate, the minority leader of the Senate, the Speaker of the House of Representatives, and the minority leader of the House of Representatives shall each provide to the President a list of candidates for membership on the Commission. The President may select one of the candidates from each of the 4 lists for membership on the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec0e1560-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70704/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition regarding federal officers and employees and members of congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No officer or employee of the Federal Government or Member of Congress shall serve as a member of the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec0e1561-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70704/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition regarding contractors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No member of the Commission shall have, or have pending, a contractual relationship with the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec0e1562-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70704/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition regarding conflict of interest","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall not appoint any individual as a member of a Commission under this section who has a current or former relationship with the Administrator that the President determines would constitute a conflict of interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec0e1563-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70704/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Experience","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent practicable, the President shall ensure that the members of the Commission include some individuals with experience relative to human carrying spacecraft, as well as some individuals with investigative experience and some individuals with legal experience.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec0e1564-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70704/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Diversity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent practicable, the President shall seek diversity in the membership of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec0e1565-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All members of a Commission established under this chapter shall be appointed no later than 30 days after the incident.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec0e1566-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial Meeting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Commission shall meet and begin operations as soon as practicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec0e1567-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70704/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsequent Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After its initial meeting, a Commission shall meet upon the call of the Chairman or a majority of its members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec0e1568-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70704/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quorum","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Eight members of a Commission shall constitute a quorum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec0e1569-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70704/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vacancies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any vacancy in a Commission shall not affect its powers, but shall be filled in the same manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec0e156a-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3433"},"text":"124 Stat. 3433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec0e156b-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idec0e156c-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idec0e156d-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text"