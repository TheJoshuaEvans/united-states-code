{"tag":"section","attrib":{"id":"idebd74d8c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20143"},"text":null,"children":[{"tag":"num","attrib":{"value":"20143"},"text":"§ 20143.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full cost appropriations account structure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebd74d8d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20143/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accounts for Appropriations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd74d8e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20143/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of 3 accounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Appropriations for the Administration shall be made in 3 accounts, “Science, Aeronautics, and Education”, “Exploration Systems and Space Operations”, and an account for amounts appropriated for the necessary expenses of the Office of the Inspector General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd74d8f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20143/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reprogramming","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within the Exploration Systems and Space Operations account, no more than 10 percent of the funds for a fiscal year for Exploration Systems may be reprogrammed for Space Operations, and no more than 10 percent of the funds for a fiscal year for Space Operations may be reprogrammed for Exploration Systems. This paragraph shall not apply to reprogramming for the purposes described in subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd74d90-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20143/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Appropriations shall remain available for 2 fiscal years, unless otherwise specified in law. Each account shall include the planned full costs of Administration activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd74d91-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20143/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfers Among Accounts.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd74d92-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20143/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To ensure the safe, timely, and successful accomplishment of Administration missions, the Administration may transfer among accounts as necessary, amounts for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebd74d93-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20143/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal salaries and benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebd74d94-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20143/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training, travel, and awards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebd74d95-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20143/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facility and related costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebd74d96-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20143/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information technology services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebd74d97-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20143/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publishing services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebd74d98-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20143/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" science, engineering, fabricating, and testing services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebd74d99-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20143/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other administrative services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd74d9a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20143/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disaster, act of terrorism, emergency rescue","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administration may also transfer amounts among accounts for the immediate costs of recovering from damage caused by a major disaster (as defined in section 102 of the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122"},"text":"42 U.S.C. 5122","children":[],"tail":")) or by an act of terrorism, or for the immediate costs associated with an emergency rescue of astronauts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd74d9b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20143/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Unexpired Balances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The unexpired balances of prior appropriations to the Administration for activities authorized under this chapter may be transferred to the new account established for such activity in subsection (a). Balances so transferred may be merged with funds in the newly established account and thereafter may be accounted for as one fund under the same terms and conditions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebd74d9c-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3349"},"text":"124 Stat. 3349","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebd74d9d-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebd74d9e-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebd74d9f-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20143","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s2459f"},"text":"42 U.S.C. 2459f","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/85/568/tIII/s313"},"text":"Pub. L. 85–568, title III, § 313","children":[],"tail":", formerly § 312, as added "},{"tag":"html:a","attrib":{"href":"/us/pl/106/377/s1/a/1/tIV/s431"},"text":"Pub. L. 106–377, § 1(a)(1) [title IV, § 431]","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 27, 2000","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/114/1441"},"text":"114 Stat. 1441","children":[],"tail":", 1441A–56; renumbered § 313 and amended, "},{"tag":"html:a","attrib":{"href":"/us/pl/108/199/dG/tIV/s417"},"text":"Pub. L. 108–199, div. G, title IV, § 417","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/118/415"},"text":"118 Stat. 415","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/108/447/dI/tIV/s417"},"text":"Pub. L. 108–447, div. I, title IV, § 417","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/118/3339"},"text":"118 Stat. 3339","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/109/155/tII/s201"},"text":"Pub. L. 109–155, title II, § 201","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 30, 2005","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/119/2915"},"text":"119 Stat. 2915","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “for fiscal year 2007 and thereafter” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idebd74da0-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idebd74da1-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Notice of Reprogramming or Reorganization","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/391/tIII/s311"},"text":"Pub. L. 106–391, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1594"},"text":"114 Stat. 1594","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/391/tIII/s311"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of Reprogramming","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If any funds authorized by this Act [see Tables for classification] are subject to a reprogramming action that requires notice to be provided to the Appropriations Committees of the House of Representatives and the Senate, notice of such action shall concurrently be provided to the Committee on Science [now Committee on Science, Space, and Technology] of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of Reorganization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator [of the National Aeronautics and Space Administration] shall provide notice to the Committees on Science [now Science, Space, and Technology] and Appropriations of the House of Representatives, and the Committees on Commerce, Science, and Transportation and Appropriations of the Senate, not later than 30 days before any major reorganization of any program, project, or activity of the National Aeronautics and Space Administration.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
