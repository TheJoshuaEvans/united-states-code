{"tag":"section","attrib":{"id":"idebef1c84-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40306"},"text":null,"children":[{"tag":"num","attrib":{"value":"40306"},"text":"§ 40306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Space grant college and space grant regional consortium","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebef1c85-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation and Qualifications.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebef1c86-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40306/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to designate","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may designate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebef1c87-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40306/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any institution of higher education as a space grant college; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebef1c88-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40306/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any association or other alliance of 2 or more persons, other than individuals, as a space grant regional consortium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1c89-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40306/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Space grant college requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No institution of higher education may be designated as a space grant college unless the Administrator finds that such institution—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebef1c8a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40306/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is maintaining a balanced program of research, education, training, and advisory services in fields related to space;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebef1c8b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40306/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will act in accordance with such guidelines as are prescribed under subsection (b)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebef1c8c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40306/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets such other qualifications as the Administrator considers necessary or appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1c8d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40306/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Space grant regional consortium requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No association or other alliance of 2 or more persons may be designated as a space grant regional consortium unless the Administrator finds that such association or alliance—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebef1c8e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40306/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is established for the purpose of sharing expertise, research, educational facilities or training facilities, and other capabilities in order to facilitate research, education, training, and advisory services in any field related to space;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebef1c8f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40306/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will encourage and follow a regional approach to solving problems or meeting needs relating to space, in cooperation with appropriate space grant colleges, space grant programs, and other persons in the region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebef1c90-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40306/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will act in accordance with such guidelines as are prescribed under subsection (b)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebef1c91-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40306/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets such other qualifications as the Administrator considers necessary or appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebef1c92-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifications and Guidelines","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall by regulation prescribe—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebef1c93-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40306/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the qualifications required to be met under paragraphs (2)(C) and (3)(D) of subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1c94-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40306/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidelines relating to the activities and responsibilities of space grant colleges and space grant regional consortia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebef1c95-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Suspension or Termination of Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may, for cause and after an opportunity for hearing, suspend or terminate any designation under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebef1c96-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3386"},"text":"124 Stat. 3386","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebef1c97-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebef1c98-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebef1c99-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"