{"tag":"section","attrib":{"id":"idebf18d3f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40905"},"text":null,"children":[{"tag":"num","attrib":{"value":"40905"},"text":"§ 40905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program to expand distance learning in rural underserved areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebf18d40-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall develop or expand programs to extend science and space educational outreach to rural communities and schools through video conferencing, interpretive exhibits, teacher education, classroom presentations, and student field trips.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebf18d41-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Priorities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Administrator shall give priority to existing programs, including Challenger Learning Centers—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebf18d42-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40905/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that utilize community-based partnerships in the field;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf18d43-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40905/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that build and maintain video conference and exhibit capacity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf18d44-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40905/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that travel directly to rural communities and serve low-income populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf18d45-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40905/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with a special emphasis on increasing the number of women and minorities in the science and engineering professions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebf18d46-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3393"},"text":"124 Stat. 3393","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebf18d47-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebf18d48-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebf18d49-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"