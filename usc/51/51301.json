{"tag":"section","attrib":{"id":"idec022f5d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51301"},"text":null,"children":[{"tag":"num","attrib":{"value":"51301"},"text":"§ 51301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec022f5e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Asteroid resource","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “asteroid resource” means a space resource found on or within a single asteroid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec022f5f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Space resource.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idec022f60-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51301/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “space resource” means an abiotic resource in situ in outer space.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022f61-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51301/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “space resource” includes water and minerals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec022f62-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"United states citizen","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “United States citizen” has the meaning given the term “citizen of the United States” in section 50902.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec022f63-3a70-11f1-9081-fe88c1712d53"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/90/tIV/s402/a"},"text":"Pub. L. 114–90, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/721"},"text":"129 Stat. 721","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
