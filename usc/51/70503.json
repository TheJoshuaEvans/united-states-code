{"tag":"section","attrib":{"id":"idec0bcc13-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70503"},"text":null,"children":[{"tag":"num","attrib":{"value":"70503"},"text":"§ 70503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ground-based analog capabilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec0bcc14-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may establish a ground-based analog capability in remote United States locations in order to assist in the development of lunar operations, life support, and in-situ resource utilization experience and capabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec0bcc15-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Environmental Characteristics","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall select locations for the activities described in subsection (a) that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec0bcc16-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are regularly accessible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec0bcc17-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have significant temperature extremes and range; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec0bcc18-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70503/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have access to energy and natural resources (including geothermal, permafrost, volcanic, or other potential resources).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec0bcc19-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Involvement of Local Populations and Private Sector Partners","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out this section, the Administrator shall involve local populations, academia, and industrial partners as much as possible to ensure that ground-based benefits and applications are encouraged and developed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec0bcc1a-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3430"},"text":"124 Stat. 3430","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec0bcc1b-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idec0bcc1c-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib