{"tag":"section","attrib":{"id":"idebe7efdc-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30503"},"text":null,"children":[{"tag":"num","attrib":{"value":"30503"},"text":"§ 30503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance assessments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebe7efdd-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The performance of each division in the Science directorate of the Administration shall be reviewed and assessed by the National Academy of Sciences at 5-year intervals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebe7efde-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Beginning with the first fiscal year following ","children":[{"tag":"date","attrib":{"date":"2005-12-30"},"text":"December 30, 2005","children":[],"tail":", the Administrator shall select at least one division for review under this section. The Administrator shall select divisions so that all disciplines will have received their first review within 6 fiscal years of "},{"tag":"date","attrib":{"date":"2005-12-30"},"text":"December 30, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebe7efdf-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than March 1 of each year, beginning with the first fiscal year after ","children":[{"tag":"date","attrib":{"date":"2005-12-30"},"text":"December 30, 2005","children":[],"tail":", the Administrator shall transmit a report to the Committee on Science and Technology of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebe7efe0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30503/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" setting forth in detail the results of any external review under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebe7efe1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30503/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" setting forth in detail actions taken by the Administration in response to any external review; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebe7efe2-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30503/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" including a summary of findings and recommendations from any other relevant external reviews of the Administration’s science mission priorities and programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebe7efe3-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","c