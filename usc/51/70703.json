{"tag":"section","attrib":{"id":"idec0e1550-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70703"},"text":null,"children":[{"tag":"num","attrib":{"value":"70703"},"text":"§ 70703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tasks of Commission","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A Commission established pursuant to this chapter shall, to the extent possible, undertake the following tasks:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec0e1551-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70703/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Investigation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Investigate the incident.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec0e1552-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70703/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cause","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Determine the cause of the incident.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec0e1553-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70703/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contributing factors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Identify all contributing factors to the cause of the incident.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec0e1554-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70703/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Make recommendations for corrective actions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec0e1555-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70703/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional findings or recommendations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Provide any additional findings or recommendations deemed by the Commission to be important, whether or not they are related to the specific incident under investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec0e1556-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70703/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Prepare a report to Congress, the President, and the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec0e1557-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3432"},"text":"124 Stat. 3432","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec0e1558-3a70-11