{"tag":"section","attrib":{"id":"idebfd7412-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914"},"text":null,"children":[{"tag":"num","attrib":{"value":"50914"},"text":"§ 50914.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability insurance and financial responsibility requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebfd7413-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebfd7414-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When a launch or reentry license is issued or transferred under this chapter, the licensee or transferee shall obtain liability insurance or demonstrate financial responsibility in amounts to compensate for the maximum probable loss from claims by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebfd7415-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a third party for death, bodily injury, or property damage or loss resulting from an activity carried out under the license; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebfd7416-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Government against a person for damage or loss to Government property resulting from an activity carried out under the license.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebfd7417-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation shall determine the amounts required under paragraph (1)(A) and (B) of this subsection, after consulting with the Administrator of the National Aeronautics and Space Administration, the Secretary of the Air Force, and the heads of other appropriate executive agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebfd7418-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the total claims related to one launch or reentry, a licensee or transferee is not required to obtain insurance or demonstrate financial responsibility of more than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebfd7419-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idebfd741a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $500,000,000 under paragraph (1)(A) of this subsection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idebfd741b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 under paragraph (1)(B) of this subsection; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebfd741c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maximum liability insurance available on the world market at reasonable cost if the amount is less than the applicable amount in clause (A)(i) or (ii) of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebfd741d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An insurance policy or demonstration of financial responsibility under this subsection shall protect the following, to the extent of their potential liability for involvement in launch services or reentry services, at no cost to the Government:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebfd741e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebfd741f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" executive agencies and personnel, contractors, and subcontractors of the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebfd7420-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contractors, subcontractors, and customers of the licensee or transferee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebfd7421-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contractors and subcontractors of the customer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebfd7422-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" space flight participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebfd7423-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subparagraph (E) of paragraph (4) ceases to be effective ","children":[{"tag":"date","attrib":{"date":"2028-09-30"},"text":"September 30, 2028","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebfd7424-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reciprocal Waiver of Claims","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebfd7425-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebfd7426-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A launch or reentry license issued or transferred under this chapter shall contain a provision requiring the licensee or transferee to make a reciprocal waiver of claims with applicable parties involved in launch services or reentry services under which each party to the waiver agrees to be responsible for personal injury to, death of, or property damage or loss sustained by it or its own employees resulting from an activity carried out under the applicable license.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebfd7427-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this paragraph, the term “applicable parties” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idebfd7428-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contractors, subcontractors, and customers of the licensee or transferee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idebfd7429-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contractors and subcontractors of the customers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idebfd742a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" space flight participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebfd742b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Clause (iii) of subparagraph (B) ceases to be effective ","children":[{"tag":"date","attrib":{"date":"2028-09-30"},"text":"September 30, 2028","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebfd742c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation shall make, for the Government, executive agencies of the Government involved in launch services or reentry services, and contractors and subcontractors involved in launch services or reentry services, a reciprocal waiver of claims with the licensee or transferee, contractors, subcontractors, crew, space flight participants, and customers of the licensee or transferee, and contractors and subcontractors of the customers, involved in launch services or reentry services under which each party to the waiver agrees to be responsible for property damage or loss it sustains, or for personal injury to, death of, or property damage or loss sustained by its own employees or by space flight participants, resulting from an activity carried out under the applicable license. The waiver applies only to the extent that claims are more than the amount of insurance or demonstration of financial responsibility required under subsection (a)(1)(B) of this section. After consulting with the Administrator and the Secretary of the Air Force, the Secretary of Transportation may waive, for the Government and a department, agency, and instrumentality of the Government, the right to recover damages for damage or loss to Government property to the extent insurance is not available because of a policy exclusion the Secretary of Transportation decides is usual for the type of insurance involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebfd742d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of Maximum Probable Losses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall determine the maximum probable losses under subsection (a)(1)(A) and (B) of this section associated with an activity under a license not later than 90 days after a licensee or transferee requires a determination and submits all information the Secretary requires. The Secretary shall amend the determination as warranted by new information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebfd742e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebfd742f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than November 15 of each year, the Secretary of Transportation shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Science of the House of Representatives a report on current determinations made under subsection (c) of this section related to all issued licenses and the reasons for the determinations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebfd7430-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than May 15 of each year, the Secretary of Transportation shall review the amounts specified in subsection (a)(3)(A) of this section and submit a report to Congress that contains proposed adjustments in the amounts to conform with changed liability expectations and availability of insurance on the world market. The proposed adjustment takes effect 30 days after a report is submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebfd7431-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Launches or Reentries Involving Government Facilities and Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall establish requirements consistent with this chapter for proof of financial responsibility and other assurances necessary to protect the Government and its executive agencies and personnel from liability, death, bodily injury, or property damage or loss as a result of a launch or operation of a launch site or reentry site or a reentry involving a facility or personnel of the Government. The Secretary may not relieve the Government of liability under this subsection for death, bodily injury, or property damage or loss resulting from the willful misconduct of the Government or its agents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebfd7432-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Collection and Crediting Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of a department, agency, or instrumentality of the Government shall collect a payment owed for damage or loss to Government property under its jurisdiction or control resulting from an activity carried out under a launch or reentry license issued or transferred under this chapter. The payment shall be credited to the current applicable appropriation, fund, or account of the department, agency, or instrumentality.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebfd7433-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50914/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any claim by a third party or space flight participant for death, bodily injury, or property damage or loss resulting from an activity carried out under the license shall be the exclusive jurisdiction of the Federal courts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebfd7434-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1336"},"text":"108 Stat. 1336","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s70112"},"text":"§ 70112 of title 49","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/74"},"text":"Pub. L. 104–287, § 5(74)","children":[],"tail":", (93), "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3396"},"text":"110 Stat. 3396","children":[],"tail":", 3398; "},{"tag":"ref","attrib":{"href":"/us/pl/105/303/tI/s102/a/12"},"text":"Pub. L. 105–303, title I, § 102(a)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2850"},"text":"112 Stat. 2850","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/492/s2/c/21"},"text":"Pub. L. 108–492, § 2(c)(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3981"},"text":"118 Stat. 3981","children":[],"tail":"; renumbered § 70112 then "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s50914"},"text":"§ 50914 of title 51","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/111/314/s4/d/2"},"text":"Pub. L. 111–314, § 4(d)(2)","children":[],"tail":", (3)(N), "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3440"},"text":"124 Stat. 3440","children":[],"tail":", 3441; "},{"tag":"ref","attrib":{"href":"/us/pl/114/90/tI"},"text":"Pub. L. 114–90, title I","children":[],"tail":", §§ 103(a)(1), 106, 107, "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/706"},"text":"129 Stat. 706","children":[],"tail":", 707; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLVII/s5702/2"},"text":"Pub. L. 118–159, div. E, title LVII, § 5702(2)","children":[],"tail":", "},{"tag":"date","attrib":{"