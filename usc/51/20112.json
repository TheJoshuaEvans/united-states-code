usc/t42/s2473/a"},"text":"42 U.S.C. 2473(a)","children":[],"tail":", (b)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/85/568/tII/s203/a"},"text":"Pub. L. 85–568, title II, § 203(a)","children":[],"tail":", (b), "},{"tag":"html:span","attrib":{},"text":"July 29, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/429"},"text":"72 Stat. 429","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/93/409/s4"},"text":"Pub. L. 93–409, § 4","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Sept. 3, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/1070"},"text":"88 Stat. 1070","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/94/413/s15/c"},"text":"Pub. L. 94–413, § 15(c)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Sept. 17, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/1270"},"text":"90 Stat. 1270","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/95/401/s6"},"text":"Pub. L. 95–401, § 6","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Sept. 30, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/860"},"text":"92 Stat. 860","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/101/611/tI/s107"},"text":"Pub. L. 101–611, title I, § 107","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/3197"},"text":"104 Stat. 3197","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
