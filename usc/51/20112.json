{"tag":"section","attrib":{"id":"idebd02197-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20112"},"text":null,"children":[{"tag":"num","attrib":{"value":"20112"},"text":"§ 20112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of the Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebd02198-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Planning, Directing, and Conducting Aeronautical and Space Activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administration, in order to carry out the purpose of this chapter, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd02199-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20112/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plan, direct, and conduct aeronautical and space activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd0219a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20112/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrange for participation by the scientific community in planning scientific measurements and observations to be made through use of aeronautical and space vehicles, and conduct or arrange for the conduct of such measurements and observations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd0219b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20112/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the widest practicable and appropriate dissemination of information concerning its activities and the results thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd0219c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20112/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek and encourage, to the maximum extent possible, the fullest commercial use of space; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd0219d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20112/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage and provide for Federal Government use of commercially provided space services and hardware, consistent with the requirements of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd0219e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Research and Development in Certain Technologies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd0219f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ground propulsion technologies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administration shall, to the extent of appropriated funds, initiate, support, and carry out such research, development, demonstration, and other related activities in ground propulsion technologies as are provided for in sections 4 to 10 of the Electric and Hybrid Vehicle Research, Development, and Demonstration Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2503"},"text":"15 U.S.C. 2503","children":[],"tail":" to 2509)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd021a0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Solar heating and cooling technologies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administration shall initiate, support, and carry out such research, development, demonstrations, and other related activities in solar heating and cooling technologies (to the extent that funds are appropriated therefor) as are provided for in sections 5, 6, and 9 of the Solar Heating and Cooling Demonstration Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5503"},"text":"42 U.S.C. 5503","children":[],"tail":", 5504, 5507)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebd021a1-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3333"},"text":"124 Stat. 3333","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebd021a2-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebd021a3-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebd021a4-3a70-11f1-9081-fe88c17