{"tag":"section","attrib":{"id":"idec022f23-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51103"},"text":null,"children":[{"tag":"num","attrib":{"value":"51103"},"text":"§ 51103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec022f24-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A sponsor may submit to the Secretary of Transportation an application for a project grant. The application must state the project to be undertaken and be in the form and contain the information the Secretary requires.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec022f25-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations and Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idec022f26-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In selecting proposed projects for grants under this section, the Secretary of Transportation shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idec022f27-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51103/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contribution of the project to industry capabilities that serve the United States Government’s space transportation needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022f28-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51103/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of industry’s financial contribution to the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022f29-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51103/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of industry’s participation in the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022f2a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51103/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the positive impact of the project on the international competitiveness of the United States space transportation industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022f2b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51103/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of State contributions to the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022f2c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51103/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of the project on launch operations and other activities at Government launch ranges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec022f2d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation shall consult with the Secretary of Defense, the Administrator of the National Space and Aeronautics Administration, and the heads of other appropriate agencies of the Government about paragraph (1)(A) and (F) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec022f2e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may approve an application only if the Secretary is satisfied that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec022f2f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project will contribute to the purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec022f30-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the project is reasonably consistent with plans (existing at the time of approval of the project) of public agencies that are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idec022f31-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51103/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized by the State in which the project is located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022f32-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51103/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responsible for the development of the area surrounding the project site;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec022f33-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51103/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the application proposes to use Government property, the specific consent of the head of the appropriate agency has been obtained;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec022f34-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51103/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project will be completed without unreasonable delay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec022f35-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51103/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sponsor submitting the application has the legal authority to engage in the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec022f36-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51103/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional requirements prescribed by the Secretary have been met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec022f37-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preference for Industry Contributions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall give preference to applications for projects for which there will be greater industry financial contributions, all other factors being equal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec022f38-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1344"},"text":"108 Stat. 1344","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s70303"},"text":"§ 70303 of title 49","children":[],"tail":"; renumbered § 70303 then "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s51103"},"text":"§ 51103 of title 51","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/111/314/s4/d/2"},"text":"Pub. L. 111–314, § 4(d)(2)","children":[],"tail":", (4)(C), "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3440"},"text":"124 Stat. 3440","children":[],"tail":", 3441.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec022f39-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"