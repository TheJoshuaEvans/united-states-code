{"tag":"section","attrib":{"id":"idebea6192-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31302"},"text":null,"children":[{"tag":"num","attrib":{"value":"31302"},"text":"§ 31302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Astronaut healthcare survey","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebea6193-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Survey","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall administer an anonymous survey of astronauts and flight surgeons to evaluate communication, relationships, and the effectiveness of policies. The survey questions and the analysis of results shall be evaluated by experts independent of the Administration. The survey shall be administered on at least a biennial basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebea6194-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall transmit a report of the results of the survey to Congress not later than 90 days following completion of the survey.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebea6195-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/1