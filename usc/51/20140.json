{"tag":"section","attrib":{"id":"idebd4dd70-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20140"},"text":null,"children":[{"tag":"num","attrib":{"value":"20140"},"text":"§ 20140.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebd4dd71-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20140/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd4dd72-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20140/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this chapter, except that nothing in this chapter shall authorize the appropriation of any amount for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebd4dd73-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20140/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition or condemnation of any real property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebd4dd74-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20140/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other item of a capital nature (such as plant or facility acquisition, construction, or expansion) which exceeds $250,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd4dd75-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20140/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sums appropriated pursuant to this subsection for the construction of facilities, or for research and development activities, shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd4dd76-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20140/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds for Emergency Repairs of Existing Facilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any funds appropriated for the construction of facilities may be used for emergency repairs of existing facilities when such existing facilities are made inoperative by major breakdown, accident, or other circumstances and such repairs are deemed by the Administrator to be of greater urgency than the construction of new facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd4dd77-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20140/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, the authorization of any appropriation to the Administration shall expire (unless an earlier expiration is specifically provided) at the close of the third fiscal year following the fiscal year in which the authorization was enacted, to the extent that such appropriation has not theretofore actually been made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebd4dd78-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3347"},"text":"124 Stat. 3347","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebd4dd79-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebd4dd7a-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebd4dd7b-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"ta