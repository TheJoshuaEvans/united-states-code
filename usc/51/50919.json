{"tag":"section","attrib":{"id":"idebffe4a7-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50919"},"text":null,"children":[{"tag":"num","attrib":{"value":"50919"},"text":"§ 50919.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other executive agencies, laws, and international obligations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebffe4a8-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50919/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in this chapter, a person is not required to obtain from an executive agency a license, approval, waiver, or exemption to launch a launch vehicle or operate a launch site or reentry site, or to reenter a reentry vehicle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebffe4a9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50919/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Communications Commission and Secretary of Commerce","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This chapter does not affect the authority of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebffe4aa-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50919/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Communications Commission under the Communications Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s151"},"text":"47 U.S.C. 151","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebffe4ab-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50919/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Commerce under chapter 601 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebffe4ac-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50919/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"States and Political Subdivisions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State or political subdivision of a State—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebffe4ad-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50919/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not adopt or have in effect a law, regulation, standard, or order inconsistent with this chapter; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebffe4ae-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50919/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may adopt or have in effect a law, regulation, standard, or order consistent with this chapter that is in addition to or more stringent than a requirement of, or regulation prescribed under, this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebffe4af-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50919/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation is encouraged to consult with a State to simplify and expedite the approval of a space launch or reentry activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebffe4b0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50919/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign Countries","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebffe4b1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50919/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out this chapter consistent with an obligation the United States Government assumes in a treaty, convention, or agreement in force between the Government and the government of a foreign country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebffe4b2-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50919/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider applicable laws and requirements of a foreign country when carrying out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebffe4b3-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50919/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Launch Not an Export; Reentry Not an Import","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A launch vehicle, reentry vehicle, or payload that is launched or reentered is not, because of the launch or reentry, an export or import, respectively, for purposes of a law controlling exports or imports, except that payloads launched pursuant to foreign trade zone procedures as provided for under the Foreign Trade Zones Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s81a–81u"},"text":"19 U.S.C. 81a–81u","children":[],"tail":") shall be considered exports with regard to customs entry."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec022ea4-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50919/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idec022ea5-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50919/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This chapter does not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idec022ea6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50919/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a launch, reentry, operation of a launch vehicle or reentry vehicle, operation of a launch site or reentry site, or other space activity the Government carries out for the Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022ea7-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50919/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planning or policies related to the launch, reentry, operation, or activity under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec022ea8-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50919/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following activities are not space activities the Government carries out for the Government under paragraph (1):","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idec022ea9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50919/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A government astronaut being carried within a launch vehicle or reentry vehicle under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022eaa-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50919/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A government astronaut performing activities directly relating to the launch, reentry, or other operation of the launch vehicle or reentry vehicle under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec022eab-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1342"},"text":"108 Stat. 1342","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s70117"},"text":"§ 70117 of title 49","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/95"},"text":"Pub. L. 104–287, § 5(95)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3398"},"text":"110 Stat. 3398","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/303/tI/s102/a/15"},"text":"Pub. L. 105–303, title I, § 102(a)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2850"},"text":"112 Stat. 2850","children":[],"tail":"; renumbered § 70117 then "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s50919"},"text":"§ 50919 of title 51","children":[],"tail":" and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/314/s4/d/2"},"text":"Pub. L. 111–314, § 4(d)(2)","children":[],"tail":", (3)(S), (5)(T), "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3440-3442"},"text":"124 Stat. 3440–3442","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/90/tI/s112"},"text":"Pub. L. 114–90, title I, § 112","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/713"},"text":"129 Stat. 713","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec022eac-3a70-11f1-9081-fe88c1712d53"},"text