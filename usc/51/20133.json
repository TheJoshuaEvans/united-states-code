{"tag":"section","attrib":{"id":"idebd2930a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20133"},"text":null,"children":[{"tag":"num","attrib":{"value":"20133"},"text":"§ 20133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permission to carry firearms","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As the Administrator deems necessary in the public interest, the Administrator may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd2930b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20133/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct officers and employees of the Administration to carry firearms while in the conduct of their official duties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd2930c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20133/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize employees of contractors and subcontractors of the Administration who are engaged in the protection of property owned by the United States, and located at facilities owned by or contracted to the United States, to carry firearms while in the conduct of their official duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebd2930d-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3338"},"text":"124 Stat. 3338","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebd2930e-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note",