{"tag":"section","attrib":{"id":"idec049ff0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60121"},"text":null,"children":[{"tag":"num","attrib":{"value":"60121"},"text":"§ 60121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General licensing authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec049ff1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Licensing Authority of Secretary.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idec049ff2-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60121/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In consultation with other appropriate United States Government agencies, the Secretary is authorized to license private sector parties to operate private remote sensing space systems for such period as the Secretary may specify and in accordance with the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec049ff3-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60121/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation with respect to system used for other purposes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a private space system that is used for remote sensing and other purposes, the authority of the Secretary under this subchapter shall be limited only to the remote sensing operations of such space system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec049ff4-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance With Law, Regulations, International Obligations, and National Security.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idec049ff5-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60121/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No license shall be granted by the Secretary unless the Secretary determines in writing that the applicant will comply with the requirements of this chapter, any regulations issued pursuant to this chapter, and any applicable international obligations and national security concerns of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec049ff6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60121/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"List of requirements for complete application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall publish in the Federal Register a complete and specific list of all information required to comprise a complete application for a license under this subchapter. An application shall be considered complete when the applicant has provided all information required by the list most recently published in the Federal Register before the date the application was first submitted. Unless the Secretary has, within 30 days after receipt of an application, notified the applicant of information necessary to complete an application, the Secretary may not deny the application on the basis of the absence of any such information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec049ff7-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60121/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for Action on Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall review any application and make a determination thereon within 120 days of the receipt of such application. If final action has not occurred within such time, the Secretary shall inform the applicant of any pending issues and of actions required to resolve them.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec049ff8-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60121/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Improper Basis for Denial","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall not deny such license in order to protect any existing licensee from competition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec049ff9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60121/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement To Provide Unenhanced Data.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idec049ffa-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60121/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of data","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, in consultation with other appropriate United States Government agencies and pursuant to paragraph (2), shall designate in a license issued pursuant to this subchapter any unenhanced data required to be provided by the licensee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s60122/b/3"},"text":"section 60122(b)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec049ffb-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60121/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preliminary determination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make a designation under paragraph (1) after determining that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idec049ffc-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60121/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such data are generated by a system for which all or a substantial part of the development, fabrication, launch, or operations costs have been or will be directly funded by the United States Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec049ffd-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60121/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is in the interest of the United States to require such data to be provided by the licensee consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s60122/b/3"},"text":"section 60122(b)(3) of this title","children":[],"tail":", after considering the impact on the licensee and the importance of promoting widespread access to remote sensing data from United States and foreign systems."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec049ffe-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60121/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consistency with contract or other arrangement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A designation made by the Secretary under paragraph (1) shall not be inconsistent with any contract or other arrangement entered into between a United States Government agency and the licensee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec049fff-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3413"},"text":"124 Stat. 3413","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec04a000-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idec04a001-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idec04a002-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60121","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t15/s5621"},"text":"15 U.S.C. 5621","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/102/555/tII/s201"},"text":"Pub. L. 102–555, title II, § 201","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/4171"},"text":"106 Stat. 4171","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/303/tI/s107/f/1"},"text":"Pub. L. 105–303, title I, § 107(f)(1)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/2854"},"text":"112 Stat. 2854","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “within 6 months after the date of the enactment of the Commercial Space Act of 1998” are omitted as obsolete.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idec04a003-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idec04a004-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prohibition on Collection and Release of Detailed Satellite Imagery Relating to Israel","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tX/s1064"},"text":"Pub. L. 104–201, div. A, title X, § 1064","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2653"},"text":"110 Stat. 2653","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/201/dA/tX/s1064"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Collection and Dissemination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A department or agency of the United States may issue a license for the collection or dissemination by a non-Federal entity of satellite imagery with respect to Israel only if such imagery is no more detailed or precise than satellite imagery of Israel that is available from commercial sources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Declassification and Release","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A department or agency of the United States may declassify or otherwise release satellite imagery with respect to Israel only if such imagery is no more detailed or precise than satellite imagery of Israel that is available from commercial sources.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
