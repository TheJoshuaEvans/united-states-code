{"tag":"section","attrib":{"id":"idebd9bef8-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20147"},"text":null,"children":[{"tag":"num","attrib":{"value":"20147"},"text":"§ 20147.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery and disposition authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebd9bef9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20147/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd9befa-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20147/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration human space flight vehicle","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Administration human space flight vehicle” means a space vehicle, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s20138/a"},"text":"section 20138(a) of this title","children":[],"tail":", that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebd9befb-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20147/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is intended to transport one or more persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebd9befc-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20147/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designed to operate in outer space; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebd9befd-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20147/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idebd9befe-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20147/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned by the Administration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idebd9beff-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20147/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned by an Administration contractor or cooperating party and operated as part of an Administration mission or a joint mission with the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd9bf00-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20147/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Crewmember","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “crewmember” means an astronaut or other person assigned to an Administration human space flight vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd9bf01-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20147/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Control of Remains.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd9bf02-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20147/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraphs (2) and (3), when there is an accident or mishap resulting in the death of a crewmember of an Administration human space flight vehicle, the Administrator may take control over the remains of the crewmember and order autopsies and other scientific or medical tests.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd9bf03-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20147/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each crewmember shall provide the Administrator with the crewmember’s preferences regarding the treatment accorded to the crewmember’s remains and the Administrator shall, to the extent possible, respect those stated preferences.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd9bf04-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20147/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall not be construed to permit the Administrator to interfere with any Federal investigation of a mishap or accident.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebd9bf05-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3353"},"text":"124 Stat. 3353","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebd9bf06-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebd9bf07-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebd9bf08-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib