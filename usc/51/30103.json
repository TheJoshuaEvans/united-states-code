"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the budget for public relations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebe3350c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the budget for technology transfer programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebe3350d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30103/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the budget for the Integrated Enterprise Management Program, by individual element;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebe3350e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30103/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the budget for the Independent Technical Authority, both total and by center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebe3350f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30103/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total budget for the prize program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s20144"},"text":"section 20144 of this title","children":[],"tail":", and the administrative budget for that program; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebe33510-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30103/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the comparable figures for at least the 2 previous fiscal years for each item in the proposed budget.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebe33511-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Budget Information Upon Request by Committees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administration shall make available, upon request from the Committee on Science and Technology of the House of Representatives or the Committee on Commerce, Science, and Transportation of the Senate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebe33512-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information on corporate and center general and administrative costs and service pool costs, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebe33513-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30103/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of funds being allocated for those purposes for any fiscal year for which the President has submitted an annual budget request to Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebe33514-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30103/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funds being allocated for those purposes for each center, for headquarters, and for each directorate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebe33515-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30103/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the major activities included in each cost category; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebe33516-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the figures on the amount of unobligated funds and unexpended funds, by appropriations account—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebe33517-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30103/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that remained at the end of the fiscal year prior to the fiscal year in which the budget is being presented that were carried over into the fiscal year in which the budget is being presented;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebe33518-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30103/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are estimated will remain at the end of the fiscal year in which the budget is being presented that are proposed to be carried over into the fiscal year for which the budget is being presented; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebe33519-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30103/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are estimated will remain at the end of the fiscal year for which the budget is being presented.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebe3351a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information in Annual Budget Justification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administration shall provide, at a minimum, the following information in its annual budget justification:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebe3351b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The actual, current, proposed funding level, and estimated budgets for the next 5 fiscal years by directorate, theme, program, project and activity within each appropriations account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebe3351c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The proposed programmatic and non-programmatic construction of facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebe3351d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30103/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The budget for headquarters including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebe3351e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30103/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the budget by office, and any division thereof, for the actual, current, proposed funding level, and estimated budgets for the next 5 fiscal years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebe3351f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30103/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the travel budget for each office, and any division thereof, for the actual, current, and proposed funding level; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebe33520-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30103/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the civil service full time equivalent assignments per headquarters office, and any division thereof, including the number of Senior Executive Service, noncareer, detailee, and contract personnel per office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebe33521-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30103/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Within 14 days of the submission of the budget to Congress an accompanying volume shall be provided to the Committees on Appropriations containing the following information for each center, facility managed by any center, and federally funded research and development center operated on behalf of the Administration:","children":[],"tail":