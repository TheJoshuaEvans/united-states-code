{"tag":"section","attrib":{"id":"idebd292f6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20131"},"text":null,"children":[{"tag":"num","attrib":{"value":"20131"},"text":"§ 20131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public access to information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebd292f7-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20131/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Inspection","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Information obtained or developed by the Administrator in the performance of the Administrator’s functions under this chapter shall be made available for public inspection, except information—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd292f8-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20131/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized or required by Federal statute to be withheld;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd292f9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20131/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" classified to protect the national security; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd292fa-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20131/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd292fb-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20131/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Handling of Trade Secret or Confidential Information.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd292fc-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20131/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator, for a period of up to 5 years after the development of information described in paragraph (2), may provide appropriate protections against the dissemination of such information, including exemption from subchapter II of chapter 5 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd292fd-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20131/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information described","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Information referred to in paragraph (1) is information that results from activities conducted under an agreement entered into under subsections (e) and (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s20113"},"text":"section 20113 of this title","children":[],"tail":", and that would be a trade secret or commercial or financial information that is privileged or confidential under the meaning of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/4"},"text":"section 552(b)(4) of title 5","children":[],"tail":" if the information had been obtained from a non-Federal party participating in such an agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd292fe-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20131/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Committees of Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this chapter authorizes the withholding of information by the Administrator from the duly authorized committees of Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebd292ff-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3338"},"text":"124 Stat. 3338","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebd29300-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebd29301-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebd29302-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"childre