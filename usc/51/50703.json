":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “The Secretary of Commerce shall submit an annual report” are substituted for “Commencing in fiscal year 1992, and every fiscal year thereafter, the Secretary of Commerce shall submit . . . a report” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “Office”, meaning the Office of Space Commercialization, is substituted for “Office of Space Commerce” to correct an error in the law.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “Committee on Science and Technology” are substituted for “Committee on Science, Space, and Technology” on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/14/s1/a/10"},"text":"section 1(a)(10) of Public Law 104–14","children":[],"tail":" (2 U.S.C. note prec. 21), Rule X(1)(n) of the Rules of the House of Representatives, adopted by House Resolution No. 5 (106th Congress, "},{"tag":"date","attrib":{"date":"1999-01-06"},"text":"January 6, 1999","children":[],"tail":"), and Rule X(1)("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of the Rules of the House of Representatives, adopted by House Resolution No. 6 (110th Congress, "},{"tag":"date","attrib":{"date":"2007-01-05"},"text":"January 5, 2007","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idebf8b8db-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idebf8b8dc-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Science and Technology of House of Representatives changed to