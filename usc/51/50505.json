"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Committee on Science and Technology” are substituted for “Committee on Science” on authority of Rule X(1)(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of the Rules of the House of Representatives, adopted by House Resolution No. 6 (110th Congress, "},{"tag":"date","attrib":{"date":"2007-01-05"},"text":"January 5, 2007","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idebf8b8a3-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idebf8b8a4-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Science and Technology of House of Representatives changed to Committee on Science, Space, and Technology of House of Representatives by House Resolution No. 5, One Hundred Twelfth Congress, ","children":[{"tag":"date","attrib":{"date":"2011-01-05"},"text":"Jan. 5, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
