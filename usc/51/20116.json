{"tag":"section","attrib":{"id":"idebd292e0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20116"},"text":null,"children":[{"tag":"num","attrib":{"value":"20116"},"text":"§ 20116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebd292e1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presidential Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall transmit to Congress in May of each year a report, which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd292e2-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20116/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comprehensive description of the programmed activities and the accomplishments of all agencies of the United States in the field of aeronautics and space activities during the preceding fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd292e3-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20116/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of such activities and accomplishments in terms of the attainment of, or the failure to attain, the objectives described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s20102/d"},"text":"section 20102(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd292e4-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendations for Additional Legislation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any report made under this section shall contain such recommendations for additional legislation as the Administrator or the President may consider necessary or desirable for the attainment of the objectives described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s20102/d"},"text":"section 20102(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd292e5-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20116/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Classified Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No information that has been classified for reasons of national security shall be included in any report made under this section, unless the information has been declassified by, or pursuant to authorization given by, the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebd292e6-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3337"},"text":"124 Stat. 3337","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebd292e7-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebd292e8-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebd292e9-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20116","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s2476"},"text":"42 U.S.C. 2476","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/85/568/tII/s206"},"text":"Pub. L. 85–568, title II, § 206","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 29, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/432"},"text":"72 Stat. 432","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/92/68/s7"},"text":"Pub. L. 92–68, § 7","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1971","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/85/177"},"text":"85 Stat. 177","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/106/391/tIII/s302/b"},"text":"Pub. L. 106–391, title III, § 302(b)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/114/1591"},"text":"114 Stat. 1591","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a)(2) and (b), the words “section 102(c) of this Act”, which appear in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/568/s206"},"text":"section 206 of Public Law 85–568","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/72/432"},"text":"72 Stat. 432","children":[],"tail":"), are treated as referring to section 102(d), rather than section 102(c), of "},{"tag":"ref","attrib":{"href":"/us/pl/85/568"},"text":"Public Law 85–568","children":[],"tail":" because of the redesignation done by section 110(a)(2) of the National Aeronautics and Space Administration Authorization Act, 1985 ("},{"tag":"ref","attrib":{"href":"/us/pl/98/361"},"text":"Public Law 98–361","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/426"},"text":"98 Stat. 426","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/85/568/s102/d"},"text":"Section 102(d) of Public Law 85–568","children":[],"tail":" is restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s20102/d"},"text":"section 20102(d) of title 51","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idebd292ea-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idebd292eb-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Certain Reporting Authority","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2004-03-05"},"text":"Mar. 5, 2004","children":[],"tail":", 69 F.R. 11489, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Administrator of the National Aeronautics and Space Administration","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":", United States Code, I hereby delegate to you the functions conferred upon the President by section 206 of the National Aeronautics and Space Act of 1958, as amended ([former] "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2476"},"text":"42 U.S.C. 2476","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s20116"},"text":"51 U.S.C. 20116","children":[],"tail":"], to provide the specified report to the Congress. Nothing in this delegation shall be construed to impair or otherwise affect the authority of the Director of the Office of Management and Budget with respect to budget, administrative, and legislative proposals."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"You are authorized and directed to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"George W. Bush.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
