{"tag":"section","attrib":{"id":"idebe5a56d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30302"},"text":null,"children":[{"tag":"num","attrib":{"value":"30302"},"text":"§ 30302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quality assurance personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebe5a56e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion of Administration Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person providing articles to the Administration under a contract entered into after ","children":[{"tag":"date","attrib":{"date":"1991-12-09"},"text":"December 9, 1991","children":[],"tail":", may not exclude Administration quality assurance personnel from work sites except as provided in a contract provision that has been submitted to Congress as provided in subsection (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebe5a56f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administration shall not enter into any contract which permits the exclusion of Administration quality assurance personnel from work sites unless the Administrator has submitted a copy of the provision permitting such exclusion to Congress at least 60 days before entering into the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebe5a570-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib"