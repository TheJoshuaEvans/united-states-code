{"tag":"section","attrib":{"id":"idebea6129-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30704"},"text":null,"children":[{"tag":"num","attrib":{"value":"30704"},"text":"§ 30704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offshore performance of contracts for the procurement of goods and services","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Administrator shall submit to Congress, not later than 120 days after the end of each fiscal year, a report on the contracts and subcontracts performed overseas and the amount of purchases directly or indirectly by the Administration from foreign entities in that fiscal year. The report shall separately indicate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebea612a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30704/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contracts and subcontracts and their dollar values for which the Administrator determines that essential goods or services under the contract are available only from a source outside the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebea612b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30704/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the items and their dollar values for which the Buy American Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s10a"},"text":"41 U.S.C. 10a","children":[],"tail":" et seq.) "},{"tag":"ref","attrib":{"idref":"fn002007"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002007"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" was waived pursuant to obligations of the United States under international agreements."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebea612c-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3371"},"text":"124 Stat. 3371","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebea612d-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebea612e-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebea612f-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30704","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s16823"},"text":"42 U.S.C. 16823","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/109/155/tVII/s709"},"text":"Pub. L. 109–155, title VII, § 709","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 30, 2005","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/119/2938"},"text":"119 Stat. 2938","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the matter before paragraph (1), the words “beginning with the first fiscal year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2005-12-30"},"text":"December 30, 2005","children":[],"tail":"]” are omitted as obsolete."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idebea6130-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idebea6131-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Buy American Act, referred to in par. (2), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-03-03/ch212"},"text":"act Mar. 3, 1933, ch. 212","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/1520"},"text":"47 Stat. 1520","children":[],"tail":", which was classified generally to sections 10a, 10b, and 10c of former Title 41, Public Contracts, and was substantially repealed and restated in chapter 83 (§ 8301 et seq.) of Title 41, Public Contracts, by "},{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":", §§ 3, 7(b), "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3677"},"text":"124 Stat. 3677","children":[],"tail":", 3855. For complete classification of this Act to the Code, see Short Title of 1933 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s101"},"text":"section 101 of Title 41","children":[],"tail":" and Tables. For disposition of sections of former Title 41, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s101"},"text":"section 101 of Title 41","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
