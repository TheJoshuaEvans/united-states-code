{"tag":"section","attrib":{"id":"idec06e926-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60126"},"text":null,"children":[{"tag":"num","attrib":{"value":"60126"},"text":"§ 60126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec06e927-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60126/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit a report to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Science, Space, and Technology of the House of Representatives not later than 180 days after the date of enactment of the U.S. Commercial Space Launch Competitiveness Act, and annually thereafter, on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec06e928-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60126/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary’s implementation of section 60121, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idec06e929-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60126/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of all applications received in the previous calendar year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec06e92a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60126/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of all applications that resulted in a license under section 60121;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec06e92b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60126/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of all applications denied and an explanation of why each application was denied, including any information relevant to the interagency adjudication process of a licensing request;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec06e92c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60126/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of all applications that required additional information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec06e92d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60126/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of all applications whose disposition exceeded the 120 day deadline established in section 60121(c), the total days overdue for each application that exceeded such deadline, and an explanation for the delay;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec06e92e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60126/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all notifications and information provided to the Secretary under section 60122; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec06e92f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60126/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of all actions taken by the Secretary under the administrative authority granted by paragraphs (4), (5), and (6) of section 60123(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec06e930-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60126/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Classified Annexes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each report under subsection (a) may include classified annexes as necessary to protect the disclosure of sensitive or classified information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec06e931-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60126/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The reporting requirement under this section terminates effective ","children":[{"tag":"date","attrib":{"date":"2020-09-30"},"text":"September 30, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec06e932-3a70-11f1-9081-fe88c1712d53"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/90/tII/s201/a"},"text":"Pub. L. 114–90, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/719"},"text":"129 Stat. 719","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec06e933-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idec06e934-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idec06e935-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the U.S. Commercial Space Launch Competitiveness Act, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/90"},"text":"Pub. L. 114–90","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
