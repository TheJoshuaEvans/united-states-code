{"tag":"section","attrib":{"id":"idebd292d9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20115"},"text":null,"children":[{"tag":"num","attrib":{"value":"20115"},"text":"§ 20115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administration, under the foreign policy guidance of the President, may engage in a program of international cooperation in work done pursuant to this chapter, and in the peaceful application of the results thereof, pursuant to agreements made by the President with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idebd292da-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3337"},"text":"124 Stat. 3337","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebd292db-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebd292dc-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebd292dd-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20115","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s2475"},"text":"42 U.S.C. 2475","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/85/568/tII/s205"},"text":"Pub. L. 85–568, title II, § 205","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 29, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/432"},"text":"72 Stat. 432","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idebd292de-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idebd292df-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Authority","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"1995-10-10"},"text":"Oct. 10, 1995","children":[],"tail":", 60 F.R. 53251, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Administrator of the National and Aeronautics and Space Administration","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, and in order to facilitate the efficient operations of the aeronautical and space programs of the National Aeronautics and Space Administration (NASA), it is hereby ordered as follows:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The authority conferred upon the President by the Constitution and the laws of the United States of America to executive mutual waivers of claims of liability on behalf of the United States for damages arising out of cooperative activities is hereby delegated to the Administrator of NASA for agreements with foreign governments and their agents regarding aeronautical, science, and space activities that are executed pursuant to the authority granted NASA by the National Aeronautics and Space Act of 1958, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/568"},"text":"Public Law 85–568","children":[],"tail":", as amended [see "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s20101"},"text":"51 U.S.C. 20101","children":[],"tail":" et seq.]. All such agreements shall be subject to coordination with and the concurrence of the Department of State to the extent provided by applicable law, regulations, and procedures. All such waivers of liability entered into prior to the date of this memorandum are hereby ratified."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"You are authorized and directed to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"William J. Clinton.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
