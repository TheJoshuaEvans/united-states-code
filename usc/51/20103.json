{"tag":"section","attrib":{"id":"idebcdb079-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20103"},"text":null,"children":[{"tag":"num","attrib":{"value":"20103"},"text":"§ 20103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebcdb07a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20103/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aeronautical and space activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “aeronautical and space activities” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebcdb07b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20103/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research into, and the solution of, problems of flight within and outside the Earth’s atmosphere;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebcdb07c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20103/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development, construction, testing, and operation for research purposes of aeronautical and space vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebcdb07d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20103/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operation of a space transportation system including the space shuttle, upper stages, space platforms, and related equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebcdb07e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20103/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other activities as may be required for the exploration of space.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebcdb07f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20103/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aeronautical and space vehicles","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “aeronautical and space vehicles” means aircraft, missiles, satellites, and other space vehicles, manned and unmanned, together with related equipment, devices, components, and parts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebcdb080-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3332"},"text":"124 Stat. 3332","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebcdb081-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebcdb082-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebcdb083-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"t