{"tag":"section","attrib":{"id":"idec1086d3-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70905"},"text":null,"children":[{"tag":"num","attrib":{"value":"70905"},"text":"§ 70905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National laboratory designation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec1086d4-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of United States Segment of the International Space Station","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section the term “United States segment of the International Space Station” means those elements of the International Space Station manufactured—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec1086d5-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70905/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec1086d6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70905/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the United States by other nations in exchange for funds or launch services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec1086d7-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To further the policy described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s70501/a"},"text":"section 70501(a) of this title","children":[],"tail":", the United States segment of the International Space Station is hereby designated a national laboratory."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec1086d8-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Management.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idec1086d9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70905/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Partnerships","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall seek to increase the utilization of the International Space Station by other Federal entities and the private sector through partnerships, cost-sharing agreements, and other arrangements that would supplement Administration funding of the International Space Station.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec1086da-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70905/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may enter into a contract with a nongovernmental entity to operate the International Space Station national laboratory, subject to all applicable Federal laws and regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec1086db-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3437"},"text":"124 Stat. 3437","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec1086dc-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idec1086dd-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idec1086de-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[