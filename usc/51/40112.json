{"tag":"section","attrib":{"id":"idebecd1e4-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112"},"text":null,"children":[{"tag":"num","attrib":{"value":"40112"},"text":"§ 40112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and technology programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebecd1e5-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supersonic Transport Research and Development","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may establish an initiative with the objective of developing and demonstrating, in a relevant environment, airframe and propulsion technologies to enable efficient, economical overland flight of supersonic civil transport aircraft with no significant impact on the environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebecd1e6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Research and Development Initiative on Reduction of Greenhouse Gas and Noise Emissions From Aircraft.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebecd1e7-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall establish an initiative to research, develop, and demonstrate new technologies and concepts—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebecd1e8-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce greenhouse gas emissions from aviation, including carbon dioxide, nitrogen oxides, other greenhouse gases, water vapor, black carbon and sulfate aerosols, and increased cloudiness due to contrail formation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebecd1e9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce aviation noise emissions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebecd1ea-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enable associated aircraft performance characteristics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebecd1eb-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Goals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goals of the initiative required by paragraph (1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebecd1ec-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure United States leadership in research and technology innovation leading to substantial reductions in aviation noise and greenhouse gas emissions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebecd1ed-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance and expand basic research, and the translation of basic research into applications, that may lead to transformational advances in reducing aviation noise and greenhouse gas emissions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebecd1ee-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accelerate research and development that contributes to maturing new technologies for reducing aircraft noise and greenhouse gas emissions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebecd1ef-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain and disseminate associated testing and performance data that facilitates the incorporation of new technologies into commercial aircraft development as soon as practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebecd1f0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Objectives","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The objectives of the initiative established under paragraph (1) and the goals described in paragraph (2) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebecd1f1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as soon as practicable, a reduction of greenhouse gas emissions from new aircraft by at least 50 percent, as compared to the highest-performing aircraft technologies in service as of ","children":[{"tag":"date","attrib":{"date":"2021-12-31"},"text":"December 31, 2021","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebecd1f2-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" noise levels from aircraft throughout all phases of flight that do not exceed ambient noise levels in the absence of flight operations in the vicinity of the flight route;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebecd1f3-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" net-zero greenhouse gas emissions from aircraft by 2050; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebecd1f4-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" demonstration of new technologies developed pursuant to such initiative on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idebecd1f5-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/b/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regional aircraft intended to enter into service by 2030; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idebecd1f6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/b/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" single-aisle aircraft designed to accommodate more than 125 passengers intended to enter into service by 2040.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebecd1f7-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rotorcraft and Other Runway-Independent Air Vehicles","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may establish a rotorcraft and other runway-independent air vehicles initiative with the objective of developing and demonstrating improved safety, noise, and environmental impact in a relevant environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebecd1f8-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hypersonics Research","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may establish a hypersonics research program with the objective of exploring the science and technology of hypersonic flight using air-breathing propulsion concepts, through a mix of theoretical work, basic and applied research, and development of flight research demonstration vehicles. The program may also include the transition to the hypersonic range of Mach 3 to Mach 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebecd1f9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revolutionary Aeronautical Concepts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may establish a research program which covers a unique range of subsonic, fixed wing vehicles and propulsion concepts. This research is intended to push technology barriers beyond current subsonic technology. Propulsion concepts include advanced materials, morphing engines, hybrid engines, and fuel cells.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebecd1fa-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fuel Cell-Powered Aircraft Research.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebecd1fb-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Objective","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may establish a fuel cell-powered aircraft research program whose objective shall be to develop and test concepts to enable a hydrogen fuel cell-powered aircraft that would have no hydrocarbon or nitrogen oxide emissions into the environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebecd1fc-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approach","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may establish a program of competitively awarded grants available to teams of researchers that may include the participation of individuals from universities, industry, and government for the conduct of this research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebecd1fd-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mars Aircraft Research.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebecd1fe-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Objective","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may establish a Mars Aircraft project whose objective shall be to develop and test concepts for an uncrewed aircraft that could operate for sustained periods in the atmosphere of Mars.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebecd1ff-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40112/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approach","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may establish a program of competitively awarded grants available to teams of researchers that may include the participation of individuals from universities, industry, and government for the conduct of this research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebecd200-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3379"},"text":"124 Stat. 3379","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVII/s10833/a"},"text":"Pub. L. 117–167, div. B, title VII, § 10833(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1749"},"text":"136 Stat. 1749","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebecd201-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebecd202-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebecd203-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40112(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s16722/b"},"text":"42 U.S.C. 16722(b)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/109/155/tIV/s422/b"},"text":"Pub. L. 109–155, title IV, § 422(b)","children":[],"tail":"–(g), "},{"tag":"html:span","attrib":{},"text":"Dec. 30, 2005","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/119/2925"},"text":"119 Stat. 2925","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40112(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s16722/c"},"text":"42 U.S.C. 16722(c)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40112(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s16722/d"},"text":"42 U.S.C. 16722(d)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40112(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s16722/e"},"text":"42 U.S.C. 16722(e)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40112(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s16722/f"},"text":"42 U.S.C. 16722(f)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40112(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s16722/g"},"text":"42 U.S.C. 16722(g)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idebecd204-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idebecd205-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsecs. (b) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":" added subsec. (b) and redesignated former subsecs. (b) to (f) as (c) to (g), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idebecd206-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idebecd207-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Technology Focus Areas, Implementation, and Annual Report for the Research and Development Initiative","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVII/s10833/b"},"text":"Pub. L. 117–167, div. B, title VII, § 10833(b)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1750"},"text":"136 Stat. 1750","children":[],"tail":", 1751, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/167/dB/tVII/s10833/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technology Focus Areas","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the research and development initiative established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s40112/b"},"text":"section 40112(b) of title 51","children":[],"tail":", United States Code, the Administrator [of the National Aeronautics and Space Administration] shall advance research, development, and demonstration projects on promising technologies such as—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced subsonic propulsion technology, design, and integration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electric and hybrid-electric propulsion, including battery electric and hydrogen fuel cell electric systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" airframe concepts and configurations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analysis of technology options, including cost-benefit analysis of greenhouse gas and noise emissions reduction technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analytical tools for system-level and system-of-systems-level modeling and integration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" airspace operations improvements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" noise emissions reduction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other effort, as determined by the [National Aeronautics and Space] Administration, that contributes to a sustainable future for aviation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In implementing the initiative established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s40112/b"},"text":"section 40112(b) of title 51","children":[],"tail":", United States Code, the Administrator shall, to the extent practicable—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that testing and performance data integrates the results of community acceptance surveys conducted by the Federal Aviation Administration and other relevant studies, including studies on the impacts of new noise effects from novel propulsion systems and from airspace operations changes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide testing and performance data on the technologies described in subsection (b) of this section to the Administrator of the Federal Aviation Administration to facilitate the work of the Federal Aviation Administration in identifying new requirements for policy, infrastructure, and administrative capacity necessary to enable the safe integration of such technologies on aircraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursue partnerships with organizations, current commercial production aircraft providers, academic institutions, small businesses, and new entrants, including partnerships to advance research and development activities related to both regional aircraft and aircraft designed to accommodate more than 125 passengers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include universities, academic institutions, and other research organizations in the partnerships described in paragraph (3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand basic research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure equity in research sponsorship of, and partnership opportunities with, underrepresented students, faculty, and minority-serving-institutions [sic];","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue to coordinate with the Secretary of Energy on battery technology research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available the research and development carried out under the initiative established under subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s40112"},"text":"section 40112 of title 51","children":[],"tail":", United States Code, to help enable an industry-wide shift toward aircraft concepts that reduce greenhouse gas emissions and aircraft noise to achieve the goals and objectives under paragraphs (2) and (3) of that subsection; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"“(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue to support research, development, and demonstration of aircraft concepts, including systems architecture, materials and components, integration of systems and airframe structures, human factors, airspace planning and operations, and the integration of related advanced technologies and concepts, with the goal of carrying out test flights with integrated subsystems by 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":"], and annually thereafter, the Administrator shall submit to the appropriate committees of Congress [Committee on Commerce, Science, and Transportation of the Senate and Committee on Science, Space, and Technology of the House of Representatives] a report on the progress of the efforts carried out under the initiative established under subsection (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s40112"},"text":"section 40112 of title 51","children":[],"tail":", United States Code, including—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of progress on such initiative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an updated, anticipated timeframe for readiness of technologies and aircraft to be adopted by industry with the emissions reduction levels directed under that subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of fundamental aeronautics research activities contributing to achieving the goals and objectives of such initiative, as described in paragraphs (2) and (3) of that subsection, and a description of any obstacles to achieving such goals and objectives.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “minority-serving institution” as used in section 10833(b)–(d) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18901"},"text":"section 18901 of Title 42","children":[],"tail":", The Public Health and Welfare.]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idebecd208-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"National Aero-Space Plane Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/611/tI/s116"},"text":"Pub. L. 101–611, title I, § 116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3202"},"text":"104 Stat. 3202","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/611/tI/s116"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Aero-Space Plane Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense (hereafter in this section referred to as the ‘Secretary’) and the Administrator shall jointly pursue on a high priority basis a National Aero-Space Plane program whose objective shall be the development and demonstration, by 1997, of a primarily air breathing single-stage-to-orbit and long range hypersonic cruise research flight vehicle. The program shall be a research program, and to the extent practicable technological information developed shall be transferred to the military and to the domestic civil aviation and other private industries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Management Plan.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary and the Adminstrator [sic] shall jointly develop a management plan for the program established under subsection (a), which shall include goals, major tasks, anticipated schedules, organizational structure, funding profiles, details of the respective responsibilities of the Secretary and the Administrator, and resource procurement strategies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The management plan developed pursuant to paragraph (1) shall be submitted to the Congress within 120 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/611/tI/s127"},"text":"Pub. L. 101–611, title I, § 127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3205"},"text":"104 Stat. 3205","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/611/tI/s127"},"text":"“For purposes of this title [see Tables for classification], the term ‘Administrator’ means the Administrator of the National Aeronautics and Space Administration.”","children":[],"tail":"\n]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
