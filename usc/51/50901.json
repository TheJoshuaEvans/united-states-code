5-year extension of the excess third party claims payment provision of [former] chapter 701 of title 49, United States Code [now ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s50901"},"text":"51 U.S.C. 50901","children":[],"tail":" et seq.] (Commercial Space Launch Activities), will have a beneficial impact on the international competitiveness of the United States space transportation industry;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" space transportation may evolve into airplane-style operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the next 3 years the Federal Government and the private sector should analyze the liability risk-sharing regime to determine its appropriateness and effectiveness, and, if needed, develop and propose a new regime to Congress at least 2 years prior to the expiration of the extension contained in this Act [see Tables for classification];","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the areas of responsibility of the Office of the Associate Administrator for Commercial Space Transportation have significantly increased as a result of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rapidly expanding commercial space transportation industry and associated government licensing requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulatory activity as a result of the emerging commercial reusable launch vehicle industry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the increased regulatory activity associated with commercial operation of launch and reentry sites; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the Associate Administrator for Commercial Space Transportation should continue to limit its promotional activities to those which support its regulatory mission.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
