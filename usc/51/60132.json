{"tag":"section","attrib":{"id":"idec06e946-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60132"},"text":null,"children":[{"tag":"num","attrib":{"value":"60132"},"text":"§ 60132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of federally gathered unenhanced data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec06e947-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60132/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All unenhanced land remote sensing data gathered and owned by the United States Government, including unenhanced data gathered under the technology demonstration program carried out pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s60133"},"text":"section 60133 of this title","children":[],"tail":", shall be made available to users in a timely fashion."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec06e948-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60132/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protection for Commercial Data Distributor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall seek to ensure that unenhanced data gathered under the technology demonstration program carried out pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s60133"},"text":"section 60133 of this title","children":[],"tail":" shall, to the extent practicable, be made available on terms that would not adversely affect the commercial market for unenhanced data gathered by the Landsat 6 spacecraft."}],"tail":"\n"}]