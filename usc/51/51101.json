{"tag":"section","attrib":{"id":"idec022f09-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51101"},"text":null,"children":[{"tag":"num","attrib":{"value":"51101"},"text":"§ 51101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec022f0a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s50501"},"text":"section 50501 of this title","children":[],"tail":" apply."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec022f0b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “commercial space transportation infrastructure development” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idec022f0c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51101/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction, improvement, design, and engineering of space transportation infrastructure in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022f0d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51101/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical studies to define how new or enhanced space transportation infrastructure can best meet the needs of the United States commercial space transportation industry.","c