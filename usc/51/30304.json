{"tag":"section","attrib":{"id":"idebe5a57d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30304"},"text":null,"children":[{"tag":"num","attrib":{"value":"30304"},"text":"§ 30304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award of contracts to small businesses and disadvantaged individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator shall annually establish a goal of at least 8 percent of the total value of prime and subcontracts awarded in support of authorized programs, including the space station by the time operational status is obtained, which funds will be made available to small business concerns or other organizations owned or controlled by socially and economically disadvantaged individuals (within the meaning of paragraphs (5) and (6) of section 8(a) of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/a"},"text":"15 U.S.C. 637(a)","children":[],"tail":")), including Historically Black Colleges and Universities that are part B institutions (as defined in section 322(2) of the Higher Education Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1061/2"},"text":"20 U.S.C. 1061(2)","children":[],"tail":")), Hispanic-serving institutions (as defined in section 502(a)(5) of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1101a/a/5"},"text":"20 U.S.C. 1101a(a)(5)","children":[],"tail":")), Tribal Colleges or Universities (as defined in section 316(b)(3) of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c/b/3"},"text":"20 U.S.C. 1059c(b)(3)","children":[],"tail":")), Alaska Native-serving institutions (as defined in section 317(b)(2) of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059d/b/2"},"text":"20 U.S.C. 1059d(b)(2)","children":[],"tail":")), Native Hawaiian-serving institutions (as defined in section 317(b)(4) of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059d/b/4"},"text":"20 U.S.C. 1059d(b)(4)","children":[],"tail":")), and minority educational institutions (as defined by the Secretary of Education pursuant to the General Education Provisions Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1221"},"text":"20 U.S.C. 1221","children":[],"tail":" et seq.))."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idebe5a57e-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3364"},"text":"124 Stat. 3364","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebe5a57f-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebe5a580-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebe5a581-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}