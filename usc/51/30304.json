"attrib":{"href":"/us/stat/119/2932"},"text":"119 Stat. 2932","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “Alaska” is substituted for “Alaskan” in the phrase “Alaska Native-serving institutions (as defined in section 317(b)(2) of that Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059d/b/2"},"text":"20 U.S.C. 1059d(b)(2)","children":[],"tail":"))” for consistency with the term defined in section 317(b)(2) of the Higher Education Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059d/b/2"},"text":"20 U.S.C. 1059d(b)(2)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idebe5a582-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idebe5a583-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Education Provisions Act, referred to in text, is title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/247"},"text":"Pub. L. 90–247","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/814"},"text":"81 Stat. 814","children":[],"tail":", which is classified generally to chapter 31 (§ 1221 et seq.) of Title 20, Education. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1221"},"text":"section 1221 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
