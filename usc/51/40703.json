{"tag":"section","attrib":{"id":"idebf18cfd-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40703"},"text":null,"children":[{"tag":"num","attrib":{"value":"40703"},"text":"§ 40703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research alignment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to pursuing the research and development initiative described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s40702"},"text":"section 40702 of this title","children":[],"tail":", the Administrator shall, to the maximum extent practicable within available funding, align the fundamental aeronautics research program to address high priority technology challenges of the National Academies’ Decadal Survey of Civil Aeronautics, and shall work to increase the degree of involvement of external organizations, and especially of universities, in the fundamental aeronautics research program."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idebf18cfe-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3390"},"text":"124 Stat. 3390","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebf18cff-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebf18d00-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebf18d01-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}