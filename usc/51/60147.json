{"tag":"section","attrib":{"id":"idec06e999-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60147"},"text":null,"children":[{"tag":"num","attrib":{"value":"60147"},"text":"§ 60147.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec06e99a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60147/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation With Secretary of Defense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary and the Landsat Program Management shall consult with the Secretary of Defense on all matters under this chapter affecting national security. The Secretary of Defense shall be responsible for determining those conditions, consistent with this chapter, necessary to meet national security concerns of the United States and for notifying the Secretary and the Landsat Program Management promptly of such conditions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec06e99b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60147/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation With Secretary of State.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idec06e99c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60147/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary and the Landsat Program Management shall consult with the Secretary of State on all matters under this chapter affecting international obligations. The Secretary of State shall be responsible for determining those conditions, consistent with this chapter, necessary to meet international obligations and policies of the United States and for notifying promptly the Secretary and the Landsat Program Management of such conditions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec06e99d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60147/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"International aid","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Appropriate United States Government agencies are authorized and encouraged to provide remote sensing data, technology, and training to developing nations as a component of programs of international aid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec06e99e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60147/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting discriminatory distribution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of State shall promptly report to the Secretary and Landsat Program Management any instances outside the United States of discriminatory distribution of Landsat data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec06e99f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60147/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Status Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Landsat Program Management shall, as often as necessary, provide to Congress complete and updated information about the status of ongoing operations of the Landsat system, including timely notification of decisions made with respect to the Landsat system in order to meet national security concerns and international obligations and policies of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec06e9a0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60147/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If, as a result of technical modifications imposed on a licensee under subchapter III on the basis of national security concerns, the Secretary, in consultation with the Secretary of Defense or with other Federal agencies, determines that additional costs will be incurred by the licensee, or that past development costs (including the cost of capital) will not be recovered by the licensee, the Secretary may require the agency or agencies requesting such technical modifications to reimburse the licensee for such additional or development costs, but not for anticipated profits. Reimbursements may cover costs associated with required changes in system performance, but not costs ordinarily associated with doing business abroad.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec06e9a1-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3421"},"text":"124 Stat. 3421","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec06e9a2-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idec06e9a3-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idec06e9a4-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60147","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t15/s5657"},"text":"15 U.S.C. 5657","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/102/555/tV/s507"},"text":"Pub. L. 102–555, title V, § 507","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/4178"},"text":"106 Stat. 4178","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
