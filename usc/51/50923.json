{"tag":"section","attrib":{"id":"idec022edf-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50923"},"text":null,"children":[{"tag":"num","attrib":{"value":"50923"},"text":"§ 50923.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall submit to Congress an annual report to accompany the President’s budget request that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec022ee0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50923/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes all activities undertaken under this chapter, including a description of the process for the application for and approval of licenses under this chapter and recommendations for legislation that may further commercial launches and reentries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec022ee1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50923/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviews the performance of the regulatory activities and the effectiveness of the Office of Commercial Space Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec022ee2-3a70-11f1-9081-fe88c1712d53"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/303/tI/s102/a/16"},"text":"Pub. L. 105–303, title I, § 102(a)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2851"},"text":"112 Stat. 2851","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s70121"},"text":"§ 70121 of title 49","children":[],"tail":";