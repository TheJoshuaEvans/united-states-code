{"tag":"section","attrib":{"id":"idec10870f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s71103"},"text":null,"children":[{"tag":"num","attrib":{"value":"71103"},"text":"§ 71103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Developing policy and recommending responsible Federal agency","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Within 2 years after ","children":[{"tag":"date","attrib":{"date":"2008-10-15"},"text":"October 15, 2008","children":[],"tail":", the Director of the Office of Science and Technology Policy shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idec108710-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s71103/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a policy for notifying Federal agencies and relevant emergency response institutions of an impending near-Earth object threat, if near-term public safety is at risk; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec108711-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s71103/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommend a Federal agency or agencies to be responsible for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idec108712-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s71103/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting the United States from a near-Earth object that is expected to collide with Earth; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec108713-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s71103/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing a deflection campaign, in consultation with international bodies, should one be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec108714-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3439"},"text":"124 Stat. 3439","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec108715-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idec108716-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idec108717-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":n