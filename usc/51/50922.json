{"tag":"section","attrib":{"id":"idec022ec6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50922"},"text":null,"children":[{"tag":"num","attrib":{"value":"50922"},"text":"§ 50922.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec022ec7-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50922/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation, within 9 months after the date of the enactment of this section, shall issue regulations to carry out this chapter that include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec022ec8-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50922/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidelines for industry and State governments to obtain sufficient insurance coverage for potential damages to third parties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec022ec9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50922/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for requesting and obtaining licenses to launch a commercial launch vehicle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec022eca-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50922/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for requesting and obtaining operator licenses for launch;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec022ecb-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50922/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for requesting and obtaining launch site operator licenses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec022ecc-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50922/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for the application of government indemnification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec022ecd-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50922/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reentry","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation, within 6 months after the date of the enactment of this section, shall issue a notice of proposed rulemaking to carry out this chapter that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec022ece-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50922/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for requesting and obtaining licenses to reenter a reentry vehicle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec022ecf-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50922/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for requesting and obtaining operator licenses for reentry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec022ed0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50922/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for requesting and obtaining reentry site operator licenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec022ed1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50922/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amendments","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idec022ed2-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50922/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 12 months after the date of enactment of the Commercial Space Launch Amendments Act of 2004, the Secretary shall publish proposed regulations to carry out that Act, including regulations relating to crew, space flight participants, and permits for launch or reentry of reusable suborbital rockets. Not later than 18 months after such date of enactment, the Secretary shall issue final regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec022ed3-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50922/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idec022ed4-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50922/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Starting 3 years after the date of enactment of the Commercial Space Launch Amendments Act of 2004, the Secretary may issue final regulations changing the definition of suborbital rocket under this chapter. No such regulation may take effect until 180 days after the Secretary has submitted the regulation to the Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022ed5-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50922/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may issue regulations under this paragraph only if the Secretary has determined that the definition in section 50902 does not describe, or will not continue to describe, all appropriate vehicles and only those vehicles. In making that determination, the Secretary shall take into account the evolving nature of the commercial space launch industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec022ed6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50922/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idec022ed7-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50922/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Licenses for the launch or reentry of launch vehicles or reentry vehicles with human beings on board and permits may be issued by the Secretary prior to the issuance of the regulations described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec022ed8-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50922/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As soon as practicable after the date of enactment of the Commercial Space Launch Amendments Act of 2004, the Secretary shall issue guidelines or advisory circulars to guide the implementation of that Act until regulations are issued.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec022ed9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50922/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding paragraphs (1) and (2), no licenses for the launch or reentry of launch vehicles or reentry vehicles with human beings on board or permits may be issued starting three years after the date of enactment of the Commercial Space Launch Amendments Act of 2004 unless the final regulations described in subsection (c) have been issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec022eda-3a70-11f1-9081-fe88c1712d53"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/303/tI/s102/a/16"},"text":"Pub. L. 105–303, title I, § 102(a)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2850"},"text":"112 Stat. 2850","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s70120"},"text":"§ 70120 of title 49","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/492/s2/c/25"},"text":"Pub. L. 108–492, § 2(c)(25)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3981"},"text":"118 Stat. 3981","children":[],"tail":"; renumbered § 70120 then "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s50922"},"text":"§ 50922 of title 51","children":[],"tail":" and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/314/s4/d/2"},"text":"Pub. L. 111–314, § 4(d)(2)","children":[],"tail":", (3)(V), (5)(U), "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3440-3442"},"text":"124 Stat. 3440–3442","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec022edb-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idec022edc-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idec022edd-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsecs. (a) and (b), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/303"},"text":"Pub. L. 105–303","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Commercial Space Launch Amendments Act of 2004, referred to in subsecs. (c) and (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/492"},"text":"Pub. L. 108–492","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3974"},"text":"118 Stat. 3974","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2004 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idec022ede-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s4/d/2"},"text":"Pub. L. 111–314, § 4(d)(2)","children":[],"tail":", (3)(V), successively renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s70120"},"text":"section 70120 of title 49","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s70120"},"text":"section 70120 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s4/d/5/U"},"text":"Pub. L. 111–314, § 4(d)(5)(U)","children":[],"tail":", substituted “section 50902” for “section 70102”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/492"},"text":"Pub. L. 108–492","children":[],"tail":" added subsecs. (c) and (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
