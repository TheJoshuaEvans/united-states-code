{"tag":"section","attrib":{"id":"idebe7eff9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701"},"text":null,"children":[{"tag":"num","attrib":{"value":"30701"},"text":"§ 30701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitiveness and international cooperation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebe7effa-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebe7effb-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Solicitation of comment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As part of the evaluation of the costs and benefits of entering into an obligation to conduct a space mission in which a foreign entity will participate as a supplier of the spacecraft, spacecraft system, or launch system, the Administrator shall solicit comment on the potential impact of such participation through notice published in Commerce Business Daily at least 45 days before entering into such an obligation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebe7effc-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreements with people’s republic of china","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall certify to Congress at least 15 days in advance of any cooperative agreement with the People’s Republic of China, or any company owned by the People’s Republic of China or incorporated under the laws of the People’s Republic of China, involving spacecraft, spacecraft systems, launch systems, or scientific or technical information, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebe7effd-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agreement is not detrimental to the United States space launch industry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebe7effe-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agreement, including any indirect technical benefit that could be derived from the agreement, will not improve the missile or space launch capabilities of the People’s Republic of China.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebe7efff-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual audit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Inspector General of the Administration, in consultation with appropriate agencies, shall conduct an annual audit of the policies and procedures of the Administration with respect to the export of technologies and the transfer of scientific and technical information, to assess the extent to which the Administration is carrying out its activities in compliance with Federal export control laws and with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebe7f000-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Interests.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebe7f001-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of united states commercial provider","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “United States commercial provider” means a commercial provider (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s30308/a"},"text":"section 30308(a) of this title","children":[],"tail":"), organized under the laws of the United States or of a State (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s30308/a"},"text":"section 30308(a) of this title","children":[],"tail":"), which is—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebe7f002-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 50 percent owned by United States nationals; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebe7f003-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a subsidiary of a foreign company and the Secretary of Commerce finds that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idebe7f004-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such subsidiary has in the past evidenced a substantial commitment to the United States market through—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idebe7f005-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/b/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investments in the United States in long-term research, development, and manufacturing (including the manufacture of major components and subassemblies); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idebe7f006-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/b/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant contributions to employment in the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idebe7f007-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the country or countries in which such foreign company is incorporated or organized, and, if appropriate, in which it principally conducts its business, affords reciprocal treatment to companies described in subparagraph (A) comparable to that afforded to such foreign company’s subsidiary in the United States, as evidenced by—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idebe7f008-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/b/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing comparable opportunities for companies described in subparagraph (A) to participate in Government sponsored research and development similar to that authorized under this section, section 30307, 30308, 30309, or 30702 of this title, or the National Aeronautics and Space Administration Authorization Act of 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/391"},"text":"Public Law 106–391","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1577"},"text":"114 Stat. 1577","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idebe7f009-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/b/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing no barriers to companies described in subparagraph (A) with respect to local investment opportunities that are not provided to foreign companies in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idebe7f00a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/b/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing adequate and effective protection for the intellectual property rights of companies described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebe7f00b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before entering into an obligation described in subsection (a), the Administrator shall consider the national interests of the United States described in paragraph (3) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebe7f00c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Description of national interests","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"International cooperation in space exploration and science activities most effectively serves the United States national interest when it—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebe7f00d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idebe7f00e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduces the cost of undertaking missions the United States Government would pursue unilaterally;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idebe7f00f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enables the United States to pursue missions that it could not otherwise afford to pursue unilaterally; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idebe7f010-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhances United States capabilities to use and develop space for the benefit of United States citizens;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebe7f011-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is undertaken in a manner that is sensitive to the desire of United States commercial providers to develop or explore space commercially;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebe7f012-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with the need for Federal agencies to use space to complete their missions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebe7f013-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30701/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is carried out in a manner consistent with United States export control laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebe7f014-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3369"},"text":"124 Stat. 3369","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebe7f015-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebe7f016-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebe7f017-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30701(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s2475a/a"},"text":"42 U.S.C. 2475a(a)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/106/391/tI/s126"},"text":"Pub. L. 106–391, title I, § 126","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/114/1585"},"text":"114 Stat. 1585","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30701(b)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"(no source)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30701(b)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s2475a/b"},"text":"42 U.S.C. 2475a(b)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30701(b)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"(no source)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the definition of “United States commercial provider” is added to carry forward the appropriate definition from section 3 of the National Aeronautics and Space Administration Authorization Act of 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/391"},"text":"Public Law 106–391","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1580"},"text":"114 Stat. 1580","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3), the description of national interests of the United States is added to carry forward the appropriate description of national interests of the United States from section 2(6) of the National Aeronautics and Space Administration Authorization Act of 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/391"},"text":"Public Law 106–391","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1578"},"text":"114 Stat. 1578","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idebea6118-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idebea6119-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Aeronautics and Space Administration Authorization Act of 2000, referred to in subsec. (b)(1)(B)(ii)(I), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/391"},"text":"Pub. L. 106–391","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1577"},"text":"114 Stat. 1577","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idebea611a-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idebea611b-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limitation on International Agreements Concerning Outer Space Activities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tIX/s913/a"},"text":"Pub. L. 112–239, div. A, title IX, § 913(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1874"},"text":"126 Stat. 1874","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/239/dA/tIX/s913/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the United States becomes a signatory to a non-legally binding international agreement concerning an International Code of Conduct for Outer Space Activities or any similar agreement, at the same time as the United States becomes such a signatory—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President shall submit to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives], the Permanent Select Committee on Intelligence of the House of Representatives, and the Select Committee on Intelligence of the Senate a certification that such agreement has no legally-binding effect or basis for limiting the activities of the United States in outer space; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense, the Chairman of the Joint Chiefs of Staff, and the Director of National Intelligence shall jointly submit to the congressional defense committees a certification that such agreement will be equitable, enhance national security, and have no militarily significant impact on the ability of the United States to conduct military or intelligence activities in space.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefings and Notifications Required.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restatement of policy formulation under the arms control and disarmament act with respect to outer space","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No action shall be taken that would obligate the United States to reduce or limit the Armed Forces or armaments of the United States in outer space in a militarily significant manner, except pursuant to the treaty-making power of the President set forth in Article II, Section 2, Clause II of the Constitution or unless authorized by the enactment of further affirmative legislation by the Congress of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefings.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense, the Secretary of State, and the Director of National Intelligence shall jointly provide to the covered congressional committees regular, detailed updates on the negotiation of a non-legally binding international agreement concerning an International Code of Conduct for Outer Space Activities or any similar agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirement to provide regular briefings under subparagraph (A) shall terminate on the date on which the United States becomes a signatory to an agreement referred to in subparagraph (A), or on the date on which the President certifies to Congress that the United States is no longer negotiating an agreement referred to in subparagraph (A), whichever is earlier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notifications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the United States becomes a signatory to a non-legally binding international agreement concerning an International Code of Conduct for Outer Space Activities or any similar agreement, not less than 60 days prior to any action that will obligate the United States to reduce or limit the Armed Forces or armaments or activities of the United States in outer space, the head of each Department or agency of the Federal Government that is affected by such action shall submit to Congress notice of such action and the effect of such action on such Department or agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term ‘covered congressional committees’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services, the Committee on Foreign Affairs, and the Permanent Select Committee on Intelligence of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services, the Committee on Foreign Relations, and the Select Committee on Intelligence of the Senate.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
