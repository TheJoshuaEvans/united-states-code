{"tag":"section","attrib":{"id":"idec022ee6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924"},"text":null,"children":[{"tag":"num","attrib":{"value":"50924"},"text":"§ 50924.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Space launch and reentry licensing and permitting user fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec022ee7-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idec022ee8-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall impose a fee, which shall be deposited in the account established under subsection (b), on each launch or reentry carried out under a license or permit issued under section 50904 during 2026 or a subsequent year, in an amount equal to the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idec022ee9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount specified in paragraph (2) for the year involved per pound of the weight of the payload; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022eea-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount specified in paragraph (3) for the year involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec022eeb-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Paragraph (2) specified amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount specified in this paragraph is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idec022eec-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for 2026, $0.25;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022eed-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for 2027, $0.35;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022eee-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for 2028, $0.50;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022eef-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for 2029, $0.60;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022ef0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for 2030, $0.75;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022ef1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for 2031, $1;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022ef2-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for 2032, $1.25;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022ef3-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for 2033, $1.50; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022ef4-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for 2034 and each subsequent year, the amount specified in this paragraph for the previous year increased by the percentage increase in the consumer price index for all urban consumers (all items; United States city average) over the previous year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec022ef5-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Paragraph (3) specified amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount specified in this paragraph is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idec022ef6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for 2026, $30,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022ef7-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for 2027, $40,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022ef8-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for 2028, $50,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022ef9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for 2029, $75,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022efa-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for 2030, $100,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022efb-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for 2031, $125,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022efc-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for 2032, $170,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022efd-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for 2033, $200,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec022efe-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/a/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for 2034 and each subsequent year, the amount specified in this paragraph for the previous year increased by the percentage increase in the consumer price index for all urban consumers (all items; United States city average) over the previous year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec022eff-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50924/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Office of Commercial Space Transportation Launch and Reentry Licensing and Permitting Fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established in the Treasury of the United States a separate account, which shall be known as the “Office of Commercial Space Transportation Launch and Reentry Licensing and Permitting Fund”, for the purposes of expenses of the Office of Commercial Space Transportation of the Federal Aviation Administration and to carry out section 630(b) of the FAA Reauthorization Act of 2024. 70 percent of the amounts deposited into the fund shall be available for such purposes and shall be available without further appropriation and without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec022f00-3a70-11f1-9081-fe88c1712d53"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tIV/s40004/a"},"text":"Pub. L. 119–21, title IV, § 40004(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/132"},"text":"139 Stat. 132","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec022f01-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idec022f02-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idec022f03-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 630(b) of the FAA Reauthorization Act of 2024, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s630/b"},"text":"section 630(b) of Pub. L. 118–63","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1245"},"text":"138 Stat. 1245","children":[],"tail":", which relates to funds for developing technology for space launch and reentry reintegration and is not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
