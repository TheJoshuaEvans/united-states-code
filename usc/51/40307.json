{"tag":"section","attrib":{"id":"idebef1c9a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40307"},"text":null,"children":[{"tag":"num","attrib":{"value":"40307"},"text":"§ 40307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Space grant fellowship program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebef1c9b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40307/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Award of Fellowships","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall support a space grant fellowship program to provide educational and training assistance to qualified individuals at the graduate level of education in fields related to space. Such fellowships shall be awarded pursuant to guidelines established by the Administrator. Space grant fellowships shall be awarded to individuals at space grant colleges, space grant regional consortia, other colleges and institutions of higher education, professional associations, and institutes in such a manner as to ensure wide geographic and institutional diversity in the pursuit of research under the fellowship program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebef1c9c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40307/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Amount Provided","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The total amount which may be provided for grants under the space grant fellowship program during any fiscal year shall not exceed an amount equal to 50 percent of the total funds appropriated for such year pursuant to this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebef1c9d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40307/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Sponsor Other Research Fellowship Programs Unaffected","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to prohibit the Administrator from sponsoring any research fellowship program, including any special emphasis program, which is established under an authority other than this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebef1c9e-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3387"},"text":"124 Stat. 3387","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebef1c9f-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebef1ca0-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebef1ca1-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text