{"tag":"section","attrib":{"id":"idec0bcba8-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60606"},"text":null,"children":[{"tag":"num","attrib":{"value":"60606"},"text":"§ 60606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Space weather knowledge transfer and information exchange","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of enactment of the PROSWIFT Act, the Administrator of the National Oceanic and Atmospheric Administration, in collaboration with the Administrator of the National Aeronautics and Space Administration and the Director of the National Science Foundation, shall enter into an arrangement with the National Academies of Sciences, Engineering, and Medicine to establish a Space Weather Government-Academic-Commercial Roundtable to facilitate communication and knowledge transfer among Government participants in the space weather interagency working group established under section 60601(c), the academic community, and the commercial space weather sector to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec0bcba9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60606/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate advances in space weather prediction and forecasting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec0bcbaa-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60606/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase coordination of space weather research to operations and operations to research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec0bcbab-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60606/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve preparedness for potential space weather phenomena.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec0bcbac-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/181/s2/b"},"text":"Pub. L. 116–181, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-21"},"text":"Oct. 21, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/891"},"text":"134 Stat. 891","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec0bcbad-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idec0bcbae-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idec0bcbaf-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the PROSWIFT Act, referred to in text, is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/181"},"text":"Pub. L. 116–181","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2020-10-21"},"text":"Oct. 21, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
