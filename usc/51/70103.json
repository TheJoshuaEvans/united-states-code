206","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/3207"},"text":"104 Stat. 3207","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/303/tII/s203/4"},"text":"Pub. L. 105–303, title II, § 203(4)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/2855"},"text":"112 Stat. 2855","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “this section” are substituted for “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/611"},"text":"Public Law 101–611","children":[],"tail":", because title II of "},{"tag":"ref","attrib":{"href":"/us/pl/101/611"},"text":"Public Law 101–611","children":[],"tail":" was previously repealed except for section 201 (a short title provision, classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2451"},"text":"42 U.S.C. 2451","children":[],"tail":" note, in which neither defined term appears) and sections 203 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2465c"},"text":"42 U.S.C. 2465c","children":[],"tail":") and 206 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2465f"},"text":"42 U.S.C. 2465f","children":[],"tail":") of "},{"tag":"ref","attrib":{"href":"/us/pl/101/611"},"text":"Public Law 101–611","children":[],"tail":", which are restated in this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idec0bcbec-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idec0bcbed-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/90"},"text":"Pub. L. 114–90","children":[],"tail":" substituted “space launch system” for “space shuttle” in section catchline and wherever appearing in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
