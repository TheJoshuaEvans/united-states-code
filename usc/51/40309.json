{"tag":"section","attrib":{"id":"idebef1cb7-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40309"},"text":null,"children":[{"tag":"num","attrib":{"value":"40309"},"text":"§ 40309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of other Federal personnel and data","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each department, agency, or other instrumentality of the Federal Government that is engaged in or concerned with, or that has authority over, matters relating to space—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebef1cb8-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40309/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, upon a written request from the Administrator, make available, on a reimbursable basis or otherwise, any personnel (with their consent and without prejudice to their position and rating), service, or facility which the Administrator considers necessary to carry out any provision of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1cb9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40309/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, upon a written request from the Administrator, furnish any available data or other information which the Administrator considers necessary to carry out any provision of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1cba-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40309/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may cooperate with the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","at