{"tag":"section","attrib":{"id":"idebd9bf09-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148"},"text":null,"children":[{"tag":"num","attrib":{"value":"20148"},"text":"§ 20148.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indemnification; NASA launch services and reentry services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebd9bf0a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under such regulations in conformity with this section as the Administrator shall prescribe taking into account the availability, cost, and terms of liability insurance, any contract between the Administration and a provider may provide that the United States will indemnify the provider against successful claims (including reasonable expenses of litigation or settlement) by third parties for death, bodily injury, or loss of or damage to property resulting from launch services and reentry services carried out under the contract that the contract defines as unusually hazardous or nuclear in nature, but only to the extent the total amount of successful claims related to the activities under the contract—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd9bf0b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is more than the amount of insurance or demonstration of financial responsibility described in subsection (c)(3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd9bf0c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not more than the amount specified in section 50915(a)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd9bf0d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms of Indemnification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A contract made under subsection (a) that provides indemnification shall provide for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd9bf0e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice to the United States of any claim or suit against the provider for death, bodily injury, or loss of or damage to property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd9bf0f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" control of or assistance in the defense by the United States, at its election, of that claim or suit and approval of any settlement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd9bf10-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability Insurance of the Provider.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd9bf11-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provider under subsection (a) shall obtain liability insurance or demonstrate financial responsibility in amounts to compensate for the maximum probable loss from claims by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebd9bf12-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a third party for death, bodily injury, or property damage or loss resulting from a launch service or reentry service carried out under the contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebd9bf13-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Government for damage or loss to Government property resulting from a launch service or reentry service carried out under the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd9bf14-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum probable losses.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebd9bf15-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall determine the maximum probable losses under subparagraphs (A) and (B) of paragraph (1) not later than 90 days after the date that the provider requests such a determination and submits all information the Administrator requires.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebd9bf16-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may revise a determination under subparagraph (A) of this paragraph if the Administrator determines the revision is warranted based on new information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd9bf17-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of insurance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the total claims related to one launch or reentry, a provider shall not be required to obtain insurance or demonstrate financial responsibility of more than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebd9bf18-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idebd9bf19-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $500,000,000 under paragraph (1)(A); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idebd9bf1a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 under paragraph (1)(B); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebd9bf1b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maximum liability insurance available on the world market at reasonable cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd9bf1c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coverage","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An insurance policy or demonstration of financial responsibility under this subsection shall protect the following, to the extent of their potential liability for involvement in launch services or reentry services:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebd9bf1d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebd9bf1e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Personnel of the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebd9bf1f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Related entities of the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebd9bf20-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Related entities of the provider.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebd9bf21-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/c/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Government astronauts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd9bf22-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Indemnification Without Cross-waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsection (a), the Administrator may not indemnify a provider under this section unless there is a cross-waiver between the Administration and the provider as described in subsection (e).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd9bf23-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cross-Waivers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd9bf24-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator, on behalf of the United States and its departments, agencies, and instrumentalities, shall reciprocally waive claims with a provider under which each party to the waiver agrees to be responsible, and agrees to ensure that its related entities are responsible, for damage or loss to its property, or for losses resulting from any injury or death sustained by its employees or agents, as a result of activities arising out of the performance of the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd9bf25-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The waiver made by the Government under paragraph (1) shall apply only to the extent that the claims are more than the amount of insurance or demonstration of financial responsibility required under subsection (c)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd9bf26-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Willful Misconduct","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Indemnification under subsection (a) may exclude claims resulting from the willful misconduct of the provider or its related entities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd9bf27-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification of Just and Reasonable Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No payment may be made under subsection (a) unless the Administrator or the Administrator’s designee certifies that the amount is just and reasonable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd9bf28-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payments.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd9bf29-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon the approval by the Administrator, payments under subsection (a) may be made from funds appropriated for such payments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd9bf2a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall not approve payments under paragraph (1), except to the extent provided in an appropriation law or to the extent additional legislative authority is enacted providing for such payments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd9bf2b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Administrator requests additional appropriations to make payments under this subsection, then the request for those appropriations shall be made in accordance with the procedures established under section 50915.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd9bf2c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rules of Construction.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd9bf2d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority to indemnify under this section shall not create any rights in third persons that would not otherwise exist by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd9bf2e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section may be construed as prohibiting the Administrator from indemnifying a provider or any other NASA contractor under other law, including under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/804"},"text":"Public Law 85–804","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1431"},"text":"50 U.S.C. 1431","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd9bf2f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Anti-deficiency act","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebd9bf30-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all obligations under this section are subject to the availability of funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebd9bf31-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nothing in this section may be construed to require obligation or payment of funds in violation of sections 1341, 1342, 1349 through 1351, and 1511 through 1519 of title 31, United States Code (commonly referred to as the “Anti-Deficiency Act”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd9bf32-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may not provide indemnification under this section for an activity that requires a license or permit under chapter 509.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebd9bf33-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebd9bf34-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Government astronaut","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “government astronaut” has the meaning given the term in section 50902.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd9bf35-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Launch services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “launch services” has the meaning given the term in section 50902.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd9bf36-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/k/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provider","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “provider” means a person that provides domestic launch services or domestic reentry services to the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd9bf37-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/k/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reentry services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “reentry services” has the meaning given the term in section 50902.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebd9bf38-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s20148/k/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","a