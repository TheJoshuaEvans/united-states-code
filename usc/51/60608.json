{"tag":"section","attrib":{"id":"idec0bcbbf-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60608"},"text":null,"children":[{"tag":"num","attrib":{"value":"60608"},"text":"§ 60608.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Space weather benchmarks","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The interagency working group established under section 60601(c) shall periodically review and update the benchmarks described in the report of the National Science and Technology Council entitled “Space Weather Phase 1 Benchmarks” and dated June 2018, as necessary, based on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec0bcbc0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60608/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any significant new data or advances in scientific understanding that become available; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec0bcbc1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60608/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the evolving needs of entities impacted by space weather phenomena.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec0bcbc2-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/181/s2/b"},"text":"Pub. L. 116–181, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-21"},"text":"Oct. 21, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/892"},"text":"134 Stat. 892","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
