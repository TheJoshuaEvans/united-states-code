{"tag":"section","attrib":{"id":"idebea613b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30902"},"text":null,"children":[{"tag":"num","attrib":{"value":"30902"},"text":"§ 30902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charles “Pete” Conrad Astronomy Awards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebea613c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Short Title","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section may be cited as the “Charles ‘Pete’ Conrad Astronomy Awards Act”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebea613d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebea613e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30902/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amateur astronomer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “amateur astronomer” means an individual whose employer does not provide any funding, payment, or compensation to the individual for the observation of asteroids and other celestial bodies, and does not include any individual employed as a professional astronomer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebea613f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30902/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minor planet center","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Minor Planet Center” means the Minor Planet Center of the Smithsonian Astrophysical Observatory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebea6140-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30902/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Near-earth asteroid","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “near-Earth asteroid” means an asteroid with a perihelion distance of less than 1.3 Astronomical Units from the Sun.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebea6141-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30902/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Program” means the Charles “Pete” Conrad Astronomy Awards Program established under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebea6142-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30902/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Charles “Pete” Conrad Astronomy Awards Program.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebea6143-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30902/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall establish the Charles “Pete” Conrad Astronomy Awards Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebea6144-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30902/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Awards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall make awards under the Program based on the recommendations of the Minor Planet Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebea6145-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30902/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Award categories","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall make one annual award, unless there are no eligible discoveries or contributions, for each of the following categories:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebea6146-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30902/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discovery of brightest near-earth asteroid","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amateur astronomer or group of amateur astronomers who in the preceding calendar year discovered the intrinsically brightest near-Earth asteroid among the near-Earth asteroids that were discovered during that year by amateur astronomers or groups of amateur astronomers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebea6147-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30902/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Greatest contribution to cataloguing near-earth asteroids","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amateur astronomer or group of amateur astronomers who made the greatest contribution to the Minor Planet Center’s mission of cataloguing near-Earth asteroids during the preceding year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebea6148-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30902/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Award amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An award under the Program shall be in the amount of $3,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebea6149-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30902/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidelines.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebea614a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30902/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Citizen or permanent resident","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No individual who is not a citizen or permanent resident of the United States at the time of the individual’s discovery or contribution may receive an award under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebea614b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30902/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Finality","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The decisions of the Administrator in making awards under this section are final.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebea614c-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3372"},"text":"124 Stat. 3372","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebea614d-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebea614e-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebea614f-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"