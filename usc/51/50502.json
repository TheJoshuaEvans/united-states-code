{"tag":"section","attrib":{"id":"idebf6486d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50502"},"text":null,"children":[{"tag":"num","attrib":{"value":"50502"},"text":"§ 50502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Launch voucher demonstration program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebf6486e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement To Establish Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall establish a demonstration program to award vouchers for the payment of commercial launch services and payload integration services for the purpose of launching payloads funded by the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebf6486f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Award of Vouchers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall award vouchers under subsection (a) to appropriate individuals as a part of grants administered by the Administration for the launch of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebf64870-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payloads to be placed in suborbital trajectories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf64871-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small payloads to be placed in orbit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebf64872-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may provide voucher award recipients with such assistance (including contract formulation and technical support during the proposal evaluation) as may be necessary to ensure the purchase of cost effective and reasonably reliable commercial launch services and payload integration services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebf64873-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3405"},"text":"124 Stat. 3405","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebf64874-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebf64875-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebf64876-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":