{"tag":"section","attrib":{"id":"idebf6488c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50504"},"text":null,"children":[{"tag":"num","attrib":{"value":"50504"},"text":"§ 50504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Government facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebf6488d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebf6488e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50504/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Federal agencies, including the Administration and the Department of Defense, may allow non-Federal entities to use their space-related facilities on a reimbursable basis if the Administrator, the Secretary of Defense, or the appropriate agency head determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebf6488f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50504/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the facilities will be used to support commercial space activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf64890-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50504/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such use can be supported by existing or planned Federal resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf64891-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50504/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such use is compatible with Federal activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf64892-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50504/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equivalent commercial services are not available on reasonable terms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf64893-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50504/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such use is consistent with public safety, national security, and international treaty obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf64894-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50504/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out paragraph (1)(E), each agency head shall consult with appropriate Federal officials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebf64895-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement Payment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebf64896-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The reimbursement referred to in subsection (a) may be an amount equal to the direct costs (including salaries of United States civilian and contractor personnel) incurred by the United States as a result of the use of such facilities by the private sector. For the purposes of this paragraph, the term “direct costs” means the actual costs that can be unambiguously associated with such use, and would not be borne by the United States Government in the absence of such use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf64897-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Credit to appropriation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of any payment received by the United States for use of facilities under this subsection shall be credited to the appropriation from which the cost of providing such facilities was paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebf64898-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3406"},"text":"124 Stat. 3406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebf64899-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebf6489a-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebf6489b-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"ht