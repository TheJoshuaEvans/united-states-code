{"tag":"section","attrib":{"id":"idebfd73ca-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50909"},"text":null,"children":[{"tag":"num","attrib":{"value":"50909"},"text":"§ 50909.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition, suspension, and end of launches, operation of launch sites and reentry sites, and reentries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebfd73cb-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50909/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation may prohibit, suspend, or end immediately the launch of a launch vehicle or the operation of a launch site or reentry site, or reentry of a reentry vehicle, licensed under this chapter if the Secretary decides the launch or operation or reentry is detrimental to the public health and safety, the safety of property, or a national security or foreign policy interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebfd73cc-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50909/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Periods of Orders","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An order under this section takes effect immediately and remains in effect during a review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s50912"},"text":"section 50912 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebfd73cd-3a70-11f1-9081-fe88c1712d53"},"text":"("