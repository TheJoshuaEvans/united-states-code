{"tag":"section","attrib":{"id":"idebf8b8bd-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50702"},"text":null,"children":[{"tag":"num","attrib":{"value":"50702"},"text":"§ 50702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebf8b8be-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established within the Department of Commerce an Office of Space Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebf8b8bf-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Office shall be headed by a Director, who shall be a senior executive and shall be compensated at a level in the Senior Executive Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5382"},"text":"section 5382 of title 5","children":[],"tail":" as determined by the Secretary of Commerce."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebf8b8c0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions of Office","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office shall be the principal unit for the coordination of space-related issues, programs, and initiatives within the Department of Commerce, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebf8b8c1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50702/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to foster the conditions for the economic growth and technological advancement of the United States space commerce industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b8c2-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50702/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate space commerce policy issues and actions within the Department of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b8c3-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50702/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to represent the Department of Commerce in the development of United States policies and in negotiations with foreign countries to promote United States space commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b8c4-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50702/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the advancement of United States geospatial technologies related to space commerce, in cooperation with relevant interagency working groups; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b8c5-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50702/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide support to Federal Government organizations working on Space-Based Positioning Navigation, and Timing policy, including the National Coordination Office for Space-Based Position,","children":[{"tag":"ref","attrib":{"idref":"fn002010"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002010"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Positioning,”."}],"tail":" Navigation, and Timing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebf8b8c6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties of Director","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The primary responsibilities of the Director in carrying out the functions of the Office shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebf8b8c7-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50702/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting commercial provider investment in space activities by collecting, analyzing, and disseminating information on space markets, and conducting workshops and seminars to increase awareness of commercial space opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b8c8-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50702/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting United States commercial providers in the efforts of those providers to conduct business with the United States Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b8c9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50702/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acting as an industry advocate within the executive branch of the Federal Government to ensure that the Federal Government meets the space-related requirements of the Federal Government, to the fullest extent feasible, using commercially available space goods and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b8ca-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50702/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that the United States Government does not compete with United States commercial providers in the provision of space hardware and services otherwise available from United States commercial providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b8cb-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50702/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting the export of space-related goods and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b8cc-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50702/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representing the Department of Commerce in the development of United States policies and in negotiations with foreign countries to ensure free and fair trade internationally in the area of space commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf8b8cd-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50702/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seeking the removal of legal, policy, and institutional impediments to space commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebf8b8ce-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3408"},"text":"124 Stat. 3408","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/90/tIII"},"text":"Pub. L. 114–90, title III","children":[],"tail":", §§ 301(c), 302, "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/720"},"text":"129 Stat. 720","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebf8b8cf-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebf8b8d0-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebf8b8d1-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"50702","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t15/s1511e"},"text":"15 U.S.C. 1511e","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/105/309/s8"},"text":"Pub. L. 105–309, § 8","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/2937"},"text":"112 Stat. 2937","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/107/305/s14"},"text":"Pub. L. 107–305, § 14","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/116/2380"},"text":"116 Stat. 2380","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/108/447/dB/tII"},"text":"Pub. L. 108–447, div. B, title II","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/118/2878"},"text":"118 Stat. 2878","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idebf8b8d2-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idebf8b8d3-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/90/s301/c"},"text":"Pub. L. 114–90, § 301(c)","children":[],"tail":", substituted “Space Commerce” for “Space Commercialization”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/90/s302"},"text":"Pub. L. 114–90, § 302","children":[],"tail":", substituted “Commerce, including—” for “Commerce.” and added pars. (1) to (5)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idebf8b8d4-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idebf8b8d5-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Cooperation With Former Soviet Republics","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/588/tII/s218"},"text":"Pub. L. 102–588, title II, § 218","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5117"},"text":"106 Stat. 5117","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/588/tII/s218"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within one year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":"], the President shall submit to Congress a report describing—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the opportunities for increased space related trade with the independent states of the former Soviet Union;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a technology procurement plan for identifying and evaluating all unique space hardware, space technology, and space services available to the United States from the independent states of the former Soviet Union, specifically including those technologies the National Aeronautics and Space Administration has identified as high priority in its Space Research and Technology Integrated Technology Plan.[;]","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trade missions carried out pursuant to subsection (c), including the private participation and the results of such missions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offices and accounts of the National Aeronautics and Space Administration to which expenses for either cooperative activities or procurement actions, involving the independent states of the former Soviet Union, are charged;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any barriers, regulatory or practical, that inhibit space-related trade between the United States and the independent states of the former Soviet Union, including such barriers in either the United States or the independent states; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any anticompetitive issues raised by a potential acquisition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If any United States Government agency denies a request for a license or other approval that may be necessary to conduct discussions on space-related matters with the independent states of the former Soviet Union, that agency shall immediately notify the Speaker of the House of Representatives and President of the Senate. Each such notification shall include a statement of the reasons for the denial.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Role of the Office of Space Commerce","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Office of Space Commerce of the Department of Commerce is authorized and encouraged to conduct trade missions to appropriate independent states of the former Soviet Union for the purpose of familiarizing United States aerospace industry representatives with space hardware, space technologies, and space services that may be available from the independent states, and with the business practices and overall business climate in the independent states. The Office of Space Commerce shall also advise the Administrator [of the National Aeronautics and Space Administration] as to the impact on United States industry of each potential acquisition of space hardware, space technology, or space services from the independent states of the former Soviet Union, specifically including any anticompetitive issues the Office may observe.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
