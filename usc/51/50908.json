{"tag":"section","attrib":{"id":"idebfd73b4-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50908"},"text":null,"children":[{"tag":"num","attrib":{"value":"50908"},"text":"§ 50908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective periods, and modifications, suspensions, and revocations, of licenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebfd73b5-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Periods of Licenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall specify the period for which a license issued or transferred under this chapter is in effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebfd73b6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modifications","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebfd73b7-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50908/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On the initiative of the Secretary or on application of the licensee, the Secretary may modify a license issued or transferred under this chapter if the Secretary decides the modification will comply with this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebfd73b8-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50908/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall modify a license issued or transferred under this chapter whenever a modification is needed for the license to be in conformity with a regulation that was issued pursuant to section 50905(c) after the issuance of the license. This paragraph shall not apply to permits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebfd73b9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50908/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Suspensions and Revocations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may suspend or revoke a license if the Secretary decides that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebfd73ba-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50908/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the licensee has not complied substantially with a requirement of this chapter or a regulation prescribed under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebfd73bb-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50908/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the suspension or revocation is necessary to protect the public health and safety, the safety of property, or a national security or foreign policy interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebfd73bc-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50908/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Suspensions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebfd73bd-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50908/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may suspend a license when a previous launch or reentry under the license has resulted in a serious or fatal injury (as defined in 49 CFR 830, as in effect on ","children":[{"tag":"date","attrib":{"date":"2004-11-10"},"text":"November 10, 2004","children":[],"tail":") to any human being and the Secretary has determined that continued operations under the license are likely to cause additional serious or fatal injury (as defined in 49 CFR 830, as in effect on "},{"tag":"date","attrib":{"date":"2004-11-10"},"text":"November 10, 2004","children":[],"tail":") to any human being."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebfd73be-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50908/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any suspension imposed under this subsection shall be for as brief a period as possible and, in any event, shall cease when the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebfd73bf-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50908/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has determined that the licensee has taken sufficient steps to reduce the likelihood of a recurrence of the serious or fatal injury; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebfd73c0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50908/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has modified the license pursuant to subsection (b) to sufficiently reduce the likelihood of a recurrence of the serious or fatal injury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebfd73c1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50908/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection shall not apply to permits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebfd73c2-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50908/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Periods of Modifications, Suspensions, and Revocations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless the Secretary specifies otherwise, a modification, suspension, or revocation under this section takes effect immediately and remains in effect during a review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s50912"},"text":"section 50912 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebfd73c3-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50908/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall notify the licensee in writing of the decision of the Secretary under this section and any action the Secretary takes or proposes to take based on the decision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebfd73c4-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1334"},"text":"108 Stat. 1334","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s70107"},"text":"§ 70107 of title 49","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/492/s2/c/18"},"text":"Pub. L. 108–492, § 2(c)(18)","children":[],"tail":", (19), "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3980"},"text":"118 Stat. 3980","children":[],"tail":"; renumbered § 70107 then "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s50908"},"text":"§ 50908 of title 51","children":[],"tail":" and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/314/s4/d/2"},"text":"Pub. L. 111–314, § 4(d)(2)","children":[],"tail":", (3)(H), (5)(J), (K), "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3440-3442"},"text":"124 Stat. 3440–3442","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/90/tI/s112/n"},"text":"Pub. L. 114–90, title I, § 112(n)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/713"},"text":"129 Stat. 713","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebfd73c5-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebfd73c6-3a70-11f1-9081-fe88