{"tag":"section","attrib":{"id":"idebf18d38-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40904"},"text":null,"children":[{"tag":"num","attrib":{"value":"40904"},"text":"§ 40904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Microgravity research","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebf18d39-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40904/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the capacity to support ground-based research leading to space-based basic and applied scientific research in a variety of disciplines with potential direct national benefits and applications that can be advanced significantly from the uniqueness of microgravity and the space environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf18d3a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40904/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out, to the maximum extent practicable, basic, applied, and commercial International Space Station research in fields such as molecular crystal growth, animal research, basic fluid physics, combustion research, cellular biotechnology, low-temperature physics, and cellular research at a level that will sustain the existing United States scientific expertise and research capability in microgravity research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebf18d3b-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},