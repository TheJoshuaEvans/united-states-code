{"tag":"section","attrib":{"id":"idebef1c6a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40304"},"text":null,"children":[{"tag":"num","attrib":{"value":"40304"},"text":"§ 40304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants or contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebef1c6b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may make grants and enter into contracts or other transactions under this subsection to assist any space grant and fellowship program or project if the Administrator finds that the program or project will carry out the purposes set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s40301"},"text":"section 40301 of this title","children":[],"tail":". The total amount paid pursuant to a grant or contract may equal not more than 66 percent of the total cost of the space grant and fellowship program or project involved, except in the case of grants or contracts paid for with funds accepted by the Administrator pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s40303/c/2"},"text":"section 40303(c)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebef1c6c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Grants","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may make special grants under this subsection to carry out the purposes set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s40301"},"text":"section 40301 of this title","children":[],"tail":". The amount of a special grant may equal up to 100 percent of the total cost of the project involved. A special grant may be made under this subsection only if the Administrator finds that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebef1c6d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no reasonable means is available through which the applicant can meet the matching requirement for a grant under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1c6e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the probable benefit of the project outweighs the public interest in the matching requirement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1c6f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40304/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the same or equivalent benefit cannot be obtained through the award of a contract or grant under subsection (a) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s40305"},"text":"section 40305 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebef1c70-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person may apply to the Administrator for a grant or contract under this section. Application shall be made in such form and manner, and with such content and other submissions, as the Administrator shall by regulation prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebef1c71-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40304/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms and Conditions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebef1c72-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40304/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any grant made, or contract entered into, under this section shall be subject to the limitations and provisions set forth in paragraphs (2) and (3) and to such other terms, conditions, and requirements as the Administrator considers necessary or appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1c73-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40304/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No payment under any grant or contract under this section may be applied to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebef1c74-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40304/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase of any land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebef1c75-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40304/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase, construction, preservation, or repair of any building; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebef1c76-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40304/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase or construction of any launch facility or launch vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1c77-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40304/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Leases","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding paragraph (2), the items in subparagraphs (A), (B), and (C) of such paragraph may be leased upon written approval of the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1c78-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40304/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person that receives or utilizes any proceeds of any grant or contract under this section shall keep such records as the Administrator shall by regulation prescribe as being necessary and appropriate to facilitate effective audit and evaluation, including records which fully disclose the amount and disposition by such recipient of such proceeds, the total cost of the program or project in connection with which such proceeds were used, and the amount, if any, of such cost which was provided through other sources. Such records shall be maintained for 3 years after the completion of such a program or project. The Administrator and the Comptroller General of the United States, or any of their duly authorized representatives, shall have access, for the purpose of audit and evaluation, to any books, documents, papers, and records of receipts which, in the opinion of the Administrator or the Comptroller General, may be related or pertinent to such grants and contracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebef1c79-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3384"},"text":"124 Stat. 3384","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebef1c7a-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebef1c7b-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebef1c7c-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40304","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s2486d"},"text":"42 U.S.C. 2486d","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/100/147/tII/s206"},"text":"Pub. L. 100–147, title II, § 206","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/101/872"},"text":"101 Stat. 872","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “not more than 66 percent” are substituted for “66 percent, or any lesser percent”, and the word “except” is substituted for “except that this limitation shall not apply”, for clarity and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “up to 100 percent” are substituted for “100 percent, or any lesser percent” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
