ull,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31101(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s2477/a"},"text":"42 U.S.C. 2477(a)","children":[],"tail":" (4th, 5th sentences)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31101(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s2477/b"},"text":"42 U.S.C. 2477(b)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(1)(B), the words “maximum rate payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of title 5","children":[],"tail":"” are substituted for “rate for GS–18” because of section 101(c) of the Federal Employees Pay Comparability Act of 1990 ("},{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Public Law 101–509","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"5 U.S.C. 5376","children":[],"tail":" note)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the date “","children":[{"tag":"date","attrib":{"date":"2005-12-30"},"text":"December 30, 2005","children":[],"tail":"” is substituted for “the date of enactment of the National Aeronautics and Space Administration Authorization Act of 2005” to reflect the date of enactment of the National Aeronautics and Space Administration Authorization Act of 2005 ("},{"tag":"ref","attrib":{"href":"/us/pl/109/155"},"text":"Public Law 109–155","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2895"},"text":"119 Stat. 2895","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
