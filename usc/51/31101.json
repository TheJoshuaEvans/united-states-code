{"tag":"section","attrib":{"id":"idebea6152-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31101"},"text":null,"children":[{"tag":"num","attrib":{"value":"31101"},"text":"§ 31101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aerospace Safety Advisory Panel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebea6153-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment and Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established an Aerospace Safety Advisory Panel consisting of a maximum of 9 members who shall be appointed by the Administrator for terms of 6 years each. Not more than 4 such members shall be chosen from among the officers and employees of the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebea6154-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairman","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"One member shall be designated by the Panel as its Chairman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebea6155-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Panel shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebea6156-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31101/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review safety studies and operations plans referred to it, including evaluating the Administration’s compliance with the return-to-flight and continue-to-fly recommendations of the Columbia Accident Investigation Board, and make reports thereon;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebea6157-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31101/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" advise the Administrator and Congress with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebea6158-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31101/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the hazards of proposed or existing facilities and proposed operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebea6159-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31101/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adequacy of proposed or existing safety standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebea615a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31101/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management and culture related to safety; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebea615b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31101/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other duties as the Administrator may request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebea615c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31101/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation and Expenses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebea615d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31101/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebea615e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31101/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal officers and employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the Panel who is an officer or employee of the Federal Government shall receive no compensation for the member’s services as such.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebea615f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31101/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members appointed from outside the federal government","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the Panel appointed from outside the Federal Government shall receive compensation, at a rate not to exceed the per diem rate equivalent to the maximum rate payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of title 5","children":[],"tail":", for each day the member is engaged in the actual performance of duties vested in the Panel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebea6160-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31101/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the Panel shall be allowed necessary travel expenses (or in the alternative, mileage for use of a privately owned vehicle and a per diem in lieu of subsistence not to exceed the rate and amount prescribed in sections 5702 and 5704 of title 5), and other necessary expenses incurred by the member in the performance of duties vested in the Panel, without regard to the provisions of subchapter I of chapter 57 of title 5, the Standardized Government Travel Regulations, or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5731"},"text":"section 5731 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebea6161-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31101/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Panel shall submit an annual report to the Administrator and to Congress. In the first annual report submitted after ","children":[{"tag":"date","attrib":{"date":"2005-12-30"},"text":"December 30, 2005","children":[],"tail":", the Panel shall include an evaluation of the Administration’s management and culture related to safety. Each annual report shall include an evaluation of the Administration’s compliance with the recommendations of the Columbia Accident Investigation Board through retirement of the space shuttle."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebea6162-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3373"},"text":"124 Stat. 3373","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebea6163-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebea6164-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebea6165-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text