{"tag":"section","attrib":{"id":"idebfd73dd-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50911"},"text":null,"children":[{"tag":"num","attrib":{"value":"50911"},"text":"§ 50911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Space advertising","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebfd73de-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50911/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Licensing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding the provisions of this chapter or any other provision of law, the Secretary may not, for the launch of a payload containing any material to be used for the purposes of obtrusive space advertising—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebfd73df-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50911/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue or transfer a license under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebfd73e0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50911/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waive the license requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebfd73e1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50911/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Launching","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No holder of a license under this chapter may launch a payload containing any material to be used for purposes of obtrusive space advertising.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebfd73e2-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50911/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commercial Space Advertising","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall apply to nonobtrusive commercial space advertising, including advertising on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebfd73e3-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50911/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercial space transportation vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebfd73e4-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50911/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" space infrastructure payloads;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebfd73e5-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50911/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" space launch facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebfd73e6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50911/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" launch support facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebfd73e7-3a70-11f1-9081-fe88c1712d53"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/391/tIII/s322/b"},"text":"Pub. L. 106–391, title III, § 322(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1598"},"text":"114 Stat. 1598","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s70109a"},"text":"§ 70109a of title 49","children":[],"tail":"; renumbered § 70109a then "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s50911"},"text":"§ 50911 of title 51","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/111/314/s4/d/2"},"text":"Pub. L. 111–314, § 4(d)(2)","children":[],"tail":", (3)(K), "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3440"},"text":"124 Stat. 3440","children":[],"tail":", 3441.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebfd73e8-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idebfd73e9-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idebfd73ea-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314"},"text":"Pub. L. 111–314","children":[],"tail":" successively renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s70109a"},"text":"section 70109a of title 49","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s70109a"},"text":"section 70109a of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idebfd73eb-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idebfd73ec-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Negotiation With Foreign Launching Nations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/391/tIII/s322/c"},"text":"Pub. L. 106–391, title III, § 322(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1598"},"text":"114 Stat. 1598","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/391/tIII/s322/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President is requested to negotiate with foreign launching nations for the purpose of reaching one or more agreements that prohibit the use of outer space for obtrusive space advertising purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is the sense of the Congress that the President should take such action as is appropriate and feasible to enforce the terms of any agreement to prohibit the use of outer space for obtrusive space advertising purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this subsection, the term ‘foreign launching nation’ means a nation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that launches, or procures the launching of, a payload into outer space; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the territory or facility of which a payload is launched into outer space.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
