{"tag":"section","attrib":{"id":"idec0959fd-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60502"},"text":null,"children":[{"tag":"num","attrib":{"value":"60502"},"text":"§ 60502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transitioning experimental research into operational services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec0959fe-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interagency Process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Office of Science and Technology Policy, in consultation with the Administrator, the Administrator of the National Oceanic and Atmospheric Administration, and other relevant stakeholders, shall develop a process to transition, when appropriate, Administration Earth science and space weather missions or sensors into operational status. The process shall include coordination of annual agency budget requests as required to execute the transitions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec0959ff-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsible Agency Official","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator and the Administrator of the National Oceanic and Atmospheric Administration shall each designate an agency official who shall have the responsibility for and authority to lead the Administration’s and the National Oceanic and Atmospheric Administration’s transition activities and interagency coordination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec095a00-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For each mission or sensor that is determined to be appropriate for transition under subsection (a), the Administration and the National Oceanic and Atmospheric Administration shall transmit to Congress a joint plan for conducting the transition. The plan shall include the strategy, milestones, and budget required to execute the transition. The transition plan shall be transmitted to Congress no later than 60 days after the successful completion of the mission or sensor critical design review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec095a01-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3425"},"text":"124 Stat. 3425","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec095a02-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idec095a03-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idec095a04-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}]