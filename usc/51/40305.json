{"tag":"section","attrib":{"id":"idebef1c7d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40305"},"text":null,"children":[{"tag":"num","attrib":{"value":"40305"},"text":"§ 40305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific national needs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebef1c7e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Identification of Specific Needs and Grant-Making and Contracting Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall identify specific national needs and problems relating to space. The Administrator may make grants or enter into contracts under this section with respect to such needs or problems. The amount of any such grant or contract may equal up to 100 percent of the total cost of the project involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebef1c7f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applications for Grants or Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person may apply to the Administrator for a grant or contract under this section. In addition, the Administrator may invite applications with respect to specific national needs or problems identified under subsection (a). Application shall be made in such form and manner, and with such content and other submissions, as the Administrator shall by regulation prescribe. Any grant made, or contract entered into, under this section shall be subject to the limitations and provisions set forth in paragraphs (2) and (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s40304/d"},"text":"section 40304(d) of this title","children":[],"tail":" and to such other terms, conditions, and requirements as the Administrator considers necessary or appropriate."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebef1c80-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3385"},"text":"124 Stat. 3385","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebef1c81-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebef1c82-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebef1c83-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40305","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s2486e"},"text":"42 U.S.C. 2486e","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/100/147/tII/s207"},"text":"Pub. L. 100–147, title II, § 207","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/101/873"},"text":"101 Stat. 873","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “up to 100 percent” are substituted for “100 percent, or any lesser percent” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
