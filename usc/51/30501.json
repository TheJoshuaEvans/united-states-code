{"tag":"section","attrib":{"id":"idebe7efbf-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30501"},"text":null,"children":[{"tag":"num","attrib":{"value":"30501"},"text":"§ 30501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lessons learned and best practices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebe7efc0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall transmit to the Committee on Science and Technology of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate an implementation plan describing the Administration’s approach for obtaining, implementing, and sharing lessons learned and best practices for its major programs and projects not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-12-30"},"text":"December 30, 2005","children":[],"tail":". The implementation plan shall be updated and maintained to ensure that it is current and consistent with the burgeoning culture of learning and safety that is emerging at the Administration."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebe7efc1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Content","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The implementation plan shall contain at a minimum the lessons learned and best practices requirements for the Administration, the organizations or positions responsible for enforcement of the requirements, the reporting structure, and the objective performance measures indicating the effectiveness of the activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebe7efc2-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incentives","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall provide incentives to encourage sharing and implementation of lessons learned and best practices by employees, projects, and programs, as well as penalties for programs and projects that are determined not to have demonstrated use of those resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebe7efc3-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3367"},"text":"124 Stat. 3367","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebe7efc4-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebe7efc5-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebe7efc6-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30501","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s16615"},"text":"42 U.S.C. 16615","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/109/155/tI/s107"},"text":"Pub. L. 109–155, title I, § 107","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 30, 2005","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/119/2912"},"text":"119 Stat. 2912","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Committee on Science and Technology” are substituted for “Committee on Science” on authority of Rule X(1)(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of the Rules of the House of Representatives, adopted by House Resolution No. 6 (110th Congress, "},{"tag":"date","attrib":{"date":"2007-01-05"},"text":"January 5, 2007","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the date “","children":[{"tag":"date","attrib":{"date":"2005-12-30"},"text":"December 30, 2005","children":[],"tail":"” is substituted for “the date of enactment of this Act” to reflect the date of enactment of the National Aeronautics and Space Administration Authorization Act of 2005 ("},{"tag":"ref","attrib":{"href":"/us/pl/109/155"},"text":"Public Law 109–155","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2895"},"text":"119 Stat. 2895","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idebe7efc7-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idebe7efc8-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Science and Technology of House of Representatives changed to Committee on Science, Space, and Technology of House of Representatives by House Resolution No. 5, One Hundred Twelfth Congress, ",