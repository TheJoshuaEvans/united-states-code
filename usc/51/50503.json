{"tag":"section","attrib":{"id":"idebf64877-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50503"},"text":null,"children":[{"tag":"num","attrib":{"value":"50503"},"text":"§ 50503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Anchor tenancy and termination liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebf64878-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Anchor Tenancy Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to appropriations, the Administrator or the Administrator of the National Oceanic and Atmospheric Administration may enter into multiyear anchor tenancy contracts for the purchase of a good or service if the appropriate Administrator determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebf64879-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the good or service meets the mission requirements of the Administration or the National Oceanic and Atmospheric Administration, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf6487a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commercially procured good or service is cost effective;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf6487b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50503/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the good or service is procured through a competitive process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf6487c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50503/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing or potential customers for the good or service other than the United States Government have been specifically identified;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf6487d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50503/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the long-term viability of the venture is not dependent upon a continued Government market or other nonreimbursable Government support; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf6487e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50503/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private capital is at risk in the venture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebf6487f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination Liability.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebf64880-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Contracts entered into under subsection (a) may provide for the payment of termination liability in the event that the Government terminates such contracts for its convenience.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf64881-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fixed schedule of payments and limitation on liability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Contracts that provide for the payment of termination liability, as described in paragraph (1), shall include a fixed schedule of such termination liability payments. Liability under such contracts shall not exceed the total payments which the Government would have made after the date of termination to purchase the good or service if the contract were not terminated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf64882-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50503/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to appropriations, funds available for such termination liability payments may be used for purchase of the good or service upon successful delivery of the good or service pursuant to the contract. In such case, sufficient funds shall remain available to cover any remaining termination liability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebf64883-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebf64884-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50503/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Contracts entered into under this section shall not exceed 10 years in duration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf64885-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50503/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fixed price","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Such contracts shall provide for delivery of the good or service on a firm, fixed price basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf64886-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50503/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance specifications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent practicable, reasonable performance specifications shall be used to define technical requirements in such contracts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf64887-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50503/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Failure to perform","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any such contract, the appropriate Administrator shall reserve the right to completely or partially terminate the contract without payment of such termination liability because of the contractor’s actual or anticipated failure to perform its contractual obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebf64888-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3405"},"text":"124 Stat. 3405","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebf64889-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebf6488a-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebf6488b-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"50503","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t15/s5806"},"text":"15 U.S.C. 5806","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/102/588/tV/s507"},"text":"Pub. L. 102–588, title V, § 507","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/5127"},"text":"106 Stat. 5127","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
