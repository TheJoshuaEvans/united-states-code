{"tag":"section","attrib":{"id":"idec022f18-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51102"},"text":null,"children":[{"tag":"num","attrib":{"value":"51102"},"text":"§ 51102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec022f19-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To ensure the resiliency of the space transportation infrastructure of the United States, the Secretary of Transportation may make project grants to sponsors as provided in this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec022f1a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make a project grant under this chapter only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec022f1b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 10 percent of the total cost of the project will be paid by the private sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec022f1c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grant will not be for more than 50 percent of the total cost of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec022f1d-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1343"},"text":"108 Stat. 1343","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s70302"},"text":"§ 70302 of title 49","children":[],"tail":"; renumbered § 70302 then "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s51102"},"text":"§ 51102 of title 51","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/111/314/s4/d/2"},"text":"Pub. L. 111–314, § 4(d)(2)","children":[],"tail":", (4)(B), "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3440"},"text":"124 Stat. 3440","children":[],"tail":", 3441.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec022f1e-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idec022f1f-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idec022f20-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":