{"tag":"section","attrib":{"id":"idec0e159b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70710"},"text":null,"children":[{"tag":"num","attrib":{"value":"70710"},"text":"§ 70710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements and termination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec0e159c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70710/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interim Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Commission may submit to the President and Congress interim reports containing such findings, conclusions, and recommendations for corrective actions as have been agreed to by a majority of Commission members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec0e159d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70710/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Final Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Commission shall submit to the President and Congress, and make concurrently available to the public, a final report containing such findings, conclusions, and recommendations for corrective actions as have been agreed to by a majority of Commission members. Such report shall include any minority views or opinions not reflected in the majority report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec0e159e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70710/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idec0e159f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70710/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Commission, and all the authorities of this chapter with respect to that Commission, shall terminate 60 days after the date on which the final report is submitted under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec0e15a0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70710/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative activities before termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Commission may use the 60-day period referred to in paragraph (1) for the purpose of concluding its activities, including providing testimony to committees of Congress concerning its reports and disseminating the final report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec0e15a1-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3436"},"text":"124 Stat. 3436","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec0e15a2-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note",