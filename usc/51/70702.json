{"tag":"section","attrib":{"id":"idec0e153e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70702"},"text":null,"children":[{"tag":"num","attrib":{"value":"70702"},"text":"§ 70702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec0e153f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall establish an independent, nonpartisan Commission within the executive branch to investigate any incident that results in the loss of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec0e1540-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a space shuttle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec0e1541-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the International Space Station or its operational viability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec0e1542-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70702/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any other orbital or suborbital space vehicle carrying humans that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idec0e1543-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70702/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned by the Federal Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idec0e1544-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70702/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" being used pursuant to a contract or Space Act Agreement with the Federal Government for carrying a government astronaut or a researcher funded by the Federal Government; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec0e1545-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70702/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a crew member or passenger of any space vehicle described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec0e1546-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall establish a Commission within 7 days after an incident specified in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec0e1547-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s70702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail"