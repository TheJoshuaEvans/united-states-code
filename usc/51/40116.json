{"tag":"section","attrib":{"id":"idebecd21e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40116"},"text":null,"children":[{"tag":"num","attrib":{"value":"40116"},"text":"§ 40116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" University-based Centers for Research on Aviation Training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebecd21f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall award grants to institutions of higher education (or consortia thereof) to establish one or more Centers for Research on Aviation Training under cooperative agreements with appropriate Administration Centers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebecd220-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of the Centers for Research on Aviation Training shall be to investigate the impact of new technologies and procedures, particularly those related to the aircraft flight deck and to the air traffic management functions, on training requirements for pilots and air traffic controllers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebecd221-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40116/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An institution of higher education (or a consortium of such institutions) seeking funding under this section shall submit an application to the Administrator at such time, in such manner, and containing such information as the Administrator may require, including, at a minimum, a 5-year research plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebecd222-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40116/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Award Duration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An award made by the Administrator under this section shall be for a period of 5 years and may be renewed on the basis of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebecd223-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40116/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfactory performance in meeting the goals of the research plan proposed in the application submitted under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebecd224-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40116/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other requirements as specified by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebecd225-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3381"},"text":"124 Stat. 3381","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebecd226-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebecd227-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebecd228-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40116","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s16727"},"text":"42 U.S.C. 16727","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/109/155/tIV/s427"},"text":"Pub. L. 109–155, title IV, § 427","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 30, 2005","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/119/2926"},"text":"119 Stat. 2926","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/110/422/tIII/s308"},"text":"Pub. L. 110–422, title III, § 308","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 2008","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/122/4788"},"text":"122 Stat. 4788","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Centers for Research on Aviation Training” are substituted for “Centers” for clarity. There are references to both “Centers for Research on Aviation Training” and “Administration Centers” in subsection (a).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(1), the words “proposed in the application submitted under subsection (c)” are substituted for “proposed by the Center in its application under subsection (c)” for clarity. Under section (c), applications are filed by an institution of higher education (or a consortium of such institutions) seeking funding, and not by the Center for which such funding is sought.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
