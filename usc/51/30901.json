{"tag":"section","attrib":{"id":"idebea6134-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30901"},"text":null,"children":[{"tag":"num","attrib":{"value":"30901"},"text":"§ 30901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional Space Medal of Honor","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebea6135-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Award","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President may award, and present in the name of Congress, a medal of appropriate design, which shall be known as the Congressional Space Medal of Honor, to any astronaut who in the performance of the astronaut’s duties has distinguished himself or herself by exceptionally meritorious efforts and contributions to the welfare of the Nation and of humankind.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebea6136-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s30901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated from time to time such sums of money as may be necessary to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebea6137-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "