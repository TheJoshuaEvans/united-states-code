{"tag":"section","attrib":{"id":"idebf6480d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50134"},"text":null,"children":[{"tag":"num","attrib":{"value":"50134"},"text":"§ 50134.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of excess intercontinental ballistic missiles","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebf6480e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50134/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Government shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebf6480f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50134/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convert any missile described in subsection (c) to a space transportation vehicle configuration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf64810-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50134/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer ownership of any such missile to another person, except as provided in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebf64811-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50134/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Federal Uses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebf64812-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50134/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A missile described in subsection (c) may be converted for use as a space transportation vehicle by the Federal Government if, except as provided in paragraph (2) and at least 30 days before such conversion, the agency seeking to use the missile as a space transportation vehicle transmits to the Committee on Armed Services and the Committee on Science and Technology of the House of Representatives, and to the Committee on Armed Services and the Committee on Commerce, Science, and Transportation of the Senate, a certification that the use of such missile—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebf64813-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50134/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would result in cost savings to the Federal Government when compared to the cost of acquiring space transportation services from United States commercial providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf64814-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50134/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets all mission requirements of the agency, including performance, schedule, and risk requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf64815-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50134/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with international obligations of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebf64816-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50134/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is approved by the Secretary of Defense or the designee of the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf64817-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50134/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception to requirement that certification be transmitted 30 days before conversion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirement under paragraph (1) that the certification described in that paragraph must be transmitted at least 30 days before conversion of the missile shall not apply if the Secretary of Defense determines that compliance with that requirement would be inconsistent with meeting immediate national security requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebf64818-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50134/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Missiles Referred to","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The missiles referred to in this section are missiles owned by the United States that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebf64819-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50134/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were formerly used by the Department of Defense for national defense purposes as intercontinental ballistic missiles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebf6481a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50134/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have been declared excess to United States national defense needs and are in compliance with international obligations of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebf6481b-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3400"},"text":"124 Stat. 3400","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebf6481c-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebf6481d-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebf6481e-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"50134","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s14734"},"text":"42 U.S.C. 14734","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/105/303/tII/s205"},"text":"Pub. L. 105–303, title II, § 205","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/2857"},"text":"112 Stat. 2857","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/106/65/dA/tX/s1067/21"},"text":"Pub. L. 106–65, div. A, title X, § 1067(21)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/113/775"},"text":"113 Stat. 775","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), in the matter before subparagraph (A), the words “Committee on Science and Technology” are substituted for “Committee on Science” on authority of Rule X(1)(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of the Rules of the House of Representatives, adopted by House Resolution No. 6 (110th Congress, "},{"tag":"date","attrib":{"date":"2007-01-05"},"text":"January 5, 2007","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idebf6481f-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idebf64820-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Science and Technology of House of Representatives changed to Committee on Science, Space, and Technology of House of Representatives by House Resolution No. 5, One Hundred Twelfth Congress, ","children":[{"tag":"date","attrib":{"date":"2011-01-05"},"text":"Jan. 5, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
