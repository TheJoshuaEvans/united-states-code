{"tag":"section","attrib":{"id":"idebfd73ed-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50912"},"text":null,"children":[{"tag":"num","attrib":{"value":"50912"},"text":"§ 50912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative hearings and judicial review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebfd73ee-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Hearings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall provide an opportunity for a hearing on the record to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebfd73ef-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50912/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an applicant under this chapter, for a decision of the Secretary under section 50905(a) or 50906 of this title to issue or transfer a license with terms or deny the issuance or transfer of a license;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebfd73f0-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50912/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an owner or operator of a payload under this chapter, for a decision of the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s50904/c"},"text":"section 50904(c) of this title","children":[],"tail":" to prevent the launch or reentry of the payload; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebfd73f1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50912/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a licensee under this chapter, for a decision of the Secretary under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebfd73f2-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50912/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 50908(b) or (c) of this title to modify, suspend, or revoke a license; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebfd73f3-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50912/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s50909/a"},"text":"section 50909(a) of this title","children":[],"tail":" to prohibit, suspend, or end a launch or operation of a launch site or reentry site, or reentry of a reentry vehicle, licensed by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebfd73f4-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Judicial Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A final action of the Secretary under this chapter is subject to judicial review as provided in chapter 7 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebfd73f5-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"t