{"tag":"section","attrib":{"id":"idec049f79-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51501"},"text":null,"children":[{"tag":"num","attrib":{"value":"51501"},"text":"§ 51501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Office of Spaceports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec049f7a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Office","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of enactment of this section, the Secretary of Transportation shall identify, within the Office of Commercial Space Transportation, a centralized policy office to be known as the Office of Spaceports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec049f7b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office of Spaceports shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec049f7c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51501/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support licensing activities for operation of launch and reentry sites;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec049f7d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51501/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop policies that promote infrastructure improvements at spaceports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec049f7e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51501/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance and guidance to spaceports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec049f7f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51501/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote United States spaceports within the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec049f80-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51501/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen the Nation’s competitiveness in commercial space transportation infrastructure and increase resilience for the Federal Government and commercial customers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec049f81-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recognition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the functions assigned in subsection (b), the Secretary shall recognize the unique needs and distinctions of spaceports that host— ","children":[{"tag":"ref","attrib":{"idref":"fn002013"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002013"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The dash probably should follow “that” and the word “host” probably should appear at the beginning of par. (1)."}],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idec049f82-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51501/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" launches to or reentries from orbit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec049f83-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51501/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are involved in suborbital launch activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec049f84-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51501/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of the Office of the Associate Administrator for Commercial Space Transportation shall designate a Director of the Office of Spaceports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec049f85-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s51501/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section the term “spaceport” means a launch or reentry site that is operated by an entity licensed by the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec049f86-3a70-11f1-9081-fe88c1712d53"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tV/s580/b/1"},"text":"Pub. L. 115–254, div. B, title V, § 580(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3395"},"text":"132 Stat. 3395","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec049f87-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idec049f88-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idec049f89-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
