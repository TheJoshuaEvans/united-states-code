{"tag":"section","attrib":{"id":"idec06e96c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60142"},"text":null,"children":[{"tag":"num","attrib":{"value":"60142"},"text":"§ 60142.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Archiving of data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec06e96d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60142/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Interest","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is in the public interest for the United States Government to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec06e96e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60142/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain an archive of land remote sensing data for historical, scientific, and technical purposes, including long-term global environmental monitoring;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec06e96f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60142/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" control the content and scope of the archive; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec06e970-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60142/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the quality, integrity, and continuity of the archive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec06e971-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60142/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Archiving Practices","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Interior, in consultation with the Landsat Program Management, shall provide for long-term storage, maintenance, and upgrading of a basic, global, land remote sensing data set (hereafter in this section referred to as the “basic data set”) and shall follow reasonable archival practices to ensure proper storage and preservation of the basic data set and timely access for parties requesting data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec06e972-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60142/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of Content of Basic Data Set","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the initial content of, or in upgrading, the basic data set, the Secretary of the Interior shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec06e973-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60142/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use as a baseline the data archived on ","children":[{"tag":"date","attrib":{"date":"1992-10-28"},"text":"October 28, 1992","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec06e974-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60142/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into account future technical and scientific developments and needs, paying particular attention to the anticipated data requirements of global environmental change research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec06e975-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60142/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with and seek the advice of users and producers of remote sensing data and data products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec06e976-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60142/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the need for data which may be duplicative in terms of geographical coverage but which differ in terms of season, spectral bands, resolution, or other relevant factors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec06e977-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60142/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include, as the Secretary of the Interior considers appropriate, unenhanced data generated either by the Landsat system, pursuant to subchapter II, or by licensees under subchapter III;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec06e978-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60142/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include, as the Secretary of the Interior considers appropriate, data collected by foreign ground stations or by foreign remote sensing space systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec06e979-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60142/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the content of the archive is developed in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s60146"},"text":"section 60146 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec06e97a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60142/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Domain","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After the expiration of any exclusive right to sell, or after relinquishment of such right, the data provided to the National Satellite Land Remote Sensing Data Archive shall be in the public domain and shall be made available to requesting parties by the Secretary of the Interior at the cost of fulfilling user requests.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec06e97b-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3419"},"text":"124 Stat. 3419","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec06e97c-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idec06e97d-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idec06e97e-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60142","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t15/s5652"},"text":"15 U.S.C. 5652","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/102/555/tV/s502"},"text":"Pub. L. 102–555, title V, § 502","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/4176"},"text":"106 Stat. 4176","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “hereafter in this section” are substituted for “hereinafter” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), in the matter before paragraph (1), the words “of the Interior” are substituted for “of Interior” to correct an error in the law.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the date “","children":[{"tag":"date","attrib":{"date":"1992-10-28"},"text":"October 28, 1992","children":[],"tail":"” is substituted for “the date of enactment of this Act” to reflect the date of enactment of the Land Remote Sensing Policy Act of 1992 ("},{"tag":"ref","attrib":{"href":"/us/pl/102/555"},"text":"Public Law 102–555","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4163"},"text":"106 Stat. 4163","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
