{"tag":"section","attrib":{"id":"idec0bcba2-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60605"},"text":null,"children":[{"tag":"num","attrib":{"value":"60605"},"text":"§ 60605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Space weather data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec0bcba3-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the National Aeronautics and Space Administration and the Director of the National Science Foundation shall continue to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec0bcba4-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60605/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make space weather-related data obtained for scientific research purposes available to space weather forecasters and operations centers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec0bcba5-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60605/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support model development and model applications to space weather forecasting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec0bcba6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Research","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the National Oceanic and Atmospheric Administration shall make space weather-related data obtained from operational forecasting available for research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec0bcba7-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/181/s2/b"},"text":"Pub. L. 116–181, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-21"},"text":"Oct. 21, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/890"},"text":"134 Stat. 890","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
