{"tag":"section","attrib":{"id":"idec06e9c5-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60302"},"text":null,"children":[{"tag":"num","attrib":{"value":"60302"},"text":"§ 60302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General responsibilities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec06e9c6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60302/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a sustained relationship with the United States commercial remote sensing industry and, consistent with applicable policies and law, to the maximum practicable, rely on their services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec06e9c7-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60302/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in conjunction with United States industry and universities, research, develop, and demonstrate prototype Earth science applications to enhance Federal, State, local, and tribal governments’ use of government and commercial remote sensing data, technologies, and other sources of geospatial information for improved decision support to address their needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec06e9c8-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3423"},"text":"124 Stat. 3423","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","