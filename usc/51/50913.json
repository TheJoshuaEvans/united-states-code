{"tag":"section","attrib":{"id":"idebfd73fb-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50913"},"text":null,"children":[{"tag":"num","attrib":{"value":"50913"},"text":"§ 50913.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquiring United States Government property and services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebfd73fc-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50913/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Requirements and Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebfd73fd-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50913/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Transportation shall facilitate and encourage the acquisition by the private sector and State governments of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebfd73fe-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50913/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" launch or reentry property of the United States Government that is excess or otherwise is not needed for public use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebfd73ff-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50913/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" launch services and reentry services, including utilities, of the Government otherwise not needed for public use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebfd7400-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50913/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In acting under paragraph (1) of this subsection, the Secretary shall consider the commercial availability on reasonable terms of substantially equivalent launch property or launch services or reentry services from a domestic source, whether such source is located on or off a Federal range.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebfd7401-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50913/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Price","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idebfd7402-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50913/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection, “direct costs” means the actual costs that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebfd7403-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50913/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can be associated unambiguously with a commercial launch or reentry effort; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebfd7404-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50913/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government would not incur if there were no commercial launch or reentry effort.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebfd7405-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50913/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In consultation with the Secretary, the head of the executive agency providing the property or service under subsection (a) of this section shall establish the price for the property or service. The price for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebfd7406-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50913/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquiring launch property by sale or transaction instead of sale is the fair market value;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebfd7407-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50913/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquiring launch property (except by sale or transaction instead of sale) is an amount equal to the direct costs, including specific wear and tear and property damage, the Government incurred because of acquisition of the property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebfd7408-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50913/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" launch services or reentry services is an amount equal to the direct costs, including the basic pay of Government civilian and contractor personnel, the Government incurred because of acquisition of the services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebfd7409-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50913/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure the establishment of uniform guidelines for, and consistent implementation of, this section by all Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebfd740a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50913/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Collection by Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may collect a payment under this section with the consent of the head of the executive agency establishing the price. Amounts collected under this subsection shall be deposited in the Treasury. Amounts (except for excess launch property) shall be credited to the appropriation from which the cost of providing the property or services was paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebfd740b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s50913/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Collection by Other Governmental Heads","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of a department, agency, or instrumentality of the Government may collect a payment for an activity involved in producing a launch vehicle or reentry vehicle, or the payload of either, for launch or reentry if the activity was agreed to by the owner or manufacturer of the launch vehicle, reentry vehicle, or payload.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebfd740c-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1335"},"text":"108 Stat. 1335","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s70111"},"text":"§ 70111 of title 49","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/303/tI/s102/a/11"},"text":"Pub. L. 105–303, title I, § 102(a)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-28"},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2849"},"text":"112 Stat. 2849","children":[],"tail":"; renumbered § 70111 then "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s50913"},"text":"§ 50913 of title 51","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/111/314/s4/d/2"},"text":"Pub. L. 111–314, § 4(d)(2)","children":[],"tail":", (3)(M), "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3440"},"text":"124 Stat. 3440","children":[],"tail":", 3441.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebfd740d-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebfd740e-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebfd740f-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70111(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2614(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/575/s15/a"},"text":"Pub. L. 98–575, § 15(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/3060"},"text":"98 Stat. 3060","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 15, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/657/s4/a"},"text":"Pub. L. 100–657, § 4(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/3900"},"text":"102 Stat. 3900","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/611/s117/b"},"text":"Pub. L. 101–611, § 117(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/3202"},"text":"104 Stat. 3202","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70111(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2614(b)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/575/s15/b/1"},"text":"Pub. L. 98–575, § 15(b)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/3061"},"text":"98 Stat. 3061","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 15, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/657/s4/b"},"text":"Pub. L. 100–657, § 4(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/3901"},"text":"102 Stat. 3901","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70111(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2614(b)(2), (3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/575/s15/b/2"},"text":"Pub. L. 98–575, § 15(b)(2)","children":[],"tail":", (3), "},{"tag":"html:a","attrib":{"href":"/us/stat/98/3061"},"text":"98 Stat. 3061","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70111(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2614(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/575"},"text":"Pub. L. 98–575","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/3055"},"text":"98 Stat. 3055","children":[],"tail":", § 15(d); added "},{"tag":"html:span","attrib":{},"text":"Nov. 15, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/657/s4/c"},"text":"Pub. L. 100–657, § 4(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/3901"},"text":"102 Stat. 3901","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), before clause (A), the words “take such actions as may be necessary to” and “(by lease, sale, transaction in lieu of sale, or otherwise)” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b)(2) and (c), the words “the head of” are added for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), before clause (A), the word “price” is substituted for “amount to be paid to the United States” and “the amount of such payment” to eliminate unnecessary words. The words “by any person who acquires launch property or launch services, including utilities” are omitted as surplus. In clause (C), the words “including utilities” are omitted as surplus. The words “basic pay” are substituted for “salaries” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “collected” is substituted for “received” for consistency in this section. The words “by the United States for launch property or launch services, including utilities” and “the general fund of” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “department, agency, or instrumentality of the Government” are substituted for “Federal agency or department” for consistency in the revised title and with other titles of the Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idebfd7410-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idebfd7411-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314"},"text":"Pub. L. 111–314","children":[],"tail":" successively renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s70111"},"text":"section 70111 of title 49","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s70111"},"text":"section 70111 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/303/s102/a/11/A"},"text":"Pub. L. 105–303, § 102(a)(11)(A)","children":[],"tail":", inserted “or reentry” after “launch”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/303/s102/a/11/B"},"text":"Pub. L. 105–303, § 102(a)(11)(B)","children":[],"tail":", inserted “and reentry services” after “launch services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/303/s102/a/11/C"},"text":"Pub. L. 105–303, § 102(a)(11)(C)","children":[],"tail":", (D), inserted “or reentry services” after “or launch services” and substituted “source, whether such source is located on or off a Federal range” for “source”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/303/s102/a/11/E"},"text":"Pub. L. 105–303, § 102(a)(11)(E)","children":[],"tail":", inserted “or reentry” after “commercial launch”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/303/s102/a/11/F"},"text":"Pub. L. 105–303, § 102(a)(11)(F)","children":[],"tail":", inserted “or reentry services” after “launch services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/303/s102/a/11/G"},"text":"Pub. L. 105–303, § 102(a)(11)(G)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/303/s102/a/11/H"},"text":"Pub. L. 105–303, § 102(a)(11)(H)","children":[],"tail":", (I), substituted “or reentry vehicle, or the payload of either, for launch or reentry” for “or its payload for launch” and inserted “, reentry vehicle,” after “manufacturer of the launch vehicle”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
