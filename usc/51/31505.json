{"tag":"section","attrib":{"id":"idebea61b1-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31505"},"text":null,"children":[{"tag":"num","attrib":{"value":"31505"},"text":"§ 31505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of enhanced-use lease policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebea61b2-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall develop an agency-wide enhanced-use lease policy that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebea61b3-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31505/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is based upon sound business practices and lessons learned from the demonstration centers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebea61b4-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31505/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes controls and procedures to ensure accountability and protect the interests of the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebea61b5-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The policy required by subsection (a) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebea61b6-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31505/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria for determining economic value","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Criteria for determining whether enhanced-use lease provides better economic value to the Government than other options, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idebecd1b7-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31505/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal financing through appropriations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idebecd1b8-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31505/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sale of the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebecd1b9-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31505/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Security and access","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Requirement for the identification of proposed physical and procedural changes needed to ensure security and restrict access to specified areas, coordination of proposed changes with existing site tenants, and development of estimated costs of such changes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebecd1ba-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31505/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Measures of effectiveness","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Measures of effectiveness for the enhanced-use lease program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebecd1bb-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s31505/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accounting controls","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Accounting controls and procedures to ensure accountability, such as an audit trail and documentation to readily support financial transactions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebecd1bc-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3377"},"text":"124 Stat. 3377","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebecd1bd-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebecd1be-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebecd1bf-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"