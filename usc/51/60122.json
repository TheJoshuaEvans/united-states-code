{"tag":"section","attrib":{"id":"idec04a005-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60122"},"text":null,"children":[{"tag":"num","attrib":{"value":"60122"},"text":"§ 60122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for operation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idec04a006-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"License Required for Operation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No person that is subject to the jurisdiction or control of the United States may, directly or through any subsidiary or affiliate, operate any private remote sensing space system without a license pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s60121"},"text":"section 60121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec04a007-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Licensing Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any license issued pursuant to this subchapter shall specify that the licensee shall comply with all of the requirements of this chapter and shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec04a008-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60122/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate the system in such manner as to preserve the national security of the United States and to observe the international obligations of the United States in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s60146"},"text":"section 60146 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec04a009-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60122/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available to the government of any country (including the United States) unenhanced data collected by the system concerning the territory under the jurisdiction of such government as soon as such data are available and on reasonable terms and conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec04a00a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60122/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make unenhanced data designated by the Secretary in the license pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s60121/e"},"text":"section 60121(e) of this title","children":[],"tail":" available in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s60141"},"text":"section 60141 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec04a00b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60122/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon termination of operations under the license, make disposition of any satellites in space in a manner satisfactory to the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec04a00c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60122/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnish the Secretary with complete orbit and data collection characteristics of the system, and inform the Secretary immediately of any deviation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec04a00d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60122/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the Secretary of any significant or substantial agreement the licensee intends to enter with a foreign nation, entity, or consortium involving foreign nations or entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idec04a00e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60122/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Licensing Requirements for Landsat","children":[],"tail":" 6 "},{"tag":"inline","attrib":{},"text":"Contractor","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the requirements of subsection (b), any license issued pursuant to this subchapter to the Landsat 6 contractor shall specify that the Landsat 6 contractor shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idec04a00f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60122/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the Secretary of any value added activities (as defined by the Secretary by regulation) that will be conducted by the Landsat 6 contractor or by a subsidiary or affiliate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idec04a010-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s60122/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such activities are to be conducted, provide the Secretary with a plan for compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s60141"},"text":"section 60141 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idec04a011-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3415"},"text":"124 Stat. 3415","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idec04a012-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idec04a013-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idec04a014-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60122","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t15/s5622"},"text":"15 U.S.C. 5622","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/102/555/tII/s202"},"text":"Pub. L. 102–555, title II, § 202","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/4172"},"text":"106 Stat. 4172","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/303/tI/s107/f/2"},"text":"Pub. L. 105–303, title I, § 107(f)(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 28, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/2854"},"text":"112 Stat. 2854","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), in the matter before paragraph (1), the words “subsection (b)” are substituted for “paragraph (b)” to correct an error in the law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
