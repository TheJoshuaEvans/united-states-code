{"tag":"section","attrib":{"id":"idebef1c50-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40303"},"text":null,"children":[{"tag":"num","attrib":{"value":"40303"},"text":"§ 40303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National space grant college and fellowship program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idebef1c51-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall establish and maintain, within the Administration, a program to be known as the national space grant college and fellowship program. The national space grant college and fellowship program shall consist of the financial assistance and other activities provided for in this chapter. The Administrator shall establish long-range planning guidelines and priorities, and adequately evaluate the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebef1c52-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within the Administration, the program shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebef1c53-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply the long-range planning guidelines and the priorities established by the Administrator under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1c54-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Administrator with respect to the expertise and capabilities which are available through the national space grant college and fellowship program, and make such expertise available to the Administration as directed by the Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1c55-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40303/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate activities conducted under grants and contracts awarded pursuant to sections 40304 and 40305 of this title to ensure that the purposes set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s40301"},"text":"section 40301 of this title","children":[],"tail":" are implemented;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1c56-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40303/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage other Federal departments, agencies, and instrumentalities to use and take advantage of the expertise and capabilities which are available through the national space grant college and fellowship program, on a cooperative or other basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1c57-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40303/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage cooperation and coordination with other Federal programs concerned with the development of space resources and fields related to space;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1c58-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40303/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Administrator on the designation of recipients supported by the national space grant college and fellowship program and, in appropriate cases, on the termination or suspension of any such designation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1c59-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40303/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the formation and growth of space grant and fellowship programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebef1c5a-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out the provisions of this chapter, the Administrator may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebef1c5b-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40303/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept conditional or unconditional gifts or donations of services, money, or property, real, personal or mixed, tangible or intangible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1c5c-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40303/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept and use funds from other Federal departments, agencies, and instrumentalities to pay for fellowships, grants, contracts, and other transactions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1c5d-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40303/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue such rules and regulations as may be necessary and appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebef1c5e-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Administration Costs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the provisions of this chapter, the Administrator—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebef1c5f-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40303/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall maximize appropriated funds for grants and contracts made under section 40304 in each fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1c60-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40303/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in each fiscal year, the Administrator shall limit its program administration costs to no more than 5 percent of funds appropriated for this program for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idebef1c61-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40303/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any fiscal year in which the Administrator cannot meet the administration cost target under subsection (d)(2), if the Administration is unable to limit program costs under subsection (b), the Administrator shall submit to the appropriate committees of Congress a report, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idebef1c62-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40303/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of why the Administrator did not meet the cost target under subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idebef1c63-3a70-11f1-9081-fe88c1712d53","identifier":"/us/usc/t51/s40303/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the measures the Administrator will take in the next fiscal year to meet the cost target under subsection (d) without drawing upon other Federal funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idebef1c64-3a70-11f1-9081-fe88c1712d53"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s3"},"text":"Pub. L. 111–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3383"},"text":"124 Stat. 3383","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tIII/s302/b"},"text":"Pub. L. 114–329, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/3003"},"text":"130 Stat. 3003","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idebef1c65-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idebef1c66-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idebef1c67-3a70-11f1-9081-fe88c1712d53"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40303","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s2486c"},"text":"42 U.S.C. 2486c","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/100/147/tII/s205"},"text":"Pub. L. 100–147, title II, § 205","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/101/871"},"text":"101 Stat. 871","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idebef1c68-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idebef1c69-3a70-11f1-9081-fe88c1712d53"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329"},"text":"Pub. L. 114–329","children":[],"tail":" added subsecs. (d) and (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
