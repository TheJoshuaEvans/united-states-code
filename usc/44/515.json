{"tag":"section","attrib":{"id":"id121e2950-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s515"},"text":null,"children":[{"tag":"num","attrib":{"value":"515"},"text":"§ 515.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Default of contractor; new contracts and purchase in open market","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If a contractor fails to comply with his contract, the Director of the Government Publishing Office shall report the default to the Joint Committee on Printing, and under its direction, enter into a new contract with the lowest, best, and most responsible bidder for the interest of the Government among those whose proposals were rejected at the last opening of bids, or he shall advertise for new proposals, under the regulations provided by sections 509–517 of this title. During the interval that may thus occur he may, under the direction of the Joint Committee on Printing, purchase in open market, at the lowest market price, paper necessary for the public printing.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id121e2951-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1245"},"text":"82 Stat. 1245","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id121e2952-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id121e2953-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 11 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s9"},"text":"Jan. 12, 1895, ch. 23, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/602"},"text":"28 Stat. 602","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1917-03-03/ch163/s6"},"text":"Mar. 3, 1917, ch. 163, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/1121"},"text":"39 Stat. 1121","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id121e2954-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id121e2955-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
