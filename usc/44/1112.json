{"tag":"section","attrib":{"id":"id12255500-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1112"},"text":null,"children":[{"tag":"num","attrib":{"value":"1112"},"text":"§ 1112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports: type for reports of executive officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The annual reports of executive officers shall be printed in the same type and form as the report of the head of the department which it accompanies, unless otherwise ordered by the Joint Committee on Printing.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12255501-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1263"},"text":"82 Stat. 1263","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12255502-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12255503-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 222 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s91"},"text":"Jan. 12, 1895, ch. 23, § 91","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/623"},"text":"28 Stat. 623","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
