{"tag":"section","attrib":{"id":"id1252a76e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3519"},"text":null,"children":[{"tag":"num","attrib":{"value":"3519"},"text":"§ 3519.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to information","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Under the conditions and procedures prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s716"},"text":"section 716 of title 31","children":[],"tail":", the Director and personnel in the Office of Information and Regulatory Affairs shall furnish such information as the Comptroller General may require for the discharge of the responsibilities of the Comptroller General. For the purpose of obtaining such information, the Comptroller General or representatives thereof shall have access to all books, documents, papers and records, regardless of form or format, of the Office."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id1252a76f-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/13/s2"},"text":"Pub. L. 104–13, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-05-22"},"text":"May 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/183"},"text":"109 Stat. 183","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1252a770-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1252a771-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id1252a772-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text