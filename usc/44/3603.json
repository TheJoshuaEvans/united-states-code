{"tag":"section","attrib":{"id":"id125e8e2f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603"},"text":null,"children":[{"tag":"num","attrib":{"value":"3603"},"text":"§ 3603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Information Officers Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id125e8e30-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established in the executive branch a Chief Information Officers Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125e8e31-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The members of the Council shall be as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id125e8e32-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Deputy Director for Management of the Office of Management and Budget, who shall act as chairperson of the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e33-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Office of Electronic Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e34-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Office of Information and Regulatory Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e35-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chief information officer of each agency described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s901/b"},"text":"section 901(b) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e36-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chief information officer of the Central Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e37-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chief information officer of the Department of the Army, the Department of the Navy, and the Department of the Air Force, if chief information officers have been designated for such departments under section 3506(a)(2)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e38-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other officer or employee of the United States designated by the chairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125e8e39-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id125e8e3a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Office of Electronic Government shall lead the activities of the Council on behalf of the Deputy Director for Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e3b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id125e8e3c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Vice Chairman of the Council shall be selected by the Council from among its members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e3d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Vice Chairman shall serve a 1-year term, and may serve multiple terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e3e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of General Services shall provide administrative and other support for the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125e8e3f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Council is designated the principal interagency forum for improving agency practices related to the design, acquisition, development, modernization, use, operation, sharing, and performance of Federal Government information resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125e8e40-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In performing its duties, the Council shall consult regularly with representatives of State, local, and tribal governments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125e8e41-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Council shall perform functions that include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id125e8e42-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Develop recommendations for the Director on Government information resources management policies and requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e43-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Share experiences, ideas, best practices, and innovative approaches related to information resources management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e44-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assist the Administrator in the identification, development, and coordination of multiagency projects and other innovative initiatives to improve Government performance through the use of information technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e45-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promote the development and use of common performance measures for agency information resources management under this chapter and title II of the E-Government Act of 2002.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e46-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Work as appropriate with the National Institute of Standards and Technology and the Administrator to develop recommendations on information technology standards developed under section 20 of the National Institute of Standards and Technology Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278g–3"},"text":"15 U.S.C. 278g–3","children":[],"tail":") and promulgated under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s11331"},"text":"section 11331 of title 40","children":[],"tail":", and maximize the use of commercial standards as appropriate, including the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id125e8e47-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/f/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Standards and guidelines for interconnectivity and interoperability as described under section 3504.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e48-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/f/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consistent with the process under section 207(d) of the E-Government Act of 2002, standards and guidelines for categorizing Federal Government electronic information to enable efficient use of technologies, such as through the use of extensible markup language.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e49-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/f/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Standards and guidelines for Federal Government computer system efficiency and security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e4a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Work with the Office of Personnel Management to assess and address the hiring, training, classification, and professional development needs of the Government related to information resources management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e4b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3603/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Work with the Archivist of the United States to assess how the Federal Records Act can be addressed effectively by Federal information resources management activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id125e8e4c-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/347/tI/s101/a"},"text":"Pub. L. 107–347, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2905"},"text":"116 Stat. 2905","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id125e8e4d-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id125e8e4e-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id125e8e4f-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The E-Government Act of 2002, referred to in subsec. (f)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/347"},"text":"Pub. L. 107–347","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2899"},"text":"116 Stat. 2899","children":[],"tail":". Title II of the Act, including section 207(d) of the Act, is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3501"},"text":"section 3501 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"No act with the name the “Federal Records Act”, referred to in subsec. (f)(7), has been enacted. The Federal Records Act of 1950, which has a similar name, was title V of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"act June 30, 1949, ch. 288","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-05/ch849/s6/d"},"text":"Sept. 5, 1950, ch. 849, § 6(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/583"},"text":"64 Stat. 583","children":[],"tail":", which was classified generally to sections 392 to 396 and 397 to 401 of former Title 44, Public Printing and Documents. Section 6(d) of act "},{"tag":"date","attrib":{"date":"1950-09-05"},"text":"Sept. 5, 1950","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1238"},"text":"82 Stat. 1238","children":[],"tail":", the first section of which enacted this title. For disposition of sections of former Title 44, see Table at the beginning of this title. Title V of act "},{"tag":"date","attrib":{"date":"1949-06-30"},"text":"June 30, 1949","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s4"},"text":"Pub. L. 107–217, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id125e8e50-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id125e8e51-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 120 days after ","children":[{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/s402/a"},"text":"section 402(a) of Pub. L. 107–347","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3601"},"text":"section 3601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
