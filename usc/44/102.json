{"tag":"section","attrib":{"id":"id12148c3c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s102"},"text":null,"children":[{"tag":"num","attrib":{"value":"102"},"text":"§ 102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint Committee on Printing: succession; powers during recess","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The members of the Joint Committee on Printing who are reelected to the succeeding Congress shall continue as members of the committee until their successors are chosen. The President of the Senate and the Speaker of the House of Representatives shall, on the last day of a Congress, appoint members of their respective Houses who have been elected to the succeeding Congress to fill vacancies which may then be about to occur on the Committee, and the appointees and members of the Committee who have been reelected shall continue until their successors are chosen.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"When Congress is not in session, the Joint Committee may exercise all its powers and duties as when Congress is in session.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12148c3d-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1238"},"text":"82 Stat. 1238","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12148c3e-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12148c3f-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 2 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-03-02/ch189/s1"},"text":"Mar. 2, 1895, ch. 189, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/962"},"text":"28 Stat. 962","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1917-03-03/ch163/s6"},"text":"Mar. 3, 1917, ch. 163, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/1121"},"text":"39 Stat. 1121","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes are made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
