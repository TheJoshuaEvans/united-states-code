{"tag":"section","attrib":{"id":"id122554d9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1106"},"text":null,"children":[{"tag":"num","attrib":{"value":"1106"},"text":"§ 1106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inserting “compliments” forbidden","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A report, document, or publication distributed by or from an executive department or independent agency or establishment of the Government may not contain a notice that it is sent with “the compliments” of an officer of the Government, or with a special notice that it is so sent, except that notice that it has been sent, with a request for an acknowledgment of its receipt, may be given.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122554da-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1261"},"text":"82 Stat. 1261","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122554db-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122554dc-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 218 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s73"},"text":"Jan. 12, 1895, ch. 23, § 73","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/620"},"text":"28 Stat. 620","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
