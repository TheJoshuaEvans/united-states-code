{"tag":"section","attrib":{"id":"id1246bfbc-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3312"},"text":null,"children":[{"tag":"num","attrib":{"value":"3312"},"text":"§ 3312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Photographs or microphotographs of records considered as originals; certified reproductions admissible in evidence","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Photographs, microphotographs of records, or digitized records made in compliance with regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3302"},"text":"section 3302 of this title","children":[],"tail":" shall have the same effect as the originals and shall be treated as originals for the purpose of their admissibility in evidence. Certified or authenticated reproductions of the photographs, microphotographs, or digitized records shall be admitted in evidence equally with the original photographs, microphotographs, or digitized records."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id1246bfbd-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1302"},"text":"82 Stat. 1302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/187/s5/e"},"text":"Pub. L. 113–187, § 5(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2010"},"text":"128 Stat. 2010","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1246bfbe-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id1246bfbf-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 378 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1943-07-07/ch192/s13"},"text":"July 7, 1943, ch. 192, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/57/382"},"text":"57 Stat. 382","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1246bfc0-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1246bfc1-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/187"},"text":"Pub. L. 113–187","children":[],"tail":" substituted “Photographs, microphotographs of records, or digitized records” for “Photographs or microphotographs of records” and substituted “photographs, microphotographs, or digitized records” for “photographs or microphotographs” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
