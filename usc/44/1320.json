{"tag":"section","attrib":{"id":"id12279fb7-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1320"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320"},"text":"§ 1320.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geological Survey: distribution of publications to public libraries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Geological Survey shall distribute to public libraries that have not already received them, copies of sale publications on hand at the expiration of five years after date of delivery to the Survey document room, excepting a reserve number not to exceed two hundred copies.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12279fb8-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1269"},"text":"82 Stat. 1269","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12279fb9-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12279fba-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 262 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1903-03-03/ch1007/s1"},"text":"Mar. 3, 1903, ch. 1007, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/1146"},"text":"32 Stat. 1146","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id12279fbb-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id12279fbc-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Geological Survey redesignated United States Geological Survey by provision of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/154"},"text":"Pub. L. 102–154","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s31"},"text":"section 31 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
