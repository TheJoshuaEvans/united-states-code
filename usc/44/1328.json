{"tag":"section","attrib":{"id":"id12279fe5-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1328"},"text":null,"children":[{"tag":"num","attrib":{"value":"1328"},"text":"§ 1328.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merchant vessels of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Five thousand copies of the annual list of merchant vessels of the United States may be printed for distribution by the Coast Guard.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12279fe6-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1270"},"text":"82 Stat. 1270","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12279fe7-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12279fe8-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 249 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s73"},"text":"Jan. 12, 1895, ch. 23, § 73","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/616"},"text":"28 Stat. 616","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1903-02-14/ch552/s4"},"text":"Feb. 14, 1903, ch. 552, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/826"},"text":"32 Stat. 826","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1932-06-30/ch314/s501"},"text":"June 30, 1932, ch. 314, § 501","children":[],"tail":", "},{"tag":"ref","attri