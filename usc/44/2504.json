{"tag":"section","attrib":{"id":"id123f93e5-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504"},"text":null,"children":[{"tag":"num","attrib":{"value":"2504"},"text":"§ 2504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties; authorization of grants for historical publications and records programs; authorization for appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id123f93e6-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall make plans, estimates, and recommendations for historical works and collections of sources it considers appropriate for preserving, publishing or otherwise recording at the public expense. The Chairman of the Commission shall transmit to the President and the Congress from time to time, and at least biennially, the plans, estimates, and recommendations developed and approved by the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id123f93e7-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall cooperate with, assist and encourage appropriate Federal, State, and local agencies and nongovernmental institutions, societies, and individuals in collecting and preserving and, when it considers it desirable, in editing and publishing papers of outstanding citizens of the United States, and other documents as may be important for an understanding and appreciation of the history of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id123f93e8-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission may conduct institutes, training and educational programs, and recommend candidates for fellowships related to the activities of the Commission and may disseminate information about documentary sources through guides, directories, and other technical publications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id123f93e9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission may recommend the expenditure of appropriated or donated funds for the collecting, describing, preserving, compiling and publishing (including microfilming and other forms of reproduction) of documentary sources significant to the history of the United States and for the activities described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id123f93ea-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Archivist of the United States may, within the limits of available appropriated and donated funds, make grants to State and local agencies and to nonprofit organizations, institutions, and individuals, for those activities in subsection (d) after considering the advice and recommendations of the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id123f93eb-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants for Presidential Centers of Historical Excellence.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id123f93ec-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Archivist, with the recommendation of the Commission, may make grants, on a competitive basis and in accordance with this subsection, to eligible entities to promote the historical preservation of, and public access to, historical records and documents relating to any former President who does not have a Presidential archival depository currently managed and maintained by the Federal Government pursuant to section 2112 (commonly known as the “Presidential Libraries Act of 1955”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123f93ed-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible entity","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, an eligible entity is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id123f93ee-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization described under section 501(c)(3) of the Internal Revenue Code of 1986 and exempt from taxation under section 501(a) of that Code; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f93ef-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or local government of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123f93f0-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts received by an eligible entity under paragraph (1) shall be used to promote the historical preservation of, and public access to, historical records or historical documents relating to any former President covered under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123f93f1-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on use of funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts received by an eligible entity under paragraph (1) may not be used for the maintenance, operating costs, or construction of any facility to house the historical records or historical documents relating to any former President covered under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123f93f2-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id123f93f3-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/f/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An eligible entity seeking a grant under this subsection shall submit to the Commission an application at such time, in such manner, and containing or accompanied by such information as the Commission may require, including a description of the activities for which a grant under this subsection is sought.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f93f4-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/f/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval of application","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall not consider or recommend a grant application submitted under subparagraph (A) unless an eligible entity establishes that such entity—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id123f93f5-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/f/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possesses, with respect to any former President covered under paragraph (1), historical works and collections of historical sources that the Commission considers appropriate for preserving, publishing, or otherwise recording at the public expense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id123f93f6-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/f/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has appropriate facilities and space for preservation of, and public access to, the historical works and collections of historical sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id123f93f7-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/f/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall ensure preservation of, and public access to, such historical works and collections of historical sources at no charge to the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id123f93f8-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/f/5/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has educational programs that make the use of such documents part of the mission of such entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id123f93f9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/f/5/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has raised funds from non-Federal sources in support of the efforts of the entity to promote the historical preservation of, and public access to, such historical works and collections of historical sources in an amount equal to the amount of the grant the entity seeks under this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id123f93fa-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/f/5/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall coordinate with any relevant Federal program or activity, including programs and activities relating to Presidential archival depositories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id123f93fb-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/f/5/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall coordinate with any relevant non-Federal program or activity, including programs and activities conducted by State and local governments and private educational historical entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id123f93fc-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/f/5/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a workable plan for preserving and providing public access to such historical works and collections of historical sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id123f93fd-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id123f93fe-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purposes specified in this section, there is hereby authorized to be appropriated to the National Historical Publications and Records Commission—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id123f93ff-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $6,000,000 for fiscal year 1989;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f9400-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $8,000,000 for fiscal year 1990;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f9401-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for each of the fiscal years 1991, 1992, and 1993;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f9402-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/g/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $6,000,000 for fiscal year 1994;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f9403-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/g/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $7,000,000 for fiscal year 1995;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f9404-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/g/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $8,000,000 for fiscal year 1996;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f9405-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/g/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 1997;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f9406-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/g/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 1998;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f9407-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/g/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 1999;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f9408-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/g/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 2000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f9409-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/g/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 2001;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f940a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/g/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 2002;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f940b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/g/1/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 2003;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f940c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/g/1/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 2004;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f940d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/g/1/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 2005;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f940e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/g/1/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 2006;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f940f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/g/1/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 2007;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f9410-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/g/1/R"},"text":null,"children":[{"tag":"num","attrib":{"value":"R"},"text":"(R)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 2008; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f9411-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/g/1/S"},"text":null,"children":[{"tag":"num","attrib":{"value":"S"},"text":"(S)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123f9412-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2504/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts appropriated under this subsection shall be available until expended when so provided in appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id123f9413-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1294"},"text":"82 Stat. 1294","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/546/s1/c"},"text":"Pub. L. 92–546, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-25"},"text":"Oct. 25, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1155"},"text":"86 Stat. 1155","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/536/s1/c"},"text":"Pub. L. 93–536, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-22"},"text":"Dec. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1735"},"text":"88 Stat. 1735","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/98/s1"},"text":"Pub. L. 96–98, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-01"},"text":"Nov. 1, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/731"},"text":"93 Stat. 731","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/189"},"text":"Pub. L. 98–189","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"No