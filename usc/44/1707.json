{"tag":"section","attrib":{"id":"id122c81e6-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1707"},"text":null,"children":[{"tag":"num","attrib":{"value":"1707"},"text":"§ 1707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reprinting of documents required for sale","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Superintendent of Documents may order reprinted, from time to time, public documents required for sale, subject to the approval of the Secretary or head of the department in which the public document originated. The Revolving Fund shall be reimbursed for the cost of reprints from the moneys received by the Superintendent of Documents from the sale of public documents.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122c81e7-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1280"},"text":"82 Stat. 1280","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/520/tII/s208"},"text":"Pub. L. 101–520, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2274"},"text":"104 Stat. 2274","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122c81e8-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122c81e9-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 79 (","children":[{"tag":"date","attrib":{"date":"1904-03-28"},"text":"Mar. 28, 1904","children":[],"tail":", No. 11, "},{"tag":"ref","attrib":{"href":"/us/stat/33/584"},"text":"33 Stat. 584","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id122c81ea-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id122c81eb-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/520"},"text":"Pub. L. 101–520","children":[],"tail":" substituted “The Revolving Fund” for “The appropriation for printing and binding”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
