{"tag":"section","attrib":{"id":"id123d2335-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2207"},"text":null,"children":[{"tag":"num","attrib":{"value":"2207"},"text":"§ 2207.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vice-Presidential records","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Vice-Presidential records shall be subject to the provisions of this chapter in the same manner as Presidential records. The duties and responsibilities of the Vice President, with respect to Vice-Presidential records, shall be the same as the duties and responsibilities of the President under this chapter, except section 2208, with respect to Presidential records. The authority of the Archivist with respect to Vice-Presidential records shall be the same as the authority of the Archivist under this chapter with respect to Presidential records, except that the Archivist may, when the Archivist determines that it is in the public interest, enter into an agreement for the deposit of Vice-Presidential records in a non-Federal archival depository. Nothing in this chapter shall be construed to authorize the establishment of separate archival depositories for such Vice-Presidential records.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id123d2336-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/591/s2/a"},"text":"Pub. L. 95–591, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-04"},"text":"Nov. 4, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2527"},"text":"92 Stat. 2527","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/187/s2/a/2/C"},"text":"Pub. L. 113–187, § 2(a)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2005"},"text":"128 Stat. 2005","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id123d2337-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id123d2338-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id123d2339-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/187"},"text":"Pub. L. 113–187","children":[],"tail":" inserted “, except section 2208,” after “chapter” in second sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id123d233a-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id123d233b-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective with respect to Presidential records created during a term of office of President beginning on or after ","children":[{"tag":"date","attrib":{"date":"1981-01-20"},"text":"Jan. 20, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/591/s3"},"text":"section 3 of Pub. L. 95–591","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id123d233c-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/187/s2/a/4"},"text":"Pub. L. 113–187, § 2(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2005"},"text":"128 Stat. 2005","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/187/s2/a/4"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Nothing in the amendment made by paragraph (2)(C) [amending this section] shall be construed to—","children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affect the requirement of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s2207"},"text":"section 2207 of title 44","children":[],"tail":", United States Code, that Vice Presidential records shall be subject to chapter 22 of that title in the same manner as Presidential records; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affect any claim of constitutionally based privilege by a President or former President with respect to a Vice Presidential record.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
