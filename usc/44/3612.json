{"tag":"section","attrib":{"id":"id1260d7fb-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3612"},"text":null,"children":[{"tag":"num","attrib":{"value":"3612"},"text":"§ 3612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of foreign interests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1260d7fc-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An independent assessment service that performs services described in section 3611 shall annually submit to the Administrator information relating to any foreign interest, foreign influence, or foreign control of the independent assessment service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1260d7fd-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 48 hours after there is a change in foreign ownership or control of an independent assessment service that performs services described in section 3611, the independent assessment service shall submit to the Administrator an update to the information submitted under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1260d7fe-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3612/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may require a representative of an independent assessment service to certify the accuracy and completeness of any information submitted under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1260d7ff-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIX/s5921/b"},"text":"Pub. L. 117–263, div. E, title LIX, § 5921(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3453"},"text":"136 Stat. 3453","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1260d800-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id1260d801-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For repeal of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5921/d/1"},"text":"section 5921(d)(1) of Pub. L. 117–263","children":[],"tail":", see Effective Date of Repeal note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1260d802-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id1260d803-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of Repeal","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIX/s5921/d/1"},"text":"Pub. L. 117–263, div. E, title LIX, § 5921(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3458"},"text":"136 Stat. 3458","children":[],"tail":", provided that the repeal of this section is effective on the date that is 5 years after "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id1260d804-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For rule of construction regarding ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5921"},"text":"section 5921 of Pub. L. 117–263","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5921/e"},"text":"section 5921(e) of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3607"},"text":"section 3607 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
