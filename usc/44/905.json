{"tag":"section","attrib":{"id":"id1222e47a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s905"},"text":null,"children":[{"tag":"num","attrib":{"value":"905"},"text":"§ 905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional Record: additional insertions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Joint Committee on Printing shall provide for printing in the daily Record the legislative program for the day together with a list of congressional committee meetings and hearings, and the place of meeting and subject matter. It shall cause a brief resume of congressional activities for the previous day to be incorporated in the Record, together with an index of its contents prepared under the supervision of the Secretary of the Senate and the Clerk of the House of Representatives, respectively.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id1222e47b-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1256"},"text":"82 Stat. 1256","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1222e47c-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id1222e47d-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 182c (","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch753"},"text":"Aug. 2, 1946, ch. 753","children":[],"tail":", title II, § 221, "},{"tag":"ref","attrib":{"href":"/us/stat/60/837"},"text":"60 Stat. 837","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
