{"tag":"section","attrib":{"id":"id1246bfb2-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3311"},"text":null,"children":[{"tag":"num","attrib":{"value":"3311"},"text":"§ 3311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Destruction of records outside continental United States in time of war or when hostile action seems imminent; written report to Archivist","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"During a state of war between the United States and another nation, or when hostile action by a foreign power appears imminent, the head of an agency of the United States Government may authorize the destruction of records in his legal custody situated in a military or naval establishment, ship, or other depository outside the territorial limits of continental United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1246bfb3-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3311/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the retention of which would be prejudicial to the interests of the United States or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1246bfb4-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3311/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which occupy space urgently needed for military purposes and are, in his opinion, without sufficient administrative, legal, research, or other value to warrant their continued preservation.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Within six months after their disposal, the official who directed the disposal shall submit a written report to the Archivist in which he shall describe the character of the records and state when and where he disposed of them.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1246bfb5-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1301"},"text":"82 Stat. 1301","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s107/b/23"},"text":"Pub. L. 98–497, title I, § 107(b)(23)","children":[],"tail":", (25)(C), "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2290"},"text":"98 Stat. 2290","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1246bfb6-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id1246bfb7-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 376 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1943-07-07/ch192/s11"},"text":"July 7, 1943, ch. 192, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/57/382"},"text":"57 Stat. 382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title I, § 104(a), "},{"tag":"ref","attrib":{"href":"/us/stat/63/381"},"text":"63 Stat. 381","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1246bfb8-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1246bfb9-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" substituted “Archivist” for “Administrator of General Services” in section catchline and text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1246bfba-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id1246bfbb-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-04-01"},"text":"Apr. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/s301"},"text":"section 301 of Pub. L. 98–497","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s2102"},"text":"section 2102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
