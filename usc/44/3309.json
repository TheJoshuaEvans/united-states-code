{"tag":"section","attrib":{"id":"id1246bfa4-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3309"},"text":null,"children":[{"tag":"num","attrib":{"value":"3309"},"text":"§ 3309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of claims of Government until settled in Government Accountability Office; disposal authorized upon written approval of Comptroller General","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Records pertaining to claims and demands by or against the Government of the United States or to accounts in which the Government of the United States is concerned, either as debtor or creditor, may not be disposed of by the head of an agency under authorization granted under this chapter, until the claims, demands, and accounts have been settled and adjusted in the Government Accountability Office, except upon the written approval of the Comptroller General of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id1246bfa5-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1301"},"text":"82 Stat. 1301","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/287/s2/b"},"text":"Pub. L. 91–287, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-23"},"text":"June 23, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/321"},"text":"84 Stat. 321","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1246bfa6-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id1246bfa7-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 374 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1943-07-07/ch192/s9"},"text":"July 7, 1943, ch. 192, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/57/382"},"text":"57 Stat. 382","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1246bfa8-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1246bfa9-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in section catchline and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/287"},"text":"Pub. L. 91–287","children":[],"tail":" substituted “under this chapter” for “under sections 3306–3308 of this title”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
