{"tag":"section","attrib":{"id":"id122c8203-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1711"},"text":null,"children":[{"tag":"num","attrib":{"value":"1711"},"text":"§ 1711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Catalog of Government publications","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On the first day of each month the Superintendent of Documents shall prepare a catalog of Government publications which shall show the documents printed during the preceding month, where obtainable, and the price. Two thousand copies of the catalog shall be printed in pamphlet form for distribution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122c8204-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1280"},"text":"82 Stat. 1280","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122c8205-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122c8206-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 77 (Jan. 12 1895, ch. 23, § 69, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/28/612"},"text":"28 Stat. 612","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
