{"tag":"section","attrib":{"id":"id1222e4a5-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s910"},"text":null,"children":[{"tag":"num","attrib":{"value":"910"},"text":"§ 910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional Record: subscriptions; sale of current, individual numbers, and bound sets; postage rate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1222e4a6-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s910/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under the direction of the Joint Committee, the Director of the Government Publishing Office may sell—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1222e4a7-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s910/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subscriptions to the daily Record; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1222e4a8-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s910/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" current, individual numbers, and bound sets of the Congressional Record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1222e4a9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s910/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The price of a subscription to the daily Record and of current, individual numbers, and bound sets shall be determined by the Director of the Government Publishing Office based upon the cost of printing and distribution. Any such price shall be paid in advance. The money from any such sale shall be paid into the Treasury and accounted for in the Public Printer’s ","children":[{"tag":"ref","attrib":{"idref":"fn002004"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002004"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Director of the Government Publishing Office’s”."}],"tail":" annual report to Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1222e4aa-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s910/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Congressional Record shall be entitled to be mailed at the same rates of postage at which any newspaper or other periodical publication, with a legitimate list of paid subscribers, is entitled to be mailed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1222e4ab-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1260"},"text":"82 Stat. 1260","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/314/s1/a"},"text":"Pub. L. 93–314, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-06-08"},"text":"June 8, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/239"},"text":"88 Stat. 239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1222e4ac-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id1222e4ad-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 188 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s40"},"text":"Jan. 12, 1895, ch. 23, § 40","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/607"},"text":"28 Stat. 607","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1222e4ae-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1222e4af-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/314"},"text":"Pub. L. 93–314","children":[],"tail":" included subscriptions and postage rate in section catchline, and inserted provisions in text authorizing sale of subscriptions, requiring price for subscriptions to be paid in advance, and directing that the Congressional Record shall be entitled to be mailed at the same rates of postage at which any newspaper or other periodical publication, with a legitimate list of paid subscribers, is entitled to be mailed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
