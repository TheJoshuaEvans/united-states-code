{"tag":"section","attrib":{"id":"id121e2991-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s707"},"text":null,"children":[{"tag":"num","attrib":{"value":"707"},"text":"§ 707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bills and resolutions: style and form","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to sections 205 and 206 of Title 1, the Joint Committee on Printing may authorize the printing of a bill or resolution, with index and ancillaries, in the style and form the Joint Committee on Printing considers most suitable in the interest of economy and efficiency, and to so continue until final enactment in both Houses of Congress. The committee may also curtail the number of copies of bills or resolutions, including the slip form of a public Act or public resolution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id121e2992-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1248"},"text":"82 Stat. 1248","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id121e2993-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id121e2994-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 189a (","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-13/ch483/s3"},"text":"June 13, 1934, ch. 483, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/948"},"text":"48 Stat. 948","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
