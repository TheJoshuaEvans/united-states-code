{"tag":"section","attrib":{"id":"id1252a71e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3514"},"text":null,"children":[{"tag":"num","attrib":{"value":"3514"},"text":"§ 3514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsiveness to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1252a71f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3514/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1252a720-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3514/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1252a721-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3514/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" keep the Congress and congressional committees fully and currently informed of the major activities under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1252a722-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3514/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit a report on such activities to the President of the Senate and the Speaker of the House of Representatives annually and at such other times as the Director determines necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1252a723-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3514/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director shall include in any such report a description of the extent to which agencies have—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1252a724-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3514/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reduced information collection burdens on the public, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1252a725-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3514/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of accomplishments and planned initiatives to reduce collection of information burdens;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1252a726-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3514/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of all violations of this subchapter and of any rules, guidelines, policies, and procedures issued pursuant to this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1252a727-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3514/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of any increase in the collection of information burden, including the authority for each such collection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1252a728-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3514/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of agencies that in the preceding year did not reduce information collection burdens in accordance with section 3505(a)(1), a list of the programs and statutory responsibilities of those agencies that precluded that reduction, and recommendations to assist those agencies to reduce information collection burdens in accordance with that section;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1252a729-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3514/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved the quality and utility of statistical information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1252a72a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3514/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved public access to Government information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1252a72b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3514/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved program performance and the accomplishment of agency missions through information resources management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1252a72c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3514/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The preparation of any report required by this section shall be based on performance results reported by the agencies and shall not increase the collection of information burden on persons outside the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1252a72d-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/13/s2"},"text":"Pub. L. 104–13, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-05-22"},"text":"May 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/181"},"text":"109 Stat. 181","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1064(b)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–275.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1252a72e-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1252a72f-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id1252a730-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3514, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/511/s2/a"},"text":"Pub. L. 96–511, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-11"},"text":"Dec. 11, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2823"},"text":"94 Stat. 2823","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/m/tVIII/s819"},"text":"Pub. L. 99–500, § 101(m) [title VIII, § 819]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18