{"tag":"section","attrib":{"id":"id12444f0b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2912"},"text":null,"children":[{"tag":"num","attrib":{"value":"2912"},"text":"§ 2912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of electronic messages and other records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id12444f0c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Archivist shall promulgate regulations governing Federal agency preservation of electronic messages that are determined to be records. Such regulations shall, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id12444f0d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2912/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the electronic capture, management, and preservation of such electronic records in accordance with the records disposition requirements of chapter 33;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12444f0e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2912/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that such electronic records are readily accessible for retrieval through electronic searches; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12444f0f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2912/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include timelines for Federal agency implementation of the regulations that ensure compliance as expeditiously as practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id12444f10-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coverage of Other Electronic Records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent practicable, the regulations promulgated under subsection (a) shall also include requirements for the capture, management, and preservation of other electronic records.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id12444f11-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2912/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of Regulations Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Archivist shall periodically review and, as necessary, amend the regulations promulgated under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id12444f12-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dH/tXCVI/s9602/b/1"},"text":"Pub. L. 116–283, div. H, title XCVI, § 9602(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4828"},"text":"134 Stat. 4828","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12444f13-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id12444f14-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id12444f15-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dH/tXCVI/s9602/b/2"},"text":"Pub. L. 116–283, div. H, title XCVI, § 9602(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4828"},"text":"134 Stat. 4828","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dH/tXCVI/s9602/b/2"},"text":"“Not later than one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"], the Archivist shall propose the regulations required under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s2912/a"},"text":"section 2912(a) of title 44","children":[],"tail":", United States Code, as added by paragraph (1).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
