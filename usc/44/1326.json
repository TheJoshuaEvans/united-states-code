{"tag":"section","attrib":{"id":"id12279fdb-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1326"},"text":null,"children":[{"tag":"num","attrib":{"value":"1326"},"text":"§ 1326.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Librarian of Congress: reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Five thousand copies of the annual and special reports of the Librarian of Congress submitted to Congress, shall be printed and bound in cloth for the Library of Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12279fdc-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1270"},"text":"82 Stat. 1270","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12279fdd-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12279fde-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 156 (","children":[{"tag":"date","attrib":{"date":"1904-02-24"},"text":"Feb. 24, 1904","children":[],"tail":", No. 8, "},{"tag":"ref","attrib":{"href":"/us/stat/33/583"},"text":"33 Stat. 583","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
