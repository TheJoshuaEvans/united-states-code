{"tag":"section","attrib":{"id":"id122c81ec-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1708"},"text":null,"children":[{"tag":"num","attrib":{"value":"1708"},"text":"§ 1708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prices for sales copies of publications; crediting of receipts; resale by dealers; sales agents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The price at which additional copies of Government publications are offered for sale to the public by the Superintendent of Documents shall be based on the cost as determined by the Director of the Government Publishing Office plus 50 percent. A discount may be allowed as determined by the Superintendent of Documents, but the printing may not interfere with prompt execution of work for the Government.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Superintendent of Documents may prescribe terms and conditions under which he authorizes the resale of Government publications by book dealers, and he may designate any Government officer his agent for the sale of Government publications under regulations agreed upon by the Superintendent of Documents and the head of the respective department or establishment of the Government.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122c81ed-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1280"},"text":"82 Stat. 1280","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/94/tIV/s409/a"},"text":"Pub. L. 95–94, title IV, § 409(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-05"},"text":"Aug. 5, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/u