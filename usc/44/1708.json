hildren":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id122c81f1-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer” in first par."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Pub. L. 108–447","children":[],"tail":", in first par., substituted “may be allowed as determined by the Superintendent of Documents” for “of not to exceed 25 percent may be allowed to book dealers and quantity purchasers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/69"},"text":"Pub. L. 103–69","children":[],"tail":", in first par., struck out at end “Receipts from general sales of publications in excess of the total costs and expenses incurred in connection with the publication and sale thereof, as determined by the Public Printer, shall be deposited in the Treasury of the United States to the credit of miscellaneous receipts.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/94"},"text":"Pub. L. 95–94","children":[],"tail":" substituted “Receipts from general sales of publications in excess of the total costs and expenses incurred in connection with the publication and sale thereof, as determined by the Public Printer,” for “Surplus receipts from sales”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id122c81f2-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","