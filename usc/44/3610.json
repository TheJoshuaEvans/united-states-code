{"tag":"section","attrib":{"id":"id1260d7da-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3610"},"text":null,"children":[{"tag":"num","attrib":{"value":"3610"},"text":"§ 3610.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FedRAMP Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1260d7db-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3610/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established a FedRAMP Board to provide input and recommendations to the Administrator regarding the requirements and guidelines for, and the prioritization of, security assessments of cloud computing products and services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1260d7dc-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3610/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The FedRAMP Board shall consist of not more than 7 senior officials or experts from agencies appointed by the Director, in consultation with the Administrator, from each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1260d7dd-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3610/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d7de-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3610/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d7df-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3610/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The General Services Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d7e0-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3610/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other agencies as determined by the Director, in consultation with the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1260d7e1-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3610/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members of the FedRAMP Board appointed under subsection (b) shall have technical expertise in domains relevant to FedRAMP, such as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1260d7e2-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3610/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cloud computing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d7e3-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3610/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cybersecurity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d7e4-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3610/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" privacy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d7e5-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3610/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" risk management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d7e6-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3610/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other competencies identified by the Director to support the secure authorization of cloud services and products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1260d7e7-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3610/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The FedRAMP Board shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1260d7e8-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3610/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the Administrator, serve as a resource for best practices to accelerate the process for obtaining a FedRAMP authorization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d7e9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3610/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and regularly update requirements and guidelines for security authorizations of cloud computing products and services, consistent with standards and guidelines established by the Director of the National Institute of Standards and Technology, to be used in the determination of FedRAMP authorizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d7ea-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3610/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor and oversee, to the greatest extent practicable, the processes and procedures by which agencies determine and validate requirements for a FedRAMP authorization, including periodic review of the agency determinations described in section 3613(b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d7eb-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3610/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure consistency and transparency between agencies and cloud service providers in a manner that minimizes confusion and engenders trust; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d7ec-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3610/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other roles and responsibilities as the Director may assign, with concurrence from the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1260d7ed-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3610/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determinations of Demand for Cloud Computing Products and Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The FedRAMP Board may consult with the Chief Information Officers Council to establish a process, which may be made available on the website maintained under section 3609(b), for prioritizing and accepting the cloud computing products and services to be granted a FedRAMP authorization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1260d7ee-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIX/s5921/b"},"text":"Pub. L. 117–263, div. E, title LIX, § 5921(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3452"},"text":"136 Stat. 3452","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1260d7ef-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id1260d7f0-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For repeal of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5921/d/1"},"text":"section 5921(d)(1) of Pub. L. 117–263","children":[],"tail":", see Effective Date of Repeal note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1260d7f1-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id1260d7f2-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of Repeal","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIX/s5921/d/1"},"text":"Pub. L. 117–263, div. E, title LIX, § 5921(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3458"},"text":"136 Stat. 3458","children":[],"tail":", provided that the repeal of this section is effective on the date that is 5 years after "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id1260d7f3-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For rule of construction regarding ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5921"},"text":"section 5921 of Pub. L. 117–263","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5921/e"},"text":"section 5921(e) of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3607"},"text":"section 3607 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
