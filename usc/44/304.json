{"tag":"section","attrib":{"id":"id1216fd6c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s304"},"text":null,"children":[{"tag":"num","attrib":{"value":"304"},"text":"§ 304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of the Government Publishing Office: vacancy in office","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In case of the death, resignation, absence, or sickness of the Director of the Government Publishing Office, the Deputy Director of the Government Publishing Office shall perform the duties of the Director of the Government Publishing Office until a successor is appointed or the Director’s absence or sickness ceases; but the President may direct any other officer of the Government, whose appointment is vested in the President by and with the advice and consent of the Senate, to perform the duties of the vacant office until a successor is appointed, or the sickness or absence of the Director of the Government Publishing Office ceases. A vacancy occasioned by death or resignation may not be filled temporarily under this section for longer than ten days, and a temporary appointment, designation, or assignment of another officer may not be made except to fill a vacancy happening during a recess of the Senate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id1216fd6d-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1239"},"text":"82 Stat. 1239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)","children":[],"tail":", (e)(1), (i)(1), "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":", 2538.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1216fd6e-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id1216fd6f-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 32 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s36"},"text":"Jan. 12, 1895, ch. 23, § 36","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/606"},"text":"28 Stat. 606","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1908-05-27/ch200/s1"},"text":"May 27, 1908, ch. 200, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/382"},"text":"35 Stat. 382","children":[],"tail":".)"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1216fd70-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1216fd71-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/i/1"},"text":"Pub. L. 113–235, § 1301(i)(1)","children":[],"tail":", substituted “or the Director’s” for “or his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/e/1"},"text":"Pub. L. 113–235, § 1301(e)(1)","children":[],"tail":", substituted “Deputy Director of the Government Publishing Office” for “Deputy Public Printer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/c"},"text":"Pub. L. 113–235, § 1301(c)","children":[],"tail":", substituted “Director of the Government Publishing Office” for “Public Printer” in section catchline and wherever appearing in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
