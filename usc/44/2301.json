{"tag":"section","attrib":{"id":"id123d2371-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2301"},"text":null,"children":[{"tag":"num","attrib":{"value":"2301"},"text":"§ 2301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Board; membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The National Archives Trust Fund Board shall consist of the Archivist of the United States, as Chairman, and the Secretary of the Treasury and the Chairman of the National Endowment for the Humanities. Membership on the Board is not an office within the meaning of the statutes of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id123d2372-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1292"},"text":"82 Stat. 1292","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/391"},"text":"Pub. L. 94–391","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-08-19"},"text":"Aug. 19, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1192"},"text":"90 Stat. 1192","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/379"},"text":"Pub. L. 95–379","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-22"},"text":"Sept. 22, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/724"},"text":"92 Stat. 724","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s107/b/8"},"text":"Pub. L. 98–497, title I, § 107(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2287"},"t