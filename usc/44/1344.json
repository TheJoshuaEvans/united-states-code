{"tag":"section","attrib":{"id":"id122a1032-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1344"},"text":null,"children":[{"tag":"num","attrib":{"value":"1344"},"text":"§ 1344.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treasury Department: reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to the usual number of the finance report of the Secretary of the Treasury, one thousand copies for the Senate and two thousand for the House of Representatives shall be printed in addition to those published as part of the departmental report.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In addition to the usual number of the annual report of the Comptroller of the Currency, thirteen thousand copies shall be printed: one thousand for the Senate, two thousand for the House of Representatives, and ten thousand for distribution by the Comptroller of the Currency.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122a1033-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1273"},"text":"82 Stat. 1273","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122a1034-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122a1035-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 295 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s73"},"text":"Jan. 12, 1895, ch. 23, § 73","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/616"},"text":"28 Stat. 616","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1907-03-04"},"text":"Mar. 4, 1907","children":[],"tail":", No. 25, "},{"tag":"ref","attrib":{"href":"/us/stat/34/1425"},"text":"34 Stat. 1425","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
