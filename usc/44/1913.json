{"tag":"section","attrib":{"id":"id122ecb7f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1913"},"text":null,"children":[{"tag":"num","attrib":{"value":"1913"},"text":"§ 1913.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations for supplying depository libraries; restriction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Appropriations available for the Office of Superintendent of Documents may not be used to supply depository libraries documents, books, or other printed matter not requested by them, and their requests shall be subject to approval by the Superintendent of Documents.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122ecb80-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1286"},"text":"82 Stat. 1286","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122ecb81-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122ecb82-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 85a (","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-06-27/ch453/s101"},"text":"June 27, 1956, ch. 453, § 101","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/369"},"text":"70 Stat. 369","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
