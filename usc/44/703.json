{"tag":"section","attrib":{"id":"id121e2979-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s703"},"text":null,"children":[{"tag":"num","attrib":{"value":"703"},"text":"§ 703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Printing extra copies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Orders for printing copies in addition to the “usual number”, otherwise than provided for by this section, shall be by simple, concurrent, or joint resolution. Either House may print extra copies to the amount of $1,200 by simple resolution; if the cost exceeds that sum, the printing shall be ordered by concurrent resolution, unless the resolution is self-appropriating, when it shall be by joint resolution. Resolutions, when presented to either House, shall be referred to the Committee on House Oversight of the House of Representatives or the Committee on Rules and Administration of the Senate, who, in making their report, shall give the probable cost of the proposed printing upon the estimate of the Director of the Government Publishing Office; and extra copies may not be printed before the committee has reported. The printing of additional copies may be performed upon orders of the Joint Committee on Printing within a limit of $700 in cost in any one instance.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id121e297a-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1247"},"text":"82 Stat. 1247","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s223/2"},"text":"Pub. L. 104–186, title II, § 223(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1751"},"text":"110 Stat. 1751","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id121e297b-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id121e297c-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 133 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s2"},"text":"Jan. 12, 1895, ch. 23, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/601"},"text":"28 Stat. 601","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1907-03-01/ch2284/s1"},"text":"Mar. 1, 1907, ch. 2284, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1013"},"text":"34 Stat. 1013","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-04-19/ch72"},"text":"Apr. 19, 1949, ch. 72","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/48"},"text":"63 Stat. 48","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id121e297d-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id121e297e-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “House Oversight” for “House Administration”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id121e297f-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id121e2980-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on House Oversight of House of Representatives changed to Committee on House Administration of House of Representatives by House Resolution No. 5, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-06"},"text":"Jan. 6, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
