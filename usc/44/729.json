{"tag":"section","attrib":{"id":"id12209a16-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s729"},"text":null,"children":[{"tag":"num","attrib":{"value":"729"},"text":"§ 729.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Statutes at Large: references in margins","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Archivist of the United States shall include in the references in margins of the United States Statutes at Large the number of the bill or joint resolution (designating S. for Senate bill, H.R. for House bill, S.J. Res. for Senate joint resolution and H.J. Res. for House joint resolution, as the case may be) under which each Act was approved and became a law, the reference in the margins to be placed within brackets immediately under the date of the approval of the Act at the beginning of each Act as printed beginning with Volume 32 of the United States Statutes at Large.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12209a17-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1252"},"text":"82 Stat. 1252","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s107/b/1"},"text":"Pub. L. 98–497, title I, § 107(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2286"},"text":"98 Stat. 2286","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12209a18-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12209a19-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 197 (","children":[{"tag":"date","attrib":{"date":"1904-04-12"},"text":"Apr. 12, 1904","children":[],"tail":", No. 20, "},{"tag":"ref","attrib":{"href":"/us/stat/33/589"},"text":"33 Stat. 589","children":[],"tail":"; 1950 Reorg. Plan No. 20, § 1, eff. "},{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3178, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1272"},"text":"64 Stat. 1272","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id12209a1a-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id12209a1b-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" substituted “Archivist of the United States” for “Administrator of General Services”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id12209a1c-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id12209a1d-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":