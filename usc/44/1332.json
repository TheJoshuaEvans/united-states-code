{"tag":"section","attrib":{"id":"id122a0ff9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1332"},"text":null,"children":[{"tag":"num","attrib":{"value":"1332"},"text":"§ 1332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National encampments of Veterans’ organizations; proceedings printed annually for Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The proceedings of the national encampments of the Veterans of Foreign Wars of the United States, the American Legion, the Military Order of the Purple Heart, the Veterans of World War I of the United States of America, Incorporated, the Disabled American Veterans, and the AMVETS (American Veterans of World War II), respectively, shall be printed annually, with accompanying illustrations, as separate House documents of the session of the Congress to which they may be submitted.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122a0ffa-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1270"},"text":"82 Stat. 1270","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/225/s3"},"text":"Pub. L. 105–225, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1498"},"text":"112 Stat. 1498","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122a0ffb-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122a0ffc-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes