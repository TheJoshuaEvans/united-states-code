{"tag":"section","attrib":{"id":"id125e8df3-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602"},"text":null,"children":[{"tag":"num","attrib":{"value":"3602"},"text":"§ 3602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Electronic Government","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id125e8df4-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established in the Office of Management and Budget an Office of Electronic Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125e8df5-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be at the head of the Office an Administrator who shall be appointed by the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125e8df6-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator shall assist the Director in carrying out—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id125e8df7-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all functions under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8df8-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all of the functions assigned to the Director under title II of the E-Government Act of 2002; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8df9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other electronic government initiatives, consistent with other statutes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125e8dfa-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator shall assist the Director and the Deputy Director for Management and work with the Administrator of the Office of Information and Regulatory Affairs in setting strategic direction for implementing electronic Government, under relevant statutes, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id125e8dfb-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 35;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8dfc-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subtitle III of title 40, United States Code;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8dfd-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":" (commonly referred to as the “Privacy Act”);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8dfe-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government Paperwork Elimination Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3504"},"text":"44 U.S.C. 3504","children":[],"tail":" note); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8dff-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Information Security Management Act of 2002.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125e8e00-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator shall work with the Administrator of the Office of Information and Regulatory Affairs and with other offices within the Office of Management and Budget to oversee implementation of electronic Government under this chapter, chapter 35, the E-Government Act of 2002, and other relevant statutes, in a manner consistent with law, relating to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id125e8e01-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capital planning and investment control for information technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e02-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of enterprise architectures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e03-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e04-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" privacy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e05-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to, dissemination of, and preservation of Government information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e06-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accessibility of information technology for persons with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e07-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other areas of electronic Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125e8e08-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to requirements of this chapter, the Administrator shall assist the Director by performing electronic Government functions as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id125e8e09-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advise the Director on the resources required to develop and effectively administer electronic Government initiatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e0a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommend to the Director changes relating to Governmentwide strategies and priorities for electronic Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e0b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide overall leadership and direction to the executive branch on electronic Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e0c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promote innovative uses of information technology by agencies, particularly initiatives involving multiagency collaboration, through support of pilot projects, research, experimentation, and the use of innovative technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e0d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Oversee the distribution of funds from, and ensure appropriate administration and coordination of, the E-Government Fund established under section 3604.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e0e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinate with the Administrator of General Services regarding programs undertaken by the General Services Administration to promote electronic government and the efficient use of information technologies by agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e0f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lead the activities of the Chief Information Officers Council established under section 3603 on behalf of the Deputy Director for Management, who shall chair the council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e10-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Assist the Director in establishing policies which shall set the framework for information technology standards for the Federal Government developed by the National Institute of Standards and Technology and promulgated by the Secretary of Commerce under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s11331"},"text":"section 11331 of title 40","children":[],"tail":", taking into account, if appropriate, recommendations of the Chief Information Officers Council, experts, and interested parties from the private and nonprofit sectors and State, local, and tribal governments, and maximizing the use of commercial standards as appropriate, including the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id125e8e11-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Standards and guidelines for interconnectivity and interoperability as described under section 3504.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e12-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consistent with the process under section 207(d) of the E-Government Act of 2002, standards and guidelines for categorizing Federal Government electronic information to enable efficient use of technologies, such as through the use of extensible markup language.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e13-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Standards and guidelines for Federal Government computer system efficiency and security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e14-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Sponsor ongoing dialogue that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id125e8e15-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be conducted among Federal, State, local, and tribal government leaders on electronic Government in the executive, legislative, and judicial branches, as well as leaders in the private and nonprofit sectors, to encourage collaboration and enhance understanding of best practices and innovative approaches in acquiring, using, and managing information resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e16-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is intended to improve the performance of governments in collaborating on the use of information technology to improve the delivery of Government information and services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e17-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id125e8e18-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/9/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" development of innovative models—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id125e8e19-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/9/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for electronic Government management and Government information technology contracts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id125e8e1a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/9/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that may be developed through focused discussions or using separately sponsored research;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id125e8e1b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/9/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of opportunities for public-private collaboration in using Internet-based technology to increase the efficiency of Government-to-business transactions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id125e8e1c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/9/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of mechanisms for providing incentives to program managers and other Government employees to develop and implement innovative uses of information technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id125e8e1d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/9/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of opportunities for public, private, and intergovernmental collaboration in addressing the disparities in access to the Internet and information technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e1e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sponsor activities to engage the general public in the development and implementation of policies and programs, particularly activities aimed at fulfilling the goal of using the most effective citizen-centered strategies and those activities which engage multiple agencies providing similar or related information and services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e1f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Oversee the work of the General Services Administration and other agencies in developing the integrated Internet-based system under section 204 of the E-Government Act of 2002.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e20-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinate with the Administrator for Federal Procurement Policy to ensure effective implementation of electronic procurement initiatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e21-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Assist Federal agencies, including the General Services Administration, the Department of Justice, and the United States Access Board in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id125e8e22-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing accessibility standards under section 508 of the Rehabilitation Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s794d"},"text":"29 U.S.C. 794d","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e23-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring compliance with those standards through the budget review process and other means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e24-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Oversee the development of enterprise architectures within and across agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e25-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assist the Director and the Deputy Director for Management in overseeing agency efforts to ensure that electronic Government activities incorporate adequate, risk-based, and cost-effective security compatible with business processes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e26-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Administer the Office of Electronic Government established under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e27-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/f/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assist the Director in preparing the E-Government report established under section 3606.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125e8e28-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3602/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall ensure that the Office of Management and Budget, including the Office of Electronic Government, the Office of Information and Regulatory Affairs, and other relevant offices, have adequate staff and resources to properly fulfill all functions under the E-Government Act of 2002.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id125e8e29-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/347/tI/s101/a"},"text":"Pub. L. 107–347, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2902"},"text":"116 Stat. 2902","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id125e8e2a-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id125e8e2b-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":