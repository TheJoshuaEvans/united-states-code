{"tag":"section","attrib":{"id":"id122a106d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1506"},"text":null,"children":[{"tag":"num","attrib":{"value":"1506"},"text":"§ 1506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative Committee of the Federal Register; establishment and composition; powers and duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id122a106e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition; Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrative Committee of the Federal Register shall consist of the Archivist of the United States or Acting Archivist, who shall chair the committee, an officer of the Department of Justice designated by the Attorney General, and the Director of the Government Publishing Office or Acting Director of the Government Publishing Office. The Director of the Federal Register shall act as secretary of the committee. The committee shall prescribe, with the approval of the President or their designee, regulations for carrying out this chapter. The regulations shall provide for, among other things, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id122a106f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1506/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The documents which shall be authorized under section 1505(b) to be published in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id122a1070-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1506/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The manner and form in which the Federal Register shall be published.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id122a1071-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1506/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The manner and form in which agencies submit documents for publication in the Federal Register and special editions of the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id122a1072-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1506/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (b), the manner of distribution to Members of Congress, officers and employees of the United States, or Federal agency, for official use, and the number which shall be available for distribution to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id122c8173-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1506/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The prices to be charged for individual copies of, and subscriptions to, the Federal Register and any reprints and bound volumes of it.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id122c8174-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1506/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The manner and form by which the Federal Register may receive information and comments from the public, if practicable and efficient.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id122c8175-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1506/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Special editions of the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id122c8176-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restrictions on Distribution of Free Printed Copies to Members of Congress and Officers and Employees of the United States.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id122c8177-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1506/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibiting subscription to printed copies without request","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the regulations prescribed to carry out subsection (a)(4), the Director of the Government Publishing Office may not provide a printed copy of the Federal Register without charge to any Member of Congress or any other office of the United States during a year unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id122c8178-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1506/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Member or office requests a printed copy of a specific issue of the Federal Register; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id122c8179-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1506/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during that year or during the previous year, the Member or office requested a subscription to printed copies of the Federal Register for that year, as described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id122c817a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1506/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration of subscriptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations prescribed to carry out subsection (a)(4) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id122c817b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1506/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provisions regarding notifications to offices of Members of Congress and other offices of the United States of the restrictions of paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id122c817c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1506/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provisions describing the process by which Members and other offices may request a specific issue of the Federal Register for purposes of paragraph (1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id122c817d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1506/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provisions describing the process by which Members and other offices may request a subscription to the Federal Register for purposes of paragraph (1)(B), except that such regulations shall limit the period for such a subscription to not longer than 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id122c817e-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1275"},"text":"82 Stat. 1275","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s107/b/5"},"text":"Pub. L. 98–497, title I, § 107(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2287"},"text":"98 Stat. 2287","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/120/dA/s2/a"},"text":"Pub. L. 115–120, div. A, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-01-22"},"text":"Jan. 22, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/28"},"text":"132 Stat. 28","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/267/s2/f"},"text":"Pub. L. 118–267, § 2(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2985"},"text":"138 Stat. 2985","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122c817f-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122c8180-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., §§ 306, 391 (part) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-07-26/ch417/s6"},"text":"July 26, 1935, ch. 417, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/501"},"text":"49 Stat. 501","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title I, § 104, "},{"tag":"ref","attrib":{"href":"/us/stat/63/381"},"text":"63 Stat. 381","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section incorporates only the last sentence from former section 391(b). The remainder of that section will be found in sections 2102, 2301, 2501, and 2902 of the revision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id122c8181-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id122c8182-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/267"},"text":"Pub. L. 118–267","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, subsec. (a) related to the composition and duties of the Administrative Committee of the Federal Register."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/120/s2/a/1"},"text":"Pub. L. 115–120, § 2(a)(1)","children":[],"tail":", designated existing provisions as subsec. (a) and inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/120/s2/a/2"},"text":"Pub. L. 115–120, § 2(a)(2)","children":[],"tail":", substituted “subject to subsection (b), the number of copies” for “the number of copies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/120/s2/a/3"},"text":"Pub. L. 115–120, § 2(a)(3)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer” in two places in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" struck out “The authority of the Administrator of General Services, under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s754"},"text":"section 754 of title 40","children":[],"tail":", to regroup, transfer, and distribute functions within the General Services Administration, does not extend to the Committee or its functions.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id122c8183-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id122c8184-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/120/dA/s2/b"},"text":"Pub. L. 115–120, div. A, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-01-22"},"text":"Jan. 22, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/29"},"text":"132 Stat. 29","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/120/dA/s2/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect ","children":[{"tag":"date","attrib":{"date":"2018-01-01"},"text":"January 1, 2018","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id122c8185-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-04-01"},"text":"Apr. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/s301"},"text":"section 301 of Pub. L. 98–497","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s2102"},"text":"section 2102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id122c8186-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id122c8187-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegations of functions vested in President by section 6 of Federal Register Act [now this section], to Attorney General and Archivist of United States, see section 6(b) of Ex. Ord. No. 10530, ","children":[{"tag":"date","attrib":{"date":"1954-05-10"},"text":"May 10, 1954","children":[],"tail":", 19 F.R. 2709, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":", The President. See, also, "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/s103/b/1"},"text":"section 103(b)(1) of Pub. L. 98–497","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s2102"},"text":"section 2102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
