{"tag":"section","attrib":{"id":"id1222e469-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s902"},"text":null,"children":[{"tag":"num","attrib":{"value":"902"},"text":"§ 902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional Record: Indexes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Government Publishing Office shall prepare the semimonthly and the session index to the Congressional Record. The Joint Committee on Printing shall direct the form and manner of its publication and distribution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id1222e46a-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1256"},"text":"82 Stat. 1256","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/102/s1/a"},"text":"Pub. L. 108–102, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-29"},"text":"Oct. 29, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1198"},"text":"117 Stat. 1198","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1222e46b-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id1222e46c-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 182 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s14"},"text":"Jan. 12, 1895, ch. 23, § 14","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/603"},"text":"28 Stat. 603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-20/ch630"},"text":"June 20, 1936, ch. 630","children":[],"tail":", title II, § 2, "},{"tag":"ref","attrib":{"href":"/us/stat/49/1546"},"text":"49 Stat. 1546","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1222e46d-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1222e46e-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/102"},"text":"Pub. L. 108–102","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows: “The Joint Committee on Printing shall designate to the Public Printer competent persons to prepare the semimonthly and the session index to the Congressional Record and shall fix the compensation to be paid by the Public Printer for that work, and direct the form and manner of its publication and distribution.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1222e46f-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id1222e470-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/102/s2"},"text":"Pub. L. 108–102, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-29"},"text":"Oct. 29, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1198"},"text":"117 Stat. 1198","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/102/s2"},"text":"“This Act [amending this section and enacting provisions set out as a note under this section] and the amendments made by this Act shall apply with respect to pay periods beginning on or after ","children":[{"tag":"date","attrib":{"date":"2003-10-01"},"text":"October 1, 2003","children":[],"tail":" (or, if later, the first day of the first month which begins after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2003-10-29"},"text":"Oct. 29, 2003","children":[],"tail":"]).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id1222e471-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transition Rule for Transferred Employees of Congressional Record Index Office","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/102/s1/b"},"text":"Pub. L. 108–102, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-29"},"text":"Oct. 29, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1198"},"text":"117 Stat. 1198","children":[],"tail":", transferred employees of the Congressional Record Index Office to the Government Printing Office as of the effective date of "},{"tag":"ref","attrib":{"href":"/us/pl/108/102"},"text":"Pub. L. 108–102","children":[],"tail":" (see Effective Date of 2003 Amendment note above) and transferred and made available accrued annual and sick leave of such employees to the individuals as an employee of the Government Printing Office."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
