{"tag":"section","attrib":{"id":"id12209a0a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s727"},"text":null,"children":[{"tag":"num","attrib":{"value":"727"},"text":"§ 727.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee reports: indexing and binding","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Senate and the Clerk of the House of Representatives shall procure and file for the use of their respective House copies of all reports made by committees, and at the close of each session of Congress shall have the reports indexed and bound, one copy to be deposited in the library of each House and one copy in the committee from which the report emanates.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12209a0b-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1252"},"text":"82 Stat. 1252","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12209a0c-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12209a0d-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 155 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s83"},"text":"Jan. 12, 1895, ch. 23, § 83","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/622"},"text":"28 Stat. 622","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
