{"tag":"section","attrib":{"id":"id121e2956-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s516"},"text":null,"children":[{"tag":"num","attrib":{"value":"516"},"text":"§ 516.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of defaulting contractor","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon failure to furnish paper, a contractor and his sureties shall be responsible for any increase of cost to the Government in procuring a supply of the paper consequent upon his default. The Director of the Government Publishing Office shall report every default, with a full statement of all the facts in the case, to the General Counsel for the Department of the Treasury, who shall prosecute the defaulting contractor and his sureties upon their bond in the district court of the United States in the district in which the defaulting contractor resides.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id121e2957-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1245"},"text":"82 Stat. 1245","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id121e2958-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id121e2959-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 12 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s10"},"text":"Jan. 12, 1895, ch. 23, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/602"},"text":"28 Stat. 602","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s291"},"text":"Mar. 3, 1911, ch. 231, § 291","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1167"},"text":"36 Stat. 1167","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1934-05-10/ch277/s512/b"},"text":"May 10, 1934, ch. 277, § 512(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/759"},"text":"48 Stat. 759","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id121e295a-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id121e295b-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
