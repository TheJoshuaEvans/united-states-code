{"tag":"section","attrib":{"id":"id12279fdf-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1327"},"text":null,"children":[{"tag":"num","attrib":{"value":"1327"},"text":"§ 1327.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mines, Bureau of: publications","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The publications of the Bureau of Mines shall be published in editions recommended by the Secretary of the Interior, but not to exceed ten thousand copies for the first edition. When the edition of a publication of the Bureau of Mines is exhausted and the demand for it continues, there may be published, on the requisition of the Secretary of the Interior, as many additional copies as the Secretary of the Interior considers necessary to meet the demand.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12279fe0-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1270"},"text":"82 Stat. 1270","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12279fe1-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12279fe2-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 272 (","children":[{"tag":"date","attrib":{"date":"1910-06-25"},"text":"June 25, 1910","children":[],"tail":", No. 36 §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/36/883"},"text":"36 Stat. 883","children":[],"tail":"; Ex. Ord. No. 6611, "},{"tag":"date","attrib":{"date":"1934-02-22"},"text":"Feb. 22, 1934","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id12279fe3-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id12279fe4-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Bureau of Mines redesignated United States Bureau of Mines by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/285/s10/b"},"text":"section 10(b) of Pub. L. 102–285","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1"},"text":"section 1 of Title 30","children":[],"tail":", Mineral Lands and Mining. For provisions relating to closure and transfer of functions of the United States Bureau of Mines, see note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1"},"text":"section 1 of Title 30","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
