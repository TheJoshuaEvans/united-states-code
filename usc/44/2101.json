{"tag":"section","attrib":{"id":"id122ecb9d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2101"},"text":null,"children":[{"tag":"num","attrib":{"value":"2101"},"text":"§ 2101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id122ecb9e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Presidential archival depository” means an institution operated by the United States to house and preserve the papers and books of a President or former President of the United States, together with other historical materials belonging to a President or former President of the United States, or related to his papers or to the events of his official or personal life, and may include research facilities and museum facilities in accordance with this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id122ecb9f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “historical materials” including books, correspondence, documents, papers, pamphlets, works of art, models, pictures, photographs, plats, maps, films, motion pictures, sound recordings, and other objects or materials having historical or commemorative value;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id122ecba0-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Archivist” means the Archivist of the United States appointed unde