{"tag":"section","attrib":{"id":"id12279f9e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1316"},"text":null,"children":[{"tag":"num","attrib":{"value":"1316"},"text":"§ 1316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fish and Wildlife Service: report of the Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to the usual number of the report of the Director of the Fish and Wildlife Service, eight thousand copies shall be printed: two thousand for the Senate, four thousand for the House of Representatives, and two thousand for distribution by the Service.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12279f9f-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1268"},"text":"82 Stat. 1268","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12279fa0-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12279fa1-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 259 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s73"},"text":"Jan. 12, 1895, ch. 23, § 73","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/614"},"text":"28 Stat. 614","children":[],"tail":"; 1940 Reorg. Plan No. III, § 3, eff. "},{"tag":"date","attrib":{"date":"1940-06-30"},"text":"June 30, 1940","children":[],"tail":", 5 F.R. 2108, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1232"},"text":"54 Stat. 1232","children":[