{"tag":"section","attrib":{"id":"id123f93d7-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2502"},"text":null,"children":[{"tag":"num","attrib":{"value":"2502"},"text":"§ 2502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A person appointed to fill a vacancy in the membership of the Commission shall be appointed only for the unexpired term of the member whom he succeeds, and his appointment shall be made in the same manner as the appointment of his predecessor.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id123f93d8-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1294"},"text":"82 Stat. 1294","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id123f93d9-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id123f93da-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 393(b) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title V, § 503(b), as added "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-05/ch849/s6/d"},"text":"Sept. 5, 1950, ch. 849, § 6(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/583"},"text":"64 Stat. 583","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
