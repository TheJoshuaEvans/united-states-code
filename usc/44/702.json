{"tag":"section","attrib":{"id":"id121e2975-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s702"},"text":null,"children":[{"tag":"num","attrib":{"value":"702"},"text":"§ 702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extra copies of documents and reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Copies in addition to the “usual number” of documents and reports shall be printed promptly when ready for publication, and may be bound in paper or cloth as the Joint Committee on Printing directs.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id121e2976-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1247"},"text":"82 Stat. 1247","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id121e2977-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id121e2978-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964, ed., §§ 132, 134 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23"},"text":"Jan. 12, 1895, ch. 23","children":[],"tail":", §§ 2, 73, "},{"tag":"ref","attrib":{"href":"/us/stat/28/601"},"text":"28 Stat. 601","children":[],"tail":", 612, "},{"tag":"ref","attrib":{"href":"/us/act/1907-03-01/ch2284/s1"},"text":"Mar. 1, 1907, ch. 2284, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1013"},"text":"34 Stat. 1013","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
