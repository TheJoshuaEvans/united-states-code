{"tag":"section","attrib":{"id":"id12279fb1-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1319"},"text":null,"children":[{"tag":"num","attrib":{"value":"1319"},"text":"§ 1319.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geological Survey: specific appropriations required for monographs and bulletins","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The scientific reports known as the monographs and bulletins of the Geological Survey may not be published until specific and detailed estimates and specific appropriations based on these estimates are made for them. Engravings for the annual reports for monographs and bulletins, or of illustrations, sections, and maps, may not be made until specific estimates are submitted and specific appropriations made based on the estimates.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12279fb2-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1269"},"text":"82 Stat. 1269","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12279fb3-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12279fb4-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 261 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s79"},"text":"Jan. 12, 1895, ch. 23, § 79","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/621"},"text":"28 Stat. 621","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1924-06-07/ch303"},"text":"June 7, 1924, ch. 303","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/592"},"text":"43 Stat. 592","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id12279fb5-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id12279fb6-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Geological Survey redesignated United States Geological Survey by provision of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/154"},"text":"Pub. L. 102–154","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s31"},"text":"section 31 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
