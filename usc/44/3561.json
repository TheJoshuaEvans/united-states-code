{"tag":"section","attrib":{"id":"id1259d301-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561"},"text":null,"children":[{"tag":"num","attrib":{"value":"3561"},"text":"§ 3561.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1259d302-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “agency” means any entity that falls within the definition of the term “executive agency”, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s102"},"text":"section 102 of title 31","children":[],"tail":", or “agency”, as defined in section 3502."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d303-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agent","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “agent” means an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1259d304-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1259d305-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is an employee of a private organization or a researcher affiliated with an institution of higher learning (including a person granted special sworn status by the Bureau of the Census under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t13/s23/c"},"text":"section 23(c) of title 13","children":[],"tail":"), and with whom a contract or other agreement is executed, on a temporary basis, by an executive agency to perform exclusively statistical activities under the control and supervision of an officer or employee of that agency;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1259d306-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is working under the authority of a government entity with which a contract or other agreement is executed by an executive agency to perform exclusively statistical activities under the control of an officer or employee of that agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1259d307-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a self-employed researcher, a consultant, a contractor, or an employee of a contractor, and with whom a contract or other agreement is executed by an executive agency to perform a statistical activity under the control of an officer or employee of that agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1259d308-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a contractor or an employee of a contractor, and who is engaged by the agency to design or maintain the systems for handling or storage of data received under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1259d309-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who agrees in writing to comply with all provisions of law that affect information acquired by that agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d30a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Business data","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “business data” means operating and financial data and information about businesses, tax-exempt organizations, and government entities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d30b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Data asset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “data asset” has the meaning given that term in section 3502.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d30c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Director” means the Director of the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d30d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evidence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “evidence” means information produced as a result of statistical activities conducted for a statistical purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d30e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Identifiable form","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “identifiable form” means any representation of information that permits the identity of the respondent to whom the information applies to be reasonably inferred by either direct or indirect means.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d30f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonstatistical purpose","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “nonstatistical purpose”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1259d310-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means the use of data in identifiable form for any purpose that is not a statistical purpose, including any administrative, regulatory, law enforcement, adjudicatory, or other purpose that affects the rights, privileges, or benefits of a particular identifiable respondent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1259d311-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" of data that are acquired for exclusively statistical purposes under a pledge of confidentiality."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d312-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Respondent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “respondent” means a person who, or organization that, is requested or required to supply information to an agency, is the subject of information requested or required to be supplied to an agency, or provides that information to an agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d313-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statistical activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “statistical activities”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1259d314-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means the collection, compilation, processing, or analysis of data for the purpose of describing or making estimates concerning the whole, or relevant groups or components within, the economy, society, or the natural environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1259d315-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the development of methods or resources that support those activities, such as measurement methods, models, statistical classifications, or sampling frames.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d316-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statistical agency or unit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “statistical agency or unit” means an agency or organizational unit of the executive branch whose activities are predominantly the collection, compilation, processing, or analysis of information for statistical purposes, as designated by the Director under section 3562.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d317-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statistical purpose","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “statistical purpose”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1259d318-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means the description, estimation, or analysis of the characteristics of groups, without identifying the individuals or organizations that comprise such groups; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1259d319-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3561/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the development, implementation, or maintenance of methods, technical or administrative procedures, or information resources that support the purposes described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1259d31a-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/435/tIII/s302/a"},"text":"Pub. L. 115–435, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5544"},"text":"132 Stat. 5544","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1259d31b-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1259d31c-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id1259d31d-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/435/s403"},"text":"section 403 of Pub. L. 115–435","children":[],"tail":", set out as an Effective Date of 2019 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s306"},"text":"section 306 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id1259d31e-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transitional and Savings Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/435/tIII/s302/d"},"text":"Pub. L. 115–435, title III, § 302(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5553"},"text":"132 Stat. 5553","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/435/tIII/s302/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cutoff date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This title [see Short Title of 2019 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s101"},"text":"section 101 of this title","children":[],"tail":"] replaces certain provisions of law enacted on "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"December 17, 2002","children":[],"tail":". If a law enacted after that date amends or repeals a provision replaced by this title, that law is deemed to amend or repeal, as the case may be, the corresponding provision enacted by this title. If a law enacted after that date is otherwise inconsistent with this title, it supersedes this title to the extent of the inconsistency."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Original date of enactment unchanged","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of determining whether one provision of law supersedes another based on enactment later in time, the date of the enactment of a provision enacted by this title is deemed to be the date of the enactment of the provision it replaced.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"References to provisions replaced","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A reference to a provision of law replaced by this title, including a reference in a regulation, order, or other law, is deemed to refer to the corresponding provision enacted by this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations, orders, and other administrative actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A regulation, order, or other administrative action in effect under a provision of law replaced by this title continues in effect under the corresponding provision enacted by this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions taken and offenses committed","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An action taken or an offense committed under a provision of law replaced by this title is deemed to have been taken or committed under the corresponding provision enacted by this title.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id1259d31f-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Guidance and Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/435/tIII/s303/c"},"text":"Pub. L. 115–435, title III, § 303(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5556"},"text":"132 Stat. 5556","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/435/tIII/s303/c"},"text":"“Not later than 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":"], the Director of the Office of Management and Budget shall promulgate or issue any regulation or guidance required by subchapter III of [chapter 35 of] title 44, United States Code, as amended by this section, with a requirement for such regulation or guidance to be implemented not later than 1 year after the date on which such regulation or guidance has been promulgated or issued.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
