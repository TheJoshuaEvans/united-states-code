{"tag":"section","attrib":{"id":"id1246bf9c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3308"},"text":null,"children":[{"tag":"num","attrib":{"value":"3308"},"text":"§ 3308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal of similar records where prior disposal was authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When it appears to the Archivist that an agency has in its custody, or is accumulating, records of the same form or character as those of the same agency previously authorized to be disposed of, he may empower the head of the agency to dispose of the records, after they have been in existence a specified period of time, in accordance with regulations promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3302"},"text":"section 3302 of this title","children":[],"tail":" and without listing or scheduling them."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id1246bf9d-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1301"},"text":"82 Stat. 1301","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/287/s2/a"},"text":"Pub. L. 91–287, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-23"},"text":"June 23, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/321"},"text":"84 Stat. 321","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s107/b/23"},"text":"Pub. L. 98–497, title I, § 107(b)(23)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2290"},"text":"98 Stat. 2290","child